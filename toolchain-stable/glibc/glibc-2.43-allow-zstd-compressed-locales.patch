   stream = fopen (pathname, "rm");
   if (stream != NULL)
     return stream;
 
+  /* Try compressed variants in fastest-decompressor-first order so the
+     common case (zstd, the new default install format) wins after one
+     failed open() of the uncompressed file.  Each memcpy includes the
+     terminating NUL so PATHNAME stays a valid C string for fopen.  */
+  memcpy (p, ".zst", 5);
+  stream = fopen_uncompressed (pathname, "zstd");
+  if (stream != NULL)
+    return stream;
+
   memcpy (p, ".gz", 4);
   stream = fopen_uncompressed (pathname, "gzip");
   if (stream != NULL)
     return stream;
 
   memcpy (p, ".bz2", 5);
   stream = fopen_uncompressed (pathname, "bzip2");
   if (stream != NULL)
     return stream;
 
