 endif
 tests-container = \
   tst-localedef-hardlinks \
   # tests-container
 
 # Files to install.
 ifeq ($(INSTALL_UNCOMPRESSED),yes)
 # This option is for testing inside the testroot container, as the
-# container does not include a working gunzip program.
+# container does not include a working gunzip / zstd program.
 install-others := $(addprefix $(inst_i18ndir)/, \
 			      $(charmaps) \
 			      $(locales))
 else
+# Install charmaps in zstd-compressed format.  zstd decompresses ~5x
+# faster than gzip while producing a slightly smaller payload at
+# --ultra -22, so the cost is paid once at "make install" time and
+# every consumer of the charmap pays less wall-time on every open.
 install-others := $(addprefix $(inst_i18ndir)/, \
-			      $(addsuffix .gz, $(charmaps)) \
+			      $(addsuffix .zst, $(charmaps)) \
 			      $(locales))
 endif
 
 tests: $(objdir)/iconvdata/gconv-modules
 
 tests-static += \
   tst-langinfo-newlocale-static \
   tst-langinfo-setlocale-static \
   # tests-static
 
@@ -424,26 +428,33 @@
 
 ifeq ($(INSTALL_UNCOMPRESSED),yes)
 # Install the charmap files as-is.  This option is for testing inside
 # the testroot container, as the container does not include a working
 # gunzip program.
 $(inst_i18ndir)/charmaps/%: charmaps/% $(+force)
 	$(make-target-directory)
 	rm -f $@
 	$(INSTALL_DATA) $< $@
 else
-# Install the charmap files in gzipped format.
-$(inst_i18ndir)/charmaps/%.gz: charmaps/% $(+force)
+# Install the charmap files in zstd-compressed format.
+# --ultra -22 maximises compression (install-time cost, decompressed
+# many times); -T0 lets the compressor use every available hardware
+# thread (very effective on modern many-core CPUs such as Raptor Lake
+# where charmap install is otherwise serial and CPU-bound); --no-progress
+# keeps build logs clean; -q silences the per-file banner.  zstd does
+# not embed a timestamp or source filename in the frame by default, so
+# the output is bit-for-bit reproducible without extra flags.
+$(inst_i18ndir)/charmaps/%.zst: charmaps/% $(+force)
 	$(make-target-directory)
-	rm -f $(@:.gz=) $@
-	$(INSTALL_DATA) $< $(@:.gz=)
-	gzip -9n $(@:.gz=)
+	rm -f $(@:.zst=) $@
+	$(INSTALL_DATA) $< $(@:.zst=)
+	zstd -q --no-progress -T0 --ultra -22 --rm $(@:.zst=)
 endif
 
 # Install the locale source files in the appropriate directory.
 $(inst_i18ndir)/locales/%: locales/% $(+force); $(do-install)
 
 ifeq ($(run-built-tests),yes)
 generated-dirs += $(LOCALES)
 
 $(addsuffix .out,$(addprefix $(objpfx),$(tests))): %: \
   $(addprefix $(objpfx),$(CTYPE_FILES))
--- a/locale/programs/charmap-dir.c
+++ b/locale/programs/charmap-dir.c
@@ -124,22 +124,26 @@
           if (stat64 (cdir->pathname, &statbuf) < 0)
             continue;
 
           mode = statbuf.st_mode;
         }
 
       if (!S_ISREG (mode))
         continue;
 
       /* For compressed charmaps, the canonical charmap name does not
-         include the extension.  */
-      if (len > 3 && memcmp (&filename[len - 3], ".gz", 3) == 0)
+         include the extension.  Order the checks from most-likely to
+         least-likely (zstd is the new default installed format) so the
+         common case takes a single 4-byte compare and short-circuits.  */
+      if (len > 4 && memcmp (&filename[len - 4], ".zst", 4) == 0)
+        filename[len - 4] = '\0';
+      else if (len > 3 && memcmp (&filename[len - 3], ".gz", 3) == 0)
         filename[len - 3] = '\0';
       else if (len > 4 && memcmp (&filename[len - 4], ".bz2", 4) == 0)
         filename[len - 4] = '\0';
 
       return filename;
     }
 }
 
 /* Finishes a charmap directory traversal, and frees the resources
    attached to the CHARMAP_DIR.  */
@@ -217,20 +221,29 @@
