    <https://www.gnu.org/licenses/>.  */
 
-#define NO_MATH_REDIRECT
-#include <config.h>
-#define dfmal __hide_dfmal
-#define f32xfmaf64 __hide_f32xfmaf64
-#include <math.h>
-#undef dfmal
-#undef f32xfmaf64
-#include <init-arch.h>
-#include <libm-alias-double.h>
-#include <math-narrow-alias.h>
+#include <sysdeps/x86/isa-level.h>
+#if MINIMUM_X86_ISA_LEVEL < AVX2_X86_ISA_LEVEL
+/* The IFUNC dispatcher is only needed for builds that may run on
+   pre-FMA hardware.  When the build targets x86-64-v3 or higher, FMA
+   is guaranteed at run time, the per-TU USE_FMA_BUILTIN selector in
+   sysdeps/x86_64/fpu/math-use-builtins-fma.h sees __FMA__ and the
+   generic dbl-64/s_fma.c collapses to a single __builtin_fma -> one
+   vfmadd213sd.  In that case we fall straight through to the
+   #include below so __fma is emitted as a 6-byte leaf with no IFUNC
+   resolver indirection at all.  This mirrors how e_sinh.c et al.
+   handle the same situation upstream.  */
+
+# define NO_MATH_REDIRECT
+# include <config.h>
+# define dfmal __hide_dfmal
+# define f32xfmaf64 __hide_f32xfmaf64
+# include <math.h>
+# undef dfmal
+# undef f32xfmaf64
+# include <init-arch.h>
+# include <libm-alias-double.h>
+# include <math-narrow-alias.h>
 
 extern double __fma_sse2 (double x, double y, double z) attribute_hidden;
 
 
 static double
 __fma_fma3 (double x, double y, double z)
 {
   asm ("vfmadd213sd %3, %2, %0" : "=x" (x) : "0" (x), "x" (y), "xm" (z));
   return x;
 }
@@ -45,13 +57,14 @@
   return x;
 }
 
 
 libm_ifunc (__fma, CPU_FEATURE_USABLE (FMA)
 	    ? __fma_fma3 : (CPU_FEATURE_USABLE (FMA4)
 			    ? __fma_fma4 : __fma_sse2));
 libm_alias_double (__fma, fma)
 libm_alias_double_narrow (__fma, fma)
 
-#define __fma __fma_sse2
+# define __fma __fma_sse2
+#endif /* MINIMUM_X86_ISA_LEVEL < AVX2_X86_ISA_LEVEL  */
 
 #include <sysdeps/ieee754/dbl-64/s_fma.c>
--- a/sysdeps/x86_64/fpu/multiarch/s_fmaf.c
+++ b/sysdeps/x86_64/fpu/multiarch/s_fmaf.c
@@ -9,25 +9,33 @@
 
    The GNU C Library is distributed in the hope that it will be useful,
    but WITHOUT ANY WARRANTY; without even the implied warranty of
    MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
    Lesser General Public License for more details.
 
    You should have received a copy of the GNU Lesser General Public
    License along with the GNU C Library; if not, see
    <https://www.gnu.org/licenses/>.  */
 
-#define NO_MATH_REDIRECT
-#include <config.h>
-#include <math.h>
-#include <init-arch.h>
-#include <libm-alias-float.h>
+#include <sysdeps/x86/isa-level.h>
+#if MINIMUM_X86_ISA_LEVEL < AVX2_X86_ISA_LEVEL
+/* See sysdeps/x86_64/fpu/multiarch/s_fma.c for the rationale of the
+   ISA-level guard.  On x86-64-v3 and higher, __FMA__ is defined, the
+   per-TU USE_FMAF_BUILTIN selector picks __builtin_fmaf, the generic
+   dbl-64/s_fmaf.c collapses to a single vfmadd213ss, and the IFUNC
+   dispatcher below is unnecessary.  */
+
+# define NO_MATH_REDIRECT
+# include <config.h>
+# include <math.h>
+# include <init-arch.h>
+# include <libm-alias-float.h>
 
 extern float __fmaf_sse2 (float x, float y, float z) attribute_hidden;
 
 
 static float
 __fmaf_fma3 (float x, float y, float z)
 {
   asm ("vfmadd213ss %3, %2, %0" : "=x" (x) : "0" (x), "x" (y), "xm" (z));
   return x;
 }
@@ -39,13 +47,14 @@
   asm ("vfmaddss %3, %2, %1, %0" : "=x" (x) : "x" (x), "x" (y), "x" (z));
   return x;
 }
 
 
 libm_ifunc (__fmaf, CPU_FEATURE_USABLE (FMA)
 	    ? __fmaf_fma3 : (CPU_FEATURE_USABLE (FMA4)
 			     ? __fmaf_fma4 : __fmaf_sse2));
 libm_alias_float (__fma, fma)
 
-#define __fmaf __fmaf_sse2
+# define __fmaf __fmaf_sse2
+#endif /* MINIMUM_X86_ISA_LEVEL < AVX2_X86_ISA_LEVEL  */
 
 #include <sysdeps/ieee754/dbl-64/s_fmaf.c>
--- a/sysdeps/x86_64/fpu/math-use-builtins-fma.h
+++ b/sysdeps/x86_64/fpu/math-use-builtins-fma.h
@@ -0,0 +1,46 @@
