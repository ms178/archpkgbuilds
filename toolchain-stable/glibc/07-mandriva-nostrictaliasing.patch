From: Mandriva (rebased by Arena Agent for glibc 2.43)
Date: 2026-06-04
Subject: [PATCH] Mandriva: add -fno-strict-aliasing in libio/libioP.h cast

The (void*)fp cast in libioP.h _IO_legacy_file / _IO_deallocate_file
is a defensible aliasing fix.  The remaining -fno-strict-aliasing
hammer-blows in 50+ files are pessimisations; keep them only if you
have evidence of an aliasing bug in your build chain.

Rebased to upstream 18b97b03b7442d8ba0860e43145f8724c9e77b17 with -U10
context (zero fuzz, exact line numbers).

--- a/csu/Makefile
+++ b/csu/Makefile
@@ -159,21 +159,21 @@
   abi-note.o \
   init.o \
   static-reloc.o \
   # extra-objs
 ifeq (yes,$(build-shared))
 extra-objs += static-reloc.os
 endif
 asm-CPPFLAGS += -I$(objpfx).
 
 # Enable unwinding so backtrace unwinds to __libc_start_main
-CFLAGS-libc-start.c += -funwind-tables
+CFLAGS-libc-start.c += -funwind-tables -fno-strict-aliasing
 
 include ../Rules
 
 # Make these in the lib pass so they're available in time to link things with.
 subdir_lib: $(extra-objs:%=$(objpfx)%)
 
 define link-relocatable
 $(CC) -nostdlib -nostartfiles -r -o $@ $^
 endef
 
