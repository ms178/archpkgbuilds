From: Adhemerval Zanella <adhemerval.zanella@linaro.org>
Date: Thu, 12 Mar 2026 11:21:11 -0300
Subject: [PATCH] x86_64: Add cosh with FMA

The cosh shows an improvement of about ~35% when building for
x86_64-v3.

Reviewed-by: DJ Delorie <dj@redhat.com>
---
 sysdeps/ieee754/dbl-64/e_cosh.c           | 13 +++++--
 sysdeps/x86_64/fpu/multiarch/Makefile     |  2 ++
 sysdeps/x86_64/fpu/multiarch/e_cosh-fma.c |  5 +++
 sysdeps/x86_64/fpu/multiarch/e_cosh.c     | 44 +++++++++++++++++++++++
 4 files changed, 61 insertions(+), 3 deletions(-)
 create mode 100644 sysdeps/x86_64/fpu/multiarch/e_cosh-fma.c
 create mode 100644 sysdeps/x86_64/fpu/multiarch/e_cosh.c

diff --git a/sysdeps/ieee754/dbl-64/e_cosh.c b/sysdeps/ieee754/dbl-64/e_cosh.c
index f9008e6e5f..4cfaf9ea59 100644
--- a/sysdeps/ieee754/dbl-64/e_cosh.c
+++ b/sysdeps/ieee754/dbl-64/e_cosh.c
@@ -1,6 +1,7 @@
 /*
  * ====================================================
- * Copyright (C) 1993 by Sun Microsystems, Inc. All rights reserved.
+ * Copyright (C) 1993 by Sun Microsystems, Inc.
+ * All rights reserved.
  *
  * Developed at SunPro, a Sun Microsystems, Inc. business.
  * Permission to use, copy, modify, and distribute this
@@ -10,76 +11,169 @@
  */
 
 /* __ieee754_cosh(x)
- * Method :
- * mathematically cosh(x) if defined to be (exp(x)+exp(-x))/2
- *	1. Replace x by |x| (cosh(x) = cosh(-x)).
- *	2.
- *							[ exp(x) - 1 ]^2
- *	    0        <= x <= ln2/2  :  cosh(x) := 1 + -------------------
- *							   2*exp(x)
+ * Method:
+ * mathematically cosh(x) if defined to be (exp(x) + exp(-x)) / 2
+ *  1. Replace x by |x| (cosh(x) = cosh(-x)).
+ *  2.
+ *                                [ exp(x) - 1 ]^2
+ *     0        <= x <= ln2/2  :  cosh(x) := 1 + -------------------
+ *                                           2 * exp(x)
  *
- *						  exp(x) +  1/exp(x)
- *	    ln2/2    <= x <= 22     :  cosh(x) := -------------------
- *							  2
- *	    22       <= x <= lnovft :  cosh(x) := exp(x)/2
- *	    lnovft   <= x <= ln2ovft:  cosh(x) := exp(x/2)/2 * exp(x/2)
- *	    ln2ovft  <  x	    :  cosh(x) := huge*huge (overflow)
+ *                                exp(x) + 1 / exp(x)
+ *     ln2/2    <= x <= 22     :  cosh(x) := -----------------------
+ *                                           2
+ *     22       <= x <= lnovft :  cosh(x) := exp(x) / 2
+ *     lnovft   <= x <= ln2ovft:
+ *                                cosh(x) := exp(x/2) / 2 * exp(x/2)
+ *     ln2ovft  <  x           :  cosh(x) := huge * huge (overflow)
  *
  * Special cases:
- *	cosh(x) is |x| if x is +INF, -INF, or NaN.
- *	only cosh(0)=1 is exact for finite x.
+ *  cosh(x) is |x| if x is +INF, -INF, or NaN.
+ *  only cosh(0) = 1 is exact for finite x.
+ *
+ * This file may also be included by architecture-specific wrappers.
+ * If __cosh is predefined by the includer, emit that symbol name
+ * instead of the default __ieee754_cosh, and suppress public aliases.
  */
 
 #include <math.h>
+#include <stdint.h>
 #include <math_private.h>
 #include <math-narrow-eval.h>
 #include <libm-alias-finite.h>
 
-static const double one = 1.0, half=0.5, huge = 1.0e300;
+#ifndef SECTION
+# define SECTION
+#endif
+
+#ifndef __cosh
+# define __glibc_cosh_impl __ieee754_cosh
+#else
+# define __glibc_cosh_impl __cosh
+#endif
+
+static const double one = 1.0;
+static const double half = 0.5;
+static const double huge = 1.0e300;
+
+#define COSH_ABS_MASK   UINT64_C (0x7fffffffffffffff)
+#define COSH_TINY_HI    UINT32_C (0x3c800000)
+#define COSH_QUAD_HI    UINT32_C (0x3e400000)
+#define COSH_SMALL_HI   UINT32_C (0x3fd62e43)
+#define COSH_MEDIUM_HI  UINT32_C (0x40360000)
+#define COSH_LOGMAX_HI  UINT32_C (0x40862e42)
+#define COSH_OVF_BITS   UINT64_C (0x408633ce8fb9f87d)
+
+/* For 2^-55 <= |x| < 2^-27, 1 + x^2 / 2 is safely correctly rounded for
+   binary64 and avoids a costly expm1 call.  */
+static inline double
+cosh_tiny_quadratic (double ax)
+{
+#if defined __FMA__
+  return __builtin_fma (half * ax, ax, one);
+#else
+  return one + (half * ax) * ax;
+#endif
+}
+
+/* Small-argument core:
+   cosh(x) = 1 + t^2 / (2 * (1 + t)), where t = expm1(|x|).
+
+   In an FMA-enabled build, use one explicit fused operation to shorten
+   the dependency chain and reduce one rounding step.  */
+static inline double
+cosh_small_expm1_core (double t)
+{
+  double w = one + t;
+
+#if defined __FMA__
+  double q = t / w;
+  return __builtin_fma (half * t, q, one);
+#else
+  return one + (t * t) / (w + w);
+#endif
+}
+
+/* Rare tail for |x| >= high-word(log(maxdouble)).  Keep it out of the
+   hot path to reduce code size and front-end pressure.  */
+static __attribute__ ((cold, noinline)) double
+cosh_overflow_path (double x)
+{
+  int64_t fix;
+  uint64_t ax_bits;
+  double ax;
+  double w;
+  double t;
+
+  EXTRACT_WORDS64 (fix, x);
+  ax_bits = (uint64_t) fix & COSH_ABS_MASK;
+
+  if (ax_bits <= COSH_OVF_BITS)
+    {
+      ax = fabs (x);
+      w = __ieee754_exp (half * ax);
+      t = half * w;
+      return t * w;
+    }
 
+  return math_narrow_eval (huge * huge);
+}
+
+SECTION
 double
-__ieee754_cosh (double x)
+__glibc_cosh_impl (double x)
 {
-	double t,w;
-	int32_t ix;
+  int32_t hx;
+  uint32_t ix;
 
-    /* High word of |x|. */
-	GET_HIGH_WORD(ix,x);
-	ix &= 0x7fffffff;
-
-    /* |x| in [0,22] */
-	if (ix < 0x40360000) {
-	    /* |x| in [0,0.5*ln2], return 1+expm1(|x|)^2/(2*exp(|x|)) */
-		if(ix<0x3fd62e43) {
-		    if (ix<0x3c800000)			/* cosh(tiny) = 1 */
-		      return one;
-		    t = __expm1(fabs(x));
-		    w = one+t;
-		    return one+(t*t)/(w+w);
-		}
-
-	    /* |x| in [0.5*ln2,22], return (exp(|x|)+1/exp(|x|)/2; */
-		t = __ieee754_exp(fabs(x));
-		return half*t+half/t;
-	}
-
-    /* |x| in [22, log(maxdouble)] return half*exp(|x|) */
-	if (ix < 0x40862e42)  return half*__ieee754_exp(fabs(x));
-
-    /* |x| in [log(maxdouble), overflowthresold] */
-	int64_t fix;
-	EXTRACT_WORDS64(fix, x);
-	fix &= UINT64_C(0x7fffffffffffffff);
-	if (fix <= UINT64_C(0x408633ce8fb9f87d)) {
-	    w = __ieee754_exp(half*fabs(x));
-	    t = half*w;
-	    return t*w;
-	}
+  GET_HIGH_WORD (hx, x);
+  ix = (uint32_t) hx & UINT32_C (0x7fffffff);
 
-    /* x is INF or NaN */
-	if(ix>=0x7ff00000) return x*x;
+  /* x is INF or NaN.  Preserve historical behavior.  */
+  if (__builtin_expect (ix >= UINT32_C (0x7ff00000), 0))
+    return x * x;
+
+  /* |x| in [0, 0.5 * ln2).  */
+  if (ix < COSH_SMALL_HI)
+    {
+      double ax;
+
+      if (ix < COSH_TINY_HI)
+        return one;
+
+      ax = fabs (x);
+
+      if (ix < COSH_QUAD_HI)
+        return cosh_tiny_quadratic (ax);
+
+      return cosh_small_expm1_core (__expm1 (ax));
+    }
+
+  /* |x| in [0.5 * ln2, 22).  */
+  if (ix < COSH_MEDIUM_HI)
+    {
+      double ax = fabs (x);
+      double t = __ieee754_exp (ax);
+      return half * t + half / t;
+    }
+
+  /* |x| in [22, log(maxdouble)).  */
+  if (ix < COSH_LOGMAX_HI)
+    return half * __ieee754_exp (fabs (x));
 
-    /* |x| > overflowthresold, cosh(x) overflow */
-	return math_narrow_eval (huge * huge);
+  /* |x| in [log(maxdouble), overflow threshold] or overflow.  */
+  return cosh_overflow_path (x);
 }
+
+#ifndef __cosh
 libm_alias_finite (__ieee754_cosh, __cosh)
+#endif
+
+#undef __glibc_cosh_impl
+#undef COSH_ABS_MASK
+#undef COSH_TINY_HI
+#undef COSH_QUAD_HI
+#undef COSH_SMALL_HI
+#undef COSH_MEDIUM_HI
+#undef COSH_LOGMAX_HI
+#undef COSH_OVF_BITS
