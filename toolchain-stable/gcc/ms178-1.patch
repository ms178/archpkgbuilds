diff --git a/gcc/config/i386/driver-i386.cc b/gcc/config/i386/driver-i386.cc
index c7fb27769..d09f07e23 100644
--- a/gcc/config/i386/driver-i386.cc
+++ b/gcc/config/i386/driver-i386.cc
@@ -289,51 +289,92 @@ static void
 detect_caches_cpuid4 (struct cache_desc *level1, struct cache_desc *level2,
 		      struct cache_desc *level3)
 {
-  struct cache_desc *cache;
-
   unsigned eax, ebx, ecx, edx;
-  int count;
 
-  for (count = 0;; count++)
+  for (unsigned count = 0;; count++)
     {
-      __cpuid_count(4, count, eax, ebx, ecx, edx);
-      switch (eax & 0x1f)
-	{
-	case CACHE_END:
-	  return;
-	case CACHE_DATA:
-	case CACHE_UNIFIED:
-	  {
-	    switch ((eax >> 5) & 0x07)
-	      {
-	      case 1:
-		cache = level1;
-		break;
-	      case 2:
-		cache = level2;
-		break;
-	      case 3:
-		cache = level3;
-		break;
-	      default:
-		cache = NULL;
-	      }
+      __cpuid_count (4, count, eax, ebx, ecx, edx);
 
-	    if (cache)
-	      {
-		unsigned sets = ecx + 1;
-		unsigned part = ((ebx >> 12) & 0x03ff) + 1;
+      unsigned type = eax & 0x1f;
+      if (type == CACHE_END)
+	return;
 
-		cache->assoc = ((ebx >> 22) & 0x03ff) + 1;
-		cache->line = (ebx & 0x0fff) + 1;
+      if (type != CACHE_DATA && type != CACHE_UNIFIED)
+	continue;
 
-		cache->sizekb = (cache->assoc * part
-				 * cache->line * sets) / 1024;
-	      }
-	  }
+      struct cache_desc *cache = NULL;
+      switch ((eax >> 5) & 0x07)
+	{
+	case 1:
+	  cache = level1;
+	  break;
+	case 2:
+	  cache = level2;
+	  break;
+	case 3:
+	  cache = level3;
+	  break;
 	default:
 	  break;
 	}
+
+      if (!cache)
+	continue;
+
+      unsigned line = (ebx & 0x0fff) + 1;
+      unsigned part = ((ebx >> 12) & 0x03ff) + 1;
+      unsigned ways = ((ebx >> 22) & 0x03ff) + 1;
+      unsigned sets = ecx + 1;
+
+      unsigned long long sizekb_ull
+	= ((unsigned long long) ways * part * line * sets) / 1024;
+      if (sizekb_ull == 0 || sizekb_ull > (unsigned) -1)
+	continue;
+
+      unsigned sizekb = (unsigned) sizekb_ull;
+
+      /* Prefer the largest descriptor for a given cache level.  This is
+	 robust for heterogeneous enumeration and harmless for homogeneous
+	 processors, where descriptors for a cache level should agree.  */
+      if (sizekb > cache->sizekb)
+	{
