# Maintainer: ms178
#
# llvm-mingw-ms178 --- NTULINUX-style llvm-mingw pinned to a specific
# upstream LLVM tag (22.1.8), built fully from source with our fish recipe.
# Preserves the NTULINUX optimizations (ThinLTO, Polly, static everything,
# ucrt, Win10 target) and additionally builds host binaries with
# -march=native so the toolchain is tuned to the packager's CPU.
#
# Everything happens under /tmp/llvm-mingw-ms178-build-$pkgver (survives
# PKGBUILD runs; bump `pkgver` or `rm -rf /tmp/llvm-mingw-ms178-build-*`
# to reset).
#
# Ships the full toolchain to /opt/llvm-mingw. The package name is
# llvm-mingw-ms178 (so it can coexist as an alternative to other
# llvm-mingw variants in your local repo), but the install prefix is
# the plain /opt/llvm-mingw that ms178's per-shell `export PATH=...`
# already points at. Nothing goes on system $PATH automatically:
# proton-cachyos and other builds that need the host clang stay
# unaffected. Enable per-shell yourself:
#     export PATH=/opt/llvm-mingw/bin:$PATH
# or per-project via .envrc.

pkgname=llvm-mingw-ms178
# llvm-project pinned to a specific main-branch commit (see the fish
# recipe for the rationale --- ms178's Unix toolchain uses the same
# commit and the patches were rebased on it).
_llvmver=22.99.0-92f01b2   # snapshot commit ahead of llvmorg-22.1.8
_llvmref=4d5856669efa7a1271d2f5201bb3ebf32420ffde
_mingwrev=master           # mingw-w64 git ref (upstream tracks master)
pkgver=${_llvmver//-/.}    # pkgver may not contain '-'; use dot as separator
pkgrel=1
pkgdesc='LLVM-based MinGW-w64 toolchain (UCRT, Win10, ThinLTO+Polly, -march=native, NTULINUX recipe + ms178 perf patches)'
url='https://github.com/NTULINUX/llvm-mingw'
license=('MIT' 'Apache-2.0 WITH LLVM-exception')
arch=('x86_64')

# Runtime deps -- the toolchain is statically linked to LLVM but the driver
# binaries still dlopen/link a few small system libs.
depends=('glibc' 'gcc-libs' 'zlib' 'zstd' 'libxml2' 'ncurses')

# Host-side build deps
makedepends=(
    'git' 'cmake' 'ninja' 'fish' 'python' 'autoconf' 'automake' 'libtool'
    'texinfo' 'pkgconf' 'clang' 'lld' 'llvm'
)

# conflicts=(): only real ones. Other llvm-mingw variants would collide
# on /opt/llvm-mingw (the -bin package uses the plain name) or on the
# provides='llvm-mingw' virtual, so they stay. mingw-w64-gcc is NOT a
# conflict --- it lives under /usr/{bin,lib}/*-w64-mingw32-* and shares
# no file paths with our /opt/llvm-mingw-ms178/ tree; and since we
# deliberately don't install a profile.d snippet, our binaries never
# hijack `$PATH` either. The two toolchains coexist cleanly.
conflicts=('llvm-mingw' 'llvm-mingw-git' 'llvm-mingw-bin')
provides=("llvm-mingw=${pkgver}" "${pkgname}=${pkgver}")

# Skip Arch's post-processing that doesn't apply to a mixed-target toolchain:
#   !strip       -- fish recipe already strips LLVM, and PE stripping is
#                   done by mingw's `make install-strip`
#   !debug       -- we don't want a debug-package split for a toolchain
#   !lto         -- we manage LTO ourselves (ThinLTO inside CMake)
#   !buildflags  -- prevents makepkg.conf's CFLAGS/CXXFLAGS/LDFLAGS from
#                   fighting our -march=native + ThinLTO setup. We set
#                   sane flags explicitly in build() below.
#   !makeflags   -- we compute -j ourselves from MAKEFLAGS
options=('!strip' '!debug' '!lto' '!buildflags' '!makeflags')

# NOTE ON source=():
#   makepkg treats any entry containing "/" as a remote URL, so we can't
#   list "wrappers/foo.cfg" here. Instead we keep the wrappers/ directory
#   inside the PKGBUILD repo and copy it from $startdir at prepare() time.
#   Only the top-level fish recipe is registered as a source (it's needed
#   before build() and lives at the PKGBUILD's own level).
source=("build-llvm-mingw-22.1.8.fish")
sha256sums=('SKIP')

# ---------------------------------------------------------------------------
# Build layout under /tmp (~30 GB free needed for the ThinLTO link phase).
# ---------------------------------------------------------------------------
_workroot="/tmp/${pkgname}-build-${_llvmver}"
_stagedir="${_workroot}/stage/llvm-mingw"    # basename == final install dir
_tarout="${_workroot}/dist"
_installprefix="/opt/llvm-mingw"             # NOT /opt/${pkgname};
                                             # ms178 already has this on
                                             # his shell's PATH.

prepare() {
    cd "${srcdir}"

    # -----------------------------------------------------------------------
    # Pull the wrappers/ directory in from $startdir (the PKGBUILD's own
    # directory) so the fish recipe sees the layout it expects.
    # -----------------------------------------------------------------------
    if [[ ! -d "${startdir}/wrappers" ]]; then
        error "wrappers/ directory not found next to PKGBUILD at ${startdir}"
        return 1
    fi
    install -dm755 wrappers
    install -m755 "${startdir}/wrappers/clang-target-wrapper.sh"    wrappers/
    install -m755 "${startdir}/wrappers/ld-wrapper.sh"              wrappers/
    install -m755 "${startdir}/wrappers/objdump-wrapper.sh"         wrappers/
    install -m644 "${startdir}/wrappers/i686-w64-windows-gnu.cfg"   wrappers/
    install -m644 "${startdir}/wrappers/x86_64-w64-windows-gnu.cfg" wrappers/

    # -----------------------------------------------------------------------
    # Same story for patches/: the ms178 perf patch set lives next to the
    # PKGBUILD and gets staged into $_workroot so the fish recipe's
    # stage_patch can find it.
    # -----------------------------------------------------------------------
    if [[ ! -d "${startdir}/patches" ]]; then
        error "patches/ directory not found next to PKGBUILD at ${startdir}"
        return 1
    fi
    install -dm755 patches
    local _p
    for _p in "${startdir}/patches"/*.patch; do
        install -m644 "${_p}" patches/
    done

    chmod +x build-llvm-mingw-22.1.8.fish

    # -----------------------------------------------------------------------
    # NOTE: No /etc/profile.d snippet is generated. See the header comment
    # for the rationale (proton-cachyos and similar builds break when a
    # cross toolchain is on PATH globally). Users opt in per-shell.
    # -----------------------------------------------------------------------

    # -----------------------------------------------------------------------
    # Reset any leftover build state from previous PKGBUILD runs, but keep
    # source checkouts in $_workroot/src (they take minutes to re-fetch).
    # -----------------------------------------------------------------------
    mkdir -p "${_workroot}"
    rm -rf  "${_stagedir}" "${_tarout}"
    mkdir -p "${_stagedir}" "${_tarout}"

    # Stage the recipe + wrappers + patches into $_workroot so the script's
    # WORKROOT-first lookups find them.
    install -m755 build-llvm-mingw-22.1.8.fish "${_workroot}/"
    rm -rf "${_workroot}/wrappers" "${_workroot}/patches"
    cp -a wrappers "${_workroot}/wrappers"
    cp -a patches  "${_workroot}/patches"
}

build() {
    cd "${_workroot}"

    # -----------------------------------------------------------------------
    # Override makepkg.conf CFLAGS/CXXFLAGS/LDFLAGS with our own sane set.
    # !buildflags in options=() already stops makepkg from injecting its
    # own; we explicitly export the flags we want so any deeper autotools
    # invocation inside the fish recipe (mingw-w64 configure, gendef,
    # widl, winpthreads) inherits a consistent, optimized environment.
    #
    # We do NOT set these for the Windows-cross CMake builds
    # (compiler-rt/libcxx/openmp): the fish recipe intentionally clears CC
    # around those stages so CMake uses per-target defaults. Setting
    # CFLAGS here doesn't leak into cross builds because our fish recipe
    # calls `set -e CFLAGS` before spinning up cross toolchains.
    # -----------------------------------------------------------------------
    local _common_flags='-O3 -march=native -mtune=native -pipe -fno-plt -fno-semantic-interposition -fprofile-use=/home/marcus/Downloads/llvm.profdata'
    export CFLAGS="${_common_flags}"
    export CXXFLAGS="${_common_flags}"
    export CPPFLAGS='-D_FORTIFY_SOURCE=0'   # we build clang, not sanitized apps
    export LDFLAGS='-Wl,-O1 -Wl,--as-needed -fuse-ld=lld -fprofile-use=/home/marcus/Downloads/llvm.profdata'
    export ASFLAGS=''
    # Prefer clang/lld for autotools bits (mingw configure, tools).
    export CC='clang'
    export CXX='clang++'
    export LD='ld.lld'
    export AR='llvm-ar'
    export RANLIB='llvm-ranlib'
    export NM='llvm-nm'
    export STRIP='llvm-strip'
    unset MAKEFLAGS   # we pass -j via the fish env explicitly
    unset LTOFLAGS

    # -----------------------------------------------------------------------
    # Parallelism: honor makepkg.conf's MAKEFLAGS but cap link jobs at 8 to
    # avoid OOM during ThinLTO link.
    # -----------------------------------------------------------------------
    local _jobs
    _jobs="$(nproc)"
    if [[ -n "${MAKEFLAGS_ORIG:-}" ]]; then
        # (MAKEFLAGS was unset above; the user can override with MAKEFLAGS_ORIG)
        local _tmp="${MAKEFLAGS_ORIG#*-j}"
        _jobs="${_tmp%% *}"
        [[ -z "${_jobs//[0-9]/}" && -n "${_jobs}" ]] || _jobs="$(nproc)"
    fi

    # -----------------------------------------------------------------------
    # Hand off to the fish recipe. `all` runs every stage in order.
    #   HOST_MARCH stays "native" (default). Set NO_NATIVE=1 for portable
    #   x86-64-v3. Set NO_LTO=1 for a faster smoke build without ThinLTO.
    # -----------------------------------------------------------------------
    export WORKROOT="${_workroot}"
    export JOBS="${_jobs}"
    export LINK_JOBS="$(( _jobs > 8 ? 8 : _jobs ))"
    export TARBALL_OUT="${_tarout}"

    msg2 "Building ${pkgname} ${_llvmver} in ${_workroot}"
    msg2 "  JOBS=${JOBS}  LINK_JOBS=${LINK_JOBS}"
    msg2 "  CFLAGS=${CFLAGS}"
    msg2 "  LDFLAGS=${LDFLAGS}"

    fish "${_workroot}/build-llvm-mingw-22.1.8.fish" "${_stagedir}"
}

package() {
    # Everything is already installed under $_stagedir by the fish recipe.
    # Relocate it under $pkgdir/opt/llvm-mingw. Nothing goes on system
    # $PATH: activate per-shell with `export PATH=/opt/llvm-mingw/bin:$PATH`.
    install -dm755 "${pkgdir}${_installprefix}"
    cp -a "${_stagedir}/." "${pkgdir}${_installprefix}/"

    # LLVM's own license (installed by the fish recipe at $prefix/LICENSE.TXT)
    if [[ -f "${pkgdir}${_installprefix}/LICENSE.TXT" ]]; then
        install -Dm644 "${pkgdir}${_installprefix}/LICENSE.TXT" \
            "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.TXT"
    fi

    # The mingw-w64 headers/CRT/winpthreads COPYING files live under
    # $prefix/{i686,x86_64}-w64-mingw32/share/mingw32/ already; leave them
    # in place for reference.
}
