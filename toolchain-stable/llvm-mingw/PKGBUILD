# Maintainer: ms178
# URL: https://github.com/NTULINUX/llvm-mingw

pkgname=llvm-mingw
pkgver=04192026
pkgrel=1
pkgdesc="LLVM-based MinGW-w64 toolchain using UCRT (NTULINUX optimized, x86-64-v3)"
url="https://github.com/NTULINUX/llvm-mingw"
license=('MIT')
arch=('x86_64')
depends=('glibc' 'gcc-libs' 'zlib')
conflicts=("${pkgname}-git")
options=('!strip' '!debug')

source=("https://github.com/NTULINUX/${pkgname}/releases/download/${pkgver}/${pkgname}-${pkgver}-ucrt-fc43-x86-64-v3.tar.xz")
sha256sums=('SKIP')

package() {
  install -dm755 "${pkgdir}/opt/${pkgname}"

  # Copy whatever top-level directory the tarball actually extracted to,
  # regardless of its name.
  cp -a "${srcdir}"/*/. "${pkgdir}/opt/${pkgname}/"
