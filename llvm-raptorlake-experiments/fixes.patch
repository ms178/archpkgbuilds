+static unsigned saturatingAddToUnsigned(unsigned Accum, size_t Delta) {
+  const size_t MaxAdditional = static_cast<size_t>(~0u - Accum);
+  if (Delta > MaxAdditional)
+    return ~0u;
+  return Accum + static_cast<unsigned>(Delta);
+}
