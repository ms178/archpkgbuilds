From a8845dfd869c31fe4596fd436baaf405cb1e8f7f Mon Sep 17 00:00:00 2001
From: Justin Lebar <justin.lebar@gmail.com>
Date: Thu, 21 May 2026 21:32:39 -0700
Subject: [PATCH] [CodeGenPrepare] Null-check PSI in _run

CodeGenPreparePass doesn't declare ProfileSummaryAnalysis as required,
so PSI is null when the pass is invoked through opt -passes=codegenprepare.
Two call sites in _run dereferenced it unconditionally and segfaulted
on any input module.

Fix for https://github.com/llvm/llvm-project/issues/173360.

This bug was found by a large run of Opus 4.7 looking for bugs in LLVM.
---
 llvm/lib/CodeGen/CodeGenPrepare.cpp                    |  5 +++--
 .../Transforms/CodeGenPrepare/X86/null-psi-no-crash.ll | 10 ++++++++++
 2 files changed, 13 insertions(+), 2 deletions(-)
 create mode 100644 llvm/test/Transforms/CodeGenPrepare/X86/null-psi-no-crash.ll

diff --git a/llvm/lib/CodeGen/CodeGenPrepare.cpp b/llvm/lib/CodeGen/CodeGenPrepare.cpp
index 74a0502d8cb7c..ba0fbac17d25c 100644
--- a/llvm/lib/CodeGen/CodeGenPrepare.cpp
+++ b/llvm/lib/CodeGen/CodeGenPrepare.cpp
@@ -587,7 +587,7 @@ bool CodeGenPrepare::_run(Function &F) {
   if (BBSectionsGuidedSectionPrefix && BBSectionsProfileReader &&
       BBSectionsProfileReader->isFunctionHot(F.getName())) {
     (void)F.setSectionPrefix("hot");
-  } else if (ProfileGuidedSectionPrefix) {
+  } else if (ProfileGuidedSectionPrefix && PSI) {
     // The hot attribute overwrites profile count based hotness while profile
     // counts based hotness overwrite the cold attribute.
     // This is a conservative behabvior.
@@ -607,7 +607,8 @@ bool CodeGenPrepare::_run(Function &F) {
 
   /// This optimization identifies DIV instructions that can be
   /// profitably bypassed and carried out with a shorter, faster divide.
-  if (!OptSize && !PSI->hasHugeWorkingSetSize() && TLI->isSlowDivBypassed()) {
+  if (!OptSize && PSI && !PSI->hasHugeWorkingSetSize() &&
+      TLI->isSlowDivBypassed()) {
     const DenseMap<unsigned int, unsigned int> &BypassWidths =
         TLI->getBypassSlowDivWidths();
     BasicBlock *BB = &*F.begin();
