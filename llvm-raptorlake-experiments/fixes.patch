+      Estimated = saturatingAddToUnsigned(
+          Estimated, FS->type_checked_load_vcalls().size());
+      Estimated = saturatingAddToUnsigned(
+          Estimated, FS->type_test_assume_const_vcalls().size());
+      Estimated = saturatingAddToUnsigned(
