+test_program "inline asm percent clobber" '
+#include <stdio.h>
+static int clobber_test(int in) {
+    int out = -1;
+#if defined(__x86_64__)
+    asm volatile (
+        "mov %1, %0\n\t"
+        "mov $99, %%ecx"
+        : "=&r"(out)
+        : "r"(in)
+        : "%rcx");
+#elif defined(__i386__)
+    asm volatile (
+        "mov %1, %0\n\t"
+        "mov $99, %%ecx"
+        : "=&r"(out)
+        : "r"(in)
+        : "%ecx");
+#else
+    out = in;
+#endif
+    return out;
+}
+int main() { printf("%d\n", clobber_test(7)); return 0; }
+'
