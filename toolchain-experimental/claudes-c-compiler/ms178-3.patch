diff --git a/.github/workflows/ccc-validation.yml b/.github/workflows/ccc-validation.yml
new file mode 100644
index 0000000..967c105
--- /dev/null
+++ b/.github/workflows/ccc-validation.yml
@@ -0,0 +1,97 @@
+name: CCC Validation
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+    branches: [main]
+
+permissions:
+  contents: read
+
+jobs:
+  build:
+    name: Release build
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - uses: dtolnay/rust-toolchain@stable
+      - uses: actions/cache@v4
+        with:
+          path: |
+            ~/.cargo/registry
+            ~/.cargo/git
+            target
+          key: ${{ runner.os }}-cargo-${{ hashFiles('**/Cargo.lock') }}
+      - name: Build release binaries
+        run: cargo build --release
+      - name: Check expected frontends exist
+        run: |
+          test -x target/release/lccc
+          ls -l target/release/lccc*
+
+  unit-tests:
+    name: Rust unit tests
+    runs-on: ubuntu-latest
+    needs: build
+    steps:
+      - uses: actions/checkout@v4
+      - uses: dtolnay/rust-toolchain@stable
+      - uses: actions/cache@v4
+        with:
+          path: |
+            ~/.cargo/registry
+            ~/.cargo/git
+            target
+          key: ${{ runner.os }}-cargo-${{ hashFiles('**/Cargo.lock') }}
+      - name: Run release unit tests
+        run: cargo test --release
+
+  x86-integration:
+    name: x86-64 integration smoke tests
+    runs-on: ubuntu-latest
+    needs: unit-tests
+    steps:
+      - uses: actions/checkout@v4
+      - uses: dtolnay/rust-toolchain@stable
+      - name: Install host tools
+        run: sudo apt-get update && sudo apt-get install -y gcc python3
+      - name: Build compiler
+        run: cargo build --release
+      - name: Progressive integration tests
+        run: python3 tests/integration/test_progressive.py --level 3
+      - name: Correctness integration tests
+        run: python3 tests/correctness/run_correctness.py
+
+  cross-arch-smoke:
+    name: Cross-architecture smoke tests
+    runs-on: ubuntu-latest
+    needs: unit-tests
+    strategy:
+      fail-fast: false
+      matrix:
+        arch: [aarch64, riscv64, i686]
+    steps:
+      - uses: actions/checkout@v4
+      - uses: dtolnay/rust-toolchain@stable
+      - name: Install cross toolchains and QEMU user emulation
+        run: |
+          sudo apt-get update
+          sudo apt-get install -y \
+            gcc-aarch64-linux-gnu \
+            gcc-riscv64-linux-gnu \
+            gcc-i686-linux-gnu \
+            qemu-user python3
+      - name: Build compiler
+        run: cargo build --release
+      - name: Compile hello for ${{ matrix.arch }}
+        run: |
+          cat > /tmp/hello.c <<'EOF'
+          int main(void) { return 0; }
+          EOF
+          case "${{ matrix.arch }}" in
+            aarch64) target/release/lccc-arm -c /tmp/hello.c -o /tmp/hello.o ;;
+            riscv64) target/release/lccc-riscv -c /tmp/hello.c -o /tmp/hello.o ;;
+            i686) target/release/lccc-i686 -c /tmp/hello.c -o /tmp/hello.o ;;
+          esac
+          test -s /tmp/hello.o
diff --git a/docs/grammar.ebnf b/docs/grammar.ebnf
new file mode 100644
index 0000000..251bb3e
--- /dev/null
+++ b/docs/grammar.ebnf
@@ -0,0 +1,953 @@
+(* =========================================================================== *)
+(* Formal EBNF Grammar for CCC (Claude's C Compiler)                         *)
+(*                                                                           *)
+(* Covers:                                                                   *)
+(*   - C11 (ISO/IEC 9899:2011) productions targeted by the CCC parser       *)
+(*   - GNU/GCC extension productions, clearly marked as (* GNU extension *)  *)
+(*                                                                           *)
+(* Intended as the authoritative grammar target for CCC. Some productions are *)
+(* implemented fully today; others document supported syntax that is being    *)
+(* completed incrementally. Parser comments may reference these production    *)
+(* names as implementation coverage expands.                                  *)
+(*                                                                           *)
+(* Notation Conventions:                                                     *)
+(*   =         definition                                                    *)
+(*   |         alternation                                                   *)
+(*   [ ... ]   optional (zero or one)                                        *)
+(*   { ... }   repetition (zero or more)                                     *)
+(*   ( ... )   grouping                                                      *)
+(*   " ... "   terminal string / token keyword                               *)
+(*   ' ... '   terminal string / token keyword (alternate quoting)           *)
+(*   (* ... *) comment                                                       *)
+(*   ;         terminates each production rule                               *)
+(*                                                                           *)
+(* Production names use lowercase with hyphens, matching C11 Annex A style.  *)
+(* =========================================================================== *)
+
+
+(* =========================================================================== *)
+(* Section 1: Lexical Elements (Terminals)                                    *)
+(* =========================================================================== *)
+
+(* --- Token terminal categories ---                                          *)
+(* These are abstract terminals produced by the lexer (src/frontend/lexer/).   *)
+(* The full lexer specification is in scan.rs; here we reference categories.   *)
+
+(* identifier: C identifier token — letter or underscore followed by           *)
+(* letters, digits, or underscores.                                           *)
+(*   identifier = letter { letter | digit | "_" } ;                           *)
+(*   letter = "a" | ... | "z" | "A" | ... | "Z" | "_" ;                      *)
+(*   digit = "0" | ... | "9" ;                                                *)
+
+(* integer-constant: integer literal (decimal, hex, octal, binary)            *)
+(*   integer-constant = decimal-constant [ integer-suffix ]                   *)
+(*                    | hex-constant [ integer-suffix ]                        *)
+(*                    | octal-constant [ integer-suffix ]                      *)
+(*                    | binary-constant [ integer-suffix ] ;                   *)
+(*   integer-suffix = ( "u" | "U" ) [ ( "l" | "L" | "ll" | "LL" ) ]          *)
+(*                  | ( "l" | "L" | "ll" | "LL" ) [ ( "u" | "U" ) ] ;        *)
+
+(* floating-constant: float / double / long double literal                    *)
+(*   floating-constant = ( digit-sequence "." [ digit-sequence ] | "." digit-sequence ) *)
+(*                        [ exponent-part ] [ floating-suffix ]                *)
+(*                      | digit-sequence exponent-part [ floating-suffix ] ;   *)
+(*   floating-suffix = "f" | "F" | "l" | "L" ;                               *)
+
+(* character-constant: character literal                                      *)
+(*   character-constant = "'" c-char-sequence "'"                             *)
+(*                      | "L'" c-char-sequence "'" ;      (* wide character *) *)
+
+(* string-literal: string literal (including wide L"", char16_t u"")          *)
+(*   string-literal = [ "L" | "u" ] '"' { s-char } '"' ;                     *)
+
+(* imaginary-constant: imaginary literal                    (* GNU extension *) *)
+(*   imaginary-constant = floating-constant "i"                               *)
+(*                      | floating-constant "fi"                              *)
+(*                      | floating-constant "Li" ;                            *)
+
+
+(* --- C11 Keyword Terminals ---                                              *)
+(* The following keywords are reserved in C11 (ISO/IEC 9899:2011 §6.4.1):    *)
+(*                                                                            *)
+(*   "auto"     "break"    "case"      "char"     "const"                     *)
+(*   "continue" "default"  "do"        "double"   "else"                      *)
+(*   "enum"     "extern"   "float"     "for"      "goto"                      *)
+(*   "if"       "inline"   "int"       "long"     "register"                  *)
+(*   "restrict" "return"   "short"     "signed"   "sizeof"                    *)
+(*   "static"   "struct"   "switch"    "typedef"  "union"                     *)
+(*   "unsigned" "void"     "volatile"  "while"                                *)
+(*                                                                            *)
+(* C11 additional keywords:                                                   *)
+(*   "_Alignas"  "_Alignof"  "_Atomic"  "_Bool"    "_Complex"                 *)
+(*   "_Generic"  "_Noreturn" "_Static_assert"      "_Thread_local"            *)
+
+
+(* --- GNU Extension Keyword Terminals ---                  (* GNU extension *) *)
+(*                                                                            *)
+(*   "__attribute__"   "__extension__"                                         *)
+(*   "asm" / "__asm__"                                                        *)
+(*   "typeof" / "__typeof__"                                                  *)
+(*   "__auto_type"                                                            *)
+(*   "__label__"                                                              *)
+(*   "__builtin_va_arg"                                                       *)
+(*   "__builtin_types_compatible_p"                                           *)
+(*   "__real__" / "__imag__"                                                  *)
+(*   "__int128" / "unsigned __int128"                                         *)
+(*   "__seg_gs" / "__seg_fs"                                                  *)
+(*   "__alignof__" / "__alignof"                                              *)
+(*   "__volatile__"                                                           *)
+(*   "__thread"                                                               *)
+
+
+(* --- Digraph Tokens (C11 §6.4.6) ---                                        *)
+(* Always recognized by the lexer unconditionally.                            *)
+(* The lexer maps these to their canonical equivalents:                        *)
+(*   "<:" -> "["    ":>" -> "]"                                               *)
+(*   "<%" -> "{"    "%>" -> "}"                                               *)
+(*   "%:" -> "#"    "%:%:" -> "##"                                            *)
+
+
+(* --- Trigraph Sequences ---                               (* GNU extension *) *)
+(* Processed in translation phase 1 when the -trigraphs flag is active.        *)
+(* The preprocessor (pipeline.rs) replaces these before lexing:                *)
+(*   "??=" -> "#"   "??(" -> "["   "??/" -> "\"                               *)
+(*   "??)" -> "]"   "??'" -> "^"   "??<" -> "{"                               *)
+(*   "??!" -> "|"   "??>" -> "}"   "??-" -> "~"                               *)
+
+
+
+(* =========================================================================== *)
+(* Section 2: Top-Level Productions (C11 §6.9)                                *)
+(* =========================================================================== *)
+
+(* see: parse.rs::Parser::parse *)
+translation-unit = { external-declaration } ;
+
+(* see: declarations.rs::Parser::parse_external_decl *)
+external-declaration = function-definition
+                     | declaration
+                     | top-level-asm                    (* GNU extension *)
+                     | static-assert-declaration ;
+
+(* see: declarations.rs — top-level asm("..."); *)
+top-level-asm = ( "asm" | "__asm__" ) [ "volatile" | "__volatile__" ]
+                "(" string-literal ")" ";" ;           (* GNU extension *)
+
+
+
+(* =========================================================================== *)
+(* Section 3: Declarations (C11 §6.7)                                         *)
+(* =========================================================================== *)
+
+(* see: declarations.rs::Parser::parse_declaration_rest *)
+declaration = declaration-specifiers [ init-declarator-list ] ";" ;
+
+(* C11 §6.7: declaration-specifiers is an unordered collection of storage     *)
+(* class specifiers, type specifiers, type qualifiers, function specifiers,   *)
+(* alignment specifiers, and GCC attribute specifiers. C allows these in any  *)
+(* order (e.g., "long unsigned int" == "unsigned long int").                  *)
+declaration-specifiers = { storage-class-specifier
+                         | type-specifier
+                         | type-qualifier
+                         | function-specifier
+                         | alignment-specifier
+                         | gcc-attribute-specifier      (* GNU extension *)
+                         } ;
+
+(* C11 §6.7.1 *)
+storage-class-specifier = "typedef"
+                        | "extern"
+                        | "static"
+                        | "auto"
+                        | "register"
+                        | "_Thread_local"
+                        | "__thread" ;                  (* GNU extension *)
+
+(* C11 §6.7.3 *)
+type-qualifier = "const"
+               | "volatile"
+               | "restrict"
+               | "_Atomic" ;
+
+(* C11 §6.7.4 *)
+function-specifier = "inline"
+                   | "_Noreturn" ;
+
+(* C11 §6.7.5 *)
+(* see: parse.rs::Parser::parse_alignas_argument *)
+alignment-specifier = "_Alignas" "(" type-name ")"
+                    | "_Alignas" "(" constant-expression ")" ;
+
+init-declarator-list = init-declarator { "," init-declarator } ;
+
+init-declarator = declarator [ gcc-attribute-specifier ] [ "=" initializer ] ;
+
+(* C11 §6.7.2.3: specifier-qualifier-list is like declaration-specifiers     *)
+(* but without storage class specifiers.                                     *)
+specifier-qualifier-list = { type-specifier | type-qualifier
+                           | gcc-attribute-specifier    (* GNU extension *)
+                           } ;
+
+
+
+(* =========================================================================== *)
+(* Section 4: Function Definitions (C11 §6.9.1)                              *)
+(* =========================================================================== *)
+
+(* see: declarations.rs::Parser::parse_function_def *)
+function-definition = declaration-specifiers declarator
+                      [ declaration-list ]              (* K&R style params *)
+                      compound-statement ;
+
+(* K&R-style parameter declarations between ')' and '{' *)
+declaration-list = { declaration } ;
+
+(* C11 §6.7.10 *)
+(* see: declarations.rs::Parser::parse_static_assert *)
+(* Note: single-argument form (omitting message) is a C23 extension also     *)
+(* supported by CCC.                                                         *)
+static-assert-declaration = "_Static_assert" "("
+                              constant-expression
+                              [ "," string-literal ]
+                            ")" ";" ;
+
+
+
+(* =========================================================================== *)
+(* Section 5: Type Specifiers (C11 §6.7.2)                                   *)
+(* =========================================================================== *)
+
+(* see: types.rs::Parser::parse_type_specifier *)
+(* C allows type keywords in arbitrary order; the parser collects flags       *)
+(* and resolves them into a concrete TypeSpecifier via resolve_type_flags.    *)
+type-specifier = "void"
+               | "char"
+               | "short"
+               | "int"
+               | "long"                                 (* up to 2 longs *)
+               | "float"
+               | "double"
+               | "signed"
+               | "unsigned"
+               | "_Bool"
+               | "_Complex"
+               | "_Atomic" "(" type-name ")"            (* atomic type specifier *)
+               | "__int128"                             (* GNU extension *)
+               | "unsigned" "__int128"                  (* GNU extension *)
+               | struct-or-union-specifier
+               | enum-specifier
+               | typedef-name
+               | typeof-specifier                       (* GNU extension *)
+               | "__auto_type"                          (* GNU extension *)
+               ;
+
+(* C11 §6.7.2.1 *)
+(* see: types.rs::Parser::parse_struct_or_union *)
+struct-or-union-specifier = ( "struct" | "union" )
+                            { gcc-attribute-specifier }   (* GNU extension *)
+                            [ identifier ]
+                            [ "{" struct-declaration-list "}" ]
+                            { gcc-attribute-specifier } ; (* GNU extension *)
+
+(* see: types.rs::Parser::parse_struct_fields *)
+struct-declaration-list = { struct-declaration } ;
+
+struct-declaration = specifier-qualifier-list
+                     [ struct-declarator-list ] ";"
+                   | static-assert-declaration ;
+
+struct-declarator-list = struct-declarator { "," struct-declarator } ;
+
+(* see: types.rs::Parser::parse_struct_field_declarators *)
+(* Bit-field declarations: a declarator may have a colon and width.          *)
+struct-declarator = declarator [ ":" constant-expression ]
+                  | ":" constant-expression ;
+
+(* C11 §6.7.2.2 *)
+(* see: types.rs::Parser::parse_enum_specifier *)
+enum-specifier = "enum"
+                 { gcc-attribute-specifier }            (* GNU extension *)
+                 [ identifier ]
+                 [ "{" enumerator-list [ "," ] "}" ]
+                 { gcc-attribute-specifier } ;           (* GNU extension *)
+
+(* see: types.rs::Parser::parse_enum_variants *)
+enumerator-list = enumerator { "," enumerator } ;
+
+enumerator = identifier [ "=" constant-expression ] ;
+
+(* see: types.rs::Parser::parse_typeof_specifier *)
+typeof-specifier = ( "typeof" | "__typeof__" )
+                   "(" ( expression | type-name ) ")" ; (* GNU extension *)
+
+(* A typedef-name is an identifier previously declared as a typedef.         *)
+typedef-name = identifier ;
+
+
+
+(* =========================================================================== *)
+(* Section 6: Declarators (C11 §6.7.6)                                       *)
+(* =========================================================================== *)
+
+(* see: declarators.rs::Parser::parse_declarator *)
+declarator = [ pointer ] direct-declarator
+             { gcc-attribute-specifier } ;              (* GNU extension *)
+
+(* The direct-declarator handles identifiers, parenthesized declarators,     *)
+(* array dimensions, and function parameter lists. C declarators follow the  *)
+(* "inside-out" rule: int [*fp](int) means fp is a pointer to a function.   *)
+direct-declarator = identifier
+                  | "(" { gcc-attribute-specifier } declarator ")"
+                  | direct-declarator "[" [ array-size ] "]"
+                  | direct-declarator "(" parameter-type-list ")"
+                  | direct-declarator "(" [ identifier-list ] ")" ;
+
+(* Array size: may include type qualifiers and 'static' (C99 §6.7.6.2)      *)
+(* for function parameter array declarators.                                 *)
+array-size = { type-qualifier | "static" } assignment-expression
+           | { type-qualifier | "static" } "*"          (* VLA star syntax *)
+           ;
+
+pointer = "*" { type-qualifier | gcc-attribute-specifier } [ pointer ] ;
+
+(* see: declarators.rs::Parser::parse_param_list *)
+parameter-type-list = parameter-list [ "," "..." ] ;
+
+parameter-list = parameter-declaration { "," parameter-declaration } ;
+
+parameter-declaration = declaration-specifiers
+                        [ declarator | abstract-declarator ] ;
+
+(* An identifier-list is used in K&R-style function definitions.             *)
+identifier-list = identifier { "," identifier } ;
+
+(* C11 §6.7.7 *)
+(* Used in casts, sizeof, _Alignas, _Alignof, _Generic, compound literals.  *)
+type-name = specifier-qualifier-list [ abstract-declarator ] ;
+
+(* see: types.rs::Parser::parse_abstract_declarator_suffix *)
+abstract-declarator = pointer
+                    | [ pointer ] direct-abstract-declarator ;
+
+direct-abstract-declarator = "(" abstract-declarator ")"
+                           | [ direct-abstract-declarator ]
+                             "[" [ assignment-expression ] "]"
+                           | [ direct-abstract-declarator ]
+                             "[" "*" "]"                 (* VLA star syntax *)
+                           | [ direct-abstract-declarator ]
+                             "(" [ parameter-type-list ] ")" ;
+
+
+
+(* =========================================================================== *)
+(* Section 7: Initializers (C11 §6.7.9)                                       *)
+(* =========================================================================== *)
+
+(* see: declarations.rs::Parser::parse_initializer *)
+initializer = assignment-expression
+            | "{" initializer-list [ "," ] "}" ;
+
+initializer-list = [ designation ] initializer
+                   { "," [ designation ] initializer } ;
+
+designation = designator-list "=" ;
+
+designator-list = designator { designator } ;
+
+designator = "[" constant-expression "]"
+           | "[" constant-expression "..." constant-expression "]"
+                                                        (* GNU range designator *)
+           | "." identifier ;
+
+
+
+(* =========================================================================== *)
+(* Section 8: Statements (C11 §6.8)                                           *)
+(* =========================================================================== *)
+
+(* see: statements.rs::Parser::parse_stmt *)
+statement = labeled-statement
+          | compound-statement
+          | expression-statement
+          | selection-statement
+          | iteration-statement
+          | jump-statement
+          | inline-asm-statement                        (* GNU extension *)
+          | declaration ;                               (* C23 / GNU extension: *)
+                                                        (* declarations in stmt *)
+                                                        (* position            *)
+
+labeled-statement = identifier ":" statement
+                  | "case" constant-expression ":" statement
+                  | "case" constant-expression "..."
+                         constant-expression ":" statement
+                                                        (* GNU case range *)
+                  | "default" ":" statement ;
+
+(* see: statements.rs::Parser::parse_compound_stmt *)
+compound-statement = "{" { block-item } "}" ;
+
+block-item = declaration
+           | statement
+           | "__label__" identifier
+             { "," identifier } ";"                     (* GNU local labels *)
+           ;
+
+expression-statement = [ expression ] ";" ;
+
+(* C11 §6.8.4 *)
+selection-statement = "if" "(" expression ")" statement [ "else" statement ]
+                    | "switch" "(" expression ")" statement ;
+
+(* C11 §6.8.5 *)
+(* see: statements.rs::Parser::parse_for_stmt *)
+(* Note: C99 for-init-declaration supported via ForInit.                     *)
+iteration-statement = "while" "(" expression ")" statement
+                    | "do" statement "while" "(" expression ")" ";"
+                    | "for" "(" for-init ";" [ expression ] ";"
+                                              [ expression ] ")" statement ;
+
+for-init = expression
+         | declaration                                  (* C99 declaration-in-for *)
+         | (* empty *) ;
+
+(* C11 §6.8.6 *)
+jump-statement = "goto" identifier ";"
+               | "goto" "*" expression ";"              (* GNU computed goto *)
+               | "continue" ";"
+               | "break" ";"
+               | "return" [ expression ] ";" ;
+
+
+
+(* =========================================================================== *)
+(* Section 9: Expressions (C11 §6.5)                                          *)
+(* =========================================================================== *)
+
+(* --- Comma Expression (C11 §6.5.17) --- *)
+(* see: expressions.rs::Parser::parse_expr *)
+expression = assignment-expression { "," assignment-expression } ;
+
+(* --- Assignment Expression (C11 §6.5.16) --- *)
+(* see: expressions.rs::Parser::parse_assignment_expr *)
+assignment-expression = conditional-expression
+                      | unary-expression assignment-operator
+                        assignment-expression ;
+
+assignment-operator = "="
+                    | "*="
+                    | "/="
+                    | "%="
+                    | "+="
+                    | "-="
+                    | "<<="
+                    | ">>="
+                    | "&="
+                    | "^="
+                    | "|=" ;
+
+(* --- Conditional Expression (C11 §6.5.15) --- *)
+(* see: expressions.rs::Parser::parse_conditional_expr *)
+conditional-expression = logical-or-expression
+                         [ "?" expression ":" conditional-expression ]
+                       | logical-or-expression
+                         "?" ":" conditional-expression ;
+                                                        (* GNU omitted middle: *)
+                                                        (* cond ?: else_expr   *)
+
+(* --- Binary Expressions (C11 §6.5.2–§6.5.14) ---                           *)
+(* see: expressions.rs::Parser::parse_binary_expr(PrecedenceLevel)            *)
+(* Implemented via table-driven precedence climbing with 10 levels.           *)
+
+(* Precedence Level 1 — Logical OR (C11 §6.5.14) *)
+logical-or-expression = logical-and-expression
+                        { "||" logical-and-expression } ;
+
+(* Precedence Level 2 — Logical AND (C11 §6.5.13) *)
+logical-and-expression = bitwise-or-expression
+                         { "&&" bitwise-or-expression } ;
+
+(* Precedence Level 3 — Bitwise OR (C11 §6.5.12) *)
+bitwise-or-expression = bitwise-xor-expression
+                        { "|" bitwise-xor-expression } ;
+
+(* Precedence Level 4 — Bitwise XOR (C11 §6.5.11) *)
+bitwise-xor-expression = bitwise-and-expression
+                         { "^" bitwise-and-expression } ;
+
+(* Precedence Level 5 — Bitwise AND (C11 §6.5.10) *)
+bitwise-and-expression = equality-expression
+                         { "&" equality-expression } ;
+
+(* Precedence Level 6 — Equality (C11 §6.5.9) *)
+equality-expression = relational-expression
+                      { ( "==" | "!=" ) relational-expression } ;
+
+(* Precedence Level 7 — Relational (C11 §6.5.8) *)
+relational-expression = shift-expression
+                        { ( "<" | ">" | "<=" | ">=" ) shift-expression } ;
+
+(* Precedence Level 8 — Shift (C11 §6.5.7) *)
+shift-expression = additive-expression
+                   { ( "<<" | ">>" ) additive-expression } ;
+
+(* Precedence Level 9 — Additive (C11 §6.5.6) *)
+additive-expression = multiplicative-expression
+                      { ( "+" | "-" ) multiplicative-expression } ;
+
+(* Precedence Level 10 — Multiplicative (C11 §6.5.5) *)
+multiplicative-expression = cast-expression
+                            { ( "*" | "/" | "%" ) cast-expression } ;
+
+
+(* --- Cast Expression (C11 §6.5.4) --- *)
+(* see: expressions.rs::Parser::parse_cast_expr *)
+cast-expression = "(" type-name ")" cast-expression
+                | "(" type-name ")" "{" initializer-list [ "," ] "}"
+                                                        (* compound literal  *)
+                                                        (* C11 §6.5.2.5     *)
+                | unary-expression ;
+
+
+(* --- Unary Expression (C11 §6.5.3) --- *)
+(* see: expressions.rs::Parser::parse_unary_expr *)
+unary-expression = postfix-expression
+                 | "++" unary-expression
+                 | "--" unary-expression
+                 | unary-operator cast-expression
+                 | "sizeof" unary-expression
+                 | "sizeof" "(" type-name ")"
+                 | "_Alignof" "(" type-name ")"
+                 | "_Alignof" "(" expression ")"        (* via macro path *)
+                 | "__alignof__" "(" type-name ")"      (* GNU extension *)
+                 | "__alignof__" "(" expression ")"     (* GNU extension *)
+                 | "&&" identifier                      (* GNU labels-as-values *)
+                 | "__real__" cast-expression            (* GNU extension *)
+                 | "__imag__" cast-expression            (* GNU extension *)
+                 ;
+
+unary-operator = "&"        (* address-of *)
+               | "*"        (* dereference *)
+               | "+"        (* unary plus *)
+               | "-"        (* unary minus / negation *)
+               | "~"        (* bitwise NOT *)
+               | "!" ;      (* logical NOT *)
+
+
+(* --- Postfix Expression (C11 §6.5.2) --- *)
+(* see: expressions.rs::Parser::parse_postfix_ops *)
+postfix-expression = primary-expression
+                   | postfix-expression "[" expression "]"
+                   | postfix-expression "(" [ argument-expression-list ] ")"
+                   | postfix-expression "." identifier
+                   | postfix-expression "->" identifier
+                   | postfix-expression "++"
+                   | postfix-expression "--" ;
+
+argument-expression-list = assignment-expression
+                           { "," assignment-expression } ;
+
+
+(* --- Primary Expression (C11 §6.5.1) --- *)
+(* see: expressions.rs::Parser::parse_primary_expr *)
+primary-expression = identifier
+                   | constant
+                   | string-literal
+                   | "(" expression ")"
+                   | "(" compound-statement ")"         (* GNU statement expr *)
+                   | generic-selection
+                   | "__builtin_va_arg" "(" assignment-expression ","
+                                            type-name ")"
+                   | "__builtin_types_compatible_p" "(" type-name ","
+                                                        type-name ")"
+                                                        (* GNU extension *)
+                   ;
+
+
+(* --- Generic Selection (C11 §6.5.1.1) --- *)
+(* see: expressions.rs::Parser::parse_generic_selection *)
+generic-selection = "_Generic" "(" assignment-expression ","
+                                    generic-assoc-list ")" ;
+
+generic-assoc-list = generic-association { "," generic-association } ;
+
+generic-association = type-name ":" assignment-expression
+                    | "default" ":" assignment-expression ;
+
+
+
+(* =========================================================================== *)
+(* Section 10: GNU __attribute__ Syntax                     (* GNU extension *) *)
+(* =========================================================================== *)
+
+(* see: parse.rs::Parser::parse_gcc_attributes *)
+(* __attribute__ specifiers may appear after type specifiers, after            *)
+(* declarators, and in other positions where GCC accepts them.                *)
+gcc-attribute-specifier = "__attribute__" "((" attribute-list "))"
+                        | "__extension__" ;
+
+(* see: parse.rs::Parser::parse_gcc_attribute_list *)
+attribute-list = [ attribute ] { "," [ attribute ] } ;
+
+(* see: parse.rs::Parser::dispatch_gcc_attribute *)
+attribute = attribute-name [ "(" attribute-arguments ")" ] ;
+
+attribute-arguments = expression
+                    | type-name
+                    | string-literal { "," string-literal }
+                    | expression { "," expression }
+                    | (* empty *) ;
+
+(* The following attribute names are recognized by the CCC parser.            *)
+(* Each name also has a double-underscore form: e.g., packed / __packed__     *)
+(*                                                                            *)
+(* --- Structure/Layout Attributes ---                                        *)
+(*   packed                 — set struct alignment to 1 byte                  *)
+(*   aligned(N)             — set minimum alignment to N bytes                *)
+(*   transparent_union      — allow implicit union member conversion          *)
+(*   common / __common__    — emit as common symbol (-fcommon behavior)       *)
+(*                                                                            *)
+(* --- Visibility and Linkage Attributes ---                                  *)
+(*   visibility("...")      — set symbol visibility (default, hidden, etc.)   *)
+(*   weak                   — emit as a weak symbol                           *)
+(*   alias("target")        — make symbol an alias for target                 *)
+(*   weakref("target")      — weak reference alias                           *)
+(*   used                   — prevent dead code elimination of symbol         *)
+(*   section("name")        — place in specific ELF section                   *)
+(*   symver("name@@VER")    — symbol version alias                           *)
+(*                                                                            *)
+(* --- Function Behavior Attributes ---                                       *)
+(*   noreturn               — function never returns (also: _Noreturn)        *)
+(*   constructor            — run before main() (ELF .init_array)             *)
+(*   destructor             — run after main() (ELF .fini_array)              *)
+(*   always_inline          — must always be inlined                          *)
+(*   noinline               — must never be inlined                           *)
+(*   gnu_inline             — force GNU89 inline semantics                    *)
+(*   fastcall               — i386 fastcall calling convention                *)
+(*   naked                  — emit no prologue/epilogue, body is pure asm     *)
+(*   cold                   — function is unlikely to be called               *)
+(*   format(archetype,N,M)  — printf/scanf format string checking             *)
+(*   warn_unused_result     — warn if return value is discarded               *)
+(*   deprecated             — warn on use, function/variable is deprecated    *)
+(*   deprecated("msg")      — warn on use with message                        *)
+(*   malloc                 — returned pointer does not alias any other        *)
+(*   pure                   — function has no side effects (reads memory)      *)
+(*   const                  — function has no side effects (no memory reads)   *)
+(*   nonnull(...)            — specified pointer args must not be NULL          *)
+(*   sentinel               — variadic function must have NULL sentinel arg    *)
+(*   may_alias              — type may alias any other type                    *)
+(*                                                                            *)
+(* --- Type/Mode Attributes ---                                               *)
+(*   mode(M)                — set integer bit-width mode:                     *)
+(*                            QI=8, HI=16, SI=32, DI=64, TI=128,             *)
+(*                            SF=float, DF=double, TC=complex long double     *)
+(*   vector_size(N)         — total SIMD vector size in bytes                 *)
+(*   ext_vector_type(N)     — element count for Clang-style vector type       *)
+(*   address_space(AS)      — named address space (__seg_gs, __seg_fs)        *)
+(*                                                                            *)
+(* --- Miscellaneous Attributes ---                                           *)
+(*   cleanup(func)          — call func(&var) at scope exit (RAII cleanup)    *)
+(*   error("msg")           — emit error if function is called                *)
+(*   warning("msg")         — emit warning if function is called              *)
+(*   optimize("...")        — per-function optimization options               *)
+(*                                                                            *)
+(* Unknown attributes are silently ignored (with -Wattributes planned for     *)
+(* future warnings). The double-underscore form (e.g., __packed__) is always  *)
+(* equivalent to the plain form (packed).                                     *)
+
+attribute-name = "packed" | "aligned" | "section" | "visibility"
+               | "unused" | "used" | "weak" | "alias" | "weakref"
+               | "constructor" | "destructor"
+               | "noreturn" | "always_inline" | "noinline"
+               | "gnu_inline" | "fastcall" | "naked"
+               | "mode" | "vector_size" | "ext_vector_type"
+               | "address_space"
+               | "cleanup" | "symver"
+               | "transparent_union" | "common"
+               | "error" | "warning"
+               | "deprecated" | "warn_unused_result"
+               | "malloc" | "pure" | "const"
+               | "format" | "cold" | "nonnull"
+               | "may_alias" | "sentinel"
+               | "optimize"
+               | identifier ;                   (* any unrecognized name *)
+
+
+
+(* =========================================================================== *)
+(* Section 11: Inline Assembly (GNU Extension)              (* GNU extension *) *)
+(* =========================================================================== *)
+
+(* see: statements.rs::Parser::parse_inline_asm *)
+inline-asm-statement = ( "asm" | "__asm__" )
+                       [ asm-qualifier-list ]
+                       "(" asm-string-literal
+                           [ ":" asm-operands
+                             [ ":" asm-operands
+                               [ ":" asm-clobbers
+                                 [ ":" asm-goto-labels ] ] ] ]
+                       ")" ";" ;
+
+asm-qualifier-list = { "volatile" | "__volatile__" | "goto" | "inline" } ;
+
+(* Template string may be multiple concatenated string literals.              *)
+asm-string-literal = string-literal { string-literal } ;
+
+asm-operands = [ asm-operand { "," asm-operand } ] ;
+
+(* see: statements.rs::Parser::parse_one_asm_operand *)
+asm-operand = [ "[" identifier "]" ]
+              string-literal "(" expression ")" ;
+
+asm-clobbers = string-literal { "," string-literal } ;
+
+asm-goto-labels = identifier { "," identifier } ;
+
+
+
+(* =========================================================================== *)
+(* Section 12: Preprocessor Directives                                        *)
+(* =========================================================================== *)
+
+(* These directives are processed before parsing by the preprocessor          *)
+(* (src/frontend/preprocessor/pipeline.rs). Documented here for completeness. *)
+
+(* see: preprocessor/pipeline.rs::process_directive *)
+preprocessing-directive = "#" "define" identifier
+                            [ "(" [ macro-param-list ] ")" ]
+                            [ replacement-list ]
+                        | "#" "undef" identifier
+                        | "#" "include" header-name
+                        | "#" "include_next" header-name  (* GNU extension *)
+                        | "#" "if" pp-constant-expression
+                        | "#" "ifdef" identifier
+                        | "#" "ifndef" identifier
+                        | "#" "elif" pp-constant-expression
+                        | "#" "else"
+                        | "#" "endif"
+                        | "#" "error" [ pp-token-string ]
+                        | "#" "warning" [ pp-token-string ]
+                                                          (* GNU extension *)
+                        | "#" "line" digit-sequence [ string-literal ]
+                        | "#" "pragma" pragma-directive
+                        | "_Pragma" "(" string-literal ")"
+                                                          (* C11 §6.10.9 *)
+                        ;
+
+header-name = "<" header-name-chars ">"
+            | '"' header-name-chars '"' ;
+
+macro-param-list = identifier { "," identifier } [ "," "..." ]
+                 | "..." ;                              (* variadic macros *)
+
+replacement-list = { pp-token } ;
+
+pp-constant-expression = (* preprocessor constant expression — similar to    *)
+                         (* constant-expression but restricted to integer    *)
+                         (* arithmetic, defined(), and macro expansion       *)
+                         conditional-expression ;
+
+pp-token-string = { pp-token } ;
+
+(* --- Pragma Directives ---                                                  *)
+(* see: preprocessor/pragmas.rs and preprocessor/pipeline.rs                  *)
+pragma-directive = "once"
+                 | "pack" "(" pack-argument ")"
+                 | "GCC" gcc-pragma
+                 | "weak" identifier [ "=" identifier ]
+                 | "redefine_extname" identifier identifier
+                 | "push_macro" "(" string-literal ")"
+                 | "pop_macro" "(" string-literal ")" ;
+
+(* #pragma pack argument syntax — see: parse.rs::Parser::handle_pragma_pack_token *)
+pack-argument = "push" [ "," integer-constant ]
+              | "pop"
+              | integer-constant
+              | (* empty — reset to default alignment *) ;
+
+(* #pragma GCC sub-directives *)
+gcc-pragma = "visibility" ( "push" "(" visibility-string ")" | "pop" )
+           | "diagnostic" gcc-diagnostic-action string-literal
+           | "system_header"
+           | "poison" identifier { identifier } ;
+
+gcc-diagnostic-action = "ignored" | "warning" | "error" | "push" | "pop" ;
+
+visibility-string = '"' ( "default" | "hidden" | "internal"
+                        | "protected" ) '"' ;
+
+
+
+(* =========================================================================== *)
+(* Section 13: Constant Expressions (C11 §6.6)                               *)
+(* =========================================================================== *)
+
+(* A constant expression is a conditional expression restricted to            *)
+(* compile-time evaluable operations. The parser accepts the same grammar     *)
+(* as conditional-expression; the semantic analyzer (sema/const_eval.rs)      *)
+(* enforces the constant-expression restriction.                              *)
+constant-expression = conditional-expression ;
+
+constant = integer-constant
+         | floating-constant
+         | character-constant
+         | imaginary-constant ;                         (* GNU extension *)
+
+
+
+(* =========================================================================== *)
+(* Section 14: Complete BinOp / UnaryOp / PostfixOp Inventories               *)
+(* =========================================================================== *)
+
+(* Binary operators from ast.rs::BinOp — 16 operators across 10 precedence   *)
+(* levels, plus 2 logical operators. Listed by precedence (loose to tight):   *)
+(*                                                                            *)
+(*   Level  1: LogicalOr    "||"                                              *)
+(*   Level  2: LogicalAnd   "&&"                                              *)
+(*   Level  3: BitOr        "|"                                               *)
+(*   Level  4: BitXor       "^"                                               *)
+(*   Level  5: BitAnd       "&"                                               *)
+(*   Level  6: Eq "=="  Ne "!="                                               *)
+(*   Level  7: Lt "<"  Le "<="  Gt ">"  Ge ">="                               *)
+(*   Level  8: Shl "<<"  Shr ">>"                                             *)
+(*   Level  9: Add "+"  Sub "-"                                               *)
+(*   Level 10: Mul "*"  Div "/"  Mod "%"                                      *)
+
+(* Unary operators from ast.rs::UnaryOp:                                      *)
+(*   Plus      "+"    — unary plus                                            *)
+(*   Neg       "-"    — unary minus / negation                                *)
+(*   BitNot    "~"    — bitwise complement                                    *)
+(*   LogicalNot "!"   — logical negation                                      *)
+(*   PreInc    "++"   — prefix increment                                      *)
+(*   PreDec    "--"   — prefix decrement                                      *)
+(*   RealPart  "__real__"  — extract real part of complex     (* GNU ext *)   *)
+(*   ImagPart  "__imag__"  — extract imaginary part of complex(* GNU ext *)   *)
+
+(* Postfix operators from ast.rs::PostfixOp:                                  *)
+(*   PostInc   "++"   — postfix increment                                     *)
+(*   PostDec   "--"   — postfix decrement                                     *)
+
+
+
+(* =========================================================================== *)
+(* Section 15: AST Node Type Summary                                          *)
+(* =========================================================================== *)
+
+(* This section documents the correspondence between EBNF productions and     *)
+(* the Rust AST types defined in src/frontend/parser/ast.rs.                  *)
+(*                                                                            *)
+(* TranslationUnit  — struct with Vec<ExternalDecl>                           *)
+(*   -> translation-unit production                                           *)
+(*                                                                            *)
+(* ExternalDecl — enum with 3 variants:                                       *)
+(*   FunctionDef(FunctionDef)       -> function-definition                    *)
+(*   Declaration(Declaration)       -> declaration                            *)
+(*   TopLevelAsm(String)            -> top-level-asm                          *)
+(*                                                                            *)
+(* Declaration — struct with TypeSpecifier + Vec<InitDeclarator>              *)
+(*   flags: static, extern, typedef, const, volatile, common,                 *)
+(*          thread_local, transparent_union, inline                           *)
+(*   alignment, alignas_type, address_space, vector_size                      *)
+(*   -> declaration production                                                *)
+(*                                                                            *)
+(* FunctionDef — struct with return_type, name, params, variadic, body, attrs *)
+(*   attrs: static, inline, extern, gnu_inline, always_inline, noinline,      *)
+(*          constructor, destructor, weak, used, fastcall, naked, noreturn    *)
+(*          section, visibility, symver                                        *)
+(*   -> function-definition production                                        *)
+(*                                                                            *)
+(* TypeSpecifier — enum with ~25 variants:                                    *)
+(*   Void, Char, Short, Int, Long, LongLong, Float, Double, LongDouble,      *)
+(*   Signed, Unsigned, UnsignedChar, UnsignedShort, UnsignedInt,              *)
+(*   UnsignedLong, UnsignedLongLong, Int128, UnsignedInt128,                  *)
+(*   Bool, ComplexFloat, ComplexDouble, ComplexLongDouble,                     *)
+(*   Struct, Union, Enum, TypedefName, Pointer, Array,                        *)
+(*   FunctionPointer, BareFunction, Typeof, TypeofType, AutoType, Vector      *)
+(*   -> type-specifier production and sub-productions                         *)
+(*                                                                            *)
+(* DerivedDeclarator — enum with 4 variants:                                  *)
+(*   Pointer              -> pointer production                               *)
+(*   Array(Option<Expr>)  -> direct-declarator array suffix                   *)
+(*   Function(params, variadic) -> direct-declarator function suffix           *)
+(*   FunctionPointer(params, variadic) -> function pointer declarator         *)
+(*                                                                            *)
+(* InitDeclarator — struct: name, derived, init, attrs                        *)
+(*   -> init-declarator production                                            *)
+(*                                                                            *)
+(* Initializer — enum with 2 variants:                                        *)
+(*   Expr(Expr)                   -> assignment-expression initializer         *)
+(*   List(Vec<InitializerItem>)   -> brace-enclosed initializer-list          *)
+(*                                                                            *)
+(* Designator — enum with 3 variants:                                         *)
+(*   Index(Expr)        -> "[" constant-expression "]"                        *)
+(*   Range(Expr, Expr)  -> "[" lo "..." hi "]"          (* GNU extension *)   *)
+(*   Field(String)      -> "." identifier                                     *)
+(*                                                                            *)
+(* Stmt — enum with 16 variants:                                              *)
+(*   Expr, Return, If, While, DoWhile, For, Compound, Break, Continue,       *)
+(*   Switch, Case, CaseRange (* GNU *), Default, Goto,                        *)
+(*   GotoIndirect (* GNU *), Label, Declaration, InlineAsm                    *)
+(*   -> statement production and sub-productions                              *)
+(*                                                                            *)
+(* BlockItem — enum with 2 variants:                                          *)
+(*   Declaration(Declaration) -> declaration block-item                        *)
+(*   Statement(Stmt)          -> statement block-item                          *)
+(*                                                                            *)
+(* CompoundStmt — struct with items: Vec<BlockItem>, local_labels: Vec<String> *)
+(*   -> compound-statement production                                         *)
+(*                                                                            *)
+(* ForInit — enum with 2 variants:                                            *)
+(*   Declaration(Declaration) -> for-init declaration                          *)
+(*   Expr(Expr)               -> for-init expression                           *)
+(*                                                                            *)
+(* Expr — enum with 33+ variants:                                             *)
+(*   IntLiteral, UIntLiteral, LongLiteral, ULongLiteral,                     *)
+(*   LongLongLiteral, ULongLongLiteral,                                      *)
+(*   FloatLiteral, FloatLiteralF32, FloatLiteralLongDouble,                   *)
+(*   ImaginaryLiteral, ImaginaryLiteralF32, ImaginaryLiteralLongDouble,       *)
+(*   StringLiteral, WideStringLiteral, Char16StringLiteral, CharLiteral,     *)
+(*   Identifier, BinaryOp, UnaryOp, PostfixOp,                               *)
+(*   Assign, CompoundAssign, Conditional, GnuConditional (* GNU *),           *)
+(*   FunctionCall, ArraySubscript, MemberAccess, PointerMemberAccess,         *)
+(*   Cast, CompoundLiteral, StmtExpr (* GNU *), Sizeof, VaArg,               *)
+(*   Alignof, AlignofExpr, GnuAlignof, GnuAlignofExpr,                       *)
+(*   Comma, AddressOf, Deref, GenericSelection,                               *)
+(*   LabelAddr (* GNU *), BuiltinTypesCompatibleP (* GNU *)                   *)
+(*   -> expression, primary-expression, and sub-productions                   *)
+(*                                                                            *)
+(* GenericAssociation — struct: type_spec (None=default), expr, is_const      *)
+(*   -> generic-association production                                        *)
+(*                                                                            *)
+(* SizeofArg — enum with 2 variants:                                          *)
+(*   Type(TypeSpecifier) -> sizeof(type-name)                                 *)
+(*   Expr(Expr)          -> sizeof unary-expression                           *)
+(*                                                                            *)
+(* BinOp — enum with 16+2 operators (see Section 14)                          *)
+(* UnaryOp — enum with 8 operators (see Section 14)                           *)
+(* PostfixOp — enum with 2 operators (see Section 14)                         *)
+(*                                                                            *)
+(* AsmOperand — struct: name, constraint, expr                                *)
+(*   -> asm-operand production                                                *)
+(*                                                                            *)
+(* StructFieldDecl — struct: type_spec, name, bit_width, derived, alignment   *)
+(*   -> struct-declarator production                                          *)
+(*                                                                            *)
+(* EnumVariant — struct: name, value                                          *)
+(*   -> enumerator production                                                 *)
+(*                                                                            *)
+(* ParamDecl — struct: type_spec, name, fptr_params, is_const,                *)
+(*             vla_size_exprs, fptr_inner_ptr_depth                            *)
+(*   -> parameter-declaration production                                      *)
+(*                                                                            *)
+(* FunctionAttributes — packed bitfield: static, inline, extern, gnu_inline,  *)
+(*   always_inline, noinline, constructor, destructor, weak, used,            *)
+(*   fastcall, naked, noreturn; plus section, visibility, symver              *)
+(*                                                                            *)
+(* DeclAttributes — packed bitfield: constructor, destructor, weak,           *)
+(*   error_attr, noreturn, used, fastcall, naked; plus alias_target,          *)
+(*   visibility, section, asm_register, cleanup_fn, symver                    *)
+
+
+(* =========================================================================== *)
+(* End of Grammar                                                             *)
+(* =========================================================================== *)
