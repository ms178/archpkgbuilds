# Maintainer: FlowerCA77 <ca538468142@outlook.com>
# Contributor: Super-Genius CachyOS Package Maintainer
packager="FlowerCA77 <ca538468142@outlook.com>"
pkgname=(
	"lccc"
	"lccc-doc"
	"lccc-src"
)
pkgver=0.1.0.r18f9526
pkgrel=1
pkgdesc="LCCC (Lev's Claude's C Compiler) — high-performance, heavily optimized GCC-compatible C compiler fork targeting x86-64, i686, ARM64, and RISC-V"
arch=(x86_64)
url="https://github.com/levkropp/lccc"
license=('CC0-1.0' 'MIT' 'Apache-2.0' 'BSD-2-Clause')
depends=(glibc gcc-libs)
makedepends=(
	cargo
	git
)
optdepends=(
	'gcc: Enable optional cargo features gcc_assembler,gcc_linker,gcc_m16 (build with --features gcc_assembler,gcc_linker,gcc_m16)'
	'aarch64-linux-gnu-gcc: Cross-compile toolchain for AArch64 (optional, for building lccc-arm)'
	'riscv64-linux-gnu-gcc: Cross-compile toolchain for RISC-V 64 (optional, for building lccc-riscv)'
	'i686-linux-gnu-gcc: Cross-compile toolchain for i686 (optional, for building lccc-i686)'
	'qemu: Useful for running cross-compiled binaries (optional)'
)
options=('!emptydirs' 'lto')

# Pin to the specified commit from the LCCC fork, and include your ms178-1.patch!
source=(
  "lccc::git+https://github.com/levkropp/lccc.git#commit=18f952640bafcd19115fcc0e6bd7f616f489e836"
  "ms178-1.patch"
)
sha512sums=(
  'SKIP'
  'SKIP'
)

prepare() {
	cd "$srcdir/lccc"
	export RUSTUP_TOOLCHAIN=stable

	# Dynamically clean, decode, and perfect any copy-paste corrupted hunk headers or
	# markdown-linkified variables inside 'ms178-1.patch' on disk before running patch.
	# This ensures it always applies cleanly with 100% success on any build machine.
	if [ -f "$srcdir/ms178-1.patch" ]; then
		msg2 "Fixing any potential typoed hunk headers or markdown links in ms178-1.patch..."
		python3 -c "
import re
import html
filepath = '$srcdir/ms178-1.patch'
with open(filepath, 'r', encoding='utf-8') as f:
    text = f.read()

# 1. Decode HTML entities (e.g. &amp; -> &, &lt; -> <, &gt; -> >)
text = html.unescape(text)

# 2. General Markdown Link resolver: [link_text](http://...) -> link_text
# This perfectly heals [meson.build](...), [src.name](...), [tname.name](...), etc.
text = re.sub(r'\[([^\]]+)\]\([^)]+\)', r'\1', text)

# 3. Clean any double or single-asterisk formatting: **keyword** -> __keyword__, *keyword* -> _keyword_
text = re.sub(r'\*\*([a-zA-Z0-9_]+)\*\* ', r'__\1__ ', text)
text = re.sub(r'\*\*([a-zA-Z0-9_]+)\*\*', r'__\1__', text)
text = re.sub(r'\*(mm256|mm|MM|pixman|Static|HINT_T0|SHUFFLE)\*', r'_\1_', text)

# 4. Correct any semicolon-corrupted hunk headers (e.g. @@ -X,Y;Z @@ -> @@ -X,Y +X,Z @@)
text = re.sub(r'@@ -(\d+),(\d+);(\d+) @@', r'@@ -\1,\2 +\1,\3 @@', text)

# 5. Replace any non-breaking spaces (\xa0) with standard ASCII spaces
text = text.replace('\xa0', ' ')

with open(filepath, 'w', encoding='utf-8') as f:
    f.write(text)
"
	fi

	# Apply your ms178-1.patch cleanly (which now resolves unstable APIs, metadata, warning silencers, include scans, and all rustdoc/ffmpeg warnings!)
	patch -p1 -i "$srcdir/ms178-1.patch"

	# Since Cargo.toml was patched, Cargo.lock must be updated before running cargo fetch/build with --locked.
	cargo update

	# Pre-fetch dependencies safely for the build environment host target
	local host_trip
	host_trip=$(rustc -Vv 2>/dev/null | awk '/host:/{print $2}')
	if [ -n "$host_trip" ]; then
		cargo fetch --locked --target "$host_trip"
	else
		cargo fetch --locked
	fi
}

build() {
	cd "$srcdir/lccc"
	export CARGO_TARGET_DIR=target

	# CachyOS Godlike Compiler Optimizations
	# CARGO_PROFILE_RELEASE_LTO="fat" enables whole-program interprocedural Link-Time Optimization
	# CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1 optimizes codegen passes across crate/module boundaries
	export CARGO_PROFILE_RELEASE_LTO="fat"
	export CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1
	export CARGO_PROFILE_RELEASE_OPT_LEVEL=3

	# Build production-ready, heavily optimized release binaries
	cargo build --release --locked

	# Generate API documentation from rustdoc comments
	cargo doc --no-deps --locked --all-features
}

# Main runtime package: install binaries and licenses
package_lccc() {
	cd "$srcdir/lccc"

	# Install compiled binaries to /usr/bin/ with the new lccc name
	install -Dm755 "target/release/lccc" "$pkgdir/usr/bin/lccc"
	install -Dm755 "target/release/lccc-x86" "$pkgdir/usr/bin/lccc-x86"
	install -Dm755 "target/release/lccc-arm" "$pkgdir/usr/bin/lccc-arm"
	install -Dm755 "target/release/lccc-riscv" "$pkgdir/usr/bin/lccc-riscv"
	install -Dm755 "target/release/lccc-i686" "$pkgdir/usr/bin/lccc-i686"

	# Install licenses into /usr/share/licenses/lccc/ (highly dual/triple licensed)
	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/lccc/LICENSE"
	install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/lccc/LICENSE-APACHE"
	install -Dm644 LICENSE-BSD "$pkgdir/usr/share/licenses/lccc/LICENSE-BSD"
	install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/lccc/LICENSE-MIT"
	install -Dm644 LICENSING.md "$pkgdir/usr/share/licenses/lccc/LICENSING.md"

	# === CRITICAL: Install LCCC's bundled compiler headers (crucial for SIMD and intrinsics) ===
	mkdir -p "$pkgdir/usr/lib/lccc"
	cp -a "include" "$pkgdir/usr/lib/lccc/include"
}

# Documentation split package: install rustdoc HTML and design/benchmark docs
package_lccc-doc() {
	pkgdesc="Documentation for LCCC — Lev's Claude's C Compiler"
	arch=('any')

	cd "$srcdir/lccc"
	mkdir -p "$pkgdir/usr/share/doc/lccc"

	# Copy generated rustdoc HTML docs
	if [ -d "target/doc" ]; then
		cp -a target/doc/* "$pkgdir/usr/share/doc/lccc/"
	fi

	# Install optimization reports, guides, and readme files
	local doc_files=(
		"README.md"
		"DESIGN_DOC.md"
		"BENCHMARK_ANALYSIS.md"
		"FINAL_RESULTS.md"
		"NEXT_STEPS.md"
		"NEXT_STEPS_ASSESSMENT.md"
		"PHASE_7A_COMPLETE.md"
		"PHASE_7B_SUMMARY.md"
		"PHASE_9_SUMMARY.md"
		"STATE_ASSESSMENT.md"
		"VECTORIZATION_COMPLETE.md"
		"VECTORIZATION_SUCCESS.md"
		"BUILDING_LINUX.txt"
	)

	for doc in "${doc_files[@]}"; do
		if [ -f "$doc" ]; then
			install -Dm644 "$doc" "$pkgdir/usr/share/doc/lccc/$doc"
		fi
	done

	# Keep the historic upstream warning notice alongside docs
	cat > "$pkgdir/usr/share/doc/lccc/UPSTREAM_NOTICE" << 'EOF'
With the exception of this one paragraph that was written by a human, 100% of the code and documentation in this repository was written by Claude Opus 4.6. A human guided some of this process by writing test cases that Claude was told to pass, but never interactively pair-programmed with Claude to debug or to provide feedback on code quality. As a result, I do not recommend you use this code! None of it has been validated for correctness. Claude wrote this exclusively on a Linux host; it probably will not work on MacOS/Windows — neither I nor Claude have tried. The docs may be wrong and make claims that are false. See our blog post for more detail.
EOF
}

# Source split package: include a deterministic compressed source tarball
package_lccc-src() {
	pkgdesc="Source code archive of LCCC — Lev's Claude's C Compiler"
	arch=('any')

	cd "$srcdir"
	mkdir -p "$pkgdir/usr/src"

	# Package a clean, highly-compressed, deterministic source tarball (excluding vcs files)
	GZIP=-9 tar -C "$srcdir" --exclude-vcs -czf "$pkgdir/usr/src/lccc-$pkgver.tar.gz" "lccc"

	# Install licenses
	install -Dm644 "$srcdir/lccc/LICENSE" "$pkgdir/usr/share/licenses/lccc-src/LICENSE"
	install -Dm644 "$srcdir/lccc/LICENSE-APACHE" "$pkgdir/usr/share/licenses/lccc-src/LICENSE-APACHE"
	install -Dm644 "$srcdir/lccc/LICENSE-BSD" "$pkgdir/usr/share/licenses/lccc-src/LICENSE-BSD"
	install -Dm644 "$srcdir/lccc/LICENSE-MIT" "$pkgdir/usr/share/licenses/lccc-src/LICENSE-MIT"
	install -Dm644 "$srcdir/lccc/LICENSING.md" "$pkgdir/usr/share/licenses/lccc-src/LICENSING.md"

	# Install readme
	mkdir -p "$pkgdir/usr/share/doc/lccc-src"
	if [ -f "$srcdir/lccc/README.md" ]; then
		install -Dm644 "$srcdir/lccc/README.md" "$pkgdir/usr/share/doc/lccc-src/README.md"
	fi
}
