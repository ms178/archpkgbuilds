+      getNarrowLowPrefixVT(MST->getValue().getValueType(), *PrefixElts, DAG);
+  EVT NarrowMemVT = getNarrowLowPrefixVT(MST->getMemoryVT(), *PrefixElts, DAG);
+  if (NarrowVT == MVT::INVALID_SIMPLE_VALUE_TYPE ||
