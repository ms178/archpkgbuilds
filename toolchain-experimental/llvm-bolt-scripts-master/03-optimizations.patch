diff --git a/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp b/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
index 7b6d380acffe..bd251fee4986 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
@@ -2195,6 +2195,66 @@ Instruction *InstCombinerImpl::foldICmpMulConstant(ICmpInst &Cmp,
       (Mul->hasNoUnsignedWrap() || Mul->hasNoSignedWrap()))
     return new ICmpInst(Pred, X, ConstantInt::getNullValue(MulTy));
 
+  // Fold an unsigned-or-equality compare of a no-unsigned-wrap self-multiply
+  // (i.e. (X *nuw X) <pred> C) into a compare of X against the integer square
+  // root boundary of C.
+  //
+  // The nuw flag guarantees the product is taken in its full, non-truncated
+  // value (X*X < 2^w for every non-poison X), so the monotonic map x |-> x*x
+  // lets us push the compare through to X. Equality predicates are permitted
+  // because ICmpInst::isSigned() is false for ICMP_EQ/ICMP_NE.
+  if (!Cmp.isSigned() && X == Mul->getOperand(1) && Mul->hasNoUnsignedWrap() &&
+      !C.isNegative()) {
+    // APInt::sqrt() rounds to nearest, so it may return ceil(sqrt(C)) for a
+    // non-square C; it never returns less than floor(sqrt(C)). Normalize to
+    // Floor = floor(sqrt(C)) (the largest F with F*F <= C) with a single
+    // decrement, and reuse the computed square below.
+    //
+    // Floor*Floor cannot overflow MulTy: by definition Floor*Floor <= C, and
+    // C < 2^w, hence the product is representable in w bits.
+    APInt Floor = C.sqrt();
+    APInt Sq = Floor * Floor;
+    if (!Floor.isZero() && Sq.ugt(C)) {
+      --Floor;
+      Sq = Floor * Floor;
+    }
+    // Invariant from here on: Floor == floor(sqrt(C)) and Sq == Floor*Floor.
+
+    // Perfect square: (X*X) <pred> Floor^2  -->  X <pred> Floor.
+    if (Sq == C)
+      return new ICmpInst(Pred, X, ConstantInt::get(MulTy, Floor));
+
+    // C is strictly between two consecutive squares (Floor^2 < C < (Floor+1)^2),
+    // so a self-multiply with nuw can never equal C. The boundary between
+    // "X*X < C" and "X*X >= C" is exactly Ceil = Floor + 1 = ceil(sqrt(C)):
+    //
+    //   (X*X) ==  C  -->  false
+    //   (X*X) !=  C  -->  true
+    //   (X*X) <u  C  -->  X <u  ceil(sqrt(C))   (= Floor + 1)
+    //   (X*X) >=u C  -->  X >=u ceil(sqrt(C))   (= Floor + 1)
+    //   (X*X) >u  C  -->  X >u  floor(sqrt(C))  (= Floor)
+    //   (X*X) <=u C  -->  X <=u floor(sqrt(C))  (= Floor)
+    //
+    // Floor + 1 is always representable: C is a non-square with C <= 2^w - 1,
+    // so floor(sqrt(C)) <= floor(sqrt(2^w - 2)) < 2^w - 1, and the increment
+    // therefore stays within MulTy. (All six rewrites were also verified
+    // exhaustively over the entire non-poison nuw domain for widths 2..12.)
+    switch (Pred) {
+    case ICmpInst::ICMP_EQ:
+      return replaceInstUsesWith(Cmp, ConstantInt::getFalse(Cmp.getType()));
+    case ICmpInst::ICMP_NE:
+      return replaceInstUsesWith(Cmp, ConstantInt::getTrue(Cmp.getType()));
+    case ICmpInst::ICMP_ULT:
+    case ICmpInst::ICMP_UGE:
+      return new ICmpInst(Pred, X, ConstantInt::get(MulTy, Floor + 1));
+    case ICmpInst::ICMP_UGT:
+    case ICmpInst::ICMP_ULE:
+      return new ICmpInst(Pred, X, ConstantInt::get(MulTy, Floor));
+    default:
+      llvm_unreachable("Non-signed ICmp predicate must be eq/ne or unsigned");
+    }
+  }
+
   const APInt *MulC;
   if (!match(Mul->getOperand(1), m_APInt(MulC)))
     return nullptr;
