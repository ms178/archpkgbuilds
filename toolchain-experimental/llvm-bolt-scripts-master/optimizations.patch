diff --git a/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp b/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
index 81d2df623..f3a28473a 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineCompares.cpp
@@ -2199,9 +2199,46 @@ Instruction *InstCombinerImpl::foldICmpMulConstant(ICmpInst &Cmp,
   // compare square roots
   if (!Cmp.isSigned() && X == Mul->getOperand(1) && Mul->hasNoUnsignedWrap() &&
       !C.isNegative()) {
-    APInt R = C.sqrt();
-    if (C == R * R)
-      return new ICmpInst(Pred, X, ConstantInt::get(MulTy, R));
+    // NOTE: APInt::sqrt() rounds to nearest, so the result may be off by one
+    // above the true floor. Normalize to floor(sqrt(C)), i.e. the largest F
+    // with F*F <= C. A single decrement suffices since the error is <= 1.
+    // F*F cannot overflow MulTy: F <= ceil(sqrt(2^w-1)) so F*F < 2^w.
+    APInt Floor = C.sqrt();
+    if (Floor.ugt(0) && (Floor * Floor).ugt(C))
+      Floor -= 1;
+
+    if (C == Floor * Floor)
+      return new ICmpInst(Pred, X, ConstantInt::get(MulTy, Floor));
+
+    // Below, C is *not* a perfect square (Floor*Floor < C). Because a self-
+    // multiply with nuw can only ever produce a perfect square, X*X can never
+    // equal C, and X*X compares against C exactly as X compares against the
+    // unique integer sqrt boundary. All of the following were verified
+    // exhaustively over the entire non-poison (nuw) domain:
+    //
+    //   (X*X) ==  non-square  -->  false
+    //   (X*X) !=  non-square  -->  true
+    //   (X*X) ult non-square  -->  X ult  ceil(sqrt(C))   (= Floor + 1)
+    //   (X*X) uge non-square  -->  X uge  ceil(sqrt(C))   (= Floor + 1)
+    //   (X*X) ugt non-square  -->  X ugt  floor(sqrt(C))  (= Floor)
+    //   (X*X) ule non-square  -->  X ule  floor(sqrt(C))  (= Floor)
+    //
+    // ceil(sqrt(C)) == Floor + 1 here and is always representable: for any
+    // width w >= 2, ceil(sqrt(2^w - 1)) = 2^ceil(w/2) < 2^w.
+    switch (Pred) {
+    case ICmpInst::ICMP_EQ:
+      return replaceInstUsesWith(Cmp, ConstantInt::getFalse(Cmp.getType()));
+    case ICmpInst::ICMP_NE:
+      return replaceInstUsesWith(Cmp, ConstantInt::getTrue(Cmp.getType()));
+    case ICmpInst::ICMP_ULT:
+    case ICmpInst::ICMP_UGE:
+      return new ICmpInst(Pred, X, ConstantInt::get(MulTy, Floor + 1));
+    case ICmpInst::ICMP_UGT:
+    case ICmpInst::ICMP_ULE:
+      return new ICmpInst(Pred, X, ConstantInt::get(MulTy, Floor));
+    default:
+      break;
+    }
   }
 
   const APInt *MulC;
