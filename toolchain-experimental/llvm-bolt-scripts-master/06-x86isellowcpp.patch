+    break;
+  case ISD::UMIN:
+    RdxOp = ISD::VECREDUCE_UMIN;
+    break;
+  default:
+    llvm_unreachable("Unexpected reduction opcode");
+  }
+
+  return DAG.getNode(RdxOp, SDLoc(Extract), ExtractVT, Src);
