+static __always_inline u64 lavd_mul_u64_u32_shr16_cap(u64 val, u32 mul,
+						      u64 cap)
+{
+	u64 hi, res, rem;
+	u32 lo;
+
+	if (!mul || !cap)
+		return 0;
+
+	hi = val >> 16;
+	lo = (u32)(val & 0xffffULL);
+
+	if (hi > cap / mul)
+		return cap;
+
+	res = hi * mul;
+	if (res >= cap)
+		return cap;
+
+	rem = ((u64)lo * mul) >> 16;
+	if (rem > cap - res)
+		return cap;
+
+	return res + rem;
+}
+
+static __always_inline u64 lavd_mul_u64_u32_div_cap(u64 val, u32 mul,
+						    u32 div, u64 cap)
+{
+	u64 q, res, rem;
+	u32 r;
+
+	if (!mul || !cap)
+		return 0;
+	if (!div)
+		return cap;
+
+	q = val / div;
+	r = (u32)(val - q * div);
+
+	if (q > cap / mul)
+		return cap;
+
+	res = q * mul;
+	if (res >= cap)
+		return cap;
+
+	rem = ((u64)r * mul) / div;
+	if (rem > cap - res)
+		return cap;
+
+	return res + rem;
+}
