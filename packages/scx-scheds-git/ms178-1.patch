+        let mut sorted_perf = cpus.clone();
+        sorted_perf.sort_unstable_by_key(|c| score_perf(c));
+
+        let primary_p_cores: Vec<usize> = sorted_perf[0..8].iter().map(|c| c.cpu_adx).collect();
+        assert_eq!(primary_p_cores, vec![0, 2, 4, 6, 8, 10, 12, 14]);
+
+        let e_cores: Vec<usize> = sorted_perf[8..20].iter().map(|c| c.cpu_adx).collect();
+        assert_eq!(e_cores, (16..28).collect::<Vec<usize>>());
+
+        let smt_siblings: Vec<usize> = sorted_perf[20..28].iter().map(|c| c.cpu_adx).collect();
+        assert_eq!(smt_siblings, vec![1, 3, 5, 7, 9, 11, 13, 15]);
+    }
+
+    #[test]
+    fn microbenchmark_raptorlake_sorting_throughput() {
+        let mut cpus = Vec::with_capacity(28);
+        for i in 0..8 {
+            cpus.push(CpuId {
+                numa_adx: 0, pd_adx: 0, llc_adx: 0, llc_rdx: 0, llc_kernel_id: 0,
+                cpu_adx: i * 2, smt_level: 0, cache_size: 33554432, cpu_cap: 1024,
+                big_core: true, turbo_core: i < 2, cpu_sibling: i * 2 + 1,
+            });
+            cpus.push(CpuId {
+                numa_adx: 0, pd_adx: 0, llc_adx: 0, llc_rdx: 0, llc_kernel_id: 0,
+                cpu_adx: i * 2 + 1, smt_level: 1, cache_size: 33554432, cpu_cap: 1024,
+                big_core: true, turbo_core: i < 2, cpu_sibling: i * 2,
+            });
+        }
+        for i in 0..12 {
+            cpus.push(CpuId {
+                numa_adx: 0, pd_adx: 1, llc_adx: 0, llc_rdx: 0, llc_kernel_id: 0,
+                cpu_adx: 16 + i, smt_level: 0, cache_size: 4194304, cpu_cap: 512,
+                big_core: false, turbo_core: false, cpu_sibling: 16 + i,
+            });
+        }
+
+        let start = std::time::Instant::now();
+        let iterations = 10_000;
+        for _ in 0..iterations {
+            let _ = EnergyModelOptimizer::get_tiered_perf_cpu_order_table(&cpus, &cpus);
+        }
+        let elapsed = start.elapsed();
+        println!("Micro-benchmark: {} iterations of Raptor Lake tiered table gen took {:?} ({:.2?} / iter)", iterations, elapsed, elapsed / iterations);
     }
