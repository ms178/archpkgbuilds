pkgname=pixman-git
pkgver=0.46.4.r25.g6fe11b2
pkgrel=2
pkgdesc="The pixel-manipulation library for X and cairo"
arch=(x86_64)
url="https://cgit.freedesktop.org/pixman/"
license=(custom)
provides=(pixman libpixman-1.so=0-64)
conflicts=(pixman)
depends=(glibc)
makedepends=(git meson ninja libpng llvm clang lld python)
source=(
  "git+https://gitlab.freedesktop.org/pixman/pixman.git"
  avx2-modern.patch
)
sha256sums=(
  'SKIP'
  'SKIP'
)

_apply_patch_auto() {
  local patchfile="$1"
  local roots=("${srcdir}/pixman" "${srcdir}")
  local root p

  [[ -f "${patchfile}" ]] || {
    error "Patch file not found: ${patchfile}"
    return 1
  }

  for root in "${roots[@]}"; do
    [[ -d "${root}" ]] || continue
    for p in 0 1 2 3 4 5 6 7 8; do
      if patch --batch --forward --silent --dry-run -d "${root}" -p"${p}" -i "${patchfile}" >/dev/null 2>&1; then
        msg2 "Applying patch: $(basename "${patchfile}") (root=$(basename "${root}"), -p${p})"
        patch --batch --forward -d "${root}" -p"${p}" -i "${patchfile}"
        return 0
      fi
    done
  done

  error "Failed to determine patch strip level for ${patchfile}"
  return 1
}

_create_trainer_source() {
  cat > "$1" <<'EOF'
#include <pixman.h>

#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

static uint32_t xs32(uint32_t *state) {
  uint32_t x = *state;
  x ^= x << 13;
  x ^= x >> 17;
  x ^= x << 5;
  *state = x ? x : 0x9e3779b9u;
  return *state;
}

static pixman_image_t *mkbits(pixman_format_code_t fmt, int w, int h, uint32_t seed, uint32_t **out_bits, int *out_stride) {
  int stride = w * 4;
  size_t bytes = (size_t)stride * (size_t)h;
  uint32_t *bits = malloc(bytes);
  pixman_image_t *img = NULL;
  size_t i;

  if (!bits) return NULL;
  for (i = 0; i < bytes / 4; ++i) bits[i] = xs32(&seed);
  img = pixman_image_create_bits(fmt, w, h, bits, stride);
  if (!img) {
    free(bits);
    return NULL;
  }
  *out_bits = bits;
  *out_stride = stride;
  return img;
}

static void pass_composite(unsigned rounds, int w, int h) {
  uint32_t *sbits = NULL, *dbits = NULL, *mbits = NULL;
  int ss = 0, ds = 0, ms = 0;
  pixman_image_t *src = mkbits(PIXMAN_a8r8g8b8, w, h, 0x11111111u, &sbits, &ss);
  pixman_image_t *dst = mkbits(PIXMAN_x8r8g8b8, w, h, 0x22222222u, &dbits, &ds);
  pixman_image_t *msk = mkbits(PIXMAN_a8, w, h, 0x33333333u, &mbits, &ms);
  unsigned r;

  if (!src || !dst || !msk) goto out;
  pixman_image_set_repeat(src, PIXMAN_REPEAT_NORMAL);
  pixman_image_set_repeat(msk, PIXMAN_REPEAT_NORMAL);
  for (r = 0; r < rounds; ++r) {
    pixman_image_composite32(PIXMAN_OP_SRC, src, NULL, dst, 0, 0, 0, 0, 0, 0, w, h);
    pixman_image_composite32(PIXMAN_OP_OVER, src, msk, dst, r & 127, (r * 3) & 127, (r * 5) & 127, (r * 7) & 127, 0, 0, w, h);
  }

out:
  if (src) pixman_image_unref(src);
  if (dst) pixman_image_unref(dst);
  if (msk) pixman_image_unref(msk);
  free(sbits);
  free(dbits);
  free(mbits);
}

static void pass_transform(unsigned rounds) {
  uint32_t *sbits = NULL, *dbits = NULL;
  int ss = 0, ds = 0;
  pixman_image_t *src = mkbits(PIXMAN_a8r8g8b8, 1024, 1024, 0x44444444u, &sbits, &ss);
  pixman_image_t *dst = mkbits(PIXMAN_x8r8g8b8, 1920, 1080, 0x55555555u, &dbits, &ds);
  pixman_transform_t t;
  unsigned r;

  if (!src || !dst) goto out;
  pixman_image_set_repeat(src, PIXMAN_REPEAT_PAD);
  pixman_image_set_filter(src, PIXMAN_FILTER_BILINEAR, NULL, 0);

  for (r = 0; r < rounds; ++r) {
    memset(&t, 0, sizeof(t));
    t.matrix[0][0] = pixman_double_to_fixed(0.53);
    t.matrix[0][1] = pixman_double_to_fixed(0.09);
    t.matrix[0][2] = pixman_double_to_fixed((double)(r & 31));
    t.matrix[1][0] = pixman_double_to_fixed(-0.04);
    t.matrix[1][1] = pixman_double_to_fixed(0.57);
    t.matrix[1][2] = pixman_double_to_fixed((double)((r * 3) & 31));
    t.matrix[2][2] = pixman_int_to_fixed(1);
    pixman_image_set_transform(src, &t);
    pixman_image_composite32(PIXMAN_OP_OVER, src, NULL, dst, 0, 0, 0, 0, 0, 0, 1920, 1080);
  }

out:
  if (src) pixman_image_unref(src);
  if (dst) pixman_image_unref(dst);
  free(sbits);
  free(dbits);
}

static void pass_masks(unsigned rounds) {
  uint32_t *sbits = NULL, *dbits = NULL, *mbits = NULL;
  int ss = 0, ds = 0, ms = 0;
  pixman_image_t *src = mkbits(PIXMAN_a8r8g8b8, 1024, 768, 0xa1a1a1a1u, &sbits, &ss);
  pixman_image_t *dst = mkbits(PIXMAN_a8r8g8b8, 1024, 768, 0xb2b2b2b2u, &dbits, &ds);
  pixman_image_t *msk = mkbits(PIXMAN_a8r8g8b8, 1024, 768, 0xc3c3c3c3u, &mbits, &ms);
  unsigned r;

  if (!src || !dst || !msk) goto out;
  pixman_image_set_repeat(src, PIXMAN_REPEAT_NORMAL);
  pixman_image_set_repeat(msk, PIXMAN_REPEAT_NORMAL);
  pixman_image_set_component_alpha(msk, 1);

  for (r = 0; r < rounds; ++r) {
    pixman_image_composite32(PIXMAN_OP_OVER, src, msk, dst,
                             (r * 11) & 127, (r * 13) & 127,
                             (r * 17) & 127, (r * 19) & 127,
                             0, 0, 1024, 768);
  }

out:
  if (src) pixman_image_unref(src);
  if (dst) pixman_image_unref(dst);
  if (msk) pixman_image_unref(msk);
  free(sbits);
  free(dbits);
  free(mbits);
}

static void pass_gradients(unsigned rounds) {
  uint32_t *dbits = NULL;
  int ds = 0;
  pixman_image_t *dst = mkbits(PIXMAN_x8r8g8b8, 1280, 720, 0xd4d4d4d4u, &dbits, &ds);
  pixman_gradient_stop_t stops[3];
  pixman_point_fixed_t p1, p2;
  pixman_image_t *lin = NULL;
  unsigned r;

  if (!dst) goto out;

  stops[0].x = pixman_int_to_fixed(0);
  stops[0].color = (pixman_color_t){0xffffu, 0xffffu, 0x0000u, 0x0000u};
  stops[1].x = pixman_int_to_fixed(1) / 2;
  stops[1].color = (pixman_color_t){0xffffu, 0x0000u, 0xffffu, 0x0000u};
  stops[2].x = pixman_int_to_fixed(1);
  stops[2].color = (pixman_color_t){0xffffu, 0x0000u, 0x0000u, 0xffffu};

  p1.x = pixman_int_to_fixed(0);
  p1.y = pixman_int_to_fixed(0);
  p2.x = pixman_int_to_fixed(1280);
  p2.y = pixman_int_to_fixed(720);

  lin = pixman_image_create_linear_gradient(&p1, &p2, stops, 3);
  if (!lin) goto out;
  pixman_image_set_repeat(lin, PIXMAN_REPEAT_PAD);

  for (r = 0; r < rounds; ++r) {
    pixman_image_composite32(PIXMAN_OP_SRC, lin, NULL, dst,
                             0, 0, 0, 0, 0, 0, 1280, 720);
  }

out:
  if (lin) pixman_image_unref(lin);
  if (dst) pixman_image_unref(dst);
  free(dbits);
}

static void pass_fills(unsigned rounds) {
  uint32_t *bits = NULL;
  int stride = 1920 * 4;
  size_t bytes = (size_t)stride * 1080u;
  unsigned r;

  bits = malloc(bytes);
  if (!bits) return;
  memset(bits, 0, bytes);

  for (r = 0; r < rounds; ++r) {
    pixman_fill(bits, stride / 4, 32, 0, 0, 1920, 1080, 0xff204060u);
    pixman_fill(bits, stride / 4, 32, 100, 100, 900, 600, 0x80a0b0c0u);
    pixman_fill(bits, stride / 4, 32, 256, 256, 640, 360, 0x00000000u);
  }

  free(bits);
}

static void pass_regions(unsigned rounds) {
  uint32_t *sbits = NULL, *dbits = NULL;
  int ss = 0, ds = 0;
  pixman_image_t *src = mkbits(PIXMAN_a8r8g8b8, 1280, 720, 0x66666666u, &sbits, &ss);
  pixman_image_t *dst = mkbits(PIXMAN_x8r8g8b8, 1280, 720, 0x77777777u, &dbits, &ds);
  pixman_box32_t a[] = {{0, 0, 360, 240}, {420, 120, 980, 460}, {160, 360, 900, 680}};
  pixman_box32_t b[] = {{48, 64, 300, 500}, {520, 80, 1180, 620}};
  pixman_region32_t r1, r2, r3;
  unsigned r;

  if (!src || !dst) goto out;
  pixman_region32_init_rects(&r1, a, 3);
  pixman_region32_init_rects(&r2, b, 2);
  pixman_region32_init(&r3);

  for (r = 0; r < rounds; ++r) {
    pixman_region32_union(&r3, &r1, &r2);
    pixman_image_set_clip_region32(dst, &r3);
    pixman_image_composite32(PIXMAN_OP_OVER, src, NULL, dst, 0, 0, 0, 0, 0, 0, 1280, 720);
    pixman_region32_intersect(&r3, &r1, &r2);
    pixman_image_set_clip_region32(dst, &r3);
    pixman_image_composite32(PIXMAN_OP_OVER, src, NULL, dst, 32, 16, 0, 0, 64, 32, 960, 540);
  }

  pixman_image_set_clip_region32(dst, NULL);
  pixman_region32_fini(&r3);
  pixman_region32_fini(&r2);
  pixman_region32_fini(&r1);

out:
  if (src) pixman_image_unref(src);
  if (dst) pixman_image_unref(dst);
  free(sbits);
  free(dbits);
}

static void pass_formats(unsigned rounds) {
  uint32_t *abits = NULL, *xbits = NULL, *f565 = NULL;
  int sa = 0, sx = 0, s565 = 640 * 2;
  pixman_image_t *srca = mkbits(PIXMAN_a8r8g8b8, 640, 480, 0x88888888u, &abits, &sa);
  pixman_image_t *dstx = mkbits(PIXMAN_x8r8g8b8, 640, 480, 0x99999999u, &xbits, &sx);
  pixman_image_t *src565 = NULL;
  unsigned r;
  size_t i, words;

  if (!srca || !dstx) goto out;
  f565 = malloc((size_t)s565 * 480u);
  if (!f565) goto out;
  words = ((size_t)s565 * 480u) / 4u;
  for (i = 0; i < words; ++i) f565[i] = 0x7bef7befu ^ (uint32_t)i;
  src565 = pixman_image_create_bits(PIXMAN_r5g6b5, 640, 480, f565, s565);
  if (!src565) goto out;

  for (r = 0; r < rounds; ++r) {
    pixman_image_composite32(PIXMAN_OP_SRC, srca, NULL, dstx, 0, 0, 0, 0, 0, 0, 640, 480);
    pixman_image_composite32(PIXMAN_OP_OVER, srca, NULL, dstx, 0, 0, 0, 0, 0, 0, 640, 480);
    pixman_image_composite32(PIXMAN_OP_SRC, src565, NULL, dstx, 0, 0, 0, 0, 0, 0, 640, 480);
  }

out:
  if (srca) pixman_image_unref(srca);
  if (dstx) pixman_image_unref(dstx);
  if (src565) pixman_image_unref(src565);
  free(abits);
  free(xbits);
  free(f565);
}

int main(int argc, char **argv) {
  const char *mode = argc > 1 ? argv[1] : "all";
  if (!strcmp(mode, "hot")) {
    pass_composite(6u, 1920, 1080);
    pass_masks(4u);
    pass_transform(4u);
    pass_regions(4u);
    pass_gradients(3u);
    pass_fills(3u);
  } else if (!strcmp(mode, "all")) {
    pass_composite(4u, 1280, 720);
    pass_composite(3u, 1920, 1080);
    pass_masks(3u);
    pass_transform(3u);
    pass_regions(3u);
    pass_gradients(3u);
    pass_fills(3u);
    pass_formats(3u);
  } else if (!strcmp(mode, "masks")) {
    pass_masks(5u);
  } else if (!strcmp(mode, "gradients")) {
    pass_gradients(5u);
  } else if (!strcmp(mode, "fills")) {
    pass_fills(6u);
  } else if (!strcmp(mode, "transform")) {
    pass_transform(5u);
  } else if (!strcmp(mode, "regions")) {
    pass_regions(5u);
  } else if (!strcmp(mode, "composite")) {
    pass_composite(5u, 1920, 1080);
  } else {
    pass_formats(4u);
    pass_masks(2u);
    pass_composite(2u, 1024, 768);
  }
  printf("pixman trainer %d\n", pixman_version());
  return 0;
}
EOF
}

_meson_setup() {
  local builddir="$1"
  rm -rf "${builddir}"
  meson setup "${builddir}" "${srcdir}/pixman" \
    --prefix=/usr \
    --buildtype=plain \
    --wrap-mode=nofallback \
    "${_meson_opts[@]}"
}

_compile_trainer() {
  local out="$1"
  local builddir="$2"

  clang ${_base_cflags} ${_base_ldflags} \
    -I"${srcdir}/pixman/pixman" \
    -I"${builddir}/pixman" \
    -L"${builddir}/pixman" \
    -Wl,-rpath,"${builddir}/pixman" \
    -o "${out}" "${_pgo_dir}/pixman_train.c" \
    -lpixman-1
}

_run_profiled() {
  local profile_dir="$1"
  shift
  LLVM_PROFILE_FILE="${profile_dir}/%p-%m.profraw" LLVM_PROFILE_MERGE_POOL_SIZE=8 "$@" || true
}

_run_training_set() {
  local builddir="$1"
  local trainer="$2"
  local profile_dir="$3"
  local mode="$4"
  local disable_impl="$5"
  local env_args=(env LD_LIBRARY_PATH="${builddir}/pixman")

  [[ -n "${disable_impl}" ]] && env_args+=(PIXMAN_DISABLE="${disable_impl}")
  mkdir -p "${profile_dir}"
  rm -f "${profile_dir}"/*.profraw

  local trainer_passes=3
  local -a cmds=("${mode}" all hot composite masks transform regions gradients fills formats)
  local pass cmd

  for ((pass = 0; pass < trainer_passes; ++pass)); do
    for cmd in "${cmds[@]}"; do
      _run_profiled "${profile_dir}" "${env_args[@]}" "${trainer}" "${cmd}" >/dev/null 2>&1
    done
  done

  LLVM_PROFILE_FILE="${profile_dir}/%p-%m.profraw" LLVM_PROFILE_MERGE_POOL_SIZE=8 \
    "${env_args[@]}" meson test -C "${builddir}" --no-rebuild --print-errorlogs --num-processes 1 || true

  LLVM_PROFILE_FILE="${profile_dir}/%p-%m.profraw" LLVM_PROFILE_MERGE_POOL_SIZE=8 \
    "${env_args[@]}" meson test -C "${builddir}" --no-rebuild --print-errorlogs --num-processes 1 || true
}

_merge_weighted_profile_dirs() {
  local out="$1"
  shift
  local spec dir weight f
  local -a args=()
  local -a files=()

  for spec in "$@"; do
    weight="${spec%%:*}"
    dir="${spec#*:}"
    files=()
    shopt -s nullglob
    files=("${dir}"/*.profraw)
    shopt -u nullglob
    for f in "${files[@]}"; do
      args+=("--weighted-input=${weight},${f}")
    done
  done

  (( ${#args[@]} > 0 )) || return 1
  llvm-profdata merge -output="${out}" "${args[@]}"
}

pkgver() {
  cd "${srcdir}/pixman"
  git describe --long --tags | sed 's/^[_a-z]*\([0-9.]*\)[^-]*/\1/;s/\([^-]*-g\)/r\1/;s/-/./g;s/^\.//'
}

prepare() {
  rm -rf "${srcdir}/_build_std_pgo" "${srcdir}/_build_cs_pgo" "${srcdir}/_build_opt" "${srcdir}/pixman-pgo"
  _apply_patch_auto "${srcdir}/avx2-modern.patch"
}

build() {
  export CC=clang
  export CXX=clang++
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  _base_cflags="${CFLAGS}"
  _base_cxxflags="${CXXFLAGS}"
  _base_ldflags="${LDFLAGS}"

  _pgo_dir="${srcdir}/pixman-pgo"
  local std_raw_hot="${_pgo_dir}/std-hot"
  local std_raw_mix="${_pgo_dir}/std-mix"
  local std_raw_generic="${_pgo_dir}/std-generic"
  local cs_raw_hot="${_pgo_dir}/cs-hot"
  local cs_raw_mix="${_pgo_dir}/cs-mix"
  local std_prof="${_pgo_dir}/standard.profdata"
  local cs_prof="${_pgo_dir}/cs.profdata"
  local merged_prof="${_pgo_dir}/merged.profdata"

  local build_std="${srcdir}/_build_std_pgo"
  local build_cs="${srcdir}/_build_cs_pgo"
  local build_opt="${srcdir}/_build_opt"

  local vp_flags="-mllvm -enable-value-profiling -mllvm -vp-counters-per-site=1024"

  _meson_opts=(
    -Dtests=enabled
    -Dgtk=disabled
    -Dtls=enabled
    -Davx2=enabled
    -Dsse2=enabled
    -Dssse3=enabled
    -Dloongson-mmi=disabled
    -Da64-neon=disabled
    -Drvv=disabled
    -Dvmx=disabled
    -Darm-simd=disabled
    -Dneon=disabled
    -Dmips-dspr2=disabled
  )

  rm -rf "${_pgo_dir}" "${build_std}" "${build_cs}" "${build_opt}"
  mkdir -p "${_pgo_dir}" "${std_raw_hot}" "${std_raw_mix}" "${std_raw_generic}" "${cs_raw_hot}" "${cs_raw_mix}"
  _create_trainer_source "${_pgo_dir}/pixman_train.c"

  msg2 "Phase 1: standard PGO instrumentation"
  export CFLAGS="${_base_cflags} -fprofile-generate=${std_raw_hot} ${vp_flags}"
  export CXXFLAGS="${_base_cxxflags} -fprofile-generate=${std_raw_hot} ${vp_flags}"
  export LDFLAGS="${_base_ldflags} -fprofile-generate=${std_raw_hot}"

  _meson_setup "${build_std}"
  ninja -C "${build_std}"
  _compile_trainer "${_pgo_dir}/pixman_train_std" "${build_std}"
  _run_training_set "${build_std}" "${_pgo_dir}/pixman_train_std" "${std_raw_hot}" hot ""

  export CFLAGS="${_base_cflags} -fprofile-generate=${std_raw_mix} ${vp_flags}"
  export CXXFLAGS="${_base_cxxflags} -fprofile-generate=${std_raw_mix} ${vp_flags}"
  export LDFLAGS="${_base_ldflags} -fprofile-generate=${std_raw_mix}"
  _run_training_set "${build_std}" "${_pgo_dir}/pixman_train_std" "${std_raw_mix}" all ""

  export CFLAGS="${_base_cflags} -fprofile-generate=${std_raw_generic} ${vp_flags}"
  export CXXFLAGS="${_base_cxxflags} -fprofile-generate=${std_raw_generic} ${vp_flags}"
  export LDFLAGS="${_base_ldflags} -fprofile-generate=${std_raw_generic}"
  _run_training_set "${build_std}" "${_pgo_dir}/pixman_train_std" "${std_raw_generic}" formats "mmx,sse2,ssse3,avx2"

  _merge_weighted_profile_dirs "${std_prof}" \
    "9:${std_raw_hot}" \
    "4:${std_raw_mix}" \
    "1:${std_raw_generic}" || {
      error "No standard PGO profile data collected"
      return 1
    }

  msg2 "Phase 2: CS-PGO instrumentation"
  export CFLAGS="${_base_cflags} -fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw_hot} ${vp_flags} -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export CXXFLAGS="${_base_cxxflags} -fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw_hot} ${vp_flags} -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export LDFLAGS="${_base_ldflags} -fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw_hot}"

  _meson_setup "${build_cs}"
  ninja -C "${build_cs}"
  _compile_trainer "${_pgo_dir}/pixman_train_cs" "${build_cs}"
  _run_training_set "${build_cs}" "${_pgo_dir}/pixman_train_cs" "${cs_raw_hot}" hot ""

  export CFLAGS="${_base_cflags} -fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw_mix} ${vp_flags} -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export CXXFLAGS="${_base_cxxflags} -fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw_mix} ${vp_flags} -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export LDFLAGS="${_base_ldflags} -fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw_mix}"
  _run_training_set "${build_cs}" "${_pgo_dir}/pixman_train_cs" "${cs_raw_mix}" all ""

  _merge_weighted_profile_dirs "${cs_prof}" \
    "8:${cs_raw_hot}" \
    "3:${cs_raw_mix}" || {
      error "No CS-PGO profile data collected"
      return 1
    }

  llvm-profdata merge -output="${merged_prof}" "${std_prof}" "${cs_prof}"

  msg2 "Phase 3: final optimized build"
  export CFLAGS="${_base_cflags} -fprofile-use=${merged_prof} -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export CXXFLAGS="${_base_cxxflags} -fprofile-use=${merged_prof} -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export LDFLAGS="${_base_ldflags} -fprofile-use=${merged_prof}"

  _meson_setup "${build_opt}"
  ninja -C "${build_opt}"

  msg2 "Phase 4: verification"
  _compile_trainer "${_pgo_dir}/pixman_train_opt" "${build_opt}"
  env LD_LIBRARY_PATH="${build_opt}/pixman" "${_pgo_dir}/pixman_train_opt" hot >/dev/null
  env LD_LIBRARY_PATH="${build_opt}/pixman" "${_pgo_dir}/pixman_train_opt" all >/dev/null

  export CFLAGS="${_base_cflags}"
  export CXXFLAGS="${_base_cxxflags}"
  export LDFLAGS="${_base_ldflags}"
}

check() {
  [[ -d "${srcdir}/_build_opt" ]] || return 0
  meson test -C "${srcdir}/_build_opt" --no-rebuild --print-errorlogs --num-processes 1
}

package() {
  meson install -C "${srcdir}/_build_opt" --destdir "${pkgdir}"
  install -Dm644 "${srcdir}/pixman/COPYING" "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}
