_apply_patch_auto() {
  local patchfile="$1"
  local root p
  local roots=(
    "${srcdir}/pixman"
    "${srcdir}"
  )

  [[ -f "${patchfile}" ]] || {
    error "Patch file not found: ${patchfile}"
    return 1
  }

  for root in "${roots[@]}"; do
    [[ -d "${root}" ]] || continue

    for p in 0 1 2 3 4 5 6 7 8; do
      if patch \
        --batch \
        --forward \
        --silent \
        --dry-run \
        -d "${root}" \
        -p"${p}" \
        -i "${patchfile}" >/dev/null 2>&1; then
        msg2 "Applying patch: $(basename "${patchfile}") (root=$(basename "${root}"), -p${p})"
        patch \
          --batch \
          --forward \
          -d "${root}" \
          -p"${p}" \
          -i "${patchfile}"
        return 0
      fi
    done
  done

  error "Failed to determine patch strip level for ${patchfile}"
  return 1
}

_create_trainer_source() {
  cat > "${1}" << 'EOF'
/*
 * pixman PGO trainer — desktop gaming workload
 *
 * Exercises the hot paths that X11/Wayland compositors and game overlays
 * use most: OVER compositing with a8r8g8b8 and a8 masks, bilinear scaling
 * between common resolutions, affine transforms, solid fills, region
 * clip operations, component-alpha blending, gradients, format conversions.
 *
 * All surfaces use deterministic PRNG content for profile stability.
 */

#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <pixman.h>

#define ARRAY_SIZE(a) (sizeof(a) / sizeof((a)[0]))

static uint32_t xs32(uint32_t *state) {
    uint32_t x = *state;
    x ^= x << 13;
    x ^= x >> 17;
    x ^= x << 5;
    *state = x ? x : 0x9e3779b9u;
    return *state;
}

struct surface32 {
    pixman_image_t *image;
    uint32_t *bits;
    int stride;
    int width;
    int height;
};

struct surface8 {
    pixman_image_t *image;
    uint8_t *bits;
    int stride;
    int width;
    int height;
};

static void fill_u32(uint32_t *ptr, size_t n, uint32_t seed) {
    size_t i;
    for (i = 0; i < n; ++i)
        ptr[i] = xs32(&seed);
}

static void fill_u8(uint8_t *ptr, size_t n, uint32_t seed) {
    size_t i;
    for (i = 0; i < n; ++i)
        ptr[i] = (uint8_t)(xs32(&seed) & 0xffu);
}

static struct surface32 make_surface32(pixman_format_code_t fmt,
                                       int width, int height, uint32_t seed) {
    struct surface32 s;
    size_t bytes;

    memset(&s, 0, sizeof(s));
    s.width  = width;
    s.height = height;
    s.stride = width * 4;
    bytes    = (size_t)s.stride * (size_t)height;

    s.bits = (uint32_t *)malloc(bytes);
    if (!s.bits)
        return s;

    fill_u32(s.bits, bytes / 4u, seed);
    s.image = pixman_image_create_bits(fmt, width, height, s.bits, s.stride);
    if (!s.image) {
        free(s.bits);
        memset(&s, 0, sizeof(s));
    }
    return s;
}

static struct surface8 make_surface8(int width, int height, uint32_t seed) {
    struct surface8 s;
    size_t bytes;

    memset(&s, 0, sizeof(s));
    s.width  = width;
    s.height = height;
    s.stride = (width + 3) & ~3;
    bytes    = (size_t)s.stride * (size_t)height;

    s.bits = (uint8_t *)malloc(bytes);
    if (!s.bits)
        return s;

    fill_u8(s.bits, bytes, seed);
    s.image = pixman_image_create_bits(PIXMAN_a8, width, height,
                                       (uint32_t *)s.bits, s.stride);
    if (!s.image) {
        free(s.bits);
        memset(&s, 0, sizeof(s));
    }
    return s;
}

static void destroy_surface32(struct surface32 *s) {
    if (!s) return;
    if (s->image) pixman_image_unref(s->image);
    free(s->bits);
    memset(s, 0, sizeof(*s));
}

static void destroy_surface8(struct surface8 *s) {
    if (!s) return;
    if (s->image) pixman_image_unref(s->image);
    free(s->bits);
    memset(s, 0, sizeof(*s));
}

static pixman_image_t *make_solid(uint16_t a, uint16_t r,
                                   uint16_t g, uint16_t b) {
    pixman_color_t c;
    c.alpha = a;
    c.red   = r;
    c.green = g;
    c.blue  = b;
    return pixman_image_create_solid_fill(&c);
}

static void set_affine(pixman_transform_t *t,
                       double xx, double xy, double x0,
                       double yx, double yy, double y0) {
    memset(t, 0, sizeof(*t));
    t->matrix[0][0] = pixman_double_to_fixed(xx);
    t->matrix[0][1] = pixman_double_to_fixed(xy);
    t->matrix[0][2] = pixman_double_to_fixed(x0);
    t->matrix[1][0] = pixman_double_to_fixed(yx);
    t->matrix[1][1] = pixman_double_to_fixed(yy);
    t->matrix[1][2] = pixman_double_to_fixed(y0);
    t->matrix[2][2] = pixman_double_to_fixed(1.0);
}

/* pass_ui — tiled OVER-blits with a8 mask (font/icon rendering) */
static void pass_ui(unsigned rounds) {
    struct surface32 src  = make_surface32(PIXMAN_a8r8g8b8, 512, 512, 0x11111111u);
    struct surface8  mask = make_surface8(512, 512, 0x22222222u);
    struct surface32 dst  = make_surface32(PIXMAN_x8r8g8b8, 1280, 720, 0x33333333u);
    pixman_image_t  *solid = make_solid(0xffffu, 0x0800u, 0x1000u, 0x1800u);
    unsigned r;
    int x, y;

    if (!src.image || !mask.image || !dst.image || !solid)
        goto out;

    pixman_image_set_repeat(src.image, PIXMAN_REPEAT_NORMAL);
    pixman_image_set_repeat(mask.image, PIXMAN_REPEAT_NORMAL);

    for (r = 0; r < rounds; ++r) {
        pixman_image_composite32(PIXMAN_OP_SRC, solid, NULL, dst.image,
                                 0, 0, 0, 0, 0, 0, dst.width, dst.height);

        for (y = 0; y < dst.height; y += 96) {
            for (x = 0; x < dst.width; x += 128) {
                pixman_image_composite32(PIXMAN_OP_OVER,
                    src.image, mask.image, dst.image,
                    (x + (int)r * 13) & 255, (y + (int)r * 7) & 255,
                    (x + (int)r * 5) & 255,  (y + (int)r * 3) & 255,
                    x, y, 96, 96);
            }
        }
    }

out:
    if (solid) pixman_image_unref(solid);
    destroy_surface32(&src);
    destroy_surface8(&mask);
    destroy_surface32(&dst);
}

/* pass_masks — component-alpha a8r8g8b8 mask (subpixel text, glass) */
static void pass_masks(unsigned rounds) {
    struct surface32 src  = make_surface32(PIXMAN_a8r8g8b8, 256, 256, 0x44444444u);
    struct surface32 mask = make_surface32(PIXMAN_a8r8g8b8, 256, 256, 0x55555555u);
    struct surface32 dst  = make_surface32(PIXMAN_a8r8g8b8, 1280, 720, 0x66666666u);
    pixman_image_t  *solid = make_solid(0xffffu, 0x2000u, 0x2800u, 0x3000u);
    unsigned r;
    int x, y;

    if (!src.image || !mask.image || !dst.image || !solid)
        goto out;

    pixman_image_set_repeat(src.image, PIXMAN_REPEAT_NORMAL);
    pixman_image_set_repeat(mask.image, PIXMAN_REPEAT_NORMAL);
    pixman_image_set_component_alpha(mask.image, 1);

    for (r = 0; r < rounds; ++r) {
        pixman_image_composite32(PIXMAN_OP_SRC, solid, NULL, dst.image,
                                 0, 0, 0, 0, 0, 0, dst.width, dst.height);

        for (y = 0; y < dst.height; y += 72) {
            for (x = 0; x < dst.width; x += 72) {
                pixman_image_composite32(PIXMAN_OP_OVER,
                    src.image, mask.image, dst.image,
                    (x + (int)r * 11) & 127, (y + (int)r * 17) & 127,
                    (x + (int)r * 19) & 127, (y + (int)r * 23) & 127,
                    x, y, 64, 64);
            }
        }
    }

out:
    if (solid) pixman_image_unref(solid);
    destroy_surface32(&src);
    destroy_surface32(&mask);
    destroy_surface32(&dst);
}

/* pass_scale — bilinear+nearest scaling 720p<->1080p */
static void pass_scale(unsigned rounds) {
    struct surface32 src_up   = make_surface32(PIXMAN_a8r8g8b8, 1280, 720,  0x77777777u);
    struct surface32 dst_up   = make_surface32(PIXMAN_x8r8g8b8, 1920, 1080, 0x88888888u);
    struct surface32 src_down = make_surface32(PIXMAN_a8r8g8b8, 1920, 1080, 0x99999999u);
    struct surface32 dst_down = make_surface32(PIXMAN_x8r8g8b8, 1280, 720,  0xaaaaaaaau);
    pixman_transform_t t_up, t_down;
    unsigned r;

    if (!src_up.image || !dst_up.image || !src_down.image || !dst_down.image)
        goto out;

    set_affine(&t_up,
               (double)src_up.width / (double)dst_up.width,     0.0, 0.0,
               0.0, (double)src_up.height / (double)dst_up.height, 0.0);
    set_affine(&t_down,
               (double)src_down.width / (double)dst_down.width,       0.0, 0.0,
               0.0, (double)src_down.height / (double)dst_down.height, 0.0);

    (void)pixman_image_set_transform(src_up.image,   &t_up);
    (void)pixman_image_set_transform(src_down.image, &t_down);

    for (r = 0; r < rounds; ++r) {
        (void)pixman_image_set_filter(src_up.image, PIXMAN_FILTER_BILINEAR, NULL, 0);
        pixman_image_composite32(PIXMAN_OP_SRC, src_up.image, NULL, dst_up.image,
                                 0, 0, 0, 0, 0, 0, dst_up.width, dst_up.height);

        (void)pixman_image_set_filter(src_up.image, PIXMAN_FILTER_NEAREST, NULL, 0);
        pixman_image_composite32(PIXMAN_OP_OVER, src_up.image, NULL, dst_up.image,
                                 0, 0, 0, 0, 0, 0, dst_up.width, dst_up.height);

        (void)pixman_image_set_filter(src_down.image, PIXMAN_FILTER_BILINEAR, NULL, 0);
        pixman_image_composite32(PIXMAN_OP_SRC, src_down.image, NULL, dst_down.image,
                                 0, 0, 0, 0, 0, 0, dst_down.width, dst_down.height);

        (void)pixman_image_set_filter(src_down.image, PIXMAN_FILTER_NEAREST, NULL, 0);
        pixman_image_composite32(PIXMAN_OP_OVER, src_down.image, NULL, dst_down.image,
                                 0, 0, 0, 0, 0, 0, dst_down.width, dst_down.height);
    }

out:
    destroy_surface32(&src_up);
    destroy_surface32(&dst_up);
    destroy_surface32(&src_down);
    destroy_surface32(&dst_down);
}

/* pass_transform — affine rotation/skew with bilinear + PAD repeat */
static void pass_transform(unsigned rounds) {
    struct surface32 src = make_surface32(PIXMAN_a8r8g8b8, 512, 512,  0xbbbbbbbbu);
    struct surface32 dst = make_surface32(PIXMAN_x8r8g8b8, 1024, 768, 0xccccccccu);
    pixman_transform_t t;
    unsigned r;

    if (!src.image || !dst.image)
        goto out;

    pixman_image_set_repeat(src.image, PIXMAN_REPEAT_PAD);
    (void)pixman_image_set_filter(src.image, PIXMAN_FILTER_BILINEAR, NULL, 0);

    for (r = 0; r < rounds; ++r) {
        set_affine(&t,
                    0.55,  0.12, 12.0 + (double)r * 2.0,
                   -0.07,  0.58,  8.0 + (double)r * 1.5);
        (void)pixman_image_set_transform(src.image, &t);

        pixman_image_composite32(PIXMAN_OP_OVER, src.image, NULL, dst.image,
                                 0, 0, 0, 0, 0, 0, dst.width, dst.height);
    }

out:
    destroy_surface32(&src);
    destroy_surface32(&dst);
}

/*
 * pass_regions — region algebra with clip-region compositing.
 * pixman_region32_init_rects takes pixman_box32_t {x1,y1,x2,y2}.
 */
static void pass_regions(unsigned rounds) {
    struct surface32 src = make_surface32(PIXMAN_a8r8g8b8, 1024, 768, 0xddddddddu);
    struct surface32 dst = make_surface32(PIXMAN_x8r8g8b8, 1024, 768, 0xeeeeeeeeu);
    pixman_image_t *solid = make_solid(0xffffu, 0x5000u, 0x3800u, 0x1800u);

    pixman_box32_t boxes_a[] = {
        {   0,   0, 420, 220 },
        { 120, 160, 480, 420 },
        { 520, 260, 840, 480 },
        { 300, 480, 700, 660 }
    };
    pixman_box32_t boxes_b[] = {
        {  80,  40, 380, 340 },
        { 460, 120, 740, 480 },
        { 260, 340, 760, 560 }
    };

    pixman_region32_t a, b, c;
    unsigned r;

    if (!src.image || !dst.image || !solid)
        goto out_no_regions;

    pixman_region32_init_rects(&a, boxes_a, ARRAY_SIZE(boxes_a));
    pixman_region32_init_rects(&b, boxes_b, ARRAY_SIZE(boxes_b));
    pixman_region32_init(&c);

    for (r = 0; r < rounds; ++r) {
        pixman_image_composite32(PIXMAN_OP_SRC, solid, NULL, dst.image,
                                 0, 0, 0, 0, 0, 0, dst.width, dst.height);

        pixman_region32_union(&c, &a, &b);
        pixman_image_set_clip_region32(dst.image, &c);
        pixman_image_composite32(PIXMAN_OP_OVER, src.image, NULL, dst.image,
                                 0, 0, 0, 0, 0, 0, dst.width, dst.height);

        pixman_region32_intersect(&c, &a, &b);
        pixman_image_set_clip_region32(dst.image, &c);
        pixman_image_composite32(PIXMAN_OP_OVER, src.image, NULL, dst.image,
                                 64, 32, 0, 0, 32, 48, 768, 512);

        pixman_region32_subtract(&c, &a, &b);
        pixman_image_set_clip_region32(dst.image, &c);
        pixman_image_composite32(PIXMAN_OP_OVER, src.image, NULL, dst.image,
                                 16, 24, 0, 0, 96, 96, 640, 480);
    }

    pixman_image_set_clip_region32(dst.image, NULL);
    pixman_region32_fini(&c);
    pixman_region32_fini(&b);
    pixman_region32_fini(&a);

out_no_regions:
    if (solid) pixman_image_unref(solid);
    destroy_surface32(&src);
    destroy_surface32(&dst);
}

/* pass_gradients — linear + radial gradient sources */
static void pass_gradients(unsigned rounds) {
    struct surface32 dst = make_surface32(PIXMAN_x8r8g8b8, 1280, 720, 0xf0f0f0f0u);
    pixman_gradient_stop_t stops[3];
    pixman_point_fixed_t p1, p2;
    pixman_point_fixed_t inner, outer;
    pixman_fixed_t r_inner, r_outer;
    pixman_image_t *lin = NULL;
    pixman_image_t *rad = NULL;
    unsigned r;

    if (!dst.image)
        goto out;

    stops[0].x     = pixman_int_to_fixed(0);
    stops[0].color = (pixman_color_t){ 0xffffu, 0xffffu, 0x0000u, 0x0000u };
    stops[1].x     = pixman_int_to_fixed(1) / 2;
    stops[1].color = (pixman_color_t){ 0xffffu, 0x0000u, 0xffffu, 0x0000u };
    stops[2].x     = pixman_int_to_fixed(1);
    stops[2].color = (pixman_color_t){ 0xffffu, 0x0000u, 0x0000u, 0xffffu };

    p1.x = pixman_int_to_fixed(0);
    p1.y = pixman_int_to_fixed(0);
    p2.x = pixman_int_to_fixed(dst.width);
    p2.y = pixman_int_to_fixed(dst.height);

    lin = pixman_image_create_linear_gradient(&p1, &p2, stops, ARRAY_SIZE(stops));
    if (!lin)
        goto out;

    inner.x = pixman_int_to_fixed(dst.width / 2);
    inner.y = pixman_int_to_fixed(dst.height / 2);
    outer   = inner;
    r_inner = pixman_int_to_fixed(0);
    r_outer = pixman_int_to_fixed(dst.width / 2);

    rad = pixman_image_create_radial_gradient(&inner, &outer,
                                               r_inner, r_outer,
                                               stops, ARRAY_SIZE(stops));
    if (!rad)
        goto out;

    pixman_image_set_repeat(lin, PIXMAN_REPEAT_PAD);
    pixman_image_set_repeat(rad, PIXMAN_REPEAT_PAD);

    for (r = 0; r < rounds; ++r) {
        pixman_image_composite32(PIXMAN_OP_SRC, lin, NULL, dst.image,
                                 0, 0, 0, 0, 0, 0, dst.width, dst.height);
        pixman_image_composite32(PIXMAN_OP_OVER, rad, NULL, dst.image,
                                 0, 0, 0, 0, 0, 0, dst.width, dst.height);
    }

out:
    if (rad) pixman_image_unref(rad);
    if (lin) pixman_image_unref(lin);
    destroy_surface32(&dst);
}

/* pass_fills — pixman_fill for solid rectangles */
static void pass_fills(unsigned rounds) {
    struct surface32 dst = make_surface32(PIXMAN_a8r8g8b8, 1920, 1080, 0x12345678u);
    unsigned r;

    if (!dst.image)
        return;

    for (r = 0; r < rounds; ++r) {
        pixman_fill(dst.bits, dst.stride / 4, 32,
                    0, 0, dst.width, dst.height, 0xff204060u);
        pixman_fill(dst.bits, dst.stride / 4, 32,
                    100, 100, 800, 600, 0x80a0b0c0u);
        pixman_fill(dst.bits, dst.stride / 4, 32,
                    200, 200, 400, 300, 0x00000000u);
    }

    destroy_surface32(&dst);
}

/* pass_formats — format conversion paths (r5g6b5 → a8r8g8b8, etc.) */
static void pass_formats(unsigned rounds) {
    struct surface32 src_argb = make_surface32(PIXMAN_a8r8g8b8, 640, 480, 0xabcdef01u);
    struct surface32 dst_xrgb = make_surface32(PIXMAN_x8r8g8b8, 640, 480, 0x01234567u);
    struct surface32 src_565;
    unsigned r;

    memset(&src_565, 0, sizeof(src_565));

    if (!src_argb.image || !dst_xrgb.image)
        goto out;

    src_565.width  = 640;
    src_565.height = 480;
    src_565.stride = 640 * 2;
    src_565.bits   = (uint32_t *)malloc((size_t)src_565.stride * (size_t)src_565.height);
    if (!src_565.bits)
        goto out;

    fill_u32(src_565.bits, ((size_t)src_565.stride * (size_t)src_565.height) / 4u, 0xdeadcafeu);
    src_565.image = pixman_image_create_bits(PIXMAN_r5g6b5,
                                              src_565.width, src_565.height,
                                              src_565.bits, src_565.stride);
    if (!src_565.image)
        goto out;

    for (r = 0; r < rounds; ++r) {
        pixman_image_composite32(PIXMAN_OP_SRC, src_argb.image, NULL, dst_xrgb.image,
                                 0, 0, 0, 0, 0, 0, 640, 480);
        pixman_image_composite32(PIXMAN_OP_OVER, src_argb.image, NULL, dst_xrgb.image,
                                 0, 0, 0, 0, 0, 0, 640, 480);
        pixman_image_composite32(PIXMAN_OP_SRC, src_565.image, NULL, dst_xrgb.image,
                                 0, 0, 0, 0, 0, 0, 640, 480);
        pixman_image_composite32(PIXMAN_OP_OVER, src_565.image, NULL, dst_xrgb.image,
                                 0, 0, 0, 0, 0, 0, 640, 480);
    }

out:
    destroy_surface32(&src_argb);
    destroy_surface32(&dst_xrgb);
    if (src_565.image) pixman_image_unref(src_565.image);
    free(src_565.bits);
}

static void run_all(void) {
    pass_ui(2u);
    pass_masks(2u);
    pass_scale(2u);
    pass_transform(2u);
    pass_regions(2u);
    pass_gradients(2u);
    pass_fills(3u);
    pass_formats(2u);
}

static void run_stress(void) {
    pass_ui(4u);
    pass_masks(3u);
    pass_scale(3u);
    pass_transform(3u);
    pass_regions(3u);
    pass_gradients(3u);
    pass_fills(4u);
    pass_formats(3u);
    pass_ui(2u);
    pass_scale(2u);
}

static void run_bench(void) {
    clock_t start = clock();
    pass_ui(2u);
    pass_scale(2u);
    pass_transform(2u);
    pass_masks(1u);
    pass_regions(1u);
    pass_gradients(1u);
    pass_fills(2u);
    pass_formats(1u);
    printf("pixman trainer %.6f\n",
           (double)(clock() - start) / (double)CLOCKS_PER_SEC);
}

int main(int argc, char **argv) {
    const char *cmd = (argc >= 2) ? argv[1] : "all";

    (void)pixman_version();

    if      (strcmp(cmd, "all")       == 0)  run_all();
    else if (strcmp(cmd, "ui")        == 0)  pass_ui(3u);
    else if (strcmp(cmd, "masks")     == 0)  pass_masks(3u);
    else if (strcmp(cmd, "scale")     == 0)  pass_scale(3u);
    else if (strcmp(cmd, "transform") == 0)  pass_transform(3u);
    else if (strcmp(cmd, "regions")   == 0)  pass_regions(3u);
    else if (strcmp(cmd, "gradients") == 0)  pass_gradients(3u);
    else if (strcmp(cmd, "fills")     == 0)  pass_fills(4u);
    else if (strcmp(cmd, "formats")   == 0)  pass_formats(3u);
    else if (strcmp(cmd, "stress")    == 0)  run_stress();
    else if (strcmp(cmd, "bench")     == 0)  run_bench();
    else                                     run_all();

    return 0;
}
EOF
}

_meson_setup() {
  local builddir="$1"

  rm -rf "${builddir}"
  meson setup "${builddir}" "${srcdir}/pixman" \
    --prefix=/usr \
    --buildtype=plain \
    --wrap-mode=nofallback \
    "${_meson_opts[@]}"
}

_compile_trainer() {
  local out="$1"
  local builddir="$2"

  clang ${_orig_cflags} ${_orig_ldflags} \
    -I"${srcdir}/pixman/pixman" \
    -I"${builddir}/pixman" \
    -L"${builddir}/pixman" \
    -Wl,-rpath,"${builddir}/pixman" \
    -o "${out}" "${_pgo_dir}/pixman_train.c" \
    -lpixman-1
}

_merge_profraw_dir() {
  local out="$1"
  local dir="$2"
  local profraws=()

  shopt -s nullglob
  profraws=("${dir}"/*.profraw)
  shopt -u nullglob

  (( ${#profraws[@]} > 0 )) || return 1
  llvm-profdata merge -output="${out}" "${profraws[@]}"
}

_run_profiled() {
  local profile_dir="$1"
  shift

  if [[ -n "${profile_dir}" ]]; then
    LLVM_PROFILE_FILE="${profile_dir}/%p-%m.profraw" "$@" || true
  else
    "$@" || true
  fi
}

run_profile_training() {
  local builddir="$1"
  local trainer="$2"
  local mode="$3"
  local profile_dir="$4"
  local trainer_passes=2
  local pass
  local cmds=(all ui masks scale transform regions gradients fills formats stress bench)

  [[ -x "${trainer}" ]] || return 1

  if [[ -n "${profile_dir}" ]]; then
    mkdir -p "${profile_dir}"
    rm -f "${profile_dir}"/*.profraw
  fi

  msg2 "Running custom pixman workload (${mode})..."
  for ((pass = 0; pass < trainer_passes; ++pass)); do
    local cmd
    for cmd in "${cmds[@]}"; do
      _run_profiled "${profile_dir}" env LD_LIBRARY_PATH="${builddir}/pixman" "${trainer}" "${cmd}" >/dev/null 2>&1
    done
  done

  msg2 "Running Meson tests (${mode})..."
  if [[ -n "${profile_dir}" ]]; then
    LLVM_PROFILE_FILE="${profile_dir}/%p-%m.profraw" \
      meson test -C "${builddir}" --no-rebuild --print-errorlogs --num-processes 1
  else
    meson test -C "${builddir}" --no-rebuild --print-errorlogs --num-processes 1
  fi
}

pkgver() {
  cd "${srcdir}/pixman"
  git describe --long --tags | sed 's/^[_a-z]*\([0-9.]*\)[^-]*/\1/;s/\([^-]*-g\)/r\1/;s/-/./g;s/^\.//'
}

prepare() {
  rm -rf \
    "${srcdir}/_build_std_pgo" \
    "${srcdir}/_build_cs_pgo" \
    "${srcdir}/_build_opt" \
    "${srcdir}/pixman-pgo"

  local src patchfile
  for src in "${source[@]}"; do
    src="${src%%::*}"
    src="${src##*/}"
    [[ "${src}" = *.patch ]] || continue
    patchfile="${srcdir}/${src}"
    _apply_patch_auto "${patchfile}" || return 1
  done
}

build() {
  export CC=clang
  export CXX=clang++
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  _orig_cflags="${CFLAGS}"
  _orig_cxxflags="${CXXFLAGS}"
  _orig_ldflags="${LDFLAGS}"

  _pgo_dir="${srcdir}/pixman-pgo"
  _std_profraw="${_pgo_dir}/standard"
  _cs_profraw="${_pgo_dir}/cs"
  _std_profdata="${_pgo_dir}/standard.profdata"
  _cs_profdata="${_pgo_dir}/cs.profdata"
  _merged_profdata="${_pgo_dir}/merged.profdata"

  local _build_std="${srcdir}/_build_std_pgo"
  local _build_cs="${srcdir}/_build_cs_pgo"
  local _build_opt="${srcdir}/_build_opt"

  _meson_opts=(
    -Dtests=enabled
    -Dgtk=disabled
    -Dtls=enabled
    -Davx2=enabled
    -Dsse2=enabled
    -Dssse3=enabled
    -Dloongson-mmi=disabled
    -Da64-neon=disabled
    -Drvv=disabled
    -Dvmx=disabled
    -Darm-simd=disabled
    -Dneon=disabled
    -Dmips-dspr2=disabled
  )

  local have_std_profile=0
  local have_cs_profile=0
  local final_profdata=''

  rm -rf "${_pgo_dir}" "${_build_std}" "${_build_cs}" "${_build_opt}"
  mkdir -p "${_std_profraw}" "${_cs_profraw}"

  _create_trainer_source "${_pgo_dir}/pixman_train.c"

  ###########################################################################
  # Phase 1: Standard PGO instrumentation
  ###########################################################################
  msg2 "Phase 1: Building with standard PGO instrumentation..."

  export CFLAGS="${_orig_cflags} -fprofile-generate=${_std_profraw} -fno-omit-frame-pointer -Xclang -mllvm -Xclang -vp-counters-per-site=50 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling"
  export CXXFLAGS="${_orig_cxxflags} -fprofile-generate=${_std_profraw} -fno-omit-frame-pointer -Xclang -mllvm -Xclang -vp-counters-per-site=50 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling"
  export LDFLAGS="${_orig_ldflags} -fprofile-generate=${_std_profraw} -Xclang -mllvm -Xclang -vp-counters-per-site=50 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling"

  _meson_setup "${_build_std}"
  ninja -C "${_build_std}"

  _compile_trainer "${_pgo_dir}/pixman_train_std" "${_build_std}"
  run_profile_training "${_build_std}" "${_pgo_dir}/pixman_train_std" "pgo-std" "${_std_profraw}"

  if _merge_profraw_dir "${_std_profdata}" "${_std_profraw}"; then
    have_std_profile=1
  else
    warning "No standard PGO profile data collected; continuing without standard PGO."
  fi

  ###########################################################################
  # Phase 2: Context-sensitive PGO instrumentation
  ###########################################################################
  if (( have_std_profile )); then
    msg2 "Phase 2: Building with context-sensitive PGO instrumentation..."

    export CFLAGS="${_orig_cflags} -fprofile-use=${_std_profdata} -fcs-profile-generate=${_cs_profraw} -fno-omit-frame-pointer -Xclang -mllvm -Xclang -vp-counters-per-site=50 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling"
    export CXXFLAGS="${_orig_cxxflags} -fprofile-use=${_std_profdata} -fcs-profile-generate=${_cs_profraw} -fno-omit-frame-pointer -Xclang -mllvm -Xclang -vp-counters-per-site=50 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling"
    export LDFLAGS="${_orig_ldflags} -fcs-profile-generate=${_cs_profraw} -Xclang -mllvm -Xclang -vp-counters-per-site=50 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling"

    _meson_setup "${_build_cs}"
    ninja -C "${_build_cs}"

    _compile_trainer "${_pgo_dir}/pixman_train_cs" "${_build_cs}"
    run_profile_training "${_build_cs}" "${_pgo_dir}/pixman_train_cs" "pgo-cs" "${_cs_profraw}"

    if _merge_profraw_dir "${_cs_profdata}" "${_cs_profraw}"; then
      have_cs_profile=1
    else
      warning "No CS-PGO profile data collected; falling back to standard PGO profile."
    fi
  else
    msg2 "Phase 2: Skipping CS-PGO because no standard profile data is available."
  fi

  if (( have_std_profile && have_cs_profile )); then
    if llvm-profdata merge -output="${_merged_profdata}" "${_std_profdata}" "${_cs_profdata}"; then
      final_profdata="${_merged_profdata}"
    else
      warning "Merged PGO profile creation failed; falling back to standard PGO profile."
      final_profdata="${_std_profdata}"
    fi
  elif (( have_std_profile )); then
    final_profdata="${_std_profdata}"
  fi

  ###########################################################################
  # Phase 3: Final optimized PGO build
  ###########################################################################
  msg2 "Phase 3: Building final optimized library..."

  if [[ -n "${final_profdata}" && -f "${final_profdata}" ]]; then
    export CFLAGS="${_orig_cflags} -fprofile-use=${final_profdata}"
    export CXXFLAGS="${_orig_cxxflags} -fprofile-use=${final_profdata}"
  else
    export CFLAGS="${_orig_cflags}"
    export CXXFLAGS="${_orig_cxxflags}"
  fi
  export LDFLAGS="${_orig_ldflags}"

  _meson_setup "${_build_opt}"
  ninja -C "${_build_opt}"

  ###########################################################################
  # Phase 4: Verification
  ###########################################################################
  msg2 "Phase 4: Verifying final output..."

  _compile_trainer "${_pgo_dir}/pixman_train_opt" "${_build_opt}"

  LD_LIBRARY_PATH="${_build_opt}/pixman" "${_pgo_dir}/pixman_train_opt" bench >/dev/null 2>&1
  local trainer_rc=$?
  if (( trainer_rc >= 128 )); then
    error "Final library crashed during trainer verification (exit ${trainer_rc})"
    return 1
  fi

  export CFLAGS="${_orig_cflags}"
  export CXXFLAGS="${_orig_cxxflags}"
  export LDFLAGS="${_orig_ldflags}"

  unset _orig_cflags _orig_cxxflags _orig_ldflags
  unset _pgo_dir _std_profraw _cs_profraw _std_profdata _cs_profdata _merged_profdata
}

check() {
  [[ -d "${srcdir}/_build_opt" ]] || return 0
  meson test -C "${srcdir}/_build_opt" --no-rebuild --print-errorlogs --num-processes 1
}

package() {
  meson install -C "${srcdir}/_build_opt" --destdir "${pkgdir}"

  install -Dm644 "${srcdir}/pixman/COPYING" \
    "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}
