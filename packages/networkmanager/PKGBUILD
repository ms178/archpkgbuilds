_pgo_instr='-g3 -fno-omit-frame-pointer -Xclang -mllvm -Xclang -vp-counters-per-site=400 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling'

_strip_profile_flags() {
  local out=() tok
  for tok in "$@"; do
    case "$tok" in
      -fprofile-generate|-fprofile-generate=*|-fprofile-use|-fprofile-use=*|-fprofile-sample-use=*|-fauto-profile=*|-fcs-profile-generate|-fcs-profile-generate=*)
        ;;
      *)
        out+=("$tok")
        ;;
    esac
  done
  printf '%s ' "${out[@]}"
}

_supports_flag() {
  local _flag="$1"
  local _tdir="$srcdir/.flagcheck-${_flag//[^[:alnum:]]/_}"

  rm -rf "$_tdir"
  mkdir -p "$_tdir"

  cat > "${_tdir}/t.c" <<'EOF'
int main(void) { return 0; }
EOF

  "$CC" "${_tdir}/t.c" -o "${_tdir}/t" ${LDFLAGS} "$_flag" >/dev/null 2>&1
}

_find_elf_shared_object() {
  local root="$1" soname="$2" cand
  while IFS= read -r cand; do
    [[ -f "$cand" ]] || continue
    readelf -h "$cand" >/dev/null 2>&1 || continue
    file -Lb "$cand" | grep -Eq 'ELF .* shared object' || continue
    echo "$cand"
    return 0
  done < <(
    find "$root" -type f \
      \( -name "${soname}.so" -o -name "${soname}.so.*" \) \
      ! -name '*.symbols' \
      ! -name '*.a' \
      ! -name '*.la' \
      ! -path '*/subprojects/*' \
      | sort -V
  )
  return 1
}

_prepare_workload_env() {
  local bdir="$1" prof_file="$2" preload_lib="$3"

  export LD_LIBRARY_PATH="$bdir/src/libnm${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
  [[ -n "$prof_file" ]] && export LLVM_PROFILE_FILE="$prof_file" || unset LLVM_PROFILE_FILE
  [[ -n "$preload_lib" ]] && export LD_PRELOAD="$preload_lib" || unset LD_PRELOAD
}

_restore_workload_env() {
  local old_ld="$1" old_prof="$2" old_preload="$3"

  [[ -n "$old_ld" ]] && export LD_LIBRARY_PATH="$old_ld" || unset LD_LIBRARY_PATH
  [[ -n "$old_prof" ]] && export LLVM_PROFILE_FILE="$old_prof" || unset LLVM_PROFILE_FILE
  [[ -n "$old_preload" ]] && export LD_PRELOAD="$old_preload" || unset LD_PRELOAD
}

_nm_timeout_run() {
  local sec="$1"
  shift
  timeout --signal=TERM -k 15 "$sec" "$@" >/dev/null 2>&1 || true
}

_nm_running() {
  local nmcli="$1"
  local st
  st="$("$nmcli" -t -f RUNNING general status 2>/dev/null || true)"
  [[ "$st" == "running" ]]
}

_nm_find_bin() {
  local bdir="$1" name="$2"
  find "$bdir" -type f -name "$name" -perm -111 -print -quit 2>/dev/null || true
}

_nm_binary_sweep() {
  local bdir="$1"
  local bins=(
    nmcli
    nm-online
    NetworkManager
    nmtui
    nmtui-connect
    nmtui-edit
    nmtui-hostname
    nm-cloud-setup
    nm-initrd-generator
  )
  local b n
  for n in "${bins[@]}"; do
    b="$(_nm_find_bin "$bdir" "$n")"
    [[ -x "$b" ]] || continue
    _nm_timeout_run 12 "$b" --help
    _nm_timeout_run 12 "$b" --version
  done
}

_nm_collect_device_matrix() {
  local nmcli="$1"
  local line dev typ state

  while IFS= read -r line; do
    IFS=':' read -r dev typ state <<<"$line"
    [[ -n "$dev" ]] || continue

    _nm_timeout_run 20 "$nmcli" -f GENERAL,IP4,IP6,WIRED,WIFI device show "$dev"
    _nm_timeout_run 20 "$nmcli" -m multiline -f GENERAL,IP4,IP6,CAPABILITIES device show "$dev"

    if [[ "$typ" == "wifi" ]]; then
      _nm_timeout_run 25 "$nmcli" device wifi list ifname "$dev"
      _nm_timeout_run 25 "$nmcli" -t -f IN-USE,SSID,MODE,CHAN,RATE,SIGNAL,BARS,SECURITY device wifi list ifname "$dev"
      _nm_timeout_run 25 "$nmcli" -m multiline -f IN-USE,SSID,SIGNAL,SECURITY device wifi list ifname "$dev"
    fi
  done < <("$nmcli" -t -f DEVICE,TYPE,STATE device status 2>/dev/null)
}

_nm_collect_connection_matrix() {
  local nmcli="$1"
  local line uuid

  _nm_timeout_run 20 "$nmcli" -t -f NAME,UUID,TYPE,DEVICE,TIMESTAMP-REAL connection show
  _nm_timeout_run 20 "$nmcli" -m multiline connection show
  _nm_timeout_run 20 "$nmcli" -f all connection show --active

  while IFS= read -r line; do
    IFS=':' read -r _ uuid _rest <<<"$line"
    [[ -n "$uuid" ]] || continue
    _nm_timeout_run 20 "$nmcli" connection show "$uuid"
    _nm_timeout_run 20 "$nmcli" -f name,uuid,type,autoconnect,timestamp-real connection show "$uuid"
    _nm_timeout_run 20 "$nmcli" -m multiline connection show "$uuid"
    _nm_timeout_run 20 "$nmcli" -g GENERAL.STATE,GENERAL.TYPE connection show "$uuid"
  done < <("$nmcli" -t -f NAME,UUID,TYPE,DEVICE,TIMESTAMP-REAL connection show 2>/dev/null)
}

_nm_train_offline() {
  local nmcli="$1" nmonline="$2"

  _nm_timeout_run 10 "$nmcli" --help
  _nm_timeout_run 10 "$nmcli" --version
  _nm_timeout_run 10 "$nmcli" help

  local sub
  for sub in general networking radio connection device agent monitor settings; do
    _nm_timeout_run 10 "$nmcli" "$sub" --help
    _nm_timeout_run 10 "$nmcli" help "$sub"
  done

  _nm_timeout_run 12 "$nmcli" -m tabular -t -f all general
  _nm_timeout_run 12 "$nmcli" -m multiline general
  _nm_timeout_run 12 "$nmcli" -c no -t general status
  _nm_timeout_run 12 "$nmcli" -g STATE general status
  _nm_timeout_run 12 "$nmcli" general permissions
  _nm_timeout_run 12 "$nmcli" general hostname
  _nm_timeout_run 12 "$nmcli" general logging

  _nm_timeout_run 12 "$nmcli" networking
  _nm_timeout_run 12 "$nmcli" networking connectivity
  _nm_timeout_run 12 "$nmcli" networking connectivity check
  _nm_timeout_run 12 "$nmcli" radio all

  _nm_timeout_run 12 "$nmcli" connection show
  _nm_timeout_run 12 "$nmcli" connection show --active
  _nm_timeout_run 12 "$nmcli" device status
  _nm_timeout_run 12 "$nmcli" device show

  _nm_collect_device_matrix "$nmcli"
  _nm_collect_connection_matrix "$nmcli"

  _nm_timeout_run 12 "$nmcli" connection show id __does_not_exist__
  _nm_timeout_run 12 "$nmcli" connection show uuid 00000000-0000-0000-0000-000000000000
  _nm_timeout_run 12 "$nmcli" connection show uuid invalid-uuid
  _nm_timeout_run 12 "$nmcli" device show __does_not_exist__
  _nm_timeout_run 12 "$nmcli" device wifi list ifname __does_not_exist__
  _nm_timeout_run 12 "$nmcli" -f DOES_NOT_EXIST general
  _nm_timeout_run 12 "$nmcli" this-subcommand-does-not-exist

  if [[ -x "$nmonline" ]]; then
    _nm_timeout_run 12 "$nmonline" --help
    _nm_timeout_run 12 "$nmonline" -t 1
    _nm_timeout_run 12 "$nmonline" -t 3
  fi
}

_nm_train_online() {
  local nmcli="$1" nmonline="$2"
  local round

  for round in 1 2 3 4 5 6 7 8; do
    _nm_timeout_run 12 "$nmcli" general status
    _nm_timeout_run 12 "$nmcli" general permissions
    _nm_timeout_run 12 "$nmcli" general hostname
    _nm_timeout_run 12 "$nmcli" general logging
    _nm_timeout_run 12 "$nmcli" -f all general
    _nm_timeout_run 12 "$nmcli" -g STATE general status
    _nm_timeout_run 12 "$nmcli" -m multiline general

    _nm_timeout_run 12 "$nmcli" networking
    _nm_timeout_run 12 "$nmcli" networking connectivity
    _nm_timeout_run 12 "$nmcli" networking connectivity check
    _nm_timeout_run 12 "$nmcli" radio all

    _nm_timeout_run 12 "$nmcli" -t -f DEVICE,TYPE,STATE device status
    _nm_timeout_run 12 "$nmcli" device show
    _nm_timeout_run 12 "$nmcli" connection show --active
    _nm_timeout_run 12 "$nmcli" -f all connection show --active

    _nm_collect_device_matrix "$nmcli"
    _nm_collect_connection_matrix "$nmcli"

    _nm_timeout_run 12 "$nmcli" -f DOES_NOT_EXIST general

    if [[ -x "$nmonline" ]]; then
      _nm_timeout_run 12 "$nmonline" -t 3
      _nm_timeout_run 12 "$nmonline" -t 5
    fi
  done

  _nm_timeout_run 12 "$nmcli" connection show id __does_not_exist__
  _nm_timeout_run 12 "$nmcli" device show __does_not_exist__
}

_run_stage_tests() {
  local builddir="$1"
  _nm_timeout_run 600 meson test -C "$builddir" --no-rebuild --print-errorlogs --num-processes "$(nproc)"
  _nm_timeout_run 600 meson test -C "$builddir" --no-rebuild --print-errorlogs --num-processes 1
}

_run_nm_workload() {
  local nmcli="$1" nmonline="$2"

  [[ -x "$nmcli" ]] || return 0

  if _nm_running "$nmcli"; then
    _nm_train_online "$nmcli" "$nmonline"
  else
    _nm_train_offline "$nmcli" "$nmonline"
  fi
}

_run_stage_training() {
  local builddir="$1" profile_file="$2" preload_lib="$3"

  local nmcli nmonline
  nmcli="$(_nm_find_bin "$builddir" nmcli)"
  nmonline="$(_nm_find_bin "$builddir" nm-online)"

  local _old_ld="${LD_LIBRARY_PATH-}"
  local _old_prof="${LLVM_PROFILE_FILE-}"
  local _old_preload="${LD_PRELOAD-}"

  _prepare_workload_env "$builddir" "$profile_file" "$preload_lib"

  _nm_binary_sweep "$builddir"
  _run_stage_tests "$builddir"

  if [[ -n "$nmcli" ]]; then
    _run_nm_workload "$nmcli" "$nmonline"
    _run_nm_workload "$nmcli" "$nmonline"
  else
    warning "nmcli not found in $builddir; custom CLI workload skipped"
  fi

  _run_stage_tests "$builddir"

  _restore_workload_env "$_old_ld" "$_old_prof" "$_old_preload"
}

build() {
  cd "$srcdir"

  export CC=clang
  export CXX=clang++

  local BASE_CFLAGS BASE_CXXFLAGS BASE_LDFLAGS
  read -r -a _cflags_arr <<<"$CFLAGS"
  read -r -a _cxxflags_arr <<<"$CXXFLAGS"
  read -r -a _ldflags_arr <<<"$LDFLAGS"
  BASE_CFLAGS="$(_strip_profile_flags "${_cflags_arr[@]}")"
  BASE_CXXFLAGS="$(_strip_profile_flags "${_cxxflags_arr[@]}")"
  BASE_LDFLAGS="$(_strip_profile_flags "${_ldflags_arr[@]}")"

  local meson_opts=(
    --buildtype=release
    --wrap-mode=nofallback

    -Db_lto=true
    -Db_ndebug=true
    -Db_pie=false
    -Dc_std=gnu23
    -Dcpp_std=gnu++20

    -Ddist_version="$pkgver-$pkgrel"
    -Dsession_tracking_consolekit=false
    -Dsuspend_resume=systemd
    -Dmodify_system=true
    -Dselinux=false
    -Dlibaudit=yes
    -Dsystemd_journal=true
    -Dconfig_logging_backend_default=journal
    -Dconfig_wifi_backend_default=wpa_supplicant

    -Diwd=true
    -Dteamdctl=true
    -Dnm_cloud_setup=false

    -Dconfig_plugins_default=keyfile
    -Difupdown=false

    -Dnetconfig=no
    -Dconfig_dns_rc_manager_default=symlink
    -Dconfig_dhcp_default=internal

    -Dintrospection=false
    -Dvapi=false
    -Ddocs=false
    -Dman=false
    -Dmore_asserts=no
    -Dmore_logging=false
    -Dqt=false
    -Dtests=yes
    -Dpython.bytecompile=2
  )

  local can_ir_pgo=1
  local can_cs_pgo=1

  if ! _supports_flag "-fprofile-generate"; then
    warning "Toolchain cannot link -fprofile-generate, building without PGO/CS-PGO"
    can_ir_pgo=0
    can_cs_pgo=0
  fi

  if (( can_ir_pgo )) && ! _supports_flag "-fcs-profile-generate"; then
    warning "Toolchain lacks -fcs-profile-generate, falling back to regular PGO"
    can_cs_pgo=0
  fi

  local gen_dir="$srcdir/pgo-gen"
  local cs_dir="$srcdir/pgo-cs"
  rm -rf "$gen_dir" "$cs_dir" "$srcdir/build-gen" "$srcdir/build-cs" "$srcdir/build-opt" \
         "$srcdir/pgo-merged.profdata" "$srcdir/pgo-cs-merged.profdata"
  mkdir -p "$gen_dir" "$cs_dir"

  local c_args_use="$BASE_CFLAGS"
  local cxx_args_use="$BASE_CXXFLAGS"
  local link_args_use="$BASE_LDFLAGS -Wl,--emit-relocs"

  # ---------------- PASS 1: standard PGO instrumentation ----------------
  if (( can_ir_pgo )); then
    local c_args_gen="$BASE_CFLAGS $_pgo_instr -fprofile-generate=$gen_dir"
    local cxx_args_gen="$BASE_CXXFLAGS $_pgo_instr -fprofile-generate=$gen_dir"
    local link_args_gen="$BASE_LDFLAGS -fprofile-generate=$gen_dir"

    echo "Stage 1: PGO instrumented build"
    arch-meson NetworkManager build-gen "${meson_opts[@]}" \
      -Db_lto=false \
      -Db_ndebug=false \
      -Dc_args="$c_args_gen" \
      -Dcpp_args="$cxx_args_gen" \
      -Dc_link_args="$link_args_gen" \
      -Dcpp_link_args="$link_args_gen"

    meson compile -C build-gen

    echo "Stage 2: PGO comprehensive training (tests + custom workload)"
    _run_stage_training "$srcdir/build-gen" "$gen_dir/nm.%p.profraw" ""

    if compgen -G "$gen_dir/*.profraw" > /dev/null; then
      llvm-profdata merge -output="$srcdir/pgo-merged.profdata" "$gen_dir"/*.profraw
    else
      warning "No stage1 profile data produced; continuing without profile-use"
      can_ir_pgo=0
      can_cs_pgo=0
    fi
  fi

  # ---------------- PASS 2: CS-PGO instrumentation ----------------
  if (( can_cs_pgo )) && [[ -f "$srcdir/pgo-merged.profdata" ]]; then
    local c_args_cs="$BASE_CFLAGS $_pgo_instr -fprofile-use=$srcdir/pgo-merged.profdata -fcs-profile-generate=$cs_dir -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
    local cxx_args_cs="$BASE_CXXFLAGS $_pgo_instr -fprofile-use=$srcdir/pgo-merged.profdata -fcs-profile-generate=$cs_dir -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
    local link_args_cs="$BASE_LDFLAGS -fprofile-use=$srcdir/pgo-merged.profdata -fcs-profile-generate=$cs_dir"

    echo "Stage 3: CS-PGO instrumented build"
    arch-meson NetworkManager build-cs "${meson_opts[@]}" \
      -Db_lto=false \
      -Db_ndebug=false \
      -Dc_args="$c_args_cs" \
      -Dcpp_args="$cxx_args_cs" \
      -Dc_link_args="$link_args_cs" \
      -Dcpp_link_args="$link_args_cs"

    meson compile -C build-cs

    echo "Stage 4: CS-PGO comprehensive training (tests + custom workload)"
    _run_stage_training "$srcdir/build-cs" "$cs_dir/nm.%p.profraw" ""

    if compgen -G "$cs_dir/*.profraw" > /dev/null; then
      llvm-profdata merge -output="$srcdir/pgo-cs-merged.profdata" "$cs_dir"/*.profraw "$srcdir/pgo-merged.profdata"
      c_args_use+=" -fprofile-use=$srcdir/pgo-cs-merged.profdata -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
      cxx_args_use+=" -fprofile-use=$srcdir/pgo-cs-merged.profdata -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
      link_args_use+=" -fprofile-use=$srcdir/pgo-cs-merged.profdata"
    else
      warning "No CS-PGO data produced; using stage1 PGO profile"
      c_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
      cxx_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
      link_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata"
    fi
  elif (( can_ir_pgo )) && [[ -f "$srcdir/pgo-merged.profdata" ]]; then
    c_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
    cxx_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
    link_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata"
  fi

  # ---------------- PASS 3: final optimized build ----------------
  echo "Stage 5: Final optimized build"
  arch-meson NetworkManager build-opt "${meson_opts[@]}" \
    -Dc_args="$c_args_use" \
    -Dcpp_args="$cxx_args_use" \
    -Dc_link_args="$link_args_use" \
    -Dcpp_link_args="$link_args_use"

  meson compile -C build-opt

  # ---------------- PASS 4: BOLT ----------------
  if command -v llvm-bolt >/dev/null 2>&1 && command -v merge-fdata >/dev/null 2>&1; then
    echo "Stage 6: BOLT optimization"

    local bolt_dir="$srcdir/bolt"
    rm -rf "$bolt_dir"
    mkdir -p "$bolt_dir"

    local nmcli_opt nmonline_opt libnm_real
    nmcli_opt="$(_nm_find_bin "$srcdir/build-opt" nmcli)"
    nmonline_opt="$(_nm_find_bin "$srcdir/build-opt" nm-online)"
    libnm_real="$(_find_elf_shared_object "$srcdir/build-opt" "libnm" || true)"

    local have_nmcli=0 have_libnm=0
    [[ -n "$nmcli_opt" && -f "$nmcli_opt" ]] && have_nmcli=1
    [[ -n "$libnm_real" && -f "$libnm_real" ]] && have_libnm=1

    [[ -n "$libnm_real" ]] && echo "BOLT: selected libnm target: $libnm_real" || echo "BOLT: no valid ELF libnm shared object found; skipping libnm BOLT"

    if (( have_nmcli )); then
      cp -f "$nmcli_opt" "$bolt_dir/nmcli.orig"
      if llvm-bolt "$nmcli_opt" \
          --relocs \
          --lite=false \
          --instrument \
          --instrumentation-file="$bolt_dir/nmcli.fdata" \
          --instrumentation-file-append-pid \
          -o "$bolt_dir/nmcli.inst"; then
        install -m755 "$bolt_dir/nmcli.inst" "$nmcli_opt"
      else
        echo "BOLT: nmcli instrumentation failed"
        have_nmcli=0
      fi
    fi

    if (( have_libnm )); then
      cp -f "$libnm_real" "$bolt_dir/libnm.so.orig"
      if llvm-bolt "$libnm_real" \
          --relocs \
          --lite=false \
          --instrument \
          --instrumentation-file="$bolt_dir/libnm.fdata" \
          --instrumentation-file-append-pid \
          -o "$bolt_dir/libnm.so.inst"; then
        install -m755 "$bolt_dir/libnm.so.inst" "$libnm_real"
      else
        echo "BOLT: libnm instrumentation failed"
        have_libnm=0
      fi
    fi

    if (( have_nmcli )); then
      local preload_lib=""
      (( have_libnm )) && preload_lib="$libnm_real"

      # Same comprehensive training methodology in BOLT instrumentation stage.
      _run_stage_training "$srcdir/build-opt" "" "$preload_lib"
      _run_stage_training "$srcdir/build-opt" "" "$preload_lib"
    fi

    local merged_cli="$bolt_dir/nmcli.merged.fdata"
    local merged_lib="$bolt_dir/libnm.merged.fdata"

    if compgen -G "$bolt_dir/nmcli.fdata*" > /dev/null; then
      merge-fdata "$bolt_dir"/nmcli.fdata* -o "$merged_cli" || true
    fi

    if compgen -G "$bolt_dir/libnm.fdata*" > /dev/null; then
      merge-fdata "$bolt_dir"/libnm.fdata* -o "$merged_lib" || true
    fi

    local bolt_help align_flags
    bolt_help="$(llvm-bolt --help 2>&1 || true)"
    align_flags=(--align-blocks)
    grep -q -- '--block-alignment' <<<"$bolt_help" && align_flags=(--align-blocks --block-alignment=32)

    if (( have_nmcli )); then
      if [[ -s "$merged_cli" ]]; then
        if llvm-bolt "$bolt_dir/nmcli.orig" \
            --relocs \
            --data="$merged_cli" \
            --reorder-blocks=ext-tsp \
            --reorder-functions=cdsort \
            --split-functions \
            --split-strategy=cdsplit \
            --icf=all \
            --jump-tables=move \
            --peepholes=all \
            --reg-reassign \
            --use-aggr-reg-reassign \
            "${align_flags[@]}" \
            --dyno-stats \
            -o "$bolt_dir/nmcli.bolt"; then
          install -m755 "$bolt_dir/nmcli.bolt" "$nmcli_opt"
          echo "BOLT: nmcli optimized"
        else
          echo "BOLT: nmcli optimization failed; restoring PGO binary"
          install -m755 "$bolt_dir/nmcli.orig" "$nmcli_opt"
        fi
      else
        echo "BOLT: no nmcli profile; restoring PGO binary"
        install -m755 "$bolt_dir/nmcli.orig" "$nmcli_opt"
      fi
    fi

    if (( have_libnm )); then
      if [[ -s "$merged_lib" ]]; then
        if llvm-bolt "$bolt_dir/libnm.so.orig" \
            --relocs \
            --data="$merged_lib" \
            --reorder-blocks=ext-tsp \
            --reorder-functions=cdsort \
            --split-functions \
            --split-strategy=cdsplit \
            --icf=all \
            --jump-tables=move \
            --peepholes=all \
            --reg-reassign \
            --use-aggr-reg-reassign \
            "${align_flags[@]}" \
            --dyno-stats \
            -o "$bolt_dir/libnm.so.bolt"; then
          install -m755 "$bolt_dir/libnm.so.bolt" "$libnm_real"
          echo "BOLT: libnm optimized"
        else
          echo "BOLT: libnm optimization failed; restoring PGO library"
          install -m755 "$bolt_dir/libnm.so.orig" "$libnm_real"
        fi
      else
        echo "BOLT: no libnm profile; restoring PGO library"
        install -m755 "$bolt_dir/libnm.so.orig" "$libnm_real"
      fi
    fi
  else
    echo "llvm-bolt/merge-fdata not found; skipping BOLT"
  fi
}

_pick() {
  local p="$1" f d
  shift
  for f; do
    [[ -e "$f" ]] || continue
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")" 2>/dev/null || true
  done
}

package_networkmanager() {
  cd "$srcdir"

  depends=(
    audit
    curl
    glib2
    glibc
    iproute2
    jansson
    libgcc
    libmm-glib
    libndp
    libnewt
    libnm
    libpsl
    libteam
    mobile-broadband-provider-info
    nspr
    nss
    readline
    systemd-libs
    wpa_supplicant
  )
  optdepends=(
    'bluez: Bluetooth support'
    'dhcpcd: alternative DHCP client'
    'dnsmasq: connection sharing'
    'firewalld: firewall support'
    'iptables: connection sharing'
    'iwd: wpa_supplicant alternative'
    'libnvme: NBFT support'
    'modemmanager: cellular network support'
    'nftables: connection sharing'
    'openresolv: alternative resolv.conf manager'
    'pacrunner: PAC proxy support'
    'polkit: let non-root users control networking'
    'ppp: dialup connection support'
  )
  backup=(etc/NetworkManager/NetworkManager.conf)
  license+=(GPL-2.0-or-later)

  meson install -C build-opt --destdir "$pkgdir"

  cd "$pkgdir"

  install -d etc/NetworkManager/{conf,dnsmasq}.d
  install -dm700 etc/NetworkManager/system-connections
  install -m644 /dev/stdin etc/NetworkManager/NetworkManager.conf <<'END'
# Configuration file for NetworkManager.
# See "man 5 NetworkManager.conf" for details.
END

  install -Dm644 /dev/stdin usr/lib/NetworkManager/conf.d/20-connectivity.conf <<'END'
[connectivity]
uri=http://ping.archlinux.org/nm-check.txt
END

  shopt -s globstar

  _pick libnm usr/include/libnm
  _pick libnm usr/lib/girepository-1.0/NM-*
  _pick libnm usr/lib/libnm.*
  _pick libnm usr/lib/nm-libnm-helper
  _pick libnm usr/lib/pkgconfig/libnm.pc
  _pick libnm usr/share/gir-1.0/NM-*
  _pick libnm usr/share/vala/vapi/libnm.*

  install -d usr/lib/NetworkManager/dispatcher.d/no-wait.d
}

package_libnm() {
  cd "$srcdir"

  pkgdesc="NetworkManager client library"
  depends=(
    glib2
    glibc
    libgcc
    nspr
    nss
    systemd-libs
    util-linux-libs
  )
  provides=(libnm.so)

  mv libnm/* "$pkgdir"
}
