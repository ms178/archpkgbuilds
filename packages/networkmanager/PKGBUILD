_pgo_instr='-g3 -fno-omit-frame-pointer -Xclang -mllvm -Xclang -vp-counters-per-site=400 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling'

_strip_profile_flags() {
  local out=() tok
  for tok in "$@"; do
    case "$tok" in
      -fprofile-generate|-fprofile-generate=*|-fprofile-use|-fprofile-use=*|-fprofile-sample-use=*|-fauto-profile=*|-fcs-profile-generate=*)
        ;;
      *)
        out+=("$tok")
        ;;
    esac
  done
  printf '%s ' "${out[@]}"
}

prepare() {
  cd NetworkManager
}

_env_with_build_libs() {
  local builddir="$1"
  echo "LD_LIBRARY_PATH=$builddir/src/libnm:${LD_LIBRARY_PATH:-}"
}

_nm_timeout_run() {
  local sec="$1"
  shift
  timeout -k 2 "$sec" "$@" >/dev/null 2>&1 || true
}

_nm_running() {
  local nmcli="$1" env_ld="$2" profenv="$3" extraenv="$4"
  local st
  st="$(env $env_ld $profenv $extraenv "$nmcli" -t -f RUNNING general status 2>/dev/null || true)"
  [[ "$st" == "running" ]]
}

_nm_train_offline() {
  local nmcli="$1" nmonline="$2" env_ld="$3" profenv="$4" extraenv="$5"

  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" --help
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" --version
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" help

  local sub
  for sub in general networking radio connection device agent monitor settings; do
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" "$sub" --help
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" help "$sub"
  done

  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -m tabular -t -f all general
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -m multiline general
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -c no -t general status
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -g STATE general status
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" general permissions
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" general hostname
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" general logging
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" connection show
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" connection show --active
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" device status
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" device show
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" radio all
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" networking
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" networking connectivity
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" networking connectivity check
  _nm_timeout_run 6 env $env_ld $profenv $extraenv "$nmcli" monitor

  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" connection show id __does_not_exist__
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" connection show uuid 00000000-0000-0000-0000-000000000000
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" connection show uuid invalid-uuid
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" device show __does_not_exist__
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" device wifi list ifname __does_not_exist__
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -f DOES_NOT_EXIST general
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" this-subcommand-does-not-exist

  [[ -x "$nmonline" ]] && {
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmonline" --help
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmonline" -t 1
  }
}

_nm_train_online() {
  local nmcli="$1" nmonline="$2" env_ld="$3" profenv="$4" extraenv="$5"
  local round line dev typ state uuid

  for round in 1 2 3 4 5 6; do
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" general status
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" general permissions
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" general hostname
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" general logging
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -f all general
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -g STATE general status
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -m multiline general

    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" networking
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" networking connectivity
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" networking connectivity check
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" radio all
    _nm_timeout_run 6 env $env_ld $profenv $extraenv "$nmcli" monitor

    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -t -f DEVICE,TYPE,STATE device status
    _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" device show
    _nm_timeout_run 6 env $env_ld $profenv $extraenv "$nmcli" connection show --active

    while IFS= read -r line; do
      IFS=':' read -r dev typ state <<<"$line"
      [[ -n "$dev" ]] || continue
      _nm_timeout_run 10 env $env_ld $profenv $extraenv "$nmcli" -f GENERAL,IP4,IP6,WIRED,WIFI device show "$dev"
      _nm_timeout_run 10 env $env_ld $profenv $extraenv "$nmcli" -m multiline -f GENERAL,IP4,IP6 device show "$dev"
      [[ "$typ" == "wifi" ]] && {
        _nm_timeout_run 12 env $env_ld $profenv $extraenv "$nmcli" device wifi list ifname "$dev"
        _nm_timeout_run 12 env $env_ld $profenv $extraenv "$nmcli" -t -f IN-USE,SSID,MODE,CHAN,RATE,SIGNAL,BARS,SECURITY device wifi list ifname "$dev"
      }
    done < <(env $env_ld $profenv $extraenv "$nmcli" -t -f DEVICE,TYPE,STATE device status 2>/dev/null)

    _nm_timeout_run 10 env $env_ld $profenv $extraenv "$nmcli" -t -f NAME,UUID,TYPE,DEVICE,TIMESTAMP-REAL connection show
    _nm_timeout_run 10 env $env_ld $profenv $extraenv "$nmcli" -m multiline connection show

    while IFS= read -r line; do
      IFS=':' read -r _ uuid _rest <<<"$line"
      [[ -n "$uuid" ]] || continue
      _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" connection show "$uuid"
      _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -f name,uuid,type,autoconnect,timestamp-real connection show "$uuid"
      _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -m multiline connection show "$uuid"
    done < <(env $env_ld $profenv $extraenv "$nmcli" -t -f NAME,UUID,TYPE,DEVICE,TIMESTAMP-REAL connection show 2>/dev/null)

    [[ -x "$nmonline" ]] && _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmonline" -t 5
  done

  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" connection show id __does_not_exist__
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" device show __does_not_exist__
  _nm_timeout_run 8 env $env_ld $profenv $extraenv "$nmcli" -f DOES_NOT_EXIST general
}

_run_nm_workload() {
  local nmcli="$1" nmonline="$2" bdir="$3" profenv="$4" extraenv="$5"
  local env_ld
  env_ld="$(_env_with_build_libs "$bdir")"

  [[ -x "$nmcli" ]] || return 0

  if _nm_running "$nmcli" "$env_ld" "$profenv" "$extraenv"; then
    _nm_train_online "$nmcli" "$nmonline" "$env_ld" "$profenv" "$extraenv"
  else
    _nm_train_offline "$nmcli" "$nmonline" "$env_ld" "$profenv" "$extraenv"
  fi
}

build() {
  export CC=clang
  export CXX=clang++

  local BASE_CFLAGS BASE_CXXFLAGS BASE_LDFLAGS
  read -r -a _cflags_arr <<<"$CFLAGS"
  read -r -a _cxxflags_arr <<<"$CXXFLAGS"
  BASE_CFLAGS="$(_strip_profile_flags "${_cflags_arr[@]}")"
  BASE_CXXFLAGS="$(_strip_profile_flags "${_cxxflags_arr[@]}")"
  BASE_LDFLAGS="$LDFLAGS"

  local meson_opts=(
    --buildtype=release
    --wrap-mode=nofallback

    -D b_lto=true
    -D b_ndebug=true
    -D b_pie=false
    -D c_std=gnu23
    -D cpp_std=gnu++20

    -D dist_version="$pkgver-$pkgrel"
    -D session_tracking_consolekit=false
    -D suspend_resume=systemd
    -D modify_system=true
    -D selinux=false

    -D iwd=true
    -D teamdctl=true
    -D nm_cloud_setup=false

    -D config_plugins_default=keyfile
    -D ifupdown=false

    -D netconfig=no
    -D config_dns_rc_manager_default=symlink

    -D introspection=false
    -D vapi=false
    -D docs=false
    -D man=false
    -D more_asserts=no
    -D more_logging=false
    -D qt=false
    -D tests=no
    -D python.bytecompile=2
  )

  # ---------------- PASS 1: PGO instrumentation ----------------
  local gen_dir="$srcdir/pgo-gen"
  mkdir -p "$gen_dir"

  local c_args_gen="$BASE_CFLAGS $_pgo_instr -fprofile-generate=$gen_dir"
  local cxx_args_gen="$BASE_CXXFLAGS $_pgo_instr -fprofile-generate=$gen_dir"
  local link_args_gen="$BASE_LDFLAGS -fprofile-generate=$gen_dir"

  echo "Stage 1: PGO instrumented build"
  arch-meson NetworkManager build-gen "${meson_opts[@]}" \
    -D b_lto=false \
    -D b_ndebug=false \
    -Dc_args="$c_args_gen" \
    -Dcpp_args="$cxx_args_gen" \
    -Dc_link_args="$link_args_gen" \
    -Dcpp_link_args="$link_args_gen"

  meson compile -C build-gen

  echo "Stage 2: PGO training"
  local nmcli_gen nmonline_gen
  nmcli_gen="$(find "$srcdir/build-gen" -type f -name nmcli -perm -111 -print -quit)"
  nmonline_gen="$(find "$srcdir/build-gen" -type f -name nm-online -perm -111 -print -quit || true)"

  if [[ -n "$nmcli_gen" ]]; then
    _run_nm_workload "$nmcli_gen" "$nmonline_gen" "$srcdir/build-gen" "LLVM_PROFILE_FILE=$gen_dir/nm.%p.profraw" ""
  else
    echo "Warning: nmcli not found for PGO training; skipping training phase."
  fi

  local c_args_use="$BASE_CFLAGS"
  local cxx_args_use="$BASE_CXXFLAGS"
  local link_args_use="$BASE_LDFLAGS -Wl,--emit-relocs"

  if compgen -G "$gen_dir/*.profraw" > /dev/null; then
    llvm-profdata merge -output="$srcdir/pgo-merged.profdata" "$gen_dir"/*.profraw
    c_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
    cxx_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata -Wno-profile-instr-missing -Wno-profile-instr-out-of-date"
    link_args_use+=" -fprofile-use=$srcdir/pgo-merged.profdata"
  else
    echo "Warning: no PGO data produced; building without profile-use"
  fi

  # ---------------- PASS 2: final optimized build ----------------
  echo "Stage 3: Final optimized PGO build"
  arch-meson NetworkManager build-opt "${meson_opts[@]}" \
    -Dc_args="$c_args_use" \
    -Dcpp_args="$cxx_args_use" \
    -Dc_link_args="$link_args_use" \
    -Dcpp_link_args="$link_args_use"

  meson compile -C build-opt

  # ---------------- PASS 3: BOLT ----------------
  if command -v llvm-bolt >/dev/null 2>&1; then
    echo "Stage 4: BOLT optimization"

    local bolt_dir="$srcdir/bolt"
    mkdir -p "$bolt_dir"

    local nmcli_opt nmonline_opt libnm_real
    nmcli_opt="$(find "$srcdir/build-opt" -type f -name nmcli -perm -111 -print -quit)"
    nmonline_opt="$(find "$srcdir/build-opt" -type f -name nm-online -perm -111 -print -quit || true)"
    libnm_real="$(find "$srcdir/build-opt" \
  -type f \( -name 'libnm.so' -o -name 'libnm.so.*' \) \
  ! -name '*.a' ! -name '*.la' \
  ! -path '*/subprojects/*' \
  -print | head -n1 || true)"

    local have_nmcli=0 have_libnm=0
    [[ -n "$nmcli_opt" && -f "$nmcli_opt" ]] && have_nmcli=1
    [[ -n "$libnm_real" && -f "$libnm_real" ]] && have_libnm=1

    if (( have_nmcli )); then
      cp -f "$nmcli_opt" "$bolt_dir/nmcli.orig"
      if llvm-bolt "$nmcli_opt" \
          --relocs \
          --lite=false \
          --instrument \
          --instrumentation-file="$bolt_dir/nmcli.fdata" \
          --instrumentation-file-append-pid \
          -o "$bolt_dir/nmcli.inst"; then
        install -m755 "$bolt_dir/nmcli.inst" "$nmcli_opt"
      else
        echo "BOLT: nmcli instrumentation failed"
        have_nmcli=0
      fi
    fi

    if (( have_libnm )); then
      cp -f "$libnm_real" "$bolt_dir/libnm.so.orig"
      if llvm-bolt "$libnm_real" \
          --relocs \
          --lite=false \
          --instrument \
          --instrumentation-file="$bolt_dir/libnm.fdata" \
          --instrumentation-file-append-pid \
          -o "$bolt_dir/libnm.so.inst"; then
        install -m755 "$bolt_dir/libnm.so.inst" "$libnm_real"
      else
        echo "BOLT: libnm instrumentation failed"
        have_libnm=0
      fi
    fi

    if (( have_nmcli )); then
      local extraenv=""
      (( have_libnm )) && extraenv="LD_PRELOAD=$libnm_real"
      _run_nm_workload "$nmcli_opt" "$nmonline_opt" "$srcdir/build-opt" "" "$extraenv"
    fi

    local merged_cli="$bolt_dir/nmcli.merged.fdata"
    local merged_lib="$bolt_dir/libnm.merged.fdata"

    if compgen -G "$bolt_dir/nmcli.fdata*" > /dev/null; then
      if command -v merge-fdata >/dev/null 2>&1; then
        merge-fdata "$bolt_dir"/nmcli.fdata* -o "$merged_cli" || true
      else
        cat "$bolt_dir"/nmcli.fdata* > "$merged_cli" || true
      fi
    fi

    if compgen -G "$bolt_dir/libnm.fdata*" > /dev/null; then
      if command -v merge-fdata >/dev/null 2>&1; then
        merge-fdata "$bolt_dir"/libnm.fdata* -o "$merged_lib" || true
      else
        cat "$bolt_dir"/libnm.fdata* > "$merged_lib" || true
      fi
    fi

    local bolt_help align_flags
    bolt_help="$(llvm-bolt --help 2>&1 || true)"
    align_flags=(--align-blocks)
    grep -q -- '--block-alignment' <<<"$bolt_help" && align_flags=(--align-blocks --block-alignment=32)

    if (( have_nmcli )); then
      if [[ -s "$merged_cli" ]]; then
        if llvm-bolt "$bolt_dir/nmcli.orig" \
            --relocs \
            --data="$merged_cli" \
            --reorder-blocks=ext-tsp \
            --reorder-functions=cdsort \
            --split-functions \
            --split-strategy=cdsplit \
            --icf=all \
            --jump-tables=move \
            --peepholes=all \
            --reg-reassign \
            --use-aggr-reg-reassign \
            "${align_flags[@]}" \
            --dyno-stats \
            -o "$bolt_dir/nmcli.bolt"; then
          install -m755 "$bolt_dir/nmcli.bolt" "$nmcli_opt"
          echo "BOLT: nmcli optimized"
        else
          echo "BOLT: nmcli optimization failed; restoring PGO binary"
          install -m755 "$bolt_dir/nmcli.orig" "$nmcli_opt"
        fi
      else
        echo "BOLT: no nmcli profile; restoring PGO binary"
        install -m755 "$bolt_dir/nmcli.orig" "$nmcli_opt"
      fi
    fi

    if (( have_libnm )); then
      if [[ -s "$merged_lib" ]]; then
        if llvm-bolt "$bolt_dir/libnm.so.orig" \
            --relocs \
            --data="$merged_lib" \
            --reorder-blocks=ext-tsp \
            --reorder-functions=cdsort \
            --split-functions \
            --split-strategy=cdsplit \
            --icf=all \
            --jump-tables=move \
            --peepholes=all \
            --reg-reassign \
            --use-aggr-reg-reassign \
            "${align_flags[@]}" \
            --dyno-stats \
            -o "$bolt_dir/libnm.so.bolt"; then
          install -m755 "$bolt_dir/libnm.so.bolt" "$libnm_real"
          echo "BOLT: libnm optimized"
        else
          echo "BOLT: libnm optimization failed; restoring PGO library"
          install -m755 "$bolt_dir/libnm.so.orig" "$libnm_real"
        fi
      else
        echo "BOLT: no libnm profile; restoring PGO library"
        install -m755 "$bolt_dir/libnm.so.orig" "$libnm_real"
      fi
    fi
  else
    echo "llvm-bolt not found; skipping BOLT"
  fi
}

_pick() {
  local p="$1" f d
  shift
  for f; do
    [[ -e "$f" ]] || continue
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")" 2>/dev/null || true
  done
}

package_networkmanager() {
  depends=(
    audit
    curl
    glib2
    glibc
    iproute2
    jansson
    libgcc
    libmm-glib
    libndp
    libnewt
    libnm
    libpsl
    libteam
    mobile-broadband-provider-info
    nspr
    nss
    readline
    systemd-libs
    wpa_supplicant
  )
  optdepends=(
    'bluez: Bluetooth support'
    'dhcpcd: alternative DHCP client'
    'dnsmasq: connection sharing'
    'firewalld: firewall support'
    'iptables: connection sharing'
    'iwd: wpa_supplicant alternative'
    'libnvme: NBFT support'
    'modemmanager: cellular network support'
    'nftables: connection sharing'
    'openresolv: alternative resolv.conf manager'
    'pacrunner: PAC proxy support'
    'polkit: let non-root users control networking'
    'ppp: dialup connection support'
  )
  backup=(etc/NetworkManager/NetworkManager.conf)
  license+=(GPL-2.0-or-later)

  meson install -C build-opt --destdir "$pkgdir"

  cd "$pkgdir"

  install -d etc/NetworkManager/{conf,dnsmasq}.d
  install -dm700 etc/NetworkManager/system-connections
  install -m644 /dev/stdin etc/NetworkManager/NetworkManager.conf <<'END'
# Configuration file for NetworkManager.
# See "man 5 NetworkManager.conf" for details.
END

  install -Dm644 /dev/stdin usr/lib/NetworkManager/conf.d/20-connectivity.conf <<'END'
[connectivity]
uri=http://ping.archlinux.org/nm-check.txt
END

  shopt -s globstar

  _pick libnm usr/include/libnm
  _pick libnm usr/lib/girepository-1.0/NM-*
  _pick libnm usr/lib/libnm.*
  _pick libnm usr/lib/nm-libnm-helper
  _pick libnm usr/lib/pkgconfig/libnm.pc
  _pick libnm usr/share/gir-1.0/NM-*
  _pick libnm usr/share/vala/vapi/libnm.*

  install -d usr/lib/NetworkManager/dispatcher.d/no-wait.d
}

package_libnm() {
  pkgdesc="NetworkManager client library"
  depends=(
    glib2
    glibc
    libgcc
    nspr
    nss
    systemd-libs
    util-linux-libs
  )
  provides=(libnm.so)

  mv libnm/* "$pkgdir"
}
