pkgbase=systemd
pkgname=(
  'systemd'
  'systemd-libs'
  'systemd-resolvconf'
  'systemd-sysvcompat'
)
pkgver=260.2
pkgrel=2.2
arch=('x86_64')
license=('LGPL-2.1-or-later')
url='https://github.com/systemd/systemd'
makedepends=(
  'acl' 'cryptsetup' 'docbook-xsl' 'gperf' 'lz4' 'xz' 'pam' 'libelf'
  'intltool' 'iptables' 'kmod' 'libarchive' 'libidn2' 'libgcrypt'
  'libmicrohttpd' 'libxcrypt' 'libxslt' 'util-linux'
  'python-jinja' 'python-lxml' 'quota-tools' 'shadow' 'git'
  'meson' 'libseccomp' 'pcre2' 'audit' 'kexec-tools' 'libxkbcommon'
  'bash-completion' 'p11-kit' 'systemd' 'libfido2' 'tpm2-tss' 'rsync'
  'bpf' 'libbpf' 'clang' 'llvm' 'curl' 'gnutls' 'python-pyelftools'
  'libpwquality' 'qrencode' 'python-pefile'
)
conflicts=("mkinitcpio<38-1")
validpgpkeys=(
  '63CDA1E5D3FC22B998D20DD6327F26951A015CC4'  # Lennart Poettering
  'A9EA9081724FFAE0484C35A1A81CEA22BC8C7E2E'  # Luca Boccassi
  '9A774DB5DB996C154EBBFBFDA0099A18E29326E1'  # Yu Watanabe
  '5C251B5FC54EB2F80F407AAAC54CA336CFEB557E'  # Zbigniew Jedrzejewski-Szmek
)
source=(
  "git+https://github.com/systemd/systemd#tag=v${pkgver/rc/-rc}?signed"
  '0001-Use-Arch-Linux-device-access-groups.patch'
  'arch.conf'
  'loader.conf'
  'splash-arch.bmp'
  'systemd-user.pam'
  'systemd-hook'
  '20-systemd-sysusers.hook'
  '21-systemd-tmpfiles.hook'
  '25-systemd-binfmt.hook'
  '25-systemd-catalog.hook'
  '25-systemd-hwdb.hook'
  '25-systemd-sysctl.hook'
  '30-systemd-daemon-reload-system.hook'
  '30-systemd-daemon-reload-user.hook'
  '35-systemd-restart-marked.hook'
  '35-systemd-udev-reload.hook'
  '35-systemd-update.hook'
)
sha512sums=(
  'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
  'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
)

_meson_version="${pkgver}-${pkgrel}"
_systemd_src_dir="${pkgbase}"

_backports=()
_reverts=()

prepare() {
  cd "${_systemd_src_dir}"

  # Replace cdrom/dialout/tape groups with optical/uucp/storage.
  patch -Np1 -i ../0001-Use-Arch-Linux-device-access-groups.patch

  git status &>/dev/null || return 0

  local _c _l
  for _c in "${_backports[@]}"; do
    if [[ "${_c}" == *..* ]]; then
      _l='--reverse'
    else
      _l='--max-count=1'
    fi
    git log --oneline "${_l}" "${_c}"
    git cherry-pick --mainline 1 --no-commit "${_c}"
  done

  for _c in "${_reverts[@]}"; do
    if [[ "${_c}" == *..* ]]; then
      _l='--reverse'
    else
      _l='--max-count=1'
    fi
    git log --oneline "${_l}" "${_c}"
    git revert --mainline 1 --no-commit "${_c}"
  done
}

build() {
  local _timeservers=({0..3}.de.pool.ntp.org)
  local _nameservers=(
    '1.1.1.1#cloudflare-dns.com'
    '2606:4700:4700::1111#cloudflare-dns.com'
  )

  local _meson_options=(
    -Dversion-tag="${_meson_version}-cachyos"
    -Dvcs-tag=false
    -Dshared-lib-tag="${_meson_version}"
    -Dmode=release

    -Dapparmor=disabled
    -Dbootloader=disabled
    -Dxenctrl=disabled
    -Dbpf-framework=enabled
    -Dima=false
    -Dinstall-tests=false
    -Dlibidn2=enabled
    -Dlz4=enabled
    -Dman=enabled
    -Dselinux=disabled
    -Dsshdprivsepdir=/usr/share/empty.sshd
    -Dsysupdated=enabled
    -Dvmlinux-h=provided
    -Dvmlinux-h-path=/usr/src/linux-cachyos/vmlinux.h
    -Dukify=disabled
    -Dwerror=false

    -Ddbuspolicydir=/usr/share/dbus-1/system.d
    -Ddefault-dnssec=no
    -Ddefault-kill-user-processes=false
    -Ddefault-locale='C.UTF-8'
    -Dlocalegen-path=/usr/bin/locale-gen
    -Ddns-over-tls=openssl
    -Dfallback-hostname='cachyos'
    -Dnologin-path=/usr/bin/nologin
    -Dntp-servers="${_timeservers[*]}"
    -Ddns-servers="${_nameservers[*]}"
    -Drpmmacrosdir=no

    -Dsbat-distro='cachyos'
    -Dsbat-distro-summary='CachyOS'
    -Dsbat-distro-pkgname="${pkgbase}"
    -Dsbat-distro-version="${pkgver}"
    -Dsbat-distro-url='https://cachyos.org/'
  )

  local _pgo_dir="${srcdir}/pgo-data"
  local _pgo_raw="${_pgo_dir}/raw"
  local _pgo_profdata="${_pgo_dir}/systemd.profdata"
  mkdir -p "${_pgo_raw}"

  _run_training_workload() {
    local build_dir="$1"
    msg2 "Running LLVM PGO training workload in ${build_dir}..."
    cd "${build_dir}"

    export SYSTEMD_PAGER=cat
    export PAGER=cat
    export SYSTEMD_LOG_LEVEL=warning
    export SYSTEMD_LOG_TARGET=console

    local T='timeout --signal=TERM --kill-after=2 8'
    _run_cmd() {
      ${T} "$@" &>/dev/null || true
    }

    local _fixtures="${PWD}/pgo-fixtures"
    local _fakeroot="${PWD}/pgo-root"

    install -d "${_fixtures}/system" "${_fixtures}/tmpfiles.d" "${_fixtures}/sysusers.d" "${_fakeroot}"

    cat >"${_fixtures}/system/pgo-test.service" <<'EOF'
[Unit]
Description=PGO Test Service
Documentation=man:systemd.service(5)

[Service]
Type=oneshot
ExecStart=/usr/bin/true
TimeoutStartSec=2
EOF

    cat >"${_fixtures}/system/pgo-timer.timer" <<'EOF'
[Unit]
Description=PGO Test Timer

[Timer]
OnCalendar=hourly
RandomizedDelaySec=5

[Install]
WantedBy=timers.target
EOF

    cat >"${_fixtures}/tmpfiles.d/pgo-test.conf" <<'EOF'
d /tmp/pgo-test 0755 root root -
f /tmp/pgo-test/state 0644 root root - pgo
EOF

    cat >"${_fixtures}/sysusers.d/pgo-test.conf" <<'EOF'
g pgotest - "PGO group"
u pgotest - "PGO user" /nonexistent
m pgotest pgotest
EOF

    # Core and analysis paths.
    _run_cmd ./systemd --version
    _run_cmd ./systemd-analyze --version
    _run_cmd ./systemd-analyze unit-paths
    _run_cmd ./systemd-analyze filesystems
    _run_cmd ./systemd-analyze calendar 'hourly'
    _run_cmd ./systemd-analyze timestamp 'now + 2h'
    _run_cmd ./systemd-analyze verify \
      "${_fixtures}/system/pgo-test.service" \
      "${_fixtures}/system/pgo-timer.timer"
    _run_cmd ./systemd-analyze security --offline=yes "${_fixtures}/system/pgo-test.service"

    # Manager/query frontends.
    _run_cmd ./systemctl --version
    _run_cmd ./systemctl list-units --all --no-pager
    _run_cmd ./systemctl list-unit-files --no-pager
    _run_cmd ./systemctl list-timers --all --no-pager
    _run_cmd ./systemctl list-dependencies --no-pager
    _run_cmd ./systemctl show --property=Version --no-pager

    [[ -x ./journalctl ]] && {
      _run_cmd ./journalctl --version
      _run_cmd ./journalctl -n 30 --no-pager
      _run_cmd ./journalctl -p err --no-pager
      _run_cmd ./journalctl --disk-usage
      _run_cmd ./journalctl --list-boots
      _run_cmd ./journalctl --header
    }

    [[ -x ./udevadm ]] && {
      _run_cmd ./udevadm info --version
      _run_cmd ./udevadm info --query=all --name=/dev/null
      _run_cmd ./udevadm test-builtin path_id /sys/class/net/lo
      _run_cmd ./udevadm test-builtin net_id /sys/class/net/lo
    }

    [[ -x ./networkctl ]] && {
      _run_cmd ./networkctl list --no-pager
      _run_cmd ./networkctl status lo --no-pager
    }

    [[ -x ./resolvectl ]] && {
      _run_cmd ./resolvectl status --no-pager
      _run_cmd ./resolvectl statistics --no-pager
      _run_cmd ./resolvectl dns --no-pager
    }

    [[ -x ./loginctl ]] && {
      _run_cmd ./loginctl list-sessions --no-pager
      _run_cmd ./loginctl list-users --no-pager
    }

    [[ -x ./timedatectl ]] && {
      _run_cmd ./timedatectl status --no-pager
      _run_cmd ./timedatectl list-timezones
    }

    [[ -x ./hostnamectl ]] && _run_cmd ./hostnamectl status --no-pager
    [[ -x ./localectl ]] && _run_cmd ./localectl status --no-pager
    [[ -x ./bootctl ]] && _run_cmd ./bootctl status --no-pager
    [[ -x ./coredumpctl ]] && _run_cmd ./coredumpctl list --no-pager

    [[ -x ./busctl ]] && {
      _run_cmd ./busctl list --no-pager
      _run_cmd ./busctl tree --no-pager
    }

    # Standalone binaries and parsers.
    [[ -x ./systemd-path ]] && {
      _run_cmd ./systemd-path search-binaries-default
      _run_cmd ./systemd-path system-runtime
      _run_cmd ./systemd-path user-runtime
    }

    [[ -x ./systemd-escape ]] && {
      _run_cmd ./systemd-escape 'test/path with spaces'
      _run_cmd ./systemd-escape --template='%i.service' 'foo/bar'
    }

    [[ -x ./systemd-id128 ]] && {
      _run_cmd ./systemd-id128 new
      _run_cmd ./systemd-id128 machine-id
    }

    [[ -x ./systemd-detect-virt ]] && {
      _run_cmd ./systemd-detect-virt
      _run_cmd ./systemd-detect-virt --container
      _run_cmd ./systemd-detect-virt --vm
    }

    [[ -x ./systemd-cat ]] && echo "pgo-systemd" | _run_cmd ./systemd-cat

    [[ -x ./systemd-tmpfiles ]] && {
      _run_cmd ./systemd-tmpfiles --create "${_fixtures}/tmpfiles.d/pgo-test.conf"
      _run_cmd ./systemd-tmpfiles --clean "${_fixtures}/tmpfiles.d/pgo-test.conf"
    }

    [[ -x ./systemd-sysusers ]] && {
      _run_cmd ./systemd-sysusers --dry-run "${_fixtures}/sysusers.d/pgo-test.conf"
      _run_cmd ./systemd-sysusers --root "${_fakeroot}" "${_fixtures}/sysusers.d/pgo-test.conf"
    }

    [[ -x ./systemd-creds ]] && {
      echo "pgo-secret" >"${_fixtures}/secret.txt"
      _run_cmd ./systemd-creds encrypt "${_fixtures}/secret.txt" "${_fixtures}/secret.cred"
      [[ -f "${_fixtures}/secret.cred" ]] && _run_cmd ./systemd-creds decrypt "${_fixtures}/secret.cred"
    }

    cd "${srcdir}"
    msg2 "LLVM PGO training workload completed."
  }

  msg2 "LLVM PGO Stage 1: Building instrumented binaries..."
  rm -rf build-pgo-gen build
  export CC=clang
  export CXX=clang++

  arch-meson "${_systemd_src_dir}" build-pgo-gen "${_meson_options[@]}" \
    -Dc_args="${CFLAGS} -fprofile-instr-generate=${_pgo_raw}/%m.profraw" \
    -Dcpp_args="${CXXFLAGS} -fprofile-instr-generate=${_pgo_raw}/%m.profraw" \
    -Dc_link_args="${LDFLAGS} -fprofile-instr-generate=${_pgo_raw}/%m.profraw" \
    -Dcpp_link_args="${LDFLAGS} -fprofile-instr-generate=${_pgo_raw}/%m.profraw"

  meson compile -C build-pgo-gen

  msg2 "LLVM PGO Stage 2: Running training workload..."
  _run_training_workload build-pgo-gen

  msg2 "LLVM PGO Stage 3: Merging profile data..."
  shopt -s nullglob
  local _raw_profiles=("${_pgo_raw}"/*.profraw)
  shopt -u nullglob
  (( ${#_raw_profiles[@]} )) || {
    printf '%s\n' "ERROR: No .profraw files were generated by the training workload." >&2
    return 1
  }
  llvm-profdata merge -output="${_pgo_profdata}" "${_raw_profiles[@]}"

  msg2 "LLVM PGO Stage 4: Building optimized binaries..."
  arch-meson "${_systemd_src_dir}" build "${_meson_options[@]}" \
    -Dc_args="${CFLAGS} -fprofile-instr-use=${_pgo_profdata} -Wno-profile-instr-unprofiled -Wno-profile-instr-out-of-date" \
    -Dcpp_args="${CXXFLAGS} -fprofile-instr-use=${_pgo_profdata} -Wno-profile-instr-unprofiled -Wno-profile-instr-out-of-date" \
    -Dc_link_args="${LDFLAGS} -fprofile-instr-use=${_pgo_profdata}" \
    -Dcpp_link_args="${LDFLAGS} -fprofile-instr-use=${_pgo_profdata}"

  meson compile -C build
}

check() {
  meson test -C build --print-errorlogs
}

package_systemd() {
  pkgdesc='system and service manager'
  license+=(
    'CC0-1.0'
    'GPL-2.0-or-later'
    'MIT-0'
  )
  depends=(
    "systemd-libs=${pkgver}"
    'acl' 'bash' 'cryptsetup' 'libcryptsetup.so' 'dbus'
    'dbus-units' 'kbd' 'kmod' 'hwdata'
    'libgcrypt' 'libxcrypt' 'libcrypt.so' 'libidn2' 'lz4' 'pam'
    'libelf' 'libseccomp' 'util-linux' 'xz' 'pcre2' 'audit'
    'openssl' 'libcrypto.so' 'libssl.so'
  )
  provides=('nss-myhostname' "systemd-tools=$pkgver" "udev=$pkgver")
  replaces=('nss-myhostname' 'systemd-tools' 'udev')
  conflicts=('nss-myhostname' 'systemd-tools' 'udev')
  optdepends=(
    'libmicrohttpd: systemd-journal-gatewayd and systemd-journal-remote'
    'quota-tools: kernel-level quota management'
    'systemd-sysvcompat: symlink package to provide sysvinit binaries'
    'polkit: allow administration as unprivileged user'
    'curl: systemd-journal-upload, machinectl pull-tar and pull-raw'
    'gnutls: systemd-journal-gatewayd and systemd-journal-remote'
    'qrencode: show QR codes'
    'iptables: firewall features'
    'libarchive: convert DDIs to tarballs'
    'libbpf: support BPF programs'
    'libpwquality: check password quality'
    'libfido2: unlocking LUKS2 volumes with FIDO2 token'
    'libp11-kit: support PKCS#11'
    'tpm2-tss: unlocking LUKS2 volumes with TPM2'
  )
  backup=(
    etc/pam.d/systemd-user
    etc/systemd/coredump.conf
    etc/systemd/homed.conf
    etc/systemd/journald.conf
    etc/systemd/journal-remote.conf
    etc/systemd/journal-upload.conf
    etc/systemd/logind.conf
    etc/systemd/networkd.conf
    etc/systemd/oomd.conf
    etc/systemd/pstore.conf
    etc/systemd/resolved.conf
    etc/systemd/sleep.conf
    etc/systemd/system.conf
    etc/systemd/timesyncd.conf
    etc/systemd/user.conf
    etc/udev/iocost.conf
    etc/udev/udev.conf
  )
  install=systemd.install

  meson install -C build --no-rebuild --destdir "$pkgdir" --quiet

  # We'll create this on installation.
  rmdir "$pkgdir"/var/log/journal/remote

  # Runtime libraries shipped with systemd-libs.
  install -d -m0755 systemd-libs/lib/
  mv "$pkgdir"/usr/lib/lib{nss,systemd,udev}*.so* systemd-libs/lib/
  mv "$pkgdir"/usr/lib/pkgconfig systemd-libs/lib/pkgconfig
  mv "$pkgdir"/usr/include systemd-libs/include
  mv "$pkgdir"/usr/share/man/man3 systemd-libs/man3

  # Manpages shipped with systemd-sysvcompat.
  rm "$pkgdir"/usr/share/man/man8/{halt,poweroff,reboot,shutdown}.8

  # Executables (symlinks) shipped with systemd-sysvcompat.
  rm "$pkgdir"/usr/bin/{halt,init,poweroff,reboot,shutdown}

  # Files shipped with systemd-resolvconf.
  rm "$pkgdir"/usr/{bin/resolvconf,share/man/man1/resolvconf.1}

  # Avoid potential conflict with [core]/filesystem.
  rm "$pkgdir"/usr/share/factory/etc/{issue,nsswitch.conf}
  sed -i -e '/^C \/etc\/nsswitch\.conf/d' \
         -e '/^C \/etc\/issue/d' "$pkgdir"/usr/lib/tmpfiles.d/etc.conf

  # Ship default policy to leave services disabled.
  echo 'disable *' >"$pkgdir"/usr/lib/systemd/system-preset/99-default.preset

  # The group 'systemd-journal' is allocated dynamically and may have varying
  # gid on different systems. Install with gid 0 (root), systemd-tmpfiles
  # will fix permissions. (see /usr/lib/tmpfiles.d/systemd.conf)
  install -d -o root -g root -m 2755 "$pkgdir"/var/log/journal

  # Example bootctl configuration.
  install -D -m0644 arch.conf "$pkgdir"/usr/share/systemd/bootctl/arch.conf
  install -D -m0644 loader.conf "$pkgdir"/usr/share/systemd/bootctl/loader.conf
  install -D -m0644 splash-arch.bmp "$pkgdir"/usr/share/systemd/bootctl/splash-arch.bmp

  # Pacman hooks.
  install -D -m0755 systemd-hook "$pkgdir"/usr/share/libalpm/scripts/systemd-hook
  install -D -m0644 -t "$pkgdir"/usr/share/libalpm/hooks *.hook

  # Overwrite systemd-user PAM configuration with our own.
  install -D -m0644 systemd-user.pam "$pkgdir"/etc/pam.d/systemd-user

  # Directory for cryptsetup keys.
  install -d -m0700 "$pkgdir"/etc/cryptsetup-keys.d

  # Handle uncommon license.
  install -d -m0755 "$pkgdir"/usr/share/licenses/$pkgbase
  ln -s /usr/share/doc/systemd/LICENSES/MIT-0.txt "$pkgdir"/usr/share/licenses/$pkgbase/

  # Symlink kernel-install to installkernel.
  ln -s kernel-install "$pkgdir"/usr/bin/installkernel
  ln -s kernel-install.8.gz "$pkgdir"/usr/share/man/man8/installkernel.8.gz
}

package_systemd-libs() {
  pkgdesc='systemd client libraries'
  depends=('glibc' 'gcc-libs' 'libgcrypt' 'lz4' 'xz' 'zstd')
  license+=(
    'CC0-1.0'
    'GPL-2.0-or-later WITH Linux-syscall-note'
  )
  provides=('libsystemd' 'libsystemd.so' 'libudev.so')
  conflicts=('libsystemd')
  replaces=('libsystemd')

  install -d -m0755 "$pkgdir"/usr/share/man
  mv systemd-libs/lib "$pkgdir"/usr/lib
  mv systemd-libs/include "$pkgdir"/usr/include
  mv systemd-libs/man3 "$pkgdir"/usr/share/man/man3
}

package_systemd-resolvconf() {
  pkgdesc='systemd resolvconf replacement (for use with systemd-resolved)'
  depends=("systemd=${pkgver}")
  provides=('openresolv' 'resolvconf')
  conflicts=('resolvconf')

  install -d -m0755 "$pkgdir"/usr/bin
  ln -s resolvectl "$pkgdir"/usr/bin/resolvconf

  install -d -m0755 "$pkgdir"/usr/share/man/man1
  ln -s resolvectl.1.gz "$pkgdir"/usr/share/man/man1/resolvconf.1.gz
}

package_systemd-sysvcompat() {
  pkgdesc='sysvinit compat for systemd'
  conflicts=('sysvinit')
  depends=("systemd=${pkgver}")

  install -D -m0644 -t "$pkgdir"/usr/share/man/man8 \
    build/man/{halt,poweroff,reboot,shutdown}.8

  install -d -m0755 "$pkgdir"/usr/bin
  ln -s ../lib/systemd/systemd "$pkgdir"/usr/bin/init
  for tool in halt poweroff reboot shutdown; do
    ln -s systemctl "$pkgdir"/usr/bin/$tool
  done
}

