_create_trainer_source() {
  cat > "${1}" << 'EOF'
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <pci/pci.h>

#define ARRAY_SIZE(a) (sizeof(a) / sizeof((a)[0]))

static uint32_t xs32(uint32_t *state) {
    uint32_t x = *state;
    x ^= x << 13;
    x ^= x >> 17;
    x ^= x << 5;
    *state = x ? x : 0x9e3779b9u;
    return *state;
}

static unsigned class_weight(unsigned class_code) {
    switch ((class_code >> 8) & 0xffu) {
        case 0x03: return 32; /* display / GPU */
        case 0x06: return 18; /* bridges / root ports */
        case 0x01: return 14; /* storage */
        case 0x04: return 12; /* audio */
        case 0x0c: return 12; /* USB / serial bus */
        case 0x02: return 10; /* network */
        default:   return 4;
    }
}

static void warm_name_lookups(struct pci_access *pacc, struct pci_dev *dev) {
    char buf[512];

    (void) pci_lookup_name(pacc, buf, sizeof(buf),
                           PCI_LOOKUP_VENDOR, dev->vendor_id);
    (void) pci_lookup_name(pacc, buf, sizeof(buf),
                           PCI_LOOKUP_DEVICE, dev->vendor_id, dev->device_id);
    (void) pci_lookup_name(pacc, buf, sizeof(buf),
                           PCI_LOOKUP_CLASS, dev->device_class);

    if (dev->subsys_vendor_id || dev->subsys_id) {
        (void) pci_lookup_name(pacc, buf, sizeof(buf),
                               PCI_LOOKUP_SUBSYSTEM,
                               dev->vendor_id, dev->device_id,
                               dev->subsys_vendor_id, dev->subsys_id);
    }
}

static void config_reads(struct pci_dev *dev, unsigned weight) {
    static const int hot_dwords[] = {
        0x00, 0x04, 0x08, 0x0c, 0x10, 0x14, 0x18, 0x1c,
        0x20, 0x24, 0x2c, 0x30, 0x34, 0x3c
    };
    static const int hot_words[] = {
        0x00, 0x02, 0x04, 0x06, 0x0a, 0x2c, 0x2e, 0x3c, 0x3e
    };
    static const int hot_bytes[] = {
        0x08, 0x09, 0x0a, 0x0b, 0x0e, 0x0f, 0x34, 0x3c, 0x3d
    };

    uint32_t seed;
    unsigned rounds;
    unsigned random_reads;
    unsigned r;
    size_t i;
    unsigned char block[256];

    seed = 0x9e3779b9u
         ^ ((uint32_t) dev->vendor_id << 16)
         ^ (uint32_t) dev->device_id
         ^ ((uint32_t) dev->bus << 8)
         ^ ((uint32_t) dev->dev << 3)
         ^ (uint32_t) dev->func
         ^ (uint32_t) dev->device_class;

    rounds = 2u + (weight / 6u);
    random_reads = 32u + (weight * 4u);

    for (r = 0; r < rounds; ++r) {
        for (i = 0; i < ARRAY_SIZE(hot_dwords); ++i)
            (void) pci_read_long(dev, hot_dwords[i]);
        for (i = 0; i < ARRAY_SIZE(hot_words); ++i)
            (void) pci_read_word(dev, hot_words[i]);
        for (i = 0; i < ARRAY_SIZE(hot_bytes); ++i)
            (void) pci_read_byte(dev, hot_bytes[i]);
    }

    (void) pci_read_block(dev, 0x00, block, 64);
    if (weight >= 12u)
        (void) pci_read_block(dev, 0x00, block, 128);

    for (r = 0; r < random_reads; ++r) {
        unsigned off = (xs32(&seed) & 0x3fu) << 2;
        (void) pci_read_long(dev, (int) off);
    }
}

static void exercise_devices(struct pci_access *pacc, int class_filter, unsigned bonus) {
    struct pci_dev *dev;

    for (dev = pacc->devices; dev; dev = dev->next) {
        unsigned fill;
        unsigned weight;

        fill = PCI_FILL_IDENT | PCI_FILL_CLASS | PCI_FILL_SUBSYS |
               PCI_FILL_BASES | PCI_FILL_SIZES;
        (void) pci_fill_info(dev, fill);

        if (class_filter >= 0 && ((int) (dev->device_class >> 8) != class_filter))
            continue;

        weight = class_weight(dev->device_class) + bonus;
        warm_name_lookups(pacc, dev);
        config_reads(dev, weight);
    }
}

static void one_scan_pass(int class_filter, unsigned bonus, unsigned rounds) {
    unsigned r;

    for (r = 0; r < rounds; ++r) {
        struct pci_access *pacc = pci_alloc();
        if (!pacc)
            return;

        pci_init(pacc);
        pci_scan_bus(pacc);
        exercise_devices(pacc, class_filter, bonus);
        pci_cleanup(pacc);
    }
}

static void train_all(void) {
    one_scan_pass(-1, 0u, 2u);
    one_scan_pass(0x03, 8u, 2u);
    one_scan_pass(0x06, 6u, 2u);
    one_scan_pass(0x01, 5u, 2u);
    one_scan_pass(0x04, 4u, 1u);
    one_scan_pass(0x0c, 4u, 1u);
    one_scan_pass(0x02, 4u, 1u);
}

static void stress_all(void) {
    unsigned i;
    for (i = 0; i < 12u; ++i)
        one_scan_pass(-1, 3u, 1u);
}

static void benchmark_all(void) {
    unsigned i;
    clock_t start = clock();

    for (i = 0; i < 48u; ++i)
        one_scan_pass(-1, 1u, 1u);

    printf("bench %.6f\n",
           (double) (clock() - start) / (double) CLOCKS_PER_SEC);
}

int main(int argc, char **argv) {
    const char *cmd = (argc >= 2) ? argv[1] : "train";

    if (strcmp(cmd, "train") == 0) {
        train_all();
    } else if (strcmp(cmd, "stress") == 0) {
        stress_all();
    } else if (strcmp(cmd, "bench") == 0) {
        benchmark_all();
    } else if (strcmp(cmd, "gpu") == 0) {
        one_scan_pass(0x03, 8u, 2u);
    } else if (strcmp(cmd, "bridge") == 0) {
        one_scan_pass(0x06, 6u, 2u);
    } else if (strcmp(cmd, "storage") == 0) {
        one_scan_pass(0x01, 5u, 2u);
    } else if (strcmp(cmd, "audio") == 0) {
        one_scan_pass(0x04, 4u, 2u);
    } else if (strcmp(cmd, "usb") == 0) {
        one_scan_pass(0x0c, 4u, 2u);
    } else if (strcmp(cmd, "net") == 0) {
        one_scan_pass(0x02, 4u, 2u);
    } else {
        train_all();
    }

    return 0;
}
EOF
}

_prepare_build_tree() {
  local builddir="$1"

  rm -rf "${builddir}"
  mkdir -p "${builddir}"
  git -C "${srcdir}/pciutils" archive --format=tar HEAD | tar -xf - -C "${builddir}"
}

_make_pciutils_shared() {
  local builddir="$1"

  make -C "${builddir}" \
    OPT="${CFLAGS}" \
    LDFLAGS="${LDFLAGS}" \
    SHARED=yes \
    ZLIB=no \
    DNS=no \
    CC=clang \
    LD=ld.lld \
    AR=llvm-ar \
    RANLIB=llvm-ranlib \
    PREFIX=/usr \
    SBINDIR=/usr/bin \
    SHAREDIR=/usr/share/hwdata \
    all
}

_make_pciutils_static() {
  local builddir="$1"

  make -C "${builddir}" \
    OPT="${CFLAGS}" \
    LDFLAGS="${LDFLAGS}" \
    SHARED=no \
    ZLIB=no \
    DNS=no \
    CC=clang \
    LD=ld.lld \
    AR=llvm-ar \
    RANLIB=llvm-ranlib \
    PREFIX=/usr \
    SBINDIR=/usr/bin \
    SHAREDIR=/usr/share/hwdata \
    all
}

_compile_trainer() {
  local out="$1"
  local builddir="$2"

  clang ${_orig_cflags} ${_orig_ldflags} \
    -I"${builddir}/lib" \
    -L"${builddir}/lib" \
    -Wl,-rpath,"${builddir}/lib" \
    -o "${out}" "${_pgo_dir}/pci_train.c" \
    -lpci
}

_merge_profraw_dir() {
  local out="$1"
  local dir="$2"
  local profraws=()

  shopt -s nullglob
  profraws=("${dir}"/*.profraw)
  shopt -u nullglob

  (( ${#profraws[@]} > 0 )) || return 1
  llvm-profdata merge -output="${out}" "${profraws[@]}"
}

_run_logged() {
  local profile_dir="$1"
  local lib_dir="$2"
  local logfile="$3"
  shift 3

  if [[ -n "${profile_dir}" ]]; then
    LLVM_PROFILE_FILE="${profile_dir}/%p-%m.profraw" \
      LD_LIBRARY_PATH="${lib_dir}" \
      "$@" > "${logfile}" 2>&1 || true
  else
    LD_LIBRARY_PATH="${lib_dir}" \
      "$@" > "${logfile}" 2>&1 || true
  fi
}

_capture_stdout() {
  local profile_dir="$1"
  local lib_dir="$2"
  local outfile="$3"
  shift 3

  if [[ -n "${profile_dir}" ]]; then
    LLVM_PROFILE_FILE="${profile_dir}/%p-%m.profraw" \
      LD_LIBRARY_PATH="${lib_dir}" \
      "$@" > "${outfile}" 2>/dev/null || true
  else
    LD_LIBRARY_PATH="${lib_dir}" \
      "$@" > "${outfile}" 2>/dev/null || true
  fi
}

_resolve_shared_lib() {
  local builddir="$1"
  local resolved

  resolved="$(readlink -f "${builddir}/lib/libpci.so" 2>/dev/null || true)"
  if [[ -n "${resolved}" && -f "${resolved}" ]]; then
    printf '%s\n' "${resolved}"
    return 0
  fi

  resolved="$(find "${builddir}/lib" -maxdepth 1 -type f -name 'libpci.so*' | LC_ALL=C sort | tail -n 1)"
  if [[ -n "${resolved}" && -f "${resolved}" ]]; then
    printf '%s\n' "${resolved}"
    return 0
  fi

  return 1
}

_lib_has_nonunique_global_function_bases() {
  local target="$1"

  readelf -Ws "${target}" 2>/dev/null | awk '
    $4 == "FUNC" && $5 == "GLOBAL" && $7 != "UND" && $8 != "" {
      name = $8
      sub(/@.*/, "", name)
      if (name == "")
        next
      addr = $2
      key = name SUBSEP addr
      if (!(key in seen)) {
        seen[key] = 1
        count[name]++
      }
    }
    END {
      bad = 0
      for (n in count) {
        if (count[n] > 1) {
          print n
          bad = 1
        }
      }
      exit bad ? 0 : 1
    }
  '
}

_bolt_instrument_target() {
  local target="$1"
  local prefix="$2"
  local backup="${target}.orig"
  local inst="${target}.bolt.inst"

  rm -f "${backup}" "${inst}"
  cp -a "${target}" "${backup}"

  if llvm-bolt "${backup}" \
    --instrument \
    --instrumentation-file="${prefix}" \
    --instrumentation-file-append-pid \
    -o "${inst}"; then
    mv -f "${inst}" "${target}"
    return 0
  fi

  rm -f "${backup}" "${inst}"
  return 1
}

_bolt_apply_target() {
  local target="$1"
  local prefix="$2"
  local merged="$3"
  local backup="${target}.orig"
  local out="${target}.bolt"

  if [[ ! -f "${backup}" ]]; then
    return 0
  fi

  if ! compgen -G "${prefix}.*" >/dev/null; then
    warning "No BOLT profiles collected for $(basename "${target}"), restoring original."
    mv -f "${backup}" "${target}"
    return 0
  fi

  if ! merge-fdata "${prefix}".* -o "${merged}"; then
    warning "merge-fdata failed for $(basename "${target}"), restoring original."
    mv -f "${backup}" "${target}"
    return 0
  fi

  if [[ ! -s "${merged}" ]]; then
    warning "Merged BOLT profile is empty for $(basename "${target}"), restoring original."
    mv -f "${backup}" "${target}"
    return 0
  fi

  if llvm-bolt "${backup}" \
    --data="${merged}" \
    -o "${out}" \
    --dyno-stats \
    --lite=false \
    --split-functions --split-all-cold --split-eh \
    --split-strategy=cdsplit \
    --icf=all \
    --plt=all \
    --peepholes=all \
    --indirect-call-promotion=all \
    --reorder-blocks=ext-tsp \
    --reorder-functions=cdsort \
    --x86-strip-redundant-address-size; then
    mv -f "${out}" "${target}"
    return 0
  fi

  warning "BOLT optimization failed for $(basename "${target}"), restoring original."
  mv -f "${backup}" "${target}"
  rm -f "${out}"
  return 0
}

_verify_or_finalize_target() {
  local target="$1"
  local lib_dir="$2"
  shift 2
  local backup="${target}.orig"
  local rc=0

  if [[ ! -f "${backup}" ]]; then
    return 0
  fi

  LD_LIBRARY_PATH="${lib_dir}" "$@" >/dev/null 2>&1
  rc=$?

  if (( rc >= 128 )); then
    warning "Detected crash while verifying $(basename "${target}") (exit ${rc}), restoring original."
    mv -f "${backup}" "${target}"
  else
    rm -f "${backup}"
  fi
}

run_profile_training() {
  local builddir="$1"
  local trainer="$2"
  local mode="$3"
  local profile_dir="$4"
  local workdir="${_pgo_dir}/train-${mode}"
  local logs="${workdir}/logs"
  local manifest_raw="${workdir}/inventory.raw"
  local manifest="${workdir}/inventory.weighted"
  local snapshot="${workdir}/lspci.snapshot"
  local macro_passes=1
  local slot class vendor device weight
  local idx=0
  local pass
  local top_slots=()
  local reg
  local bus

  rm -rf "${workdir}"
  mkdir -p "${logs}"

  if [[ -n "${profile_dir}" ]]; then
    mkdir -p "${profile_dir}"
    rm -f "${profile_dir}"/*.profraw
  fi

  if [[ "${mode}" == "bolt" ]]; then
    macro_passes=2
  fi

  msg2 "Collecting PCI inventory (${mode})..."
  _capture_stdout "${profile_dir}" "${builddir}/lib" "${manifest_raw}" \
    "${builddir}/lspci" -D -n

  awk '
    function weight(cls, base) {
      base = substr(cls, 1, 2)
      if (base == "03") return 32
      if (base == "06") return 18
      if (base == "01") return 14
      if (base == "04") return 12
      if (base == "0c") return 12
      if (base == "02") return 10
      return 4
    }
    NF >= 3 {
      cls = $2
      sub(/:$/, "", cls)
      split($3, ids, ":")
      if (ids[1] != "" && ids[2] != "")
        printf "%s %s %s %s %u\n", $1, cls, ids[1], ids[2], weight(cls)
    }
  ' "${manifest_raw}" > "${manifest}"

  msg2 "Running lspci matrix (${mode})..."
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_basic.log" \
    "${builddir}/lspci"
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_D_nn.log" \
    "${builddir}/lspci" -D -nn
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_D_nnk.log" \
    "${builddir}/lspci" -D -nn -k
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_v.log" \
    "${builddir}/lspci" -v
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_vv.log" \
    "${builddir}/lspci" -vv
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_vvv.log" \
    "${builddir}/lspci" -vvv
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_m_nn.log" \
    "${builddir}/lspci" -m -nn
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_mm_nn.log" \
    "${builddir}/lspci" -mm -nn
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_vmm_nn.log" \
    "${builddir}/lspci" -vmm -nn
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_tree.log" \
    "${builddir}/lspci" -t
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_tree_verbose.log" \
    "${builddir}/lspci" -tv
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_path.log" \
    "${builddir}/lspci" -D -PP -nn
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_buscentric.log" \
    "${builddir}/lspci" -b -nn
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_gpu.log" \
    "${builddir}/lspci" -vvnn -k -d ::0300
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_3d.log" \
    "${builddir}/lspci" -vvnn -k -d ::0302
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_net.log" \
    "${builddir}/lspci" -vvnn -k -d ::0200
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_storage.log" \
    "${builddir}/lspci" -vvnn -k -d ::0100
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_nvme.log" \
    "${builddir}/lspci" -vvnn -k -d ::0108
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_usb.log" \
    "${builddir}/lspci" -vvnn -k -d ::0c03
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_audio.log" \
    "${builddir}/lspci" -vvnn -k -d ::0403
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_bridge.log" \
    "${builddir}/lspci" -vvnn -d ::0604

  _capture_stdout "${profile_dir}" "${builddir}/lib" "${snapshot}" \
    "${builddir}/lspci" -D -nn -vvx
  if [[ -s "${snapshot}" ]]; then
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_snapshot_basic.log" \
      "${builddir}/lspci" -F "${snapshot}"
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_snapshot_nn.log" \
      "${builddir}/lspci" -F "${snapshot}" -nn
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_snapshot_vv.log" \
      "${builddir}/lspci" -F "${snapshot}" -vv
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/lspci_snapshot_tree.log" \
      "${builddir}/lspci" -F "${snapshot}" -tv
  fi

  if [[ -x "${builddir}/setpci" ]]; then
    msg2 "Running setpci matrix (${mode})..."
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/setpci_dumpregs.log" \
      "${builddir}/setpci" --dumpregs
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/setpci_version.log" \
      "${builddir}/setpci" --version
  fi

  msg2 "Running helper library trainer (${mode})..."
  for ((pass = 0; pass < macro_passes; ++pass)); do
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_train_${pass}.log" \
      "${trainer}" train
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_stress_${pass}.log" \
      "${trainer}" stress
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_bench_${pass}.log" \
      "${trainer}" bench
  done
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_gpu.log" \
    "${trainer}" gpu
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_bridge.log" \
    "${trainer}" bridge
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_storage.log" \
    "${trainer}" storage
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_audio.log" \
    "${trainer}" audio
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_usb.log" \
    "${trainer}" usb
  _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/trainer_net.log" \
    "${trainer}" net

  if [[ -s "${manifest}" ]]; then
    msg2 "Running weighted per-device passes (${mode})..."
    while read -r slot class vendor device weight; do
      top_slots+=("${slot}")

      _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/slot_${idx}_vvnnk.log" \
        "${builddir}/lspci" -s "${slot}" -vvnn -k
      _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/slot_${idx}_path.log" \
        "${builddir}/lspci" -D -PP -s "${slot}" -vvnn
      _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/slot_${idx}_machine.log" \
        "${builddir}/lspci" -mm -nn -s "${slot}"

      if (( idx < 4 )); then
        _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/slot_${idx}_vvv.log" \
          "${builddir}/lspci" -s "${slot}" -vvv
        _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/slot_${idx}_xxxx.log" \
          "${builddir}/lspci" -s "${slot}" -xxxx
      fi

      if [[ -x "${builddir}/setpci" ]]; then
        for reg in 00.w 02.w 04.w 08.l 0c.l 10.l 14.l 18.l 1c.l 2c.w 2e.w 34.b 3c.b; do
          _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/slot_${idx}_setpci_${reg//./_}.log" \
            "${builddir}/setpci" -s "${slot}" "${reg}"
        done
      fi

      idx=$((idx + 1))
    done < <(LC_ALL=C sort -k5,5nr "${manifest}" | head -n 16)
  fi

  if (( ${#top_slots[@]} > 0 )); then
    msg2 "Running hot-slot reinforcement passes (${mode})..."
    idx=0
    for slot in "${top_slots[@]}"; do
      if (( idx >= 4 )); then
        break
      fi

      _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/hot_${idx}_detail_1.log" \
        "${builddir}/lspci" -s "${slot}" -vvnn -k
      _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/hot_${idx}_detail_2.log" \
        "${builddir}/lspci" -s "${slot}" -vvnn -k
      _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/hot_${idx}_path.log" \
        "${builddir}/lspci" -D -PP -s "${slot}" -vvnn

      if [[ -x "${builddir}/setpci" ]]; then
        _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/hot_${idx}_cfg_00w.log" \
          "${builddir}/setpci" -s "${slot}" 00.w
        _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/hot_${idx}_cfg_08l.log" \
          "${builddir}/setpci" -s "${slot}" 08.l
        _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/hot_${idx}_cfg_10l.log" \
          "${builddir}/setpci" -s "${slot}" 10.l
      fi

      idx=$((idx + 1))
    done
  fi

  for bus in $(awk '{split($1, a, ":"); print a[1] ":" a[2]}' "${manifest}" 2>/dev/null | LC_ALL=C sort -u | head -n 6); do
    _run_logged "${profile_dir}" "${builddir}/lib" "${logs}/bus_${bus//:/_}.log" \
      "${builddir}/lspci" -s "${bus}:" -vvnn
  done
}

pkgver() {
  cd "${srcdir}/pciutils"
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  export CC=clang
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  _orig_cflags="${CFLAGS}"
  _orig_ldflags="${LDFLAGS}"

  _pgo_dir="${srcdir}/${pkgname}-pgo"
  _std_profraw="${_pgo_dir}/standard"
  _cs_profraw="${_pgo_dir}/cs"
  _std_profdata="${_pgo_dir}/standard.profdata"
  _cs_profdata="${_pgo_dir}/cs.profdata"
  _merged_profdata="${_pgo_dir}/merged.profdata"

  _build_std="${srcdir}/pciutils-build-std"
  _build_cs="${srcdir}/pciutils-build-cs"
  _build_opt_shared="${srcdir}/pciutils-build-opt-shared"
  _build_opt_static="${srcdir}/pciutils-build-opt-static"

  local have_std_profile=0
  local have_cs_profile=0
  local final_profdata=''
  local libpci_target
  local libpci_nonunique_file="${_pgo_dir}/bolt/libpci.nonunique"

  rm -rf "${_pgo_dir}" "${_build_std}" "${_build_cs}" "${_build_opt_shared}" "${_build_opt_static}"
  mkdir -p "${_std_profraw}" "${_cs_profraw}" "${_pgo_dir}/bolt"

  _create_trainer_source "${_pgo_dir}/pci_train.c"

  ###########################################################################
  # Phase 1: Standard PGO instrumentation
  ###########################################################################
  msg2 "Phase 1: Building with standard PGO instrumentation..."

  _prepare_build_tree "${_build_std}"

  export CFLAGS="${_orig_cflags} -fprofile-generate=${_std_profraw} -fno-omit-frame-pointer"
  export LDFLAGS="${_orig_ldflags} -fprofile-generate=${_std_profraw}"

  _make_pciutils_shared "${_build_std}"
  _compile_trainer "${_pgo_dir}/pci_train_std" "${_build_std}"

  run_profile_training "${_build_std}" "${_pgo_dir}/pci_train_std" "pgo-std" "${_std_profraw}"

  if _merge_profraw_dir "${_std_profdata}" "${_std_profraw}"; then
    have_std_profile=1
  else
    warning "No standard PGO profile data collected; continuing without standard PGO."
  fi

  ###########################################################################
  # Phase 2: Context-sensitive PGO instrumentation
  ###########################################################################
  if (( have_std_profile )); then
    msg2 "Phase 2: Building with context-sensitive PGO instrumentation..."

    _prepare_build_tree "${_build_cs}"

    export CFLAGS="${_orig_cflags} -fprofile-use=${_std_profdata} -fprofile-correction -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled -fcs-profile-generate=${_cs_profraw} -fno-omit-frame-pointer"
    export LDFLAGS="${_orig_ldflags} -fcs-profile-generate=${_cs_profraw}"

    _make_pciutils_shared "${_build_cs}"
    _compile_trainer "${_pgo_dir}/pci_train_cs" "${_build_cs}"

    run_profile_training "${_build_cs}" "${_pgo_dir}/pci_train_cs" "pgo-cs" "${_cs_profraw}"

    if _merge_profraw_dir "${_cs_profdata}" "${_cs_profraw}"; then
      have_cs_profile=1
    else
      warning "No CS-PGO profile data collected; falling back to standard PGO profile."
    fi
  else
    msg2 "Phase 2: Skipping CS-PGO because no standard profile data is available."
  fi

  if (( have_std_profile && have_cs_profile )); then
    if llvm-profdata merge -output="${_merged_profdata}" "${_std_profdata}" "${_cs_profdata}"; then
      final_profdata="${_merged_profdata}"
    else
      warning "Merged PGO profile creation failed; falling back to standard PGO profile."
      final_profdata="${_std_profdata}"
    fi
  elif (( have_std_profile )); then
    final_profdata="${_std_profdata}"
  fi

  ###########################################################################
  # Phase 3: Final optimized builds
  ###########################################################################
  msg2 "Phase 3: Building final optimized shared binaries..."

  _prepare_build_tree "${_build_opt_shared}"

  if [[ -n "${final_profdata}" && -f "${final_profdata}" ]]; then
    export CFLAGS="${_orig_cflags} -fprofile-use=${final_profdata} -fprofile-correction -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  else
    export CFLAGS="${_orig_cflags}"
  fi
  export LDFLAGS="${_orig_ldflags} -Wl,--emit-relocs"

  _make_pciutils_shared "${_build_opt_shared}"
  _compile_trainer "${_pgo_dir}/pci_train_opt" "${_build_opt_shared}"

  msg2 "Phase 3b: Building final optimized static library..."
  _prepare_build_tree "${_build_opt_static}"

  if [[ -n "${final_profdata}" && -f "${final_profdata}" ]]; then
    export CFLAGS="${_orig_cflags} -fprofile-use=${final_profdata} -fprofile-correction -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  else
    export CFLAGS="${_orig_cflags}"
  fi
  export LDFLAGS="${_orig_ldflags}"

  _make_pciutils_static "${_build_opt_static}"

  ###########################################################################
  # Phase 4: BOLT instrumentation + training
  ###########################################################################
  if [[ "${CARCH}" == x86_64 ]] && command -v llvm-bolt >/dev/null 2>&1 && command -v merge-fdata >/dev/null 2>&1; then
    msg2 "Phase 4: BOLT instrumentation and training..."

    libpci_target="$(_resolve_shared_lib "${_build_opt_shared}")" || {
      error "Could not resolve libpci shared object in ${_build_opt_shared}/lib"
      return 1
    }

    if _lib_has_nonunique_global_function_bases "${libpci_target}" | LC_ALL=C sort -u > "${libpci_nonunique_file}"; then
      warning "Skipping BOLT for $(basename "${libpci_target}") due to non-unique exported function base names incompatible with current llvm-bolt."
      while read -r sym; do
        [[ -n "${sym}" ]] && warning "  duplicate base symbol: ${sym}"
      done < "${libpci_nonunique_file}"
    else
      _bolt_instrument_target "${libpci_target}" "${_pgo_dir}/bolt/libpci.fdata" || true
    fi

    [[ -x "${_build_opt_shared}/lspci" ]] && \
      _bolt_instrument_target "${_build_opt_shared}/lspci" "${_pgo_dir}/bolt/lspci.fdata" || true
    [[ -x "${_build_opt_shared}/setpci" ]] && \
      _bolt_instrument_target "${_build_opt_shared}/setpci" "${_pgo_dir}/bolt/setpci.fdata" || true

    run_profile_training "${_build_opt_shared}" "${_pgo_dir}/pci_train_opt" "bolt" ""

    _bolt_apply_target "${libpci_target}" "${_pgo_dir}/bolt/libpci.fdata" "${_pgo_dir}/bolt/libpci.merged.fdata"
    _bolt_apply_target "${_build_opt_shared}/lspci" "${_pgo_dir}/bolt/lspci.fdata" "${_pgo_dir}/bolt/lspci.merged.fdata"
    _bolt_apply_target "${_build_opt_shared}/setpci" "${_pgo_dir}/bolt/setpci.fdata" "${_pgo_dir}/bolt/setpci.merged.fdata"
  else
    warning "BOLT tools unavailable or unsupported architecture; skipping BOLT optimization."
  fi

  ###########################################################################
  # Phase 5: Verification and finalization
  ###########################################################################
  msg2 "Phase 5: Verifying final output..."

  if [[ -x "${_build_opt_shared}/lspci" ]]; then
    _verify_or_finalize_target "${_build_opt_shared}/lspci" "${_build_opt_shared}/lib" \
      "${_build_opt_shared}/lspci" -nn
  fi

  if [[ -x "${_build_opt_shared}/setpci" ]]; then
    _verify_or_finalize_target "${_build_opt_shared}/setpci" "${_build_opt_shared}/lib" \
      "${_build_opt_shared}/setpci" --dumpregs
  fi

  if [[ -n "${libpci_target}" && -f "${libpci_target}" ]]; then
    _verify_or_finalize_target "${libpci_target}" "${_build_opt_shared}/lib" \
      "${_build_opt_shared}/lspci" -nn
  fi

  LD_LIBRARY_PATH="${_build_opt_shared}/lib" "${_pgo_dir}/pci_train_opt" bench >/dev/null 2>&1 || true

  export CFLAGS="${_orig_cflags}"
  export LDFLAGS="${_orig_ldflags}"

  unset _orig_cflags _orig_ldflags
  unset _pgo_dir _std_profraw _cs_profraw _std_profdata _cs_profdata _merged_profdata
  unset _build_std _build_cs _build_opt_shared _build_opt_static
}

check() {
  local builddir="${srcdir}/pciutils-build-opt-shared"

  [[ -d "${builddir}" ]] || return 0

  if [[ -x "${builddir}/lspci" ]]; then
    LD_LIBRARY_PATH="${builddir}/lib" "${builddir}/lspci" -nn >/dev/null 2>&1 || true
  fi

  if [[ -x "${builddir}/setpci" ]]; then
    LD_LIBRARY_PATH="${builddir}/lib" "${builddir}/setpci" --dumpregs >/dev/null 2>&1 || true
  fi
}

package() {
  local builddir="${srcdir}/pciutils-build-opt-shared"
  local staticdir="${srcdir}/pciutils-build-opt-static"

  make -C "${builddir}" \
    DESTDIR="${pkgdir}" \
    PREFIX=/usr \
    SBINDIR=/usr/bin \
    SHAREDIR=/usr/share/hwdata \
    SHARED=yes \
    ZLIB=no \
    DNS=no \
    install \
    install-lib

  if [[ -f "${staticdir}/lib/libpci.a" ]]; then
    install -Dm644 "${staticdir}/lib/libpci.a" "${pkgdir}/usr/lib/libpci.a"
  fi

  rm -rf "${pkgdir}/usr"/{bin/update-pciids,share/{hwdata,man/man8/update-pciids.8}}

  if [[ -f "${srcdir}/pciutils/COPYING" ]]; then
    install -Dm644 "${srcdir}/pciutils/COPYING" \
      "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
  fi
}
