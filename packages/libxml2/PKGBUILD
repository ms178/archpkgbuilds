pkgname=libxml2
pkgver=2.15.3
pkgrel=6.1
pkgdesc="XML C parser and toolkit"
url="https://gitlab.gnome.org/GNOME/libxml2/-/wikis/home"
arch=(x86_64)
license=(MIT)
depends=(
  bash
  glibc
  icu
  readline
  zlib
)
makedepends=(
  clang
  git
  lld
  llvm
  meson
)
provides=(libxml2.so)
source=(
  "git+https://gitlab.gnome.org/GNOME/libxml2.git#tag=v${pkgver}"
  https://www.w3.org/XML/Test/xmlts20130923.tar.gz
)
b2sums=(
  'bcf3ac7f06fb875d20f62b6f1ecb4c406d28d86e8124e9781a8d6fae8b3815062a6fa152fc4c570fb5c2d162b1eee4b9cf3ac5c17f434d71b72807fce0d57e41'
  '63a47bc69278ef510cd0b3779aed729e1b309e30efa0015d28ed051cc03f9dfddb447ab57b07b3393e8f47393d15473b0e199c34cb1f5f746b15ddfaa55670be'
)

# ── Build-directory names (plain names — never full paths at global scope) ─────
_builddir_pgo1="build-pgo1"   # Standard PGO instrumentation
_builddir_pgo2="build-pgo2"   # Context-sensitive PGO instrumentation
_builddir_opt="build-opt"     # Final PGO optimised build

# ── Common instrumentation flags (PGO stages only) ────────────────────────────
_pgo_instrument_cflags=(
  "-g3"
  "-fno-omit-frame-pointer"
  "-mllvm" "-vp-counters-per-site=16"
  "-mllvm" "-runtime-counter-relocation"
  "-mllvm" "-enable-value-profiling"
)

# ──────────────────────────────────────────────────────────────────────────────
prepare() {
  cd libxml2
  # Symlink the W3C XML conformance test suite so xmlconf tests resolve.
  ln -s ../xmlconf xmlconf
}

# ──────────────────────────────────────────────────────────────────────────────
# _configure_libxml2 <builddir_name>
# ──────────────────────────────────────────────────────────────────────────────
_configure_libxml2() {
  local builddir_name="$1"
  local builddir="${srcdir}/${builddir_name}"

  local -a meson_opts=(
    -D icu=enabled
    -D legacy=enabled
    -D docs=disabled
    -D python=enabled
  )

  arch-meson libxml2 "${builddir}" "${meson_opts[@]}"
}

# ──────────────────────────────────────────────────────────────────────────────
# _run_pgo_workload <builddir_name>
#   Full training workload for PGO stages (includes meson test suite).
# ──────────────────────────────────────────────────────────────────────────────
_run_pgo_workload() {
  local builddir="${srcdir}/${1}"
  local xmllint="${builddir}/xmllint"

  # Official meson test suite — exercises C-level code paths
  meson test -C "${builddir}" --print-errorlogs --no-rebuild -q || true

  [[ -x "${xmllint}" ]] || {
    echo "WARNING: xmllint not found at ${xmllint}" >&2
    return 0
  }

  _run_xmllint_workload "${1}"
}

# ──────────────────────────────────────────────────────────────────────────────
# _run_xmllint_workload <builddir_name>
#   xmllint/xmlcatalog-based training corpus.
# ──────────────────────────────────────────────────────────────────────────────
_run_xmllint_workload() {
  local builddir="${srcdir}/${1}"
  local xmllint="${builddir}/xmllint"
  local xmlcatalog="${builddir}/xmlcatalog"
  local workdir="${srcdir}/pgo-work"

  [[ -x "${xmllint}" ]] || return 0

  # ── Collect XML corpus ───────────────────────────────────────────────────────
  local -a xml_files=()
  mapfile -t xml_files < <(
    find \
      "${srcdir}/libxml2/test" \
      "${srcdir}/xmlconf" \
      -type f \
      \( -name '*.xml' -o -name '*.xhtml' -o -name '*.svg' \
         -o -name '*.rdf' -o -name '*.html' \) \
    | sort
  )

  local -a html_files=()
  mapfile -t html_files < <(
    find "${srcdir}/libxml2/test" -type f -name '*.html' | sort
  )

  # ── Multi-pass file corpus ───────────────────────────────────────────────────
  local xml
  for xml in "${xml_files[@]}"; do
    "${xmllint}" --nonet --noout "${xml}" >/dev/null 2>&1 || true
  done
  for xml in "${xml_files[@]:0:700}"; do
    "${xmllint}" --nonet --recover --noout "${xml}" >/dev/null 2>&1 || true
  done
  for xml in "${xml_files[@]:0:500}"; do
    "${xmllint}" --nonet --stream --noout "${xml}" >/dev/null 2>&1 || true
  done
  for xml in "${xml_files[@]:0:300}"; do
    "${xmllint}" --nonet --push --noout "${xml}" >/dev/null 2>&1 || true
  done
  for xml in "${xml_files[@]:0:200}"; do
    "${xmllint}" --nonet --sax    --noout "${xml}" >/dev/null 2>&1 || true
    "${xmllint}" --nonet --format --noout "${xml}" >/dev/null 2>&1 || true
  done
  for xml in "${xml_files[@]:0:300}"; do
    "${xmllint}" --nonet --noent  --noout "${xml}" >/dev/null 2>&1 || true
  done
  for xml in "${xml_files[@]:0:200}"; do
    "${xmllint}" --nonet --valid  --noout "${xml}" >/dev/null 2>&1 || true
  done

  # ── HTML parser ──────────────────────────────────────────────────────────────
  for xml in "${html_files[@]}"; do
    "${xmllint}" --html --noout    "${xml}" >/dev/null 2>&1 || true
    "${xmllint}" --html --recover --noout "${xml}" >/dev/null 2>&1 || true
  done

  # ── XPath ────────────────────────────────────────────────────────────────────
  local -a xpath_exprs=(
    "/*" "//*[@id]" "//*[local-name()='a']" "count(//*)"
    "string(//title[1])" "//*[contains(@class,'item')]"
    "//node()[not(self::text())]"
    "substring-before(normalize-space(//text()[1]),' ')"
  )

  local xpath_src="${srcdir}/libxml2/test/XPath"
  if [[ -d "${xpath_src}" ]]; then
    local -a xpath_files=()
    mapfile -t xpath_files < <(find "${xpath_src}" -name '*.xml' | sort)
    local xfile expr
    for xfile in "${xpath_files[@]}"; do
      for expr in "${xpath_exprs[@]}"; do
        "${xmllint}" --nonet --xpath "${expr}" --noout \
          "${xfile}" >/dev/null 2>&1 || true
      done
    done
  fi

  for xml in "${xml_files[@]:0:100}"; do
    "${xmllint}" --nonet --xpath '/*'         --noout "${xml}" >/dev/null 2>&1 || true
    "${xmllint}" --nonet --xpath 'count(//*)'  --noout "${xml}" >/dev/null 2>&1 || true
  done

  # ── XInclude ─────────────────────────────────────────────────────────────────
  local xinclude_dir="${srcdir}/libxml2/test/XInclude"
  if [[ -d "${xinclude_dir}" ]]; then
    find "${xinclude_dir}" -name '*.xml' | while read -r xfile; do
      "${xmllint}" --nonet --xinclude --noout "${xfile}" >/dev/null 2>&1 || true
    done
  fi

  # ── Schema / RelaxNG validation ──────────────────────────────────────────────
  local schema_dir="${srcdir}/libxml2/test/schemas"
  local relaxng_dir="${srcdir}/libxml2/test/relaxng"

  if [[ -d "${schema_dir}" ]]; then
    find "${schema_dir}" -name '*.xsd' | while read -r xsd; do
      local instance="${xsd%.xsd}.xml"
      [[ -f "${instance}" ]] || \
        instance="${srcdir}/libxml2/test/valid/REC-xml-19980210.xml"
      "${xmllint}" --nonet --schema "${xsd}" --noout \
        "${instance}" >/dev/null 2>&1 || true
    done
  fi

  if [[ -d "${relaxng_dir}" ]]; then
    find "${relaxng_dir}" -name '*.rng' | while read -r rng; do
      local instance="${rng%.rng}.xml"
      [[ -f "${instance}" ]] || continue
      "${xmllint}" --nonet --relaxng "${rng}" --noout \
        "${instance}" >/dev/null 2>&1 || true
    done
  fi

  # ── XML catalog operations ───────────────────────────────────────────────────
  rm -rf "${workdir}"; mkdir -p "${workdir}"

  cat > "${workdir}/catalog.xml" << 'CATEOF'
<?xml version="1.0"?>
<!DOCTYPE catalog PUBLIC "-//OASIS//DTD Entity Resolution XML Catalog V1.0//EN"
  "http://www.oasis-open.org/committees/entity/release/1.0/catalog.dtd">
<catalog xmlns="urn:oasis:names:tc:entity:xmlns:xml:catalog">
  <system systemId="https://pgo.invalid/doc.dtd" uri="doc.dtd"/>
  <public publicId="-//PGO//DTD Test//EN" uri="doc.dtd"/>
  <rewriteURI uriStartString="https://pgo.invalid/" rewritePrefix="./"/>
</catalog>
CATEOF

  cat > "${workdir}/doc.dtd" << 'DTDEOF'
<!ELEMENT root (section+, footer?)>
<!ELEMENT section (#PCDATA|em|code|link)*>
<!ELEMENT footer (#PCDATA)>
<!ELEMENT em (#PCDATA)>
<!ELEMENT code (#PCDATA)>
<!ELEMENT link EMPTY>
<!ATTLIST root lang CDATA #IMPLIED id ID #IMPLIED>
<!ATTLIST link href CDATA #REQUIRED>
DTDEOF

  cat > "${workdir}/doc.xml" << 'XMLEOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE root SYSTEM "https://pgo.invalid/doc.dtd">
<root lang="en" id="r1">
  <section>Introduction with <em>emphasis</em> and <code>code</code>.</section>
  <section>Second section. <link href="https://example.org/"/></section>
  <footer>Copyright 2025</footer>
</root>
XMLEOF

  if [[ -x "${xmlcatalog}" ]]; then
    "${xmlcatalog}" --noout "${workdir}/catalog.xml" >/dev/null 2>&1 || true
    "${xmlcatalog}" "${workdir}/catalog.xml" "https://pgo.invalid/doc.dtd" \
      >/dev/null 2>&1 || true
    "${xmlcatalog}" "${workdir}/catalog.xml" "-//PGO//DTD Test//EN" \
      >/dev/null 2>&1 || true
    XML_CATALOG_FILES="${workdir}/catalog.xml" \
      "${xmllint}" --nonet --valid --noout "${workdir}/doc.xml" \
      >/dev/null 2>&1 || true
  fi

  # ── Encoding coverage ────────────────────────────────────────────────────────
  printf '\xff\xfe' > "${workdir}/utf16le.xml"
  printf '<r a="1"><c>text</c></r>' | iconv -f UTF-8 -t UTF-16LE \
    >> "${workdir}/utf16le.xml" 2>/dev/null || true
  "${xmllint}" --nonet --noout "${workdir}/utf16le.xml" >/dev/null 2>&1 || true
  "${xmllint}" --nonet --encode UTF-8 --noout \
    "${workdir}/utf16le.xml" >/dev/null 2>&1 || true

  printf '\xef\xbb\xbf<?xml version="1.0"?><r/>' > "${workdir}/bom_utf8.xml"
  "${xmllint}" --nonet --noout "${workdir}/bom_utf8.xml" >/dev/null 2>&1 || true

  cat > "${workdir}/latin1.xml" << 'LATEOF'
<?xml version="1.0" encoding="ISO-8859-1"?>
<root><elem>Caf</elem></root>
LATEOF
  "${xmllint}" --nonet --noout "${workdir}/latin1.xml" >/dev/null 2>&1 || true

  # ── Writer / serialization roundtrip ─────────────────────────────────────────
  for xml in "${xml_files[@]:0:150}"; do
    "${xmllint}" --nonet --format "${xml}" 2>/dev/null \
      | "${xmllint}" --nonet --noout - 2>/dev/null || true
  done

  # ── Pattern matching ─────────────────────────────────────────────────────────
  local -a patterns=("//section" "//item[@id]" "//*/text()" "/root/child")
  for xml in "${xml_files[@]:0:100}"; do
    for pat in "${patterns[@]}"; do
      "${xmllint}" --nonet --pattern "${pat}" --noout \
        "${xml}" >/dev/null 2>&1 || true
    done
  done

  # ── W3C conformance suite ────────────────────────────────────────────────────
  if [[ -f "${srcdir}/xmlconf/xmlconf.xml" ]]; then
    "${xmllint}" --nonet --noout \
      --xpath 'count(//TEST)' \
      "${srcdir}/xmlconf/xmlconf.xml" >/dev/null 2>&1 || true
    find "${srcdir}/xmlconf" -name '*.xml' -not -name 'xmlconf.xml' \
    | sort | while read -r f; do
      "${xmllint}" --nonet --noout    "${f}" >/dev/null 2>&1 || true
      "${xmllint}" --nonet --recover --noout "${f}" >/dev/null 2>&1 || true
    done
  fi

  # ── Large synthetic document ──────────────────────────────────────────────────
  python3 - << 'PYEOF' > "${workdir}/large.xml" 2>/dev/null || true
print('<?xml version="1.0" encoding="UTF-8"?>')
print('<catalog xmlns:meta="http://meta.example.org">')
for i in range(3000):
    cat = (i % 20) + 1
    print(f'  <item id="item{i}" category="cat{cat}" priority="{i%5}">')
    print(f'    <meta:name lang="en">Product {i}</meta:name>')
    print(f'    <description>Item {i}: &amp; &#65;&#x42;&#x43;</description>')
    print(f'    <price currency="USD">{i*99//100}.{i%100:02d}</price>')
    print( '    <tags>')
    print(f'      <tag>tag{i%10}</tag><tag>group{i%5}</tag>')
    print( '    </tags>')
    if i % 3 == 0:
        print(f'    <![CDATA[Raw {i} with <special> & chars]]>')
    print( '  </item>')
print('</catalog>')
PYEOF

  for mode in "" "--stream" "--push" "--format"; do
    "${xmllint}" --nonet ${mode:+${mode}} --noout \
      "${workdir}/large.xml" >/dev/null 2>&1 || true
  done
  "${xmllint}" --nonet --xpath 'count(//item)' --noout \
    "${workdir}/large.xml" >/dev/null 2>&1 || true
  "${xmllint}" --nonet --xpath '//item[@priority="0"]/@id' --noout \
    "${workdir}/large.xml" >/dev/null 2>&1 || true

  # ── Additional xmllint modes ──────────────────────────────────────────────────
  for xml in "${xml_files[@]:0:200}"; do
    "${xmllint}" --nonet --noblanks --noout "${xml}" >/dev/null 2>&1 || true
    "${xmllint}" --nonet --nsclean  --noout "${xml}" >/dev/null 2>&1 || true
    "${xmllint}" --nonet --dropdtd  --noout "${xml}" >/dev/null 2>&1 || true
    "${xmllint}" --nonet --dtdattr  --noout "${xml}" >/dev/null 2>&1 || true
    "${xmllint}" --nonet --nocdata  --noout "${xml}" >/dev/null 2>&1 || true
    "${xmllint}" --nonet --loaddtd  --noout "${xml}" >/dev/null 2>&1 || true
  done

  for xml in "${xml_files[@]:0:100}"; do
    "${xmllint}" --nonet --postvalid --noout "${xml}" >/dev/null 2>&1 || true
  done
}

# ──────────────────────────────────────────────────────────────────────────────
# _merge_profraw <profile_dir> <output_file>
# ──────────────────────────────────────────────────────────────────────────────
_merge_profraw() {
  local profile_dir="$1"
  local output_file="$2"
  local -a profraw_files=()
  shopt -s nullglob
  profraw_files=("${profile_dir}"/*.profraw)
  shopt -u nullglob
  if (( ${#profraw_files[@]} == 0 )); then
    echo "ERROR: No .profraw files found in ${profile_dir}" >&2
    return 1
  fi
  llvm-profdata merge \
    --output="${output_file}" \
    "${profraw_files[@]}"
}

# ──────────────────────────────────────────────────────────────────────────────
build() {
  export CC=clang
  export CXX=clang++

  # Save makepkg.conf flags — only PGO deltas are added per stage
  local _base_cflags="${CFLAGS}"
  local _base_cxxflags="${CXXFLAGS}"
  local _base_ldflags="${LDFLAGS}"

  local pgo_root="${srcdir}/pgo"
  local ir_dir="${pgo_root}/ir"
  local cs_dir="${pgo_root}/cs"
  local ir_data="${pgo_root}/ir.profdata"
  local cs_data="${pgo_root}/cs.profdata"
  local merged_data="${pgo_root}/merged.profdata"

  rm -rf "${pgo_root}" "${srcdir}/pgo-work" \
         "${srcdir}/${_builddir_pgo1}" \
         "${srcdir}/${_builddir_pgo2}" \
         "${srcdir}/${_builddir_opt}"
  mkdir -p "${ir_dir}" "${cs_dir}"

  # Suppress "function control flow hash mismatch" warnings
  local -a _warn_suppress=(
    "-Wno-profile-instr-out-of-date"
    "-Wno-profile-instr-unprofiled"
  )

  local -a _pgo1_cflags=(
    "-fprofile-generate=${ir_dir}"
    "${_pgo_instrument_cflags[@]}"
    "${_warn_suppress[@]}"
  )

  local -a _pgo2_cflags=(
    "-fprofile-use=${ir_data}"
    "-fcs-profile-generate=${cs_dir}"
    "${_pgo_instrument_cflags[@]}"
    "${_warn_suppress[@]}"
  )

  local -a _opt_cflags=(
    "-fprofile-use=${merged_data}"
    "${_warn_suppress[@]}"
  )

  # ═══════════════════════════════════════════════════════════════════════════
  # STAGE 1 — Standard PGO instrumentation
  # ═══════════════════════════════════════════════════════════════════════════
  echo ">>> [PGO Stage 1] Instrumented build"
  (
    export CFLAGS="${_base_cflags} ${_pgo1_cflags[*]}"
    export CXXFLAGS="${_base_cxxflags} ${_pgo1_cflags[*]}"
    export LDFLAGS="${_base_ldflags} -fprofile-generate=${ir_dir}"
    _configure_libxml2 "${_builddir_pgo1}"
  )
  meson compile -C "${srcdir}/${_builddir_pgo1}"

  echo ">>> [PGO Stage 1] Training workload"
  LLVM_PROFILE_FILE="${ir_dir}/default_%m.profraw" \
    _run_pgo_workload "${_builddir_pgo1}"
  _merge_profraw "${ir_dir}" "${ir_data}"

  # ═══════════════════════════════════════════════════════════════════════════
  # STAGE 2 — Context-Sensitive PGO instrumentation
  # ═══════════════════════════════════════════════════════════════════════════
  echo ">>> [PGO Stage 2] CS-instrumented build"
  (
    export CFLAGS="${_base_cflags} ${_pgo2_cflags[*]}"
    export CXXFLAGS="${_base_cxxflags} ${_pgo2_cflags[*]}"
    export LDFLAGS="${_base_ldflags} -fprofile-use=${ir_data} -fcs-profile-generate=${cs_dir}"
    _configure_libxml2 "${_builddir_pgo2}"
  )
  meson compile -C "${srcdir}/${_builddir_pgo2}"

  echo ">>> [PGO Stage 2] CS training workload"
  LLVM_PROFILE_FILE="${cs_dir}/default_%m.profraw" \
    _run_pgo_workload "${_builddir_pgo2}"
  _merge_profraw "${cs_dir}" "${cs_data}"

  # CS first (richer context), then IR as fallback coverage
  llvm-profdata merge \
    --output="${merged_data}" \
    "${cs_data}" \
    "${ir_data}"

  # ═══════════════════════════════════════════════════════════════════════════
  # STAGE 3 — Final PGO-optimised build
  # ═══════════════════════════════════════════════════════════════════════════
  echo ">>> [PGO Stage 3] Final optimised build"
  (
    export CFLAGS="${_base_cflags} ${_opt_cflags[*]}"
    export CXXFLAGS="${_base_cxxflags} ${_opt_cflags[*]}"
    export LDFLAGS="${_base_ldflags} -fprofile-use=${merged_data}"
    _configure_libxml2 "${_builddir_opt}"
  )
  meson compile -C "${srcdir}/${_builddir_opt}"
}

# ──────────────────────────────────────────────────────────────────────────────
check() {
  meson test -C "${srcdir}/${_builddir_opt}" --print-errorlogs --no-rebuild
}

# ──────────────────────────────────────────────────────────────────────────────
package() {
  depends+=(libicuuc.so)
  provides+=(libxml2.so)

  meson install -C "${srcdir}/${_builddir_opt}" --destdir "${pkgdir}"
  install -Dm644 libxml2/libxml.m4 -t "${pkgdir}/usr/share/aclocal"

  # Remove docs (disabled at configure time, but clean up residual files)
  rm -rf "${pkgdir}/usr/share/doc"

  install -Dm644 libxml2/Copyright -t "${pkgdir}/usr/share/licenses/${pkgname}"
}

