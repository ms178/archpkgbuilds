pkgname=libxml2
pkgver=2.15.3
pkgrel=4.1
pkgdesc="XML C parser and toolkit"
url="https://gitlab.gnome.org/GNOME/libxml2/-/wikis/home"
arch=(x86_64)
license=(MIT)
depends=(
  bash
  glibc
  icu
  readline
  zlib
)
makedepends=(
  git
  llvm
  meson
  python
)
source=(
  "git+https://gitlab.gnome.org/GNOME/libxml2.git#tag=v$pkgver"
  https://www.w3.org/XML/Test/xmlts20130923.tar.gz
)
b2sums=('bcf3ac7f06fb875d20f62b6f1ecb4c406d28d86e8124e9781a8d6fae8b3815062a6fa152fc4c570fb5c2d162b1eee4b9cf3ac5c17f434d71b72807fce0d57e41'
        '63a47bc69278ef510cd0b3779aed729e1b309e30efa0015d28ed051cc03f9dfddb447ab57b07b3393e8f47393d15473b0e199c34cb1f5f746b15ddfaa55670be')

_optimized_builddir="build-opt"

prepare() {
  cd libxml2

  # Use xmlconf from conformance test suite.
  ln -sfn ../xmlconf xmlconf
}

_configure_libxml2() {
  local builddir="$1"
  local meson_options=(
    -D icu=enabled
    -D legacy=enabled
    -D docs=disabled
  )

  arch-meson libxml2 "$builddir" "${meson_options[@]}"
}

_build_with_flags() {
  local builddir="$1"
  local cflags_extra="$2"
  local cxxflags_extra="$3"
  local ldflags_extra="$4"

  (
    export CFLAGS+=" $cflags_extra"
    export CXXFLAGS+=" $cxxflags_extra"
    export LDFLAGS+=" $ldflags_extra"

    _configure_libxml2 "$builddir"
    meson compile -C "$builddir"
  )
}

_merge_llvm_profraw() {
  local profdata_tool="$1"
  local profile_dir="$2"
  local output_file="$3"
  local -a profile_files=()

  shopt -s nullglob
  profile_files=("$profile_dir"/*.profraw)
  shopt -u nullglob

  if (( ${#profile_files[@]} == 0 )); then
    printf '%s\n' "error: no .profraw files found in $profile_dir" >&2
    return 1
  fi

  "$profdata_tool" merge -output="$output_file" "${profile_files[@]}"
}

_run_pgo_workload() {
  local builddir="$1"
  local xmllint="$builddir/xmllint"
  local xmlcatalog="$builddir/xmlcatalog"
  local workdir="$srcdir/pgo-work"
  local -a xml_files=()

  # Exercise official tests first for broad real-world path coverage.
  meson test -C "$builddir" --print-errorlogs --no-rebuild

  if [[ -x "$xmllint" ]]; then
    mapfile -t xml_files < <(
      find \
        "$srcdir/libxml2/test" \
        "$srcdir/xmlconf" \
        -type f \
        \( -name '*.xml' -o -name '*.xhtml' -o -name '*.svg' -o -name '*.rdf' -o -name '*.html' \) \
        | sort
    )

    local xml
    for xml in "${xml_files[@]}"; do
      "$xmllint" --nonet --noout "$xml" >/dev/null 2>&1 || true
    done

    for xml in "${xml_files[@]:0:700}"; do
      "$xmllint" --nonet --recover --noout "$xml" >/dev/null 2>&1 || true
    done

    for xml in "${xml_files[@]:0:500}"; do
      "$xmllint" --nonet --stream --noout "$xml" >/dev/null 2>&1 || true
    done

    if [[ -f "$srcdir/xmlconf/xmlconf.xml" ]]; then
      "$xmllint" --nonet --xpath 'count(//TEST)' "$srcdir/xmlconf/xmlconf.xml" >/dev/null 2>&1 || true
    fi
  fi

  if [[ -x "$xmlcatalog" && -x "$xmllint" ]]; then
    rm -rf "$workdir"
    mkdir -p "$workdir"

    cat >"$workdir/catalog.xml" <<'EOF'
<?xml version="1.0"?>
<catalog xmlns="urn:oasis:names:tc:entity:xmlns:xml:catalog">
  <system systemId="https://example.invalid/pgo.dtd" uri="pgo.dtd"/>
</catalog>
EOF

    cat >"$workdir/pgo.dtd" <<'EOF'
<!ELEMENT root (#PCDATA)>
EOF

    cat >"$workdir/pgo.xml" <<'EOF'
<?xml version="1.0"?>
<!DOCTYPE root SYSTEM "https://example.invalid/pgo.dtd">
<root>profile-guided</root>
EOF

    "$xmlcatalog" --noout "$workdir/catalog.xml"
    "$xmlcatalog" "$workdir/catalog.xml" "https://example.invalid/pgo.dtd" >/dev/null
    XML_CATALOG_FILES="$workdir/catalog.xml" \
      "$xmllint" --nonet --valid --noout "$workdir/pgo.xml" >/dev/null
  fi
}

build() {
  local compiler_version
  compiler_version="$(${CC:-cc} --version 2>/dev/null | head -n 1)"

  local pgo_root="$srcdir/pgo"
  local ir_profile_dir="$pgo_root/ir"
  local cs_profile_dir="$pgo_root/cs"
  local ir_profile_data="$pgo_root/ir.profdata"
  local cs_profile_data="$pgo_root/cs.profdata"
  local merged_profile_data="$pgo_root/merged.profdata"
  local profdata_tool
  local clang_vp_flags="-mllvm -vp-counters-per-site=8"

  rm -rf "$pgo_root" "$srcdir/pgo-work" build-pgo-gen build-pgo-cs "$_optimized_builddir"
  mkdir -p "$ir_profile_dir" "$cs_profile_dir"

  if [[ "$compiler_version" == *clang* ]]; then
    if ! profdata_tool="$(command -v llvm-profdata)"; then
      printf '%s\n' "error: clang CS-PGO requires llvm-profdata from llvm" >&2
      return 1
    fi

    _build_with_flags \
      build-pgo-gen \
      "-fprofile-generate=$ir_profile_dir $clang_vp_flags" \
      "-fprofile-generate=$ir_profile_dir $clang_vp_flags" \
      "-fprofile-generate=$ir_profile_dir"

    LLVM_PROFILE_FILE="$ir_profile_dir/default_%m.profraw" \
      _run_pgo_workload build-pgo-gen

    _merge_llvm_profraw "$profdata_tool" "$ir_profile_dir" "$ir_profile_data"

    _build_with_flags \
      build-pgo-cs \
      "-fprofile-use=$ir_profile_data -fcs-profile-generate=$cs_profile_dir $clang_vp_flags -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
      "-fprofile-use=$ir_profile_data -fcs-profile-generate=$cs_profile_dir $clang_vp_flags -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
      "-fprofile-use=$ir_profile_data -fcs-profile-generate=$cs_profile_dir"

    LLVM_PROFILE_FILE="$cs_profile_dir/default_%m.profraw" \
      _run_pgo_workload build-pgo-cs

    _merge_llvm_profraw "$profdata_tool" "$cs_profile_dir" "$cs_profile_data"
    "$profdata_tool" merge -output="$merged_profile_data" \
      "$cs_profile_data" \
      "$ir_profile_data"

    _build_with_flags \
      "$_optimized_builddir" \
      "-fprofile-use=$merged_profile_data -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
      "-fprofile-use=$merged_profile_data -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
      "-fprofile-use=$merged_profile_data"
  else
    _build_with_flags \
      build-pgo-gen \
      "-fprofile-generate=$ir_profile_dir -fprofile-update=atomic" \
      "-fprofile-generate=$ir_profile_dir -fprofile-update=atomic" \
      "-fprofile-generate=$ir_profile_dir"

    _run_pgo_workload build-pgo-gen

    _build_with_flags \
      "$_optimized_builddir" \
      "-fprofile-use=$ir_profile_dir -fprofile-correction" \
      "-fprofile-use=$ir_profile_dir -fprofile-correction" \
      "-fprofile-use=$ir_profile_dir"
  fi
}

check() {
  meson test -C "$_optimized_builddir" --print-errorlogs --no-rebuild
}

package() {
  depends+=(libicuuc.so)
  optdepends=('python: Python bindings')
  provides=(libxml2.so)

  meson install -C "$_optimized_builddir" --destdir "$pkgdir"
  install -Dm644 libxml2/libxml.m4 -t "$pkgdir/usr/share/aclocal"
  install -Dm644 libxml2/Copyright -t "$pkgdir/usr/share/licenses/$pkgname"
}

