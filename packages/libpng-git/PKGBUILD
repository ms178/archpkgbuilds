pkgname=libpng
pkgver=1.6.56
pkgrel=3.1
pkgdesc="A collection of routines used to create PNG format graphics files"
arch=(x86_64)
url="https://libpng.org/pub/png/libpng.html"
license=(libpng-2.0)
depends=(
  glibc
  zlib
)
makedepends=(
  autoconf
  automake
  clang
  compiler-rt
  git
  libtool
  llvm
)
provides=(libpng16.so)
source=(
  "${pkgname}::git+https://github.com/pnggroup/libpng.git?signed#tag=v${pkgver}"
)
b2sums=('SKIP')
validpgpkeys=(
  'F57A55036A4D45837074FD92C9E384533403C2F8'
  '1FED507E3236B4A6E53E922BB292C64843FF5BCF'
)

_configure_args=(
  --prefix=/usr
  --libdir=/usr/lib
  --disable-static
  --enable-shared
  --disable-dependency-tracking
  --enable-hardware-optimizations=yes
)

_pkg_compile_flags=(
  -fno-semantic-interposition
)

_pgo_compile_tuning_flags=(
  -g3
  -fno-omit-frame-pointer
  -Xclang -mllvm -Xclang -vp-counters-per-site=150
  -Xclang -mllvm -Xclang -runtime-counter-relocation
  -Xclang -mllvm -Xclang -enable-value-profiling
)

prepare() {
  cd "${pkgname}"
  autoreconf -fiv
}

_configure_build() {
  local builddir=$1
  local -n compile_flags_ref=$2
  local -n linker_flags_ref=$3

  rm -rf "${builddir}"
  mkdir -p "${builddir}"

  (
    cd "${builddir}"

    env \
      CC=clang \
      CXX=clang++ \
      AR=llvm-ar \
      NM=llvm-nm \
      RANLIB=llvm-ranlib \
      CPPFLAGS="${CPPFLAGS}" \
      CFLAGS="${CFLAGS} ${compile_flags_ref[*]}" \
      CXXFLAGS="${CXXFLAGS} ${compile_flags_ref[*]}" \
      LDFLAGS="${LDFLAGS} ${linker_flags_ref[*]}" \
      "${srcdir}/${pkgname}/configure" \
      "${_configure_args[@]}"
  )
}

_run_profiled_check() {
  local builddir=$1
  local profdir=$2

  rm -rf "${profdir}"
  mkdir -p "${profdir}"

  (
    cd "${builddir}"
    export LLVM_PROFILE_FILE="${profdir}/%m-%p.profraw"
    # Run test suite. If it fails, print a warning but DO NOT abort PGO generation.
    # Profile data is written to disk as tests execute, so it remains valid.
    if ! make check; then
      printf 'WARNING: make check reported failures, but continuing PGO profile generation...\n' >&2
    fi
  )
}

_merge_profdata() {
  local profdir=$1
  local outfile=$2
  local -a profraw_files

  mapfile -d '' -t profraw_files < <(find "${profdir}" -type f -name '*.profraw' -print0)

  if (( ${#profraw_files[@]} == 0 )); then
    printf 'ERROR: no raw profile data was generated in %s\n' "${profdir}" >&2
    return 1
  fi

  llvm-profdata merge -output="${outfile}" "${profraw_files[@]}"
}

_compile_pngminus_tool() {
  local outfile=$1
  local srcfile=$2
  local final_builddir=$3
  local sourcedir=$4
  local -n compile_flags_ref=$5
  local -n linker_flags_ref=$6

  clang \
    ${CPPFLAGS} \
    ${CFLAGS} \
    "${compile_flags_ref[@]}" \
    -I"${final_builddir}" \
    -I"${sourcedir}" \
    ${LDFLAGS} \
    "${linker_flags_ref[@]}" \
    -L"${final_builddir}/.libs" \
    -Wl,-rpath-link,"${final_builddir}/.libs" \
    "${srcfile}" \
    -lpng16 -lz -lm \
    -o "${outfile}"
}

build() {
  local sourcedir="${srcdir}/${pkgname}"
  local pgo_builddir="${srcdir}/build-pgo"
  local cs_pgo_builddir="${srcdir}/build-cs-pgo"
  local final_builddir="${srcdir}/build-final"
  local tools_builddir="${srcdir}/build-tools"

  local pgo_profdir="${srcdir}/pgo-data"
  local cs_pgo_profdir="${srcdir}/cs-pgo-data"
  local pgo_profdata="${srcdir}/libpng-pgo.profdata"
  local cs_pgo_tmp_profdata="${srcdir}/libpng-cs-pgo.tmp.profdata"
  local cs_pgo_profdata="${srcdir}/libpng-cs-pgo.profdata"

  local -a pgo_compile_flags=(
    "${_pkg_compile_flags[@]}"
    "${_pgo_compile_tuning_flags[@]}"
    "-fprofile-generate=${pgo_profdir}"
  )
  local -a pgo_link_flags=(
    "-fprofile-generate=${pgo_profdir}"
  )

  local -a cs_pgo_compile_flags=(
    "${_pkg_compile_flags[@]}"
    "${_pgo_compile_tuning_flags[@]}"
    "-fprofile-use=${pgo_profdata}"
    "-fcs-profile-generate=${cs_pgo_profdir}"
  )
  local -a cs_pgo_link_flags=(
    "-fprofile-use=${pgo_profdata}"
    "-fcs-profile-generate=${cs_pgo_profdir}"
  )

  local -a final_compile_flags=(
    "${_pkg_compile_flags[@]}"
    "-fprofile-use=${cs_pgo_profdata}"
  )
  local -a final_link_flags=(
    "-fprofile-use=${cs_pgo_profdata}"
  )

  rm -rf \
    "${pgo_builddir}" \
    "${cs_pgo_builddir}" \
    "${final_builddir}" \
    "${tools_builddir}" \
    "${pgo_profdir}" \
    "${cs_pgo_profdir}" \
    "${pgo_profdata}" \
    "${cs_pgo_tmp_profdata}" \
    "${cs_pgo_profdata}"

  echo '==> Building Clang PGO-instrumented libpng...'
  _configure_build "${pgo_builddir}" pgo_compile_flags pgo_link_flags
  make -C "${pgo_builddir}"

  _run_profiled_check "${pgo_builddir}" "${pgo_profdir}"

  echo '==> Merging initial profile data...'
  _merge_profdata "${pgo_profdir}" "${pgo_profdata}"

  echo '==> Building Clang CS-PGO-instrumented libpng...'
  _configure_build "${cs_pgo_builddir}" cs_pgo_compile_flags cs_pgo_link_flags
  make -C "${cs_pgo_builddir}"

  _run_profiled_check "${cs_pgo_builddir}" "${cs_pgo_profdir}"

  echo '==> Merging context-sensitive profile data...'
  _merge_profdata "${cs_pgo_profdir}" "${cs_pgo_tmp_profdata}"
  llvm-profdata merge \
    -output="${cs_pgo_profdata}" \
    "${pgo_profdata}" \
    "${cs_pgo_tmp_profdata}"

  echo '==> Building final Clang PGO/CS-PGO optimized libpng...'
  _configure_build "${final_builddir}" final_compile_flags final_link_flags
  make -C "${final_builddir}"

  echo '==> Building pngminus utilities against the final optimized shared library...'
  mkdir -p "${tools_builddir}"

  _compile_pngminus_tool \
    "${tools_builddir}/png2pnm" \
    "${sourcedir}/contrib/pngminus/png2pnm.c" \
    "${final_builddir}" \
    "${sourcedir}" \
    final_compile_flags \
    final_link_flags

  _compile_pngminus_tool \
    "${tools_builddir}/pnm2png" \
    "${sourcedir}/contrib/pngminus/pnm2png.c" \
    "${final_builddir}" \
    "${sourcedir}" \
    final_compile_flags \
    final_link_flags
}

#check() {
  # Final validation uses relaxed mode to avoid zlib-ng byte-exact false positives.
#  export PNGTEST_FLAGS="--relaxed"
#  make -C "${srcdir}/build-final" check
#}

package() {
  make -C "${srcdir}/build-final" DESTDIR="${pkgdir}" install

  install -vDm 644 \
    "${srcdir}/${pkgname}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  install -vDm 755 \
    "${srcdir}/build-tools/png2pnm" \
    "${pkgdir}/usr/bin/png2pnm"

  install -vDm 755 \
    "${srcdir}/build-tools/pnm2png" \
    "${pkgdir}/usr/bin/pnm2png"
}
