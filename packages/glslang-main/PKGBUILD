# Maintainer: Super-Genius CachyOS Maintainer
pkgname=glslang
pkgver=1.4.341.0
pkgrel=11
pkgdesc="OpenGL and OpenGL ES shader front end and validator"
arch=('x86_64')
url='https://github.com/KhronosGroup/glslang'
license=('BSD-3-Clause' 'GPL-3.0-or-later' 'MIT')
depends=('glibc' 'libstdc++' 'spirv-tools')
makedepends=('cmake' 'ninja' 'spirv-headers' 'python' 'llvm' 'clang' 'lld')
options=('staticlibs')
source=("git+${url}.git#tag=vulkan-sdk-${pkgver}")
sha256sums=('SKIP')

_generate_shaders() {
  local out="$1"
  rm -rf "$out"
  mkdir -p "$out"

  # Base PBR Vert
  cat > "$out/pbr.vert" << 'EOF'
#version 460 core
#extension GL_EXT_multiview : enable
layout(location = 0) in vec3 inPos;
layout(location = 1) in vec3 inNormal;
layout(location = 2) in vec2 inUV;
layout(location = 0) out vec3 fragNormal;
layout(location = 1) out vec2 fragUV;
layout(push_constant) uniform PC { mat4 m, v, p; } pc;
void main() {
    fragNormal = mat3(pc.m) * inNormal;
    fragUV = inUV;
    gl_Position = pc.p * pc.v * pc.m * vec4(inPos, 1.0);
}
EOF

  # Base PBR Frag
  cat > "$out/pbr.frag" << 'EOF'
#version 460 core
#extension GL_EXT_nonuniform_qualifier : enable
layout(location = 0) in vec3 fragNormal;
layout(location = 1) in vec2 fragUV;
layout(location = 0) out vec4 outColor;
layout(set = 0, binding = 0) uniform sampler2D samplers[];
void main() {
    vec3 n = normalize(fragNormal);
    vec3 l = normalize(vec3(1.0));
    float ndotl = max(dot(n, l), 0.0);
    vec4 albedo = texture(samplers[nonuniformEXT(0)], fragUV);
    outColor = vec4(albedo.rgb * ndotl, 1.0);
}
EOF

  # Compute (Particles, Subgroups, Shared Mem, Atomics)
  cat > "$out/particle.comp" << 'EOF'
#version 460 core
#extension GL_KHR_shader_subgroup_arithmetic : enable
#extension GL_EXT_buffer_reference : enable
#extension GL_EXT_scalar_block_layout : enable
layout(local_size_x = 256) in;
layout(buffer_reference, scalar) buffer Node { int id; float val; };
layout(set = 0, binding = 0, scalar) buffer Data { Node nodes[]; };
shared float shared_sum;
void main() {
    uint idx = gl_GlobalInvocationID.x;
    Node n = nodes[idx];
    float sg_sum = subgroupAdd(n.val);
    if (subgroupElect()) {
        atomicAdd(shared_sum, sg_sum);
    }
    barrier();
    if (gl_LocalInvocationID.x == 0) n.val = shared_sum;
}
EOF

  # Mesh Shader
  cat > "$out/draw.mesh" << 'EOF'
#version 460 core
#extension GL_EXT_mesh_shader : require
layout(local_size_x = 32) in;
layout(triangles, max_vertices = 64, max_primitives = 126) out;
layout(location = 0) out vec4 v_color[];
void main() {
    uint i = gl_LocalInvocationID.x;
    SetMeshOutputsEXT(64, 126);
    gl_MeshVerticesEXT[i].gl_Position = vec4(float(i), float(i), 0.0, 1.0);
    v_color[i] = vec4(1.0);
    if (i < 126) {
        gl_PrimitiveTriangleIndicesEXT[i] = uvec3(0, 1, 2);
    }
}
EOF

  # Raygen & RayQuery
  cat > "$out/trace.rgen" << 'EOF'
#version 460 core
#extension GL_EXT_ray_tracing : require
#extension GL_EXT_ray_query : require
layout(location = 0) rayPayloadEXT vec3 payload;
layout(set = 0, binding = 0) uniform accelerationStructureEXT tlas;
layout(set = 0, binding = 1, rgba8) uniform image2D imgOut;
void main() {
    vec2 uv = vec2(gl_LaunchIDEXT.xy) / vec2(gl_LaunchSizeEXT.xy);
    vec3 origin = vec3(uv * 2.0 - 1.0, -1.0);
    vec3 dir = vec3(0.0, 0.0, 1.0);
    traceRayEXT(tlas, gl_RayFlagsOpaqueEXT, 0xff, 0, 0, 0, origin, 0.001, dir, 10000.0, 0);
    rayQueryEXT rq;
    rayQueryInitializeEXT(rq, tlas, gl_RayFlagsOpaqueEXT, 0xFF, origin, 0.1, dir, 100.0);
    while(rayQueryProceedEXT(rq)) {
        if (rayQueryGetIntersectionTypeEXT(rq, false) == gl_RayQueryCandidateIntersectionTriangleEXT) {
            rayQueryConfirmIntersectionEXT(rq);
        }
    }
    imageStore(imgOut, ivec2(gl_LaunchIDEXT.xy), vec4(payload, 1.0));
}
EOF

  # Tessellation Control
  cat > "$out/tess.tesc" << 'EOF'
#version 460 core
layout(vertices = 3) out;
layout(location = 0) in vec3 inPos[];
layout(location = 0) out vec3 outPos[];
void main() {
    outPos[gl_InvocationID] = inPos[gl_InvocationID];
    if (gl_InvocationID == 0) {
        gl_TessLevelInner[0] = gl_TessLevelOuter[0] = gl_TessLevelOuter[1] = gl_TessLevelOuter[2] = 3.0;
    }
}
EOF

  # Tessellation Eval
  cat > "$out/tess.tese" << 'EOF'
#version 460 core
layout(triangles, equal_spacing, cw) in;
layout(location = 0) in vec3 inPos[];
void main() {
    vec3 p0 = gl_TessCoord.x * inPos[0];
    vec3 p1 = gl_TessCoord.y * inPos[1];
    vec3 p2 = gl_TessCoord.z * inPos[2];
    gl_Position = vec4(p0 + p1 + p2, 1.0);
}
EOF

  # Geometry
  cat > "$out/geom.geom" << 'EOF'
#version 460 core
layout(triangles) in;
layout(triangle_strip, max_vertices = 3) out;
void main() {
    for (int i = 0; i < 3; i++) {
        gl_Position = gl_in[i].gl_Position;
        EmitVertex();
    }
    EndPrimitive();
}
EOF

  # Ray AnyHit
  cat > "$out/hit.rahit" << 'EOF'
#version 460 core
#extension GL_EXT_ray_tracing : require
layout(location = 0) rayPayloadInEXT vec3 payload;
hitAttributeEXT vec2 attribs;
void main() { if (attribs.x < 0.1) ignoreIntersectionEXT; }
EOF

  # Malformed shaders for AST/Parser error-recovery coverage
  cat > "$out/err1.vert" << 'EOF'
#version 460 core
layout(location = 0) in vec3 p
void main() { gl_Position = vec4(p, 1.0); }
EOF

  cat > "$out/err2.frag" << 'EOF'
#version 460 core
layout(location = 0) out vec4 c;
void main() { c = vec4(1.0) * undefined_var; }
EOF

  cat > "$out/err3.comp" << 'EOF'
#version 460 core
layout(local_size_x = 16) in;
void main() { float x = 1.0 / 0.0; x += "string"; }
EOF

  # Procedural Variants for deep coverage
  local i
  for ((i = 0; i < 150; i++)); do
    cat > "$out/var_${i}.frag" << EOF
#version 460 core
layout(location = 0) out vec4 c;
void main() {
    float x = sin(float($i));
    c = vec4(x, 1.0-x, x*0.5, 1.0);
}
EOF
    cat > "$out/var_${i}.comp" << EOF
#version 460 core
layout(local_size_x = $((16 + i % 64))) in;
layout(std430, binding = 0) buffer B { float v[]; };
void main() { v[gl_GlobalInvocationID.x] += ${i}.0; }
EOF
    cat > "$out/var_${i}.vert" << EOF
#version 460 core
layout(location = 0) in vec3 inPos;
layout(location = 1) in vec2 inUV;
layout(location = 0) out vec2 fragUV;
layout(push_constant) uniform PC { mat4 mvp; } pc;
void main() {
    fragUV = inUV * float($i);
    gl_Position = pc.mvp * vec4(inPos + vec3(float($i)), 1.0);
}
EOF
  done
}

_run_workload() {
  local bdir="$1"
  local glslv="$bdir/StandAlone/glslang"

  # Enforce binary check to prevent silently skipped training
  if [[ ! -x "$glslv" ]]; then
    error "Compiled executable not found at %s" "$glslv"
    return 1
  fi

  local wdir="${srcdir}/workload_tmp"
  _generate_shaders "$wdir"

  local runner="$wdir/runner.sh"
  cat > "$runner" << 'EOF'
#!/bin/bash
glslv="$1"
f="$2"

targets=(vulkan1.1 vulkan1.2 vulkan1.3 vulkan1.4 opengl)

for target in "${targets[@]}"; do
    if [[ "$target" != opengl ]]; then
       "$glslv" -q -V --target-env "$target" -o /dev/null "$f" >/dev/null 2>&1 || true
       "$glslv" -q -V -Od --target-env "$target" -o /dev/null "$f" >/dev/null 2>&1 || true
       "$glslv" -q -V -Os --target-env "$target" -o /dev/null "$f" >/dev/null 2>&1 || true
    else
       "$glslv" -q -G --target-env "$target" -o /dev/null "$f" >/dev/null 2>&1 || true
       "$glslv" -q -G -Od --target-env "$target" -o /dev/null "$f" >/dev/null 2>&1 || true
       "$glslv" -q -G -Os --target-env "$target" -o /dev/null "$f" >/dev/null 2>&1 || true
    fi
done

"$glslv" -q -E -o /dev/null "$f" >/dev/null 2>&1 || true
EOF
  chmod +x "$runner"

  # Parallel shader execution mapping
  find "$wdir" -maxdepth 1 -type f -not -name "runner.sh" -print0 | \
    xargs -0 -n 1 -P "$(nproc)" "$runner" "$glslv"

  # Upstream Test Suite Coverage (Runs `Test/runtests` bash suite internally)
  if [[ -f "$bdir/CTestTestfile.cmake" ]]; then
    ctest --test-dir "$bdir" -j"$(nproc)" --output-on-failure >/dev/null 2>&1 || true
  fi

  rm -rf "$wdir"
}

build() {
  # Enforce pure LLVM Toolchain Pipeline
  export CC=clang
  export CXX=clang++
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib
  export STRIP=llvm-strip
  export OBJCOPY=llvm-objcopy
  export LDFLAGS="-fuse-ld=lld $LDFLAGS"

  local _profraw_s1="$srcdir/profraw-s1"
  local _profraw_s2="$srcdir/profraw-s2"
  local _prof_s1="$srcdir/s1.profdata"
  local _prof_final="$srcdir/final.profdata"

  mkdir -p "$_profraw_s1" "$_profraw_s2"

  local _cm_common=(
    -DCMAKE_INSTALL_PREFIX=/usr
    -DCMAKE_BUILD_TYPE=Release
    -DBUILD_SHARED_LIBS=ON
    -DALLOW_EXTERNAL_SPIRV_TOOLS=ON
    -DGLSLANG_TESTS=ON
    -DENABLE_GLSLANG_BINARIES=ON
  )

  # Phase Flags Setup
  local _pgo_gen="-fprofile-generate=${_profraw_s1}"
  local _cs_gen="-fprofile-use=${_prof_s1} -fcs-profile-generate=${_profraw_s2}"
  local _pgo_use="-fprofile-use=${_prof_final}"

  local _lto_flags="-flto"
  local _vp_flags="-mllvm -vp-counters-per-site=8 -mllvm -runtime-counter-relocation"

  # === Stage 1: Profile Generate ===
  # _vp_flags strictly in C/CXX flags. Linker only receives the path hook.
  cmake -S glslang -B build-s1 -G Ninja \
    "${_cm_common[@]}" \
    -DCMAKE_C_FLAGS="${CFLAGS} ${_pgo_gen} ${_vp_flags} ${_lto_flags}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} ${_pgo_gen} ${_vp_flags} ${_lto_flags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} ${_pgo_gen} ${_lto_flags}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS} ${_pgo_gen} ${_lto_flags}" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS} ${_pgo_gen} ${_lto_flags}"

  ninja -C build-s1
  _run_workload "${srcdir}/build-s1"

  shopt -s nullglob
  local s1_profs=("${_profraw_s1}"/*.profraw)
  shopt -u nullglob

  if (( ${#s1_profs[@]} == 0 )); then
    error "No stage-1 profile data generated!"
    return 1
  fi
  llvm-profdata merge -o "$_prof_s1" "${s1_profs[@]}"

  # === Stage 2: Context-Sensitive Profile Generate ===
  # CS-PGO enforces LTO mathematically.
  cmake -S glslang -B build-s2 -G Ninja \
    "${_cm_common[@]}" \
    -DCMAKE_C_FLAGS="${CFLAGS} ${_cs_gen} ${_vp_flags} ${_lto_flags}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} ${_cs_gen} ${_vp_flags} ${_lto_flags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} ${_cs_gen} ${_lto_flags}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS} ${_cs_gen} ${_lto_flags}" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS} ${_cs_gen} ${_lto_flags}"

  ninja -C build-s2
  _run_workload "${srcdir}/build-s2"

  shopt -s nullglob
  local s2_profs=("${_profraw_s2}"/*.profraw)
  shopt -u nullglob

  if (( ${#s2_profs[@]} == 0 )); then
    error "No stage-2 context-sensitive profile data generated!"
    return 1
  fi
  llvm-profdata merge -o "$_prof_final" "${s2_profs[@]}" "$_prof_s1"

  # === Stage 3: Final PGO-Optimized Build ===
  cmake -S glslang -B build -G Ninja \
    "${_cm_common[@]}" \
    -DCMAKE_C_FLAGS="${CFLAGS} ${_pgo_use} ${_lto_flags}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} ${_pgo_use} ${_lto_flags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} ${_pgo_use} ${_lto_flags}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS} ${_pgo_use} ${_lto_flags}" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS} ${_pgo_use} ${_lto_flags}"

  ninja -C build
}

check() {
  ctest --test-dir build --output-on-failure -j"$(nproc)"
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 glslang/LICENSE.txt \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  # Backward compatibility symlink explicitly requested by Khronos migration paths
  ln -sf glslang "$pkgdir/usr/bin/glslangValidator"
}
