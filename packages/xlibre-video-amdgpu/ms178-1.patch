+        count = (uint32_t)(sizeof(gfx10_mods_arr) /
+                           sizeof(gfx10_mods_arr[0]));
+    } else if (info->family >= AMDGPU_FAMILY_AI) {
+        mods  = gfx9_mods_arr;
+        count = (uint32_t)(sizeof(gfx9_mods_arr) /
+                           sizeof(gfx9_mods_arr[0]));
