+        };
+
+        ret = drmIoctl(pAMDGPUEnt->fd,
+                       DRM_IOCTL_SYNCOBJ_TRANSFER,
+                       &transfer);
+        if (UNLIKELY(ret != 0)) {
+            struct drm_syncobj_destroy destroy_args = {
+                .handle = temp_handle
+            };
+            (void)drmIoctl(pAMDGPUEnt->fd,
+                           DRM_IOCTL_SYNCOBJ_DESTROY,
+                           &destroy_args);
+            return -1;
+        }
+
+        handle_args.handle = temp_handle;
+    } else {
+        handle_args.handle = amdgpu_syncobj->syncobj_handle;
+    }
+
+    handle_args.flags = DRM_SYNCOBJ_HANDLE_TO_FD_FLAGS_EXPORT_SYNC_FILE;
+    handle_args.fd    = -1;
+
+    ret = drmIoctl(pAMDGPUEnt->fd,
+                   DRM_IOCTL_SYNCOBJ_HANDLE_TO_FD,
+                   &handle_args);
+
+    /* Always clean up the temporary handle */
+    if (temp_handle != 0) {
+        struct drm_syncobj_destroy destroy_args = {
+            .handle = temp_handle
+        };
+        (void)drmIoctl(pAMDGPUEnt->fd,
+                       DRM_IOCTL_SYNCOBJ_DESTROY,
+                       &destroy_args);
+    }
+
+    return (ret == 0) ? handle_args.fd : -1;
+}
