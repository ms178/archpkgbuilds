+/*
+ * amdgpu_dri3_fd_from_pixmap — export pixmap as single DMA-buf FD
+ *
+ * DRI3 v1.0 entry point. Legacy single-FD export path for GLX
+ * and non-Present use cases.
+ *
+ * NOTE: This function intentionally keeps amdgpu_glamor_flush().
+ * Unlike amdgpu_dri3_fds_from_pixmap (DRI3 path), this function
+ * is used by GLX which has different synchronization semantics.
+ * GLX expects an explicit flush before FD export to ensure
+ * the OpenGL context's rendering is complete.
+ *
+ * @param screen: X11 screen
+ * @param pixmap: X11 pixmap to export
+ * @param stride: output buffer stride
+ * @param size: output buffer size
+ *
+ * @returns: DMA-buf FD on success, -1 on failure
+ */
+static int ATTR_HOT
+amdgpu_dri3_fd_from_pixmap(
+    ScreenPtr screen,
+    PixmapPtr pixmap,
+    CARD16 *restrict stride,
+    CARD32 *restrict size)
+{
+    ScrnInfoPtr scrn = xf86ScreenToScrn(screen);
+    AMDGPUInfoPtr info = AMDGPUPTR(scrn);
+
+    if (LIKELY(info->use_glamor)) {
+        int ret = glamor_fd_from_pixmap(screen, pixmap, stride, size);
+
+        /*
+         * GLX path: explicit flush is correct here.
+         * glamor_fd_from_pixmap flushes the GL context, but GLX
+         * protocol semantics require an additional explicit flush
+         * to ensure ordering with respect to other X11 requests.
+         */
+        if (LIKELY(ret >= 0))
+            amdgpu_glamor_flush(scrn);
+
+        return ret;
+    }
+
+    struct amdgpu_buffer *bo = amdgpu_get_pixmap_bo(pixmap);
+
+    /*
+     * Security: protect against integer truncation on extreme devKind.
+     * CARD16 is 16-bit; devKind could exceed UINT16_MAX on very large
+     * pixmaps. Return -1 rather than truncating.
+     */
+    if (UNLIKELY(bo == NULL || pixmap->devKind > UINT16_MAX))
+        return -1;
+
+    struct amdgpu_bo_info bo_info;
+    if (UNLIKELY(amdgpu_bo_query_info(bo->bo.amdgpu, &bo_info) != 0))
+        return -1;
+
+    uint32_t fd;
+    if (UNLIKELY(amdgpu_bo_export(bo->bo.amdgpu,
+                                  amdgpu_bo_handle_type_dma_buf_fd,
+                                  &fd) != 0))
+        return -1;
+
+    *stride = (CARD16)pixmap->devKind;
+    *size   = bo_info.alloc_size;
+
+    return (int)fd;
+}
