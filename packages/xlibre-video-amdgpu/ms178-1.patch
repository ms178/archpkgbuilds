+static int ATTR_HOT
+amdgpu_dri3_get_modifiers(
+    ScreenPtr screen,
+    [[maybe_unused]] uint32_t format,
+    uint32_t *restrict num_modifiers,
+    uint64_t **restrict modifiers)
+{
+    ScrnInfoPtr scrn = xf86ScreenToScrn(screen);
+    AMDGPUInfoPtr info = AMDGPUPTR(scrn);
+    const uint64_t *mods;
+    uint32_t count;
