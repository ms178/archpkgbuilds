+/*
+ * open_card_node — open primary DRM card node for authentication
+ *
+ * Opens /dev/dri/cardN and authenticates with the DRM master.
+ * Used as a fallback when render node is unavailable.
+ *
+ * @param screen: X11 screen
+ * @param out: output pointer for opened FD
+ *
+ * @returns: Success on success, BadAlloc/BadMatch on error
+ *
+ * Thread safety: Called during screen initialization (single-threaded).
+ */
+static int ATTR_COLD
+open_card_node(ScreenPtr screen, int *out)
+{
+    ScrnInfoPtr scrn = xf86ScreenToScrn(screen);
+    AMDGPUEntPtr pAMDGPUEnt = AMDGPUEntPriv(scrn);
+    AMDGPUInfoPtr info = AMDGPUPTR(scrn);
+    drm_magic_t magic;
+
+    auto_close_fd int fd = -1;
+
+    fd = open(info->dri2.device_name, O_RDWR | O_CLOEXEC);
+    if (UNLIKELY(fd < 0))
+        return BadAlloc;
+
+    if (drmGetMagic(fd, &magic) < 0) {
+        if (errno == EACCES) {
+            /*
+             * EACCES: Already authenticated (DRM master held by another
+             * X server or compositor). Return the FD anyway — it's
+             * valid for non-authenticated operations.
+             */
+            *out = fd;
+            fd = -1; /* Prevent auto_close_fd from closing */
+            return Success;
+        }
+        return BadMatch;
+    }
+
+    if (UNLIKELY(drmAuthMagic(pAMDGPUEnt->fd, magic) < 0))
+        return BadMatch;
+
+    *out = fd;
+    fd = -1; /* Prevent auto_close_fd from closing */
+    return Success;
+}
