+/*
+ * amdgpu_tiling_info_to_modifier — convert legacy tiling info to DRM modifier
+ *
+ * Converts AMDGPU driver's internal tiling info (from amdgpu_bo_info) to
+ * a DRM format modifier for use in DRI3 buffer sharing.
+ *
+ * GFX9 (Vega 64) tile modes:
+ *   - 64K_S: 64 KiB bank-interleaved tiled surface, swizzle mode 9
+ *   - 64K_D: 64 KiB dual-pitched tiled surface, swizzle mode 10
+ *
+ * These modifiers match the hardware tile configuration for zero-copy scanout
+ * and ensure RADV ACO can program the VGT (Vertex Grouper Tessellator)
+ * directly without swizzling corrections.
+ *
+ * @param tiling_info: AMDGPU tiling info register value
+ * @param asic_family: AMDGPU_FAMILY_* value from amdgpu_drv.h
+ *
+ * @returns: DRM format modifier (DRM_FORMAT_MOD_LINEAR, GFX9, or GFX10)
+ *
+ * Performance: Small switch table. Compiled with -O3 and always_inline,
+ * this is ~20 instructions and fully in L1 cache.
+ */
+static uint64_t ATTR_HOT ATTR_INLINE
+amdgpu_tiling_info_to_modifier(uint64_t tiling_info, int asic_family)
+{
+    if (tiling_info == 0)
+        return DRM_FORMAT_MOD_LINEAR;
+
+    if (asic_family >= AMDGPU_FAMILY_AI) {
+        uint32_t swizzle_mode = AMDGPU_TILING_GET(tiling_info, SWIZZLE_MODE);
+        uint64_t modifier;
+
+        if (asic_family >= AMDGPU_FAMILY_NV) {
+            modifier = AMD_FMT_MOD |
+                AMD_FMT_MOD_SET(TILE_VERSION,
+                                AMD_FMT_MOD_TILE_VER_GFX10);
+        } else {
+            modifier = AMD_FMT_MOD |
+                AMD_FMT_MOD_SET(TILE_VERSION,
+                                AMD_FMT_MOD_TILE_VER_GFX9);
+        }
+
+        switch (swizzle_mode) {
+        case 9:
+            return modifier |
+                AMD_FMT_MOD_SET(TILE, AMD_FMT_MOD_TILE_GFX9_64K_S);
+        case 10:
+            return modifier |
+                AMD_FMT_MOD_SET(TILE, AMD_FMT_MOD_TILE_GFX9_64K_D);
+        default:
+            return DRM_FORMAT_MOD_INVALID;
+        }
+    }
+
+    return DRM_FORMAT_MOD_INVALID;
+}
