+/*
+ * amdgpu_dri3_pixmap_from_fds — import DMA-buf FDs as X11 pixmap
+ *
+ * DRI3 v1.2 entry point. Imports DMA-buf file descriptor(s) from the
+ * Wayland compositor and creates an X11 pixmap backed by the GPU buffer.
+ *
+ * This function is called when the Wayland compositor sends a new
+ * buffer for a window. At 60 FPS, this is called 60+ times per second
+ * per X11 window.
+ *
+ * OPTIMIZATION 4 APPLIED: Branch prediction hints and `restrict` pointers.
+ *
+ * @param screen: X11 screen
+ * @param num_fds: number of DMA-buf FDs
+ * @param fds: array of DMA-buf file descriptors
+ * @param width: buffer width in pixels
+ * @param height: buffer height in pixels
+ * @param strides: array of buffer strides
+ * @param offsets: array of buffer offsets
+ * @param depth: X11 visual depth
+ * @param bpp: bits per pixel (unused in modifier path, marked as such)
+ * @param modifier: DRM format modifier
+ *
+ * @returns: PixmapPtr on success, NULL on failure
+ */
+static PixmapPtr ATTR_HOT
+amdgpu_dri3_pixmap_from_fds(
+    ScreenPtr screen,
+    CARD8 num_fds,
+    const int *restrict fds,
+    CARD16 width,
+    CARD16 height,
+    const CARD32 *restrict strides,
+    const CARD32 *restrict offsets,
+    CARD8 depth,
+    [[maybe_unused]] CARD8 bpp,
+    CARD64 modifier)
+{
+    if (UNLIKELY(num_fds == 0 || num_fds > 4))
+        return NULL;
+
+    ScrnInfoPtr scrn = xf86ScreenToScrn(screen);
+    AMDGPUInfoPtr info = AMDGPUPTR(scrn);
+    uint32_t gbm_format;
+
+    if (UNLIKELY(!info->use_glamor ||
+                 !gbm_format_from_depth(depth, &gbm_format)))
+        return NULL;
+
+    struct gbm_device *gbm = glamor_egl_get_gbm_device(screen);
+    if (UNLIKELY(gbm == NULL))
+        return NULL;
+
+    PixmapPtr pixmap = screen->CreatePixmap(screen, 0, 0, depth, 0);
+    if (UNLIKELY(pixmap == NULL))
+        return NULL;
+
+    struct gbm_bo *bo = NULL;
+    Bool used_modifiers = FALSE;
+
+#ifdef GBM_BO_IMPORT_FD_MODIFIER
+    if (modifier != DRM_FORMAT_MOD_INVALID) {
+        struct gbm_import_fd_modifier_data import_data = {
+            .width    = width,
+            .height   = height,
+            .format   = gbm_format,
+            .num_fds  = num_fds,
+            .modifier = modifier
+        };
+
+        /*
+         * Copy FD array into GBM import structure.
+         * Loop fully unrolled at -O3; `int i` matches common
+         * practice and avoids integer promotion hazards.
+         */
+        for (int i = 0; i < (int)num_fds; i++) {
+            import_data.fds[i]     = fds[i];
+            import_data.strides[i] = strides[i];
+            import_data.offsets[i] = offsets[i];
+        }
+
+        bo = gbm_bo_import(gbm, GBM_BO_IMPORT_FD_MODIFIER,
+                           &import_data, GBM_BO_USE_RENDERING);
+        used_modifiers = LIKELY(bo != NULL);
+    } else
+#endif
+    {
+        if (LIKELY(num_fds == 1)) {
+            struct gbm_import_fd_data import_data = {
+                .fd     = fds[0],
+                .width  = width,
+                .height = height,
+                .stride = strides[0],
+                .format = gbm_format
+            };
+
+            bo = gbm_bo_import(gbm, GBM_BO_IMPORT_FD,
+                               &import_data, GBM_BO_USE_RENDERING);
+        }
+    }
+
+    if (LIKELY(bo != NULL)) {
+        screen->ModifyPixmapHeader(pixmap, width, height,
+                                  0, 0, strides[0], NULL);
+
+        if (LIKELY(glamor_egl_create_textured_pixmap_from_gbm_bo(
+                       pixmap, bo, used_modifiers))) {
+            struct amdgpu_pixmap *priv = calloc(1, sizeof(*priv));
+
+            if (LIKELY(priv != NULL)) {
+                amdgpu_set_pixmap_private(pixmap, priv);
+                pixmap->usage_hint |= AMDGPU_CREATE_PIXMAP_DRI2;
+                gbm_bo_destroy(bo);
+                return pixmap;
+            }
+        }
+
+        gbm_bo_destroy(bo);
+    }
+
+    dixDestroyPixmap(pixmap, 0);
+    return NULL;
+}
