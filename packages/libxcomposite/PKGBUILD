pkgname=libxcomposite
pkgver=0.4.7
pkgrel=5
pkgdesc="X11 Composite extension library"
arch=('x86_64')
url="https://xorg.freedesktop.org/"
license=('custom')
depends=('libxfixes')
makedepends=('clang' 'llvm' 'xorg-util-macros' 'xorgproto' 'xorg-server-xvfb' 'xorg-xauth')
source=("${url}/releases/individual/lib/libXcomposite-${pkgver}.tar.xz"{,.sig})
sha512sums=('f35a0da8f9f22fd788eee01209557fe3a1b1abdc9744f76330ba42b21b6e3af5464ca4451c33415856417c30da5aa5624e3707980c644327249bfeda5a62a59b'
            'SKIP')
validpgpkeys=('4A193C06D35E7C670FA4EF0BA2FB9E081F2D130E') # Alan Coopersmith

prepare() {
  cd "libXcomposite-${pkgver}"
  autoreconf -vfi

  cat > "${srcdir}/xcomposite_pgo_workload.c" <<'EOF'
#include <X11/Xlib.h>
#include <X11/extensions/Xcomposite.h>
#include <X11/extensions/Xfixes.h>

#include <stdio.h>
#include <stdlib.h>

static int run_round(Display *dpy, Window root, int i, int force_noext) {
  int ev = 0, err = 0;
  int maj = 0, min = 0;
  int has_ext = 0;
  XSetWindowAttributes a = {0};
  unsigned long m = 0;
  Window parent = 0, child = 0;
  Pixmap px = 0;
  Window overlay = 0;
  XserverRegion reg = 0;

  has_ext = XCompositeQueryExtension(dpy, &ev, &err);
  if (force_noext || !has_ext) {
    return has_ext ? 0 : 0;
  }

  if (!XCompositeQueryVersion(dpy, &maj, &min)) {
    return 1;
  }

  a.background_pixel = (unsigned long)(i * 2654435761U);
  a.event_mask = ExposureMask | StructureNotifyMask;
  m = CWBackPixel | CWEventMask;

  parent = XCreateWindow(dpy, root, 8 + (i % 32), 8 + (i % 32), 320, 240, 0,
                         CopyFromParent, InputOutput, CopyFromParent, m, &a);
  if (!parent) return 1;

  child = XCreateWindow(dpy, parent, 4 + (i % 16), 4 + (i % 16), 120, 90, 0,
                        CopyFromParent, InputOutput, CopyFromParent, m, &a);
  if (!child) {
    XDestroyWindow(dpy, parent);
    return 1;
  }

  XMapWindow(dpy, parent);
  XMapWindow(dpy, child);
  XSync(dpy, False);

  XCompositeRedirectWindow(dpy, child, CompositeRedirectAutomatic);
  XCompositeRedirectSubwindows(dpy, parent, CompositeRedirectAutomatic);
  XCompositeRedirectSubwindows(dpy, parent, CompositeRedirectManual);

  px = XCompositeNameWindowPixmap(dpy, child);
  if (px) XFreePixmap(dpy, px);

  reg = XCompositeCreateRegionFromBorderClip(dpy, child);
  if (reg) XFixesDestroyRegion(dpy, reg);

  overlay = XCompositeGetOverlayWindow(dpy, root);
  if (overlay) XCompositeReleaseOverlayWindow(dpy, root);

  XCompositeUnredirectSubwindows(dpy, parent, CompositeRedirectManual);
  XCompositeUnredirectSubwindows(dpy, parent, CompositeRedirectAutomatic);
  XCompositeUnredirectWindow(dpy, child, CompositeRedirectAutomatic);

  XSync(dpy, False);
  XDestroyWindow(dpy, child);
  XDestroyWindow(dpy, parent);
  return 0;
}

int main(int argc, char **argv) {
  int rounds = 120000;
  int force_noext = 0;
  int fail = 0;
  Display *dpy = NULL;
  Window root;

  if (argc > 1) {
    char *end = NULL;
    long v = strtol(argv[1], &end, 10);
    if (end && *end == '\0' && v > 0 && v <= 2000000) rounds = (int)v;
  }
  if (argc > 2) {
    char *end = NULL;
    long v = strtol(argv[2], &end, 10);
    if (end && *end == '\0') force_noext = (v != 0);
  }

  dpy = XOpenDisplay(NULL);
  if (!dpy) {
    fprintf(stderr, "XOpenDisplay failed\n");
    return 1;
  }
  root = DefaultRootWindow(dpy);

  for (int i = 0; i < rounds; ++i) {
    fail += run_round(dpy, root, i, force_noext);
  }

  XCloseDisplay(dpy);
  return fail ? 1 : 0;
}
EOF
}

_configure_make() {
  local build_dir="$1"
  local extra_cflags="$2"
  local extra_ldflags="$3"
  local src_tree="${srcdir}/libXcomposite-${pkgver}"

  rm -rf "${build_dir}"
  mkdir -p "${build_dir}"

  pushd "${build_dir}" >/dev/null
  CC=clang \
  CFLAGS="${CFLAGS} ${extra_cflags}" \
  LDFLAGS="${LDFLAGS} ${extra_ldflags}" \
    "${src_tree}/configure" \
      --prefix=/usr \
      --sysconfdir=/etc \
      --disable-static
  make
  popd >/dev/null
}

_build_runner() {
  local build_dir="$1"
  local out_bin="$2"
  local src_tree="${srcdir}/libXcomposite-${pkgver}"

  clang ${CFLAGS} ${CPPFLAGS} \
    "${srcdir}/xcomposite_pgo_workload.c" \
    -I"${src_tree}/include" \
    -L"${build_dir}/src/.libs" \
    -Wl,-rpath,"${build_dir}/src/.libs" \
    -lXcomposite -lXfixes -lX11 \
    ${LDFLAGS} \
    -o "${out_bin}"
}

_run_profile_training() {
  local build_dir="$1"
  local runner="$2"
  local ldpath="${build_dir}/src/.libs:${LD_LIBRARY_PATH}"

  # Composite enabled, multiple display configs.
  xvfb-run -a -s "-screen 0 1280x1024x24 +extension Composite" \
    env LD_LIBRARY_PATH="${ldpath}" "${runner}" 150000 0
  xvfb-run -a -s "-screen 0 1920x1080x24 +extension Composite" \
    env LD_LIBRARY_PATH="${ldpath}" "${runner}" 180000 0
  xvfb-run -a -s "-screen 0 1024x768x16 +extension Composite" \
    env LD_LIBRARY_PATH="${ldpath}" "${runner}" 120000 0

  # Composite disabled branch coverage.
  xvfb-run -a -s "-screen 0 1280x1024x24 -extension Composite" \
    env LD_LIBRARY_PATH="${ldpath}" "${runner}" 120000 1
}

build() {
  local build_pgo="${srcdir}/build-pgo-gen"
  local build_cs="${srcdir}/build-cspgo-gen"
  local build_opt="${srcdir}/build-opt"
  local pgo_raw="${srcdir}/pgo-raw"
  local cs_raw="${srcdir}/cspgo-raw"
  local pgo_prof="${srcdir}/pgo.profdata"
  local cs_prof="${srcdir}/cspgo.profdata"
  local merged_prof="${srcdir}/pgo-cspgo.profdata"
  local pgo_llvm_flags="-mllvm -enable-value-profiling -mllvm -vp-counters-per-site=1024"

  rm -rf "${pgo_raw}" "${cs_raw}" "${pgo_prof}" "${cs_prof}" "${merged_prof}"
  mkdir -p "${pgo_raw}" "${cs_raw}"

  _configure_make \
    "${build_pgo}" \
    "-fprofile-generate=${pgo_raw} ${pgo_llvm_flags}" \
    "-fprofile-generate=${pgo_raw}"

  _build_runner "${build_pgo}" "${srcdir}/xcomposite_pgo_runner"
  _run_profile_training "${build_pgo}" "${srcdir}/xcomposite_pgo_runner"
  (
    cd "${build_pgo}"
    xvfb-run -a -s "-screen 0 1280x1024x24 +extension Composite" make -k check || true
  )

  llvm-profdata merge --output="${pgo_prof}" "${pgo_raw}"

  _configure_make \
    "${build_cs}" \
    "-fprofile-use=${pgo_prof} -fcs-profile-generate=${cs_raw} ${pgo_llvm_flags} -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
    "-fprofile-use=${pgo_prof} -fcs-profile-generate=${cs_raw}"

  _build_runner "${build_cs}" "${srcdir}/xcomposite_cspgo_runner"
  _run_profile_training "${build_cs}" "${srcdir}/xcomposite_cspgo_runner"
  (
    cd "${build_cs}"
    xvfb-run -a -s "-screen 0 1280x1024x24 +extension Composite" make -k check || true
  )

  llvm-profdata merge --output="${cs_prof}" "${cs_raw}"
  llvm-profdata merge --output="${merged_prof}" "${pgo_prof}" "${cs_prof}"

  _configure_make \
    "${build_opt}" \
    "-fprofile-use=${merged_prof} -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
    "-fprofile-use=${merged_prof}"
}

check() {
  cd "${srcdir}/build-opt"
  xvfb-run -a -s "-screen 0 1280x1024x24 +extension Composite" make check
}

package() {
  local src_tree="${srcdir}/libXcomposite-${pkgver}"

  cd "${srcdir}/build-opt"
  make DESTDIR="${pkgdir}" install

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  install -m644 "${src_tree}/COPYING" "${pkgdir}/usr/share/licenses/${pkgname}/"
}
