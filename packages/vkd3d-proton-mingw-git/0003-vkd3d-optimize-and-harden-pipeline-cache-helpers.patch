From 989d1d74ffa38ed52651e58d6eeb97a32e36ab34 Mon Sep 17 00:00:00 2001
From: Arena Agent <agent@example.invalid>
Date: Wed, 17 Jun 2026 13:41:10 +0000
Subject: [PATCH 3/4] vkd3d: optimize and harden pipeline cache helpers

---
 libs/vkd3d/cache.c | 69 +++++++++++++++++++++++++++++-----------------
 1 file changed, 44 insertions(+), 25 deletions(-)

diff --git a/libs/vkd3d/cache.c b/libs/vkd3d/cache.c
index 14a5755..5e818b3 100644
--- a/libs/vkd3d/cache.c
+++ b/libs/vkd3d/cache.c
@@ -80,23 +80,23 @@ enum vkd3d_serialized_pipeline_stream_entry_type
 static size_t vkd3d_compute_size_varint(const uint32_t *words, size_t word_count)
 {
     size_t size = 0;
-    uint32_t w;
     size_t i;
 
     for (i = 0; i < word_count; i++)
     {
-        w = words[i];
-        if (w < (1u << 7))
-            size += 1;
-        else if (w < (1u << 14))
-            size += 2;
-        else if (w < (1u << 21))
-            size += 3;
-        else if (w < (1u << 28))
-            size += 4;
-        else
-            size += 5;
+        uint32_t word = words[i];
+
+#if defined(__GNUC__) || defined(__clang__)
+        size += word ? (32u - (uint32_t)__builtin_clz(word) + 6u) / 7u : 1u;
+#else
+        size += 1u;
+        size += word >= (1u << 7);
+        size += word >= (1u << 14);
+        size += word >= (1u << 21);
+        size += word >= (1u << 28);
+#endif
     }
+
     return size;
 }
 
@@ -142,28 +142,46 @@ static uint8_t *vkd3d_encode_varint(uint8_t *buffer, const uint32_t *words, size
 
 static bool vkd3d_decode_varint(uint32_t *words, size_t words_size, const uint8_t *buffer, size_t buffer_size)
 {
-    size_t offset = 0;
-    uint32_t shift;
-    uint32_t *w;
+    const uint8_t *ptr = buffer;
+    const uint8_t *end = buffer + buffer_size;
     size_t i;
 
     for (i = 0; i < words_size; i++)
     {
-        w = &words[i];
-        *w = 0;
+        uint32_t value = 0;
+        unsigned int shift = 0;
+        unsigned int j;
 
-        shift = 0;
-        do
+        for (j = 0; j < 5; j++)
         {
-            if (offset >= buffer_size || shift >= 32u)
+            uint8_t byte;
+
+            if (ptr >= end)
                 return false;
 
-            *w |= (buffer[offset] & 0x7f) << shift;
+            byte = *ptr++;
+
+            if (j == 4 && byte > 0x0f)
+                return false;
+
+            value |= (uint32_t)(byte & 0x7f) << shift;
+
+            if (!(byte & 0x80))
+            {
+                words[i] = value;
+                goto next_word;
+            }
+
             shift += 7;
-        } while (buffer[offset++] & 0x80);
+        }
+
+        return false;
+
+next_word:
+        ;
     }
 
-    return buffer_size == offset;
+    return ptr == end;
 }
 
 VkResult vkd3d_create_pipeline_cache(struct d3d12_device *device,
@@ -529,7 +547,8 @@ static struct vkd3d_pipeline_blob_chunk *finish_and_iterate_blob_chunk(struct vk
 {
     uint32_t aligned_size = align(chunk->size, VKD3D_PIPELINE_BLOB_CHUNK_ALIGN);
     /* Ensure we get stable hashes if we need to pad. */
-    memset(&chunk->data[chunk->size], 0, aligned_size - chunk->size);
+    if (aligned_size > chunk->size)
+        memset(&chunk->data[chunk->size], 0, aligned_size - chunk->size);
     return (struct vkd3d_pipeline_blob_chunk *)&chunk->data[aligned_size];
 }
 
@@ -2101,8 +2120,8 @@ static HRESULT STDMETHODCALLTYPE d3d12_pipeline_library_Serialize(d3d12_pipeline
     }
 
     hr = d3d12_pipeline_library_serialize(pipeline_library, data, data_size);
-    rwlock_unlock_read(&pipeline_library->mutex);
     rwlock_unlock_read(&pipeline_library->internal_hashmap_mutex);
+    rwlock_unlock_read(&pipeline_library->mutex);
     return hr;
 }
 
