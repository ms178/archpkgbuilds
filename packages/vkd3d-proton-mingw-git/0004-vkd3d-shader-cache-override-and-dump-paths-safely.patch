+    if (ret < 0 || (size_t)ret >= ARRAY_SIZE(filename))
         return false;
-    }
 
-    snprintf(filename, ARRAY_SIZE(filename), "%s/%016"PRIx64".spv", path, hash);
     return vkd3d_shader_replace_path(filename, hash, data, size);
 }
 
