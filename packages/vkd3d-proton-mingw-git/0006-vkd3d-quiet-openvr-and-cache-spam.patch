From 5a9d645e92379daf94807362cf1d0429b06a3f40 Mon Sep 17 00:00:00 2001
From: Arena Agent <agent@arena.ai>
Date: Tue, 23 Jun 2026 15:10:08 +0000
Subject: [PATCH 6/6] 0006-vkd3d-quiet-openvr-and-cache-spam

---
 libs/d3d12core/main.c | 14 +++++++-------
 libs/vkd3d/device.c   |  4 ++--
 2 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/libs/d3d12core/main.c b/libs/d3d12core/main.c
index fa299e33..f08055e2 100644
--- a/libs/d3d12core/main.c
+++ b/libs/d3d12core/main.c
@@ -73,12 +73,12 @@ static BOOL wait_vr_key(HKEY vr_key)
     size = sizeof(value);
     if ((status = RegQueryValueExA(vr_key, "state", NULL, &type, (BYTE *)&value, &size)))
     {
-        ERR("OpenVR: could not query value, status %d.\n", (int)status);
+        TRACE("OpenVR: could not query value, status %d.\n", (int)status);
         return false;
     }
     if (type != REG_DWORD)
     {
-        ERR("OpenVR: unexpected value type %d.\n", (int)type);
+        TRACE("OpenVR: unexpected value type %d.\n", (int)type);
         return false;
     }
 
@@ -136,12 +136,12 @@ static char *openvr_instance_extensions()
 
     if (status != ERROR_SUCCESS)
     {
-        WARN("Failed to open VR registry key, status %d.\n", (int)status);
+        TRACE("OpenVR: could not open registry key, status %d\n", (int)status);
         return NULL;
     }
     if (!wait_vr_key(vr_key))
     {
-        WARN("Failed to wait for VR registry key ready.\n");
+        TRACE("OpenVR: Failed to initialize OpenVR\n");
         RegCloseKey(vr_key);
         return NULL;
     }
@@ -182,12 +182,12 @@ static char *openvr_device_extensions(DXGI_ADAPTER_DESC *desc)
 
     if (status != ERROR_SUCCESS)
     {
-        WARN("Failed to open VR registry key, status %d.\n", (int)status);
+        TRACE("OpenVR: could not open registry key, status %d\n", (int)status);
         return NULL;
     }
     if (!wait_vr_key(vr_key))
     {
-        WARN("Failed to wait for VR registry key ready.\n");
+        TRACE("OpenVR: Failed to initialize OpenVR\n");
         RegCloseKey(vr_key);
         return NULL;
     }
@@ -235,7 +235,7 @@ static char *openxr_vulkan_extensions(bool device_extensions)
 
     if (get_extensions(0, &len, NULL))
     {
-        WARN("Failed to get OpenXR extensions size from wineopenxr.\n");
+        TRACE("OpenXR: Unable to get required Vulkan %s extensions size\n", device_extensions ? "Device" : "instance");
         return NULL;
     }
 
diff --git a/libs/vkd3d/device.c b/libs/vkd3d/device.c
index 0b5d99e2..c14d2549 100644
--- a/libs/vkd3d/device.c
+++ b/libs/vkd3d/device.c
@@ -1234,7 +1234,7 @@ static void vkd3d_instance_deduce_config_flags_from_environment(void)
             vkd3d_get_env_var("VKD3D_SHADER_DUMP_PATH", env, sizeof(env)) ||
             vkd3d_get_env_var("VKD3D_QA_HASHES", env, sizeof(env)))
     {
-        INFO("VKD3D_SHADER_OVERRIDE, VKD3D_SHADER_DUMP_PATH or VKD3D_QA_HASHES is used, pipeline_library_ignore_spirv option is enforced.\n");
+        TRACE("VKD3D_SHADER_OVERRIDE, VKD3D_SHADER_DUMP_PATH or VKD3D_QA_HASHES is used, pipeline_library_ignore_spirv option is enforced.\n");
         vkd3d_config_flag_global_add(VKD3D_CONFIG_FLAG(PIPELINE_LIBRARY_IGNORE_SPIRV));
     }
 
@@ -1255,7 +1255,7 @@ static void vkd3d_instance_deduce_config_flags_from_environment(void)
     /* If we're using a global shader cache, it's meaningless to use PSO caches. */
     if (!VKD3D_CONFIG_FLAG_IS_SET(PIPELINE_LIBRARY_APP_CACHE_ONLY))
     {
-        INFO("shader_cache is used, global_pipeline_cache is enforced.\n");
+        TRACE("shader_cache is used, global_pipeline_cache is enforced.\n");
         vkd3d_config_flag_global_add(VKD3D_CONFIG_FLAG(GLOBAL_PIPELINE_CACHE));
     }
 
-- 
