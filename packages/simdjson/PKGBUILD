# Maintainer: Bert Peters <bertptrs@archlinux.org>
pkgname=simdjson
epoch=1
pkgver=4.6.4
pkgrel=3.1
pkgdesc="A C++ library to see how fast we can parse JSON with complete validation."
arch=('x86_64')
url="https://github.com/simdjson/simdjson"
license=('Apache-2.0')
depends=(
  libgcc
  libstdc++
)
# This package should makedepend on cxxopts to build the tools, but that doesn't
# work regardless so we skip it.
makedepends=(
  cmake
  llvm
)

source=(
  "$pkgname-$pkgver.tar.gz::https://github.com/simdjson/simdjson/archive/v$pkgver.tar.gz"
)
sha256sums=('c240d4bffcccda4fe3a2bba2872718d96fc92e56d2615bfac4f9b2bad89a6386')

_optimized_builddir="build-opt"
_pgo_excluded_tests='^(avoid_stderr|iterate_char_star_should_not_compile)$'
_check_excluded_tests='^(iterate_char_star_should_not_compile)$'

_configure_simdjson() {
  local builddir="$1"

  cmake -B "$builddir" -S "$pkgname-$pkgver" \
    -DBUILD_SHARED_LIBS='On' \
    -DCMAKE_BUILD_TYPE='None' \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -DCPM_USE_LOCAL_PACKAGES='On' \
    -DSIMDJSON_DEVELOPER_MODE='On' \
    -DSIMDJSON_ALLOW_DOWNLOADS='Off' \
    -Wno-dev
}

_run_pgo_workload() {
  local builddir="$1"
  local jsonexamples="$srcdir/$pkgname-$pkgver/jsonexamples"

  # Broad test coverage ensures both hot and uncommon parser paths get sampled.
  ctest \
    --test-dir "$builddir" \
    --output-on-failure \
    --parallel "$(nproc)" \
    --exclude-regex "$_pgo_excluded_tests"

  local tool
  local json
  for tool in minify json2json jsonstats; do
    [[ -x "$builddir/tools/$tool" ]] || continue
    for json in "$jsonexamples"/*.json; do
      "$builddir/tools/$tool" "$json" >/dev/null
    done
  done

  if [[ -x "$builddir/tools/json2json" ]]; then
    for json in "$jsonexamples"/*.json; do
      "$builddir/tools/json2json" -d "$json" >/dev/null
    done
  fi

  if [[ -x "$builddir/tools/jsonpointer" && -f "$jsonexamples/twitter.json" ]]; then
    "$builddir/tools/jsonpointer" "$jsonexamples/twitter.json" "/search_metadata/count" >/dev/null
  fi
}

_build_with_flags() {
  local builddir="$1"
  local cflags_extra="$2"
  local cxxflags_extra="$3"
  local ldflags_extra="$4"

  local old_cflags="$CFLAGS"
  local old_cxxflags="$CXXFLAGS"
  local old_ldflags="$LDFLAGS"

  # Always restore user flags from makepkg.conf, even if configure/build fails.
  trap 'CFLAGS="$old_cflags"; CXXFLAGS="$old_cxxflags"; LDFLAGS="$old_ldflags"' RETURN

  CFLAGS+=" $cflags_extra"
  CXXFLAGS+=" $cxxflags_extra"
  LDFLAGS+=" $ldflags_extra"

  _configure_simdjson "$builddir"
  cmake --build "$builddir"
}

_merge_llvm_profraw() {
  local profdata_tool="$1"
  local profile_dir="$2"
  local output_file="$3"
  local -a profile_files=()

  shopt -s nullglob
  profile_files=("$profile_dir"/*.profraw)
  shopt -u nullglob

  if (( ${#profile_files[@]} == 0 )); then
    printf '%s\n' "error: no .profraw files found in $profile_dir" >&2
    return 1
  fi

  "$profdata_tool" merge -output="$output_file" "${profile_files[@]}"
}

build() {
  local compiler_version
  compiler_version="$(${CXX:-c++} --version 2>/dev/null | head -n 1)"

  local pgo_root="$srcdir/pgo"
  local ir_profile_dir="$pgo_root/ir"
  local cs_profile_dir="$pgo_root/cs"
  local ir_profile_data="$pgo_root/ir.profdata"
  local cs_profile_data="$pgo_root/cs.profdata"
  local merged_profile_data="$pgo_root/merged.profdata"
  local profdata_tool

  rm -rf "$pgo_root" build-pgo-gen build-pgo-cs "$_optimized_builddir"
  mkdir -p "$ir_profile_dir" "$cs_profile_dir"

  if [[ "$compiler_version" == *clang* ]]; then
    if ! profdata_tool="$(command -v llvm-profdata)"; then
      printf '%s\n' "error: clang CS-PGO requires llvm-profdata from llvm" >&2
      return 1
    fi

    _build_with_flags \
      build-pgo-gen \
      "-fprofile-generate=$ir_profile_dir" \
      "-fprofile-generate=$ir_profile_dir" \
      "-fprofile-generate=$ir_profile_dir"

    LLVM_PROFILE_FILE="$ir_profile_dir/default_%m.profraw" \
      _run_pgo_workload build-pgo-gen

    _merge_llvm_profraw "$profdata_tool" "$ir_profile_dir" "$ir_profile_data"

    _build_with_flags \
      build-pgo-cs \
      "-fprofile-use=$ir_profile_data -fcs-profile-generate=$cs_profile_dir -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
      "-fprofile-use=$ir_profile_data -fcs-profile-generate=$cs_profile_dir -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
      "-fprofile-use=$ir_profile_data -fcs-profile-generate=$cs_profile_dir"

    LLVM_PROFILE_FILE="$cs_profile_dir/default_%m.profraw" \
      _run_pgo_workload build-pgo-cs

    _merge_llvm_profraw "$profdata_tool" "$cs_profile_dir" "$cs_profile_data"
    "$profdata_tool" merge -output="$merged_profile_data" \
      "$cs_profile_data" \
      "$ir_profile_data"

    _build_with_flags \
      "$_optimized_builddir" \
      "-fprofile-use=$merged_profile_data -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
      "-fprofile-use=$merged_profile_data -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled" \
      "-fprofile-use=$merged_profile_data"
  else
    _build_with_flags \
      build-pgo-gen \
      "-fprofile-generate=$ir_profile_dir -fprofile-update=atomic" \
      "-fprofile-generate=$ir_profile_dir -fprofile-update=atomic" \
      "-fprofile-generate=$ir_profile_dir"

    _run_pgo_workload build-pgo-gen

    _build_with_flags \
      "$_optimized_builddir" \
      "-fprofile-use=$ir_profile_dir -fprofile-correction" \
      "-fprofile-use=$ir_profile_dir -fprofile-correction" \
      "-fprofile-use=$ir_profile_dir"
  fi
}

check() {
  local excluded_tests="$_check_excluded_tests"
  local ctest_flags=(
    --test-dir "$_optimized_builddir"
    # show the stdout and stderr when the test fails
    --output-on-failure
    # execute tests in parallel
    --parallel "$(nproc)"
  )

  if [[ -n "$excluded_tests" ]]; then
    ctest_flags+=(--exclude-regex "$excluded_tests")
  fi

  ctest "${ctest_flags[@]}"
}

package() {
  DESTDIR="$pkgdir/" cmake --install "$_optimized_builddir"
}

