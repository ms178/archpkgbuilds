# Maintainer: ms178
# Contributor: Mario Roy
# Minimum systemd Baseline: 260.1
pkgname=linux-cgroup-always-ms178
pkgver=0.2
pkgrel=1
pkgdesc="Production-grade, BORE-scheduler optimized cgroup slice & context boundaries using systemd 260.1 features"
arch=('any')
url="https://github.com/ms178/archpkgbuilds"
license=('GPL3')
depends=('fish' 'systemd>=260.1' 'procps-ng')
optdepends=(
  'linux-cachyos: CachyOS kernel with native BORE CPU scheduler implementation'
  'systemd-oomd: Active userspace out-of-memory prevention'
)
provides=('linux-cgroup-always')
conflicts=('linux-cgroup-always')
backup=(
  'etc/systemd/user/app.slice.d/60-linux-cgroup-always-app-slice.conf'
  'etc/systemd/user/background.slice.d/60-linux-cgroup-always-background-slice.conf'
  'etc/systemd/user/session.slice.d/60-linux-cgroup-always-session-slice.conf'
)
install='linux-cgroup-always.install'
source=(
  '60-linux-cgroup-always-app-slice.conf'
  '60-linux-cgroup-always-background-slice.conf'
  '60-linux-cgroup-always-session-slice.conf'
  'attach_shell_to_unique_cgroup.fish'
  'cgterm-14700kf-profile.fish'
  'cgterm-autoprofile-init.fish'
)
sha256sums=(
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
)
package() {
  # 1. Install Systemd Slice overrides under user system hierarchy
  install -Dm644 '60-linux-cgroup-always-app-slice.conf' \
    "${pkgdir}/etc/systemd/user/app.slice.d/60-linux-cgroup-always-app-slice.conf"

  install -Dm644 '60-linux-cgroup-always-background-slice.conf' \
    "${pkgdir}/etc/systemd/user/background.slice.d/60-linux-cgroup-always-background-slice.conf"

  install -Dm644 '60-linux-cgroup-always-session-slice.conf' \
    "${pkgdir}/etc/systemd/user/session.slice.d/60-linux-cgroup-always-session-slice.conf"
  # 2. Install Fish shell vendors core configurations & hooks
  install -Dm644 'attach_shell_to_unique_cgroup.fish' \
    "${pkgdir}/usr/share/fish/vendor_functions.d/attach_shell_to_unique_cgroup.fish"

  install -Dm644 'cgterm-14700kf-profile.fish' \
    "${pkgdir}/usr/share/fish/vendor_conf.d/30-cgterm-14700kf-profile.fish"

  install -Dm644 'cgterm-autoprofile-init.fish' \
    "${pkgdir}/usr/share/fish/vendor_conf.d/31-cgterm-autoprofile-init.fish"
}
