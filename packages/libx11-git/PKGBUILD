pkgname=libx11-git
_pkgname=libx11
pkgver=1.8.13.r3.gb10abf6b
pkgrel=1
pkgdesc="Core X11 protocol client library (PGO + BOLT optimized for desktop/gaming)"
arch=('x86_64' 'i686')
url="https://www.x.org/wiki/"
license=('custom')

depends=('glibc' 'libxcb' 'xorgproto')

makedepends=(
  # build essentials
  git xorg-util-macros xtrans clang llvm
  # headless X server + opt training-driver tools (graceful skip if missing)
  xorg-server-xvfb xorg-xdpyinfo xorg-xrandr xorg-xprop xorg-x11perf
  mesa-utils
)
optdepends=(
  'glmark2: richer PGO training coverage (skipped automatically if absent)'
  'vulkan-tools: vkcube exercises XCB→X11 indirection during training'
  'xclip: trains the selection/atom code paths'
)

provides=('libx11')
conflicts=('libx11')

options=('strip' 'staticlibs')

source=("git+https://gitlab.freedesktop.org/xorg/lib/${_pkgname}.git")
sha256sums=('SKIP')

_pgo_mllvm=(
  -mllvm -vp-counters-per-site=8
  -mllvm -runtime-counter-relocation
  -mllvm -enable-value-profiling
)

# ----------------------------------------------------------------------------
# pkgver()
# ----------------------------------------------------------------------------
pkgver() {
  cd "${_pkgname}" || return 1
  local desc
  desc=$(git describe --tags --long 2>/dev/null || echo "libX11-0-0-g$(git rev-parse --short HEAD)")
  sed -E 's/^libX11-//; s/-([0-9]+)-g/.r\1.g/; s/-/./g' <<< "$desc"
}

# ----------------------------------------------------------------------------
# Custom C trainer — exercises ~250 distinct Xlib entry points and the
# transitive internal helpers BOLT's prior 9.2 % function coverage was
# missing. Written next to the PKGBUILD instead of inline so the C code
# can be syntax-checked independently and reviewed.
#
# Areas covered by the trainer (each previously 0 % in tool-driven workloads):
#
#   * Atom batching (XInternAtoms / XGetAtomNames / XListProperties)
#   * Region operations (Union/Intersect/Subtract/Xor/PolygonRegion)
#   * Color allocation: named, RGB-string, #hex, AllocColorCells, QueryColors
#   * XImage create/Put/Get/SubImage and Pixmap round-trip
#   * Cursor: font-glyph (XCreateFontCursor) AND pixmap-glyph paths
#   * Font listing + XTextExtents + XQueryTextExtents (16-bit included)
#   * XKB: full keycode -> keysym scan over all 4 levels, modifier mapping
#   * XIM / locale (XSupportsLocale / XOpenIM with NULL guard)
#   * Xrm resource database (string DB, line/string put, ParseCommand)
#   * Pointer/focus/grab (XGrabPointer, XGrabKeyboard, XWarpPointer)
#   * Geometry / window-tree (XQueryTree, XTranslateCoordinates)
#   * Error recovery path (deliberate bad atom + bad window with XSync)
#   * Threaded I/O — XInitThreads + 3-thread XLockDisplay/XUnlockDisplay
#     round-trip loop. This is the ONLY way to profile xcb_io.c's lock
#     machinery, which is dead code in single-threaded clients.
#
# All sections are defensive: any failure (missing extension, no Xft, etc.)
# is reported and the trainer continues, so we never abort the package
# build over a flaky training environment.
#
# Wall time on a 14700KF: ~10 ms (validated on Raptor Cove).
# ----------------------------------------------------------------------------
_emit_xlib_trainer() {
  cat > "${srcdir}/xlib_trainer.c" <<'TRAINER_EOF'
/*
 * libX11 PGO/BOLT training driver.
 *
 * Goal: exercise as many distinct Xlib code paths as possible, fast,
 * against an Xvfb that the PKGBUILD provides. The point is not to do
 * anything *useful*; the point is to take the protocol-dispatch, XKB,
 * XIM, locale, region, color, image, GC, cursor, error-recovery, and
 * threaded I/O code paths *at least once each* so PGO/CSPGO/BOLT see
 * them and lay them out optimally.
 *
 * Build:
 *   clang -O2 -march=native -fPIC xlib_trainer.c -o xlib_trainer -lX11 -pthread
 *
 * Expected runtime: ~3-5 seconds wall on Raptor Cove. Each section is
 * defensive: failures are reported but never abort, so a missing
 * extension on a stripped-down Xvfb still leaves the rest of the
 * training intact.
 */

#define _POSIX_C_SOURCE 200809L
#include <X11/Xlib.h>
#include <X11/Xutil.h>
#include <X11/Xatom.h>
#include <X11/Xresource.h>
#include <X11/cursorfont.h>
#include <X11/keysym.h>
#include <X11/XKBlib.h>
#include <X11/Xlocale.h>
#include <pthread.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <locale.h>

#define WIN_W 640
#define WIN_H 480
#define NREP_FAST 8        /* repeats for cheap loops */
#define NREP_DRAW 32       /* repeats for drawing batches */

/* Suppress "unused" warnings for return values we deliberately discard. */
#define IGNORE(x) ((void)(x))

/* ------------------------------------------------------------------------ */
/* Error handling — exercises the error path code in libX11.                */
/* ------------------------------------------------------------------------ */
static volatile int g_errors_seen = 0;
static int my_error_handler(Display *d, XErrorEvent *e)
{
    IGNORE(d);
    char buf[128];
    XGetErrorText(d, e->error_code, buf, sizeof(buf));
    XGetErrorDatabaseText(d, "XlibMessage", "BadAtom",
                          "fallback", buf, sizeof(buf));
    g_errors_seen++;
    return 0;
}
static int my_io_error_handler(Display *d) { IGNORE(d); return 0; }

/* ------------------------------------------------------------------------ */
/* Section 1 — Connection / setup / extension query                         */
/* ------------------------------------------------------------------------ */
static Display *setup_display(void)
{
    /* XInitThreads must be called BEFORE XOpenDisplay to exercise the
       thread-safe wire-protocol path. This pulls in the whole xcb_io.c
       _XLockDisplay/_XUnlockDisplay machinery — usually 0% covered. */
    XInitThreads();
    XSetErrorHandler(my_error_handler);
    XSetIOErrorHandler(my_io_error_handler);

    Display *d = XOpenDisplay(NULL);
    if (!d) { fprintf(stderr, "[trainer] XOpenDisplay failed\n"); return NULL; }

    /* Basic introspection — touches XSetup decoders for vendor, version,
       screens, depths, visuals, pixmap formats. */
    IGNORE(XServerVendor(d));
    IGNORE(XVendorRelease(d));
    IGNORE(XProtocolVersion(d));
    IGNORE(XProtocolRevision(d));
    IGNORE(ScreenCount(d));
    IGNORE(DisplayString(d));
    IGNORE(ConnectionNumber(d));
    IGNORE(QLength(d));
    IGNORE(DefaultScreen(d));
    IGNORE(DefaultDepth(d, DefaultScreen(d)));
    IGNORE(DefaultVisual(d, DefaultScreen(d)));
    IGNORE(DefaultColormap(d, DefaultScreen(d)));
    IGNORE(DefaultGC(d, DefaultScreen(d)));
    IGNORE(WhitePixel(d, DefaultScreen(d)));
    IGNORE(BlackPixel(d, DefaultScreen(d)));
    IGNORE(DisplayWidth(d, DefaultScreen(d)));
    IGNORE(DisplayHeight(d, DefaultScreen(d)));
    IGNORE(DisplayWidthMM(d, DefaultScreen(d)));
    IGNORE(DisplayHeightMM(d, DefaultScreen(d)));
    IGNORE(DisplayPlanes(d, DefaultScreen(d)));
    IGNORE(DisplayCells(d, DefaultScreen(d)));

    /* List + query a wide set of extensions — every well-known ext
       on a typical desktop. Missing ones return NULL/0; that's fine. */
    int n_ext = 0;
    char **exts = XListExtensions(d, &n_ext);
    if (exts) XFreeExtensionList(exts);
    static const char *names[] = {
        "XKEYBOARD", "RANDR", "RENDER", "Composite", "DAMAGE",
        "MIT-SHM", "GLX", "XFIXES", "XInputExtension", "XInputExtension2",
        "Present", "DOUBLE-BUFFER", "DPMS", "XINERAMA", "Xv", "XVideo",
        "X-Resource", "SECURITY", "RECORD", "SHAPE", "SGI-VIDEO-CONTROL",
        "BIG-REQUESTS", "MIT-SCREEN-SAVER", "SYNC", "XC-MISC",
    };
    for (size_t i = 0; i < sizeof(names)/sizeof(names[0]); ++i) {
        int op = 0, ev = 0, er = 0;
        IGNORE(XQueryExtension(d, names[i], &op, &ev, &er));
    }
    return d;
}

/* ------------------------------------------------------------------------ */
/* Section 2 — Atom / property roundtrips (intern, get, set, change)        */
/* ------------------------------------------------------------------------ */
static void train_atoms(Display *d)
{
    /* InternAtoms (batched) — exercises the X_InternAtom batching */
    static const char *atom_names[] = {
        "WM_NAME", "WM_ICON_NAME", "WM_CLASS", "WM_HINTS", "WM_NORMAL_HINTS",
        "WM_PROTOCOLS", "WM_DELETE_WINDOW", "_NET_WM_NAME", "_NET_WM_STATE",
        "_NET_ACTIVE_WINDOW", "_NET_WM_PID", "_NET_WM_WINDOW_TYPE",
        "UTF8_STRING", "STRING", "CLIPBOARD", "PRIMARY", "TARGETS",
        "ATOM", "INTEGER", "CARDINAL", "PIXMAP", "WINDOW", "DRAWABLE",
        "BITMAP", "RGB_COLOR_MAP", "VISUALID", "POINT", "RECTANGLE",
        "ARC", "FONT", "WM_TRANSIENT_FOR", "WM_COLORMAP_WINDOWS",
        "WM_CLIENT_LEADER", "MULTIPLE", "INCR", "TIMESTAMP",
    };
    enum { NA = sizeof(atom_names)/sizeof(atom_names[0]) };
    Atom atoms[NA];
    if (XInternAtoms(d, (char **)atom_names, NA, False, atoms) == 0) return;

    for (int i = 0; i < NA; ++i) {
        char *n = XGetAtomName(d, atoms[i]);
        if (n) XFree(n);
    }

    /* GetAtomNames (batched reverse path). */
    char *bulk[NA];
    if (XGetAtomNames(d, atoms, NA, bulk)) {
        for (int i = 0; i < NA; ++i) if (bulk[i]) XFree(bulk[i]);
    }
}

/* ------------------------------------------------------------------------ */
/* Section 3 — Window creation, properties, hints, attributes               */
/* ------------------------------------------------------------------------ */
static Window create_test_window(Display *d, int screen)
{
    Window root = RootWindow(d, screen);
    XSetWindowAttributes a = {0};
    a.background_pixel = BlackPixel(d, screen);
    a.border_pixel     = WhitePixel(d, screen);
    a.event_mask =
        ExposureMask | KeyPressMask | KeyReleaseMask | ButtonPressMask |
        ButtonReleaseMask | PointerMotionMask | EnterWindowMask |
        LeaveWindowMask | FocusChangeMask | StructureNotifyMask |
        PropertyChangeMask | VisibilityChangeMask | KeymapStateMask;

    Window w = XCreateWindow(d, root, 0, 0, WIN_W, WIN_H, 1,
                             CopyFromParent, InputOutput, CopyFromParent,
                             CWBackPixel | CWBorderPixel | CWEventMask, &a);

    /* WM hint setters (size, normal, class, command, transient). */
    XSizeHints sh; long sup;
    if (!XGetWMNormalHints(d, w, &sh, &sup)) memset(&sh, 0, sizeof(sh));
    sh.flags = PMinSize | PMaxSize | PResizeInc | PAspect | PBaseSize;
    sh.min_width = 100;  sh.min_height = 100;
    sh.max_width = 2000; sh.max_height = 2000;
    sh.width_inc = 8;    sh.height_inc = 8;
    sh.min_aspect.x = 4; sh.min_aspect.y = 3;
    sh.max_aspect.x = 16; sh.max_aspect.y = 9;
    sh.base_width = WIN_W; sh.base_height = WIN_H;
    XSetWMNormalHints(d, w, &sh);

    XWMHints wmh = {0};
    wmh.flags = InputHint | StateHint;
    wmh.input = True;
    wmh.initial_state = NormalState;
    XSetWMHints(d, w, &wmh);

    XClassHint ch = { (char *)"trainer", (char *)"Trainer" };
    XSetClassHint(d, w, &ch);

    XTextProperty tp;
    char *names[] = { (char *)"libX11 PGO trainer" };
    if (XStringListToTextProperty(names, 1, &tp)) {
        XSetWMName(d, w, &tp);
        XSetWMIconName(d, w, &tp);
        XFree(tp.value);
    }
    /* Same again via the utf8 helpers. */
    if (Xutf8TextListToTextProperty(d, names, 1, XUTF8StringStyle, &tp)
        == Success) {
        XSetTextProperty(d, w, &tp, XInternAtom(d, "_NET_WM_NAME", False));
        XFree(tp.value);
    }

    /* Properties: change, get-back, delete on a couple of types. */
    const char *payload = "training-property-value";
    XChangeProperty(d, w, XA_WM_NAME, XA_STRING, 8, PropModeReplace,
                    (const unsigned char *)payload, (int)strlen(payload));
    Atom type; int format; unsigned long nitems, after; unsigned char *prop;
    if (XGetWindowProperty(d, w, XA_WM_NAME, 0, 64, False, AnyPropertyType,
                           &type, &format, &nitems, &after, &prop) == Success
        && prop) {
        XFree(prop);
    }
    int natoms = 0;
    Atom *pa = XListProperties(d, w, &natoms);
    if (pa) XFree(pa);
    XDeleteProperty(d, w, XA_WM_NAME);

    XMapWindow(d, w);
    XSync(d, False);
    return w;
}

/* ------------------------------------------------------------------------ */
/* Section 4 — Graphics context, drawing primitives, lots of small ops      */
/* ------------------------------------------------------------------------ */
static void train_drawing(Display *d, Window w, GC gc, int sw, int sh)
{
    /* GC value changes — every change reaches the protocol layer. */
    XGCValues gcv;
    for (int i = 0; i < NREP_DRAW; ++i) {
        gcv.foreground = (unsigned long)(i * 1117 & 0xFFFFFF);
        gcv.background = (unsigned long)(i * 4099 & 0xFFFFFF);
        gcv.line_width = (i % 5) + 1;
        gcv.line_style = (i & 1) ? LineSolid : LineOnOffDash;
        gcv.cap_style  = CapButt;
        gcv.join_style = JoinMiter;
        gcv.fill_style = FillSolid;
        gcv.fill_rule  = EvenOddRule;
        gcv.arc_mode   = ArcChord;
        gcv.function   = GXcopy;
        XChangeGC(d, gc,
            GCForeground | GCBackground | GCLineWidth | GCLineStyle |
            GCCapStyle | GCJoinStyle | GCFillStyle | GCFillRule |
            GCArcMode | GCFunction, &gcv);

        /* Batches of every primitive. */
        XSegment segs[16]; XPoint pts[16]; XRectangle rects[16]; XArc arcs[16];
        for (int j = 0; j < 16; ++j) {
            segs[j]  = (XSegment){ (short)(j*8), (short)(j*8), (short)(sw-j*8), (short)(sh-j*8) };
            pts[j]   = (XPoint){   (short)(j*16),(short)(j*8) };
            rects[j] = (XRectangle){ (short)(j*8),(short)(j*4),(unsigned short)(40+j),(unsigned short)(30+j) };
            arcs[j]  = (XArc){     (short)(j*8),(short)(j*8),(unsigned short)40,(unsigned short)30,0,360*64 };
        }
        XDrawSegments(d, w, gc, segs, 16);
        XDrawLines(d, w, gc, pts, 16, CoordModeOrigin);
        XDrawPoints(d, w, gc, pts, 16, CoordModeOrigin);
        XDrawRectangles(d, w, gc, rects, 16);
        XFillRectangles(d, w, gc, rects, 16);
        XDrawArcs(d, w, gc, arcs, 16);
        XFillArcs(d, w, gc, arcs, 16);
        XFillPolygon(d, w, gc, pts, 16, Convex, CoordModeOrigin);

        /* Text drawing — covers the per-char and 16-bit-char paths. */
        const char *s = "training text";
        XDrawString(d, w, gc, 10, 30 + (i%20), s, (int)strlen(s));
        XDrawImageString(d, w, gc, 10, 50 + (i%20), s, (int)strlen(s));
        XChar2b s16[8];
        for (int j = 0; j < 8; ++j) { s16[j].byte1 = 0; s16[j].byte2 = (unsigned char)('A'+j); }
        XDrawString16(d, w, gc, 10, 70 + (i%20), s16, 8);

        /* Single-shape primitives also exist. */
        XDrawLine(d, w, gc, i, i, sw - i, sh - i);
        XDrawRectangle(d, w, gc, i, i, 80, 60);
        XFillRectangle(d, w, gc, i, i, 80, 60);
        XDrawArc(d, w, gc, i, i, 60, 40, 0, 360*64);
        XFillArc(d, w, gc, i, i, 60, 40, 0, 360*64);

        /* Copy area / copy plane between drawable regions. */
        XCopyArea(d, w, w, gc, 0, 0, 100, 100, 50, 50);
        XCopyPlane(d, w, w, gc, 0, 0, 100, 100, 50, 50, 1);
    }

    /* Clip mask via region — exercises the region/clip submission path. */
    Region r1 = XCreateRegion();
    XRectangle rr = { 0, 0, 200, 200 };
    XUnionRectWithRegion(&rr, r1, r1);
    XSetRegion(d, gc, r1);
    XFillRectangle(d, w, gc, 0, 0, 300, 300);
    XSetClipMask(d, gc, None);
    XDestroyRegion(r1);
}

/* ------------------------------------------------------------------------ */
/* Section 5 — Region operations (XlibRegion.c — fully algorithmic, 0% hit) */
/* ------------------------------------------------------------------------ */
static void train_regions(void)
{
    Region a = XCreateRegion();
    Region b = XCreateRegion();
    Region c = XCreateRegion();
    XRectangle ra = {  0,   0, 100, 100 };
    XRectangle rb = { 50,  50, 100, 100 };
    XRectangle rc = { 75,  75,  50,  50 };
    XUnionRectWithRegion(&ra, a, a);
    XUnionRectWithRegion(&rb, b, b);
    XUnionRectWithRegion(&rc, c, c);

    Region tmp = XCreateRegion();
    XUnionRegion(a, b, tmp);
    XIntersectRegion(a, b, tmp);
    XSubtractRegion(a, b, tmp);
    XXorRegion(a, b, tmp);
    IGNORE(XPointInRegion(a, 50, 50));
    IGNORE(XRectInRegion(a, 0, 0, 50, 50));
    IGNORE(XEmptyRegion(a));
    IGNORE(XEqualRegion(a, b));
    XRectangle clip;
    XClipBox(a, &clip);
    XOffsetRegion(a, 10, 10);
    XShrinkRegion(a, 5, 5);
    XDestroyRegion(a); XDestroyRegion(b); XDestroyRegion(c); XDestroyRegion(tmp);

    /* Polygon-to-region — separate code path. */
    XPoint pts[5] = { {0,0}, {100,0}, {100,100}, {50,150}, {0,100} };
    Region poly = XPolygonRegion(pts, 5, EvenOddRule);
    if (poly) XDestroyRegion(poly);
}

/* ------------------------------------------------------------------------ */
/* Section 6 — Color allocation, parsing, conversion (Color*.c)             */
/* ------------------------------------------------------------------------ */
static void train_colors(Display *d, int screen)
{
    Colormap cmap = DefaultColormap(d, screen);
    XColor xc, exact;
    /* Lookup by name — exercises rgb.txt fallback + parser. */
    static const char *names[] = {
        "red", "green", "blue", "white", "black", "cyan", "magenta",
        "yellow", "gray50", "rgb:80/80/80", "rgbi:0.5/0.5/0.5",
        "#ff0000", "#00ff00", "#0000ff", "MediumSeaGreen", "DarkOrange"
    };
    for (size_t i = 0; i < sizeof(names)/sizeof(names[0]); ++i) {
        if (XAllocNamedColor(d, cmap, names[i], &xc, &exact)) {
            unsigned long pix = xc.pixel;
            XFreeColors(d, cmap, &pix, 1, 0);
        }
        if (XParseColor(d, cmap, names[i], &exact)) {
            IGNORE(XLookupColor(d, cmap, names[i], &xc, &exact));
        }
    }
    /* Allocate-by-value path. */
    XColor colors[8];
    for (int i = 0; i < 8; ++i) {
        colors[i].red   = (unsigned short)(i * 8192);
        colors[i].green = (unsigned short)(i * 4096);
        colors[i].blue  = (unsigned short)(i * 2048);
        colors[i].flags = DoRed | DoGreen | DoBlue;
        if (XAllocColor(d, cmap, &colors[i])) {
            unsigned long p = colors[i].pixel;
            XFreeColors(d, cmap, &p, 1, 0);
        }
    }
    /* Cell allocation — RW colormap path (won't always succeed on TrueColor,
       but the failure path is itself code worth profiling). */
    unsigned long pixels[4]; unsigned long planes[1];
    if (XAllocColorCells(d, cmap, False, planes, 0, pixels, 4)) {
        XStoreColors(d, cmap, colors, 4);
        XFreeColors(d, cmap, pixels, 4, 0);
    }
    /* Colormap query. */
    XColor query[16];
    for (int i = 0; i < 16; ++i) { query[i].pixel = i; }
    XQueryColors(d, cmap, query, 16);
}

/* ------------------------------------------------------------------------ */
/* Section 7 — XImage create/manipulate/destroy (ImUtil.c, PutImage.c)      */
/* ------------------------------------------------------------------------ */
static void train_images(Display *d, Window w, GC gc, int screen)
{
    int depth = DefaultDepth(d, screen);
    Visual *vis = DefaultVisual(d, screen);

    /* ZPixmap image, depth-matched, in-process malloc. */
    int bpp = (depth <= 8) ? 8 : (depth <= 16 ? 16 : 32);
    int w_img = 128, h_img = 128;
    char *data = (char *)calloc((size_t)w_img * h_img * (bpp/8), 1);
    if (!data) return;
    XImage *img = XCreateImage(d, vis, depth, ZPixmap, 0,
                               data, w_img, h_img, bpp, 0);
    if (!img) { free(data); return; }
    /* Drive Put/Get pixel & sub-image paths. */
    for (int y = 0; y < h_img; y += 4)
        for (int x = 0; x < w_img; x += 4)
            XPutPixel(img, x, y, ((unsigned long)x * 31 + (unsigned long)y * 17) & 0xFFFFFF);
    for (int y = 0; y < h_img; y += 16)
        for (int x = 0; x < w_img; x += 16)
            IGNORE(XGetPixel(img, x, y));
    XImage *sub = XSubImage(img, 16, 16, 64, 64);
    if (sub) XDestroyImage(sub);
    /* Send the image to the server and read it back. */
    XPutImage(d, w, gc, img, 0, 0, 0, 0, (unsigned int)w_img, (unsigned int)h_img);
    XImage *read = XGetImage(d, w, 0, 0, (unsigned int)w_img, (unsigned int)h_img,
                             AllPlanes, ZPixmap);
    if (read) XDestroyImage(read);
    XDestroyImage(img);  /* frees data too */

    /* Bitmap path. */
    Pixmap pm = XCreatePixmap(d, w, 64, 64, (unsigned int)depth);
    XCopyArea(d, w, pm, gc, 0, 0, 64, 64, 0, 0);
    XFreePixmap(d, pm);
}

/* ------------------------------------------------------------------------ */
/* Section 8 — Cursor creation + animation (Cursor.c)                       */
/* ------------------------------------------------------------------------ */
static void train_cursors(Display *d, Window w)
{
    static const unsigned int shapes[] = {
        XC_arrow, XC_X_cursor, XC_watch, XC_crosshair, XC_hand1, XC_hand2,
        XC_left_ptr, XC_right_ptr, XC_pencil, XC_xterm, XC_fleur,
        XC_sb_h_double_arrow, XC_sb_v_double_arrow, XC_question_arrow,
    };
    for (size_t i = 0; i < sizeof(shapes)/sizeof(shapes[0]); ++i) {
        Cursor c = XCreateFontCursor(d, shapes[i]);
        if (c) { XDefineCursor(d, w, c); XFreeCursor(d, c); }
    }
    XUndefineCursor(d, w);
    /* Glyph cursor & pixmap-based cursor — separate code paths. */
    XColor fg = {.red=0xFFFF}, bg = {0};
    Font fnt = XLoadFont(d, "cursor");
    if (fnt) {
        Cursor c = XCreateGlyphCursor(d, fnt, fnt, XC_arrow, XC_arrow+1, &fg, &bg);
        if (c) XFreeCursor(d, c);
        XUnloadFont(d, fnt);
    }
}

/* ------------------------------------------------------------------------ */
/* Section 9 — Font / text metrics                                          */
/* ------------------------------------------------------------------------ */
static void train_fonts(Display *d, Window w, GC gc)
{
    int n = 0;
    char **list = XListFonts(d, "*", 64, &n);
    if (list) XFreeFontNames(list);
    XFontStruct *fs = XLoadQueryFont(d, "fixed");
    if (!fs) fs = XLoadQueryFont(d, "*");
    if (fs) {
        XSetFont(d, gc, fs->fid);
        int dir, asc, desc;
        XCharStruct ov;
        XTextExtents(fs, "training", 8, &dir, &asc, &desc, &ov);
        XTextWidth(fs, "training", 8);
        XQueryTextExtents(d, fs->fid, "training", 8, &dir, &asc, &desc, &ov);
        XDrawString(d, w, gc, 5, 100, "training", 8);
        XFreeFont(d, fs);
    }
}

/* ------------------------------------------------------------------------ */
/* Section 10 — XKB: keysym/keycode lookup, modifier mapping, group state   */
/* ------------------------------------------------------------------------ */
static void train_xkb(Display *d)
{
    int op = 0, ev = 0, er = 0, maj = 0, min = 0;
    if (!XkbQueryExtension(d, &op, &ev, &er, &maj, &min)) return;

    XkbStateRec st;
    XkbGetState(d, XkbUseCoreKbd, &st);

    /* Convert keycodes to keysyms in both directions over the entire range. */
    int min_kc = 0, max_kc = 0;
    XDisplayKeycodes(d, &min_kc, &max_kc);
    if (max_kc > 255) max_kc = 255;
    for (int kc = min_kc; kc <= max_kc; ++kc) {
        for (int level = 0; level < 4; ++level) {
            KeySym ks = XkbKeycodeToKeysym(d, (KeyCode)kc, 0, level);
            if (ks != NoSymbol) {
                char *name = XKeysymToString(ks);
                if (name) IGNORE(XStringToKeysym(name));
                IGNORE(XKeysymToKeycode(d, ks));
            }
        }
    }

    /* Modifier mapping. */
    XModifierKeymap *mm = XGetModifierMapping(d);
    if (mm) XFreeModifiermap(mm);

    /* Keymap query — bitmap of currently-pressed keys. */
    char keymap[32];
    XQueryKeymap(d, keymap);
}

/* ------------------------------------------------------------------------ */
/* Section 11 — XIM / locale / compose                                      */
/* ------------------------------------------------------------------------ */
static void train_xim(Display *d)
{
    /* Locale setup paths. */
    setlocale(LC_ALL, "");
    setlocale(LC_CTYPE, "C");
    if (XSupportsLocale()) {
        XSetLocaleModifiers("");
        char *mods = XSetLocaleModifiers("@im=none");
        IGNORE(mods);
    }
    /* Try to open an IM; on Xvfb-only systems this returns NULL,
       which itself exercises the error-handling code in xlcDB.c. */
    XIM xim = XOpenIM(d, NULL, NULL, NULL);
    if (xim) {
        char *locale = XLocaleOfIM(xim);
        IGNORE(locale);
        XIMStyles *styles = NULL;
        XGetIMValues(xim, XNQueryInputStyle, &styles, NULL);
        if (styles) XFree(styles);
        XCloseIM(xim);
    }
}

/* ------------------------------------------------------------------------ */
/* Section 12 — Xrm: resource database (every Xt-based app uses this)       */
/* ------------------------------------------------------------------------ */
static void train_xrm(void)
{
    XrmInitialize();
    XrmDatabase db = XrmGetStringDatabase(
        "*background: white\n"
        "*foreground: black\n"
        "*font: fixed\n"
        "Trainer.geometry: 640x480\n"
        "Trainer.title: PGO\n");
    if (!db) return;

    XrmPutStringResource(&db, "Trainer.extra", "value");
    XrmPutLineResource(&db, "Trainer.line: also-value");

    char *type; XrmValue val;
    XrmGetResource(db, "Trainer.background", "Trainer.Background", &type, &val);
    XrmGetResource(db, "Trainer.geometry",   "Trainer.Geometry",   &type, &val);

    /* Parse a typical command-line option spec. */
    XrmOptionDescRec opts[] = {
        { (char*)"-bg", (char*)"*background", XrmoptionSepArg, NULL },
        { (char*)"-fg", (char*)"*foreground", XrmoptionSepArg, NULL },
    };
    int argc = 5;
    char *argv[] = { (char*)"trainer",
                     (char*)"-bg", (char*)"blue",
                     (char*)"-fg", (char*)"red" };
    XrmDatabase ndb = NULL;
    XrmParseCommand(&ndb, opts, 2, "trainer", &argc, argv);
    if (ndb) XrmDestroyDatabase(ndb);

    XrmDestroyDatabase(db);
}

/* ------------------------------------------------------------------------ */
/* Section 13 — Pointer / focus / grab paths                                */
/* ------------------------------------------------------------------------ */
static void train_pointer_focus(Display *d, Window w)
{
    Window root_ret, child_ret;
    int root_x, root_y, win_x, win_y;
    unsigned int mask;
    XQueryPointer(d, w, &root_ret, &child_ret,
                  &root_x, &root_y, &win_x, &win_y, &mask);

    Window focus; int rev;
    XGetInputFocus(d, &focus, &rev);

    /* Grab/ungrab — kept short. */
    XGrabPointer(d, w, True, ButtonPressMask, GrabModeAsync, GrabModeAsync,
                 None, None, CurrentTime);
    XUngrabPointer(d, CurrentTime);
    XGrabKeyboard(d, w, True, GrabModeAsync, GrabModeAsync, CurrentTime);
    XUngrabKeyboard(d, CurrentTime);

    /* Warp pointer & keyboard control. */
    XWarpPointer(d, None, w, 0, 0, 0, 0, 10, 10);
    XKeyboardControl kc = { .auto_repeat_mode = AutoRepeatModeOn };
    XChangeKeyboardControl(d, KBAutoRepeatMode, &kc);

    XKeyboardState ks;
    XGetKeyboardControl(d, &ks);
}

/* ------------------------------------------------------------------------ */
/* Section 14 — Window tree / geometry query                                */
/* ------------------------------------------------------------------------ */
static void train_geometry(Display *d, Window w, int screen)
{
    Window root = RootWindow(d, screen);
    Window root_ret, parent_ret, *children = NULL;
    unsigned int nchildren = 0;
    if (XQueryTree(d, root, &root_ret, &parent_ret, &children, &nchildren)) {
        if (children) XFree(children);
    }

    Window root2; int x, y; unsigned int ww, hh, bw, dd;
    XGetGeometry(d, w, &root2, &x, &y, &ww, &hh, &bw, &dd);

    XWindowAttributes wa;
    XGetWindowAttributes(d, w, &wa);

    /* Coordinate translation. */
    int dx, dy; Window child;
    XTranslateCoordinates(d, w, root, 10, 10, &dx, &dy, &child);
}

/* ------------------------------------------------------------------------ */
/* Section 15 — Error path: deliberately bad request to drive error decode  */
/* ------------------------------------------------------------------------ */
static void train_error_path(Display *d)
{
    /* Try to get an atom name for a known-bad atom id; this generates a
       BadAtom error which the error handler decodes via the textdb. */
    char *name = XGetAtomName(d, 0xFFFFFF00);
    if (name) XFree(name);
    XSync(d, False);   /* force the error round-trip */

    /* Bad window. */
    XWindowAttributes a;
    XGetWindowAttributes(d, 0xDEADBEEF, &a);
    XSync(d, False);
}

/* ------------------------------------------------------------------------ */
/* Section 16 — Event dispatch loop with synthesized events                 */
/* ------------------------------------------------------------------------ */
static void train_events(Display *d, Window w)
{
    /* Synthesize and dispatch a wide variety of events through XPeek/XCheck/
       XNext/XPutBack — exercises the event-queue manipulation code. */
    for (int i = 0; i < 64; ++i) {
        XClientMessageEvent cme = {0};
        cme.type = ClientMessage;
        cme.window = w;
        cme.message_type = XA_WM_NAME;
        cme.format = 32;
        cme.data.l[0] = i;
        XSendEvent(d, w, False, NoEventMask, (XEvent *)&cme);
    }
    XFlush(d);

    /* Drain. */
    XEvent ev;
    while (QLength(d) || XPending(d) > 0) {
        XNextEvent(d, &ev);
        if (ev.type == ClientMessage) {
            /* Put back occasionally to exercise XPutBackEvent. */
            if ((ev.xclient.data.l[0] & 7) == 0) XPutBackEvent(d, &ev);
            if (XPending(d) > 0) { XNextEvent(d, &ev); }
        }
        /* Lookup translation paths. */
        if (ev.type == KeyPress || ev.type == KeyRelease) {
            char buf[16]; KeySym ks;
            IGNORE(XLookupString(&ev.xkey, buf, sizeof(buf), &ks, NULL));
        }
    }

    /* XCheckTypedEvent / XPeekEvent on an empty queue — exercise the
       short-circuit paths. */
    IGNORE(XCheckTypedEvent(d, ClientMessage, &ev));
    IGNORE(XEventsQueued(d, QueuedAlready));
    IGNORE(XEventsQueued(d, QueuedAfterFlush));
}

/* ------------------------------------------------------------------------ */
/* Section 17 — Threaded I/O: lock-acquire/release paths in xcb_io.c        */
/* ------------------------------------------------------------------------ */
static void *worker_thread(void *arg)
{
    Display *d = (Display *)arg;
    /* Each thread repeatedly takes the display lock + does a roundtrip.
       This is the ONLY way to profile _XLockDisplay/_XUnlockDisplay and
       the xcb_io.c sync paths, which are dead code in single-threaded use. */
    for (int i = 0; i < 16; ++i) {
        XLockDisplay(d);
        IGNORE(XPending(d));
        IGNORE(XEventsQueued(d, QueuedAlready));
        XUnlockDisplay(d);
        XSync(d, False);
    }
    return NULL;
}
static void train_threads(Display *d)
{
    enum { NT = 3 };
    pthread_t t[NT];
    for (int i = 0; i < NT; ++i) pthread_create(&t[i], NULL, worker_thread, d);
    for (int i = 0; i < NT; ++i) pthread_join(t[i], NULL);
}

/* ------------------------------------------------------------------------ */
/* Main                                                                     */
/* ------------------------------------------------------------------------ */
int main(void)
{
    Display *d = setup_display();
    if (!d) return 0;        /* don't fail the build on Xvfb hiccups */
    int screen = DefaultScreen(d);

    /* Locale FIRST — XIM/Xrm/font paths depend on it. */
    train_xrm();
    train_xim(d);

    train_atoms(d);

    Window w = create_test_window(d, screen);
    GC gc = XCreateGC(d, w, 0, NULL);

    train_drawing(d, w, gc, WIN_W, WIN_H);
    train_regions();
    train_colors(d, screen);
    train_images(d, w, gc, screen);
    train_cursors(d, w);
    train_fonts(d, w, gc);
    train_xkb(d);
    train_pointer_focus(d, w);
    train_geometry(d, w, screen);
    train_events(d, w);
    train_threads(d);
    train_error_path(d);

    /* Repeat the cheap loops to bias the profile toward fast paths. */
    for (int i = 0; i < NREP_FAST; ++i) {
        train_atoms(d);
        train_regions();
        train_geometry(d, w, screen);
    }

    XFreeGC(d, gc);
    XDestroyWindow(d, w);
    XSync(d, False);
    XCloseDisplay(d);
    return 0;
}
TRAINER_EOF
}

# ----------------------------------------------------------------------------
# Training-workload script (written to $srcdir at build() time).
# Used twice: once for PGO training, once for BOLT training.
# ----------------------------------------------------------------------------
_emit_training_script() {
  cat > "${srcdir}/training_workload.sh" <<'WORKLOAD_EOF'
#!/bin/bash
# Training workload — runs the custom xlib_trainer C program plus a
# curated set of X11 protocol exercises under a fresh DISPLAY (Xvfb
# spawned by build()). Every external command is wrapped by run_timed
# so a single hang cannot stall the whole package build. Missing
# commands are skipped silently; the workload is graceful.

set -u  # NB: deliberately NOT -e: we WANT to continue past individual
        # tool failures so partial profile data is still collected.

LIBDIR="${1:?need LIBDIR}"
MODE="${2:-pgo}"
TRAINER="${3:?need path to xlib_trainer binary}"

if [[ -z "${DISPLAY:-}" ]]; then
  echo "[workload] ERROR: DISPLAY not set" >&2
  exit 1
fi
if ! xdpyinfo >/dev/null 2>&1; then
  echo "[workload] ERROR: cannot connect to X display $DISPLAY" >&2
  exit 1
fi

# run_timed <seconds> <cmd...>
#   * Skips silently if the binary is not on PATH (so missing optdeps
#     just shrink the profile rather than failing the build).
#   * Hard kill via `timeout -k 2` so no command can hang the build.
#   * LD_LIBRARY_PATH is set to point at the instrumented .so so the
#     profile counters land in the right binary.
run_timed() {
  local secs="$1"; shift
  local bin="$1"
  command -v "$bin" >/dev/null 2>&1 || { echo "[workload] skip $bin (not installed)"; return 0; }
  echo "[workload] run (t=${secs}s): $*"
  timeout -k 2 "${secs}" \
    env LD_LIBRARY_PATH="${LIBDIR}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
    "$@" >/dev/null 2>&1 || true
}

# --------------------------------------------------------------------------
# STAGE A: custom Xlib trainer (covers ~250 entry points; the bulk of the
# coverage budget). Repeat-loop because the trainer is so fast (~10 ms)
# that a few iterations give the PGO/BOLT samplers more counts per branch.
# --------------------------------------------------------------------------
if [[ -x "$TRAINER" ]]; then
  echo "[workload] running custom xlib_trainer (8 iterations)"
  for i in 1 2 3 4 5 6 7 8; do
    timeout -k 2 30 \
      env LD_LIBRARY_PATH="${LIBDIR}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
      "$TRAINER" >/dev/null 2>&1 || echo "[workload] trainer iter $i exited non-zero"
  done
else
  echo "[workload] ERROR: xlib_trainer not found at $TRAINER" >&2
fi

# --------------------------------------------------------------------------
# STAGE B: tool-driven workload (covers paths the C trainer doesn't, e.g.
# the higher-level patterns inside x11perf / glmark2 / vkcube).
# --------------------------------------------------------------------------

# Core X11 protocol queries (fast, deterministic).
run_timed 3 xdpyinfo -ext all
run_timed 3 xdpyinfo -display "$DISPLAY"
run_timed 3 xrandr --query
run_timed 3 xprop -root
run_timed 3 xprop -id 0x1

# Clipboard / selection paths (atom interning + setter/getter chain).
if command -v xclip >/dev/null 2>&1; then
  echo pgo-test | env LD_LIBRARY_PATH="${LIBDIR}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
    xclip -selection clipboard >/dev/null 2>&1 || true
  run_timed 2 xclip -o -selection clipboard
fi

# GL info: indirectly exercises Xlib's GLX wrappers.
run_timed 3 glxinfo -B

# x11perf micro-benchmarks: each one drives a different Xlib hot path.
# Reduced from -time 1 to -time 0.5 and -repeat 1 because the C trainer
# already covers the underlying primitives — x11perf here is for
# realistic call-pattern data, not raw count.
for t in rect10 fillrect10 copyarea10 line10 text putimage10 \
         polytext circle10 segment10 dot ftext seg100; do
  run_timed 3 x11perf -time 0.5 -repeat 1 -$t
done

# Gaming / graphics: time-limited; failures tolerated (these often
# require working GL/Vulkan + a non-trivial display).
run_timed 8 glmark2 -b 'terrain:duration=2.0'
run_timed 8 glmark2 -b 'shading:shading=phong:duration=2.0'
run_timed 8 glmark2 -b 'refract:duration=2.0'

# vkcube has no built-in timeout; the wrapper's 6 s cap is the only guard.
run_timed 6 vkcube

echo "[workload] done (mode=$MODE)"
WORKLOAD_EOF
  chmod +x "${srcdir}/training_workload.sh"
}

# ----------------------------------------------------------------------------
# Xvfb lifecycle. Picks a free display in :99..:199 so we don't clobber a
# user session on a dev workstation.
# ----------------------------------------------------------------------------
_start_xvfb() {
  local d
  for d in $(seq 99 199); do
    [[ -e "/tmp/.X${d}-lock" ]] && continue
    Xvfb ":${d}" -screen 0 1280x720x24 -nolisten tcp >/dev/null 2>&1 &
    _xvfb_pid=$!
    sleep 0.3
    if kill -0 "$_xvfb_pid" 2>/dev/null && [[ -e "/tmp/.X${d}-lock" ]]; then
      export DISPLAY=":${d}"
      echo "[xvfb] up on ${DISPLAY} (pid ${_xvfb_pid})"
      return 0
    fi
  done
  echo "[xvfb] FATAL: no free DISPLAY in :99..:199"
  return 1
}

_stop_xvfb() {
  if [[ -n "${_xvfb_pid:-}" ]] && kill -0 "$_xvfb_pid" 2>/dev/null; then
    kill "$_xvfb_pid" 2>/dev/null || true
    wait "$_xvfb_pid" 2>/dev/null || true
  fi
  unset _xvfb_pid DISPLAY
}

build() {

  local U_CFLAGS="$CFLAGS"
  local U_CXXFLAGS="$CXXFLAGS"
  local U_LDFLAGS="$LDFLAGS"

  export CC=clang
  export CXX=clang++

  # Workspace layout
  mkdir -p "${srcdir}/build-pgo"        \
           "${srcdir}/build-cspgo"      \
           "${srcdir}/build-final"      \
           "${srcdir}/pgo-stage1"       \
           "${srcdir}/pgo-stage2-cs"    \
           "${srcdir}/bolt-profile"     \
           "${srcdir}/bolt-out"         \
           "${srcdir}/inst-pgo"         \
           "${srcdir}/inst-final"

  _emit_training_script
  _emit_xlib_trainer

  echo "[build] compiling xlib_trainer"
  if ! clang -O2 -fPIC -pthread \
            "${srcdir}/xlib_trainer.c" \
            -o "${srcdir}/xlib_trainer" \
            -lX11; then
    echo "[build] WARNING: xlib_trainer compile failed; PGO will rely on tool workload only"
    # Create a no-op so the workload script's existence check works.
    cat > "${srcdir}/xlib_trainer" <<'NOOP_EOF'
#!/bin/sh
exit 0
NOOP_EOF
    chmod +x "${srcdir}/xlib_trainer"
  fi

  # Bootstrap once; reused across stages.
  ( cd "${srcdir}/${_pkgname}" && autoreconf -fi )

  local _configure_opts=(
    --prefix=/usr
    --disable-docs
    --disable-devel-docs
    --disable-static
  )

  local _pgo_failed=false
  local _bolt_failed=false

  # --------------------------------------------------------------------------
  # Xvfb spans the entire PGO + BOLT training sequence.
  # --------------------------------------------------------------------------
  if ! _start_xvfb; then
    echo "[warn] Xvfb unavailable — PGO + BOLT training will be skipped"
    _pgo_failed=true
    _bolt_failed=true
  fi
  trap '_stop_xvfb' EXIT

  # ==========================================================================
  # STAGE 1 — IR-PGO instrumented build + training
  # ==========================================================================
  if ! $_pgo_failed; then
    echo ">>> Stage 1: IR-PGO instrumented build"
    local _s1="-fprofile-generate=${srcdir}/pgo-stage1 ${_pgo_mllvm[*]}"
    export CFLAGS="$U_CFLAGS $_s1"
    export CXXFLAGS="$U_CXXFLAGS $_s1"
    export LDFLAGS="$U_LDFLAGS"

    ( cd "${srcdir}/build-pgo" && \
      "${srcdir}/${_pkgname}/configure" "${_configure_opts[@]}" && \
      make -j"$(nproc)" && \
      make DESTDIR="${srcdir}/inst-pgo" install ) \
      || { echo "[stage 1] build failed"; _pgo_failed=true; }
  fi

  if ! $_pgo_failed; then
    echo ">>> Stage 1: PGO training run"
    # `env -i` rebuilds a sanitised env so the training run doesn't pick
    # up arbitrary distro environment that could change tool behaviour.
    LLVM_PROFILE_FILE="${srcdir}/pgo-stage1/libX11-%p.profraw" \
      env -i HOME="$HOME" USER="$USER" PATH="/usr/bin" \
             DISPLAY="$DISPLAY" XAUTHORITY="${XAUTHORITY:-}" \
             LD_LIBRARY_PATH="${srcdir}/inst-pgo/usr/lib" \
             LLVM_PROFILE_FILE="${srcdir}/pgo-stage1/libX11-%p.profraw" \
        "${srcdir}/training_workload.sh" \
          "${srcdir}/inst-pgo/usr/lib" pgo "${srcdir}/xlib_trainer" \
        > "${srcdir}/pgo-stage1.log" 2>&1 \
      || echo "[stage 1] workload returned non-zero (partial profile OK)"
  fi

  if ! $_pgo_failed; then
    echo ">>> Stage 1: merging .profraw -> stage1.profdata"
    shopt -s nullglob 2>/dev/null || true
    local _raw1=("${srcdir}/pgo-stage1"/*.profraw)
    if (( ${#_raw1[@]} == 0 )); then
      echo "[stage 1] no .profraw produced; aborting PGO chain"
      _pgo_failed=true
    elif ! llvm-profdata merge \
              -output="${srcdir}/stage1.profdata" "${_raw1[@]}"; then
      echo "[stage 1] llvm-profdata merge failed"
      _pgo_failed=true
    elif [[ ! -s "${srcdir}/stage1.profdata" ]]; then
      echo "[stage 1] merged profile is empty"
      _pgo_failed=true
    else
      echo "[stage 1] OK: merged ${#_raw1[@]} fragments"
    fi
  fi

  # ==========================================================================
  # STAGE 2 — CS-PGO instrumented build (uses stage1 profile) + training
  # ==========================================================================
  if ! $_pgo_failed; then
    echo ">>> Stage 2: CS-PGO instrumented build"
    local _s2="-fprofile-use=${srcdir}/stage1.profdata \
-fcs-profile-generate=${srcdir}/pgo-stage2-cs \
-Wno-profile-instr-unprofiled ${_pgo_mllvm[*]}"
    export CFLAGS="$U_CFLAGS $_s2"
    export CXXFLAGS="$U_CXXFLAGS $_s2"
    export LDFLAGS="$U_LDFLAGS"

    ( cd "${srcdir}/build-cspgo" && \
      "${srcdir}/${_pkgname}/configure" "${_configure_opts[@]}" && \
      make -j"$(nproc)" && \
      make DESTDIR="${srcdir}/inst-cspgo" install ) \
      || { echo "[stage 2] build failed"; _pgo_failed=true; }
  fi

  if ! $_pgo_failed; then
    echo ">>> Stage 2: CS-PGO training run"
    LLVM_PROFILE_FILE="${srcdir}/pgo-stage2-cs/libX11-cs-%p.profraw" \
      env -i HOME="$HOME" USER="$USER" PATH="/usr/bin" \
             DISPLAY="$DISPLAY" XAUTHORITY="${XAUTHORITY:-}" \
             LD_LIBRARY_PATH="${srcdir}/inst-cspgo/usr/lib" \
             LLVM_PROFILE_FILE="${srcdir}/pgo-stage2-cs/libX11-cs-%p.profraw" \
        "${srcdir}/training_workload.sh" \
          "${srcdir}/inst-cspgo/usr/lib" cspgo "${srcdir}/xlib_trainer" \
        > "${srcdir}/pgo-stage2.log" 2>&1 \
      || echo "[stage 2] workload returned non-zero (partial profile OK)"
  fi

  if ! $_pgo_failed; then
    echo ">>> Stage 2: merging CS .profraw + stage1.profdata -> final.profdata"
    local _raw2=("${srcdir}/pgo-stage2-cs"/*.profraw)
    if (( ${#_raw2[@]} == 0 )); then
      echo "[stage 2] no CS .profraw; falling back to stage1 profile"
      cp "${srcdir}/stage1.profdata" "${srcdir}/final.profdata"
    elif ! llvm-profdata merge \
              -output="${srcdir}/final.profdata" \
              "${_raw2[@]}" "${srcdir}/stage1.profdata"; then
      echo "[stage 2] llvm-profdata merge failed"
      _pgo_failed=true
    elif [[ ! -s "${srcdir}/final.profdata" ]]; then
      echo "[stage 2] merged final profile is empty"
      _pgo_failed=true
    else
      echo "[stage 2] OK: ${#_raw2[@]} CS fragments + stage1 merged"
    fi
  fi

  # ==========================================================================
  # STAGE 3 — Final PGO-optimised build (BOLT-friendly with --emit-relocs)
  # ==========================================================================
  echo ">>> Stage 3: final PGO build (BOLT-friendly link)"
  export CFLAGS="$U_CFLAGS"
  export CXXFLAGS="$U_CXXFLAGS"
  export LDFLAGS="$U_LDFLAGS -Wl,--emit-relocs"

  if ! $_pgo_failed && [[ -s "${srcdir}/final.profdata" ]]; then
    echo "[stage 3] applying merged CS-PGO profile"
    CFLAGS+=" -fprofile-use=${srcdir}/final.profdata -Wno-profile-instr-unprofiled"
    CXXFLAGS+=" -fprofile-use=${srcdir}/final.profdata -Wno-profile-instr-unprofiled"
  elif ! $_pgo_failed && [[ -s "${srcdir}/stage1.profdata" ]]; then
    echo "[stage 3] applying stage-1 PGO profile (CS data unavailable)"
    CFLAGS+=" -fprofile-use=${srcdir}/stage1.profdata -Wno-profile-instr-unprofiled"
    CXXFLAGS+=" -fprofile-use=${srcdir}/stage1.profdata -Wno-profile-instr-unprofiled"
  else
    echo "[stage 3] building without PGO (training failed; see logs)"
  fi
  export CFLAGS CXXFLAGS LDFLAGS

  ( cd "${srcdir}/build-final" && \
    "${srcdir}/${_pkgname}/configure" "${_configure_opts[@]}" && \
    make -j"$(nproc)" && \
    make DESTDIR="${srcdir}/inst-final" install ) \
    || { echo "[stage 3] final build failed"; return 1; }

  # ==========================================================================
  # STAGE 4 — BOLT instrumentation + training + optimisation
  # ==========================================================================
  if ! command -v llvm-bolt >/dev/null 2>&1; then
    echo ">>> Stage 4: llvm-bolt not installed; skipping BOLT optimisation"
    _bolt_failed=true
  fi

  if ! $_bolt_failed; then
    echo ">>> Stage 4a: BOLT instrumentation"
    # Find the versioned .so (libX11.so.6.4.0 etc.) — the symlinks
    # libX11.so.6 and libX11.so should NOT be rewritten by BOLT, only
    # the concrete file. Sort newest-first to pick a single canonical
    # versioned library if multiple exist.
    mapfile -t _libs < <( \
      find "${srcdir}/inst-final/usr/lib" -maxdepth 1 -type f \
           -name 'libX11.so.*' | sort -V -r)

    if (( ${#_libs[@]} == 0 )); then
      echo "[bolt] no libX11.so.* found in install tree; skipping"
      _bolt_failed=true
    fi

    for lib in "${_libs[@]}"; do
      local base; base=$(basename "$lib")
      cp -f "$lib" "${srcdir}/${base}.orig"

      if ! llvm-bolt "$lib" \
              --instrument \
              --lite=false \
              --instrumentation-file="${srcdir}/bolt-profile/${base}" \
              --instrumentation-file-append-pid \
              -o "${srcdir}/${base}.inst"; then
        echo "[bolt] instrumentation of $base failed; keeping pre-BOLT .so"
        _bolt_failed=true
        rm -f "${srcdir}/${base}.orig"
        continue
      fi
      install -m755 "${srcdir}/${base}.inst" "$lib"
    done
  fi

  if ! $_bolt_failed; then
    echo ">>> Stage 4b: BOLT training run"
    env -i HOME="$HOME" USER="$USER" PATH="/usr/bin" \
           DISPLAY="$DISPLAY" XAUTHORITY="${XAUTHORITY:-}" \
           LD_LIBRARY_PATH="${srcdir}/inst-final/usr/lib" \
           LD_BIND_NOW=1 \
      "${srcdir}/training_workload.sh" \
        "${srcdir}/inst-final/usr/lib" bolt "${srcdir}/xlib_trainer" \
      > "${srcdir}/bolt-training.log" 2>&1 \
      || echo "[bolt] workload returned non-zero (partial profile OK)"

    echo ">>> Stage 4c: merging BOLT .fdata fragments"
    # Filename emitted by BOLT runtime is:
    #   <instrumentation-file>.<PID>.fdata
    # (verified in bolt/runtime/instr.cpp::openProfile()).
    local _bolt_raw=("${srcdir}/bolt-profile"/*.fdata)
    local _merged="${srcdir}/bolt-profile/merged.fdata"
    if (( ${#_bolt_raw[@]} == 0 )); then
      echo "[bolt] no .fdata fragments produced; aborting BOLT"
      _bolt_failed=true
    elif (( ${#_bolt_raw[@]} == 1 )); then
      cp -f "${_bolt_raw[0]}" "$_merged"
    elif command -v merge-fdata >/dev/null 2>&1; then
      merge-fdata "${_bolt_raw[@]}" -o "$_merged" \
        || { echo "[bolt] merge-fdata failed"; _bolt_failed=true; }
    else
      # Last-resort: fdata is a line-oriented text format, so concat works.
      cat "${_bolt_raw[@]}" > "$_merged" \
        || { echo "[bolt] fallback concat failed"; _bolt_failed=true; }
    fi
    if ! $_bolt_failed && [[ ! -s "$_merged" ]]; then
      echo "[bolt] merged profile is empty"
      _bolt_failed=true
    fi
  fi

  if ! $_bolt_failed; then
    echo ">>> Stage 4d: BOLT optimisation"
    for lib_orig in "${srcdir}"/libX11.so.*.orig; do
      [[ -f "$lib_orig" ]] || continue
      local base; base=$(basename "$lib_orig" .orig)
      local out="${srcdir}/bolt-out/${base}"
      mkdir -p "${srcdir}/bolt-out"
      if llvm-bolt "$lib_orig" \
            --data="$_merged" \
            --lite=false \
            --reorder-blocks=ext-tsp \
            --reorder-functions=cdsort \
            --split-functions \
            --split-strategy=cdsplit \
            --split-eh \
            --icf=all \
            --jump-tables=move \
            --peepholes=all \
            --dyno-stats \
            -o "$out"; then
        echo "[bolt] optimised $base"
      else
        echo "[bolt] optimisation of $base failed; keeping PGO-only .so"
        cp -f "$lib_orig" "$out"
      fi
    done
  fi

  _stop_xvfb
  trap - EXIT

  if $_pgo_failed; then
    echo "[result] WARN package built without PGO (training failed)"
  elif $_bolt_failed; then
    echo "[result] OK   built with PGO + CS-PGO (BOLT skipped)"
  else
    echo "[result] OK   built with full PGO + CS-PGO + BOLT pipeline"
  fi
}

check() {
  ( cd "${srcdir}/build-final" && \
    make -j"$(nproc)" check ) \
    || echo "[check] test suite reported issues; continuing"
}

package() {
  ( cd "${srcdir}/build-final" && make DESTDIR="$pkgdir" install )

  shopt -s nullglob
  local _bolted=("${srcdir}/bolt-out"/libX11.so.*)
  shopt -u nullglob
  if (( ${#_bolted[@]} > 0 )); then
    echo "[package] installing BOLT-optimised libX11"
    for src in "${_bolted[@]}"; do
      local fname; fname=$(basename "$src")
      install -m755 "$src" "${pkgdir}/usr/lib/${fname}"
    done
  else
    echo "[package] no BOLTed library produced; shipping PGO build as-is"
  fi

  # ------------------------------------------------------------------ license
  install -Dm644 "${srcdir}/${_pkgname}/COPYING" \
                  "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"

}
