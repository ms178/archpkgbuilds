# ── GCC toolchain setup ──────────────────────────────────────────────────────
#
# GCC with default GNU binutils — no LLVM tools needed.
# Linker, ar, nm, ranlib, strip, and objcopy are the system defaults.

_setup_gcc_toolchain() {
  export CC=gcc
  export CXX=g++
  export FC=gfortran
}

# ── Staging helpers ──────────────────────────────────────────────────────────

_prepare_stage_tree() {
  local srcroot="$1"
  local dstroot="$2"
  rm -rf "$dstroot"
  cp -a --reflink=auto "$srcroot" "$dstroot"
}

_stage_ldpath() {
  local stageroot="$1"
  printf '%s' \
    "${stageroot}/libtextstyle/lib/.libs:" \
    "${stageroot}/libtextstyle/src/.libs:" \
    "${stageroot}/gettext-runtime/intl/.libs:" \
    "${stageroot}/gettext-runtime/gnulib-lib/.libs:" \
    "${stageroot}/gettext-runtime/src/.libs:" \
    "${stageroot}/gettext-tools/gnulib-lib/.libs:" \
    "${stageroot}/gettext-tools/intl/.libs:" \
    "${stageroot}/gettext-tools/src/.libs"
}

_stage_make() {
  local stageroot="$1"
  local relpath="$2"
  local jobs="$3"
  shift 3
  local saved_ldpath="${LD_LIBRARY_PATH:-}"
  local stage_ldpath
  stage_ldpath="$(_stage_ldpath "$stageroot")"
  if (( $# > 0 )); then
    env MAKEFLAGS= \
      LD_LIBRARY_PATH="${stage_ldpath}${saved_ldpath:+:${saved_ldpath}}" \
      make -C "${stageroot}/${relpath}" -j"${jobs}" "$@"
  else
    env MAKEFLAGS= \
      LD_LIBRARY_PATH="${stage_ldpath}${saved_ldpath:+:${saved_ldpath}}" \
      make -C "${stageroot}/${relpath}" -j"${jobs}"
  fi
}

_ensure_uninstalled_so() {
  local libdir="$1"
  local libname="$2"
  local wanted="${libdir}/.libs/${libname}.so"
  local candidate
  [[ -e "$wanted" ]] && return 0
  shopt -s nullglob
  local -a candidates=(
    "${libdir}/.libs/${libname}.so."*
    "${libdir}/.libs/${libname}-"*.so
  )
  shopt -u nullglob
  for candidate in "${candidates[@]}"; do
    [[ -f "$candidate" ]] || continue
    ln -sfn "$(basename "$candidate")" "$wanted"
    [[ -e "$wanted" ]] && return 0
  done
  echo "ERROR: missing required libtool shared object: ${wanted}" >&2
  echo "Directory contents of ${libdir}/.libs:" >&2
  find "${libdir}/.libs" -maxdepth 1 -mindepth 1 -printf '  %f\n' 2>/dev/null >&2 || true
  return 1
}

_ensure_stage_libs() {
  local stageroot="$1"
  _ensure_uninstalled_so "${stageroot}/libtextstyle/lib" libtextstyle
  _ensure_uninstalled_so "${stageroot}/gettext-tools/gnulib-lib" libgettextlib
  _ensure_uninstalled_so "${stageroot}/gettext-tools/src" libgettextsrc
}

_stage_configure() {
  local stageroot="$1"
  local extra_cflags="$2"
  local extra_cxxflags="$3"
  local extra_ldflags="$4"
  pushd "$stageroot" >/dev/null
  CFLAGS="${_base_cflags} ${extra_cflags}" \
  CXXFLAGS="${_base_cxxflags} ${extra_cxxflags}" \
  LDFLAGS="${_base_ldflags} ${extra_ldflags}" \
    ./configure \
      --prefix=/usr \
      --libexecdir=/usr/lib \
      --enable-csharp \
      --enable-nls \
      --enable-shared \
      --disable-static \
      --with-xz \
      --without-included-gettext \
      --without-included-libunistring
  popd >/dev/null
}

_stage_ordered_build() {
  local stageroot="$1"
  local ncpus
  ncpus="$(nproc)"

  # libtextstyle must be serial: generated gnulib headers have implicit deps
  echo "  [stage] building libtextstyle serially"
  _stage_make "$stageroot" "libtextstyle" 1
  _ensure_uninstalled_so "${stageroot}/libtextstyle/lib" libtextstyle

  # gettext-runtime is safe in parallel
  echo "  [stage] building gettext-runtime"
  _stage_make "$stageroot" "gettext-runtime" "$ncpus"

  # gettext-tools: serial.  libtool .la ordering is fragile under PGO+LTO
  echo "  [stage] building gettext-tools serially"
  _stage_make "$stageroot" "gettext-tools" 1
  _ensure_stage_libs "$stageroot"

  # Final serial pass
  echo "  [stage] top-level serial finalization"
  _stage_make "$stageroot" "." 1
  _ensure_stage_libs "$stageroot"
}

_stage_configure_build() {
  local stageroot="$1"
  local extra_cflags="$2"
  local extra_cxxflags="$3"
  local extra_ldflags="$4"
  _stage_configure "$stageroot" "$extra_cflags" "$extra_cxxflags" "$extra_ldflags"
  _stage_ordered_build "$stageroot"
}

# ── Tool discovery ───────────────────────────────────────────────────────────

_find_tool() {
  local stageroot="$1"
  local tool="$2"
  local cand
  for cand in \
    "${stageroot}/gettext-tools/src/${tool}" \
    "${stageroot}/gettext-tools/src/.libs/${tool}" \
    "${stageroot}/gettext-runtime/src/${tool}" \
    "${stageroot}/gettext-runtime/src/.libs/${tool}"
  do
    [[ -x "$cand" ]] && { printf '%s\n' "$cand"; return 0; }
  done
  return 1
}

# ── Enhanced training workload ───────────────────────────────────────────────
#
# Corpus operations: process up to 600 bundled PO files through every
# gettext tool in the pipeline.  This exercises the JSON parser
# (nlohmann::json), the PO/MO format parsers, charset conversion, and
# all the tool-specific logic paths that dominate gettext CPU profiles.

_run_corpus_ops() {
  local stageroot="$1"
  local msgfmt="$2" msgmerge="$3" msguniq="$4" msgattrib="$5" msgcat="$6"
  local msgcmp="$7" msgunfmt="$8" msgconv="$9" msggrep="${10}"
  local msgcomm="${11}" msgfilter="${12}" msgexec="${13}"
  local count=0 pofile tmp_po tmp_mo tmp_po2
  tmp_po="$(mktemp --suffix=.po)"
  tmp_po2="$(mktemp --suffix=.po)"
  tmp_mo="$(mktemp --suffix=.mo)"
  while IFS= read -r -d '' pofile; do
    "$msgfmt" -c -o /dev/null "$pofile" >/dev/null 2>&1 || true
    "$msgfmt" --statistics -o "$tmp_mo" "$pofile" >/dev/null 2>&1 || true
    [[ -n "$msgunfmt" ]] && "$msgunfmt" -o "$tmp_po" "$tmp_mo" >/dev/null 2>&1 || true
    [[ -n "$msgmerge" ]] && "$msgmerge" -q -o "$tmp_po" "$pofile" "$pofile" >/dev/null 2>&1 || true
    [[ -n "$msguniq" ]] && "$msguniq" -o "$tmp_po2" "$tmp_po" >/dev/null 2>&1 || true
    [[ -n "$msgattrib" ]] && "$msgattrib" --translated "$tmp_po" -o "$tmp_po2" >/dev/null 2>&1 || true
    [[ -n "$msgcat" ]] && "$msgcat" "$pofile" "$tmp_po" -o "$tmp_po2" >/dev/null 2>&1 || true
    [[ -n "$msgcmp" ]] && "$msgcmp" "$pofile" "$tmp_po2" >/dev/null 2>&1 || true
    [[ -n "$msgconv" ]] && "$msgconv" -t UTF-8 "$tmp_po" -o "$tmp_po2" >/dev/null 2>&1 || true
    [[ -n "$msggrep" ]] && "$msggrep" --msgid -e '.' "$tmp_po2" -o "$tmp_po" >/dev/null 2>&1 || true
    [[ -n "$msgcomm" ]] && "$msgcomm" "$pofile" "$tmp_po2" -o "$tmp_po" >/dev/null 2>&1 || true
    [[ -n "$msgfilter" ]] && "$msgfilter" -i "$tmp_po2" -o "$tmp_po" -- sed -e 's/foo/bar/g' >/dev/null 2>&1 || true
    [[ -n "$msgexec" ]] && "$msgexec" -i "$tmp_po2" -- /bin/true >/dev/null 2>&1 || true
    (( ++count >= 600 )) && break
  done < <(
    find \
      "${stageroot}/gettext-runtime/po" \
      "${stageroot}/gettext-tools/po" \
      "${stageroot}/gettext-tools/examples/po" \
      -type f -name '*.po' -print0 2>/dev/null
  )
  rm -f "$tmp_po" "$tmp_po2" "$tmp_mo"
}

# Full gettext tool workout: 50 iterations through xgettext (5 languages),
# msginit, msgmerge, msgcat, msguniq, msgattrib, msgfmt, msgunfmt, msgconv,
# msgen, msgcmp, msggrep, msgcomm, msgfilter (sed + awk), msgexec,
# gettext, ngettext, and envsubst.
#
# The 50-iteration loop ensures hot-path counters stabilise and the profile
# reaches deep into the PO parser, MO writer, and nlohmann::json internals
# that dominate real-world gettext workloads.

_run_tool_workload() {
  local stageroot="$1"
  local work="$2"
  local xgettext msginit msgmerge msgcat msguniq msgattrib msgfmt msgunfmt
  local msgconv msgen msgcmp msggrep msgcomm msgfilter msgexec envsubst_bin
  local gettext_bin ngettext_bin

  xgettext="$(_find_tool "$stageroot" xgettext 2>/dev/null)" || xgettext=""
  msginit="$(_find_tool "$stageroot" msginit 2>/dev/null)" || msginit=""
  msgmerge="$(_find_tool "$stageroot" msgmerge 2>/dev/null)" || msgmerge=""
  msgcat="$(_find_tool "$stageroot" msgcat 2>/dev/null)" || msgcat=""
  msguniq="$(_find_tool "$stageroot" msguniq 2>/dev/null)" || msguniq=""
  msgattrib="$(_find_tool "$stageroot" msgattrib 2>/dev/null)" || msgattrib=""
  msgfmt="$(_find_tool "$stageroot" msgfmt 2>/dev/null)" || msgfmt=""
  msgunfmt="$(_find_tool "$stageroot" msgunfmt 2>/dev/null)" || msgunfmt=""
  msgconv="$(_find_tool "$stageroot" msgconv 2>/dev/null)" || msgconv=""
  msgen="$(_find_tool "$stageroot" msgen 2>/dev/null)" || msgen=""
  msgcmp="$(_find_tool "$stageroot" msgcmp 2>/dev/null)" || msgcmp=""
  msggrep="$(_find_tool "$stageroot" msggrep 2>/dev/null)" || msggrep=""
  msgcomm="$(_find_tool "$stageroot" msgcomm 2>/dev/null)" || msgcomm=""
  msgfilter="$(_find_tool "$stageroot" msgfilter 2>/dev/null)" || msgfilter=""
  msgexec="$(_find_tool "$stageroot" msgexec 2>/dev/null)" || msgexec=""
  envsubst_bin="$(_find_tool "$stageroot" envsubst 2>/dev/null)" || envsubst_bin=""
  gettext_bin="$(_find_tool "$stageroot" gettext 2>/dev/null)" || gettext_bin=""
  ngettext_bin="$(_find_tool "$stageroot" ngettext 2>/dev/null)" || ngettext_bin=""

  [[ -n "$xgettext" && -n "$msgfmt" ]] || return 0

  mkdir -p "$work"

  # ── Diverse source samples (C, Python, Shell, Perl, Glade) ──

  cat > "${work}/sample.c" <<'CEOF'
#include <stdio.h>
#define _(x) (x)
int main(void) {
  puts(_("Hello world"));
  puts(_("File not found"));
  puts(_("Permission denied"));
  puts(_("Processing completed"));
  puts(_("Connection timed out"));
  puts(_("Invalid argument"));
  return 0;
}
CEOF

  cat > "${work}/sample.py" <<'PYEOF'
_ = lambda s: s
print(_("Hello from Python"))
print(_("Translated output"))
print(_("Network error"))
PYEOF

  cat > "${work}/sample.sh" <<'SHEOF'
#!/bin/sh
echo "$(gettext "Shell hello")"
echo "$(gettext "Shell world")"
echo "$(gettext "Operation successful")"
SHEOF
  chmod +x "${work}/sample.sh"

  cat > "${work}/sample.pl" <<'PLEOF'
use Locale::TextDomain ('sample');
print __"Perl hello\n";
print __x("Found {count} files", count => 42);
PLEOF

  cat > "${work}/sample.glade" <<'GLEOF'
<?xml version="1.0"?>
<interface>
  <object class="GtkLabel">
    <property name="label" translatable="yes">Application Name</property>
  </object>
</interface>
GLEOF

  local pot="${work}/messages.pot"
  local po="${work}/de.po"
  local outpo="${work}/merged.po"
  local mofile="${work}/messages.mo"
  local commpo="${work}/comm.po"
  local filtpo="${work}/filt.po"
  local saved_ldpath="${LD_LIBRARY_PATH:-}"
  export LD_LIBRARY_PATH="$(_stage_ldpath "$stageroot")${saved_ldpath:+:${saved_ldpath}}"

  local i
  for i in {1..50}; do
    # xgettext: 5 languages
    "$xgettext" -o "$pot" --language=C --keyword=_ "${work}/sample.c" >/dev/null 2>&1 || true
    "$xgettext" -j -o "$pot" --language=Python --keyword=_ "${work}/sample.py" >/dev/null 2>&1 || true
    "$xgettext" -j -o "$pot" --language=Shell --keyword=gettext "${work}/sample.sh" >/dev/null 2>&1 || true
    "$xgettext" -j -o "$pot" --language=Perl --keyword=__ "${work}/sample.pl" >/dev/null 2>&1 || true
    "$xgettext" -j -o "$pot" --language=Glade "${work}/sample.glade" >/dev/null 2>&1 || true

    # msginit
    [[ -n "$msginit" ]] && "$msginit" --no-translator --locale=de_DE.UTF-8 -i "$pot" -o "$po" >/dev/null 2>&1 || true
    [[ -f "$po" ]] || cp "$pot" "$po"

    # msgmerge
    [[ -n "$msgmerge" ]] && "$msgmerge" -q -o "$outpo" "$po" "$pot" >/dev/null 2>&1 || true
    [[ -f "$outpo" ]] || cp "$po" "$outpo"

    # msgcat
    [[ -n "$msgcat" ]] && "$msgcat" "$po" "$outpo" -o "$outpo" >/dev/null 2>&1 || true

    # msguniq
    [[ -n "$msguniq" ]] && "$msguniq" -o "$outpo" "$outpo" >/dev/null 2>&1 || true

    # msgattrib
    [[ -n "$msgattrib" ]] && "$msgattrib" --translated "$outpo" -o "$outpo" >/dev/null 2>&1 || true

    # msgfmt → MO
    "$msgfmt" -o "$mofile" "$outpo" >/dev/null 2>&1 || true

    # msgunfmt → PO
    [[ -n "$msgunfmt" ]] && "$msgunfmt" -o "$po" "$mofile" >/dev/null 2>&1 || true

    # msgconv: exercise encoding path
    [[ -n "$msgconv" ]] && "$msgconv" -t UTF-8 "$po" -o "$outpo" >/dev/null 2>&1 || true

    # msgen
    [[ -n "$msgen" ]] && "$msgen" "$po" -o "$outpo" >/dev/null 2>&1 || true

    # msgcmp
    [[ -n "$msgcmp" ]] && "$msgcmp" "$po" "$outpo" >/dev/null 2>&1 || true

    # msggrep
    [[ -n "$msggrep" ]] && "$msggrep" --msgid -e 'Hello' "$outpo" -o /dev/null >/dev/null 2>&1 || true

    # msgcomm
    [[ -n "$msgcomm" ]] && "$msgcomm" "$po" "$outpo" -o "$commpo" >/dev/null 2>&1 || true

    # msgfilter: sed (exercises subprocess)
    [[ -n "$msgfilter" ]] && "$msgfilter" -i "$outpo" -o "$filtpo" -- sed -e 's/Hello/Hallo/g' >/dev/null 2>&1 || true

    # msgfilter: awk
    [[ -n "$msgfilter" ]] && "$msgfilter" -i "$outpo" -o "$filtpo" -- awk '{print}' >/dev/null 2>&1 || true

    # msgexec
    [[ -n "$msgexec" && -f "$outpo" ]] && "$msgexec" -i "$outpo" -- /bin/true >/dev/null 2>&1 || true
  done

  # ── Runtime library testing ──────────────────────────────────

  if [[ -n "$gettext_bin" ]]; then
    local txt
    for txt in "hello" "world" "sample" "gettext runtime" "longer test string" \
               "special chars: äöü" "emoji: 🚀" "path: /usr/share/locale"; do
      "$gettext_bin" -- "$txt" >/dev/null 2>&1 || true
    done
  fi

  if [[ -n "$ngettext_bin" ]]; then
    "$ngettext_bin" -- "file" "files" 1 >/dev/null 2>&1 || true
    "$ngettext_bin" -- "file" "files" 2 >/dev/null 2>&1 || true
    "$ngettext_bin" -- "file" "files" 0 >/dev/null 2>&1 || true
    "$ngettext_bin" -- "file" "files" 100 >/dev/null 2>&1 || true
  fi

  if [[ -n "$envsubst_bin" ]]; then
    HOME=/tmp USER=pgo "$envsubst_bin" '$HOME $USER' <<< 'home=${HOME} user=${USER} path=${PATH}' >/dev/null 2>&1 || true
    HOME=/tmp "$envsubst_bin" '${HOME:-/fallback}' <<< '' >/dev/null 2>&1 || true
  fi

  # ── Corpus: 600 bundled PO files ─────────────────────────────

  _run_corpus_ops "$stageroot" \
    "$msgfmt" "$msgmerge" "$msguniq" "$msgattrib" "$msgcat" \
    "$msgcmp" "$msgunfmt" "$msgconv" "$msggrep" "$msgcomm" \
    "$msgfilter" "$msgexec"

  export LD_LIBRARY_PATH="$saved_ldpath"
}

# ── Training harness ─────────────────────────────────────────────────────────
#
# Runs the test suite (parallel + serial) and the tool workout (3 passes)
# against an instrumented stage tree.  GCC writes .gcda profile files
# automatically to the directory specified by -fprofile-generate.

_run_profile_training() {
  local stageroot="$1"
  local profdir="$2"
  local label="$3"
  local work="$4"

  mkdir -p "$profdir"

  local saved_ldpath="${LD_LIBRARY_PATH:-}"
  export LD_LIBRARY_PATH="$(_stage_ldpath "$stageroot")${saved_ldpath:+:${saved_ldpath}}"

  # Test suite: parallel + serial for coverage diversity
  echo "==> ${label}: test suite (parallel)"
  env MAKEFLAGS= make -C "$stageroot" -k check -j"$(nproc)" >/dev/null 2>&1 || true

  echo "==> ${label}: test suite (serial)"
  env MAKEFLAGS= make -C "$stageroot" -k check -j1 >/dev/null 2>&1 || true

  # Tool workout: 3 passes for profile stability
  local pass
  for pass in 1 2 3; do
    echo "==> ${label}: tool workout pass ${pass}/3"
    rm -rf "$work"
    mkdir -p "$work"
    _run_tool_workload "$stageroot" "$work"
  done
  rm -rf "$work"

  export LD_LIBRARY_PATH="$saved_ldpath"
}

# ── Build ────────────────────────────────────────────────────────────────────
#
# Three-stage iterative PGO with GCC:
#
#   Stage 1 — -fprofile-generate (instrumentation), train, collect .gcda
#   Stage 2 — -fprofile-use (stage-1 profile) + -fprofile-generate
#             (re-instrument with prior feedback = GCC's CS-PGO equivalent),
#             train, collect .gcda
#   Stage 3 — -fprofile-use (stage-2 profile), final optimized build
#
# -fprofile-prefix-path strips the stage-specific directory from .gcda
# paths so that profiles collected in one stage directory resolve cleanly
# when -fprofile-use reads them from a different stage directory.
#
# -fprofile-update=atomic  — thread-safe counters (critical for make -jN check)
# -fprofile-correction     — corrects multi-threaded counter skew
# -fprofile-partial-training — allows profile-use even when some TUs are cold

build() {
  _setup_gcc_toolchain

  local srcroot="${srcdir}/${pkgname}-${pkgver}"
  local stage_std="${srcdir}/stage-pgo-gen"
  local stage_cs="${srcdir}/stage-cspgo-gen"
  local stage_opt="${srcdir}/stage-opt"
  local pgo_dir="${srcdir}/pgo"
  local std_dir="${pgo_dir}/standard"
  local cs_dir="${pgo_dir}/cs"
  local work_std="${srcdir}/pgo-work-std"
  local work_cs="${srcdir}/pgo-work-cs"

  _base_cflags="${CFLAGS}"
  _base_cxxflags="${CXXFLAGS}"
  _base_ldflags="${LDFLAGS}"

  local pgo_upd="-fprofile-update=atomic"
  local pgo_corr="-fprofile-correction"
  local pgo_part="-fprofile-partial-training"
  local pgo_warn="-Wno-coverage-mismatch"

  rm -rf "$stage_std" "$stage_cs" "$stage_opt" "$pgo_dir" "$work_std" "$work_cs"
  mkdir -p "$std_dir" "$cs_dir"

  # ══════════════════════════════════════════════════════════════════
  echo "======================================================================"
  echo " Stage 1/3: GCC IR-PGO instrumented build"
  echo "======================================================================"

  _prepare_stage_tree "$srcroot" "$stage_std"

  # -fprofile-prefix-path strips the stage_std directory so .gcda paths
  # are relative to the source tree, not the specific staged copy
  local s1_flags="-fprofile-generate=${std_dir} -fprofile-prefix-path=${stage_std} ${pgo_upd}"

  _stage_configure_build "$stage_std" "$s1_flags" "$s1_flags" "$s1_flags"

  _run_profile_training "$stage_std" "$std_dir" "Stage-1" "$work_std"

  local n_gcda
  n_gcda="$(find "$std_dir" -name '*.gcda' -print -quit | wc -l)"
  (( n_gcda > 0 )) || {
    echo "ERROR: stage 1 produced no .gcda files in ${std_dir}" >&2
    return 1
  }
  echo "  Stage 1: $(find "$std_dir" -name '*.gcda' | wc -l) .gcda profile(s) collected"

  # ══════════════════════════════════════════════════════════════════
  echo "======================================================================"
  echo " Stage 2/3: GCC iterative (CS-PGO) instrumented build"
  echo "======================================================================"

  _prepare_stage_tree "$srcroot" "$stage_cs"

  # Use stage-1 profile to optimise, then re-instrument for finer-grained
  # stage-2 profiles.  This is GCC's equivalent of LLVM's CS-PGO.
  local s2_flags="-fprofile-use=${std_dir} -fprofile-prefix-path=${stage_cs} ${pgo_corr} ${pgo_part} \
-fprofile-generate=${cs_dir} -fprofile-prefix-path=${stage_cs} ${pgo_upd}"

  _stage_configure_build "$stage_cs" \
    "${s2_flags} ${pgo_warn}" \
    "${s2_flags} ${pgo_warn}" \
    "${s2_flags}"

  _run_profile_training "$stage_cs" "$cs_dir" "Stage-2" "$work_cs"

  n_gcda="$(find "$cs_dir" -name '*.gcda' -print -quit | wc -l)"
  (( n_gcda > 0 )) || {
    echo "ERROR: stage 2 produced no .gcda files in ${cs_dir}" >&2
    return 1
  }
  echo "  Stage 2: $(find "$cs_dir" -name '*.gcda' | wc -l) .gcda profile(s) collected"

  # ══════════════════════════════════════════════════════════════════
  echo "======================================================================"
  echo " Stage 3/3: Final PGO-optimized build"
  echo "======================================================================"

  _prepare_stage_tree "$srcroot" "$stage_opt"

  local s3_flags="-fprofile-use=${cs_dir} -fprofile-prefix-path=${stage_opt} ${pgo_corr} ${pgo_part}"

  _stage_configure_build "$stage_opt" \
    "${s3_flags} ${pgo_warn}" \
    "${s3_flags} ${pgo_warn}" \
    "${s3_flags}"

  # Clean up instrumented stages and profiles — keep stage_opt for check/package
  rm -rf "$stage_std" "$stage_cs" "$pgo_dir"
}

# ── Check ────────────────────────────────────────────────────────────────────

check() {
  local saved_ldpath="${LD_LIBRARY_PATH:-}"
  export LD_LIBRARY_PATH="$(_stage_ldpath "${srcdir}/stage-opt")${saved_ldpath:+:${saved_ldpath}}"
  env MAKEFLAGS= make -C "${srcdir}/stage-opt" check
  export LD_LIBRARY_PATH="$saved_ldpath"
}

# ── Package ──────────────────────────────────────────────────────────────────

package() {
  local saved_ldpath="${LD_LIBRARY_PATH:-}"
  export LD_LIBRARY_PATH="$(_stage_ldpath "${srcdir}/stage-opt")${saved_ldpath:+:${saved_ldpath}}"
  env MAKEFLAGS= make -C "${srcdir}/stage-opt" DESTDIR="$pkgdir" install
  export LD_LIBRARY_PATH="$saved_ldpath"
  find "$pkgdir" -name '*.la' -delete
}

