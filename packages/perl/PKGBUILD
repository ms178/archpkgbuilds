_prepare_perl_env() {
  unset PERL5LIB
  unset PERLLIB
  unset PERL5OPT
  unset PERL_LOCAL_LIB_ROOT
  unset PERL_MB_OPT
  unset PERL_MM_OPT

  export TZ=UTC
  export CC=clang
  export LD=clang
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib
}

_copy_tree() {
  local _src=$1
  local _dst=$2

  rm -rf -- "${_dst}"
  cp -a --reflink=auto "${_src}" "${_dst}"
}

_configure_perl() {
  local _builddir=$1
  local _cflags=$2
  local _ldflags=$3

  cd "${_builddir}"

  cp -f "${srcdir}/config.over" .
  cp -f "${srcdir}/db_config.in" ./cpan/DB_File/config.in

  ./Configure -des \
    -Dcc="${CC}" \
    -Dld="${LD}" \
    -Dprefix=/usr \
    -Dvendorprefix=/usr \
    -Dprivlib=/usr/share/perl5/core_perl \
    -Darchlib=/usr/lib/perl5/${_baseversion}/core_perl \
    -Dsitelib=/usr/share/perl5/site_perl \
    -Dsitearch=/usr/lib/perl5/${_baseversion}/site_perl \
    -Dvendorlib=/usr/share/perl5/vendor_perl \
    -Dvendorarch=/usr/lib/perl5/${_baseversion}/vendor_perl \
    -Dscriptdir=/usr/bin/core_perl \
    -Dsitescript=/usr/bin/site_perl \
    -Dvendorscript=/usr/bin/vendor_perl \
    -Dinc_version_list=none \
    -Dman1ext=1perl \
    -Dman3ext=3perl \
    -Dcccdlflags='-fPIC' \
    -Doptimize="${_cflags}" \
    -Dlddlflags="-shared ${_ldflags}" \
    -Dldflags="${_ldflags}" \
    -Dloclibpth="/usr/lib/db5.3" \
    -Dlocincpth="/usr/include/db5.3" \
    -Dusethreads \
    -Duseshrplib
}

prepare() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  # Reproducible patchlevel date
  if [[ -n "${SOURCE_DATE_EPOCH:-}" ]]; then
    touch -h -d "@${SOURCE_DATE_EPOCH}" patchlevel.h
  fi

  patch -Np1 -i "${srcdir}/clearlinux.patch"
}

build() {
  local _src="${srcdir}/${pkgname}-${pkgver}"
  local _pgobuild="${srcdir}/${pkgname}-${pkgver}-pgo"
  local _finalbuild="${srcdir}/${pkgname}-${pkgver}-final"
  local _profiledir="${srcdir}/${pkgname}-${pkgver}-pgodata"
  local _profiledata="${_profiledir}/merged.profdata"
  local _jobs
  local _llvm_profdata
  local -a _profraws

  _jobs="$(nproc)"

  _prepare_perl_env
  _llvm_profdata="$(${CC} --print-prog-name=llvm-profdata)"

  # Clean all previous build/profile artifacts so old sessions cannot pollute PGO.
  rm -rf -- "${_pgobuild}" "${_finalbuild}" "${_profiledir}"
  mkdir -p -- "${_profiledir}"

  _copy_tree "${_src}" "${_pgobuild}"
  _copy_tree "${_src}" "${_finalbuild}"

  local _common_cflags="${CPPFLAGS} ${CFLAGS/-O2/-O3} -fno-semantic-interposition"
  local _common_ldflags="${LDFLAGS} -fuse-ld=lld"

  # Extra value profile counters are only needed for the instrumented build.
  # This avoids "Running out of static counters" warnings without affecting
  # final package size/performance.
  local _pgo_gen_cflags="${_common_cflags} -fprofile-generate=${_profiledir} -mllvm -vp-counters-per-site=16"
  local _pgo_gen_ldflags="${_common_ldflags} -fprofile-generate=${_profiledir}"

  echo ">>> PGO Stage 1: instrumented build"
  _configure_perl "${_pgobuild}" "${_pgo_gen_cflags}" "${_pgo_gen_ldflags}"
  make -C "${_pgobuild}" -j"${_jobs}"

  echo ">>> PGO Stage 2: training run"
  (
    cd "${_pgobuild}"

    # Force the benchmark/training run to use the just-built tree and not the
    # host system Perl installation.
    unset PERL5OPT
    unset PERL_LOCAL_LIB_ROOT
    unset PERL_MB_OPT
    unset PERL_MM_OPT
    export PERL5LIB="${_pgobuild}/lib"
    export PERLLIB="${_pgobuild}/lib"
    export LLVM_PROFILE_FILE="${_profiledir}/perl-%p-%m.profraw"

    # Keep this serialized for reliability and cleaner profiles.
    make test_pgo
  )

  echo ">>> PGO Stage 3: merging profile data"
  shopt -s nullglob
  _profraws=("${_profiledir}"/*.profraw)
  shopt -u nullglob

  if (( ${#_profraws[@]} == 0 )); then
    echo "ERROR: no .profraw files were generated during PGO training." >&2
    return 1
  fi

  "${_llvm_profdata}" merge \
    --failure-mode=all \
    -output="${_profiledata}" \
    "${_profraws[@]}"

  echo ">>> PGO Stage 4: final optimized build"
  local _pgo_use_cflags="${_common_cflags} -fprofile-use=${_profiledata}"

  _configure_perl "${_finalbuild}" "${_pgo_use_cflags}" "${_common_ldflags}"
  make -C "${_finalbuild}" -j"${_jobs}"
}

check() {
  local _finalbuild="${srcdir}/${pkgname}-${pkgver}-final"
  local _jobs

  _jobs="$(nproc)"
  (( _jobs > 16 )) && _jobs=16

  _prepare_perl_env

  cd "${_finalbuild}"
  export PERL5LIB="${_finalbuild}/lib"
  export PERLLIB="${_finalbuild}/lib"

  make test_harness TEST_JOBS="${_jobs}"
}

package() {
  local _finalbuild="${srcdir}/${pkgname}-${pkgver}-final"

  cd "${_finalbuild}"
  make DESTDIR="${pkgdir}" install

  # Perl settings
  sed -e '/^man1ext=/ s/1perl/1p/' \
      -e '/^man3ext=/ s/3perl/3pm/' \
      -e "/^cf_email=/ s/'.*'/''/" \
      -e "/^perladmin=/ s/'.*'/''/" \
      -i "${pkgdir}/usr/lib/perl5/${_baseversion}/core_perl/Config_heavy.pl"

  # CPAN defaults: install to site dirs
  sed -e '/(makepl_arg =>/   s/""/"INSTALLDIRS=site"/' \
      -e '/(mbuildpl_arg =>/ s/""/"installdirs=site"/' \
      -i "${pkgdir}/usr/share/perl5/core_perl/CPAN/FirstTime.pm"

  install -Dm644 "${srcdir}/perlbin.sh" \
    "${pkgdir}/etc/profile.d/perlbin.sh"
  install -Dm644 "${srcdir}/perlbin.csh" \
    "${pkgdir}/etc/profile.d/perlbin.csh"
  install -Dm755 "${srcdir}/perlbin.fish" \
    "${pkgdir}/usr/share/fish/vendor_conf.d/perlbin.fish"

  # Ensure these are present in PATH immediately after first module installs
  install -d -m755 "${pkgdir}/usr/bin/vendor_perl"
  install -d -m755 "${pkgdir}/usr/bin/site_perl"

  rm -f "${pkgdir}/usr/bin/perl${pkgver}"

  install -Dm755 "${srcdir}/detect-old-perl-modules.sh" \
    "${pkgdir}/usr/share/libalpm/scripts/detect-old-perl-modules.sh"
  install -Dm644 "${srcdir}/detect-old-perl-modules.hook" \
    "${pkgdir}/usr/share/libalpm/hooks/detect-old-perl-modules.hook"

  find "${pkgdir}" -name perllocal.pod -delete
  find "${pkgdir}" -name .packlist -delete
}
