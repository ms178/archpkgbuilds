package_pango-git() {
  provides=(pango libpango-1.0.so=0-64 libpango{,cairo,ft2,xft}-1.0.so)
  conflicts=(pango)

  meson install -C build-opt --destdir "$pkgdir"

  # mkdir -p doc/usr/share
  # mv {"$pkgdir",doc}/usr/share/doc
}
