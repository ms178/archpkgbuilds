+template <typename T>
+[[nodiscard]] inline constexpr bool vk_has_value(const T &res) noexcept {
+    if constexpr (requires { res.has_value(); }) {
+        return res.has_value();
+    } else if constexpr (requires { res.result; }) {
+        return res.result == vk::Result::eSuccess;
+    } else {
+        return true;
+    }
+}
