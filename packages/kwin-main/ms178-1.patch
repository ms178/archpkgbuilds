+// Absolute-time sleep on CLOCK_MONOTONIC with EINTR handling. This is the
+// lowest-jitter way to wake up just before the target pageflip time.
+// [PERF] Cached steady→MONOTONIC offset for the commit thread.
+// On Linux, steady_clock and CLOCK_MONOTONIC share the same underlying
+// clock source (ktime_get_ts64), so their offset is constant for the
+// lifetime of the process.  Computing it once and caching eliminates
+// two vDSO calls per frame (~20-40 ns of jitter per wake-up).
+// The offset is validated on first use and re-verified every 1024 calls
+// as a defensive measure against unexpected clock adjustments.
+struct CommitThreadClockOffset {
+    int64_t offsetNs = 0;
+    bool initialized = false;
+    uint32_t callCount = 0;
+
+    int64_t get() noexcept
+    {
+        // Re-validate every 1024 calls (~16 seconds at 60 Hz, ~6s at 165 Hz).
+        if (!initialized || (callCount & 0x3FF) == 0) [[unlikely]] {
+            timespec monoTs{};
+            if (clock_gettime(CLOCK_MONOTONIC, &monoTs) == 0) {
+                const auto steadyNow = std::chrono::steady_clock::now();
+                const int64_t monoNs = static_cast<int64_t>(monoTs.tv_sec) * 1000000000LL + monoTs.tv_nsec;
+                const int64_t steadyNs = std::chrono::duration_cast<std::chrono::nanoseconds>(
+                    steadyNow.time_since_epoch()).count();
+                offsetNs = steadyNs - monoNs;
+                initialized = true;
+            }
+        }
+        ++callCount;
+        return offsetNs;
+    }
+};
+
+inline void preciseSleepUntil(const std::chrono::steady_clock::time_point &target) noexcept
+{
+    const auto now = std::chrono::steady_clock::now();
+    if (target <= now) {
+        return;
+    }
+
+    // [PERF] Use cached clock offset instead of computing it every call.
+    // The offset is constant on Linux (steady_clock == CLOCK_MONOTONIC epoch).
+    static thread_local CommitThreadClockOffset s_offset;
+    const int64_t offsetNs = s_offset.get();
+
+    const int64_t targetNs = target.time_since_epoch().count();
+    const int64_t monoTargetNs = targetNs - offsetNs;
+
+    timespec monoNowTs{};
+    if (clock_gettime(CLOCK_MONOTONIC, &monoNowTs) != 0) [[unlikely]] {
+        // Fallback to relative sleep.
+        const auto dur = target - now;
+        const auto ns = std::chrono::duration_cast<std::chrono::nanoseconds>(dur).count();
+        if (ns > 0) {
+            timespec ts{ .tv_sec = ns / 1000000000LL, .tv_nsec = ns % 1000000000LL };
+            clock_nanosleep(CLOCK_MONOTONIC, 0, &ts, nullptr);
+        }
+        return;
+    }
+    const int64_t monoNowNs = static_cast<int64_t>(monoNowTs.tv_sec) * 1000000000LL + monoNowTs.tv_nsec;
+    if (monoTargetNs <= monoNowNs) {
+        return;
+    }
+
+    timespec ts;
+    ts.tv_sec = static_cast<time_t>(monoTargetNs / 1000000000LL);
+    ts.tv_nsec = static_cast<long>(monoTargetNs % 1000000000LL);
+
+    int ret;
+    do {
+        ret = clock_nanosleep(CLOCK_MONOTONIC, TIMER_ABSTIME, &ts, nullptr);
+    } while (ret == EINTR);
+}
+
+[[nodiscard]] inline std::chrono::nanoseconds clampNs(std::chrono::nanoseconds val,
+                                                      std::chrono::nanoseconds lo,
+                                                      std::chrono::nanoseconds hi) noexcept
+{
+    if (val < lo) {
+        return lo;
+    }
+    if (val > hi) {
+        return hi;
+    }
+    return val;
+}
+
+[[nodiscard]] inline bool isFramelessSinglePlaneCommit(const DrmAtomicCommit *commit) noexcept
+{
+    return commit
+        && !commit->targetPageflipTime().has_value()
+        && commit->modifiedPlanes().size() == 1;
+}
+
+[[nodiscard]] inline bool touchesSamePlane(const DrmAtomicCommit *left, const DrmAtomicCommit *right) noexcept
+{
+    if (!isFramelessSinglePlaneCommit(left) || !isFramelessSinglePlaneCommit(right)) {
+        return false;
+    }
+    DrmPlane *const plane = *left->modifiedPlanes().begin();
+    return right->modifiedPlanes().contains(plane);
+}
