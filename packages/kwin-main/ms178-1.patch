+    } else {
+        return res;
+    }
+}
+
+template <typename T>
+[[nodiscard]] inline constexpr vk::Result vk_get_error(const T &res) noexcept {
+    if constexpr (requires { res.error(); }) {
+        return res.error();
+    } else if constexpr (requires { res.result; }) {
