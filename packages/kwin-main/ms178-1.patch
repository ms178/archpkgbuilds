+template <typename T>
+[[nodiscard]] inline constexpr auto &vk_get_value(T &res) noexcept {
+    if constexpr (requires { res.value(); }) {
+        return res.value();
+    } else if constexpr (requires { res.value; }) {
+        return res.value;
+    } else {
+        return res;
+    }
