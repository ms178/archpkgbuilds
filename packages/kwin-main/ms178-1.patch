diff --git a/src/wayland/committiming_v1.cpp b/src/wayland/committiming_v1.cpp
new file mode 100644
index 0000000..ac8b10e
--- /dev/null
+++ b/src/wayland/committiming_v1.cpp
@@ -0,0 +1,125 @@
+/*
+    SPDX-FileCopyrightText: 2026 Vlad Zahorodnii <vlad.zahorodnii@kde.org>
+
+    SPDX-License-Identifier: LGPL-2.1-only OR LGPL-3.0-only OR LicenseRef-KDE-Accepted-LGPL
+*/
+#include "committiming_v1.h"
+
+#include "display.h"
+#include "surface_p.h"
+
+#include <chrono>
+#include <cstdint>
+#include <limits>
+#include <optional>
+
+namespace KWin
+{
+namespace
+{
+
+constexpr uint32_t s_version = 1;
+constexpr uint64_t s_nsecPerSec = 1'000'000'000;
+constexpr uint64_t s_maxTimestampNs = static_cast<uint64_t>(std::numeric_limits<int64_t>::max());
+constexpr uint64_t s_maxTimestampSec = s_maxTimestampNs / s_nsecPerSec;
+constexpr uint64_t s_maxTimestampSubSecNs = s_maxTimestampNs % s_nsecPerSec;
+
+[[nodiscard]] inline std::optional<std::chrono::nanoseconds> timestampFromParts(uint32_t tvSecHi, uint32_t tvSecLo, uint32_t tvNsec) noexcept
+{
+    if (tvNsec >= s_nsecPerSec) [[unlikely]] {
+        return std::nullopt;
+    }
+    const uint64_t tvSec = (uint64_t{tvSecHi} << 32) | uint64_t{tvSecLo};
+    if (tvSec > s_maxTimestampSec || (tvSec == s_maxTimestampSec && tvNsec > s_maxTimestampSubSecNs)) [[unlikely]] {
+        return std::nullopt;
+    }
+
+    return std::chrono::nanoseconds{static_cast<int64_t>(tvSec * s_nsecPerSec + tvNsec)};
+}
+
+} // namespace
+
+CommitTimingManagerV1::CommitTimingManagerV1(Display *display, QObject *parent)
+    : QObject(parent)
+    , QtWaylandServer::wp_commit_timing_manager_v1(*display, s_version)
+{
+}
+
+void CommitTimingManagerV1::wp_commit_timing_manager_v1_destroy(Resource *resource)
+{
+    wl_resource_destroy(resource->handle);
+}
+
+void CommitTimingManagerV1::wp_commit_timing_manager_v1_get_timer(Resource *resource, uint32_t id, struct ::wl_resource *wlSurface)
+{
+    SurfaceInterface *const surface = SurfaceInterface::get(wlSurface);
+    if (!surface) [[unlikely]] {
+        // SurfaceInterface::get() returns nullptr if the wl_surface has already
+        // been destroyed but its resource is still being torn down. Guard the
+        // dereference instead of crashing the whole compositor: the client is
+        // misbehaving, so terminate just this request.
+        wl_resource_post_error(resource->handle, WL_DISPLAY_ERROR_INVALID_OBJECT, "get_timer called with an invalid wl_surface");
+        return;
+    }
+
+    SurfaceInterfacePrivate *const surfacePrivate = SurfaceInterfacePrivate::get(surface);
+    if (surfacePrivate->commitTimer) [[unlikely]] {
+        wl_resource_post_error(resource->handle, error_commit_timer_exists, "Attempted to create a second commit timer for the wl_surface");
+        return;
+    }
+
+    surfacePrivate->commitTimer = new CommitTimerV1(resource->client(), id, resource->version(), surface);
+}
+
+CommitTimerV1::CommitTimerV1(wl_client *client, uint32_t id, uint32_t version, SurfaceInterface *surface)
+    : QtWaylandServer::wp_commit_timer_v1(client, id, version)
+    , m_surface(surface)
+{
+}
+
+CommitTimerV1::~CommitTimerV1()
+{
+    if (m_surface) {
+        SurfaceInterfacePrivate::get(m_surface)->commitTimer = nullptr;
+    }
+}
+
+void CommitTimerV1::notifySurfaceDestroyed() noexcept
+{
+    m_surface = nullptr;
+}
+
+void CommitTimerV1::wp_commit_timer_v1_destroy_resource(Resource *)
+{
+    delete this;
+}
+
+void CommitTimerV1::wp_commit_timer_v1_destroy(Resource *resource)
+{
+    wl_resource_destroy(resource->handle);
+}
+
+void CommitTimerV1::wp_commit_timer_v1_set_timestamp(Resource *resource, uint32_t tvSecHi, uint32_t tvSecLo, uint32_t tvNsec)
+{
+    if (!m_surface) [[unlikely]] {
+        wl_resource_post_error(resource->handle, error_surface_destroyed, "called set_timestamp on a destroyed surface");
+        return;
+    }
+    const auto timestamp = timestampFromParts(tvSecHi, tvSecLo, tvNsec);
+    if (!timestamp) [[unlikely]] {
+        wl_resource_post_error(resource->handle,
+                               error_invalid_timestamp,
+                               tvNsec >= s_nsecPerSec ? "invalid timestamp nanoseconds value" : "timestamp is outside the supported range");
+        return;
+    }
+
+    SurfaceInterfacePrivate *const surfacePrivate = SurfaceInterfacePrivate::get(m_surface);
+    if (surfacePrivate->pending->targetPresentationTime.has_value()) [[unlikely]] {
+        wl_resource_post_error(resource->handle, error_timestamp_exists, "timestamp already exists for the pending commit");
+        return;
+    }
+
+    surfacePrivate->pending->targetPresentationTime = *timestamp;
+}
+
+} // namespace KWin
