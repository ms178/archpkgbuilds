+                continue;
+            }
+            auto notifier = std::make_unique<QSocketNotifier>(fd.get(), QSocketNotifier::Read, this);
+            QObject::connect(notifier.get(), &QSocketNotifier::activated, notifier.get(), [this, notifier = notifier.get()]() {
+                notifier->setEnabled(false);
+                if (m_pendingCount > 0) {
