+    std::shared_ptr<SyncTimeline> m_timeline;
+    uint64_t m_timelinePoint = 0;
+    std::vector<FileDescriptor> m_fences;
+    std::vector<std::unique_ptr<QSocketNotifier>> m_notifiers;
+    size_t m_pendingCount = 0;
