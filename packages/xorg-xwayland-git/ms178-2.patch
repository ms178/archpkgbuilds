+    /* Since libxcvt 0.1.3 (division-by-zero / overflow hardening,
+     * commit 23c30d4 et al.) libxcvt_gen_mode_info() returns NULL for invalid
+     * geometry (hdisplay/vdisplay <= 0) instead of computing a garbage mode as
+     * older versions did. It also returns NULL on allocation failure. Xwayland
+     * used to dereference the result unconditionally, which caused a hard
+     * SIGSEGV at address 0x10 (offsetof ->dot_clock). Bail out cleanly and let
+     * the caller decide instead of crashing the whole server. */
+    if (!libxcvt_mode_info)
+        return FALSE;
