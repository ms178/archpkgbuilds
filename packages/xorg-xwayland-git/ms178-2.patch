     char name[128];
     xRRModeInfo modeinfo = { 0, };
 
-    xwayland_modeinfo_from_cvt(&modeinfo,
-                               hdisplay, vdisplay, vrefresh, reduced, interlaced);
+    if (!xwayland_modeinfo_from_cvt(&modeinfo,
+                                    hdisplay, vdisplay, vrefresh,
+                                    reduced, interlaced))
+        return NULL;
 
