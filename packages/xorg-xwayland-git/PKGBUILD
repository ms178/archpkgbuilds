# Maintainer: CachyOS <admin@cachyos.org>

pkgname=xorg-xwayland-git
pkgver=24.1.12.r0.gaf4b3d72
pkgrel=1
pkgdesc='Run X clients under Wayland (PGO + CS-PGO + BOLT, gaming-tuned)'
arch=('x86_64')
url='https://xorg.freedesktop.org'
license=('MIT')
groups=('xorg')
# !lto: makepkg.conf owns LTO via $CFLAGS; meson b_lto=false below keeps it deterministic.
# !debug: no -g3 spam in shipped binary (PGO accuracy independent of DWARF).
# strip ON: BOLTed binary safe to strip on modern binutils (verified by user).
options=(!lto !debug)
depends=(
  glibc libxau libxcvt libxfont2 libxshmfence libdrm libepoxy libglvnd libei
  libtirpc mesa nettle pixman systemd-libs wayland xkeyboard-config
  xorg-server-common xorg-xkbcomp
)
makedepends=(
  git meson ninja clang llvm xorgproto xtrans libxkbfile dbus xorg-font-util
  wayland-protocols systemd weston mesa-utils glmark2 vulkan-tools
  xorg-x11perf xorg-xrandr xorg-xprop xorg-xdpyinfo xclip xdotool
  # trainer build-time only (linked, but the trainer itself is not shipped):
  libx11 libxcb libxi libxext
)
provides=(xorg-xwayland xorg-server-xwayland xorg-server-xwayland-git)
conflicts=(xorg-xwayland xorg-server-xwayland xorg-server-xwayland-git)
replaces=(xorg-server-xwayland-git)
source=(
  'xserver::git+https://gitlab.freedesktop.org/xorg/xserver.git#branch=xwayland-24.1'
  'ms178-1.patch'
)
sha256sums=('SKIP' 'SKIP')

# Per-stage instrumentation flags. These are the ONLY flags this PKGBUILD adds
# on top of /etc/makepkg.conf. Lessons from libx11 v2->v3 baked in:
#   * no -g3                : zero PGO accuracy gain, +80% object size
#   * no -fno-omit-fp       : mismatch with final build = silently worse PGO
#   * vp-counters-per-site=8: upstream default (Xwayland has <50 hot IC sites)
#   * -runtime-counter-relocation: required when counter section is relocated
_pgo_mllvm=(
  -mllvm -vp-counters-per-site=8
  -mllvm -runtime-counter-relocation
  -mllvm -enable-value-profiling
)

# Xwayland is shipped PIE by upstream. BOLT can re-layout PIE, but a no-PIE
# binary gives BOLT maximum freedom (no GOT indirection on internal calls,
# RIP-relative -> direct call promotion is easier). User accepts the loss
# of ASLR on Xwayland (long-running server, ASLR remap-on-fork doesn't apply).
_anti_pie_cflags=(-fno-pie)
_anti_pie_ldflags=(-no-pie)

_profile_silence=(
  -Wno-profile-instr-unprofiled
  -Wno-profile-instr-out-of-date
)

_prefix_map_flags=(
  "-ffile-prefix-map=${srcdir}/xserver=/usr/src/debug/${pkgname}"
  "-ffile-prefix-map=${srcdir}=/usr/src/debug/${pkgname}"
)

pkgver() {
  cd xserver
  git describe --long --tags --abbrev=8 | sed 's/^xwayland-//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd xserver
  local src
  for src in "${source[@]}"; do
    src="${src%%::*}"
    src="${src##*/}"
    [[ $src = *.patch ]] || continue
    [[ -f "$srcdir/$src" ]] || { echo "Patch $src missing, skipping"; continue; }
    echo "Applying $src"
    patch -Np1 -i "$srcdir/$src"
  done
}

# -------- helpers --------------------------------------------------------- #

_split_flags() {
  local -n _out="$2"
  _out=()
  [[ -n "${!1:-}" ]] && read -r -a _out <<< "${!1}"
}

# meson '[built-in options]' wants quoted-comma-separated tokens. Build that
# without printf %q which would mangle UTF-8.
_meson_array() {
  local arg first=1
  for arg in "$@"; do
    arg=${arg//\\/\\\\}
    arg=${arg//\'/\\\'}
    (( first )) || printf ', '
    printf "'%s'" "$arg"
    first=0
  done
}

_emit_meson_native() {
  local out="$1"
  local -n _cf="$2" _cxf="$3" _lf="$4"
  cat > "$out" <<EOF
[built-in options]
c_args      = [$(_meson_array "${_cf[@]}")]
cpp_args    = [$(_meson_array "${_cxf[@]}")]
c_link_args = [$(_meson_array "${_lf[@]}")]
cpp_link_args = [$(_meson_array "${_lf[@]}")]

[binaries]
c      = 'clang'
cpp    = 'clang++'
ar     = 'llvm-ar'
nm     = 'llvm-nm'
ranlib = 'llvm-ranlib'
strip  = 'llvm-strip'
EOF
}

# Always strip CFLAGS/CXXFLAGS/CPPFLAGS/LDFLAGS from the environment before
# invoking meson — otherwise meson silently appends them to the args we set
# via --native-file, double-applying everything.
_meson() { env -u CFLAGS -u CXXFLAGS -u CPPFLAGS -u LDFLAGS "$@"; }

_compile_xwayland() {
  _meson meson compile -C "$1" hw/xwayland/Xwayland
}

_have_host_wayland() {
  [[ "${XW_PGO_FORCE_NESTED:-0}" == 1 ]] && return 1
  [[ -n "${XDG_RUNTIME_DIR:-}" ]] || return 1
  [[ -n "${WAYLAND_DISPLAY:-}" ]] || return 1
  [[ -S "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}" ]]
}

# Should training reuse the user's compositor (KWin/Mutter/etc.)?
#
# DEFAULT: NO. Reusing the host compositor means every workload window
# (glxgears -fullscreen, glmark2, vkcube, the trainer's own Xlib windows)
# pops up on the user's interactive desktop and stays there for the duration
# of a 3-stage PGO+CSPGO+BOLT chain. That's ~5 minutes of unsolicited
# fullscreen-gears taking over the screen.
#
# Instead we always spawn a private headless weston with hardware-accelerated
# GL (radeonsi via EGL on AMD) so:
#   1. The user's session is undisturbed (zero visible windows).
#   2. The training compositor uses the GPU you actually care about
#      (radeonsi/RADV via the AMD pin env), so the codegen path PGO
#      counters reflect matches what real games will hit at runtime.
#
# Opt-in to host reuse with XW_PGO_USE_HOST_COMPOSITOR=1 (only useful when
# you want training to happen against a specific desktop's compositor
# protocols, e.g. you're profiling KWin's xdg-decoration interaction
# specifically).
_xw_should_use_host_wayland() {
  [[ "${XW_PGO_USE_HOST_COMPOSITOR:-0}" == 1 ]] || return 1
  _have_host_wayland
}

# ----- AMD GPU (radeonsi + RADV) targeting -------------------------------- #
# On AMD hosts (sysfs vendor 0x1002, or XW_PGO_AMD_PROFILE=1) we pin the GL
# and Vulkan ICDs to radeonsi/RADV so PGO/BOLT counters reflect the codegen
# paths Xwayland's glamor+present+dri3 actually take at runtime. Silent
# software fallback during training would poison the profile.
# Knobs (all opt-in; auto-detect is the default):
#   XW_PGO_AMD_PROFILE=1        force AMD targeting + REQUIRE_HW=1
#   XW_PGO_AMD_PROFILE=0        disable AMD auto-detect entirely
#   XW_PGO_REQUIRE_HW_TARGETS=1 hard-fail if probe doesn't show AMD
#   XW_PGO_FORCE_RADEONSI=1     pin MESA_LOADER_DRIVER_OVERRIDE=radeonsi
#   XW_PGO_FORCE_RADV=1         pin VK_DRIVER_FILES to RADV ICD only
#   XW_PGO_VK_DRIVER_SELECT=    filter ICDs by filename substring (e.g. radv);
#                                 bare token is auto-wrapped to '*radv*';
#                                 IGNORED when XW_PGO_FORCE_RADV pins a single
#                                 ICD via VK_DRIVER_FILES (redundant + conflicts).
#   XW_PGO_DRI_PRIME=1          for hybrid GPU rigs
#   XW_PGO_EXPECT_GL_DRIVER=    expected GL substring (default radeonsi)
#   XW_PGO_EXPECT_VK_DRIVER=    expected VK substring (default radv)
#   XW_PGO_AMDVLK_OVERRIDE=1    use AMDVLK in place of RADV (not recommended)

_xw_amd_detected=""
_xw_have_amd_gpu() {
  [[ -n "$_xw_amd_detected" ]] && { [[ "$_xw_amd_detected" == 1 ]]; return $?; }
  local v
  shopt -s nullglob
  for v in /sys/class/drm/card*/device/vendor; do
    [[ -r "$v" ]] || continue
    if [[ "$(<"$v")" == "0x1002" ]]; then
      _xw_amd_detected=1; shopt -u nullglob; return 0
    fi
  done
  shopt -u nullglob
  _xw_amd_detected=0
  return 1
}

_xw_amd_active() {
  case "${XW_PGO_AMD_PROFILE:-auto}" in
    1|true|yes|on)   return 0 ;;
    0|false|no|off)  return 1 ;;
    *)               _xw_have_amd_gpu ;;
  esac
}

_xw_find_radv_icd() {
  local p
  shopt -s nullglob
  for p in \
      /usr/share/vulkan/icd.d/radeon_icd.x86_64.json \
      /usr/share/vulkan/icd.d/radeon_icd.json \
      /usr/share/vulkan/icd.d/radeon_icd*.json \
      /etc/vulkan/icd.d/radeon_icd*.json
  do
    [[ -r "$p" ]] || continue
    printf '%s\n' "$p"; shopt -u nullglob; return 0
  done
  shopt -u nullglob; return 1
}

_xw_find_amdvlk_icd() {
  local p
  shopt -s nullglob
  for p in \
      /usr/share/vulkan/icd.d/amd_icd64.json \
      /usr/share/vulkan/icd.d/amd_pro_icd64.json \
      /etc/vulkan/icd.d/amd_icd64.json \
      /etc/vulkan/icd.d/amd_pro_icd64.json
  do
    [[ -r "$p" ]] || continue
    printf '%s\n' "$p"; shopt -u nullglob; return 0
  done
  shopt -u nullglob; return 1
}

# Populate a name-ref array with VAR=VAL env entries; caller passes to `env`.
#
# IMPORTANT: VK_LOADER_DRIVERS_SELECT matches against the ICD manifest's
# *filename* using glob globs ("*sub*", "pre*", "*suf", or exact whole name)
# per Vulkan-Loader/docs/LoaderInterfaceArchitecture.md ("Filter Environment
# Variable Behaviors" → "Globs"). Bare 'radv' is treated as an EXACT filename
# match and rejects every ICD (radeon_icd.x86_64.json, radeon_icd.json, ...),
# so vulkaninfo reports "Found no drivers!" and the audit fails.
#
# Rules implemented here:
#   1. When VK_DRIVER_FILES is also being set (the AMD pin case), do NOT emit
#      VK_LOADER_DRIVERS_SELECT at all -- the file pin is already exact.
#   2. If user explicitly sets XW_PGO_VK_DRIVER_SELECT (multi-ICD scenarios
#      without a file pin), auto-wrap a bare token in '*...*' so it works as
#      a substring glob across distro filename variants.
_xw_append_gpu_env() {
  local -n _envref="$1"
  _envref=()
  local force_radeonsi=0 force_radv=0
  if _xw_amd_active; then force_radeonsi=1; force_radv=1; fi
  [[ "${XW_PGO_FORCE_RADEONSI:-0}" == 1 ]] && force_radeonsi=1
  [[ "${XW_PGO_FORCE_RADV:-0}"     == 1 ]] && force_radv=1

  (( force_radeonsi )) && _envref+=("MESA_LOADER_DRIVER_OVERRIDE=radeonsi")

  local icd_pinned=0
  if (( force_radv )); then
    local icd=""
    if [[ "${XW_PGO_AMDVLK_OVERRIDE:-0}" == 1 ]]; then
      icd="$(_xw_find_amdvlk_icd 2>/dev/null || true)"
      [[ -z "$icd" ]] && icd="$(_xw_find_radv_icd 2>/dev/null || true)"
    else
      icd="$(_xw_find_radv_icd 2>/dev/null || true)"
    fi
    if [[ -n "$icd" ]]; then
      _envref+=(
        "VK_DRIVER_FILES=$icd"
        "VK_ICD_FILENAMES=$icd"
        "DISABLE_LAYER_AMD_SWITCHABLE_GRAPHICS_1=1"
      )
      icd_pinned=1
    fi
  fi

  # Only honour DRIVERS_SELECT when the user asked for it AND we have not
  # pinned a single ICD file (which would conflict and reject everything).
  if [[ -n "${XW_PGO_VK_DRIVER_SELECT:-}" ]] && (( ! icd_pinned )); then
    local sel="$XW_PGO_VK_DRIVER_SELECT"
    # If user passed a bare token (no '*'), turn it into a substring glob so
    # 'radv' matches 'radeon_icd.x86_64.json', 'lvp' matches 'lvp_icd.json',
    # etc. Preserve already-globbed input as-is.
    [[ "$sel" != *'*'* ]] && sel="*${sel}*"
    _envref+=("VK_LOADER_DRIVERS_SELECT=$sel")
  fi

  [[ -n "${XW_PGO_DRI_PRIME:-}" ]] && _envref+=("DRI_PRIME=${XW_PGO_DRI_PRIME}")
  return 0
}

# Probe active GL/Vulkan drivers. Returns non-zero ONLY when REQUIRE_HW=1
# and the expected substring is missing. Otherwise just prints findings.
_xw_audit_gpu_targets() {
  local expect_gl="${XW_PGO_EXPECT_GL_DRIVER:-}"
  local expect_vk="${XW_PGO_EXPECT_VK_DRIVER:-}"
  local require_hw="${XW_PGO_REQUIRE_HW_TARGETS:-0}"
  local fail=0
  if _xw_amd_active; then
    [[ -n "$expect_gl" ]] || expect_gl="radeonsi"
    [[ -n "$expect_vk" ]] || expect_vk="radv"
    require_hw=1
  fi
  [[ "${XW_PGO_FORCE_RADEONSI:-0}" == 1 && -z "$expect_gl" ]] && expect_gl="radeonsi"
  [[ "${XW_PGO_FORCE_RADV:-0}"     == 1 && -z "$expect_vk" ]] && expect_vk="radv"
  [[ -z "$expect_gl$expect_vk" && "$require_hw" != 1 ]] && return 0

  local -a env_amd=()
  _xw_append_gpu_env env_amd

  # GL probe -- needs DISPLAY (glxinfo creates a GLX context). Use longer
  # timeout because the instrumented Xwayland is 5-30x slower per request
  # under PGO/CS-PGO counter overhead.
  if command -v glxinfo >/dev/null 2>&1; then
    local gl_raw gl_info
    gl_raw="$(env "${env_amd[@]}" timeout -k 2 20 glxinfo -B 2>&1 || true)"
    gl_info="$(grep -Eim2 'OpenGL renderer string|OpenGL vendor string' \
               <<< "$gl_raw" || true)"
    [[ -n "$gl_info" ]] && echo "  -> GL probe: $(tr '\n' '|' <<< "$gl_info")"
    if [[ -n "$expect_gl" && "${gl_info,,}" != *"${expect_gl,,}"* ]]; then
      echo "  -> GL driver MISMATCH: expected '${expect_gl}', raw probe (head):"
      head -n 6 <<< "$gl_raw" | sed 's/^/       /'
      fail=1
    fi
  fi
  # Vulkan probe -- vulkaninfo --summary enumerates WSI surfaces when DISPLAY
  # or WAYLAND_DISPLAY is set (AppCreateXcbSurface, AppCreateWaylandSurface,
  # ...). Against our slow instrumented Xwayland that can stall past any
  # reasonable timeout, get SIGTERMed mid-init, and produce ZERO output --
  # leaving the audit with a useless "probe output:" line.
  # FIX: strip display env vars for the audit probe so vulkaninfo skips
  # surface enumeration entirely. ICD/driver enumeration does not need
  # a display server; the loader walks /usr/share/vulkan/icd.d/ directly.
  if command -v vulkaninfo >/dev/null 2>&1; then
    local vk_raw vk_info
    vk_raw="$(env -u DISPLAY -u WAYLAND_DISPLAY -u XDG_RUNTIME_DIR \
              "${env_amd[@]}" \
              timeout -k 2 15 vulkaninfo --summary 2>&1 || true)"
    vk_info="$(grep -Eim2 'driverName|deviceName' <<< "$vk_raw" || true)"
    [[ -n "$vk_info" ]] && echo "  -> Vulkan probe: $(tr '\n' '|' <<< "$vk_info")"
    if [[ -n "$expect_vk" && "${vk_info,,}" != *"${expect_vk,,}"* ]]; then
      echo "  -> Vulkan driver MISMATCH: expected '${expect_vk}', probe output:"
      # Print loader diagnostics so the user sees WHY (Found no drivers,
      # ICD ignored, ERROR/WARNING lines).
      grep -Eim10 'driverName|deviceName|Found no|ignored because|ERROR|WARNING' \
        <<< "$vk_raw" | sed 's/^/       /'
      # And if grep matched nothing (silent failure), dump first 6 raw lines.
      grep -qEm1 'driverName|deviceName|Found no|ignored because|ERROR|WARNING' \
        <<< "$vk_raw" || {
          echo "       (no diagnostic output; raw head:)"
          head -n 6 <<< "$vk_raw" | sed 's/^/       /'
        }
      fail=1
    fi
  fi

  if (( fail )) && [[ "$require_hw" == 1 ]]; then
    echo "  -> ERROR: required AMD hardware targets not selected for training." >&2
    echo "  -> Set XW_PGO_REQUIRE_HW_TARGETS=0 to allow software fallback," >&2
    echo "  -> or fix pinning (XW_PGO_FORCE_RADEONSI / XW_PGO_FORCE_RADV)." >&2
    return 1
  fi
  return 0
}

# Spawn weston headless on its own session bus + socket. Returns weston pid.
_spawn_weston() {
  local runtime="$1" sock="$2" log="$3"
  local renderer pid
  # Honour AMD pinning inside the compositor process: weston's GL renderer
  # uses EGL on a DRM render node; with MESA_LOADER_DRIVER_OVERRIDE=radeonsi
  # set, the compositor renders on the AMD GPU, matching production.
  local -a wenv=()
  _xw_append_gpu_env wenv
  for renderer in gl pixman; do
    : > "$log"
    setsid env "${wenv[@]}" dbus-run-session -- \
      weston --backend=headless --socket="$sock" \
             --idle-time=0 --renderer="$renderer" >"$log" 2>&1 &
    pid=$!
    for _ in {1..120}; do
      [[ -S "$runtime/$sock" ]] && { echo "$pid"; return 0; }
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.1
    done
    kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
  done
  return 1
}

# Start an Xwayland instance against the active WAYLAND_DISPLAY.
# CRITICAL: NO -terminate flag. -terminate makes Xwayland die the moment its
# last client disconnects; every probe between workload steps would kill the
# server. We manage lifetime explicitly via cleanup_trainers.
_spawn_xwayland() {
  local bin="$1" log="$2" df disp pid
  df=$(mktemp)
  : > "$log"
  "$bin" -ac -noreset -displayfd 3 3>"$df" >"$log" 2>&1 &
  pid=$!
  for _ in {1..150}; do
    [[ -s "$df" ]] && break
    kill -0 "$pid" 2>/dev/null || break
    sleep 0.1
  done
  disp=$(< "$df"); rm -f "$df"
  if [[ -z "$disp" ]]; then
    kill "$pid" 2>/dev/null; wait "$pid" 2>/dev/null
    return 1
  fi
  printf '%s:%s\n' "$pid" "$disp"
}

# Trainer source — embedded verbatim. Written to $srcdir at build() time.
# Heredoc is single-quoted ('TRAINER_EOF') so $ / backticks / \ stay literal.
_emit_trainer() {
  cat > "${srcdir}/xwayland_trainer.c" <<'TRAINER_EOF'
/*
 * xwayland_trainer.c — PGO/BOLT training driver for Xwayland.
 *
 * Drives the *server-side* hot paths in xwayland-{window,present,pixmap,
 * cursor,input,output,glamor,shm}.c by acting as a chatty X11+XCB+Present
 * client. Intended to be run against an instrumented Xwayland under a
 * fresh Wayland compositor (either the host KWin/Mutter or weston-headless).
 *
 * What we hit, mapped to xwayland source files:
 *
 *   xwayland-screen.c, xwayland-output.c     -> connect, screen/visual setup
 *   xwayland-window.c                        -> Map/Unmap/Configure churn
 *   xwayland-window-buffers.c                -> damage burst -> buffer rotation
 *   xwayland-pixmap.c                        -> Pixmap create/free, GLX dri3 fd
 *   xwayland-cursor.c                        -> cursor define/recolor cycle
 *   xwayland-shm.c                           -> XShm round-trip on huge image
 *   xwayland-input.c                         -> XI2 device-info + grab cycle
 *   xwayland-present.c                       -> PRESENT pixmap submit loop
 *   xwayland-drm-lease.c                     -> not exercised (needs HMD)
 *
 * Linux X clients only. -lX11 -lxcb -lxcb-present -lxcb-shm -lxcb-xinput
 * -lxcb-dri3 -lXi (XI2 init). The Present and DRI3 sections are guarded
 * by extension probes so a stripped-down build environment doesn't fail.
 *
 * Wall time on a 14700KF: ~1.5 s per invocation. Designed to be looped
 * 16-32 times by the training workload.
 *
 * Exit codes:
 *   0  -- ran every reachable section to completion
 *   1  -- could not connect to X display
 *   2  -- internal trainer bug (assertion failed)
 * SEGV / non-zero exit signals must be treated as build-fatal by the
 * caller (smoke-test pattern from libx11 v3).
 */

#define _POSIX_C_SOURCE 200809L
#include <X11/Xlib.h>
#include <X11/Xutil.h>
#include <X11/Xatom.h>
#include <X11/extensions/XShm.h>
#include <X11/extensions/XInput2.h>
#include <X11/cursorfont.h>
#include <X11/Xlib-xcb.h>
#include <xcb/xcb.h>
#include <xcb/present.h>
#include <xcb/shm.h>
#include <xcb/xinput.h>
#include <xcb/dri3.h>
#include <xcb/sync.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <sys/types.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <time.h>

#define W 1280
#define H 720
#define IGNORE(x) ((void)(x))

static volatile int g_err_count = 0;
static int eh(Display *d, XErrorEvent *e) {
    char buf[128];
    XGetErrorText(d, e->error_code, buf, sizeof(buf));
    g_err_count++;
    return 0;
}
static int io_eh(Display *d) { IGNORE(d); return 0; }

static void sync_round(Display *d) {
    /* Force a server-side flush + reply so XCB/Xlib drain code is exercised. */
    XSync(d, False);
}

/* ----- Sec 1: screens, visuals, depth-32 ARGB --------------------------- */
static Visual *find_argb_visual(Display *d, int *depth_out) {
    XVisualInfo tpl = { .screen = DefaultScreen(d), .depth = 32, .class = TrueColor };
    int n = 0;
    long mask = VisualScreenMask | VisualDepthMask | VisualClassMask;
    XVisualInfo *vi = XGetVisualInfo(d, mask, &tpl, &n);
    Visual *v = NULL;
    if (vi && n > 0) {
        v = vi[0].visual;
        if (depth_out) *depth_out = vi[0].depth;
    }
    if (vi) XFree(vi);
    return v;
}

/* ----- Sec 2: hot damage loop ------------------------------------------- */
static void damage_burst(Display *d, Window w, GC gc, int iters) {
    for (int i = 0; i < iters; ++i) {
        XSetForeground(d, gc, (unsigned long)(i * 0x010203));
        XFillRectangle(d, w, gc, (i * 13) % (W - 64), (i * 17) % (H - 64), 64, 64);
        if ((i & 0x3f) == 0) XFlush(d);
    }
    sync_round(d);
}

/* ----- Sec 3: cursor churn ---------------------------------------------- */
static void cursor_churn(Display *d, Window w) {
    static const unsigned shapes[] = {
        XC_arrow, XC_X_cursor, XC_watch, XC_crosshair, XC_hand1, XC_hand2,
        XC_left_ptr, XC_xterm, XC_fleur, XC_sb_h_double_arrow,
        XC_sb_v_double_arrow, XC_pencil,
    };
    XColor fg = { .red = 0xFFFF, .green = 0xFFFF, .blue = 0xFFFF,
                  .flags = DoRed|DoGreen|DoBlue };
    XColor bg = { .red = 0,      .green = 0,      .blue = 0,
                  .flags = DoRed|DoGreen|DoBlue };
    for (size_t i = 0; i < sizeof(shapes)/sizeof(*shapes); ++i) {
        Cursor c = XCreateFontCursor(d, shapes[i]);
        if (!c) continue;
        XDefineCursor(d, w, c);
        XRecolorCursor(d, c, &fg, &bg);
        XFreeCursor(d, c);
    }
    /* Pixmap cursor — different code path in xwayland-cursor.c */
    Pixmap bp = XCreatePixmap(d, w, 16, 16, 1);
    Pixmap mp = XCreatePixmap(d, w, 16, 16, 1);
    Cursor pc = XCreatePixmapCursor(d, bp, mp, &fg, &bg, 0, 0);
    if (pc) XFreeCursor(d, pc);
    XFreePixmap(d, bp);
    XFreePixmap(d, mp);
    XUndefineCursor(d, w);
    sync_round(d);
}

/* ----- Sec 4: atom storm (Qt/GTK startup pattern) ----------------------- */
static void atom_storm(Display *d) {
    static const char *names[] = {
        "WM_NAME","WM_ICON_NAME","WM_CLASS","WM_HINTS","WM_NORMAL_HINTS",
        "WM_PROTOCOLS","WM_DELETE_WINDOW","WM_TAKE_FOCUS","WM_STATE",
        "WM_CHANGE_STATE","WM_CLIENT_MACHINE","WM_COMMAND","WM_WINDOW_ROLE",
        "_NET_WM_NAME","_NET_WM_ICON_NAME","_NET_WM_VISIBLE_NAME",
        "_NET_WM_STATE","_NET_WM_STATE_FULLSCREEN","_NET_WM_STATE_HIDDEN",
        "_NET_WM_STATE_MAXIMIZED_VERT","_NET_WM_STATE_MAXIMIZED_HORZ",
        "_NET_ACTIVE_WINDOW","_NET_WM_PID","_NET_WM_USER_TIME","_NET_WM_OPACITY",
        "_NET_WM_WINDOW_TYPE","_NET_WM_WINDOW_TYPE_DIALOG",
        "_NET_WM_WINDOW_TYPE_NORMAL","_NET_WM_WINDOW_TYPE_UTILITY",
        "_NET_WM_WINDOW_TYPE_TOOLBAR","_NET_WM_WINDOW_TYPE_SPLASH",
        "_NET_WM_ICON","_NET_WM_OPAQUE_REGION","_NET_WM_BYPASS_COMPOSITOR",
        "_NET_FRAME_EXTENTS","_NET_WM_DESKTOP","_NET_WORKAREA",
        "_NET_CURRENT_DESKTOP","_NET_NUMBER_OF_DESKTOPS",
        "_MOTIF_WM_HINTS","_GTK_FRAME_EXTENTS","_GTK_THEME_VARIANT",
        "_GTK_HIDE_TITLEBAR_WHEN_MAXIMIZED","_KDE_NET_WM_BLUR_BEHIND_REGION",
        "_KDE_NET_WM_WINDOW_TYPE_OVERRIDE","UTF8_STRING","STRING",
        "CLIPBOARD","PRIMARY","SECONDARY","TARGETS","INCR","MULTIPLE",
        "TIMESTAMP","ATOM_PAIR","COMPOUND_TEXT","TEXT","C_STRING",
        "XdndAware","XdndProxy","XdndTypeList","XdndActionCopy",
        "XdndActionMove","XdndActionList","XdndSelection",
    };
    enum { NA = sizeof(names)/sizeof(*names) };
    Atom atoms[NA];
    XInternAtoms(d, (char **)names, NA, False, atoms);
    char *bulk[NA] = { 0 };
    if (XGetAtomNames(d, atoms, NA, bulk))
        for (int i = 0; i < NA; ++i) if (bulk[i]) XFree(bulk[i]);
    sync_round(d);
}

/* ----- Sec 5: property burst -------------------------------------------- */
static void property_burst(Display *d, Window w) {
    Atom utf8 = XInternAtom(d, "UTF8_STRING", False);
    Atom net_name = XInternAtom(d, "_NET_WM_NAME", False);
    Atom pid_atom = XInternAtom(d, "_NET_WM_PID", False);
    long pid = (long)getpid();
    XChangeProperty(d, w, XA_WM_NAME, XA_STRING, 8, PropModeReplace,
                    (const unsigned char *)"xw-trainer", 10);
    XChangeProperty(d, w, net_name, utf8, 8, PropModeReplace,
                    (const unsigned char *)"xw-trainer", 10);
    XChangeProperty(d, w, pid_atom, XA_CARDINAL, 32, PropModeReplace,
                    (const unsigned char *)&pid, 1);
    Atom type; int fmt; unsigned long n, after; unsigned char *prop;
    if (XGetWindowProperty(d, w, net_name, 0, 64, False, AnyPropertyType,
                            &type, &fmt, &n, &after, &prop) == Success && prop)
        XFree(prop);
    XDeleteProperty(d, w, pid_atom);
    sync_round(d);
}

/* ----- Sec 6: Pixmap churn (drives glamor pixmap path) ------------------ */
static void pixmap_churn(Display *d, Window w, int s) {
    int depth = DefaultDepth(d, s);
    for (int i = 0; i < 32; ++i) {
        Pixmap p = XCreatePixmap(d, w, 256, 256, (unsigned)depth);
        if (p) {
            GC gc = XCreateGC(d, p, 0, NULL);
            if (gc) {
                XSetForeground(d, gc, 0x123456);
                XFillRectangle(d, p, gc, 0, 0, 256, 256);
                XCopyArea(d, p, w, gc, 0, 0, 256, 256, i * 4, i * 4);
                XFreeGC(d, gc);
            }
            XFreePixmap(d, p);
        }
    }
    sync_round(d);
}

/* ----- Sec 7: MIT-SHM round-trip (large) -------------------------------- */
static void shm_roundtrip(Display *d, Window w, int s) {
    if (!XShmQueryExtension(d)) return;
    int depth = DefaultDepth(d, s);
    Visual *vis = DefaultVisual(d, s);
    XShmSegmentInfo seg = { 0 };
    XImage *img = XShmCreateImage(d, vis, (unsigned)depth, ZPixmap, NULL,
                                  &seg, 512, 512);
    if (!img) return;
    seg.shmid = shmget(IPC_PRIVATE,
                       (size_t)img->bytes_per_line * (size_t)img->height,
                       IPC_CREAT | 0600);
    if (seg.shmid < 0) { XDestroyImage(img); return; }
    seg.shmaddr = shmat(seg.shmid, NULL, 0);
    img->data = seg.shmaddr;
    seg.readOnly = False;
    if (seg.shmaddr != (void *)-1 && XShmAttach(d, &seg)) {
        sync_round(d);
        /* Paint a gradient so the server actually has to read it. */
        for (int y = 0; y < 512; ++y)
            memset(seg.shmaddr + y * img->bytes_per_line, y & 0xff,
                   (size_t)img->bytes_per_line);
        GC gc = XCreateGC(d, w, 0, NULL);
        if (gc) {
            XShmPutImage(d, w, gc, img, 0, 0, 0, 0, 512, 512, False);
            sync_round(d);
            XFreeGC(d, gc);
        }
        XShmDetach(d, &seg);
        sync_round(d);
    }
    if (seg.shmaddr != (void *)-1) shmdt(seg.shmaddr);
    shmctl(seg.shmid, IPC_RMID, NULL);
    XDestroyImage(img);
}

/* ----- Sec 8: XI2 device-info + grab cycle ------------------------------ */
static void xi2_cycle(Display *d, Window w) {
    int op = 0, ev = 0, er = 0;
    if (!XQueryExtension(d, "XInputExtension", &op, &ev, &er)) return;
    int major = 2, minor = 3;
    if (XIQueryVersion(d, &major, &minor) != Success) return;
    int ndev = 0;
    XIDeviceInfo *devs = XIQueryDevice(d, XIAllDevices, &ndev);
    if (devs) XIFreeDeviceInfo(devs);
    /* Subscribe to a broad mask, then unsubscribe. */
    unsigned char mask_bits[XIMaskLen(XI_LASTEVENT)] = { 0 };
    XISetMask(mask_bits, XI_KeyPress);
    XISetMask(mask_bits, XI_KeyRelease);
    XISetMask(mask_bits, XI_ButtonPress);
    XISetMask(mask_bits, XI_ButtonRelease);
    XISetMask(mask_bits, XI_Motion);
    XISetMask(mask_bits, XI_Enter);
    XISetMask(mask_bits, XI_Leave);
    XISetMask(mask_bits, XI_FocusIn);
    XISetMask(mask_bits, XI_FocusOut);
    XISetMask(mask_bits, XI_HierarchyChanged);
    XISetMask(mask_bits, XI_DeviceChanged);
    XIEventMask em = {
        .deviceid = XIAllMasterDevices,
        .mask_len = sizeof(mask_bits),
        .mask = mask_bits,
    };
    XISelectEvents(d, w, &em, 1);
    sync_round(d);
    /* Clear by setting an empty mask. */
    em.mask_len = 0;
    em.mask = NULL;
    XISelectEvents(d, w, &em, 1);
    sync_round(d);
}

/* ----- Sec 9: PRESENT via xcb-present (steady-state submit loop) -------- */
static void present_loop(Display *d, Window w, int s, int frames) {
    xcb_connection_t *c = XGetXCBConnection(d);
    if (!c) return;
    const xcb_query_extension_reply_t *ext =
        xcb_get_extension_data(c, &xcb_present_id);
    if (!ext || !ext->present) return;
    /* Negotiate version */
    xcb_present_query_version_cookie_t qv =
        xcb_present_query_version(c, XCB_PRESENT_MAJOR_VERSION,
                                  XCB_PRESENT_MINOR_VERSION);
    xcb_present_query_version_reply_t *qvr =
        xcb_present_query_version_reply(c, qv, NULL);
    if (qvr) free(qvr);

    /* Allocate an event sub-id for completion notify (don't bother
     * waiting for the events; the server-side path is what we want
     * to exercise). */
    xcb_present_event_t eid = xcb_generate_id(c);
    xcb_present_select_input(c, eid, (xcb_window_t)w,
                             XCB_PRESENT_EVENT_MASK_COMPLETE_NOTIFY |
                             XCB_PRESENT_EVENT_MASK_IDLE_NOTIFY);

    int depth = DefaultDepth(d, s);
    xcb_pixmap_t pm = xcb_generate_id(c);
    xcb_create_pixmap(c, (uint8_t)depth, pm, (xcb_window_t)w, W, H);
    xcb_flush(c);

    for (int i = 0; i < frames; ++i) {
        xcb_present_pixmap(c, (xcb_window_t)w, pm, (uint32_t)(i + 1),
                            0, 0, 0, 0,
                            XCB_NONE, XCB_NONE, XCB_NONE,
                            XCB_PRESENT_OPTION_NONE,
                            0, 0, 0, 0, NULL);
        if ((i & 0xf) == 0) xcb_flush(c);
    }
    xcb_flush(c);
    /* Drain pending events for ~50 ms */
    for (int i = 0; i < 50; ++i) {
        xcb_generic_event_t *e;
        while ((e = xcb_poll_for_event(c)) != NULL) free(e);
        struct timespec ts = { 0, 1 * 1000 * 1000 };
        nanosleep(&ts, NULL);
    }
    xcb_free_pixmap(c, pm);
    xcb_present_select_input(c, eid, (xcb_window_t)w, 0);
    xcb_flush(c);
}

/* ----- Sec 10: configure / resize / map / unmap churn ------------------- */
static void window_churn(Display *d, Window w) {
    for (int i = 0; i < 8; ++i) {
        XMoveResizeWindow(d, w, 16 * i, 8 * i, (unsigned)(W - 32 * i),
                          (unsigned)(H - 16 * i));
        XSync(d, False);
    }
    XMoveResizeWindow(d, w, 0, 0, W, H);
    XUnmapWindow(d, w);
    XSync(d, False);
    XMapWindow(d, w);
    XSync(d, False);
}

/* ----- Sec 11: 32-bit ARGB child window --------------------------------- */
static Window create_argb_child(Display *d, Window parent) {
    int depth = 32;
    Visual *vis = find_argb_visual(d, &depth);
    if (!vis) return 0;
    XSetWindowAttributes swa = { 0 };
    swa.colormap = XCreateColormap(d, parent, vis, AllocNone);
    swa.border_pixel = 0;
    swa.background_pixel = 0;
    Window c = XCreateWindow(d, parent, 0, 0, 256, 256, 0, depth,
                              InputOutput, vis,
                              CWColormap | CWBorderPixel | CWBackPixel, &swa);
    if (c) {
        XMapWindow(d, c);
        sync_round(d);
    }
    return c;
}

int main(void) {
    XSetErrorHandler(eh);
    XSetIOErrorHandler(io_eh);

    Display *d = XOpenDisplay(NULL);
    if (!d) {
        fprintf(stderr, "xwayland_trainer: cannot open DISPLAY\n");
        return 1;
    }
    int s = DefaultScreen(d);
    Window root = RootWindow(d, s);

    /* Main 24/32-bit window. */
    XSetWindowAttributes swa = {
        .event_mask = ExposureMask | StructureNotifyMask | ButtonPressMask
                      | ButtonReleaseMask | KeyPressMask | KeyReleaseMask
                      | PointerMotionMask | EnterWindowMask | LeaveWindowMask
                      | FocusChangeMask | PropertyChangeMask,
        .background_pixel = BlackPixel(d, s),
    };
    Window w = XCreateWindow(d, root, 0, 0, W, H, 0,
                              CopyFromParent, InputOutput,
                              CopyFromParent,
                              CWEventMask | CWBackPixel, &swa);
    XStoreName(d, w, "xwayland_trainer");
    XMapWindow(d, w);
    sync_round(d);

    GC gc = XCreateGC(d, w, 0, NULL);

    atom_storm(d);
    property_burst(d, w);
    window_churn(d, w);
    cursor_churn(d, w);
    pixmap_churn(d, w, s);
    shm_roundtrip(d, w, s);
    xi2_cycle(d, w);
    damage_burst(d, w, gc, 1000);  /* hottest path, single big batch */
    present_loop(d, w, s, 256);

    /* ARGB child + a final damage flush on it. */
    Window argb = create_argb_child(d, w);
    if (argb) {
        GC gc2 = XCreateGC(d, argb, 0, NULL);
        if (gc2) {
            damage_burst(d, argb, gc2, 200);
            XFreeGC(d, gc2);
        }
        XDestroyWindow(d, argb);
    }

    /* Final teardown — exercises Xwayland's per-client cleanup path. */
    XFreeGC(d, gc);
    XDestroyWindow(d, w);
    XSync(d, False);
    XCloseDisplay(d);
    return 0;
}
TRAINER_EOF
}

# Trainer compile (one-shot). The trainer is NOT instrumented; it's the driver
# that exercises the instrumented Xwayland it connects to.
_build_trainer() {
  echo "  -> emitting + compiling xwayland_trainer"
  _emit_trainer
  clang -O2 -fPIC -pthread \
    "${srcdir}/xwayland_trainer.c" \
    -o "${srcdir}/xwayland_trainer" \
    -lX11 -lX11-xcb -lxcb -lxcb-present -lxcb-shm \
    -lxcb-xinput -lxcb-dri3 -lxcb-sync -lXi -lXext \
    || return 1
}

# Smoke-test: run reference (system) Xwayland against a fresh weston, then
# run trainer once. Crash = build aborted. This is the libx11 v3 pattern.
_smoke_test_trainer() {
  command -v Xwayland >/dev/null 2>&1 || {
    echo "  -> system Xwayland not installed; skipping smoke-test"
    return 0
  }
  local rd sock wlog xlog wpid info xpid disp
  rd=$(mktemp -d)
  chmod 700 "$rd"
  sock="xw-smoke-$$"
  wlog="$rd/weston.log"; xlog="$rd/xw.log"
  wpid=$(XDG_RUNTIME_DIR="$rd" _spawn_weston "$rd" "$sock" "$wlog") || {
    echo "  -> smoke-test: weston spawn failed"; tail -40 "$wlog"
    rm -rf "$rd"; return 1
  }
  info=$(XDG_RUNTIME_DIR="$rd" WAYLAND_DISPLAY="$sock" \
         _spawn_xwayland "$(command -v Xwayland)" "$xlog") || {
    echo "  -> smoke-test: Xwayland spawn failed"; tail -40 "$xlog"
    kill -TERM -- "-$wpid" 2>/dev/null; wait "$wpid" 2>/dev/null
    rm -rf "$rd"; return 1
  }
  xpid="${info%%:*}"; disp="${info##*:}"
  local rc
  local -a _gpu_env=()
  _xw_append_gpu_env _gpu_env
  DISPLAY=":$disp" XDG_RUNTIME_DIR="$rd" WAYLAND_DISPLAY="$sock" \
    timeout -k 2 30 env "${_gpu_env[@]}" "${srcdir}/xwayland_trainer" \
    > "$rd/smoke.log" 2>&1
  rc=$?
  kill "$xpid" 2>/dev/null; wait "$xpid" 2>/dev/null
  kill -TERM -- "-$wpid" 2>/dev/null; wait "$wpid" 2>/dev/null
  if (( rc != 0 )); then
    echo "  -> trainer SMOKE-TEST FAILED rc=$rc"
    tail -40 "$rd/smoke.log"; tail -40 "$xlog"
    rm -rf "$rd"; return 1
  fi
  echo "  -> trainer smoke-test OK (rc=0)"
  rm -rf "$rd"
}

# Workload driver. Spawns weston-or-uses-host-wayland, spawns the instrumented
# Xwayland, runs the trainer N times + a curated tool subset, tears down.
# Args: $1 instrumented Xwayland path, $2 stage tag, $3 profile output dir
_run_workload() {
  local xway_bin="$1" stage="$2" profile_dir="$3"
  local rd sock wlog xlog wpid info xpid disp use_host=0

  # Profile env hygiene: always start from a clean slate so a stale
  # LLVM_PROFILE_FILE exported by a previous stage cannot cause a binary
  # that happens to retain LLVM profile-runtime hooks (e.g. an instrumented
  # client library loaded by Xwayland) to dump profraws into the wrong
  # stage's directory. Re-export ONLY if this stage is in -fprofile-generate
  # mode (profile_dir non-empty).
  unset LLVM_PROFILE_FILE
  if [[ -n "$profile_dir" ]]; then
    mkdir -p "$profile_dir"
    export LLVM_PROFILE_FILE="$profile_dir/xwayland-%m-%p.profraw"
  fi

  if _xw_should_use_host_wayland; then
    # Explicit opt-in only (XW_PGO_USE_HOST_COMPOSITOR=1). Training windows
    # will be visible on the user's desktop; this is rarely what you want.
    echo "  -> training under HOST Wayland: $WAYLAND_DISPLAY (visible on desktop)"
    use_host=1
  else
    # DEFAULT path: private headless weston (GL renderer preferred). All
    # workload windows render into invisible virtual surfaces; the user's
    # interactive session is undisturbed. On AMD hosts the GL renderer uses
    # radeonsi via EGL render-node, matching the production codegen path.
    rd=$(mktemp -d -p "$srcdir" "xw-runtime-${stage}.XXXXXX")
    chmod 700 "$rd"
    sock="xw-pgo-${stage}-$$"
    wlog="$srcdir/weston-${stage}.log"
    wpid=$(XDG_RUNTIME_DIR="$rd" _spawn_weston "$rd" "$sock" "$wlog") || {
      echo "  -> weston spawn failed; aborting stage ${stage}"
      tail -40 "$wlog"; rm -rf "$rd"; return 1
    }
    # Drop host env explicitly so child Xwayland + clients connect to OUR
    # private weston, not whatever was inherited from the build user's session.
    export XDG_RUNTIME_DIR="$rd" WAYLAND_DISPLAY="$sock"
    unset DISPLAY  # nuke inherited :0 -> no leakage to host X11/XWayland
  fi

  xlog="$srcdir/xwayland-${stage}.log"
  info=$(_spawn_xwayland "$xway_bin" "$xlog") || {
    echo "  -> instrumented Xwayland spawn failed"; tail -40 "$xlog"
    [[ $use_host == 0 ]] && {
      kill -TERM -- "-$wpid" 2>/dev/null; wait "$wpid" 2>/dev/null
      rm -rf "$rd"
    }
    return 1
  }
  xpid="${info%%:*}"; disp="${info##*:}"
  export DISPLAY=":$disp"
  echo "  -> instrumented Xwayland up, DISPLAY=$DISPLAY (pid $xpid)"

  # Wait for first-client readiness (don't disconnect repeatedly).
  local ready=0 _
  for _ in {1..50}; do
    if xdpyinfo >/dev/null 2>&1; then ready=1; break; fi
    kill -0 "$xpid" 2>/dev/null || break
    sleep 0.1
  done
  if (( ! ready )); then
    echo "  -> Xwayland never accepted clients"; tail -40 "$xlog"
    kill "$xpid" 2>/dev/null; wait "$xpid" 2>/dev/null
    [[ $use_host == 0 ]] && {
      kill -TERM -- "-$wpid" 2>/dev/null; wait "$wpid" 2>/dev/null
      rm -rf "$rd"
    }
    return 1
  fi

  # AMD GPU pinning (radeonsi + RADV). Empty on non-AMD systems.
  local -a _gpu_env=()
  _xw_append_gpu_env _gpu_env

  # Probe drivers; if AMD profile is active, mismatch is fatal.
  if ! _xw_audit_gpu_targets; then
    kill "$xpid" 2>/dev/null; wait "$xpid" 2>/dev/null
    if (( use_host == 0 )); then
      kill -TERM -- "-$wpid" 2>/dev/null; wait "$wpid" 2>/dev/null
      rm -rf "$rd"
    fi
    return 1
  fi

  # ---- Run trainer 16 iterations (under GPU env) ------------------------ #
  local ok=0 fail=0 i rc
  echo "  -> trainer x 16 iterations"
  for i in $(seq 1 16); do
    timeout -k 2 30 env "${_gpu_env[@]}" "${srcdir}/xwayland_trainer" \
      >/dev/null 2>&1
    rc=$?
    if (( rc == 0 )); then ok=$((ok+1)); else
      fail=$((fail+1))
      echo "  -> trainer iter $i FAILED rc=$rc"
    fi
  done
  echo "  -> trainer: $ok/$((ok+fail)) iterations OK"

  # ---- Tool workloads (each wrapped with GPU env) ----------------------- #
  # _run <timeout_s> <cmd...>   — runs under the AMD pin env when active.
  # Function-body redirect `} 2>/dev/null` suppresses bash's job-status
  # "Speicherzugriffsfehler/Segmentation fault" message when a workload
  # client (vkcube/glmark2/etc.) dies by signal -- those crashes are
  # cosmetic noise (the X server survives client SEGVs, BOLT counters keep
  # incrementing for everything else), and they cluttered the user log.
  _run() {
    local secs="$1"; shift
    timeout -k 2 "$secs" env "${_gpu_env[@]}" "$@" >/dev/null 2>&1 || true
  } 2>/dev/null

  # GL throughput — drives glamor pixmap + present.
  command -v glxgears >/dev/null && {
    _run 6 env vblank_mode=0 glxgears -fullscreen
    _run 4 env vblank_mode=0 glxgears
  }
  if command -v glmark2 >/dev/null; then
    local scene
    # build/jellyfish/shading: closest call patterns to real games under
    # XWayland on AMD (vertex throughput, texture upload, shader switch).
    for scene in \
      'build:use-vbo=true:duration=2.0' \
      'build:use-vbo=false:duration=2.0' \
      'texture:texture-filter=nearest:duration=2.0' \
      'texture:texture-filter=mipmap:duration=2.0' \
      'shading:shading=phong:duration=2.0' \
      'shading:shading=cel:duration=2.0' \
      'jellyfish:duration=2.0' \
      'shadow:duration=2.0' \
      'refract:duration=2.0' \
      'terrain:duration=2.0'
    do
      _run 6 glmark2 --size 1280x720 -b "$scene"
    done
  fi

  # X11 protocol coverage — small but high-coverage subset.
  _run 5 xdpyinfo -ext all
  _run 5 xrandr --query
  _run 5 xprop -root
  command -v glxinfo >/dev/null && {
    _run 5 glxinfo -B
    _run 5 glxinfo -l
  }

  # x11perf — drives concrete server-side per-op fast paths.
  local t
  for t in -noop -rect100 -fillrect100 -copywinwin500 -putimage500 \
           -getimage500 -shmput500 -line10 -seg100 -circle10 \
           -aa10text -rgb10text -scroll500
  do
    _run 4 x11perf -time 0.5 -repeat 1 "$t"
  done

  # Clipboard/selection paths (atom + selection owner change).
  if command -v xclip >/dev/null; then
    printf 'xw-pgo-clip\n' | _run 3 xclip -selection clipboard
    _run 3 xclip -o -selection clipboard
  fi

  # Synthetic input -> drives xwayland-input.c translation.
  if command -v xdotool >/dev/null; then
    _run 3 xdotool mousemove 100 100
    _run 3 xdotool mousemove 800 600
    _run 3 xdotool click 1
    _run 3 xdotool key Return
    _run 3 xdotool key alt+Tab
  fi

  # Vulkan presenter (xlib WSI) — drives DXVK-style present path through RADV.
  if command -v vkcube >/dev/null; then
    _run 8 vkcube --wsi xlib --suppress_popups --width 1280 --height 720 \
      || _run 8 vkcube --suppress_popups
  fi
  command -v vkcubepp >/dev/null && \
    _run 8 vkcubepp --wsi xlib --suppress_popups --width 1280 --height 720

  # ---- Teardown --------------------------------------------------------- #
  # Graceful Xwayland shutdown sequence for BOLT profile flush:
  #   1. SIGTERM (xserver GiveUp() sets dispatchException flag).
  #   2. Wait up to 10s for the main loop to drain, drop clients, and call
  #      exit(1) via xwl_give_up(). exit() triggers DT_FINI -> BOLT runtime
  #      dumps .fdata. The forked watcher (sleep-time=3) also dumps when it
  #      sees the parent die via kill(ppid, 0) failing.
  #   3. Only SIGKILL if it didn't drain (avoids skipping DT_FINI).
  #   4. Additional 4s grace AFTER reap so the BOLT watcher (separate
  #      process, different pid) has time to flush its final dump and exit.
  kill -TERM "$xpid" 2>/dev/null
  local _wait_t
  for _wait_t in $(seq 1 100); do
    kill -0 "$xpid" 2>/dev/null || break
    sleep 0.1
  done
  if kill -0 "$xpid" 2>/dev/null; then
    echo "  -> Xwayland did not exit gracefully after 10s; SIGKILL (BOLT watcher fallback handles dump)"
    kill -KILL "$xpid" 2>/dev/null
  fi
  wait "$xpid" 2>/dev/null
  # Wait for BOLT runtime to flush its .fdata. THREE possible writers:
  #   1. Parent Xwayland's DT_FINI hook (instr.cpp:1820 __bolt_instr_fini)
  #      -- fires when main() returns / exit() is called.
  #   2. The forked watcher process (instr.cpp:1610 watchProcess) doing
  #      periodic dumps every --instrumentation-sleep-time=N seconds.
  #   3. The watcher's final dump when kill(ppid, 0) detects parent death.
  #
  # Even after `wait $xpid` reaps the Xwayland zombie, DT_FINI may still be
  # mid-serialization (BOLT profiles for a 2 MB binary can take 1-3 s of
  # pure write under the BOLT-instrumented codegen overhead). The user's
  # build proved 4 s grace can be insufficient: .fdata was eventually
  # written but only AFTER we'd already declared "no .fdata produced".
  # Use a generous 30 s ceiling with early-exit on first file appearance.
  if [[ "$stage" == 4 ]]; then
    local _flush
    local -a _peek=()
    for _flush in $(seq 1 300); do
      shopt -s nullglob
      _peek=("$srcdir/bolt"/xway.fdata*.fdata)
      shopt -u nullglob
      (( ${#_peek[@]} > 0 )) && break
      sleep 0.1
    done
    if (( ${#_peek[@]} > 0 )); then
      echo "  -> BOLT .fdata files after ${_flush}*0.1s grace: ${#_peek[@]}"
    else
      echo "  -> BOLT .fdata NOT FOUND after 30s grace; watcher fork inactive?"
      ls -la "$srcdir/bolt/" 2>&1 | head -5
    fi
  fi
  if (( use_host == 0 )); then
    kill -TERM -- "-$wpid" 2>/dev/null || kill -TERM "$wpid" 2>/dev/null || true
    wait "$wpid" 2>/dev/null || true
    rm -rf "$rd"
    unset XDG_RUNTIME_DIR WAYLAND_DISPLAY
  fi
  unset DISPLAY

  # Hard fail if zero trainer iterations succeeded — coverage would be junk.
  (( ok > 0 )) || { echo "  -> ALL trainer iterations failed"; return 1; }
  return 0
}

_count_profraw() {
  local d="$1" n
  shopt -s nullglob
  local files=("$d"/*.profraw)
  shopt -u nullglob
  n=${#files[@]}
  echo "$n"
}

# -------- build ----------------------------------------------------------- #

build() {
  export CC=clang CXX=clang++
  export CCACHE_DISABLE=1
  ulimit -s unlimited 2>/dev/null || true

  cd "$srcdir/xserver"
  rm -rf build-pgo build-cspgo build-final \
         "$srcdir/pgo_raw" "$srcdir/cs_pgo_raw" "$srcdir/bolt" \
         "$srcdir/profdata1.prof" "$srcdir/final.prof"

  local -a base_cppflags=() base_cflags=() base_cxxflags=() base_ldflags=()
  _split_flags CPPFLAGS base_cppflags
  _split_flags CFLAGS   base_cflags
  _split_flags CXXFLAGS base_cxxflags
  _split_flags LDFLAGS  base_ldflags

  # Minimal-but-complete meson option set for an Xwayland-only build.
  # Disabled extensions Xwayland never uses on a Wayland desktop:
  #   xf86bigfont, xdmcp, xdm-auth-1, secure-rpc, xselinux, xcsecurity
  # Disabled extensions tangential to gaming (kept off):
  #   xinerama (KWin handles multi-monitor, XWayland reports one screen)
  # Kept on — measurably used by gaming/desktop XWayland clients:
  #   xv (video overlay), xres (per-client resource accounting used by
  #   monitoring tools), xace (security hook framework used by some apps),
  #   screensaver (used by libXss for inhibitors), dri3, drm, glx, glamor,
  #   mitshm (Steam/older clients), dpms (used for game power saving).
  local common_opts=(
    --prefix /usr
    --wrap-mode=nofallback
    --buildtype=plain
    -Dipv6=true
    -Dxwayland_ei=socket
    -Dxvfb=false
    -Dglx=true
    -Dxdmcp=false
    -Dxdm-auth-1=false
    -Dsecure-rpc=false
    -Dinput_thread=auto
    -Dlisten_tcp=false
    -Dlisten_unix=true
    -Dlisten_local=true
    -Dsystemd_notify=auto
    -Ddpms=true
    -Dxf86bigfont=false
    -Dscreensaver=true
    -Dxres=true
    -Dxace=true
    -Dxselinux=false
    -Dxinerama=false
    -Dxcsecurity=false
    -Dxv=true
    -Dmitshm=true
    -Dsha1=libnettle
    -Ddri3=true
    -Ddrm=true
    -Dglamor=true
    -Dlibdecor=auto
    -Ddocs=false
    -Ddevel-docs=false
    -Ddocs-pdf=false
    -Dxkb_dir=/usr/share/X11/xkb
    -Dxkb_output_dir=/var/lib/xkb
    -Db_ndebug=true
    # LTO and PIE owned by us; makepkg !lto + meson b_lto=false are consistent.
    -Db_lto=false
    -Db_pie=false
  )

  # ---- Build the trainer + smoke-test it BEFORE any instrumented build --- #
  _build_trainer || { echo "Error: trainer build failed"; return 1; }
  _smoke_test_trainer || {
    echo "Error: trainer smoke-test failed -- refusing to start PGO chain"
    return 1
  }

  # ====================================================================== #
  # Stage 1 — IR-PGO instrument + train
  # ====================================================================== #
  echo "-> Stage 1: IR-PGO instrumented build"
  local -a pgo_cf=("${_prefix_map_flags[@]}" "${base_cppflags[@]}"
                   "${base_cflags[@]}" "${_anti_pie_cflags[@]}"
                   "-fprofile-generate=${srcdir}/pgo_raw" "${_pgo_mllvm[@]}")
  local -a pgo_cxxf=("${_prefix_map_flags[@]}" "${base_cppflags[@]}"
                     "${base_cxxflags[@]}" "${_anti_pie_cflags[@]}"
                     "-fprofile-generate=${srcdir}/pgo_raw" "${_pgo_mllvm[@]}")
  local -a pgo_lf=("${base_ldflags[@]}" "${_anti_pie_ldflags[@]}"
                   "-fprofile-generate=${srcdir}/pgo_raw")
  _emit_meson_native meson-native-pgo.ini pgo_cf pgo_cxxf pgo_lf
  _meson meson setup build-pgo "${common_opts[@]}" \
                                 --native-file=meson-native-pgo.ini
  _compile_xwayland build-pgo

  echo "-> Stage 1: workload"
  _run_workload "$PWD/build-pgo/hw/xwayland/Xwayland" 1 "$srcdir/pgo_raw" || {
    echo "Error: Stage 1 workload failed"; return 1
  }

  (( $(_count_profraw "$srcdir/pgo_raw") > 0 )) || {
    echo "Error: Stage 1 produced no .profraw"; return 1
  }
  llvm-profdata merge -sparse \
    -output="$srcdir/profdata1.prof" "$srcdir/pgo_raw"/*.profraw
  [[ -s "$srcdir/profdata1.prof" ]] || {
    echo "Error: stage 1 merge empty"; return 1
  }

  # ====================================================================== #
  # Stage 2 — CS-PGO instrument (uses stage 1) + train
  # ====================================================================== #
  echo "-> Stage 2: CS-PGO instrumented build"
  local -a cs_cf=("${_prefix_map_flags[@]}" "${base_cppflags[@]}"
                  "${base_cflags[@]}" "${_anti_pie_cflags[@]}"
                  "-fcs-profile-generate=${srcdir}/cs_pgo_raw"
                  "-fprofile-use=${srcdir}/profdata1.prof"
                  "${_profile_silence[@]}" "${_pgo_mllvm[@]}")
  local -a cs_cxxf=("${_prefix_map_flags[@]}" "${base_cppflags[@]}"
                    "${base_cxxflags[@]}" "${_anti_pie_cflags[@]}"
                    "-fcs-profile-generate=${srcdir}/cs_pgo_raw"
                    "-fprofile-use=${srcdir}/profdata1.prof"
                    "${_profile_silence[@]}" "${_pgo_mllvm[@]}")
  local -a cs_lf=("${base_ldflags[@]}" "${_anti_pie_ldflags[@]}"
                  "-fcs-profile-generate=${srcdir}/cs_pgo_raw"
                  "-fprofile-use=${srcdir}/profdata1.prof")
  _emit_meson_native meson-native-cspgo.ini cs_cf cs_cxxf cs_lf
  _meson meson setup build-cspgo "${common_opts[@]}" \
                                   --native-file=meson-native-cspgo.ini
  _compile_xwayland build-cspgo

  echo "-> Stage 2: workload"
  _run_workload "$PWD/build-cspgo/hw/xwayland/Xwayland" 2 "$srcdir/cs_pgo_raw" \
    || { echo "Error: Stage 2 workload failed"; return 1; }

  if (( $(_count_profraw "$srcdir/cs_pgo_raw") > 0 )); then
    # MERGE ORDER MATTERS: stage1 must be FIRST so its values seed
    # context-sensitive merging (per LLVM CSPGO docs).
    llvm-profdata merge -sparse -output="$srcdir/final.prof" \
      "$srcdir/profdata1.prof" "$srcdir/cs_pgo_raw"/*.profraw
  else
    echo "Warn: stage 2 produced no CS profraw; using stage1 as final"
    cp "$srcdir/profdata1.prof" "$srcdir/final.prof"
  fi
  [[ -s "$srcdir/final.prof" ]] || {
    echo "Error: final merged profile empty"; return 1
  }

  # ====================================================================== #
  # Stage 3 — Final PGO build with BOLT-friendly link
  # ====================================================================== #
  echo "-> Stage 3: final PGO build (--emit-relocs for BOLT)"
  local -a fin_cf=("${_prefix_map_flags[@]}" "${base_cppflags[@]}"
                   "${base_cflags[@]}" "${_anti_pie_cflags[@]}"
                   "-fprofile-use=${srcdir}/final.prof" "${_profile_silence[@]}")
  local -a fin_cxxf=("${_prefix_map_flags[@]}" "${base_cppflags[@]}"
                     "${base_cxxflags[@]}" "${_anti_pie_cflags[@]}"
                     "-fprofile-use=${srcdir}/final.prof" "${_profile_silence[@]}")
  local -a fin_lf=("${base_ldflags[@]}" "${_anti_pie_ldflags[@]}"
                   "-fprofile-use=${srcdir}/final.prof"
                   "-Wl,--emit-relocs")
  _emit_meson_native meson-native-final.ini fin_cf fin_cxxf fin_lf
  _meson meson setup build-final "${common_opts[@]}" \
                                   --native-file=meson-native-final.ini
  _compile_xwayland build-final

  # ====================================================================== #
  # Stage 4 — BOLT instrument + train + optimise
  # ====================================================================== #
  command -v llvm-bolt >/dev/null 2>&1 || {
    echo "-> Stage 4: llvm-bolt missing; final binary is PGO-only"
    return 0
  }
  echo "-> Stage 4a: BOLT instrument (--lite=false)"
  local bolt="$srcdir/bolt"
  mkdir -p "$bolt"
  local xway="$PWD/build-final/hw/xwayland/Xwayland"
  cp -f "$xway" "$bolt/Xwayland.orig"

  # BOLT runtime profile-dump strategy:
  #
  #   Without --instrumentation-sleep-time, the runtime ONLY dumps .fdata
  #   from its DT_FINI hook (bolt/runtime/instr.cpp::__bolt_instr_fini).
  #   DT_FINI fires only when the process exits via exit(3) / _exit(2).
  #   Xwayland's SIGTERM handler (os/connection.c -> GiveUp()) just sets
  #   the dispatchException flag; the main loop polls it. If the main loop
  #   doesn't drain within our cleanup window (or if a client SEGV racing
  #   with our SIGTERM causes a non-graceful exit path), DT_FINI never
  #   runs -> NO .fdata is ever written. That is exactly what bit the
  #   user: stage 4b workload completed, then "no .fdata produced".
  #
  #   With --instrumentation-sleep-time=N + --instrumentation-no-counters-clear,
  #   BOLT forks a watcher process at startup (see watchProcess() in instr.cpp).
  #   It dumps every N seconds AND once more when the parent dies (detected via
  #   kill(ppid, 0)). Counters are MAP_SHARED so the watcher sees live data.
  #   --instrumentation-no-counters-clear keeps the cumulative profile across
  #   dumps, so the file always represents the full execution to date instead
  #   of just the last N-second window.
  llvm-bolt "$bolt/Xwayland.orig" \
    --instrument \
    --lite=false \
    --instrumentation-file="$bolt/xway.fdata" \
    --instrumentation-file-append-pid \
    --instrumentation-sleep-time=3 \
    --instrumentation-no-counters-clear \
    -o "$bolt/Xwayland.instr" || {
      echo "Warn: BOLT instrumentation failed; keeping PGO binary"
      return 0
    }

  echo "-> Stage 4b: BOLT training workload"
  _run_workload "$bolt/Xwayland.instr" 4 "" || {
    echo "Warn: BOLT training failed; keeping PGO binary"
    return 0
  }

  echo "-> Stage 4c: merge .fdata"
  # Defence-in-depth retry: _run_workload already waited up to 30 s, but
  # leave one more 10 s safety net in case the watcher's final dump landed
  # mid-cleanup. Glob-only on '*.fdata' to avoid matching the
  # .fdata-prefixed (no-suffix) tmp files BOLT might create transiently.
  local _retry
  shopt -s nullglob
  local fdata=("$bolt"/xway.fdata*.fdata)
  shopt -u nullglob
  if (( ${#fdata[@]} == 0 )); then
    for _retry in $(seq 1 100); do
      sleep 0.1
      shopt -s nullglob
      fdata=("$bolt"/xway.fdata*.fdata)
      shopt -u nullglob
      (( ${#fdata[@]} > 0 )) && break
    done
  fi
  if (( ${#fdata[@]} == 0 )); then
    echo "Warn: no .fdata produced; keeping PGO binary"
    echo "  -> Inspecting $bolt for diagnostic:"
    ls -la "$bolt/" 2>&1 | head -10
    return 0
  fi
  echo "  -> ${#fdata[@]} .fdata file(s) to merge"
  if (( ${#fdata[@]} == 1 )); then
    cp -f "${fdata[0]}" "$bolt/merged.fdata"
  elif command -v merge-fdata >/dev/null 2>&1; then
    merge-fdata "${fdata[@]}" -o "$bolt/merged.fdata" || \
      cat "${fdata[@]}" > "$bolt/merged.fdata"
  else
    cat "${fdata[@]}" > "$bolt/merged.fdata"
  fi
  [[ -s "$bolt/merged.fdata" ]] || {
    echo "Warn: merged .fdata empty"; return 0
  }

  echo "-> Stage 4d: BOLT optimise (--lite=false, BOLT-23git flag set)"
  # Excluded (verified crash-prone in BOLT-23git):
  #   --use-aggr-reg-reassign (#123809), --icf=all (#123835 + cdsplit),
  #   --frame-opt=* (#123835), --hugify (needs StartFunctionAddress).
  if llvm-bolt "$bolt/Xwayland.orig" \
       --data="$bolt/merged.fdata" \
       --lite=false \
       --relocs \
       --reorder-blocks=ext-tsp \
       --reorder-functions=cdsort \
       --split-functions \
       --split-strategy=cdsplit \
       --split-all-cold \
       --split-eh \
       --icf=safe \
       --jump-tables=aggressive \
       --indirect-call-promotion=all \
       --icp-eliminate-loads \
       --reg-reassign \
       --x86-strip-redundant-address-size \
       --peepholes=all \
       --simplify-conditional-tail-calls \
       --simplify-rodata-loads \
       --eliminate-unreachable \
       --inline-small-functions \
       --inline-small-functions-bytes=4 \
       --inline-memcpy \
       --plt=all \
       --hot-data \
       --tail-duplication=cache \
       --equalize-bb-counts \
       --infer-stale-profile=1 \
       --match-profile-with-function-hash \
       --cu-processing-batch-size=64 \
       --dyno-stats \
       -o "$bolt/Xwayland.bolt"
  then
    install -m755 "$bolt/Xwayland.bolt" "$xway"
    echo "-> BOLT-optimised Xwayland installed."
  else
    echo "Warn: BOLT optimise failed; keeping PGO binary"
  fi
}

package() {
  cd "$srcdir/xserver"
  DESTDIR="$pkgdir" _meson meson install -C build-final --no-rebuild
  # xwayland-24.1 still drops these from the legacy xserver tree; clean.
  rm -f "$pkgdir/usr/lib/xorg/protocol.txt" \
        "$pkgdir/usr/share/man/man1/Xserver.1" 2>/dev/null || true
  rmdir --ignore-fail-on-non-empty "$pkgdir/usr/lib/xorg" 2>/dev/null || true
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
