)

pkgver() {
  cd xserver
  git describe --long --tags --abbrev=8 | sed 's/^xwayland-//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd xserver
  local src
  for src in "${source[@]}"; do
    src="${src%%::*}"
    src="${src##*/}"
    [[ $src = *.patch ]] || continue
    echo "Applying patch $src..."
    patch -Np1 -i "$srcdir/$src"
  done
}

_split_flags() {
  local varname="$1"
  local -n out_ref="$2"
  out_ref=()
  [[ -n ${!varname:-} ]] && read -r -a out_ref <<< "${!varname}"
}

_meson_array() {
  local arg first=1
  for arg in "$@"; do
    arg=${arg//\\/\\\\}
    arg=${arg//\'/\\\'}
    (( first )) || printf ', '
    printf "'%s'" "$arg"
    first=0
  done
}

_generate_meson_native_file() {
  local outfile="$1"
  local -n _cflags_ref="$2"
  local -n _cxxflags_ref="$3"
  local -n _ldflags_ref="$4"

  cat > "$outfile" <<EOF
[built-in options]
c_args = [$(_meson_array "${_cflags_ref[@]}")]
cpp_args = [$(_meson_array "${_cxxflags_ref[@]}")]
c_link_args = [$(_meson_array "${_ldflags_ref[@]}")]
cpp_link_args = [$(_meson_array "${_ldflags_ref[@]}")]

[binaries]
c = 'clang'
cpp = 'clang++'
ar = 'llvm-ar'
nm = 'llvm-nm'
ranlib = 'llvm-ranlib'
strip = 'llvm-strip'
EOF
}

_meson_env() {
  env -u CFLAGS -u CXXFLAGS -u CPPFLAGS -u LDFLAGS "$@"
}

_compile_xwayland_target() {
  local builddir="$1"
  _meson_env meson compile -C "$builddir" hw/xwayland/Xwayland
}

_have_host_wayland() {
  [[ "${XW_PGO_FORCE_NESTED:-0}" == 1 ]] && return 1
  [[ -n "${XDG_RUNTIME_DIR:-}" ]] || return 1
  [[ -n "${WAYLAND_DISPLAY:-}" ]] || return 1
  [[ -S "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}" ]]
}

_dump_stage_logs() {
  local stage="$1"
  local log
  shopt -s nullglob
  for log in "$srcdir"/xwayland-"${stage}"*.log "$srcdir"/weston-"${stage}"*.log; do
    [[ -s "$log" ]] || continue
    echo "---- $(basename "$log") ----"
    tail -n 120 "$log"
  done
  shopt -u nullglob
}

_vulkan_presenter_cache_path() {
  printf '%s\n' "$srcdir/.xwayland-vulkan-presenter"
}

_load_cached_vulkan_presenter() {
  local __mode_var="$1"
  local __presenter_var="$2"
  local __wsi_var="$3"
  local __icd_var="${4:-}"
  local __mode=""
  local __presenter=""
  local __wsi="auto"
  local __icd=""
  local __path

  __path="$(_vulkan_presenter_cache_path)"

  if [[ -n "${XW_PGO_VK_PRESENTER:-}" ]]; then
    # Format: mode:binary:wsi[:icd-file] ; wsi can be auto
    IFS=':' read -r __mode __presenter __wsi __icd <<< "${XW_PGO_VK_PRESENTER}"
  elif [[ -f "$__path" ]]; then
    read -r __mode __presenter __wsi __icd < "$__path" || true
  fi

  # Backward compatibility: previous cache format stored only presenter name.
  if [[ -n "$__mode" && -z "$__presenter" ]]; then
    __presenter="$__mode"
    __mode="x11"
  fi

  [[ -n "$__mode" ]] || __mode="x11"
  [[ -n "$__wsi" ]] || __wsi="auto"

  printf -v "$__mode_var" '%s' "$__mode"
  printf -v "$__presenter_var" '%s' "$__presenter"
  printf -v "$__wsi_var" '%s' "$__wsi"
  [[ -n "$__icd_var" ]] && printf -v "$__icd_var" '%s' "$__icd"
}

_save_cached_vulkan_presenter() {
  local mode="$1"
  local presenter="$2"
  local wsi="${3:-auto}"
  local icd_file="${4:-}"
  printf '%s %s %s %s\n' "$mode" "$presenter" "$wsi" "$icd_file" > "$(_vulkan_presenter_cache_path)"
}

_clear_cached_vulkan_presenter() {
  rm -f "$(_vulkan_presenter_cache_path)"
}

_find_radv_icd() {
  local path
  local -a candidates=(
    /usr/share/vulkan/icd.d/radeon_icd.x86_64.json
    /usr/share/vulkan/icd.d/radeon_icd*.json
  )

  for path in "${candidates[@]}"; do
    for path in $path; do
      [[ -r "$path" ]] || continue
      printf '%s\n' "$path"
      return 0
    done
  done

  return 1
}

_append_gpu_env() {
  local -n __out_ref="$1"
  __out_ref=()

  local gl_driver="${XW_PGO_GL_DRIVER:-}"
  local vk_driver_files="${XW_PGO_VK_DRIVER_FILES:-}"

  if [[ "${XW_PGO_AMD_PROFILE:-0}" == 1 ]]; then
    [[ -n "$gl_driver" ]] || gl_driver=radeonsi
    if [[ -z "$vk_driver_files" ]]; then
      vk_driver_files="$(_find_radv_icd 2>/dev/null || true)"
    fi
  fi

  if [[ "${XW_PGO_FORCE_RADEONSI:-0}" == 1 && -z "$gl_driver" ]]; then
    gl_driver=radeonsi
  fi

  if [[ "${XW_PGO_FORCE_RADV:-0}" == 1 && -z "$vk_driver_files" ]]; then
    vk_driver_files="$(_find_radv_icd 2>/dev/null || true)"
  fi

  [[ -n "${XW_PGO_DRI_PRIME:-}" ]] && __out_ref+=("DRI_PRIME=${XW_PGO_DRI_PRIME}")
  [[ -n "$gl_driver" ]] && __out_ref+=("MESA_LOADER_DRIVER_OVERRIDE=$gl_driver")

  if [[ -n "$vk_driver_files" ]]; then
    __out_ref+=(
      "VK_DRIVER_FILES=$vk_driver_files"
      "VK_ICD_FILENAMES=$vk_driver_files"
      'DISABLE_LAYER_AMD_SWITCHABLE_GRAPHICS_1=1'
    )
  fi

  [[ -n "${XW_PGO_VK_DRIVER_SELECT:-}" ]] && \
    __out_ref+=("VK_LOADER_DRIVERS_SELECT=${XW_PGO_VK_DRIVER_SELECT}")
}

_capture_x11_cmd() {
  local __outvar="$1"
  shift

  local __output=""
  local -a __gpu_env=()
  _append_gpu_env __gpu_env

  __output="$({
    env \
      -u MANGOHUD \
      -u MANGOHUD_CONFIG \
      -u MANGOHUD_DLSYM \
      -u ENABLE_VKBASALT \
      -u VKBASALT_CONFIG_FILE \
      -u OBS_VKCAPTURE \
      -u VK_INSTANCE_LAYERS \
      -u VK_LAYER_PATH \
      -u VK_ADD_LAYER_PATH \
      -u VK_LOADER_DEBUG \
      -u VK_LOADER_LAYERS_ENABLE \
      -u VK_LOADER_LAYERS_DISABLE \
      -u DXVK_HUD \
      -u GALLIUM_HUD \
      -u LD_PRELOAD \
      -u ENABLE_GAMESCOPE_WSI \
      -u GAMESCOPE_WSI \
      -u GAMESCOPE_WSI_HIDE_PRESENT_WAIT_EXT \
      -u GAMESCOPE_LIMITER_FILE \
      -u WAYLAND_DISPLAY \
      DISPLAY="$DISPLAY" \
      XDG_SESSION_TYPE=x11 \
      GDK_BACKEND=x11 \
      QT_QPA_PLATFORM=xcb \
      SDL_VIDEODRIVER=x11 \
      CLUTTER_BACKEND=x11 \
      MOZ_ENABLE_WAYLAND=0 \
      VK_LOADER_LAYERS_DISABLE='~all~' \
      "${__gpu_env[@]}" \
      "$@"
  } 2>/dev/null || true)"

  printf -v "$__outvar" '%s' "$__output"
  return 0
}

_audit_gpu_targets() {
  local expect_gl="${XW_PGO_EXPECT_GL_DRIVER:-}"
  local expect_vk="${XW_PGO_EXPECT_VK_DRIVER:-}"
  local require_hw="${XW_PGO_REQUIRE_HW_TARGETS:-0}"
  local gl_info=""
  local vk_info=""
  local fail=0

  if [[ "${XW_PGO_AMD_PROFILE:-0}" == 1 ]]; then
    [[ -n "$expect_gl" ]] || expect_gl=radeonsi
    [[ -n "$expect_vk" ]] || expect_vk=radv
    require_hw=1
  fi

  if [[ "${XW_PGO_FORCE_RADEONSI:-0}" == 1 && -z "$expect_gl" ]]; then
    expect_gl=radeonsi
  fi

  if [[ "${XW_PGO_FORCE_RADV:-0}" == 1 && -z "$expect_vk" ]]; then
    expect_vk=radv
  fi

  if [[ -z "$expect_gl$expect_vk" && "$require_hw" != 1 ]]; then
    return 0
  fi

  if command -v glxinfo >/dev/null 2>&1; then
    _capture_x11_cmd gl_info timeout 6s glxinfo -B
    gl_info="$(grep -Eim1 'OpenGL renderer string|OpenGL vendor string' <<< "$gl_info" || true)"
    [[ -n "$gl_info" ]] && echo "  -> GL probe: ${gl_info}"

    if [[ -n "$expect_gl" && "${gl_info,,}" != *"${expect_gl,,}"* ]]; then
      echo "  -> GL driver mismatch: expected '${expect_gl}', probe='${gl_info:-unavailable}'."
      fail=1
    fi
  fi

  if command -v vulkaninfo >/dev/null 2>&1; then
    _capture_x11_cmd vk_info timeout 8s vulkaninfo --summary
    vk_info="$(grep -Eim1 'driverName|GPU id|deviceName' <<< "$vk_info" || true)"
    [[ -n "$vk_info" ]] && echo "  -> Vulkan probe: ${vk_info}"

    if [[ -n "$expect_vk" && "${vk_info,,}" != *"${expect_vk,,}"* ]]; then
      echo "  -> Vulkan driver mismatch: expected '${expect_vk}', probe='${vk_info:-unavailable}'."
      fail=1
    fi
  fi

  if (( fail )) && [[ "$require_hw" == 1 ]]; then
    echo "Error: required hardware GPU targets were not selected for training." >&2
    return 1
  fi

  return 0
}

# Run a command in a child bash without exec(), so a crashing child returns
# a status code instead of killing the helper shell.
_run_quiet_status() {
  local __outvar="$1"
  shift

  local __rc=0
  local __had_errexit=0
  [[ $- == *e* ]] && __had_errexit=1

  set +e
  bash -c '"$@" >/dev/null 2>&1; exit $?' bash "$@" 2>/dev/null
  __rc=$?
  (( __had_errexit )) && set -e

  printf -v "$__outvar" '%d' "$__rc"
  return 0
}

_run_clean_status() {
  local __outvar="$1"
  shift
  local __child_rc=0
  local -a __gpu_env=()

  _append_gpu_env __gpu_env

  _run_quiet_status __child_rc env \
    -u MANGOHUD \
    -u MANGOHUD_CONFIG \
    -u MANGOHUD_DLSYM \
    -u ENABLE_VKBASALT \
    -u VKBASALT_CONFIG_FILE \
    -u OBS_VKCAPTURE \
    -u VK_INSTANCE_LAYERS \
    -u VK_LAYER_PATH \
    -u VK_ADD_LAYER_PATH \
    -u VK_LOADER_DEBUG \
    -u VK_LOADER_LAYERS_ENABLE \
    -u VK_LOADER_LAYERS_DISABLE \
    -u DXVK_HUD \
    -u GALLIUM_HUD \
    -u LD_PRELOAD \
    -u GDK_BACKEND \
    -u QT_QPA_PLATFORM \
    -u SDL_VIDEODRIVER \
    -u CLUTTER_BACKEND \
    -u MOZ_ENABLE_WAYLAND \
    -u ENABLE_GAMESCOPE_WSI \
    -u GAMESCOPE_WSI \
    -u GAMESCOPE_WSI_HIDE_PRESENT_WAIT_EXT \
    -u GAMESCOPE_LIMITER_FILE \
    "${__gpu_env[@]}" \
    VK_LOADER_LAYERS_DISABLE='~all~' \
    "$@"

  printf -v "$__outvar" '%d' "$__child_rc"
  return 0
}

_run_x11_status() {
  local __outvar="$1"
  shift
  local __child_rc=0
  local -a __gpu_env=()

  _append_gpu_env __gpu_env

  _run_quiet_status __child_rc env \
    -u MANGOHUD \
    -u MANGOHUD_CONFIG \
    -u MANGOHUD_DLSYM \
    -u ENABLE_VKBASALT \
    -u VKBASALT_CONFIG_FILE \
    -u OBS_VKCAPTURE \
    -u VK_INSTANCE_LAYERS \
    -u VK_LAYER_PATH \
    -u VK_ADD_LAYER_PATH \
    -u VK_LOADER_DEBUG \
    -u VK_LOADER_LAYERS_ENABLE \
    -u VK_LOADER_LAYERS_DISABLE \
    -u DXVK_HUD \
    -u GALLIUM_HUD \
    -u LD_PRELOAD \
    -u ENABLE_GAMESCOPE_WSI \
    -u GAMESCOPE_WSI \
    -u GAMESCOPE_WSI_HIDE_PRESENT_WAIT_EXT \
    -u GAMESCOPE_LIMITER_FILE \
    -u WAYLAND_DISPLAY \
    DISPLAY="$DISPLAY" \
    XDG_SESSION_TYPE=x11 \
    GDK_BACKEND=x11 \
    QT_QPA_PLATFORM=xcb \
    SDL_VIDEODRIVER=x11 \
    CLUTTER_BACKEND=x11 \
    MOZ_ENABLE_WAYLAND=0 \
    "${__gpu_env[@]}" \
    VK_LOADER_LAYERS_DISABLE='~all~' \
    "$@"

  printf -v "$__outvar" '%d' "$__child_rc"
  return 0
}

_run_mode_status() {
  local mode="$1"
  local __outvar="$2"
  shift 2

  local __rc=0
  if [[ "$mode" == x11 ]]; then
    _run_x11_status __rc "$@"
  else
    _run_clean_status __rc "$@"
  fi

  printf -v "$__outvar" '%d' "$__rc"
  return 0
}

_run_clean_ignore() {
  local __rc=0
  _run_clean_status __rc "$@"
  return 0
}

_run_x11_ignore() {
  local __rc=0
  _run_x11_status __rc "$@"
  return 0
}

_start_training_compositor() {
  local runtime_dir="$1"
  local socket_name="$2"
  local weston_log="$3"
  local renderer pid

  for renderer in gl pixman; do
    echo "  -> Starting headless Weston fallback (${renderer})..." >&2
    : > "$weston_log"

    setsid dbus-run-session -- \
      weston --backend=headless --socket="$socket_name" --idle-time=0 --renderer="$renderer" \
      >"$weston_log" 2>&1 &
    pid=$!

    for _ in {1..120}; do
      [[ -S "$runtime_dir/$socket_name" ]] && {
        printf '%s\n' "$pid"
        return 0
      }
      if ! kill -0 "$pid" 2>/dev/null; then
        break
      fi
      sleep 0.1
    done

    kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
  done

  return 1
}

_presenter_supports_wsi() {
  local presenter="$1"
  "$presenter" --help 2>&1 | grep -q -- '--wsi'
}

_find_lavapipe_icd() {
  local pattern match
  local -a candidates=(
    /usr/share/vulkan/icd.d/lvp_icd.x86_64.json
    /usr/share/vulkan/icd.d/lvp_icd*.json
    /etc/vulkan/icd.d/lvp_icd*.json
    /usr/share/vulkan/icd.d/*lavapipe*.json
    /etc/vulkan/icd.d/*lavapipe*.json
  )

  shopt -s nullglob
  for pattern in "${candidates[@]}"; do
    for match in $pattern; do
      [[ -r "$match" ]] || continue
      printf '%s\n' "$match"
      shopt -u nullglob
      return 0
    done
  done
  shopt -u nullglob
  return 1
}

_run_vulkan_presenter_variant() {
  local mode="$1"
  local presenter="$2"
  local wsi="$3"
  local smoke_cycles="$4"
  local run_cycles="$5"
  local smoke_timeout="$6"
  local run_timeout="$7"
  local icd_file="${8:-}"

  local smoke_rc=0
  local run_rc=0
  local wsi_label="$wsi"
  local gpu_label="hw"
  local -a cmd_args=(--suppress_popups --width 1280 --height 720)
  local -a timeout_smoke_cmd=(timeout --signal=TERM --kill-after=2s "$smoke_timeout")
  local -a timeout_run_cmd=(timeout --signal=TERM --kill-after=2s "$run_timeout")
  local -a env_prefix=()

  [[ "$wsi_label" == auto ]] && wsi_label="default"
  [[ -n "$icd_file" ]] && {
    gpu_label="sw-lavapipe"
    env_prefix=(env VK_ICD_FILENAMES="$icd_file" VK_DRIVER_FILES="$icd_file")
  }
  [[ "$wsi" != auto ]] && cmd_args+=(--wsi "$wsi")

  # Avoid vkcube short-frame teardown crashes on some stacks by profiling
  # timeout-bounded steady-state loops instead of finite --c exits.

  echo "  -> Smoke-testing ${presenter} (mode=${mode}, wsi=${wsi_label}, gpu=${gpu_label})..."
  _run_mode_status "$mode" smoke_rc "${env_prefix[@]}" "${timeout_smoke_cmd[@]}" "$presenter" "${cmd_args[@]}"

  if (( smoke_rc != 0 && smoke_rc != 124 )); then
    if (( smoke_rc >= 128 )); then
      echo "  -> ${presenter} crashed by signal in smoke test (mode=${mode}, wsi=${wsi_label}, gpu=${gpu_label}, rc=${smoke_rc})."
    else
      echo "  -> ${presenter} unstable in smoke test (mode=${mode}, wsi=${wsi_label}, gpu=${gpu_label}, rc=${smoke_rc})."
    fi
    return 1
  fi

  echo "  -> Running ${presenter} for Vulkan presentation training (mode=${mode}, wsi=${wsi_label}, gpu=${gpu_label})..."
  _run_mode_status "$mode" run_rc "${env_prefix[@]}" "${timeout_run_cmd[@]}" "$presenter" "${cmd_args[@]}"

  if (( run_rc == 0 || run_rc == 124 )); then
    _save_cached_vulkan_presenter "$mode" "$presenter" "$wsi" "$icd_file"
    return 0
  fi

  if (( run_rc >= 128 )); then
    echo "  -> ${presenter} crashed by signal in extended run (mode=${mode}, wsi=${wsi_label}, gpu=${gpu_label}, rc=${run_rc})."
  else
    echo "  -> ${presenter} exited non-cleanly in extended run (mode=${mode}, wsi=${wsi_label}, gpu=${gpu_label}, rc=${run_rc})."
  fi

  return 1
}

_run_vulkan_training() {
  local stage="$1"

  local smoke_cycles=6
  local run_cycles=0
  local smoke_timeout=5s
  local run_timeout=""
  local cached_mode=""
  local cached_presenter=""
  local cached_wsi=""
  local cached_icd=""
  local presenter=""
  local have_stable=0
  local lavapipe_icd=""
  local lavapipe_allowed=0
  local lavapipe_smoke_timeout=3s
  local lavapipe_run_timeout=4s

  if command -v vulkaninfo >/dev/null 2>&1; then
    _run_x11_ignore timeout 8s vulkaninfo --summary
    _run_clean_ignore timeout 8s vulkaninfo --summary
  fi

  [[ "${XW_PGO_DISABLE_VKCUBE:-0}" == 1 ]] && {
    echo "  -> Skipping Vulkan presenter training (XW_PGO_DISABLE_VKCUBE=1)."
    return 0
  }

  case "$stage" in
    1)
      run_cycles=24
      run_timeout=8s
      ;;
    2)
      run_cycles=48
      run_timeout=10s
      ;;
    4)
      run_cycles=72
      run_timeout=12s
      ;;
    *)
      run_cycles=36
      run_timeout=8s
      ;;
  esac

  _load_cached_vulkan_presenter cached_mode cached_presenter cached_wsi cached_icd
  if [[ -n "$cached_presenter" ]] && command -v "$cached_presenter" >/dev/null 2>&1; then
    echo "  -> Trying cached stable Vulkan presenter (${cached_presenter}, mode=${cached_mode}, wsi=${cached_wsi})..."
    if _run_vulkan_presenter_variant "$cached_mode" "$cached_presenter" "$cached_wsi" "$smoke_cycles" "$run_cycles" "$smoke_timeout" "$run_timeout" "$cached_icd"; then
      return 0
    fi
    echo "  -> Cached Vulkan presenter became unstable; re-detecting."
    _clear_cached_vulkan_presenter
  fi

  for presenter in vkcubepp vkcube; do
    command -v "$presenter" >/dev/null 2>&1 || continue

    if _presenter_supports_wsi "$presenter"; then
      # Prefer xlib first: on some stacks xcb path is crash-prone under Xwayland.
      if _run_vulkan_presenter_variant x11 "$presenter" xlib "$smoke_cycles" "$run_cycles" "$smoke_timeout" "$run_timeout"; then
        return 0
      fi

      if _run_vulkan_presenter_variant x11 "$presenter" xcb "$smoke_cycles" "$run_cycles" "$smoke_timeout" "$run_timeout"; then
        return 0
      fi

      if _run_vulkan_presenter_variant x11 "$presenter" auto "$smoke_cycles" "$run_cycles" "$smoke_timeout" "$run_timeout"; then
        return 0
      fi

      if _run_vulkan_presenter_variant clean "$presenter" wayland "$smoke_cycles" "$run_cycles" "$smoke_timeout" "$run_timeout"; then
        have_stable=1
        break
      fi
    else
      if _run_vulkan_presenter_variant x11 "$presenter" auto "$smoke_cycles" "$run_cycles" "$smoke_timeout" "$run_timeout"; then
        return 0
      fi
    fi
  done

  if (( have_stable )); then
    echo "  -> Vulkan presenter training completed via Wayland fallback after X11 variants were unstable."
    return 0
  fi

  # Keep software Vulkan fallback profile influence minimal by default.
  # Full-stage software Vulkan profiling can be enabled explicitly.
  if [[ "$stage" == 1 || "${XW_PGO_LAVAPIPE_ALL_STAGES:-0}" == 1 ]]; then
    lavapipe_allowed=1
  fi

  if (( lavapipe_allowed )) && lavapipe_icd="$(_find_lavapipe_icd)"; then
    echo "  -> Retrying Vulkan presenter training with lavapipe fallback ICD: ${lavapipe_icd}"
    for presenter in vkcubepp vkcube; do
      command -v "$presenter" >/dev/null 2>&1 || continue

      if _presenter_supports_wsi "$presenter"; then
        if _run_vulkan_presenter_variant x11 "$presenter" xlib "$smoke_cycles" "$run_cycles" "$lavapipe_smoke_timeout" "$lavapipe_run_timeout" "$lavapipe_icd"; then
          return 0
        fi

        if _run_vulkan_presenter_variant x11 "$presenter" xcb "$smoke_cycles" "$run_cycles" "$lavapipe_smoke_timeout" "$lavapipe_run_timeout" "$lavapipe_icd"; then
          return 0
        fi

        if _run_vulkan_presenter_variant x11 "$presenter" auto "$smoke_cycles" "$run_cycles" "$lavapipe_smoke_timeout" "$lavapipe_run_timeout" "$lavapipe_icd"; then
          return 0
        fi

        if _run_vulkan_presenter_variant clean "$presenter" wayland "$smoke_cycles" "$run_cycles" "$lavapipe_smoke_timeout" "$lavapipe_run_timeout" "$lavapipe_icd"; then
          return 0
        fi
      else
        if _run_vulkan_presenter_variant x11 "$presenter" auto "$smoke_cycles" "$run_cycles" "$lavapipe_smoke_timeout" "$lavapipe_run_timeout" "$lavapipe_icd"; then
          return 0
        fi
      fi
    done
  elif (( ! lavapipe_allowed )); then
    echo "  -> Skipping lavapipe Vulkan presenter profiling for stage ${stage} to avoid software-profile bias."
  fi

  _clear_cached_vulkan_presenter
  echo "  -> No stable Vulkan presenter variant available; keeping Vulkan coverage to vulkaninfo."
  return 0
}

run_comprehensive_workloads() {
  local xwayland_bin="$1"
  local stage="${2:-generic}"
  local profile_dir="${3:-}"

  local backend=""
  local backend_success=0

  local weston_pid=""
  local xway_pid=""
  local disp_file=""
  local display_num=""
  local ready=0

  local runtime_dir="$srcdir/xwayland-pgo-runtime-${stage}-$$"
  local weston_log=""
  local xway_log=""

  local had_xdg_runtime_dir=0
  local had_wayland_display=0
  local had_display=0
  local had_llvm_profile_file=0

  local old_xdg_runtime_dir="${XDG_RUNTIME_DIR-}"
  local old_wayland_display="${WAYLAND_DISPLAY-}"
  local old_display="${DISPLAY-}"
  local old_llvm_profile_file="${LLVM_PROFILE_FILE-}"

  [[ -v XDG_RUNTIME_DIR ]] && had_xdg_runtime_dir=1
  [[ -v WAYLAND_DISPLAY ]] && had_wayland_display=1
  [[ -v DISPLAY ]] && had_display=1
  [[ -v LLVM_PROFILE_FILE ]] && had_llvm_profile_file=1

  cleanup_workloads() {
    if [[ -n "$xway_pid" ]]; then
      kill -TERM "$xway_pid" 2>/dev/null || true
      wait "$xway_pid" 2>/dev/null || true
    fi

    if [[ -n "$weston_pid" ]]; then
      kill -TERM -- "-$weston_pid" 2>/dev/null || kill -TERM "$weston_pid" 2>/dev/null || true
      wait "$weston_pid" 2>/dev/null || true
    fi

    [[ -n "$disp_file" ]] && rm -f "$disp_file"
    [[ -d "$runtime_dir" ]] && rm -rf "$runtime_dir"

    if (( had_xdg_runtime_dir )); then
      export XDG_RUNTIME_DIR="$old_xdg_runtime_dir"
    else
      unset XDG_RUNTIME_DIR
    fi

    if (( had_wayland_display )); then
      export WAYLAND_DISPLAY="$old_wayland_display"
    else
      unset WAYLAND_DISPLAY
    fi

    if (( had_display )); then
      export DISPLAY="$old_display"
    else
      unset DISPLAY
    fi

    if (( had_llvm_profile_file )); then
      export LLVM_PROFILE_FILE="$old_llvm_profile_file"
    else
      unset LLVM_PROFILE_FILE
    fi
  }

  ulimit -s unlimited 2>/dev/null || true
  ulimit -c 0 2>/dev/null || true

  if [[ -n "$profile_dir" ]]; then
    mkdir -p "$profile_dir"
    export LLVM_PROFILE_FILE="$profile_dir/xwayland-%m-%p.profraw"
  fi

  local -a backends=()
  if _have_host_wayland; then
    backends=(host nested)
  else
    backends=(nested)
  fi

  for backend in "${backends[@]}"; do
    weston_pid=""
    xway_pid=""
    disp_file=""
    display_num=""
    ready=0

    if (( had_xdg_runtime_dir )); then
      export XDG_RUNTIME_DIR="$old_xdg_runtime_dir"
    else
      unset XDG_RUNTIME_DIR
    fi

    if (( had_wayland_display )); then
      export WAYLAND_DISPLAY="$old_wayland_display"
    else
      unset WAYLAND_DISPLAY
    fi

    if (( had_display )); then
      export DISPLAY="$old_display"
    else
      unset DISPLAY
    fi

    weston_log="$srcdir/weston-${stage}-${backend}.log"
    xway_log="$srcdir/xwayland-${stage}-${backend}.log"

    if [[ "$backend" == host ]]; then
      echo "  -> Reusing host Wayland compositor (${WAYLAND_DISPLAY})..."
    else
      mkdir -p "$runtime_dir"
      chmod 700 "$runtime_dir"
      export XDG_RUNTIME_DIR="$runtime_dir"
      export WAYLAND_DISPLAY="xwayland-pgo-${stage}-$$"

      weston_pid="$(_start_training_compositor "$runtime_dir" "$WAYLAND_DISPLAY" "$weston_log")" || {
        echo "  -> Failed to start fallback Weston for stage ${stage}."
        [[ -s "$weston_log" ]] && tail -n 80 "$weston_log"
        cleanup_workloads
        continue
      }
    fi

    echo "  -> Starting Xwayland..."
    disp_file="$(mktemp)"
    : > "$xway_log"

    "$xwayland_bin" -ac -noreset -terminate -displayfd 3 3>"$disp_file" >"$xway_log" 2>&1 &
    xway_pid=$!

    for _ in {1..150}; do
      if [[ -s "$disp_file" ]]; then
        read -r display_num < "$disp_file"
        break
      fi
      if ! kill -0 "$xway_pid" 2>/dev/null; then
        break
      fi
      sleep 0.1
    done

    if [[ -z "$display_num" ]]; then
      echo "  -> Xwayland did not report a display on ${backend} backend."
      [[ -s "$xway_log" ]] && tail -n 120 "$xway_log"
      cleanup_workloads
      continue
    fi

    export DISPLAY=":$display_num"
    echo "  -> Waiting for DISPLAY=$DISPLAY to accept clients..."

    local xdpy_rc=0
    for _ in {1..150}; do
      _run_x11_status xdpy_rc timeout 1s xdpyinfo
      if (( xdpy_rc == 0 )); then
        ready=1
        break
      fi
      if ! kill -0 "$xway_pid" 2>/dev/null; then
        break
      fi
      sleep 0.1
    done

    if (( ready )); then
      backend_success=1
      break
    fi

    echo "  -> DISPLAY=$DISPLAY never became ready on ${backend} backend."
    [[ -s "$xway_log" ]] && tail -n 120 "$xway_log"
    [[ -s "$weston_log" ]] && tail -n 80 "$weston_log"
    cleanup_workloads
  done

  if (( ! backend_success )); then
    echo "Error: unable to establish a usable Xwayland training display for stage ${stage}." >&2
    cleanup_workloads
    return 1
  fi

  echo "  -> Training on DISPLAY=$DISPLAY (stage ${stage})"
  _audit_gpu_targets || {
    cleanup_workloads
    return 1
  }
  sleep 0.5

  _run_x11_ignore vblank_mode=0 timeout 10s glxgears -fullscreen
  _run_x11_ignore vblank_mode=0 timeout 8s glxgears

  if command -v glmark2 >/dev/null 2>&1; then
    _run_x11_ignore timeout 8s glmark2 --size 1280x720 -b "build:use-vbo=false:duration=1800"
    _run_x11_ignore timeout 8s glmark2 --size 1280x720 -b "build:use-fbo=true:duration=1800"
    _run_x11_ignore timeout 8s glmark2 --size 1280x720 -b "jellyfish:duration=1800"
    _run_x11_ignore timeout 8s glmark2 --size 1280x720 -b "shadow:duration=1800"
    _run_x11_ignore timeout 8s glmark2 --size 1280x720 -b "terrain:duration=1800"
    _run_x11_ignore timeout 8s glmark2 --size 1280x720 -b "shading:shading=phong:duration=1800"
  fi

  _run_x11_ignore timeout 6s xdpyinfo -ext all
  _run_x11_ignore timeout 5s xrandr --query
  _run_x11_ignore timeout 5s xprop -root

  local test
  for test in \
    -noop \
    -rect10 \
    -fillrect100 \
    -copywinwin500 \
    -putimage500 \
    -getimage500 \
    -shmput500 \
    -line10 \
    -seg10 \
    -circle10 \
    -aa10text \
    -rgb10text \
    -scroll500
  do
    _run_x11_ignore timeout 4s x11perf "$test"
  done

  printf '%s\n' 'xw-pgo-clipboard-test' | _run_x11_ignore timeout 4s xclip -selection clipboard
  _run_x11_ignore timeout 4s xclip -o -selection clipboard

  if command -v glxinfo >/dev/null 2>&1; then
    _run_x11_ignore timeout 6s glxinfo -B
    _run_x11_ignore timeout 5s glxinfo -l
  fi

  _run_vulkan_training "$stage"

  cleanup_workloads
  return 0
}

build() {
  export CC=clang
  export CXX=clang++
  export CCACHE_DISABLE=1
  ulimit -s unlimited 2>/dev/null || true

  cd "$srcdir/xserver"
  rm -rf build-pgo build-cspgo build-final \
         "$srcdir/pgo_raw" "$srcdir/cs_pgo_raw" "$srcdir/bolt" \
         "$srcdir/profdata1.prof" "$srcdir/final.prof"
  _clear_cached_vulkan_presenter

  local -a base_cppflags=()
  local -a base_cflags=()
  local -a base_cxxflags=()
  local -a base_ldflags=()

  _split_flags CPPFLAGS base_cppflags
  _split_flags CFLAGS base_cflags
  _split_flags CXXFLAGS base_cxxflags
  _split_flags LDFLAGS base_ldflags

  local common_opts=(
    --prefix /usr
    --wrap-mode=nofallback
    --buildtype=plain
    -Dipv6=true
    -Dxwayland_ei=socket
    -Dxvfb=false
    -Dglx=true
    -Dxdmcp=false
    -Dxdm-auth-1=false
    -Dsecure-rpc=false
    -Dinput_thread=auto
    -Dlisten_tcp=false
    -Dlisten_unix=true
    -Dlisten_local=true
    -Dsystemd_notify=auto
    -Ddpms=true
    -Dxf86bigfont=false
    -Dscreensaver=true
    -Dxres=true
    -Dxace=true
    -Dxselinux=false
    -Dxinerama=true
    -Dxcsecurity=false
    -Dxv=true
    -Dmitshm=true
    -Dsha1=libnettle
    -Ddri3=true
    -Ddrm=true
    -Dglamor=true
    -Dlibdecor=auto
    -Ddocs=false
    -Ddevel-docs=false
    -Ddocs-pdf=false
    -Dxkb_dir=/usr/share/X11/xkb
    -Dxkb_output_dir=/var/lib/xkb
    -Db_ndebug=true
    -Db_lto=true
    -Db_lto_mode=default
    -Db_pie=false
  )

  echo "-> Stage 1: Building PGO instrumented Xwayland..."
  local -a pgo_cflags=("${_prefix_map_flags[@]}" "${base_cppflags[@]}" "${base_cflags[@]}" "${_anti_pie_cflags[@]}" -fprofile-generate="$srcdir/pgo_raw" "${_extra_instr[@]}")
  local -a pgo_cxxflags=("${_prefix_map_flags[@]}" "${base_cppflags[@]}" "${base_cxxflags[@]}" "${_anti_pie_cflags[@]}" -fprofile-generate="$srcdir/pgo_raw" "${_extra_instr[@]}")
  local -a pgo_ldflags=("${base_ldflags[@]}" "${_anti_pie_ldflags[@]}" -fprofile-generate="$srcdir/pgo_raw")

  _generate_meson_native_file meson-native-pgo.ini pgo_cflags pgo_cxxflags pgo_ldflags
  _meson_env meson setup build-pgo "${common_opts[@]}" --native-file=meson-native-pgo.ini
  _compile_xwayland_target build-pgo

  echo "-> Stage 1: Running comprehensive workloads..."
  mkdir -p "$srcdir/pgo_raw"
  run_comprehensive_workloads "$PWD/build-pgo/hw/xwayland/Xwayland" 1 "$srcdir/pgo_raw" || {
    _dump_stage_logs 1
    return 1
  }

  local -a pgo_raws=()
  shopt -s nullglob
  pgo_raws=("$srcdir/pgo_raw"/*.profraw)
  shopt -u nullglob

  if (( ${#pgo_raws[@]} )); then
    llvm-profdata merge -sparse -output="$srcdir/profdata1.prof" "${pgo_raws[@]}"
  else
    echo "Error: Stage 1 produced no .profraw files." >&2
    _dump_stage_logs 1
    return 1
  fi

  echo "-> Stage 2: Building CS-PGO instrumented Xwayland..."
  local -a cspgo_cflags=("${_prefix_map_flags[@]}" "${base_cppflags[@]}" "${base_cflags[@]}" "${_anti_pie_cflags[@]}" -fcs-profile-generate="$srcdir/cs_pgo_raw" "${_extra_instr[@]}")
  local -a cspgo_cxxflags=("${_prefix_map_flags[@]}" "${base_cppflags[@]}" "${base_cxxflags[@]}" "${_anti_pie_cflags[@]}" -fcs-profile-generate="$srcdir/cs_pgo_raw" "${_extra_instr[@]}")
  local -a cspgo_ldflags=("${base_ldflags[@]}" "${_anti_pie_ldflags[@]}" -fcs-profile-generate="$srcdir/cs_pgo_raw")

  cspgo_cflags+=(-fprofile-use="$srcdir/profdata1.prof" "${_profile_use_silence[@]}")
  cspgo_cxxflags+=(-fprofile-use="$srcdir/profdata1.prof" "${_profile_use_silence[@]}")
  cspgo_ldflags+=(-fprofile-use="$srcdir/profdata1.prof")

  _generate_meson_native_file meson-native-cspgo.ini cspgo_cflags cspgo_cxxflags cspgo_ldflags
  _meson_env meson setup build-cspgo "${common_opts[@]}" --native-file=meson-native-cspgo.ini
  _compile_xwayland_target build-cspgo

  echo "-> Stage 2: Running comprehensive workloads..."
  mkdir -p "$srcdir/cs_pgo_raw"
  run_comprehensive_workloads "$PWD/build-cspgo/hw/xwayland/Xwayland" 2 "$srcdir/cs_pgo_raw" || {
    _dump_stage_logs 2
    return 1
  }

  local -a cs_raws=()
  shopt -s nullglob
  cs_raws=("$srcdir/cs_pgo_raw"/*.profraw)
  shopt -u nullglob

  if (( ${#cs_raws[@]} )); then
    llvm-profdata merge -sparse -output="$srcdir/final.prof" "$srcdir/profdata1.prof" "${cs_raws[@]}"
  else
    echo "Error: Stage 2 produced no CS-PGO .profraw files." >&2
    _dump_stage_logs 2
    return 1
  fi

  echo "-> Stage 3: Building final optimized Xwayland..."
  local -a final_cflags=("${_prefix_map_flags[@]}" "${base_cppflags[@]}" "${base_cflags[@]}" "${_anti_pie_cflags[@]}")
  local -a final_cxxflags=("${_prefix_map_flags[@]}" "${base_cppflags[@]}" "${base_cxxflags[@]}" "${_anti_pie_cflags[@]}")
  local -a final_ldflags=("${base_ldflags[@]}" "${_anti_pie_ldflags[@]}" -Wl,--emit-relocs)

  final_cflags+=(-fprofile-use="$srcdir/final.prof" "${_profile_use_silence[@]}")
  final_cxxflags+=(-fprofile-use="$srcdir/final.prof" "${_profile_use_silence[@]}")
  final_ldflags+=(-fprofile-use="$srcdir/final.prof")

  _generate_meson_native_file meson-native-final.ini final_cflags final_cxxflags final_ldflags
  _meson_env meson setup build-final "${common_opts[@]}" --native-file=meson-native-final.ini
  _compile_xwayland_target build-final

  if command -v llvm-bolt >/dev/null 2>&1; then
    echo "-> Stage 4: BOLT optimization..."
    local bolt_dir="$srcdir/bolt"
    mkdir -p "$bolt_dir"

    local xway_bin="$PWD/build-final/hw/xwayland/Xwayland"
    cp -f "$xway_bin" "$bolt_dir/Xwayland.orig"

    if llvm-bolt "$bolt_dir/Xwayland.orig" \
      --instrument \
      --lite=true \
      --instrumentation-file-append-pid \
      --instrumentation-file="$bolt_dir/xway.fdata" \
      -o "$bolt_dir/Xwayland.instr"; then

      echo "-> Stage 4: Running comprehensive workloads on instrumented binary..."
      if run_comprehensive_workloads "$bolt_dir/Xwayland.instr" 4; then
        local -a fdata_files=()
        shopt -s nullglob
        fdata_files=("$bolt_dir"/xway.fdata*)
        shopt -u nullglob

        if (( ${#fdata_files[@]} )); then
          if command -v merge-fdata >/dev/null 2>&1; then
            merge-fdata "${fdata_files[@]}" > "$bolt_dir/merged.fdata" 2>/dev/null || \
              cat "${fdata_files[@]}" > "$bolt_dir/merged.fdata"
          else
            cat "${fdata_files[@]}" > "$bolt_dir/merged.fdata"
          fi
        fi

        if [[ -s "$bolt_dir/merged.fdata" ]]; then
          echo "-> Applying BOLT optimizations..."
          if llvm-bolt "$bolt_dir/Xwayland.orig" \
            --data="$bolt_dir/merged.fdata" \
            --lite=true \
            --relocs \
            --hugify \
            --reorder-blocks=ext-tsp \
            --reorder-functions=cdsort \
            --split-functions --split-all-cold --split-eh \
            --x86-strip-redundant-address-size \
            --indirect-call-promotion=all \
            --split-strategy=cdsplit \
            --icf=all \
            --jump-tables=aggressive \
            --peepholes=all \
            --plt=hot \
            --dyno-stats \
            -o "$bolt_dir/Xwayland.bolt"; then

            if [[ -s "$bolt_dir/Xwayland.bolt" ]]; then
              install -m755 "$bolt_dir/Xwayland.bolt" "$xway_bin"
              echo "BOLT optimization successfully applied."
            fi
          fi
        else
          echo "Warning: no BOLT fdata was generated; keeping non-BOLT final binary."
          _dump_stage_logs 4
        fi
      else
        echo "Warning: BOLT training workload failed; keeping non-BOLT final binary."
        _dump_stage_logs 4
      fi
    else
      echo "Warning: BOLT instrumentation failed; keeping non-BOLT final binary."
    fi
  fi
}

package() {
  cd "$srcdir/xserver"
  DESTDIR="$pkgdir" _meson_env meson install -C build-final --no-rebuild

  rm -f "$pkgdir/usr/lib/xorg/protocol.txt" \
        "$pkgdir/usr/share/man/man1/Xserver.1" 2>/dev/null || true
  rmdir --ignore-fail-on-non-empty "$pkgdir/usr/lib/xorg" 2>/dev/null || true

  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
