# === GCC 2-stage-PGO REBUILD :: xorg-xwayland-git ================================
# Emergency GCC rebuild (clang 'llvm-ultimate' miscompiled the X stack: Xwayland
# SIGSEGV at 0x10 via ffi_call -> wl_display_dispatch). Toolchain pinned to
# gcc/g++ + GNU binutils; clang-only flags scrubbed. MANDATORY GCC 2-stage PGO
# (-fprofile-generate -> training -> -fprofile-use +correction). No GCC 2-stage PGO/BOLT
# (no GCC equivalent). Rename to 'PKGBUILD' before use.
# ====================================================================
# Maintainer: CachyOS <admin@cachyos.org>

pkgname=xorg-xwayland-git
pkgver=24.1.13.r0.gc5a47fda
pkgrel=1
pkgdesc='Run X clients under Wayland (GCC 2-stage PGO, stable rebuild)'
arch=('x86_64')
url='https://xorg.freedesktop.org'
license=('MIT')
groups=('xorg')
# !lto: makepkg.conf owns LTO via $CFLAGS; meson b_lto=false below keeps it deterministic.
# !debug: no -g3 spam in shipped binary (PGO accuracy independent of DWARF).
# strip ON: BOLTed binary safe to strip on modern binutils (verified by user).
options=(!lto !debug)
depends=(
  glibc libxau libxcvt libxfont2 libxshmfence libdrm libepoxy libglvnd libei
  libtirpc mesa nettle pixman systemd-libs wayland xkeyboard-config
  xorg-server-common xorg-xkbcomp
)
makedepends=(git meson ninja xorgproto xtrans libxkbfile dbus xorg-font-util wayland-protocols systemd weston mesa-utils glmark2 vulkan-tools xorg-x11perf xorg-xrandr xorg-xprop xorg-xdpyinfo xclip xdotool libx11 libxcb libxi libxext 'xorg-server-xvfb')
provides=(xorg-xwayland xorg-server-xwayland xorg-server-xwayland-git)
conflicts=(xorg-xwayland xorg-server-xwayland xorg-server-xwayland-git)
replaces=(xorg-server-xwayland-git)
source=(
  'xserver::git+https://gitlab.freedesktop.org/xorg/xserver.git#branch=xwayland-24.1'
  'ms178-1.patch'
  'ms178-2.patch'
)
# ms178-1.patch: existing ms178 gaming-tuning patch (kept as-is).
# ms178-2.patch: fixes the deterministic Xwayland SIGSEGV at address 0x10 —
#   a NULL-pointer deref in xwayland_modeinfo_from_cvt() when
#   libxcvt_gen_mode_info() returns NULL (see the patch header). prepare()
#   applies every *.patch in source-array order with `patch -Np1`, so no other
#   changes are required.
sha256sums=('SKIP' 'SKIP' 'SKIP')

# Per-stage instrumentation flags. These are the ONLY flags this PKGBUILD adds
# on top of /etc/makepkg.conf. Lessons from libx11 v2->v3 baked in:
#   * no -g3                : zero PGO accuracy gain, +80% object size
#   * no -fno-omit-fp       : mismatch with final build = silently worse PGO
#   * vp-counters-per-site=8: upstream default (Xwayland has <50 hot IC sites)
#   * -runtime-counter-relocation: required when counter section is relocated
# Xwayland is shipped PIE by upstream. BOLT can re-layout PIE, but a no-PIE
# binary gives BOLT maximum freedom (no GOT indirection on internal calls,
# RIP-relative -> direct call promotion is easier). User accepts the loss
# of ASLR on Xwayland (long-running server, ASLR remap-on-fork doesn't apply).
pkgver() {
  cd xserver
  git describe --long --tags --abbrev=8 | sed 's/^xwayland-//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd xserver
  local src
  for src in "${source[@]}"; do
    src="${src%%::*}"
    src="${src##*/}"
    [[ $src = *.patch ]] || continue
    [[ -f "$srcdir/$src" ]] || { echo "Patch $src missing, skipping"; continue; }
    echo "Applying $src"
    patch -Np1 -i "$srcdir/$src"
  done
}

# NOTE: original clang-only helper functions/arrays removed for the GCC
# rebuild; not used by the 2-stage GCC PGO build() below.

# ============================================================================
# GCC 2-stage PGO scaffold (shared preamble)  —  CachyOS xorg emergency GCC set
# ----------------------------------------------------------------------------
# WHY THIS EXISTS
#   /etc/makepkg.conf on this box points CC/CXX/*FLAGS at the clang
#   "llvm-ultimate" toolchain (clang 24 + ThinLTO/Polly/BOLT). That toolchain
#   miscompiled the X/Wayland stack (Xwayland SIGSEGV at 0x10 through
#   ffi_call -> wl_display_dispatch). These are the GCC emergency rebuilds.
#   They MUST pin GCC and MUST scrub clang-only flags, else the fix is void.
#
# WHAT IT PROVIDES
#   _gcc_pgo_init      : pin gcc/g++ + GNU binutils; sanitize inherited flags.
#   _gcc_pgo_xvfb_run  : run a training command on a private Xvfb (auto ports,
#                        robust wait, always tears the server down).
#   _gcc_pgo_merge_ok  : verify .gcda were produced (PGO is MANDATORY; the build
#                        aborts if training generated no profile).
#   Stage flags:  ${_PGO_GEN[@]}  (stage 1)   ${_PGO_USE[@]} (stage 2, needs dir)
#
#   GCC has no context-sensitive PGO and no BOLT; a clean, correct 2-stage PGO
#   (-fprofile-generate -> -fprofile-use, +correction +partial-training) is the
#   right, stable GCC equivalent. Per the GCC manual, -fprofile-correction and
#   -fprofile-partial-training make profile-use robust to multithreaded and
#   partially-covered training runs (both true here).
# ============================================================================

# Stage-1 instrumentation flags. The profile directory is passed EXPLICITLY via
# -fprofile-generate=<dir> so the .gcda live OUT of tree and survive the
# `make clean` / fresh meson dir between stage 1 and stage 2 (an in-tree default
# location would be wiped). -fprofile-update=atomic is REQUIRED: the X libraries
# and servers are multi-threaded (XCB i/o thread, input thread) and non-atomic
# counters corrupt under concurrent updates. -fprofile-generate at LINK time is
# needed so the instrumented runtime (-lgcov) is pulled in.
_gcc_pgo_gen() {  # $1 = profile dir -> stage-1 compile flags
  # -Wno-error: PGO instrumentation legitimately perturbs codegen and can trip
  # upstream -Werror=array-bounds / -Werror=maybe-uninitialized false positives
  # (e.g. libxcb's generated xinput.c). Instrumented objects are throwaway; we
  # must never let a warning promotion abort the profiling build.
  printf '%s' "-fprofile-generate=$1 -fprofile-update=atomic -Wno-error"
}
# Back-compat array (dir-less) kept for callers that set the dir themselves.
_PGO_GEN=(-fprofile-generate -fprofile-update=atomic)

_gcc_pgo_use() {  # $1 = profile dir  -> echoes stage-2 flags
  # -Wno-error for the same reason as the gen stage: -fprofile-use changes inlining
  # and block layout, which can surface new upstream -Werror= promotions on code
  # that is otherwise correct. The final objects are still fully optimized.
  printf '%s' "-fprofile-use=$1 -fprofile-correction -fprofile-partial-training -Wno-missing-profile -Wno-coverage-mismatch -Wno-error"
}

_gcc_pgo_init() {
  # These are GCC-specific rebuilds: the clang 'llvm-ultimate' toolchain
  # miscompiled the X stack (Xwayland SIGSEGV at 0x10 via ffi_call ->
  # wl_display_dispatch). Pin the GNU toolchain so the build is GCC regardless
  # of what CC/CXX /etc/makepkg.conf exports. gcc-ar/gcc-nm/gcc-ranlib are the
  # LTO-safe binutils wrappers (correct even if your makepkg.conf enables -flto).
  export CC=gcc CXX=g++
  export AR=gcc-ar NM=gcc-nm RANLIB=gcc-ranlib
  export CCACHE_DISABLE=1

  # HONOR /etc/makepkg.conf flags VERBATIM. This PKGBUILD injects ONLY the PGO
  # flags (see _gcc_pgo_gen / _gcc_pgo_use); it deliberately does NOT add
  # -march / -O / -fuse-ld / hardening / LTO — those come from your makepkg.conf.
  # NOTE: since the toolchain is pinned to GCC, your makepkg.conf CFLAGS/CXXFLAGS/
  # LDFLAGS must be GCC-compatible (no clang-only tokens such as -mllvm/-Xclang/
  # -flto=thin/-fuse-ld=lld-with-clang-plugins). That is the expected setup for a
  # GCC rebuild set.
  _ORIG_CFLAGS="${CFLAGS:-}"
  _ORIG_CXXFLAGS="${CXXFLAGS:-}"
  _ORIG_LDFLAGS="${LDFLAGS:-}"
}

# _gcc_pgo_xvfb_run <cmd...> : run cmd on a private Xvfb; returns cmd's status,
# 0 if no Xvfb/display is available (training is best-effort but profiles are
# still required — see _gcc_pgo_require).
_gcc_pgo_xvfb_run() {
  local d rc=0 xvfb_pid=""
  if ! command -v Xvfb >/dev/null 2>&1; then
    "$@"; return $?
  fi
  for d in 99 101 123 137 151; do
    [[ -e "/tmp/.X11-unix/X$d" ]] && continue
    Xvfb ":$d" -screen 0 1280x1024x24 -nolisten tcp >/dev/null 2>&1 &
    xvfb_pid=$!
    local ok=0 i
    for i in $(seq 1 80); do
      if command -v xdpyinfo >/dev/null 2>&1; then
        DISPLAY=":$d" xdpyinfo >/dev/null 2>&1 && { ok=1; break; }
      else
        kill -0 "$xvfb_pid" 2>/dev/null && { sleep 0.5; ok=1; break; }
      fi
      sleep 0.1
    done
    if (( ok )); then
      DISPLAY=":$d" "$@"; rc=$?
      kill "$xvfb_pid" 2>/dev/null; wait "$xvfb_pid" 2>/dev/null
      return $rc
    fi
    kill "$xvfb_pid" 2>/dev/null; wait "$xvfb_pid" 2>/dev/null
    xvfb_pid=""
  done
  # No Xvfb could start; run headless (some libs train without a display).
  "$@"; return $?
}

# _gcc_pgo_require <dir> : hard requirement that PGO training produced data.
_gcc_pgo_require() {
  local dir="$1" n
  n=$(find "$dir" -name '*.gcda' 2>/dev/null | wc -l)
  if (( n == 0 )); then
    echo "FATAL: PGO training produced no .gcda in $dir (PGO is mandatory)." >&2
    return 1
  fi
  echo "PGO: $n .gcda profile file(s) collected."
}

build() {
  _gcc_pgo_init
  cd "$srcdir/xserver"
  local _pgo="$srcdir/pgo-data"; rm -rf "$_pgo" build-gen build-use; mkdir -p "$_pgo"
  local common_opts=(
    --prefix /usr --wrap-mode=nofallback --buildtype=plain
    -Dipv6=true -Dxwayland_ei=socket -Dxvfb=false -Dglx=true
    -Dxdmcp=false -Dxdm-auth-1=false -Dsecure-rpc=false -Dinput_thread=auto
    -Dlisten_tcp=false -Dlisten_unix=true -Dlisten_local=true
    -Dsystemd_notify=auto -Ddpms=true -Dxf86bigfont=false -Dscreensaver=true
    -Dxres=true -Dxace=true -Dxselinux=false -Dxinerama=false -Dxcsecurity=false
    -Dxv=true -Dmitshm=true -Dsha1=libnettle -Ddri3=true -Ddrm=true
    -Dglamor=true -Dlibdecor=auto -Ddocs=false -Ddevel-docs=false -Ddocs-pdf=false
    -Dxkb_dir=/usr/share/X11/xkb -Dxkb_output_dir=/var/lib/xkb -Db_ndebug=true
    -Db_lto=false -Db_pie=true
  )
  base64 -d > "$srcdir/train_xserver.sh" <<'__TRAIN_B64__'

__TRAIN_B64__
  chmod +x "$srcdir/train_xserver.sh"

  local _gen; _gen="$(_gcc_pgo_gen "$_pgo")"
  arch-meson . build-gen "${common_opts[@]}" \
    -Dc_args="$_ORIG_CFLAGS $_gen" -Dcpp_args="$_ORIG_CXXFLAGS $_gen" \
    -Dc_link_args="$_ORIG_LDFLAGS -fprofile-generate=$_pgo" \
    -Dcpp_link_args="$_ORIG_LDFLAGS -fprofile-generate=$_pgo"
  meson compile -C build-gen hw/xwayland/Xwayland

  # --- training: exercise the instrumented Xwayland ---
  _gcc_pgo_xvfb_run bash "$srcdir/train_xserver.sh" \
     "$PWD/build-gen/hw/xwayland/Xwayland" xwayland || true
  _gcc_pgo_require "$_pgo" || return 1

  local _use; _use="$(_gcc_pgo_use "$_pgo")"
  arch-meson . build-use "${common_opts[@]}" \
    -Dc_args="$_ORIG_CFLAGS $_use" -Dcpp_args="$_ORIG_CXXFLAGS $_use" \
    -Dc_link_args="$_ORIG_LDFLAGS" -Dcpp_link_args="$_ORIG_LDFLAGS"
  meson compile -C build-use
}

package() {
  cd "$srcdir/xserver"
  DESTDIR="$pkgdir" meson install -C "$srcdir/xserver/build-use" --no-rebuild
  # xwayland-24.1 still drops these from the legacy xserver tree; clean.
  rm -f "$pkgdir/usr/lib/xorg/protocol.txt" \
        "$pkgdir/usr/share/man/man1/Xserver.1" 2>/dev/null || true
  rmdir --ignore-fail-on-non-empty "$pkgdir/usr/lib/xorg" 2>/dev/null || true
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}

# =====================================================================
# PACKAGE NAME: xorg-xwayland-git
# Rename this file to 'PKGBUILD' inside the 'xorg-xwayland-git' package directory.
# =====================================================================
