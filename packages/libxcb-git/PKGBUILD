pkgname=libxcb-git
pkgver=1.17.0.r20.g4d6e1c8
pkgrel=1
pkgdesc='X11 client-side library (PGO + GCC 2-stage PGO optimized, git version)'
arch=(i686 x86_64)
url='http://xcb.freedesktop.org'
depends=(xcb-proto-git libxdmcp libxau)
makedepends=('meson' 'xorg-server-xvfb')
conflicts=(libxcb)
provides=("libxcb=$pkgver")
license=(custom)
options=(strip)
source=('git+https://gitlab.freedesktop.org/xorg/lib/libxcb.git')
sha256sums=('SKIP')

# === GCC 2-stage-PGO REBUILD :: libxcb-git =================================
# Emergency GCC rebuild after the clang 'llvm-ultimate' toolchain miscompiled
# the X/Wayland stack (Xwayland SIGSEGV at 0x10 via ffi_call ->
# wl_display_dispatch, crash4.txt). Toolchain pinned to gcc/g++ + GNU binutils;
# inherited clang-only flags scrubbed (_gcc_pgo_init). MANDATORY GCC 2-stage
# PGO: -fprofile-generate  ->  representative training workload (run headless on
# a private Xvfb)  ->  -fprofile-use (+ -fprofile-correction
# -fprofile-partial-training). No GCC 2-stage PGO / BOLT: GCC has no equivalent; a clean
# 2-stage PGO is the correct, stable GCC path. If training yields no profile the
# build ABORTS (PGO is required). Rename this file to 'PKGBUILD' before use.
# =====================================================================


# ============================================================================
# GCC 2-stage PGO scaffold (shared preamble)  —  CachyOS xorg emergency GCC set
# ----------------------------------------------------------------------------
# WHY THIS EXISTS
#   /etc/makepkg.conf on this box points CC/CXX/*FLAGS at the clang
#   "llvm-ultimate" toolchain (clang 24 + ThinLTO/Polly/BOLT). That toolchain
#   miscompiled the X/Wayland stack (Xwayland SIGSEGV at 0x10 through
#   ffi_call -> wl_display_dispatch). These are the GCC emergency rebuilds.
#   They MUST pin GCC and MUST scrub clang-only flags, else the fix is void.
#
# WHAT IT PROVIDES
#   _gcc_pgo_init      : pin gcc/g++ + GNU binutils; sanitize inherited flags.
#   _gcc_pgo_xvfb_run  : run a training command on a private Xvfb (auto ports,
#                        robust wait, always tears the server down).
#   _gcc_pgo_merge_ok  : verify .gcda were produced (PGO is MANDATORY; the build
#                        aborts if training generated no profile).
#   Stage flags:  ${_PGO_GEN[@]}  (stage 1)   ${_PGO_USE[@]} (stage 2, needs dir)
#
#   GCC has no context-sensitive PGO and no BOLT; a clean, correct 2-stage PGO
#   (-fprofile-generate -> -fprofile-use, +correction +partial-training) is the
#   right, stable GCC equivalent. Per the GCC manual, -fprofile-correction and
#   -fprofile-partial-training make profile-use robust to multithreaded and
#   partially-covered training runs (both true here).
# ============================================================================

# Stage-1 instrumentation flags. The profile directory is passed EXPLICITLY via
# -fprofile-generate=<dir> so the .gcda live OUT of tree and survive the
# `make clean` / fresh meson dir between stage 1 and stage 2 (an in-tree default
# location would be wiped). -fprofile-update=atomic is REQUIRED: the X libraries
# and servers are multi-threaded (XCB i/o thread, input thread) and non-atomic
# counters corrupt under concurrent updates. -fprofile-generate at LINK time is
# needed so the instrumented runtime (-lgcov) is pulled in.
_gcc_pgo_gen() {  # $1 = profile dir -> stage-1 compile flags
  # -Wno-error: PGO instrumentation legitimately perturbs codegen and can trip
  # upstream -Werror=array-bounds / -Werror=maybe-uninitialized false positives
  # (e.g. libxcb's generated xinput.c). Instrumented objects are throwaway; we
  # must never let a warning promotion abort the profiling build.
  printf '%s' "-fprofile-generate=$1 -fprofile-update=atomic -Wno-error"
}
# Back-compat array (dir-less) kept for callers that set the dir themselves.
_PGO_GEN=(-fprofile-generate -fprofile-update=atomic)

_gcc_pgo_use() {  # $1 = profile dir  -> echoes stage-2 flags
  # -Wno-error for the same reason as the gen stage: -fprofile-use changes inlining
  # and block layout, which can surface new upstream -Werror= promotions on code
  # that is otherwise correct. The final objects are still fully optimized.
  printf '%s' "-fprofile-use=$1 -fprofile-correction -fprofile-partial-training -Wno-missing-profile -Wno-coverage-mismatch -Wno-error"
}

_gcc_pgo_init() {
  # These are GCC-specific rebuilds: the clang 'llvm-ultimate' toolchain
  # miscompiled the X stack (Xwayland SIGSEGV at 0x10 via ffi_call ->
  # wl_display_dispatch). Pin the GNU toolchain so the build is GCC regardless
  # of what CC/CXX /etc/makepkg.conf exports. gcc-ar/gcc-nm/gcc-ranlib are the
  # LTO-safe binutils wrappers (correct even if your makepkg.conf enables -flto).
  export CC=gcc CXX=g++
  export AR=gcc-ar NM=gcc-nm RANLIB=gcc-ranlib
  export CCACHE_DISABLE=1

  # HONOR /etc/makepkg.conf flags VERBATIM. This PKGBUILD injects ONLY the PGO
  # flags (see _gcc_pgo_gen / _gcc_pgo_use); it deliberately does NOT add
  # -march / -O / -fuse-ld / hardening / LTO — those come from your makepkg.conf.
  # NOTE: since the toolchain is pinned to GCC, your makepkg.conf CFLAGS/CXXFLAGS/
  # LDFLAGS must be GCC-compatible (no clang-only tokens such as -mllvm/-Xclang/
  # -flto=thin/-fuse-ld=lld-with-clang-plugins). That is the expected setup for a
  # GCC rebuild set.
  _ORIG_CFLAGS="${CFLAGS:-}"
  _ORIG_CXXFLAGS="${CXXFLAGS:-}"
  _ORIG_LDFLAGS="${LDFLAGS:-}"
}

# _gcc_pgo_xvfb_run <cmd...> : run cmd on a private Xvfb; returns cmd's status,
# 0 if no Xvfb/display is available (training is best-effort but profiles are
# still required — see _gcc_pgo_require).
_gcc_pgo_xvfb_run() {
  local d rc=0 xvfb_pid=""
  if ! command -v Xvfb >/dev/null 2>&1; then
    "$@"; return $?
  fi
  for d in 99 101 123 137 151; do
    [[ -e "/tmp/.X11-unix/X$d" ]] && continue
    Xvfb ":$d" -screen 0 1280x1024x24 -nolisten tcp >/dev/null 2>&1 &
    xvfb_pid=$!
    local ok=0 i
    for i in $(seq 1 80); do
      if command -v xdpyinfo >/dev/null 2>&1; then
        DISPLAY=":$d" xdpyinfo >/dev/null 2>&1 && { ok=1; break; }
      else
        kill -0 "$xvfb_pid" 2>/dev/null && { sleep 0.5; ok=1; break; }
      fi
      sleep 0.1
    done
    if (( ok )); then
      DISPLAY=":$d" "$@"; rc=$?
      kill "$xvfb_pid" 2>/dev/null; wait "$xvfb_pid" 2>/dev/null
      return $rc
    fi
    kill "$xvfb_pid" 2>/dev/null; wait "$xvfb_pid" 2>/dev/null
    xvfb_pid=""
  done
  # No Xvfb could start; run headless (some libs train without a display).
  "$@"; return $?
}

# _gcc_pgo_require <dir> : hard requirement that PGO training produced data.
_gcc_pgo_require() {
  local dir="$1" n
  n=$(find "$dir" -name '*.gcda' 2>/dev/null | wc -l)
  if (( n == 0 )); then
    echo "FATAL: PGO training produced no .gcda in $dir (PGO is mandatory)." >&2
    return 1
  fi
  echo "PGO: $n .gcda profile file(s) collected."
}

pkgver() {
  cd "$srcdir/${pkgname%-*}" || return 1
  git describe --tags | sed 's/libxcb-//;s/-/.r/;s/-/./g'
}

prepare() {
  cd "$srcdir/${pkgname%-*}" || return 1

  cat > "$srcdir/xcb_workload.c" <<'EOF'
#include <xcb/xcb.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

/* Tuned for ~3s wall time at zero pacing: pure libxcb-path coverage. */
#define WORKLOAD_FRAMES        300
#define RECTS_PER_FRAME         64
#define INPUT_BURST_EVERY        5
#define INPUT_BURST_SIZE        16
#define WINDOW_W              1280
#define WINDOW_H               720

static const char *EXTENSIONS[] = {
    "RANDR",  "Present", "GLX",     "XFIXES", "XInputExtension",
    "XKEYBOARD", "DAMAGE", "MIT-SHM", "RENDER", "Composite",
    "DPMS",   "XINERAMA", "Xv",     "DOUBLE-BUFFER",
};
#define EXT_COUNT (sizeof(EXTENSIONS) / sizeof(EXTENSIONS[0]))

typedef struct { int16_t x, y; uint16_t w, h; uint32_t color; } Rect;

static void init_rects(Rect *r, int n) {
    for (int i = 0; i < n; ++i) {
        r[i].x     = (int16_t)(rand() % WINDOW_W);
        r[i].y     = (int16_t)(rand() % WINDOW_H);
        r[i].w     = (uint16_t)(20 + rand() % 100);
        r[i].h     = (uint16_t)(20 + rand() % 100);
        r[i].color = (uint32_t)(rand() & 0xFFFFFF);
    }
}

static void step_rects(Rect *r, int n) {
    for (int i = 0; i < n; ++i) {
        r[i].x = (int16_t)((r[i].x + (rand() % 11 - 5) + WINDOW_W) % WINDOW_W);
        r[i].y = (int16_t)((r[i].y + (rand() % 11 - 5) + WINDOW_H) % WINDOW_H);
    }
}

/* Cookie-based extension query exercises libxcb's synchronous wire path. */
static int query_extension(xcb_connection_t *c, const char *name) {
    xcb_query_extension_cookie_t k =
        xcb_query_extension(c, (uint16_t)strlen(name), name);
    xcb_query_extension_reply_t *r = xcb_query_extension_reply(c, k, NULL);
    int present = r && r->present;
    free(r);
    return present;
}

/* Synthetic event burst — exercises xcb_send_event() and the
 * sequence-number bookkeeping that wraps it. */
static void inject_input(xcb_connection_t *c, xcb_window_t w, int n) {
    for (int i = 0; i < n; ++i) {
        if (i % 2 == 0) {
            xcb_key_press_event_t e = {
                .response_type = (uint8_t)((i % 4 == 0) ? XCB_KEY_PRESS
                                                        : XCB_KEY_RELEASE),
                .detail = (xcb_keycode_t)(30 + (i % 4)),
                .time   = XCB_CURRENT_TIME,
                .event  = w,
                .event_x = (int16_t)(rand() % WINDOW_W),
                .event_y = (int16_t)(rand() % WINDOW_H),
                .same_screen = 1,
            };
            xcb_send_event(c, 0, w,
                XCB_EVENT_MASK_KEY_PRESS | XCB_EVENT_MASK_KEY_RELEASE,
                (const char *)&e);
        } else {
            xcb_motion_notify_event_t e = {
                .response_type = XCB_MOTION_NOTIFY,
                .time          = XCB_CURRENT_TIME,
                .event         = w,
                .event_x       = (int16_t)(rand() % WINDOW_W),
                .event_y       = (int16_t)(rand() % WINDOW_H),
                .same_screen   = 1,
            };
            xcb_send_event(c, 0, w, XCB_EVENT_MASK_POINTER_MOTION,
                           (const char *)&e);
        }
    }
    xcb_flush(c);
}

int main(void) {
    /* Deterministic seed — stable profile across PGO runs. */
    srand(0xC0FFEE);

    int screen_num = 0;
    xcb_connection_t *c = xcb_connect(NULL, &screen_num);
    if (xcb_connection_has_error(c)) {
        fprintf(stderr, "[workload] cannot connect to X (DISPLAY=%s)\n",
                getenv("DISPLAY") ? getenv("DISPLAY") : "(unset)");
        return 1;
    }

    /* Exercise extension-query path against a wide set of names. */
    for (size_t i = 0; i < EXT_COUNT; ++i)
        (void)query_extension(c, EXTENSIONS[i]);

    const xcb_setup_t *setup = xcb_get_setup(c);
    xcb_screen_iterator_t it = xcb_setup_roots_iterator(setup);
    for (int i = 0; i < screen_num; ++i) xcb_screen_next(&it);
    xcb_screen_t *screen = it.data;
    if (!screen) { xcb_disconnect(c); return 1; }

    xcb_window_t win = xcb_generate_id(c);
    uint32_t mask = XCB_CW_BACK_PIXEL | XCB_CW_EVENT_MASK;
    uint32_t vals[2] = {
        screen->black_pixel,
        XCB_EVENT_MASK_EXPOSURE        | XCB_EVENT_MASK_BUTTON_PRESS    |
        XCB_EVENT_MASK_BUTTON_RELEASE  | XCB_EVENT_MASK_POINTER_MOTION  |
        XCB_EVENT_MASK_KEY_PRESS       | XCB_EVENT_MASK_KEY_RELEASE     |
        XCB_EVENT_MASK_STRUCTURE_NOTIFY,
    };
    xcb_create_window(c, XCB_COPY_FROM_PARENT, win, screen->root,
                      0, 0, WINDOW_W, WINDOW_H, 0,
                      XCB_WINDOW_CLASS_INPUT_OUTPUT, screen->root_visual,
                      mask, vals);

    /* Window-property roundtrip exercises ChangeProperty + intern-atom paths
     * libxcb is asked about by every real X11 client at startup. */
    const char title[] = "xcb-pgo-workload";
    xcb_change_property(c, XCB_PROP_MODE_REPLACE, win,
                        XCB_ATOM_WM_NAME, XCB_ATOM_STRING, 8,
                        (uint32_t)(sizeof(title) - 1), title);

    xcb_gcontext_t gc = xcb_generate_id(c);
    uint32_t gc_mask = XCB_GC_FOREGROUND | XCB_GC_GRAPHICS_EXPOSURES;
    uint32_t gc_vals[2] = { screen->white_pixel, 0 };
    xcb_create_gc(c, gc, win, gc_mask, gc_vals);

    xcb_map_window(c, win);
    xcb_flush(c);

    Rect rects[RECTS_PER_FRAME];
    init_rects(rects, RECTS_PER_FRAME);

    /* Main loop — no usleep(), the workload is CPU-bound on libxcb itself.
     * For PGO we want maximum call-site coverage per second, not realtime. */
    for (int f = 0; f < WORKLOAD_FRAMES &&
                    !xcb_connection_has_error(c); ++f) {
        /* Drain events with xcb_poll_for_event (the async path). */
        xcb_generic_event_t *e;
        while ((e = xcb_poll_for_event(c)) != NULL) {
            switch (e->response_type & ~0x80u) {
                case XCB_EXPOSE:
                case XCB_BUTTON_PRESS:
                case XCB_BUTTON_RELEASE:
                case XCB_MOTION_NOTIFY:
                case XCB_KEY_PRESS:
                case XCB_KEY_RELEASE:
                case XCB_CONFIGURE_NOTIFY:
                    break;
            }
            free(e);
        }

        step_rects(rects, RECTS_PER_FRAME);

        /* One big batch of GC-change + fill-rect requests — the typical
         * 2D-clear-and-redraw pattern of any X11 client. */
        for (int i = 0; i < RECTS_PER_FRAME; ++i) {
            xcb_change_gc(c, gc, XCB_GC_FOREGROUND, &rects[i].color);
            xcb_rectangle_t r = { rects[i].x, rects[i].y,
                                  rects[i].w, rects[i].h };
            xcb_poly_fill_rectangle(c, win, gc, 1, &r);
        }

        if (f % INPUT_BURST_EVERY == 0)
            inject_input(c, win, INPUT_BURST_SIZE);

        xcb_flush(c);

        /* Round-trip via xcb_get_geometry every ~30 frames — exercises the
         * reply-matching hot path that real clients hit on resize. */
        if (f % 30 == 0) {
            xcb_get_geometry_cookie_t gk = xcb_get_geometry(c, win);
            xcb_get_geometry_reply_t *gr = xcb_get_geometry_reply(c, gk, NULL);
            free(gr);
        }
    }

    xcb_free_gc(c, gc);
    xcb_destroy_window(c, win);
    xcb_disconnect(c);
    return 0;
}
EOF

  autoreconf -vfi
}


build() {
  _gcc_pgo_init
  local _src="$srcdir/${pkgname%-*}"
  local _pgo="$srcdir/pgo-data"
  rm -rf "$_pgo"; mkdir -p "$_pgo"

  # --- write the embedded training workload -------------------------------
  base64 -d > "$srcdir/wl_libxcb.c" <<'__WL_B64__'

__WL_B64__

  # ---- STAGE 1: instrumented build --------------------------------------
  cd "$_src"
  autoreconf -vfi
  ./configure --prefix=/usr --enable-xinput --enable-xkb --with-doxygen=no --disable-devel-docs --disable-unit-tests --disable-static --disable-selective-werror
  local _gen; _gen="$(_gcc_pgo_gen "$_pgo")"
  make -j"$(nproc)" \
    CFLAGS="$_ORIG_CFLAGS $_gen" \
    CXXFLAGS="$_ORIG_CXXFLAGS $_gen" \
    LDFLAGS="$_ORIG_LDFLAGS -fprofile-generate=$_pgo"

  # ---- STAGE 1 training: build the workload against the in-tree lib ------
  _train() {
    local wlbin="$srcdir/wl_libxcb.runner"
    # Bind the trainer to the freshly-built INSTRUMENTED lib. Use the top-level
    # libtool archive (NOT the internal .libs/*.la copy) so libtool resolves the
    # in-tree .so and emits a wrapper that sets the right rpath automatically.
    local la
    # Pick the MAIN library archive (libxcb.la), not the first .la found
    # (libx11 etc. ship many helper/module .la files; the alphabetically-first
    # is wrong and would leave the real library untrained). Fall back to the
    # largest top-level .la if the exact name is not present.
    la="$(find "$_src" -name 'libxcb.la' -not -path '*/.libs/*' | head -1)"
    if [[ -z "$la" ]]; then
      la="$(find "$_src" -maxdepth 3 -name '*.la' -not -path '*/.libs/*' -printf '%s %p\n' \
            | sort -rn | head -1 | cut -d' ' -f2-)"
    fi
    if [[ -n "$la" && -x ./libtool ]]; then
      if ! CFLAGS="$_ORIG_CFLAGS" ./libtool --tag=CC --mode=link "$CC" \
             "$srcdir/wl_libxcb.c" -o "$wlbin" \
             -I"$_src/include" -I"$_src" "$la" ; then
        echo "warn: trainer libtool-link failed; skipping training" >&2
        return 0
      fi
    else
      local sodir
      sodir="$(find "$_src" -name 'libxcb*.so*' -printf '%h\n' 2>/dev/null | head -1)"
      [[ -z "$sodir" ]] && sodir="$_src/src/.libs"
      if ! "$CC" $_ORIG_CFLAGS "$srcdir/wl_libxcb.c" -o "$wlbin" \
             -lxcb -L"$sodir" -Wl,-rpath,"$sodir"; then
        echo "warn: trainer link failed; skipping training" >&2
        return 0
      fi
    fi
    _gcc_pgo_xvfb_run "$wlbin" || true
    rm -f "$wlbin"
  }
  _train

  _gcc_pgo_require "$_pgo" || return 1

  # ---- STAGE 2: profile-use rebuild -------------------------------------
  make clean
  local _use; _use="$(_gcc_pgo_use "$_pgo")"
  make -j"$(nproc)" \
    CFLAGS="$_ORIG_CFLAGS $_use" \
    CXXFLAGS="$_ORIG_CXXFLAGS $_use" \
    LDFLAGS="$_ORIG_LDFLAGS"
}

package() {
  cd "$srcdir/${pkgname%-*}" || return 1
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}

# =====================================================================
