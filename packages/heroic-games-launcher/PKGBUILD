pkgname=heroic-games-launcher
_pkgver=2.21.0
pkgver=2.21.0
pkgrel=8.1
pkgdesc='A Native GOG and Epic Games Launcher for Linux (built from source)'
arch=(x86_64)
url='https://heroicgameslauncher.com/'
license=(GPL3)
depends=(alsa-lib gtk3 nss)
makedepends=(git pnpm nodejs clang jq)
options=(!debug)
source=("git+https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher.git")
sha256sums=('SKIP')

prepare() {
  cd "HeroicGamesLauncher"

  # Force hoisted node_modules so electron-builder can pack all transitive
  # deps into the asar (pnpm's default symlink layout breaks this).
  cat > .npmrc << 'EOF'
shamefully-hoist=true
node-linker=hoisted
EOF

  # Patch package.json:
  # - Override node-addon-api for newer Node compatibility
  # - Remove deprecated 'unimported' (dev-only linter, not needed for build)
  # - Upgrade @fortawesome/react-fontawesome to v0.3 (v0.2 is deprecated)
  # - Pin electron-builder to 26.8.1
  # - Add @electron/asar for post-build asar verification
  # - Allow unused patch entries without fatal error
  # - Suppress harmless peer-dep mismatches: dmg-builder and
  #   squirrel-windows are macOS/Windows-only, irrelevant on Linux
  msg "Patching package.json..."
  jq '
    .pnpm.overrides."node-addon-api" = "8.0.0" |
    del(.devDependencies.unimported) |
    .devDependencies["@fortawesome/react-fontawesome"] = "^0.3.0" |
    .devDependencies["electron-builder"] = "26.8.1" |
    .devDependencies["@electron/asar"] = "^4.2.0" |
    .pnpm.allowUnusedPatches = true |
    .pnpm.peerDependencyRules.allowedVersions."electron-builder-squirrel-windows" = "24" |
    .pnpm.peerDependencyRules.allowedVersions."dmg-builder" = "26"
  ' package.json > package.json.tmp
  mv package.json.tmp package.json

  msg "Installing dependencies..."
  pnpm install --no-frozen-lockfile
}

build() {
  cd "HeroicGamesLauncher"

  msg "Step 1/3: Downloading helper binaries..."
  pnpm run download-helper-binaries

  # Remove all darwin/arm64/aarch32 binaries. Uses both -path (catches files
  # inside arch-named directories, e.g. arm64/linux/comet) and -name (catches
  # files with the arch in their filename, e.g. legendary_macOS_x86_64).
  msg "Cleaning unwanted platform binaries..."
  find build/bin -type f \( \
    -path '*/darwin/*' -o \
    -path '*/macOS/*'   -o \
    -path '*/arm64/*'   -o \
    -path '*/aarch64/*' -o \
    -name '*macOS*'     -o \
    -name '*darwin*'    -o \
    -name '*arm64*'     -o \
    -name '*aarch64*'   \
  \) -delete 2>/dev/null || true
  find build/bin -type d -empty -delete 2>/dev/null || true

  msg "Step 2/3: Compiling application source..."
  pnpm exec electron-vite build

  msg "Step 3/3: Packaging into a native directory..."
  pnpm exec electron-builder --linux dir

  # Post-build asar verification & repair
  msg "Verifying asar contents..."
  local _asar="dist/linux-unpacked/resources/app.asar"
  local _required_modules=(ms debug builder-util-runtime electron-updater)
  local _missing=()

  for _mod in "${_required_modules[@]}"; do
    if ! pnpm exec asar list "${_asar}" 2>/dev/null | grep -q "/node_modules/${_mod}/"; then
      _missing+=("${_mod}")
    fi
  done

  if [[ ${#_missing[@]} -gt 0 ]]; then
    warning "Modules missing from asar: ${_missing[*]}"
    msg "Injecting from local node_modules..."

    local _tmpdir
    _tmpdir=$(mktemp -d)

    pnpm exec asar extract "${_asar}" "${_tmpdir}"

    mkdir -p "${_tmpdir}/node_modules"
    for _mod in "${_missing[@]}"; do
      if [[ -d "node_modules/${_mod}" ]]; then
        cp -r "node_modules/${_mod}" "${_tmpdir}/node_modules/"
        msg2 "Injected: ${_mod}"
      else
        error "Cannot find ${_mod} in node_modules — package would crash at runtime"
        rm -rf "${_tmpdir}"
        return 1
      fi
    done

    pnpm exec asar pack "${_tmpdir}" "${_asar}"
    rm -rf "${_tmpdir}"

    msg "Injection complete."
  else
    msg "All critical modules present in asar."
  fi
}

package() {
  cd "HeroicGamesLauncher"

  msg "Copying helper binaries into final artifact..."
  install -d dist/linux-unpacked/resources/app.asar.unpacked/build
  cp -r build/bin dist/linux-unpacked/resources/app.asar.unpacked/build/

  install -d "${pkgdir}/opt/heroic"
  cp -r dist/linux-unpacked/* "${pkgdir}/opt/heroic"

  # Final belt-and-suspenders cleanup: remove any darwin/arm64/aarch64
  # binaries that may have leaked through.  Uses -path to catch files
  # inside arch-named directories AND -name to catch files with the
  # arch string in their filename.
  find "${pkgdir}/opt/heroic" -type f \( \
    -path '*/darwin/*' -o \
    -path '*/macOS/*'   -o \
    -path '*/arm64/*'   -o \
    -path '*/aarch64/*' -o \
    -name '*macOS*'     -o \
    -name '*darwin*'    -o \
    -name '*arm64*'     -o \
    -name '*aarch64*'   \
  \) -delete 2>/dev/null || true
  find "${pkgdir}/opt/heroic" -type d -empty -delete 2>/dev/null || true

  install -d "${pkgdir}/usr/bin"
  ln -s /opt/heroic/heroic "${pkgdir}/usr/bin/heroic-games-launcher"

  install -Dm644 "public/icon.png" "${pkgdir}/usr/share/pixmaps/heroic.png"

  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/heroic.desktop" << 'EOF'
[Desktop Entry]
Name=Heroic Games Launcher
Exec=heroic-games-launcher %U
Terminal=false
Type=Application
Icon=heroic
StartupWMClass=Heroic
Comment=Open-source GOG and Epic Games launcher
MimeType=x-scheme-handler/heroic;
Categories=Game;
EOF
}
