pkgname=heroic-games-launcher
_pkgver=2.20.1
pkgver=2.20.1
pkgrel=5
pkgdesc='A Native GOG and Epic Games Launcher for Linux (built from source)'
arch=(x86_64)
url='https://heroicgameslauncher.com/'
license=(GPL3)
depends=(alsa-lib gtk3 nss)
makedepends=(git pnpm nodejs clang jq)
options=(!debug)
source=("git+https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher.git#tag=v${_pkgver}")
sha256sums=('SKIP')

prepare() {
  cd "HeroicGamesLauncher"

  # ── Fix 1: Force hoisted node_modules ──
  # pnpm's default symlink-based store breaks electron-builder's asar
  # packing — transitive deps silently vanish from the archive.
  cat > .npmrc << 'EOF'
shamefully-hoist=true
node-linker=hoisted
EOF

  # ── Fix 2: Patch package.json ──
  msg "Patching package.json..."
  jq '
    .pnpm.overrides."node-addon-api" = "8.0.0" |
    .pnpm.allowUnusedPatches = true
  ' package.json > package.json.tmp
  mv package.json.tmp package.json

  # ── Install dependencies ──
  msg "Installing dependencies..."
  pnpm install --no-frozen-lockfile

  # electron-builder for packaging + @electron/asar for verification/repair
  pnpm add -Dw electron-builder@26.8.1 @electron/asar
}

build() {
  cd "HeroicGamesLauncher"

  msg "Step 1/3: Downloading helper binaries (Legendary, gogdl, etc.)..."
  pnpm run download-helper-binaries

  msg "Step 2/3: Compiling application source..."
  pnpm exec electron-vite build

  msg "Step 3/3: Packaging into a native directory..."
  pnpm exec electron-builder --linux dir

  # ── Post-build asar verification & repair ──
  # electron-builder's pnpm dep resolution is known to miss transitive
  # production dependencies. Verify and inject from our local (hoisted)
  # node_modules if anything is missing.
  msg "Verifying asar contents..."
  local _asar="dist/linux-unpacked/resources/app.asar"
  local _required_modules=(ms debug builder-util-runtime electron-updater)
  local _missing=()

  for _mod in "${_required_modules[@]}"; do
    if ! pnpm exec asar list "${_asar}" 2>/dev/null | grep -q "/node_modules/${_mod}/"; then
      _missing+=("${_mod}")
    fi
  done

  if [[ ${#_missing[@]} -gt 0 ]]; then
    warning "Modules missing from asar: ${_missing[*]}"
    msg "Injecting from local node_modules..."

    local _tmpdir
    _tmpdir=$(mktemp -d)

    pnpm exec asar extract "${_asar}" "${_tmpdir}"

    mkdir -p "${_tmpdir}/node_modules"
    for _mod in "${_missing[@]}"; do
      if [[ -d "node_modules/${_mod}" ]]; then
        cp -r "node_modules/${_mod}" "${_tmpdir}/node_modules/"
        msg2 "Injected: ${_mod}"
      else
        error "Cannot find ${_mod} in node_modules — package would crash at runtime"
        rm -rf "${_tmpdir}"
        return 1
      fi
    done

    pnpm exec asar pack "${_tmpdir}" "${_asar}"
    rm -rf "${_tmpdir}"

    msg "Injection complete."
  else
    msg "All critical modules present in asar."
  fi
}

package() {
  cd "HeroicGamesLauncher"

  # electron-builder does NOT package the helper binaries (Legendary,
  # gogdl, nile, comet). Copy them into the unpacked resources.
  msg "Copying helper binaries into final artifact..."
  install -d dist/linux-unpacked/resources/app.asar.unpacked/build
  cp -r build/bin dist/linux-unpacked/resources/app.asar.unpacked/build/

  # Application files
  install -d "${pkgdir}/opt/heroic"
  cp -r dist/linux-unpacked/* "${pkgdir}/opt/heroic"

  # Wrapper in PATH
  install -d "${pkgdir}/usr/bin"
  ln -s /opt/heroic/heroic "${pkgdir}/usr/bin/heroic-games-launcher"

  # Icon
  install -Dm644 "public/icon.png" "${pkgdir}/usr/share/pixmaps/heroic.png"

  # Desktop entry
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/heroic.desktop" << 'EOF'
[Desktop Entry]
Name=Heroic Games Launcher
Exec=heroic-games-launcher %U
Terminal=false
Type=Application
Icon=heroic
StartupWMClass=Heroic
Comment=Open-source GOG and Epic Games launcher
MimeType=x-scheme-handler/heroic;
Categories=Game;
EOF
}
