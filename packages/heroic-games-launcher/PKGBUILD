# Maintainer: CachyOS Team <team@cachyos.org>
# Contributor: Super-Genius Package Maintainer (Arena.ai optimized) - v25 (ajv ecosystem fix)

pkgname=heroic-games-launcher
_pkgver=2.22.0
pkgver=2.22.0
pkgrel=33
pkgdesc='A Native GOG and Epic Games Launcher for Linux (built from source)'
arch=(x86_64)
url='https://heroicgameslauncher.com/'
license=(GPL-3.0-or-later)
depends=(alsa-lib gtk3 nss)
makedepends=(git pnpm nodejs clang jq)
options=(!debug)

source=("git+https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher.git#tag=v${_pkgver}")
sha256sums=('SKIP')

prepare() {
  cd "HeroicGamesLauncher"

  cat > .npmrc << 'EOF'
shamefully-hoist=true
node-linker=hoisted
strict-peer-dependencies=false
auto-install-peers=true
allow-unused-patches=true
resolution-mode=highest
EOF

  msg "Patching package.json (v25 - strong ajv ecosystem handling)..."

  sed -i 's|"@fortawesome/react-fontawesome": "\^0\.2\.[0-9]*"|"@fortawesome/react-fontawesome": "3.3.1"|' package.json

  jq '
    .overrides = {
      "yocto-queue": "^1.1.1",
      "p-limit": "^6.2.0",
      "node-addon-api": "8.0.0",
      "uri-js": "^4.4.1",
      "ajv": "^8.17.1",
      "ajv-formats": "^3.0.1",
      "fast-json-stable-stringify": "^2.1.0",

      "@fortawesome/react-fontawesome": "3.3.1",
      "@fortawesome/fontawesome-svg-core": "6.7.2",
      "@fortawesome/free-solid-svg-icons": "6.7.2",
      "@fortawesome/free-brands-svg-icons": "6.7.2",

      "@xmldom/xmldom": "^0.9.8",
      "boolean": "^3.2.0",
      "glob": "^11.0.1",
      "inflight": "^1.0.6",
      "lodash.isequal": "^4.5.0",
      "tar": "^7.4.3",
      "whatwg-encoding": "^3.1.1",
      "rimraf": "^6.0.1"
    } |

    .dependencies["yocto-queue"] = "^1.1.1" |
    .dependencies["uri-js"] = "^4.4.1" |
    .dependencies["ajv"] = "^8.17.1" |
    .dependencies["ajv-formats"] = "^3.0.1" |
    .dependencies["fast-json-stable-stringify"] = "^2.1.0" |

    .devDependencies["@fortawesome/react-fontawesome"] = "3.3.1" |
    .devDependencies["@fortawesome/fontawesome-svg-core"] = "6.7.2" |
    .devDependencies["@fortawesome/free-solid-svg-icons"] = "6.7.2" |
    .devDependencies["@fortawesome/free-brands-svg-icons"] = "6.7.2" |

    .devDependencies["electron-builder"] = "26.15.6" |
    .devDependencies["@electron/asar"] = "^4.2.0" |

    del(.devDependencies["i18next-parser"]) |
    del(.devDependencies.unimported) |
    del(.pnpm)
  ' package.json > package.json.tmp && mv package.json.tmp package.json

  msg "Installing dependencies..."
  pnpm install --no-frozen-lockfile

  msg "Forcing correct Font Awesome packages..."
  rm -rf node_modules/@fortawesome/react-fontawesome
  pnpm add -D @fortawesome/react-fontawesome@3.3.1 --ignore-scripts --force

  pnpm add -D \
    @fortawesome/fontawesome-svg-core@6.7.2 \
    @fortawesome/free-solid-svg-icons@6.7.2 \
    @fortawesome/free-brands-svg-icons@6.7.2 \
    --ignore-scripts --force
}

build() {
  cd "HeroicGamesLauncher"

  msg "Step 1/3: Downloading helper binaries..."
  pnpm run download-helper-binaries

  msg "Cleaning unwanted platform binaries..."
  find build/bin -type f \( \
    -path '*/darwin/*' -o \
    -path '*/macOS/*'   -o \
    -path '*/arm64/*'   -o \
    -path '*/aarch64/*' -o \
    -name '*macOS*'     -o \
    -name '*darwin*'    -o \
    -name '*arm64*'     -o \
    -name '*aarch64*'   \
  \) -delete 2>/dev/null || true
  find build/bin -type d -empty -delete 2>/dev/null || true

  msg "Step 2/3: Compiling application source..."
  pnpm exec electron-vite build

  msg "Step 3/3: Packaging into a native directory..."
  pnpm exec electron-builder --linux dir

  # =====================================================================
  # STRONG AJV ECOSYSTEM ASAR REPAIR (v25)
  # =====================================================================
  msg "Verifying and repairing asar contents (ajv ecosystem focus)..."

  local _asar="dist/linux-unpacked/resources/app.asar"
  local _tmpdir
  _tmpdir=$(mktemp -d)

  pnpm exec asar extract "${_asar}" "${_tmpdir}" 2>/dev/null || true

  # Prioritize ajv ecosystem
  local required_modules=(
    ajv
    ajv-formats
    yocto-queue
    p-limit
    p-locate
    locate-path
    find-up
    pkg-up
    conf
    electron-store
    uri-js
    fast-json-stable-stringify
    ms
    debug
    builder-util-runtime
    electron-updater
  )

  local missing=()
  for mod in "${required_modules[@]}"; do
    if [[ ! -d "${_tmpdir}/node_modules/${mod}" ]]; then
      missing+=("${mod}")
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    warning "Modules missing from asar: ${missing[*]}"
    msg "Injecting missing modules..."

    mkdir -p "${_tmpdir}/node_modules"

    for mod in "${missing[@]}"; do
      if [[ -d "node_modules/${mod}" ]]; then
        cp -r "node_modules/${mod}" "${_tmpdir}/node_modules/"
        msg2 "Injected: ${mod}"
      else
        error "Cannot find ${mod} in node_modules"
        rm -rf "${_tmpdir}"
        return 1
      fi
    done

    pnpm exec asar pack "${_tmpdir}" "${_asar}"
    msg "Asar repair complete."
  else
    msg "All critical modules present in asar."
  fi

  rm -rf "${_tmpdir}"
}

package() {
  cd "HeroicGamesLauncher"

  msg "Copying helper binaries into final artifact..."
  install -d dist/linux-unpacked/resources/app.asar.unpacked/build
  cp -r build/bin dist/linux-unpacked/resources/app.asar.unpacked/build/

  install -d "${pkgdir}/opt/heroic"
  cp -r dist/linux-unpacked/* "${pkgdir}/opt/heroic"

  find "${pkgdir}/opt/heroic" -type f \( \
    -path '*/darwin/*' -o \
    -path '*/macOS/*'   -o \
    -path '*/arm64/*'   -o \
    -path '*/aarch64/*' -o \
    -name '*macOS*'     -o \
    -name '*darwin*'    -o \
    -name '*arm64*'     -o \
    -name '*aarch64*'   \
  \) -delete 2>/dev/null || true
  find "${pkgdir}/opt/heroic" -type d -empty -delete 2>/dev/null || true

  install -d "${pkgdir}/usr/bin"
  ln -s /opt/heroic/heroic "${pkgdir}/usr/bin/heroic-games-launcher"

  install -Dm644 "public/icon.png" "${pkgdir}/usr/share/pixmaps/heroic.png"

  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/heroic.desktop" << 'EOF'
[Desktop Entry]
Name=Heroic Games Launcher
Exec=heroic-games-launcher %U
Terminal=false
Type=Application
Icon=heroic
StartupWMClass=Heroic
Comment=Open-source GOG and Epic Games launcher
MimeType=x-scheme-handler/heroic;
Categories=Game;
EOF
}
