EOF

  cat > "${srcdir}/fixture_globals.bpf.c" <<'EOF'
#include <linux/bpf.h>
#include <bpf/bpf_helpers.h>

const volatile __u32 threshold = 42;
volatile __u64 mutable_counter;
volatile const char rostr[] = "libbpf-fixture";

struct {
  __uint(type, BPF_MAP_TYPE_ARRAY);
  __uint(max_entries, 4);
  __type(key, __u32);
  __type(value, __u64);
} globals_map SEC(".maps");

SEC("tracepoint/syscalls/sys_enter_gettid")
int globals_prog(void *ctx)
{
  __u32 key = threshold & 3;
  __u64 *v = bpf_map_lookup_elem(&globals_map, &key);
  if (v)
    __sync_fetch_and_add(v, mutable_counter + rostr[0]);
  return 0;
}

char LICENSE[] SEC("license") = "GPL";
EOF
}

_build_one_fixture() {
  local incdir="$1"
  local src="$2"
  local out="$3"

  if ! clang -target bpf -O2 -g \
      -D__TARGET_ARCH_x86 \
      -I"$incdir" -I/usr/include \
      -c "$src" \
      -o "$out"; then
    rm -f "$out"
    return 1
  fi
  return 0
}

_build_all_fixtures() {
  local incdir="$1"
  local outdir="$2"
  local -n _out_ref="$3"
  _out_ref=()

  mkdir -p "$outdir"

  local -a srcs=(
    "${srcdir}/fixture_core.bpf.c"
    "${srcdir}/fixture_net.bpf.c"
    "${srcdir}/fixture_misc.bpf.c"
    "${srcdir}/fixture_sections.bpf.c"
    "${srcdir}/fixture_maps.bpf.c"
    "${srcdir}/fixture_progtypes.bpf.c"
    "${srcdir}/fixture_globals.bpf.c"
  )
  local -a pids=()
  local -a outs=()
  local max_jobs="${LIBBPF_PGO_JOBS}"
  local f out pid

  (( max_jobs < 1 )) && max_jobs=1

  for f in "${srcs[@]}"; do
    out="${outdir}/$(basename "${f%.c}").o"
    outs+=("$out")
    _build_one_fixture "$incdir" "$f" "$out" &
    pids+=($!)

    while (( ${#pids[@]} >= max_jobs )); do
      wait -n || true
      _wait_for_pid_settle pids
    done
  done

  for pid in "${pids[@]}"; do
    wait "$pid" || true
  done

  for out in "${outs[@]}"; do
    [[ -f "$out" ]] && _out_ref+=("$out")
  done

  echo "  -> Built ${#_out_ref[@]} synthetic BPF fixture(s)"
}

_build_workload_helper() {
  local stage="$1"
  local incdir="$2"
  local libdir="$3"
  local outpath="$4"

  local have_ring=0 have_perf=0 have_user_ring=0 have_linker=0
  _detect_optional_libbpf_apis "$incdir" have_ring have_perf have_user_ring have_linker

  clang -std=gnu17 -O2 -pipe \
    -DHAVE_RINGBUF_API="$have_ring" \
    -DHAVE_PERFBUF_API="$have_perf" \
    -DHAVE_USER_RINGBUF_API="$have_user_ring" \
    -DHAVE_LINKER_API="$have_linker" \
    -I"$incdir" -I/usr/include \
    "${srcdir}/libbpf_pgo_workload.c" \
    -L"$libdir" \
    -Wl,-rpath-link,"$libdir" \
    -lbpf -lelf -lz -lzstd -ldl -lpthread \
    -o "$outpath"
}

_wait_for_pid_settle() {
  local -n pids_ref="$1"
  local -a alive=()
  local pid

  for pid in "${pids_ref[@]}"; do
    kill -0 "$pid" 2>/dev/null && alive+=("$pid")
  done
  pids_ref=("${alive[@]}")
}

_run_libbpf_workload_matrix() {
  local stage="$1"
  local libdir="$2"
  local helper="$3"
  local base_scale="$4"
  shift 4
  local -a fixtures=("$@")

  local -a rev=() rot=() inter=()
  local -a pids=()
  local i n start left right
  local workers="${LIBBPF_PGO_JOBS}"
  local passes="${LIBBPF_PGO_WORKER_PASSES}"
  local parallel

  (( workers < 1 )) && workers=1
  (( passes < 1 )) && passes=1

  n=${#fixtures[@]}
  for (( i=n-1; i>=0; i-- )); do rev+=("${fixtures[i]}"); done

  start=$(( n / 2 ))
  for (( i=0; i<n; i++ )); do rot+=("${fixtures[(start + i) % n]}"); done

  left=0
  right=$(( n - 1 ))
  while (( left <= right )); do
    inter+=("${fixtures[left]}")
    if (( left == right )); then
      break
    fi
    inter+=("${fixtures[right]}")
    ((left++, right--))
  done

  _print_fixture_order "${stage} fixture order" "${fixtures[@]}"

  # libbpf workload is syscall/kernel-heavy; scaling past 8 workers usually wastes CPU.
  parallel=$workers
  (( parallel > 8 )) && parallel=8

  echo "  -> ${stage}: balanced parallel=${parallel}, passes=${passes} (work normalized)"

  _LIBBPF_BG_PIDS=()

  _launch_task() {
    local btf="$1"
    local sc="$2"
    shift 2
    local -a run=("$@")
    local pid
    (
      trap 'exit 0' INT TERM
      export LD_LIBRARY_PATH="$libdir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
      export LIBBPF_PGO_VMLINUX_BTF="$btf"
      export LIBBPF_PGO_SCALE="$sc"
      export LIBBPF_PGO_LOOP_DIVISOR="$parallel"
      "$helper" "${run[@]}" >/dev/null 2>&1 || true
    ) &
    pid=$!
    pids+=("$pid")
    _LIBBPF_BG_PIDS+=("$pid")
  }

  local p ord btf sc
  local -a run=()

  for (( p=0; p<passes; p++ )); do
    for ord in 0 1 2 3 4 5 6 7; do
      case "$ord" in
        0) run=("${fixtures[@]}"); btf="/sys/kernel/btf/vmlinux"; sc="$base_scale" ;;
        1) run=("${rev[@]}");      btf="/sys/kernel/btf/vmlinux"; sc="$base_scale" ;;
        2) run=("${rot[@]}");      btf="/sys/kernel/btf/vmlinux"; sc="$((base_scale+1))" ;;
        3) run=("${inter[@]}");    btf="/sys/kernel/btf/vmlinux"; sc="$((base_scale+1))" ;;
        4) run=("${rev[@]}");      btf="/no/such/btf";            sc="$base_scale" ;;
        5) run=("${inter[@]}");    btf="/no/such/btf";            sc="$base_scale" ;;
        6) run=("${fixtures[@]}"); btf="/sys/kernel/btf/vmlinux"; sc="$((base_scale+2))" ;;
        7) run=("${rot[@]}");      btf="/sys/kernel/btf/vmlinux"; sc="$((base_scale+2))" ;;
      esac

      _launch_task "$btf" "$sc" "${run[@]}"

      while (( ${#pids[@]} >= parallel )); do
        wait -n || true
        _wait_for_pid_settle pids
        _wait_for_pid_settle _LIBBPF_BG_PIDS
      done
    done
  done

  local pid
  for pid in "${pids[@]}"; do
    wait "$pid" || true
  done

  _LIBBPF_BG_PIDS=()
}

_collect_bolt_profile() {
  local helper="$1"
  local libdir="$2"
  local out_fdata="$3"
  local scale="$4"
  shift 4
  local -a fixtures=("$@")

  rm -f "${out_fdata}" "${out_fdata}".* "${out_fdata}.merged"

  _run_libbpf_workload_matrix "Stage 4 BOLT" "$libdir" "$helper" "$scale" "${fixtures[@]}"

  local -a fdata_files=()
  local f largest=''
  shopt -s nullglob
  fdata_files=("${out_fdata}".*.fdata)
  shopt -u nullglob
  (( ${#fdata_files[@]} > 0 )) || return 1

  local -a nonempty=()
  for f in "${fdata_files[@]}"; do
    [[ -s "$f" ]] && nonempty+=("$f")
  done
  (( ${#nonempty[@]} > 0 )) || return 1

  if command -v merge-fdata >/dev/null 2>&1; then
    merge-fdata "${nonempty[@]}" > "${out_fdata}.merged" 2>/dev/null || return 1
  else
    largest="$(ls -S "${nonempty[@]}" | head -n1)"
    cp -f "$largest" "${out_fdata}.merged"
  fi

  [[ -s "${out_fdata}.merged" ]]
}

_extract_bolt_profiled_ratio() {
  local bolt_log="$1"
  local outvar="$2"
  local line prof total pct

  line="$(grep -E '[0-9]+ out of [0-9]+ functions in the binary' "$bolt_log" | tail -n1 || true)"
  if [[ -z "$line" ]]; then
    printf -v "$outvar" '%d' 0
    return 0
  fi

  prof="$(sed -E 's/.*: ([0-9]+) out of ([0-9]+).*/\1/' <<<"$line")"
  total="$(sed -E 's/.*: ([0-9]+) out of ([0-9]+).*/\2/' <<<"$line")"

  if [[ -n "$prof" && -n "$total" && "$total" -gt 0 ]]; then
    pct=$(( prof * 100 / total ))
    printf -v "$outvar" '%d' "$pct"
  else
    printf -v "$outvar" '%d' 0
  fi
}

_show_bolt_fdata() {
  local bolt_dir="$1"
  local so_name="$2"
  if compgen -G "${bolt_dir}/${so_name}.fdata*" >/dev/null; then
    ls -lh "${bolt_dir}/${so_name}.fdata"* 2>/dev/null || true
  fi
}

check() {
  local finalroot="${srcdir}/libbpf-final"
  local so=""

  [[ -d "$finalroot/src" ]] || return 0
  cd "$finalroot/src"

  if _find_real_shared_object "$PWD" 'libbpf.so.*' so; then
    nm -D "$so" 2>/dev/null | grep -q 'libbpf_major_version' || {
      echo "libbpf symbol sanity check failed" >&2
      return 1
    }
  fi
}

prepare() {
  _create_workload_sources
}

build() {
  trap '_cleanup_bg_workers; return 130' INT TERM
  trap '_cleanup_bg_workers' EXIT

  _setup_llvm_toolchain

  local srcroot="${srcdir}/libbpf"
  local stage_pgo="${srcdir}/libbpf-pgo"
  local stage_cs="${srcdir}/libbpf-cs"
  local stage_final="${srcdir}/libbpf-final"

  local inst_pgo="${srcdir}/inst_pgo"
  local inst_cs="${srcdir}/inst_cs"
  local inst_final="${srcdir}/inst_final"
  local inst_bolt="${srcdir}/inst_bolt"

  local pgo_dir="${srcdir}/pgo_profiles"
  local cs_dir="${srcdir}/cs_pgo_profiles"
  local bolt_dir="${srcdir}/bolt"

  rm -rf "$stage_pgo" "$stage_cs" "$stage_final"
  rm -rf "$inst_pgo" "$inst_cs" "$inst_final" "$inst_bolt"
  rm -rf "$pgo_dir" "$cs_dir" "$bolt_dir"
  mkdir -p "$pgo_dir" "$cs_dir" "$bolt_dir"

  local _orig_cflags="$CFLAGS"
  local _orig_ldflags="$LDFLAGS"
  local njobs="${LIBBPF_PGO_JOBS}"

  local _prefix_maps=(
    "-ffile-prefix-map=$srcdir=/usr/src/debug/$pkgname"
    "-fdebug-prefix-map=$srcdir=/usr/src/debug/$pkgname"
    "-fmacro-prefix-map=$srcdir=/usr/src/debug/$pkgname"
  )

  local _pgo_common_flags="-mllvm -enable-value-profiling -fprofile-update=atomic"
  local _std_vp_flags="${_pgo_common_flags} -mllvm -vp-counters-per-site=8192"
  local _cs_vp_flags="${_pgo_common_flags} -mllvm -vp-counters-per-site=32768"
  local _profile_warnings=(-Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled)

  echo "=== Stage 1: Standard PGO instrumentation ==="
  _copy_stage_tree "$srcroot" "$stage_pgo"

  cd "$stage_pgo/src"
  make clean >/dev/null 2>&1 || true
  make -j"$njobs" \
    CC="$CC" \
    EXTRA_CFLAGS="${_orig_cflags} ${_prefix_maps[*]} ${_std_vp_flags} -fprofile-generate=${pgo_dir}" \
    EXTRA_LDFLAGS="${_orig_ldflags} -fprofile-generate=${pgo_dir} -fprofile-update=atomic"

  _stage_install "$stage_pgo" "$inst_pgo"

  local pgo_incdir pgo_libdir
  pgo_incdir="$inst_pgo/usr/include"
  _get_stage_libdir "$inst_pgo" pgo_libdir || { echo "Error: Stage 1 libdir not found." >&2; return 1; }

  local helper_pgo="${srcdir}/libbpf-workload-stage1"
  _build_workload_helper stage1 "$pgo_incdir" "$pgo_libdir" "$helper_pgo"

  local -a fixtures_pgo=()
  _build_all_fixtures "$pgo_incdir" "${srcdir}/fixtures-stage1" fixtures_pgo

  export LLVM_PROFILE_FILE="${pgo_dir}/default_%m.profraw"
  export LLVM_PROFILE_MERGE_POOL_SIZE=8
  _run_libbpf_workload_matrix "Stage 1" "$pgo_libdir" "$helper_pgo" 2 "${fixtures_pgo[@]}"
  unset LLVM_PROFILE_FILE LLVM_PROFILE_MERGE_POOL_SIZE

  _merge_profraw_dir "${srcdir}/libbpf.profdata" "$pgo_dir" || {
    echo "Error: Stage 1 profile merge failed." >&2
    return 1
  }

  echo "=== Stage 2: Context-Sensitive PGO instrumentation ==="
  _copy_stage_tree "$srcroot" "$stage_cs"

  cd "$stage_cs/src"
  make clean >/dev/null 2>&1 || true
  make -j"$njobs" \
    CC="$CC" \
    EXTRA_CFLAGS="${_orig_cflags} ${_prefix_maps[*]} ${_cs_vp_flags} -fprofile-use=${srcdir}/libbpf.profdata -fcs-profile-generate=${cs_dir} ${_profile_warnings[*]}" \
    EXTRA_LDFLAGS="${_orig_ldflags} -fprofile-use=${srcdir}/libbpf.profdata -fcs-profile-generate=${cs_dir} -fprofile-update=atomic"

  _stage_install "$stage_cs" "$inst_cs"

  local cs_incdir cs_libdir
  cs_incdir="$inst_cs/usr/include"
  _get_stage_libdir "$inst_cs" cs_libdir || { echo "Error: Stage 2 libdir not found." >&2; return 1; }

  local helper_cs="${srcdir}/libbpf-workload-stage2"
  _build_workload_helper stage2 "$cs_incdir" "$cs_libdir" "$helper_cs"

  local -a fixtures_cs=()
  _build_all_fixtures "$cs_incdir" "${srcdir}/fixtures-stage2" fixtures_cs

  export LLVM_PROFILE_FILE="${cs_dir}/default_%m.profraw"
  export LLVM_PROFILE_MERGE_POOL_SIZE=8
  _run_libbpf_workload_matrix "Stage 2" "$cs_libdir" "$helper_cs" 2 "${fixtures_cs[@]}"
  unset LLVM_PROFILE_FILE LLVM_PROFILE_MERGE_POOL_SIZE

  _merge_profraw_dir "${srcdir}/cs_stage.profdata" "$cs_dir" || {
    echo "Error: Stage 2 profile merge failed." >&2
    return 1
  }

  llvm-profdata merge -sparse \
    -output="${srcdir}/cs_libbpf.profdata" \
    "${srcdir}/libbpf.profdata" \
    "${srcdir}/cs_stage.profdata"

  [[ -s "${srcdir}/cs_libbpf.profdata" ]] || {
    echo "Error: merged CS profile missing." >&2
    return 1
  }

  echo "=== Stage 3: Final PGO build ==="
  _copy_stage_tree "$srcroot" "$stage_final"

  cd "$stage_final/src"
  make clean >/dev/null 2>&1 || true
  make -j"$njobs" \
    CC="$CC" \
    EXTRA_CFLAGS="${_orig_cflags} ${_prefix_maps[*]} -fprofile-use=${srcdir}/cs_libbpf.profdata ${_profile_warnings[*]}" \
    EXTRA_LDFLAGS="${_orig_ldflags} -fprofile-use=${srcdir}/cs_libbpf.profdata -Wl,--emit-relocs"

  _stage_install "$stage_final" "$inst_final"

  local final_incdir final_libdir
  final_incdir="$inst_final/usr/include"
  _get_stage_libdir "$inst_final" final_libdir || { echo "Error: Stage 3 libdir not found." >&2; return 1; }

  if ! command -v llvm-bolt >/dev/null 2>&1; then
    echo "=== Stage 4: llvm-bolt not found; skipping BOLT ==="
    _cleanup_bg_workers
    trap - INT TERM EXIT
    return 0
  fi

  echo "=== Stage 4: BOLT post-link optimization ==="

  local final_so=""
  _find_real_shared_object "$stage_final/src" 'libbpf.so.*' final_so || {
    echo "No real libbpf shared object found for BOLT; skipping." >&2
    _cleanup_bg_workers
    trap - INT TERM EXIT
    return 0
  }

  local so_name
  so_name="$(basename "$final_so")"
  local prebolt="${bolt_dir}/${so_name}.orig"
  local inst_bolt_libdir="${inst_bolt}/usr/lib"

  mkdir -p "$inst_bolt_libdir"
  cp -f "$final_so" "$prebolt"

  local bolt_fdata_base="${bolt_dir}/${so_name}.fdata"

  if llvm-bolt "$prebolt" \
      --instrument \
      --lite=true \
      --instrumentation-file-append-pid \
      --instrumentation-file="${bolt_fdata_base}" \
      -o "${bolt_dir}/${so_name}.instr"; then

    cp -f "${bolt_dir}/${so_name}.instr" "${inst_bolt_libdir}/${so_name}"

    if [[ "$so_name" =~ ^(libbpf\.so\.[0-9]+)\..* ]]; then
      ln -sf "$so_name" "${inst_bolt_libdir}/${BASH_REMATCH[1]}"
      ln -sf "${BASH_REMATCH[1]}" "${inst_bolt_libdir}/libbpf.so"
    else
      ln -sf "$so_name" "${inst_bolt_libdir}/libbpf.so"
    fi

    local helper_bolt="${srcdir}/libbpf-workload-bolt"
    _build_workload_helper bolt "$final_incdir" "$inst_bolt_libdir" "$helper_bolt"

    local -a fixtures_bolt=()
    _build_all_fixtures "$final_incdir" "${srcdir}/fixtures-bolt" fixtures_bolt

    _collect_bolt_profile "$helper_bolt" "$inst_bolt_libdir" "$bolt_fdata_base" 3 "${fixtures_bolt[@]}" || {
      echo "  -> Failed to collect BOLT profile data; keeping PGO-only binary."
      _cleanup_bg_workers
      trap - INT TERM EXIT
      return 0
    }

    _show_bolt_fdata "$bolt_dir" "$so_name"

    local merged_fdata="${bolt_fdata_base}.merged"
    local bolt_log="${bolt_dir}/${so_name}.bolt.log"

    set -o pipefail
    if llvm-bolt "$prebolt" \
        --data="$merged_fdata" \
        --lite=true \
        --relocs \
        --reorder-blocks=ext-tsp \
        --reorder-functions=cdsort \
        --split-functions --split-all-cold --split-eh \
        --x86-strip-redundant-address-size \
        --split-strategy=cdsplit \
        --icf=all \
        --indirect-call-promotion=all \
        --jump-tables=aggressive \
        --peepholes=all \
        --plt=hot \
        --dyno-stats \
        -o "${bolt_dir}/${so_name}.bolt" 2>&1 | tee "$bolt_log"; then

      local prof_pct=0
      _extract_bolt_profiled_ratio "$bolt_log" prof_pct
      echo "  -> BOLT profiled-function ratio: ${prof_pct}%"

      if (( prof_pct < 25 )); then
        echo "  -> Sparse BOLT profile detected, retrying with heavier training..."
        _collect_bolt_profile "$helper_bolt" "$inst_bolt_libdir" "$bolt_fdata_base" 6 "${fixtures_bolt[@]}" || true

        if llvm-bolt "$prebolt" \
            --data="${bolt_fdata_base}.merged" \
            --lite=true \
            --relocs \
            --reorder-blocks=ext-tsp \
            --reorder-functions=cdsort \
            --split-functions --split-all-cold --split-eh \
            --x86-strip-redundant-address-size \
            --split-strategy=cdsplit \
            --icf=all \
            --indirect-call-promotion=all \
            --jump-tables=aggressive \
            --peepholes=all \
            --plt=hot \
            --dyno-stats \
            -o "${bolt_dir}/${so_name}.bolt.retry" 2>&1 | tee "${bolt_dir}/${so_name}.bolt.retry.log"; then
          [[ -s "${bolt_dir}/${so_name}.bolt.retry" ]] && cp -f "${bolt_dir}/${so_name}.bolt.retry" "${bolt_dir}/${so_name}.bolt"
        fi
      fi

      if [[ -s "${bolt_dir}/${so_name}.bolt" ]]; then
        cp -f "${bolt_dir}/${so_name}.bolt" "$final_so"
        echo "  -> BOLT optimization applied."
      else
        echo "  -> BOLT output empty; keeping PGO-only binary."
      fi
    else
      echo "  -> BOLT optimize pass failed; keeping PGO-only binary."
    fi
    set +o pipefail
  else
    echo "  -> BOLT instrumentation failed; skipping BOLT."
  fi

  _cleanup_bg_workers
  trap - INT TERM EXIT
}

check() {
  local finalroot="${srcdir}/libbpf-final"
  local so=""

  [[ -d "$finalroot/src" ]] || return 0
  cd "$finalroot/src"

  if _find_real_shared_object "$PWD" 'libbpf.so.*' so; then
    nm -D "$so" 2>/dev/null | grep -q 'libbpf_major_version' || {
      echo "libbpf symbol sanity check failed" >&2
      return 1
    }
  fi
}

package() {
  cd "${srcdir}/libbpf-final/src"
  DESTDIR="${pkgdir}" make prefix=/usr LIBDIR=/usr/lib install install_headers

  install -Dm644 "${srcdir}/libbpf/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "${srcdir}/libbpf/LICENSE.BSD-2-Clause" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.BSD-2-Clause"

  if [[ -d "${pkgdir}/usr/lib64" ]]; then
    mkdir -p "${pkgdir}/usr/lib"
    cp -a "${pkgdir}/usr/lib64"/. "${pkgdir}/usr/lib"/
    rm -rf "${pkgdir}/usr/lib64"
  fi
}
