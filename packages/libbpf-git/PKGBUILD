_build_one_fixture() {
  local incdir="$1"
  local src="$2"
  local out="$3"

  echo "  -> Building synthetic BPF fixture: $out"
  if ! clang -target bpf -O2 -g \
      -D__TARGET_ARCH_x86 \
      -I"$incdir" -I/usr/include \
      -c "$src" \
      -o "$out"; then
    echo "  -> WARNING: Failed to build fixture $(basename "$src")"
    rm -f "$out"
    return 1
  fi
  return 0
}

_build_all_fixtures() {
  local incdir="$1"
  local outdir="$2"
  local -n _out_ref="$3"
  _out_ref=()

  mkdir -p "$outdir"

  local f out
  for f in \
    "${srcdir}/fixture_core.bpf.c" \
    "${srcdir}/fixture_net.bpf.c" \
    "${srcdir}/fixture_misc.bpf.c" \
    "${srcdir}/fixture_sections.bpf.c" \
    "${srcdir}/fixture_maps.bpf.c"
  do
    out="${outdir}/$(basename "${f%.c}").o"
    if _build_one_fixture "$incdir" "$f" "$out"; then
      _out_ref+=("$out")
    fi
  done

  echo "  -> Built ${#_out_ref[@]} synthetic fixture object(s)."
  local x
  for x in "${_out_ref[@]}"; do
    echo "     $x"
  done
}

_build_workload_helper() {
  local stage="$1"
  local incdir="$2"
  local libdir="$3"
  local outpath="$4"

  echo "  -> Building libbpf workload helper: $outpath"
  clang -std=gnu17 -O2 -pipe \
    -I"$incdir" -I/usr/include \
    "${srcdir}/libbpf_pgo_workload.c" \
    -L"$libdir" \
    -Wl,-rpath-link,"$libdir" \
    -lbpf -lelf -lz -lzstd -ldl -lpthread \
    -o "$outpath"
}

_run_libbpf_workload() {
  local stage="$1"
  local libdir="$2"
  local profdir="$3"
  local helper="$4"
  shift 4
  local -a fixtures=("$@")
  local logfile="${srcdir}/libbpf-training-$(_stage_slug "$stage").log"

  echo "→ ${stage}: Running custom libbpf workload..."
  echo "  -> helper: $helper"
  echo "  -> logfile: $logfile"
  echo "  -> LD_LIBRARY_PATH=$libdir"

  (
    export LD_LIBRARY_PATH="$libdir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    export LIBBPF_PGO_VMLINUX_BTF="/sys/kernel/btf/vmlinux"
    set -o pipefail
    "$helper" "${fixtures[@]}" 2>&1 | tee "$logfile"
  ) || {
    echo "Error: custom libbpf workload failed during ${stage}." >&2
    return 1
  }

  _show_generated_profiles "$profdir" "$stage"
}

_show_generated_profiles() {
  local profdir="$1"
  local label="$2"
  local count=0

  count=$(find "$profdir" -maxdepth 1 -name '*.profraw' 2>/dev/null | wc -l)
  echo "  -> ${label}: generated ${count} raw profile file(s)"
  find "$profdir" -maxdepth 1 -name '*.profraw' -printf '     %f\n' 2>/dev/null | head -20 || true
}

_show_bolt_fdata() {
  local bolt_dir="$1"
  local so_name="$2"

  echo "  -> BOLT fdata files for ${so_name}:"
  if compgen -G "${bolt_dir}/${so_name}.fdata*" >/dev/null; then
    ls -lh "${bolt_dir}/${so_name}.fdata"* 2>/dev/null || true
  else
    echo "     (none)"
  fi
}

check() {
  local finalroot="${srcdir}/libbpf-final"
  local so=""

  [[ -d "$finalroot/src" ]] || return 0
  cd "$finalroot/src"

  echo "=== libbpf sanity check ==="
  if _find_real_shared_object "$PWD" 'libbpf.so.*' so; then
    echo "  -> shared object: $so"
    if nm -D "$so" 2>/dev/null | grep -q 'libbpf_major_version'; then
      echo "  -> core symbol check: ok"
    else
      echo "  -> core symbol check: FAILED" >&2
      return 1
    fi
  fi
}

prepare() {
  _create_workload_sources
}

build() {
  _setup_llvm_toolchain

  local srcroot="${srcdir}/libbpf"
  local stage_pgo="${srcdir}/libbpf-pgo"
  local stage_cs="${srcdir}/libbpf-cs"
  local stage_final="${srcdir}/libbpf-final"

  local inst_pgo="${srcdir}/inst_pgo"
  local inst_cs="${srcdir}/inst_cs"
  local inst_final="${srcdir}/inst_final"
  local inst_bolt="${srcdir}/inst_bolt"

  local pgo_dir="${srcdir}/pgo_profiles"
  local cs_dir="${srcdir}/cs_pgo_profiles"
  local bolt_dir="${srcdir}/bolt"

  rm -rf "$stage_pgo" "$stage_cs" "$stage_final"
  rm -rf "$inst_pgo" "$inst_cs" "$inst_final" "$inst_bolt"
  rm -rf "$pgo_dir" "$cs_dir" "$bolt_dir"
  mkdir -p "$pgo_dir" "$cs_dir" "$bolt_dir"

  local _orig_cflags="$CFLAGS"
  local _orig_ldflags="$LDFLAGS"

  local _instr_flags=(
    -g3
    -fno-omit-frame-pointer
    -Xclang -mllvm -Xclang -vp-counters-per-site=50
    -Xclang -mllvm -Xclang -runtime-counter-relocation
    -Xclang -mllvm -Xclang -enable-value-profiling
  )

  local _profile_warnings=(
    -Wno-profile-instr-out-of-date
    -Wno-profile-instr-unprofiled
  )

  local _prefix_maps=(
    "-ffile-prefix-map=$srcdir=/usr/src/debug/$pkgname"
    "-fdebug-prefix-map=$srcdir=/usr/src/debug/$pkgname"
    "-fmacro-prefix-map=$srcdir=/usr/src/debug/$pkgname"
  )

  # Stage 1
  echo "=== Stage 1: Standard PGO instrumentation ==="
  _copy_stage_tree "$srcroot" "$stage_pgo"

  cd "$stage_pgo/src"
  make clean >/dev/null 2>&1 || true
  make \
    CC="$CC" \
    EXTRA_CFLAGS="${_orig_cflags} ${_prefix_maps[*]} -fprofile-generate=${pgo_dir} ${_instr_flags[*]}" \
    EXTRA_LDFLAGS="${_orig_ldflags} -fprofile-generate=${pgo_dir}"

  _stage_install "$stage_pgo" "$inst_pgo"

  local pgo_incdir pgo_libdir
  pgo_incdir="$inst_pgo/usr/include"
  _get_stage_libdir "$inst_pgo" pgo_libdir || {
    echo "Error: could not determine staged lib dir for Stage 1." >&2
    return 1
  }

  local helper_pgo="${srcdir}/libbpf-workload-stage1"
  _build_workload_helper stage1 "$pgo_incdir" "$pgo_libdir" "$helper_pgo"

  local -a fixtures_pgo=()
  _build_all_fixtures "$pgo_incdir" "${srcdir}/fixtures-stage1" fixtures_pgo

  export LLVM_PROFILE_FILE="${pgo_dir}/libbpf-%m-%p.profraw"
  _run_libbpf_workload "Stage 1" "$pgo_libdir" "$pgo_dir" "$helper_pgo" "${fixtures_pgo[@]}"
  unset LLVM_PROFILE_FILE

  local -a pgo_raws=()
  shopt -s nullglob
  pgo_raws=("${pgo_dir}"/*.profraw)
  shopt -u nullglob

  if (( ${#pgo_raws[@]} )); then
    llvm-profdata merge -sparse -output="${srcdir}/libbpf.profdata" "${pgo_raws[@]}"
  else
    echo "Error: no Stage 1 PGO profile data generated." >&2
    return 1
  fi

  # Stage 2
  echo "=== Stage 2: Context-Sensitive PGO instrumentation ==="
  _copy_stage_tree "$srcroot" "$stage_cs"

  cd "$stage_cs/src"
  make clean >/dev/null 2>&1 || true
  make \
    CC="$CC" \
    EXTRA_CFLAGS="${_orig_cflags} ${_prefix_maps[*]} -fprofile-use=${srcdir}/libbpf.profdata -fcs-profile-generate=${cs_dir} ${_profile_warnings[*]} ${_instr_flags[*]}" \
    EXTRA_LDFLAGS="${_orig_ldflags} -fprofile-use=${srcdir}/libbpf.profdata -fcs-profile-generate=${cs_dir}"

  _stage_install "$stage_cs" "$inst_cs"

  local cs_incdir cs_libdir
  cs_incdir="$inst_cs/usr/include"
  _get_stage_libdir "$inst_cs" cs_libdir || {
    echo "Error: could not determine staged lib dir for Stage 2." >&2
    return 1
  }

  local helper_cs="${srcdir}/libbpf-workload-stage2"
  _build_workload_helper stage2 "$cs_incdir" "$cs_libdir" "$helper_cs"

  local -a fixtures_cs=()
  _build_all_fixtures "$cs_incdir" "${srcdir}/fixtures-stage2" fixtures_cs

  export LLVM_PROFILE_FILE="${cs_dir}/libbpf-cs-%m-%p.profraw"
  _run_libbpf_workload "Stage 2" "$cs_libdir" "$cs_dir" "$helper_cs" "${fixtures_cs[@]}"
  unset LLVM_PROFILE_FILE

  local -a cs_raws=()
  shopt -s nullglob
  cs_raws=("${cs_dir}"/*.profraw)
  shopt -u nullglob

  if (( ${#cs_raws[@]} )); then
    llvm-profdata merge -sparse \
      -output="${srcdir}/cs_libbpf.profdata" \
      "${srcdir}/libbpf.profdata" "${cs_raws[@]}"
  else
    echo "Error: no Stage 2 CS-PGO profile data generated." >&2
    return 1
  fi

  # Stage 3
  echo "=== Stage 3: Final PGO build ==="
  _copy_stage_tree "$srcroot" "$stage_final"

  cd "$stage_final/src"
  make clean >/dev/null 2>&1 || true
  make \
    CC="$CC" \
    EXTRA_CFLAGS="${_orig_cflags} ${_prefix_maps[*]} -fprofile-use=${srcdir}/cs_libbpf.profdata ${_profile_warnings[*]}" \
    EXTRA_LDFLAGS="${_orig_ldflags} -fprofile-use=${srcdir}/cs_libbpf.profdata -Wl,--emit-relocs"

  _stage_install "$stage_final" "$inst_final"

  local final_incdir final_libdir
  final_incdir="$inst_final/usr/include"
  _get_stage_libdir "$inst_final" final_libdir || {
    echo "Error: could not determine staged lib dir for Stage 3." >&2
    return 1
  }

  echo "=== Stage 3: Built shared libraries ==="
  find "$stage_final/src" -maxdepth 1 -type f -name 'libbpf.so*' -print

  # Stage 4
  if ! command -v llvm-bolt >/dev/null 2>&1; then
    echo "=== Stage 4: llvm-bolt not found; skipping BOLT ==="
    return 0
  fi

  echo "=== Stage 4: BOLT post-link optimization ==="

  local final_so=""
  _find_real_shared_object "$stage_final/src" 'libbpf.so.*' final_so || {
    echo "No real libbpf shared object found for BOLT; skipping." >&2
    return 0
  }

  local so_name
  so_name="$(basename "$final_so")"
  local prebolt="${bolt_dir}/${so_name}.orig"
  local inst_bolt_libdir="${inst_bolt}/usr/lib"

  mkdir -p "$inst_bolt_libdir"
  cp -f "$final_so" "$prebolt"

  echo "  -> Instrumenting ${so_name}..."
  if llvm-bolt "$prebolt" \
      --instrument \
      --lite=true \
      --instrumentation-file-append-pid \
      --instrumentation-file="${bolt_dir}/${so_name}.fdata" \
      -o "${bolt_dir}/${so_name}.instr"; then

    cp -f "${bolt_dir}/${so_name}.instr" "${inst_bolt_libdir}/${so_name}"

    if [[ "$so_name" =~ ^(libbpf\.so\.[0-9]+)\..* ]]; then
      ln -sf "$so_name" "${inst_bolt_libdir}/${BASH_REMATCH[1]}"
      ln -sf "${BASH_REMATCH[1]}" "${inst_bolt_libdir}/libbpf.so"
    else
      ln -sf "$so_name" "${inst_bolt_libdir}/libbpf.so"
    fi

    local helper_bolt="${srcdir}/libbpf-workload-bolt"
    _build_workload_helper bolt "$final_incdir" "$inst_bolt_libdir" "$helper_bolt"

    local -a fixtures_bolt=()
    local -a fixtures_bolt_rev=()
    local -a fixtures_bolt_rot=()

    _build_all_fixtures "$final_incdir" "${srcdir}/fixtures-bolt" fixtures_bolt
    _reverse_array fixtures_bolt fixtures_bolt_rev
    _rotate_array_half fixtures_bolt fixtures_bolt_rot

    _run_libbpf_workload "Stage 4 BOLT pass1" "$inst_bolt_libdir" "$bolt_dir" "$helper_bolt" "${fixtures_bolt[@]}"
    _run_libbpf_workload "Stage 4 BOLT pass2" "$inst_bolt_libdir" "$bolt_dir" "$helper_bolt" "${fixtures_bolt_rev[@]}"
    _run_libbpf_workload "Stage 4 BOLT pass3" "$inst_bolt_libdir" "$bolt_dir" "$helper_bolt" "${fixtures_bolt_rot[@]}"

    _show_bolt_fdata "$bolt_dir" "$so_name"

    local -a fdata_files=()
    shopt -s nullglob
    fdata_files=("${bolt_dir}/${so_name}".fdata*)
    shopt -u nullglob

    if (( ${#fdata_files[@]} )); then
      local merged_fdata="${bolt_dir}/${so_name}.merged.fdata"
      if command -v merge-fdata >/dev/null 2>&1; then
        merge-fdata "${fdata_files[@]}" > "$merged_fdata" 2>/dev/null || \
          cat "${fdata_files[@]}" > "$merged_fdata"
      else
        cat "${fdata_files[@]}" > "$merged_fdata"
      fi

      if [[ -s "$merged_fdata" ]]; then
        echo "  -> Applying BOLT to ${so_name}..."
        if llvm-bolt "$prebolt" \
            --data="$merged_fdata" \
            --lite=true \
            --relocs \
            --reorder-blocks=ext-tsp \
            --reorder-functions=cdsort \
            --split-functions --split-all-cold --split-eh \
            --x86-strip-redundant-address-size \
            --split-strategy=cdsplit \
            --icf=all \
            --indirect-call-promotion=all \
            --jump-tables=aggressive \
            --peepholes=all \
            --plt=hot \
            --dyno-stats \
            -o "${bolt_dir}/${so_name}.bolt"; then
          if [[ -s "${bolt_dir}/${so_name}.bolt" ]]; then
            cp -f "${bolt_dir}/${so_name}.bolt" "$final_so"
            echo "  -> BOLT optimization successful."
          fi
        else
          echo "  -> BOLT optimization failed; keeping non-BOLT final shared library."
        fi
      else
        echo "  -> Empty BOLT fdata; keeping non-BOLT final shared library."
      fi
    else
      echo "  -> No BOLT fdata collected; keeping non-BOLT final shared library."
    fi
  else
    echo "  -> BOLT instrumentation failed; skipping BOLT."
  fi
}

package() {
  cd "${srcdir}/libbpf-final/src"
  DESTDIR="${pkgdir}" make prefix=/usr LIBDIR=/usr/lib install install_headers

  install -Dm644 "${srcdir}/libbpf/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "${srcdir}/libbpf/LICENSE.BSD-2-Clause" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.BSD-2-Clause"

  if [[ -d "${pkgdir}/usr/lib64" ]]; then
    mkdir -p "${pkgdir}/usr/lib"
    cp -a "${pkgdir}/usr/lib64"/. "${pkgdir}/usr/lib"/
    rm -rf "${pkgdir}/usr/lib64"
  fi
}
