# Maintainer: CachyOS Team <team@cachyos.org>
pkgname=libbpf-git
pkgver=1.6.0.r122.6ddc03d4
pkgrel=1
pkgdesc='BPF library (PGO + ThinLTO + BOLT optimized for scx-scheds)'
arch=('x86_64')
url='https://github.com/libbpf/libbpf'
license=('LGPL-2.1-only' 'BSD-2-Clause')
depends=('libelf' 'zlib' 'zstd' 'linux-api-headers>=6.2')
makedepends=('clang' 'llvm')
provides=("libbpf=${pkgver}" 'libbpf.so=1-64')
conflicts=('libbpf')
source=("git+https://github.com/libbpf/libbpf.git")
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/libbpf"
  printf "%s" "$(git describe --long --tags | sed 's/\([^-]*-\)g/r\1/;s/-/./g;s/^v//')"
}

run_heavy_workload() {
  local ld_path="$1"
  echo "=== Running HEAVY comprehensive libbpf workload (1200× BTF + full API hammer - scx-scheds hot paths) ==="

  cat > "${srcdir}/heavy_libbpf_workload.c" << 'EOF'
#include <bpf/libbpf.h>
#include <bpf/btf.h>
#include <unistd.h>
#include <stdio.h>
#include <pthread.h>
#include <bpf/bpf.h>

#define BTF_LOOPS 1200
#define NUM_MAPS 8
#define NUM_THREADS 4

static int map_fds[NUM_MAPS];

static void* map_thread(void* arg) {
  long tid = (long)arg;
  for (int i = 0; i < 300; i++) {
    int map_idx = (tid + i) % NUM_MAPS;
    int fd = map_fds[map_idx];
    if (fd < 0) continue;
    int key = tid * 1000 + i;
    long value = key * 2;
    bpf_map_update_elem(fd, &key, &value, BPF_ANY);
    bpf_map_lookup_elem(fd, &key, &value);
    if (i % 5 == 0) bpf_map_delete_elem(fd, &key);
  }
  return NULL;
}

int main() {
  // Heavy BTF parsing (the #1 hot path in scx-scheds)
  for (int i = 0; i < BTF_LOOPS; i++) {
    struct btf *btf = btf__parse("/sys/kernel/btf/vmlinux", NULL);
    if (btf) {
      btf__free(btf);
    }
    if (i % 100 == 0) usleep(500);
  }

  // Basic API hammering
  libbpf_major_version();
  libbpf_minor_version();
  libbpf_set_print(NULL);

  // Safe map operations (graceful fallback if no privileges)
  for (int i = 0; i < NUM_MAPS; i++) {
    map_fds[i] = bpf_map_create(BPF_MAP_TYPE_HASH, NULL, 4, 8, 64, NULL);
  }

  pthread_t threads[NUM_THREADS];
  for (long i = 0; i < NUM_THREADS; i++) {
    pthread_create(&threads[i], NULL, map_thread, (void*)i);
  }
  for (int i = 0; i < NUM_THREADS; i++) {
    pthread_join(threads[i], NULL);
  }

  // Cleanup
  for (int i = 0; i < NUM_MAPS; i++) {
    if (map_fds[i] >= 0) close(map_fds[i]);
  }

  printf("Heavy libbpf workload completed\n");
  return 0;
}
EOF

  clang -O2 -I"${srcdir}/libbpf/include" "${srcdir}/heavy_libbpf_workload.c" \
    -o "${srcdir}/heavy_libbpf_workload" ${ld_path:+-L"$ld_path"} -lbpf -lelf -lz -pthread

  if [ -n "$ld_path" ]; then
    LD_LIBRARY_PATH="$ld_path" "${srcdir}/heavy_libbpf_workload" || true
  else
    "${srcdir}/heavy_libbpf_workload" || true
  fi
  sleep 3  # Guarantee profile flush for PGO/BOLT runtime
}

build() {
  cd "${srcdir}/libbpf/src"

  local pgo_dir="${srcdir}/pgo_profiles"
  local cs_pgo_dir="${srcdir}/cs_pgo_profiles"
  mkdir -p "$pgo_dir" "$cs_pgo_dir"

  local instrument_flags="-g3 -fno-omit-frame-pointer -mllvm -vp-counters-per-site=10 -mllvm -enable-value-profiling"

  # Phase 1: Standard PGO instrumentation + HEAVY workload
  echo "=== Phase 1: Standard PGO instrumentation ==="
  make clean
  make CC=clang \
    EXTRA_CFLAGS="-fprofile-generate=${pgo_dir} ${instrument_flags}" \
    EXTRA_LDFLAGS="-fprofile-generate=${pgo_dir}"

  rm -rf "${srcdir}/inst_pgo"
  make DESTDIR="${srcdir}/inst_pgo" prefix=/usr LIBDIR=/usr/lib install

  export LD_LIBRARY_PATH="${srcdir}/inst_pgo/usr/lib"
  export LLVM_PROFILE_FILE="${pgo_dir}/libbpf-%m.profraw"
  run_heavy_workload "${srcdir}/inst_pgo/usr/lib"
  unset LD_LIBRARY_PATH

  if ls "${pgo_dir}"/*.profraw &>/dev/null; then
    llvm-profdata merge -sparse -output="${srcdir}/libbpf.profdata" "${pgo_dir}"/*.profraw
  fi

  # Phase 2: Context-Sensitive PGO + SAME HEAVY workload
  echo "=== Phase 2: Context-Sensitive PGO ==="
  make clean
  make CC=clang \
    EXTRA_CFLAGS="-fprofile-use=${srcdir}/libbpf.profdata -fcs-profile-generate=${cs_pgo_dir} ${instrument_flags}" \
    EXTRA_LDFLAGS="-fcs-profile-generate=${cs_pgo_dir}"

  rm -rf "${srcdir}/inst_cs"
  make DESTDIR="${srcdir}/inst_cs" prefix=/usr LIBDIR=/usr/lib install

  export LD_LIBRARY_PATH="${srcdir}/inst_cs/usr/lib"
  export LLVM_PROFILE_FILE="${cs_pgo_dir}/libbpf-cs-%m.profraw"
  run_heavy_workload "${srcdir}/inst_cs/usr/lib"
  unset LD_LIBRARY_PATH

  if ls "${cs_pgo_dir}"/*.profraw &>/dev/null; then
    llvm-profdata merge -sparse -output="${srcdir}/cs_libbpf.profdata" "${cs_pgo_dir}"/*.profraw "${srcdir}/libbpf.profdata"
  fi

  # Phase 3: Final PGO build
  echo "=== Phase 3: Final PGO build ==="
  make clean
  make CC=clang \
    EXTRA_CFLAGS="-fprofile-use=${srcdir}/cs_libbpf.profdata" \
    EXTRA_LDFLAGS="-fprofile-use=${srcdir}/cs_libbpf.profdata -Wl,--emit-relocs"

  # Phase 4: BOLT (instrumented library + SAME HEAVY workload)
  echo "=== Phase 4: BOLT post-link optimization ==="
  local libname=$(find . -maxdepth 1 -name 'libbpf.so.1.*' | head -n1)
  if [ -n "$libname" ] && command -v llvm-bolt >/dev/null 2>&1; then
    local prebolt="${srcdir}/libbpf.prebolt.so"
    local bolt_inst_dir="${srcdir}/bolt_inst"
    local bolted="${srcdir}/libbpf.bolted.so"
    local fdata="${srcdir}/bolt.fdata"

    mkdir -p "$bolt_inst_dir"
    cp "$libname" "$prebolt"

    llvm-bolt "$prebolt" -instrument -o "${srcdir}/libbpf.bolt-inst.so" \
      --instrumentation-file="$fdata" \
      --instrumentation-sleep-time=3 \
      --instrumentation-no-counters-clear || echo "BOLT instrumentation failed (non-fatal)"

    if [ -f "${srcdir}/libbpf.bolt-inst.so" ]; then
      cp "${srcdir}/libbpf.bolt-inst.so" "$bolt_inst_dir/$(basename "$libname")"
      ln -sf "$(basename "$libname")" "$bolt_inst_dir/libbpf.so.1"
      ln -sf libbpf.so.1 "$bolt_inst_dir/libbpf.so"
    fi

    if [ -d "$bolt_inst_dir" ]; then
      run_heavy_workload "$bolt_inst_dir"
    fi

    if [ -s "$fdata" ]; then
      local prof_size=$(wc -c < "$fdata")
      echo "BOLT profile collected successfully (${prof_size} bytes)"
      llvm-bolt "$prebolt" -o "$bolted" -data="$fdata" \
        -reorder-blocks=ext-tsp \
        -reorder-functions=hfsort+ \
        -split-functions \
        -split-all-cold \
        -split-eh \
        -dyno-stats && {
          echo "BOLT optimization successful!"
          cp "$bolted" "$libname"
          ln -sf "$(basename "$libname")" libbpf.so.1
          ln -sf libbpf.so.1 libbpf.so
        } || echo "BOLT optimization failed"
    else
      echo "WARNING: No BOLT profile data collected"
    fi
  else
    echo "BOLT skipped."
  fi
}

check() {
  cd "${srcdir}/libbpf/src"
  echo "=== libbpf sanity check ==="
  if ls libbpf.so.1.* >/dev/null 2>&1 && nm -D libbpf.so.1.* 2>/dev/null | grep -q libbpf_major_version; then
    echo "✓ Core symbols verified"
  fi
}

package() {
  cd "${srcdir}/libbpf/src"
  DESTDIR="${pkgdir}" make prefix=/usr LIBDIR=/usr/lib install install_headers

  install -Dm644 -t "${pkgdir}/usr/share/licenses/${pkgname}" \
    "${srcdir}/libbpf/LICENSE" "${srcdir}/libbpf/LICENSE.BSD-2-Clause"

  if [ -d "${pkgdir}/usr/lib64" ]; then
    mv "${pkgdir}/usr/lib64" "${pkgdir}/usr/lib"
  fi
}
