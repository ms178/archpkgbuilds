pkgname=libbpf-git
pkgver=1.7.0.r16.dd92bef7
pkgrel=1
pkgdesc='BPF library (high-coverage CS-PGO + robust BOLT optimized)'
arch=('x86_64')
url='https://github.com/libbpf/libbpf'
license=('LGPL-2.1-only' 'BSD-2-Clause')
depends=(
  'libelf'
  'zlib'
  'zstd'
  'linux-api-headers>=6.2'
)
makedepends=(
  'git'
  'clang'
  'llvm'
  'lld'
  'libelf'
  'zlib'
  'zstd'
  'linux-api-headers'
)
provides=(
  "libbpf=${pkgver}"
  'libbpf.so=1-64'
)
conflicts=('libbpf')
source=('git+https://github.com/libbpf/libbpf.git')
sha256sums=('SKIP')
options=(!lto strip)

: "${LIBBPF_PGO_JOBS:=$(nproc)}"
: "${LIBBPF_PGO_WORKER_PASSES:=2}"

declare -ag _LIBBPF_BG_PIDS=()

pkgver() {
  cd "${srcdir}/libbpf"
  git describe --long --tags --abbrev=8 | sed 's/^v//;s/\([^-]*-\)g/r\1/;s/-/./g'
}

_setup_llvm_toolchain() {
  export CC='clang -fuse-ld=lld'
  export CXX='clang++ -fuse-ld=lld'
  export AR=llvm-ar
  export NM=llvm-nm
  export STRIP=llvm-strip
  export RANLIB=llvm-ranlib
  export READELF=llvm-readelf
  export OBJCOPY=llvm-objcopy
  export OBJDUMP=llvm-objdump
}

_copy_stage_tree() {
  local srcroot="$1"
  local dstroot="$2"
  rm -rf "$dstroot"
  cp -a --reflink=auto "$srcroot" "$dstroot"
}

_stage_install() {
  local stageroot="$1"
  local destdir="$2"

  rm -rf "$destdir"
  mkdir -p "$destdir"

  make -C "$stageroot/src" \
    DESTDIR="$destdir" \
    prefix=/usr \
    LIBDIR=/usr/lib \
    install install_headers

  if [[ -d "$destdir/usr/lib64" ]]; then
    mkdir -p "$destdir/usr/lib"
    cp -a "$destdir/usr/lib64"/. "$destdir/usr/lib"/
    rm -rf "$destdir/usr/lib64"
  fi
}

_get_stage_libdir() {
  local instroot="$1"
  local outvar="$2"

  if [[ -d "$instroot/usr/lib" ]]; then
    printf -v "$outvar" '%s' "$instroot/usr/lib"
    return 0
  elif [[ -d "$instroot/usr/lib64" ]]; then
    printf -v "$outvar" '%s' "$instroot/usr/lib64"
    return 0
  fi
  return 1
}

_find_real_shared_object() {
  local search_dir="$1"
  local pattern="$2"
  local outvar="$3"
  local f=''

  while IFS= read -r -d '' f; do
    [[ -L "$f" ]] && continue
    [[ -f "$f" ]] || continue
    "${READELF:-readelf}" -h "$f" >/dev/null 2>&1 || continue
    printf -v "$outvar" '%s' "$f"
    return 0
  done < <(find "$search_dir" -maxdepth 1 -type f -name "$pattern" -print0 2>/dev/null)

  return 1
}

_detect_optional_libbpf_apis() {
  local incdir="$1"
  local out_ring="$2"
  local out_perf="$3"
  local out_user_ring="$4"
  local out_linker="$5"

  local hdrdir="$incdir/bpf"
  local have_ring=0
  local have_perf=0
  local have_user_ring=0
  local have_linker=0

  [[ -d "$hdrdir" ]] || {
    printf -v "$out_ring" '%d' 0
    printf -v "$out_perf" '%d' 0
    printf -v "$out_user_ring" '%d' 0
    printf -v "$out_linker" '%d' 0
    return 0
  }

  grep -Rqs 'ring_buffer__new' "$hdrdir"      && have_ring=1
  grep -Rqs 'perf_buffer__new' "$hdrdir"      && have_perf=1
  grep -Rqs 'user_ring_buffer__new' "$hdrdir" && have_user_ring=1
  grep -Rqs 'bpf_linker__new' "$hdrdir"       && have_linker=1

  printf -v "$out_ring" '%d' "$have_ring"
  printf -v "$out_perf" '%d' "$have_perf"
  printf -v "$out_user_ring" '%d' "$have_user_ring"
  printf -v "$out_linker" '%d' "$have_linker"
}

_merge_profraw_dir() {
  local out="$1"
  local dir="$2"

  if llvm-profdata merge -sparse -output="$out" "$dir" 2>/dev/null; then
    [[ -s "$out" ]] && return 0
  fi

  local -a files chunk parts
  local idx=0 chunk_idx=0
  local tmpdir="${dir}/.merge_tmp"

  rm -rf "$tmpdir"
  mkdir -p "$tmpdir"

  shopt -s nullglob
  files=("$dir"/*.profraw)
  shopt -u nullglob
  (( ${#files[@]} > 0 )) || return 1

  while (( idx < ${#files[@]} )); do
    chunk=("${files[@]:idx:400}")
    llvm-profdata merge -sparse -output="${tmpdir}/part-${chunk_idx}.profdata" "${chunk[@]}"
    ((idx += 400, chunk_idx++))
  done

  shopt -s nullglob
  parts=("${tmpdir}"/*.profdata)
  shopt -u nullglob
  (( ${#parts[@]} > 0 )) || return 1

  llvm-profdata merge -sparse -output="$out" "${parts[@]}"
}

_cleanup_bg_workers() {
  local pid

  ((${#_LIBBPF_BG_PIDS[@]})) || return 0
  echo "  -> stopping ${#_LIBBPF_BG_PIDS[@]} background worker(s)..."

  for pid in "${_LIBBPF_BG_PIDS[@]}"; do
    kill -TERM "$pid" 2>/dev/null || true
    pkill -TERM -P "$pid" 2>/dev/null || true
  done

  sleep 0.3

  for pid in "${_LIBBPF_BG_PIDS[@]}"; do
    kill -KILL "$pid" 2>/dev/null || true
    pkill -KILL -P "$pid" 2>/dev/null || true
  done

  _LIBBPF_BG_PIDS=()
}

_print_fixture_order() {
  local label="$1"
  shift
  local -a arr=("$@")
  local i
  echo "  -> ${label}: ${#arr[@]} fixture(s)"
  for (( i=0; i<${#arr[@]}; i++ )); do
    echo "     [$i] ${arr[i]}"
  done
}

_create_workload_sources() {
  cat > "${srcdir}/libbpf_pgo_workload.c" <<'EOF'
#define _GNU_SOURCE
#ifndef HAVE_RINGBUF_API
#define HAVE_RINGBUF_API 0
#endif
#ifndef HAVE_PERFBUF_API
#define HAVE_PERFBUF_API 0
#endif
#ifndef HAVE_USER_RINGBUF_API
#define HAVE_USER_RINGBUF_API 0
#endif
#ifndef HAVE_LINKER_API
#define HAVE_LINKER_API 0
#endif

#include <bpf/libbpf.h>
#include <bpf/btf.h>
#include <bpf/bpf.h>
#include <linux/bpf.h>
#include <stdarg.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

static int scale(void) {
  const char *s = getenv("LIBBPF_PGO_SCALE");
  const char *d = getenv("LIBBPF_PGO_LOOP_DIVISOR");
  long v = 1;
  long div = 1;

  if (s && *s) {
    char *e = NULL;
    v = strtol(s, &e, 10);
    if (!e || *e || v < 1 || v > 64) v = 1;
  }

  if (d && *d) {
    char *e = NULL;
    div = strtol(d, &e, 10);
    if (!e || *e || div < 1 || div > 128) div = 1;
  }

  v = (v + div - 1) / div;  /* ceil(v/div) */
  if (v < 1) v = 1;
  return (int)v;
}

static int quiet_libbpf(enum libbpf_print_level level, const char *fmt, va_list args) {
  (void)level; (void)fmt; (void)args;
  return 0;
}

static unsigned char *read_file(const char *path, size_t *sz) {
  FILE *f = fopen(path, "rb");
  unsigned char *buf = NULL;
  long size;

  if (!f) return NULL;
  if (fseek(f, 0, SEEK_END) != 0) { fclose(f); return NULL; }
  size = ftell(f);
  if (size < 0) { fclose(f); return NULL; }
  rewind(f);

  buf = malloc((size_t)size);
  if (!buf) { fclose(f); return NULL; }

  if (fread(buf, 1, (size_t)size, f) != (size_t)size) {
    free(buf);
    fclose(f);
    return NULL;
  }
  fclose(f);
  *sz = (size_t)size;
  return buf;
}

static void ex_kernel_btf(const char *path, int mul) {
  int loops = 1200 * mul;
  if (!path || access(path, R_OK) != 0) return;

  for (int i = 0; i < loops; i++) {
    struct btf *btf = btf__parse(path, NULL);
    if (libbpf_get_error(btf)) continue;

    int cnt = btf__type_cnt(btf);
    int lim = cnt < 1024 ? cnt : 1024;
    for (int id = 1; id < lim; id++) {
      const struct btf_type *t = btf__type_by_id(btf, id);
      if (!t) continue;
      if (t->name_off) (void)btf__name_by_offset(btf, t->name_off);
      (void)btf_kind(t);
      (void)btf_vlen(t);
    }

    (void)btf__find_by_name_kind(btf, "task_struct", BTF_KIND_STRUCT);
    (void)btf__find_by_name_kind(btf, "file", BTF_KIND_STRUCT);
    (void)btf__find_by_name_kind(btf, "sock", BTF_KIND_STRUCT);

    btf__free(btf);
  }
}

static void ex_object_open_file(char **fixtures, int nfixtures, int mul) {
  int loops = 420 * mul;
  for (int i = 0; i < loops; i++) {
    for (int f = 0; f < nfixtures; f++) {
      struct bpf_object *obj = bpf_object__open_file(fixtures[f], NULL);
      if (libbpf_get_error(obj)) continue;

      struct bpf_program *prog;
      bpf_object__for_each_program(prog, obj) {
        (void)bpf_program__name(prog);
        (void)bpf_program__section_name(prog);
        (void)bpf_program__insn_cnt(prog);
        (void)bpf_program__type(prog);
        (void)bpf_program__expected_attach_type(prog);
      }

      struct bpf_map *map;
      bpf_object__for_each_map(map, obj) {
        (void)bpf_map__name(map);
        (void)bpf_map__type(map);
        (void)bpf_map__key_size(map);
        (void)bpf_map__value_size(map);
        (void)bpf_map__max_entries(map);
      }

      (void)bpf_object__find_map_by_name(obj, "arr");
      (void)bpf_object__find_map_by_name(obj, "hash_map");
      (void)bpf_object__find_map_by_name(obj, "rb");
      (void)bpf_object__find_program_by_name(obj, "tp_prog");
      (void)bpf_object__find_program_by_name(obj, "xdp_prog");

      bpf_object__close(obj);
    }
  }
}

static void ex_object_open_mem(char **fixtures, int nfixtures, int mul) {
  int loops = 320 * mul;
  for (int f = 0; f < nfixtures; f++) {
    size_t sz = 0;
    unsigned char *buf = read_file(fixtures[f], &sz);
    if (!buf) continue;

    for (int i = 0; i < loops; i++) {
      struct bpf_object *obj = bpf_object__open_mem(buf, sz, NULL);
      if (libbpf_get_error(obj)) continue;

      struct bpf_program *prog;
      bpf_object__for_each_program(prog, obj) {
        (void)bpf_program__name(prog);
        (void)bpf_program__section_name(prog);
      }
      bpf_object__close(obj);
    }

    free(buf);
  }
}

static void ex_object_btf_parse(char **fixtures, int nfixtures, int mul) {
  int loops = 260 * mul;
  for (int f = 0; f < nfixtures; f++) {
    for (int i = 0; i < loops; i++) {
      struct btf_ext *btf_ext = NULL;
      struct btf *btf = btf__parse_elf(fixtures[f], &btf_ext);
      if (libbpf_get_error(btf)) continue;

      int cnt = btf__type_cnt(btf);
      int lim = cnt < 512 ? cnt : 512;
      for (int id = 1; id < lim; id++) {
        const struct btf_type *t = btf__type_by_id(btf, id);
        if (!t) continue;
        if (t->name_off) (void)btf__name_by_offset(btf, t->name_off);
      }

      if (btf_ext) btf_ext__free(btf_ext);
      btf__free(btf);
    }
  }
}

static void maybe_attach_prog(struct bpf_program *prog) {
  struct bpf_link *link = NULL;
  if (bpf_program__fd(prog) < 0) return;
  link = bpf_program__attach(prog);
  if (!libbpf_get_error(link) && link) bpf_link__destroy(link);
}

static void ex_object_load_best_effort(char **fixtures, int nfixtures, int mul) {
  int loops = 200 * mul;
  for (int i = 0; i < loops; i++) {
    for (int f = 0; f < nfixtures; f++) {
      struct bpf_object *obj = bpf_object__open_file(fixtures[f], NULL);
      if (libbpf_get_error(obj)) continue;

      (void)bpf_object__load(obj);

      struct bpf_program *prog;
      bpf_object__for_each_program(prog, obj) {
        (void)bpf_program__fd(prog);
        maybe_attach_prog(prog);
      }

      struct bpf_map *map;
      bpf_object__for_each_map(map, obj) {
        int fd = bpf_map__fd(map);
        if (fd >= 0) {
          int key = i;
          long value = 123;
          (void)bpf_map_lookup_elem(fd, &key, &value);
        }
      }

      bpf_object__close(obj);
    }
  }
}

static int try_map_create(enum bpf_map_type t, const char *name, __u32 key_sz, __u32 val_sz, __u32 max_entries) {
  return bpf_map_create(t, name, key_sz, val_sz, max_entries, NULL);
}

static void ex_map_api(int mul) {
  int loops = 640 * mul;
  for (int i = 0; i < loops; i++) {
    int fd1 = try_map_create(BPF_MAP_TYPE_HASH, "hash", sizeof(int), sizeof(long), 64);
    int fd2 = try_map_create(BPF_MAP_TYPE_ARRAY, "array", sizeof(int), sizeof(long), 64);
    int fd3 = try_map_create(BPF_MAP_TYPE_PERCPU_ARRAY, "percpu", sizeof(int), sizeof(long), 32);
    int fd4 = try_map_create(BPF_MAP_TYPE_QUEUE, "queue", 0, sizeof(long), 16);
    int fd5 = try_map_create(BPF_MAP_TYPE_STACK, "stack", 0, sizeof(long), 16);
    int fd6 = try_map_create(BPF_MAP_TYPE_RINGBUF, "ringbuf", 0, 0, 4096);

    int key = i;
    long value = i * 3L;

    if (fd1 >= 0) { (void)bpf_map_update_elem(fd1, &key, &value, BPF_ANY); (void)bpf_map_lookup_elem(fd1, &key, &value); close(fd1); }
    if (fd2 >= 0) { (void)bpf_map_update_elem(fd2, &key, &value, BPF_ANY); (void)bpf_map_lookup_elem(fd2, &key, &value); close(fd2); }
    if (fd3 >= 0) close(fd3);
    if (fd4 >= 0) close(fd4);
    if (fd5 >= 0) close(fd5);
    if (fd6 >= 0) close(fd6);
  }
}

#if HAVE_RINGBUF_API
static int ring_cb(void *ctx, void *data, size_t size) {
  (void)ctx; (void)data; (void)size;
  return 0;
}
#endif

#if HAVE_PERFBUF_API
static void perf_cb(void *ctx, int cpu, void *data, __u32 size) {
  (void)ctx; (void)cpu; (void)data; (void)size;
}
static void perf_lost(void *ctx, int cpu, __u64 lost) {
  (void)ctx; (void)cpu; (void)lost;
}
#endif

static void ex_buffer_apis(int mul) {
  int loops = 420 * mul;
  for (int i = 0; i < loops; i++) {
#if HAVE_RINGBUF_API
    struct ring_buffer *rb = ring_buffer__new(-1, ring_cb, NULL, NULL);
    if (!libbpf_get_error(rb) && rb) {
      (void)ring_buffer__poll(rb, 0);
      ring_buffer__free(rb);
    }
#endif
#if HAVE_PERFBUF_API
    struct perf_buffer *pb = perf_buffer__new(-1, 8, perf_cb, perf_lost, NULL, NULL);
    if (!libbpf_get_error(pb) && pb) {
      (void)perf_buffer__poll(pb, 0);
      perf_buffer__free(pb);
    }
#endif
#if HAVE_USER_RINGBUF_API
    struct user_ring_buffer *urb = user_ring_buffer__new(-1, NULL);
    if (!libbpf_get_error(urb) && urb)
      user_ring_buffer__free(urb);
#endif
  }
}

#if HAVE_LINKER_API
static void ex_linker_api(char **fixtures, int nfixtures, int mul) {
  int loops = 240 * mul;
  for (int i = 0; i < loops; i++) {
    char out[256];
    snprintf(out, sizeof(out), "/tmp/libbpf-link-%ld-%d.o", (long)getpid(), i);
    struct bpf_linker *linker = bpf_linker__new(out, NULL);
    if (libbpf_get_error(linker)) continue;
    for (int f = 0; f < nfixtures; f++)
      (void)bpf_linker__add_file(linker, fixtures[f], NULL);
    bpf_linker__free(linker);
    unlink(out);
  }
}
#endif

int main(int argc, char **argv) {
  libbpf_set_print(quiet_libbpf);

  const char *vmlinux_btf = getenv("LIBBPF_PGO_VMLINUX_BTF");
  if (!vmlinux_btf || !*vmlinux_btf) vmlinux_btf = "/sys/kernel/btf/vmlinux";

  int mul = scale();
  int nfixtures = argc - 1;
  char **fixtures = argv + 1;

  ex_kernel_btf(vmlinux_btf, mul);
  ex_object_open_file(fixtures, nfixtures, mul);
  ex_object_open_mem(fixtures, nfixtures, mul);
  ex_object_btf_parse(fixtures, nfixtures, mul);
  ex_object_load_best_effort(fixtures, nfixtures, mul);
  ex_map_api(mul);
  ex_buffer_apis(mul);
#if HAVE_LINKER_API
  ex_linker_api(fixtures, nfixtures, mul);
#endif

  return 0;
}
EOF

  cat > "${srcdir}/fixture_core.bpf.c" <<'EOF'
#include <linux/bpf.h>
#include <bpf/bpf_helpers.h>

const volatile __u32 cfg = 1;
__u64 hit_cnt = 0;
__u64 hot_bss;

struct {
  __uint(type, BPF_MAP_TYPE_HASH);
  __uint(max_entries, 64);
  __type(key, __u32);
  __type(value, __u64);
} hash_map SEC(".maps");

struct {
  __uint(type, BPF_MAP_TYPE_ARRAY);
  __uint(max_entries, 16);
  __type(key, __u32);
  __type(value, __u64);
} arr SEC(".maps");

SEC("tracepoint/syscalls/sys_enter_nanosleep")
int tp_prog(void *ctx)
{
  __u32 k = 0;
  __u64 *v = bpf_map_lookup_elem(&arr, &k);
  if (v)
    __sync_fetch_and_add(v, 1);
  hot_bss++;
  return 0;
}

SEC("raw_tp/sys_enter")
int rawtp_prog(void *ctx)
{
  __u32 k = 0;
  __u64 *v = bpf_map_lookup_elem(&arr, &k);
  if (v)
    __sync_fetch_and_add(v, 1);
  return 0;
}

SEC("kprobe/do_sys_openat2")
int kp_prog(void *ctx)
{
  __u32 k = cfg;
  __u64 v = hit_cnt + 1;
  bpf_map_update_elem(&hash_map, &k, &v, BPF_ANY);
  return 0;
}

