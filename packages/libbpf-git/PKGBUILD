pkgname=libbpf-git
pkgver=1.6.0.r138.f5dcbae7
pkgrel=1
pkgdesc='BPF library (custom libbpf/scx-style CS-PGO + BOLT optimized)'
arch=('x86_64')
url='https://github.com/libbpf/libbpf'
license=('LGPL-2.1-only' 'BSD-2-Clause')
depends=(
  'libelf'
  'zlib'
  'zstd'
  'linux-api-headers>=6.2'
)
makedepends=(
  'git'
  'clang'
  'llvm'
  'lld'
  'libelf'
  'zlib'
  'zstd'
  'linux-api-headers'
)
provides=(
  "libbpf=${pkgver}"
  'libbpf.so=1-64'
)
conflicts=('libbpf')
source=('git+https://github.com/libbpf/libbpf.git')
sha256sums=('SKIP')
options=(!lto strip)

pkgver() {
  cd "${srcdir}/libbpf"
  git describe --long --tags --abbrev=8 | sed 's/^v//;s/\([^-]*-\)g/r\1/;s/-/./g'
}

_setup_llvm_toolchain() {
  export CC="clang -fuse-ld=lld"
  export CXX="clang++ -fuse-ld=lld"
  export AR=llvm-ar
  export NM=llvm-nm
  export STRIP=llvm-strip
  export RANLIB=llvm-ranlib
  export READELF=llvm-readelf
  export OBJCOPY=llvm-objcopy
  export OBJDUMP=llvm-objdump
}

_stage_slug() {
  printf '%s' "$1" | tr ' /' '__'
}

_copy_stage_tree() {
  local srcroot="$1"
  local dstroot="$2"
  rm -rf "$dstroot"
  cp -a --reflink=auto "$srcroot" "$dstroot"
}

_stage_install() {
  local stageroot="$1"
  local destdir="$2"

  rm -rf "$destdir"
  mkdir -p "$destdir"

  make -C "$stageroot/src" \
    DESTDIR="$destdir" \
    prefix=/usr \
    LIBDIR=/usr/lib \
    install install_headers

  if [[ -d "$destdir/usr/lib64" ]]; then
    mkdir -p "$destdir/usr/lib"
    cp -a "$destdir/usr/lib64"/. "$destdir/usr/lib"/
    rm -rf "$destdir/usr/lib64"
  fi
}

_get_stage_libdir() {
  local instroot="$1"
  local outvar="$2"

  if [[ -d "$instroot/usr/lib" ]]; then
    printf -v "$outvar" '%s' "$instroot/usr/lib"
    return 0
  elif [[ -d "$instroot/usr/lib64" ]]; then
    printf -v "$outvar" '%s' "$instroot/usr/lib64"
    return 0
  fi

  return 1
}

_find_real_shared_object() {
  local search_dir="$1"
  local pattern="$2"
  local outvar="$3"
  local f=''

  while IFS= read -r -d '' f; do
    [[ -L "$f" ]] && continue
    [[ -f "$f" ]] || continue
    "${READELF:-readelf}" -h "$f" >/dev/null 2>&1 || continue
    printf -v "$outvar" '%s' "$f"
    return 0
  done < <(find "$search_dir" -maxdepth 1 -type f -name "$pattern" -print0 2>/dev/null)

  return 1
}

_reverse_array() {
  local -n _in_ref="$1"
  local -n _out_ref="$2"
  _out_ref=()

  local i
  for (( i=${#_in_ref[@]}-1; i>=0; i-- )); do
    _out_ref+=("${_in_ref[i]}")
  done
}

_rotate_array_half() {
  local -n _in_ref="$1"
  local -n _out_ref="$2"
  _out_ref=()

  local n=${#_in_ref[@]}
  (( n == 0 )) && return 0

  local start=$(( n / 2 ))
  local i
  for (( i=0; i<n; i++ )); do
    _out_ref+=("${_in_ref[(start + i) % n]}")
  done
}

_create_workload_sources() {
  cat > "${srcdir}/libbpf_pgo_workload.c" <<'EOF'
#define _GNU_SOURCE
#include <bpf/libbpf.h>
#include <bpf/btf.h>
#include <bpf/bpf.h>
#include <dlfcn.h>
#include <linux/bpf.h>
#include <stdarg.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

#define VMLINUX_BTF_LOOPS       1000
#define VMLINUX_TYPE_SCAN_MAX    768
#define OBJ_OPEN_FILE_LOOPS      320
#define OBJ_OPEN_MEM_LOOPS       240
#define OBJ_BTF_PARSE_LOOPS      200
#define OBJ_LOAD_LOOPS           128
#define MAP_API_LOOPS            384

static int quiet_libbpf(enum libbpf_print_level level, const char *fmt, va_list args) {
  (void)level;
  (void)fmt;
  (void)args;
  return 0;
}

static void print_loaded_libs(void) {
  Dl_info info;

  if (dladdr((void *)&bpf_object__open_file, &info) && info.dli_fname)
    printf("  libbpf path: %s\n", info.dli_fname);

  if (dladdr((void *)&btf__parse, &info) && info.dli_fname)
    printf("  libbpf/btf path: %s\n", info.dli_fname);
}

static unsigned char *read_file(const char *path, size_t *sz) {
  FILE *f = fopen(path, "rb");
  unsigned char *buf = NULL;
  long size;

  if (!f)
    return NULL;
  if (fseek(f, 0, SEEK_END) != 0) {
    fclose(f);
    return NULL;
  }
  size = ftell(f);
  if (size < 0) {
    fclose(f);
    return NULL;
  }
  rewind(f);

  buf = malloc((size_t)size);
  if (!buf) {
    fclose(f);
    return NULL;
  }
  if (fread(buf, 1, (size_t)size, f) != (size_t)size) {
    free(buf);
    fclose(f);
    return NULL;
  }
  fclose(f);
  *sz = (size_t)size;
  return buf;
}

static void ex_kernel_btf(const char *path) {
  if (!path || access(path, R_OK) != 0) {
    printf("  kernel-btf: unavailable\n");
    return;
  }

  printf("  kernel-btf: %d parses of %s\n", VMLINUX_BTF_LOOPS, path);
  for (int i = 0; i < VMLINUX_BTF_LOOPS; i++) {
    struct btf *btf = btf__parse(path, NULL);
    if (libbpf_get_error(btf))
      continue;

    int cnt = btf__type_cnt(btf);
    int lim = cnt < VMLINUX_TYPE_SCAN_MAX ? cnt : VMLINUX_TYPE_SCAN_MAX;
    for (int id = 1; id < lim; id++) {
      const struct btf_type *t = btf__type_by_id(btf, id);
      if (!t)
        continue;
      if (t->name_off)
        (void)btf__name_by_offset(btf, t->name_off);
      (void)btf_kind(t);
      (void)btf_vlen(t);
    }

    (void)btf__find_by_name_kind(btf, "task_struct", BTF_KIND_STRUCT);
    (void)btf__find_by_name_kind(btf, "file", BTF_KIND_STRUCT);
    (void)btf__find_by_name_kind(btf, "sock", BTF_KIND_STRUCT);

    btf__free(btf);
  }
}

static void ex_object_open_file(char **fixtures, int nfixtures) {
  printf("  object-open-file: %d fixtures x %d loops\n", nfixtures, OBJ_OPEN_FILE_LOOPS);
  for (int i = 0; i < OBJ_OPEN_FILE_LOOPS; i++) {
    for (int f = 0; f < nfixtures; f++) {
      struct bpf_object *obj = bpf_object__open_file(fixtures[f], NULL);
      if (libbpf_get_error(obj))
        continue;

      struct bpf_program *prog;
      bpf_object__for_each_program(prog, obj) {
        (void)bpf_program__name(prog);
        (void)bpf_program__section_name(prog);
        (void)bpf_program__insn_cnt(prog);
        (void)bpf_program__type(prog);
        (void)bpf_program__expected_attach_type(prog);
        bpf_program__set_autoload(prog, false);
        bpf_program__set_autoload(prog, true);
      }

      struct bpf_map *map;
      bpf_object__for_each_map(map, obj) {
        (void)bpf_map__name(map);
        (void)bpf_map__type(map);
        (void)bpf_map__key_size(map);
        (void)bpf_map__value_size(map);
        (void)bpf_map__max_entries(map);
        (void)bpf_map__map_flags(map);
      }

      (void)bpf_object__find_map_by_name(obj, "arr");
      (void)bpf_object__find_map_by_name(obj, "hash_map");
      (void)bpf_object__find_map_by_name(obj, "rb");
      bpf_object__close(obj);
    }
  }
}

static void ex_object_open_mem(char **fixtures, int nfixtures) {
  printf("  object-open-mem: %d fixtures x %d loops\n", nfixtures, OBJ_OPEN_MEM_LOOPS);
  for (int f = 0; f < nfixtures; f++) {
    size_t sz = 0;
    unsigned char *buf = read_file(fixtures[f], &sz);
    if (!buf)
      continue;

    for (int i = 0; i < OBJ_OPEN_MEM_LOOPS; i++) {
      struct bpf_object *obj = bpf_object__open_mem(buf, sz, NULL);
      if (libbpf_get_error(obj))
        continue;

      struct bpf_program *prog;
      bpf_object__for_each_program(prog, obj) {
        (void)bpf_program__name(prog);
        (void)bpf_program__section_name(prog);
        (void)bpf_program__insn_cnt(prog);
      }

      struct bpf_map *map;
      bpf_object__for_each_map(map, obj) {
        (void)bpf_map__name(map);
        (void)bpf_map__type(map);
      }

      bpf_object__close(obj);
    }

    free(buf);
  }
}

static void ex_object_btf_parse(char **fixtures, int nfixtures) {
  printf("  object-btf-parse: %d fixtures x %d loops\n", nfixtures, OBJ_BTF_PARSE_LOOPS);
  for (int f = 0; f < nfixtures; f++) {
    for (int i = 0; i < OBJ_BTF_PARSE_LOOPS; i++) {
      struct btf_ext *btf_ext = NULL;
      struct btf *btf = btf__parse_elf(fixtures[f], &btf_ext);
      if (libbpf_get_error(btf))
        continue;

      int cnt = btf__type_cnt(btf);
      int lim = cnt < 256 ? cnt : 256;
      for (int id = 1; id < lim; id++) {
        const struct btf_type *t = btf__type_by_id(btf, id);
        if (!t)
          continue;
        if (t->name_off)
          (void)btf__name_by_offset(btf, t->name_off);
      }

      if (btf_ext)
        btf_ext__free(btf_ext);
      btf__free(btf);
    }
  }
}

static void maybe_attach_prog(struct bpf_program *prog) {
  struct bpf_link *link = NULL;

  if (bpf_program__fd(prog) < 0)
    return;

  link = bpf_program__attach(prog);
  if (!libbpf_get_error(link) && link)
    bpf_link__destroy(link);
}

static void ex_object_load_best_effort(char **fixtures, int nfixtures) {
  printf("  object-load: %d fixtures x %d loops\n", nfixtures, OBJ_LOAD_LOOPS);
  for (int i = 0; i < OBJ_LOAD_LOOPS; i++) {
    for (int f = 0; f < nfixtures; f++) {
      struct bpf_object *obj = bpf_object__open_file(fixtures[f], NULL);
      if (libbpf_get_error(obj))
        continue;

      struct bpf_program *prog;
      bpf_object__for_each_program(prog, obj) {
        bpf_program__set_autoload(prog, true);
      }

      (void)bpf_object__load(obj);

      bpf_object__for_each_program(prog, obj) {
        (void)bpf_program__fd(prog);
        maybe_attach_prog(prog);
      }

      struct bpf_map *map;
      bpf_object__for_each_map(map, obj) {
        int fd = bpf_map__fd(map);
        if (fd >= 0) {
          int key = 0;
          long value = 123;
          (void)bpf_map_lookup_elem(fd, &key, &value);
        }
      }

      bpf_object__close(obj);
    }
  }
}

static int try_map_create(enum bpf_map_type t, const char *name, __u32 key_sz, __u32 val_sz, __u32 max_entries) {
  return bpf_map_create(t, name, key_sz, val_sz, max_entries, NULL);
}

static void ex_map_api(void) {
  printf("  map-api: %d best-effort syscall cycles\n", MAP_API_LOOPS);
  for (int i = 0; i < MAP_API_LOOPS; i++) {
    int fd1 = try_map_create(BPF_MAP_TYPE_HASH, "hash", sizeof(int), sizeof(long), 64);
    int fd2 = try_map_create(BPF_MAP_TYPE_ARRAY, "array", sizeof(int), sizeof(long), 64);
    int fd3 = try_map_create(BPF_MAP_TYPE_PERCPU_ARRAY, "percpu", sizeof(int), sizeof(long), 32);
    int fd4 = try_map_create(BPF_MAP_TYPE_QUEUE, "queue", 0, sizeof(long), 16);

    int key = i;
    long value = i * 3L;

    if (fd1 >= 0) {
      (void)bpf_map_update_elem(fd1, &key, &value, BPF_ANY);
      (void)bpf_map_lookup_elem(fd1, &key, &value);
      if ((i & 7) == 0)
        (void)bpf_map_delete_elem(fd1, &key);
      close(fd1);
    }

    if (fd2 >= 0) {
      (void)bpf_map_update_elem(fd2, &key, &value, BPF_ANY);
      (void)bpf_map_lookup_elem(fd2, &key, &value);
      close(fd2);
    }

    if (fd3 >= 0)
      close(fd3);
    if (fd4 >= 0)
      close(fd4);
  }
}

int main(int argc, char **argv) {
  setvbuf(stdout, NULL, _IONBF, 0);
  setvbuf(stderr, NULL, _IONBF, 0);

  libbpf_set_print(quiet_libbpf);

  const char *vmlinux_btf = getenv("LIBBPF_PGO_VMLINUX_BTF");
  if (!vmlinux_btf || !*vmlinux_btf)
    vmlinux_btf = "/sys/kernel/btf/vmlinux";

  int nfixtures = argc - 1;
  char **fixtures = argv + 1;

  printf("libbpf PGO helper start\n");
  print_loaded_libs();
  printf("  kernel BTF path: %s\n", vmlinux_btf);
  printf("  libbpf version: %d.%d\n", libbpf_major_version(), libbpf_minor_version());
  printf("  fixtures passed: %d\n", nfixtures);
  for (int i = 0; i < nfixtures; i++)
    printf("    fixture[%d]: %s\n", i, fixtures[i]);

  ex_kernel_btf(vmlinux_btf);
  ex_object_open_file(fixtures, nfixtures);
  ex_object_open_mem(fixtures, nfixtures);
  ex_object_btf_parse(fixtures, nfixtures);
  ex_object_load_best_effort(fixtures, nfixtures);
  ex_map_api();

  printf("libbpf PGO helper end\n");
  return 0;
}
EOF

  cat > "${srcdir}/fixture_core.bpf.c" <<'EOF'
#include <linux/bpf.h>
#include <bpf/bpf_helpers.h>

const volatile __u32 cfg = 1;
__u64 hit_cnt = 0;
__u64 hot_bss;

struct {
  __uint(type, BPF_MAP_TYPE_HASH);
  __uint(max_entries, 64);
  __type(key, __u32);
  __type(value, __u64);
} hash_map SEC(".maps");

struct {
  __uint(type, BPF_MAP_TYPE_ARRAY);
  __uint(max_entries, 16);
  __type(key, __u32);
  __type(value, __u64);
} arr SEC(".maps");

static __always_inline int subprog(__u32 k)
{
  __u64 *v = bpf_map_lookup_elem(&arr, &k);
  if (v)
    __sync_fetch_and_add(v, 1);
  return 0;
}

SEC("tracepoint/syscalls/sys_enter_nanosleep")
int tp_prog(void *ctx)
{
  __u32 k = 0;
  subprog(k);
  hot_bss++;
  return 0;
}

SEC("raw_tp/sys_enter")
int rawtp_prog(void *ctx)
{
  __u32 k = 0;
  subprog(k);
  return 0;
}

SEC("kprobe/do_sys_openat2")
int kp_prog(void *ctx)
{
  __u32 k = cfg;
  __u64 v = hit_cnt + 1;
  bpf_map_update_elem(&hash_map, &k, &v, BPF_ANY);
  return 0;
}

