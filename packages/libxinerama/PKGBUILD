pkgname=libxinerama
pkgver=1.1.6
pkgrel=3.7
pkgdesc="X11 Xinerama extension library (PGO/CS-PGO optimized)"
arch=('x86_64')
url="https://xorg.freedesktop.org/"
license=('custom')
depends=('libxext')
makedepends=('xorg-util-macros' 'xorgproto' 'clang' 'llvm' 'xorg-server-xvfb')
options=('strip')
source=("${url}"/archive/individual/lib/libXinerama-${pkgver}.tar.xz{,.sig})
sha512sums=('735b5320de4782005b379e409bf2f976131c17d496b297d33a0e127ca1443034778586b6b25c077b2ad73a4ab34d440d7510475e0041f38202bb40f15fb08ff7'
            'SKIP')
validpgpkeys=('4A193C06D35E7C670FA4EF0BA2FB9E081F2D130E') # Alan Coopersmith <alan.coopersmith@oracle.com>

prepare() {
  cd "libXinerama-${pkgver}"

  cat > "${srcdir}/xinerama_pgo_workload.c" << 'EOF'
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <unistd.h>
#include <X11/Xlib.h>
#include <X11/extensions/Xinerama.h>

static uint64_t checksum_screens(const XineramaScreenInfo *info, int n, int reverse) {
  uint64_t acc = 0xcbf29ce484222325ULL;
  if (!info || n <= 0) return acc;

  if (!reverse) {
    for (int i = 0; i < n; ++i) {
      acc ^= (uint64_t)info[i].screen_number; acc *= 0x100000001b3ULL;
      acc ^= (uint64_t)(uint32_t)info[i].x_org; acc *= 0x100000001b3ULL;
      acc ^= (uint64_t)(uint32_t)info[i].y_org; acc *= 0x100000001b3ULL;
      acc ^= (uint64_t)info[i].width; acc *= 0x100000001b3ULL;
      acc ^= (uint64_t)info[i].height; acc *= 0x100000001b3ULL;
    }
  } else {
    for (int i = n - 1; i >= 0; --i) {
      acc ^= (uint64_t)info[i].screen_number; acc *= 0x100000001b3ULL;
      acc ^= (uint64_t)(uint32_t)info[i].x_org; acc *= 0x100000001b3ULL;
      acc ^= (uint64_t)(uint32_t)info[i].y_org; acc *= 0x100000001b3ULL;
      acc ^= (uint64_t)info[i].width; acc *= 0x100000001b3ULL;
      acc ^= (uint64_t)info[i].height; acc *= 0x100000001b3ULL;
    }
  }
  return acc;
}

static void phase_train(Display *dpy, int loops, int sync_interval, int secondary_queries) {
  int event_base = 0, error_base = 0;
  int major = 0, minor = 0;
  volatile uint64_t sink = 0;

  for (int i = 0; i < loops; ++i) {
    XineramaQueryExtension(dpy, &event_base, &error_base);
    XineramaQueryVersion(dpy, &major, &minor);

    if (XineramaIsActive(dpy)) {
      int n1 = 0;
      XineramaScreenInfo *s1 = XineramaQueryScreens(dpy, &n1);
      sink ^= checksum_screens(s1, n1, 0);

      if (secondary_queries) {
        int n2 = 0;
        XineramaScreenInfo *s2 = XineramaQueryScreens(dpy, &n2);
        sink ^= checksum_screens(s2, n2, 1);
        if (s2) XFree(s2);
      }

      if (s1) XFree(s1);
    }

    if (sync_interval > 0 && (i % sync_interval) == 0) {
      XSync(dpy, False);
    }
  }

  if (sink == 0xdeadbeefULL) {
    fprintf(stderr, "sink=%llu\n", (unsigned long long)sink);
  }
}

static void train_connection(const char *display_name, int base_loops) {
  Display *dpy = XOpenDisplay(display_name);
  if (!dpy) return;

  phase_train(dpy, base_loops / 2, 64, 0);
  phase_train(dpy, base_loops,     32, 1);
  phase_train(dpy, base_loops * 2, 16, 1);
  phase_train(dpy, base_loops / 3,  8, 0);

  XSync(dpy, False);
  XCloseDisplay(dpy);
}

int main(int argc, char **argv) {
  int loops = (argc > 1) ? atoi(argv[1]) : 2400;
  if (loops < 200) loops = 200;

  const char *disp = getenv("DISPLAY");
  train_connection(disp, loops);
  usleep(10000);
  train_connection(disp, loops / 2);

  return 0;
}
EOF
}

_strip_pgo_flags() {
  local in="$1"
  # Remove any pre-existing profile flags so stages do not conflict with each other.
  in="$(sed -E \
    -e 's/(^|[[:space:]])-f(profile|cs-profile)[^[:space:]]*//g' \
    -e 's/(^|[[:space:]])-W(no-)?profile[^[:space:]]*//g' \
    -e 's/[[:space:]]+/ /g' <<< "$in")"
  echo "${in#"${in%%[![:space:]]*}"}"
}

_supports_flags() {
  local flags="$1"
  printf 'int main(void){return 0;}\n' | "${CC:-clang}" ${flags} -x c - -o /dev/null >/dev/null 2>&1
}

_start_xvfb() {
  local d
  for d in :99 :100 :101 :102 :103; do
    Xvfb "$d" -screen 0 1920x1080x24 \
      +extension XINERAMA +extension RANDR +extension RENDER +extension XFIXES \
      -nolisten tcp >/dev/null 2>&1 &
    XVFB_PID=$!
    sleep 1
    if kill -0 "$XVFB_PID" 2>/dev/null; then
      export DISPLAY="$d"
      return 0
    fi
  done
  return 1
}

_stop_xvfb() {
  if [[ -n "${XVFB_PID:-}" ]]; then
    kill "$XVFB_PID" >/dev/null 2>&1 || true
    wait "$XVFB_PID" 2>/dev/null || true
  fi
}

_compile_workload() {
  local build_dir="$1"
  local lib_so="${build_dir}/src/.libs/libXinerama.so"

  [[ -f "${lib_so}" ]] || return 1
  cd "$build_dir" || return 1

  ./libtool --tag=CC --mode=link "${CC:-clang}" \
    "${srcdir}/xinerama_pgo_workload.c" \
    -o "${srcdir}/xinerama_pgo_runner" \
    -I"${build_dir}/include" \
    -I"${srcdir}/libXinerama-${pkgver}/include" \
    "${lib_so}" \
    -lX11 -lXext \
    -Wl,-rpath,"${build_dir}/src/.libs"
}

_run_training() {
  local build_dir="$1"
  local profile_pattern="$2"

  cd "$build_dir" || return 1
  _compile_workload "$build_dir" || return 1

  for loops in 1800 2600 3400; do
    ./libtool --mode=execute env \
      LD_LIBRARY_PATH="${build_dir}/src/.libs:${LD_LIBRARY_PATH}" \
      LLVM_PROFILE_FILE="${profile_pattern}" \
      LLVM_PROFILE_MERGE_POOL_SIZE=8 \
      "${srcdir}/xinerama_pgo_runner" "${loops}" || true
  done

  rm -f "${srcdir}/xinerama_pgo_runner"
}

_validate_profdata() {
  local prof="$1"
  [[ -s "$prof" ]] || return 1

  if llvm-profdata show --help 2>&1 | grep -q -- '--summary-only'; then
    llvm-profdata show --summary-only "$prof" >/dev/null 2>&1
  else
    llvm-profdata show "$prof" >/dev/null 2>&1
  fi
}

_merge_raw_to_profdata() {
  local raw_dir="$1"
  local out_prof="$2"
  local stage="$3"

  mapfile -t _raw_profiles < <(find "${raw_dir}" -maxdepth 1 -type f -name '*.profraw' -size +0c | sort)
  if (( ${#_raw_profiles[@]} < 1 )); then
    echo "ERROR: ${stage}: no profraw files found in ${raw_dir}."
    return 1
  fi

  llvm-profdata merge -o "${out_prof}" "${_raw_profiles[@]}" || {
    echo "ERROR: ${stage}: llvm-profdata merge failed."
    return 1
  }

  _validate_profdata "${out_prof}" || {
    echo "ERROR: ${stage}: merged profile failed validation."
    return 1
  }
}

build() {
  cd "libXinerama-${pkgver}"

  export CC=clang
  export CXX=clang++

  local _base_cflags="$(_strip_pgo_flags "${CFLAGS}")"
  local _base_cxxflags="$(_strip_pgo_flags "${CXXFLAGS}")"
  local _base_ldflags="$(_strip_pgo_flags "${LDFLAGS}")"

  local _pgo_dir="${srcdir}/pgo-data"
  local _cspgo_dir="${srcdir}/cspgo-data"

  mkdir -p "${_pgo_dir}" "${_cspgo_dir}"
  rm -f "${_pgo_dir}"/*.profraw "${_cspgo_dir}"/*.profraw \
        "${_pgo_dir}/default.profdata" "${_cspgo_dir}/cs.profdata"

  trap '_stop_xvfb; rm -f "${srcdir}/xinerama_pgo_runner"' EXIT

  _start_xvfb || {
    echo "ERROR: could not start Xvfb; refusing to continue."
    return 1
  }

  # Stage 1: classic PGO profile generation
  export CFLAGS="${_base_cflags} -fprofile-generate=${_pgo_dir}"
  export CXXFLAGS="${_base_cxxflags} -fprofile-generate=${_pgo_dir}"
  export LDFLAGS="${_base_ldflags}"

  ./configure --prefix=/usr || return 1
  make ${MAKEFLAGS:-"-j$(nproc)"} || return 1

  _run_training "$PWD" "${_pgo_dir}/stage1-%h-%p-%m.profraw" || return 1
  _merge_raw_to_profdata "${_pgo_dir}" "${_pgo_dir}/default.profdata" "Stage 1" || return 1

  # Stage 2: CS profile generation (without -fprofile-generate to avoid clang conflict)
  make distclean || true

  local _cs_gen_flags="-fcs-profile-generate"
  if _supports_flags "-fprofile-instr-generate -fcs-profile-generate"; then
    _cs_gen_flags="-fprofile-instr-generate -fcs-profile-generate"
  fi

  export CFLAGS="${_base_cflags} ${_cs_gen_flags}"
  export CXXFLAGS="${_base_cxxflags} ${_cs_gen_flags}"
  export LDFLAGS="${_base_ldflags}"

  ./configure --prefix=/usr || return 1
  make ${MAKEFLAGS:-"-j$(nproc)"} || return 1

  _run_training "$PWD" "${_cspgo_dir}/stage2-%h-%p-%m.profraw" || return 1

  mapfile -t _stage2_raw < <(find "${_cspgo_dir}" -maxdepth 1 -type f -name '*.profraw' -size +0c | sort)
  if (( ${#_stage2_raw[@]} < 1 )); then
    echo "ERROR: Stage 2: no CS profraw files found."
    return 1
  fi

  llvm-profdata merge -o "${_cspgo_dir}/cs.profdata" "${_stage2_raw[@]}" "${_pgo_dir}/default.profdata" || {
    echo "ERROR: Stage 2: final CS merge failed."
    return 1
  }

  _validate_profdata "${_cspgo_dir}/cs.profdata" || {
    echo "ERROR: Stage 2: cs.profdata validation failed."
    return 1
  }

  # Stage 3: final optimized build
  make distclean || true

  export CFLAGS="${_base_cflags} -fprofile-use=${_cspgo_dir}/cs.profdata -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export CXXFLAGS="${_base_cxxflags} -fprofile-use=${_cspgo_dir}/cs.profdata -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export LDFLAGS="${_base_ldflags}"

  ./configure --prefix=/usr || return 1
  make ${MAKEFLAGS:-"-j$(nproc)"} || return 1
}

package() {
  cd "libXinerama-${pkgver}"
  make DESTDIR="${pkgdir}" install

  install -m755 -d "${pkgdir}/usr/share/licenses/${pkgname}"
  install -m644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/"
}
