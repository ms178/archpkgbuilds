	--enable-decoder=mp3 \
	--enable-decoder=flac \
	--enable-decoder=alac \
	--enable-decoder=pcm* \
	--enable-decoder=apng \
	--enable-decoder=libvpx_vp8 \
	--enable-decoder=libvpx_vp9 \
	--enable-encoder=aac \
	--enable-encoder=h264_vaapi \
	--enable-encoder=hevc_vaapi \
	--enable-demuxer=aac \
	--enable-demuxer=gif \
	--enable-demuxer=ogg \
	--enable-demuxer=mov \
	--enable-demuxer=mp3 \
	--enable-demuxer=flac \
	--enable-demuxer=wav \
	--enable-demuxer=flv \
	--enable-demuxer=apng \
	--enable-demuxer=mpegts \
	--enable-demuxer=asf \
	--enable-demuxer=rtsp \
	--enable-demuxer=xwma \
	--enable-muxer=asf \
	--enable-muxer=asf_stream \
	--enable-muxer=flv \
	--enable-muxer=mp4 \
	--enable-muxer=dash \
	--enable-muxer=webm \
	--enable-muxer=mpegts \
	--enable-parser=mpeg4video \
	--enable-parser=h264 \
	--enable-parser=hevc \
	--enable-parser=vc1 \
	--enable-parser=mpegaudio \
	--enable-filter=scale \
	--enable-protocol=file \
	--enable-protocol=rtp \
	--enable-protocol=rtmp \
	--enable-protocol=rtsp \

FFMPEG_i386-unix_CONFIGURE_ARGS := \
	--cross-prefix=i686-pc-linux-gnu- \
	--arch=x86 \
	--target-os=linux

FFMPEG_i386-unix_CONFIGURE_ARGS += \
	--optflags="$(CFLAGS) $(i386_CFLAGS)"

FFMPEG_x86_64-unix_CONFIGURE_ARGS := \
	--cross-prefix=x86_64-pc-linux-gnu- \
	--arch=x86_64 \
	--target-os=linux

FFMPEG_x86_64-unix_CONFIGURE_ARGS += \
	--optflags="$(CFLAGS) $(x86_64_CFLAGS)"

FFMPEG_aarch64-unix_CONFIGURE_ARGS := \
	--cross-prefix=aarch64-linux-gnu- \
	--arch=aarch64 \
	--target-os=linux

$(eval $(call rules-source,ffmpeg,$(SRCDIR)/ffmpeg))
$(eval $(call rules-configure,ffmpeg,i386,unix))
$(eval $(call rules-configure,ffmpeg,x86_64,unix))
$(eval $(call rules-configure,ffmpeg,aarch64,unix))


