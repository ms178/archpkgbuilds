GST_LIBAV_MESON_ARGS := \
    $(GST_LTO) \
    -Dtests=disabled \
    -Ddoc=disabled \

GST_LIBAV_DEPENDS = gst_orc gstreamer gst_base ffmpeg

$(eval $(call rules-source,gst_libav,$(SRCDIR)/gstreamer/subprojects/gst-libav))
