##
## FFmpeg
##

FFMPEG_CONFIGURE_ARGS := \
	--enable-shared \
	--disable-static \
	--disable-everything \
	--disable-programs \
	--disable-doc \
	--disable-inline-asm \
	--enable-demuxer=matroska \

FFMPEG_CONFIGURE_ARGS += \
	$(FFMPEG_LTO) \
	--enable-decoders \
	--enable-muxers \
