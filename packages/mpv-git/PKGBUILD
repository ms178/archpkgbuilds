_gitname=mpv
pkgname=mpv-git
pkgver=git_release_135_g7aa8580cab
pkgrel=1
pkgdesc='Video player based on MPlayer/mplayer2 (git version, CS-PGO + BOLT optimized)'
arch=('x86_64')
license=('GPL-2.0-or-later')
url='https://mpv.io'
install=mpv.install

# ──────────────────────────────────────────────────────────────────────
# Feature selection — uncomment to enable
# ──────────────────────────────────────────────────────────────────────
_opt_features=(
  #dvd
  #cd
  #sdl2
  #openal
  #lua
  luajit
  #javascript
  x11
  wayland
  #uchardet
  #rubberband
  #vapoursynth
  dvbin
)

# ──────────────────────────────────────────────────────────────────────
# Dependencies — provider-neutral: we depend on the *virtual* provides
# that any correct libglvnd package (repo or -git) exposes, never on a
# concrete package name.
# ──────────────────────────────────────────────────────────────────────
_undetected_depends=(
  'hicolor-icon-theme'
)

depends=(
  'ffmpeg'
  'libplacebo'
  'libass'
  'libgl'          # satisfied by libglvnd OR libglvnd-git
  'libegl'         # satisfied by libglvnd OR libglvnd-git
  'libgles'        # satisfied by libglvnd OR libglvnd-git
  "${_undetected_depends[@]}"
)

optdepends=(
  'yt-dlp: for video-sharing websites playback (preferred over youtube-dl)'
  'youtube-dl: for video-sharing websites playback'
)

makedepends=(
  'git'
  'meson'
  'ninja'
  'clang'
  'llvm'
  'lld'
  'python'
  'python-docutils'
  'pacman-contrib'
  'vulkan-headers'
  'pkgconf'
)

provides=('mpv' 'libmpv.so')
conflicts=('mpv')
options=('!emptydirs' '!lto' 'strip')

source=(
  'git+https://github.com/mpv-player/mpv'
  'find-deps.py'
)
sha256sums=(
  'SKIP'
  '1ba780ede4a28b68ae5b7ab839958ff91ed01d3c6c1d24cce8a5dd24492f8d2b'
)

# ──────────────────────────────────────────────────────────────────────
# Process feature toggles
# ──────────────────────────────────────────────────────────────────────
_opt_extra_flags=()

for _feature in "${_opt_features[@]}"; do
  case "$_feature" in
    dvd)
      depends+=('libdvdnav')
      _opt_extra_flags+=('-Ddvdnav=enabled')
      ;;
    cd)
      depends+=('libcdio-paranoia')
      _opt_extra_flags+=('-Dcdda=enabled')
      ;;
    lua)
      depends+=('lua52')
      _opt_extra_flags+=('-Dlua=enabled' '-Dlua=lua52')
      ;;
    luajit)
      depends+=('luajit')
      _opt_extra_flags+=('-Dlua=enabled' '-Dlua=luajit')
      ;;
    javascript)
      depends+=('mujs')
      _opt_extra_flags+=('-Djavascript=enabled')
      ;;
    x11)
      depends+=('libxinerama' 'libxpresent' 'libxss')
      _opt_extra_flags+=('-Dx11=enabled')
      ;;
    wayland)
      depends+=('wayland' 'libxkbcommon')
      makedepends+=('wayland-protocols')
      _opt_extra_flags+=('-Dwayland=enabled')
      ;;
    sdl2|openal|uchardet|rubberband|vapoursynth)
      depends+=("$_feature")
      _opt_extra_flags+=("-D${_feature}=enabled")
      ;;
    dvbin)
      _opt_extra_flags+=("-D${_feature}=enabled")
      ;;
    *)
      echo "ERROR: Unknown feature option: $_feature" >&2
      exit 1
      ;;
  esac
done

# ──────────────────────────────────────────────────────────────────────
# Helper functions
# ──────────────────────────────────────────────────────────────────────

_setup_llvm_toolchain() {
  export CC="clang -fuse-ld=lld"
  export CXX="clang++ -fuse-ld=lld"
  export AR=llvm-ar
  export NM=llvm-nm
  export STRIP=llvm-strip
  export RANLIB=llvm-ranlib
  export READELF=llvm-readelf
  export OBJCOPY=llvm-objcopy
  export OBJDUMP=llvm-objdump
}

_stage_slug() {
  printf '%s' "$1" | tr ' /' '__'
}

_stage_install() {
  local builddir="$1"
  local destdir="$2"

  rm -rf "$destdir"
  mkdir -p "$destdir"
  DESTDIR="$destdir" meson install -C "$builddir" --no-rebuild
}

_get_stage_bindir() {
  local instroot="$1"
  local outvar="$2"

  if [[ -x "$instroot/usr/bin/mpv" ]]; then
    printf -v "$outvar" '%s' "$instroot/usr/bin"
    return 0
  fi
  return 1
}

_get_stage_libdir() {
  local instroot="$1"
  local outvar="$2"

  for d in "$instroot/usr/lib" "$instroot/usr/lib64"; do
    if [[ -d "$d" ]]; then
      printf -v "$outvar" '%s' "$d"
      return 0
    fi
  done
  return 1
}

_show_generated_profiles() {
  local profdir="$1"
  local label="$2"
  local count

  count=$(find "$profdir" -maxdepth 1 -name '*.profraw' 2>/dev/null | wc -l)
  echo "  -> ${label}: generated ${count} raw profile file(s)"
  find "$profdir" -maxdepth 1 -name '*.profraw' -printf '     %f\n' 2>/dev/null | head -20 || true
}

_show_bolt_fdata() {
  local bolt_dir="$1"
  local name="$2"

  echo "  -> BOLT fdata files for ${name}:"
  if compgen -G "${bolt_dir}/${name}.fdata*" >/dev/null; then
    ls -lh "${bolt_dir}/${name}.fdata"* 2>/dev/null || true
  else
    echo "     (none)"
  fi
}

_collect_bolt_targets() {
  local searchroot="$1"
  local -n _out_ref="$2"
  _out_ref=()

  local -a patterns=(
    'mpv'
    'libmpv.so*'
  )

  local -A seen=()
  local p f

  for p in "${patterns[@]}"; do
    while IFS= read -r -d '' f; do
      [[ -L "$f" ]] && continue
      [[ -f "$f" ]] || continue
      "${READELF:-readelf}" -h "$f" >/dev/null 2>&1 || continue
      [[ -n "${seen[$f]:-}" ]] && continue
      seen["$f"]=1
      _out_ref+=("$f")
    done < <(find "$searchroot" -type f -name "$p" -print0 2>/dev/null)
  done

  echo "=== BOLT target discovery ==="
  local x
  for x in "${_out_ref[@]}"; do
    echo "  -> $x"
  done
  echo "=== End BOLT target discovery ==="
}

# ──────────────────────────────────────────────────────────────────────
# PGO workload — exercises mpv through its most performance-critical
# code paths: demuxing, decoding (sw), video output initialisation,
# subtitle rendering, and the event loop.
# ──────────────────────────────────────────────────────────────────────

_create_pgo_workload_assets() {
  local assetdir="${srcdir}/pgo-assets"
  rm -rf "$assetdir"
  mkdir -p "$assetdir"

  # Generate a 4-second synthetic test video with ffmpeg.
  # lavfi sources need zero external files.
  if command -v ffmpeg >/dev/null 2>&1; then
    echo "  -> Generating synthetic PGO training video..."

    ffmpeg -y -nostdin \
      -f lavfi -i "testsrc2=duration=4:size=640x360:rate=30" \
      -f lavfi -i "sine=frequency=440:duration=4:sample_rate=48000" \
      -c:v libx264 -preset ultrafast -crf 28 \
      -c:a aac -b:a 64k \
      -movflags +faststart \
      -t 4 \
      "${assetdir}/test.mp4" 2>/dev/null

    ffmpeg -y -nostdin \
      -f lavfi -i "testsrc=duration=3:size=320x240:rate=24" \
      -c:v libvpx-vp9 -crf 50 -b:v 0 \
      -an \
      -t 3 \
      "${assetdir}/test.webm" 2>/dev/null

    ffmpeg -y -nostdin \
      -f lavfi -i "color=c=blue:duration=2:size=160x120:rate=15" \
      -c:v libx265 -preset ultrafast -crf 40 \
      -an \
      -t 2 \
      "${assetdir}/test_hevc.mp4" 2>/dev/null
  fi

  # Generate a small subtitle file
  cat > "${assetdir}/test.srt" <<'SRTEOF'
1
00:00:00,000 --> 00:00:02,000
PGO training subtitle line one

2
00:00:02,000 --> 00:00:04,000
PGO training subtitle line two
SRTEOF

  echo "  -> PGO assets:"
  ls -lh "${assetdir}/" 2>/dev/null || true
}

_run_mpv_pgo_workload() {
  local stage="$1"
  local mpv_bin="$2"
  local libdir="$3"
  local profdir="$4"
  local mode="$5"       # "normal" or "bolt"
  local assetdir="${srcdir}/pgo-assets"
  local logfile="${srcdir}/mpv-training-$(_stage_slug "$stage").log"

  local loops=1
  [[ "$mode" == bolt ]] && loops=3

  echo "-> ${stage}: Running mpv PGO workload (mode=${mode}, loops=${loops})..."
  echo "  -> mpv: ${mpv_bin}"
  echo "  -> libdir: ${libdir}"
  echo "  -> logfile: ${logfile}"

  (
    export LD_LIBRARY_PATH="${libdir}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    export LD_BIND_NOW=1

    set -o pipefail

    _run_mpv_once() {
      local video="$1"
      shift

      if [[ ! -f "$video" ]]; then
        echo "    (skipped, not found: $video)"
        return 0
      fi

      echo "    -> playing: $(basename "$video") $*"

      # --no-terminal --vo=null --ao=null --no-video --no-audio for pure demux exercise
      # Then again with --vo=null --ao=null for full decode exercise
      # Then with actual video output if DISPLAY is set

      # Pass 1: demux + decode, no output
      timeout 15s "$mpv_bin" \
        --no-config \
        --vo=null --ao=null \
        --frames=120 \
        --no-terminal \
        --really-quiet \
        "$@" \
        "$video" 2>/dev/null || true

      # Pass 2: demux only (audio)
      timeout 10s "$mpv_bin" \
        --no-config \
        --no-video \
        --ao=null \
        --no-terminal \
        --really-quiet \
        "$@" \
        "$video" 2>/dev/null || true

      # Pass 3: with hwdec=auto attempt (exercises hwdec probing)
      timeout 10s "$mpv_bin" \
        --no-config \
        --vo=null --ao=null \
        --hwdec=auto \
        --frames=60 \
        --no-terminal \
        --really-quiet \
        "$@" \
        "$video" 2>/dev/null || true
    }

    for (( i=0; i<loops; i++ )); do
      echo "  --- workload iteration $((i+1))/${loops} ---"

      # Exercise --version and --list-options (cold paths but important)
      "$mpv_bin" --no-config --version 2>/dev/null || true
      "$mpv_bin" --no-config --list-options 2>/dev/null | head -50 >/dev/null || true

      # Synthetic videos
      _run_mpv_once "${assetdir}/test.mp4"
      _run_mpv_once "${assetdir}/test.mp4" --sub-file="${assetdir}/test.srt"
      _run_mpv_once "${assetdir}/test.webm"
      _run_mpv_once "${assetdir}/test_hevc.mp4"

      # Benchmark mode exercise
      if [[ -f "${assetdir}/test.mp4" ]]; then
        echo "    -> benchmark decode"
        timeout 15s "$mpv_bin" \
          --no-config \
          --vo=null --ao=null \
          --untimed \
          --no-terminal \
          --really-quiet \
          "${assetdir}/test.mp4" 2>/dev/null || true
      fi

      # If we have a display, exercise actual video output briefly
      if [[ -n "${DISPLAY:-}" && -f "${assetdir}/test.mp4" ]]; then
        echo "    -> windowed playback (gpu/x11)"
        timeout 6s "$mpv_bin" \
          --no-config \
          --vo=gpu \
          --ao=null \
          --frames=45 \
          --no-terminal \
          --really-quiet \
          --geometry=320x240 \
          "${assetdir}/test.mp4" 2>/dev/null || true

        echo "    -> windowed playback (x11)"
        timeout 6s "$mpv_bin" \
          --no-config \
          --vo=x11 \
          --ao=null \
          --frames=45 \
          --no-terminal \
          --really-quiet \
          --geometry=320x240 \
          "${assetdir}/test.mp4" 2>/dev/null || true
      fi

      if [[ -n "${WAYLAND_DISPLAY:-}" && -f "${assetdir}/test.mp4" ]]; then
        echo "    -> wayland playback"
        timeout 6s "$mpv_bin" \
          --no-config \
          --vo=gpu \
          --ao=null \
          --frames=45 \
          --no-terminal \
          --really-quiet \
          --geometry=320x240 \
          "${assetdir}/test.mp4" 2>/dev/null || true
      fi

      # lavfi direct source (no file I/O, exercises filter chain)
      echo "    -> lavfi source exercise"
      timeout 8s "$mpv_bin" \
        --no-config \
        --vo=null --ao=null \
        --frames=90 \
        --no-terminal \
        --really-quiet \
        "lavfi://[testsrc2=duration=3:size=320x240:rate=30]" 2>/dev/null || true

      # Screenshot exercise (exercises encoder paths)
      if [[ -f "${assetdir}/test.mp4" ]]; then
        local tmpshot
        tmpshot=$(mktemp -d)
        echo "    -> screenshot exercise"
        timeout 8s "$mpv_bin" \
          --no-config \
          --vo=null --ao=null \
          --frames=10 \
          --no-terminal \
          --really-quiet \
          --screenshot-directory="$tmpshot" \
          --screenshot-format=png \
          "${assetdir}/test.mp4" \
          --script-opts=osc-visibility=never 2>/dev/null || true
        rm -rf "$tmpshot"
      fi
    done

  ) 2>&1 | tee "$logfile"

  if [[ -n "$profdir" ]]; then
    _show_generated_profiles "$profdir" "$stage"
  fi
}

# ──────────────────────────────────────────────────────────────────────
# Meson setup helper
# ──────────────────────────────────────────────────────────────────────

_meson_stage_setup() {
  local msrcdir="$1"
  local mbuilddir="$2"
  local mcflags="$3"
  local mcxxflags="$4"
  local mldflags="$5"
  shift 5
  local -a extra_meson_args=("$@")

  rm -rf "$mbuilddir"

  env \
    CC="$CC" \
    CXX="$CXX" \
    AR="$AR" \
    NM="$NM" \
    RANLIB="$RANLIB" \
    STRIP="$STRIP" \
    CFLAGS="$mcflags" \
    CXXFLAGS="$mcxxflags" \
    LDFLAGS="$mldflags" \
    meson setup "$mbuilddir" "$msrcdir" \
      --prefix=/usr \
      --sysconfdir=/etc \
      --buildtype=plain \
      --wrap-mode=nodownload \
      -Dlibmpv=true \
      "${_opt_extra_flags[@]}" \
      "${extra_meson_args[@]}"
}

# ──────────────────────────────────────────────────────────────────────
# Standard PKGBUILD functions
# ──────────────────────────────────────────────────────────────────────

pkgver() {
  cd "$srcdir/$_gitname"
  git describe --always --tags --dirty | sed -e 's/^v//' -e 's/-/_/g'
}

prepare() {
  cd "$srcdir/$_gitname"
  # nothing extra needed
}

build() {
  _setup_llvm_toolchain

  local mpv_srcdir="${srcdir}/${_gitname}"

  local build_pgo="${srcdir}/build-pgo"
  local build_cs="${srcdir}/build-cs"
  local build_final="${srcdir}/build-final"

  local inst_pgo="${srcdir}/inst-pgo"
  local inst_cs="${srcdir}/inst-cs"
  local inst_final="${srcdir}/inst-final"
  local inst_bolt="${srcdir}/inst-bolt"
  local inst_verify="${srcdir}/inst-verify"

  local pgo_dir="${srcdir}/pgo"
  local cs_dir="${srcdir}/cspgo"
  local bolt_dir="${srcdir}/bolt"

  rm -rf "$build_pgo" "$build_cs" "$build_final"
  rm -rf "$inst_pgo" "$inst_cs" "$inst_final" "$inst_bolt" "$inst_verify"
  rm -rf "$pgo_dir" "$cs_dir" "$bolt_dir"
  mkdir -p "$pgo_dir" "$cs_dir" "$bolt_dir"

  local orig_cflags="$CFLAGS"
  local orig_cxxflags="$CXXFLAGS"
  local orig_ldflags="$LDFLAGS"

  local -a instr_flags=(
    -g3
    -fno-omit-frame-pointer
    -Xclang -mllvm -Xclang -vp-counters-per-site=64
    -Xclang -mllvm -Xclang -runtime-counter-relocation
    -Xclang -mllvm -Xclang -enable-value-profiling
  )

  local -a profile_warnings=(
    -Wno-profile-instr-out-of-date
    -Wno-profile-instr-unprofiled
  )

  local -a prefix_maps=(
    "-ffile-prefix-map=${srcdir}=/usr/src/debug/${pkgname}"
    "-fdebug-prefix-map=${srcdir}=/usr/src/debug/${pkgname}"
    "-fmacro-prefix-map=${srcdir}=/usr/src/debug/${pkgname}"
  )

  # Generate PGO workload assets (synthetic videos)
  _create_pgo_workload_assets

  # ── Stage 1: Standard PGO instrumented build ──────────────────────
  echo "=== Stage 1: Standard PGO instrumentation ==="

  local cflags_s1="${orig_cflags} ${prefix_maps[*]} -fprofile-generate=${pgo_dir} ${instr_flags[*]}"
  local cxxflags_s1="${orig_cxxflags} ${prefix_maps[*]} -fprofile-generate=${pgo_dir} ${instr_flags[*]}"
  local ldflags_s1="${orig_ldflags} -fprofile-generate=${pgo_dir}"

  _meson_stage_setup "$mpv_srcdir" "$build_pgo" "$cflags_s1" "$cxxflags_s1" "$ldflags_s1"
  meson compile -C "$build_pgo"
  _stage_install "$build_pgo" "$inst_pgo"

  local pgo_bindir pgo_libdir
  _get_stage_bindir "$inst_pgo" pgo_bindir || {
    echo "Error: Stage 1 mpv binary not found." >&2
    return 1
  }
  _get_stage_libdir "$inst_pgo" pgo_libdir || pgo_libdir=""

  export LLVM_PROFILE_FILE="${pgo_dir}/mpv-%m-%p.profraw"
  _run_mpv_pgo_workload "Stage 1" "${pgo_bindir}/mpv" "${pgo_libdir}" "$pgo_dir" normal
  unset LLVM_PROFILE_FILE

  local -a pgo_raws=()
  shopt -s nullglob
  pgo_raws=("${pgo_dir}"/*.profraw)
  shopt -u nullglob

  if (( ! ${#pgo_raws[@]} )); then
    echo "Error: no Stage 1 PGO profile data generated." >&2
    return 1
  fi

  llvm-profdata merge -sparse -output="${srcdir}/standard.profdata" "${pgo_raws[@]}"

  # ── Stage 2: Context-Sensitive PGO instrumented build ─────────────
  echo "=== Stage 2: Context-Sensitive PGO instrumentation ==="

  local cflags_s2="${orig_cflags} ${prefix_maps[*]} -fprofile-use=${srcdir}/standard.profdata -fcs-profile-generate=${cs_dir} ${profile_warnings[*]} ${instr_flags[*]}"
  local cxxflags_s2="${orig_cxxflags} ${prefix_maps[*]} -fprofile-use=${srcdir}/standard.profdata -fcs-profile-generate=${cs_dir} ${profile_warnings[*]} ${instr_flags[*]}"
  local ldflags_s2="${orig_ldflags} -fprofile-use=${srcdir}/standard.profdata -fcs-profile-generate=${cs_dir}"

  _meson_stage_setup "$mpv_srcdir" "$build_cs" "$cflags_s2" "$cxxflags_s2" "$ldflags_s2"
  meson compile -C "$build_cs"
  _stage_install "$build_cs" "$inst_cs"

  local cs_bindir cs_libdir
  _get_stage_bindir "$inst_cs" cs_bindir || {
    echo "Error: Stage 2 mpv binary not found." >&2
    return 1
  }
  _get_stage_libdir "$inst_cs" cs_libdir || cs_libdir=""

  export LLVM_PROFILE_FILE="${cs_dir}/mpv-cs-%m-%p.profraw"
  _run_mpv_pgo_workload "Stage 2" "${cs_bindir}/mpv" "${cs_libdir}" "$cs_dir" normal
  unset LLVM_PROFILE_FILE

  local -a cs_raws=()
  shopt -s nullglob
  cs_raws=("${cs_dir}"/*.profraw)
  shopt -u nullglob

  if (( ! ${#cs_raws[@]} )); then
    echo "Error: no Stage 2 CS-PGO profile data generated." >&2
    return 1
  fi

  llvm-profdata merge -sparse \
    -output="${srcdir}/merged.profdata" \
    "${srcdir}/standard.profdata" "${cs_raws[@]}"

  # ── Stage 3: Final PGO-optimized build ────────────────────────────
  echo "=== Stage 3: Final optimized build ==="

  local cflags_s3="${orig_cflags} ${prefix_maps[*]} -fprofile-use=${srcdir}/merged.profdata ${profile_warnings[*]}"
  local cxxflags_s3="${orig_cxxflags} ${prefix_maps[*]} -fprofile-use=${srcdir}/merged.profdata ${profile_warnings[*]}"
  local ldflags_s3="${orig_ldflags} -fprofile-use=${srcdir}/merged.profdata -Wl,--emit-relocs"

  _meson_stage_setup "$mpv_srcdir" "$build_final" "$cflags_s3" "$cxxflags_s3" "$ldflags_s3"
  meson compile -C "$build_final"
  _stage_install "$build_final" "$inst_final"

  local final_bindir final_libdir
  _get_stage_bindir "$inst_final" final_bindir || {
    echo "Error: Stage 3 mpv binary not found." >&2
    return 1
  }
  _get_stage_libdir "$inst_final" final_libdir || final_libdir=""

  echo "=== Stage 3: Built artifacts ==="
  find "$build_final" -type f \( -name 'mpv' -o -name 'libmpv.so*' \) | sort

  # ── Stage 4: BOLT post-link optimization ──────────────────────────
  if command -v llvm-bolt >/dev/null 2>&1; then
    echo "=== Stage 4: BOLT post-link optimization ==="

    local -a bolt_targets=()
    _collect_bolt_targets "$build_final" bolt_targets

    if (( ${#bolt_targets[@]} )); then
      local target tgt_name bolt_any=0

      for target in "${bolt_targets[@]}"; do
        tgt_name="$(basename "$target")"
        echo "  -> Instrumenting ${tgt_name}..."
        cp -f "$target" "${bolt_dir}/${tgt_name}.orig"

        if llvm-bolt "${bolt_dir}/${tgt_name}.orig" \
            --instrument \
            --lite=true \
            --instrumentation-file-append-pid \
            --instrumentation-file="${bolt_dir}/${tgt_name}.fdata" \
            -o "${bolt_dir}/${tgt_name}.instr" 2>/dev/null; then
          cp -f "${bolt_dir}/${tgt_name}.instr" "$target"
          bolt_any=1
        else
          echo "  -> BOLT instrumentation failed for ${tgt_name}; restoring original."
          cp -f "${bolt_dir}/${tgt_name}.orig" "$target"
        fi
      done

      if (( bolt_any )); then
        _stage_install "$build_final" "$inst_bolt"

        local bolt_bindir bolt_libdir
        _get_stage_bindir "$inst_bolt" bolt_bindir || {
          echo "Error: BOLT staged mpv binary not found." >&2
          return 1
        }
        _get_stage_libdir "$inst_bolt" bolt_libdir || bolt_libdir=""

        _run_mpv_pgo_workload "Stage 4 BOLT pass1" "${bolt_bindir}/mpv" "${bolt_libdir}" "" bolt
        _run_mpv_pgo_workload "Stage 4 BOLT pass2" "${bolt_bindir}/mpv" "${bolt_libdir}" "" bolt
        _run_mpv_pgo_workload "Stage 4 BOLT pass3" "${bolt_bindir}/mpv" "${bolt_libdir}" "" bolt

        for target in "${bolt_targets[@]}"; do
          tgt_name="$(basename "$target")"
          _show_bolt_fdata "$bolt_dir" "$tgt_name"

          local -a fdata_files=()
          shopt -s nullglob
          fdata_files=("${bolt_dir}/${tgt_name}".fdata*)
          shopt -u nullglob

          if (( ! ${#fdata_files[@]} )); then
            echo "  -> No BOLT fdata for ${tgt_name}; restoring original."
            cp -f "${bolt_dir}/${tgt_name}.orig" "$target"
            continue
          fi

          local merged_fdata="${bolt_dir}/${tgt_name}.merged.fdata"
          if command -v merge-fdata >/dev/null 2>&1; then
            merge-fdata "${fdata_files[@]}" > "$merged_fdata" 2>/dev/null || \
              cat "${fdata_files[@]}" > "$merged_fdata"
          else
            cat "${fdata_files[@]}" > "$merged_fdata"
          fi

          if [[ ! -s "$merged_fdata" ]]; then
            echo "  -> Empty BOLT fdata for ${tgt_name}; restoring original."
            cp -f "${bolt_dir}/${tgt_name}.orig" "$target"
            continue
          fi

          echo "  -> Applying BOLT to ${tgt_name}..."

          local -a bolt_opt_flags=(
            --data="$merged_fdata"
            --lite=true
            --relocs
            --reorder-blocks=ext-tsp
            --reorder-functions=cdsort
            --split-functions --split-all-cold --split-eh
            --x86-strip-redundant-address-size
            --split-strategy=cdsplit
            --icf=all
            --indirect-call-promotion=all
            --jump-tables=aggressive
            --peepholes=all
            --plt=hot
            --dyno-stats
          )

          if llvm-bolt "${bolt_dir}/${tgt_name}.orig" \
              "${bolt_opt_flags[@]}" \
              -o "${bolt_dir}/${tgt_name}.bolt" 2>/dev/null; then
            if [[ -s "${bolt_dir}/${tgt_name}.bolt" ]]; then
              cp -f "${bolt_dir}/${tgt_name}.bolt" "$target"
              echo "  -> BOLT optimization successful for ${tgt_name}."
            else
              cp -f "${bolt_dir}/${tgt_name}.orig" "$target"
            fi
          else
            echo "  -> BOLT optimization failed for ${tgt_name}; restoring original."
            cp -f "${bolt_dir}/${tgt_name}.orig" "$target"
          fi
        done
      else
        echo "  -> No binaries successfully BOLT-instrumented; skipping."
      fi
    else
      echo "No BOLT targets found; skipping."
    fi
  else
    echo "=== Stage 4: llvm-bolt not found; skipping BOLT ==="
  fi

  # ── Stage 5: End-to-end verification ──────────────────────────────
  echo "=== Stage 5: Final end-to-end verification ==="

  _stage_install "$build_final" "$inst_verify"

  local verify_bindir verify_libdir
  _get_stage_bindir "$inst_verify" verify_bindir || {
    echo "Error: verification mpv binary not found." >&2
    return 1
  }
  _get_stage_libdir "$inst_verify" verify_libdir || verify_libdir=""

  echo "  -> Smoke-testing final mpv..."

  (
    export LD_LIBRARY_PATH="${verify_libdir}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

    "${verify_bindir}/mpv" --no-config --version || {
      echo "Error: final mpv --version failed!" >&2
      return 1
    }

    if [[ -f "${srcdir}/pgo-assets/test.mp4" ]]; then
      echo "  -> Final decode verification..."
      timeout 10s "${verify_bindir}/mpv" \
        --no-config \
        --vo=null --ao=null \
        --frames=30 \
        --no-terminal \
        --really-quiet \
        "${srcdir}/pgo-assets/test.mp4" || {
        echo "Error: final mpv decode test failed!" >&2
        return 1
      }
    fi

    # Verify libmpv.so exists and is loadable
    if [[ -n "$verify_libdir" ]]; then
      local libmpv_so
      libmpv_so=$(find "$verify_libdir" -name 'libmpv.so*' -not -type l | head -1)
      if [[ -n "$libmpv_so" ]]; then
        echo "  -> libmpv.so found: $libmpv_so"
        "${READELF:-readelf}" -d "$libmpv_so" | grep -i soname || true
      fi
    fi
  ) || return 1

  echo "=== All stages completed successfully ==="
}

package() {
  cd "$srcdir/$_gitname"

  DESTDIR="$pkgdir" meson install -C "${srcdir}/build-final" --no-rebuild

  # Auto-detect runtime dependencies from linked shared libraries
  if [[ -f "$srcdir/find-deps.py" ]]; then
    local -a _detected_depends=()

    _detected_depends=($(python3 "$srcdir/find-deps.py" \
      "$pkgdir"/usr/bin/mpv \
      "$pkgdir"/usr/lib/libmpv.so 2>/dev/null)) || true

    if (( ${#_detected_depends[@]} )); then
      echo 'Auto-detected dependencies:'
      echo "${_detected_depends[@]}" | fold -s -w 79 | sed 's/^/ /'
      depends=("${_detected_depends[@]}" "${_undetected_depends[@]}")
    fi
  fi
}
