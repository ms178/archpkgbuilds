pkgbase=harfbuzz-git
pkgname=(
  harfbuzz-git
  harfbuzz-icu-git
)
pkgver=14.0.0.r1.ga243dcb
pkgrel=1
pkgdesc="OpenType text shaping engine (PGO-optimized, with upstream raster/vector GPU stack)"
url="https://harfbuzz.github.io/"
arch=(x86_64)
license=(MIT)

makedepends=(
  cairo
  chafa
  clang
  freetype2
  git
  glew
  glfw
  glib2
  gobject-introspection
  graphite
  help2man
  icu
  lld
  llvm
  libgl
  libpng
  meson
  python
  python-fonttools
  python-setuptools
  ragel
  zlib

  # PGO training fonts
  noto-fonts
  noto-fonts-cjk
  ttf-dejavu
)

source=("git+https://github.com/harfbuzz/harfbuzz.git#branch=main")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/harfbuzz"

  if git describe --long --tags --abbrev=7 --match '[0-9]*' >/dev/null 2>&1; then
    git describe --long --tags --abbrev=7 --match '[0-9]*' \
      | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
  else
    printf '0.r%s.g%s\n' \
      "$(git rev-list --count HEAD)" \
      "$(git rev-parse --short=7 HEAD)"
  fi
}

_pick() {
  local p="$1" f d
  shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

_find_build_tool() {
  local build_dir="$1"
  local tool="$2"
  local base="$srcdir/$build_dir"
  local cand

  for cand in \
    "$base/util/$tool" \
    "$base/$tool"
  do
    if [[ -x "$cand" ]]; then
      printf '%s\n' "$cand"
      return 0
    fi
  done

  return 1
}

_run_training_workload() {
  local build_dir="$1"
  local run_num="$2"

  local hb_shape=''
  local hb_subset=''
  local hb_view=''
  local hb_ot_shape_closure=''
  local hb_gpu=''

  hb_shape=$(_find_build_tool "$build_dir" hb-shape 2>/dev/null || true)
  hb_subset=$(_find_build_tool "$build_dir" hb-subset 2>/dev/null || true)
  hb_view=$(_find_build_tool "$build_dir" hb-view 2>/dev/null || true)
  hb_ot_shape_closure=$(_find_build_tool "$build_dir" hb-ot-shape-closure 2>/dev/null || true)
  hb_gpu=$(_find_build_tool "$build_dir" hb-gpu 2>/dev/null || true)

  echo "==> PGO Training Run $run_num: executing comprehensive workload..."

  # Phase 1: test suite
  echo "  -> Running Meson test suite..."
  meson test -C "$build_dir" --print-errorlogs --no-rebuild -j"$(nproc)" || true

  # Phase 2: deterministic font collection
  local -a fonts=()
  local -a font_paths=(
    /usr/share/fonts/noto
    /usr/share/fonts/noto-cjk
    /usr/share/fonts/TTF
    /usr/share/fonts/OTF
    /usr/share/fonts/truetype/dejavu
    /usr/share/fonts/truetype/noto
  )

  local fp
  for fp in "${font_paths[@]}"; do
    [[ -d "$fp" ]] || continue
    while IFS= read -r -d '' f; do
      fonts+=("$f")
      (( ${#fonts[@]} >= 60 )) && break 2
    done < <(
      LC_ALL=C find "$fp" -maxdepth 2 -type f \
        \( -name '*.ttf' -o -name '*.otf' \) -print0 2>/dev/null \
        | sort -z \
        | head -z -n 120
    )
  done

  if (( ${#fonts[@]} == 0 )); then
    echo "  -> Warning: no fonts found, skipping extended training"
    return 0
  fi

  echo "  -> Training with ${#fonts[@]} fonts..."

  local -a texts=(
    "The quick brown fox jumps over the lazy dog. WAVE Typography fi fl ffi ffl"
    "ÀÁÂÃÄÅÆÇÈÉÊË àáâãäåæçèéêë ñÑøØœŒßÿ Příliš žluťoučký kůň"
    "Съешь ещё этих мягких французских булок, да выпей чаю. АБВГДЕЁЖЗИЙ"
    "Ξεσκεπάζω τὴν ψυχοφθόρα βδελυγμία. ΑΒΓΔΕΖΗΘΙΚΛΜΝ αβγδεζηθ"
    "صِف خَلقَ خَودٍ كَمِثلِ الشَّمسِ إِذ بَزَغَت يَحظى الضَّجيعُ بِها نَجلاءَ مِعطارِ"
    "דג סקרן שט בים מאוכזב ולפתע מצא חברה. אבגדהוזחטיכלמנסעפצקרשת"
    "ऋषियों को सताने वाले दुष्ट राक्षसों के राजा रावण क्ष त्र ज्ञ श्र"
    "เป็นมนุษย์สุดประเสริฐเลิศคุณค่า กว่าบรรดาฝูงสัตว์เดรัจฉาน"
    "天地玄黄宇宙洪荒日月盈昃辰宿列张寒来暑往秋收冬藏"
    "日本語テキスト。ひらがなカタカナABC漢字123プログラミング"
    "한국어 텍스트 샘플입니다. 가나다라마바사아자차카타파하"
    "😀🎉🚀💻🔥✨🌍🎨📚🔧 ©®™ →←↑↓ ★☆♠♣♥♦ 0123456789"
  )

  local -a features=(
    "+kern,+liga"
    "+calt,+clig,+liga"
    "-liga,-kern"
    "+smcp"
    "+onum,+pnum"
    "+tnum,+lnum"
    "+dlig,+hlig"
  )

  local -a directions=(ltr rtl ttb)

  # Phase 3: shaping
  if [[ -n "$hb_shape" ]]; then
    echo "  -> Exercising hb-shape..."
    local count=0
    local font text feat dir cl
    for font in "${fonts[@]}"; do
      for text in "${texts[@]}"; do
        "$hb_shape" "$font" "$text" &>/dev/null || true
        ((++count))

        for feat in "${features[@]}"; do
          "$hb_shape" --features="$feat" "$font" "$text" &>/dev/null || true
        done

        for dir in "${directions[@]}"; do
          "$hb_shape" --direction="$dir" "$font" "$text" &>/dev/null || true
        done
      done

      for cl in 0 1 2; do
        "$hb_shape" --cluster-level="$cl" "$font" "${texts[0]}" &>/dev/null || true
      done
    done
    echo "    Completed $count base shaping operations"
  fi

  # Phase 4: subsetting
  if [[ -n "$hb_subset" ]]; then
    echo "  -> Exercising hb-subset..."
    local tmpout
    tmpout=$(mktemp --suffix=.ttf)

    local -a ranges=(
      "U+0020-007F"
      "U+0080-00FF"
      "U+0100-017F"
      "U+0400-04FF"
      "U+0600-06FF"
      "U+0900-097F"
      "U+3040-30FF"
      "U+4E00-4FFF"
      "U+AC00-ACFF"
    )

    local range
    for font in "${fonts[@]:0:25}"; do
      for range in "${ranges[@]}"; do
        "$hb_subset" --output-file="$tmpout" --unicodes="$range" "$font" &>/dev/null || true
        "$hb_subset" --output-file="$tmpout" --unicodes="$range" --retain-gids "$font" &>/dev/null || true
        "$hb_subset" --output-file="$tmpout" --unicodes="$range" --desubroutinize "$font" &>/dev/null || true
        "$hb_subset" --output-file="$tmpout" --unicodes="$range" --no-hinting "$font" &>/dev/null || true
      done

      for text in "${texts[@]:0:8}"; do
        "$hb_subset" --output-file="$tmpout" --text="$text" "$font" &>/dev/null || true
      done

      "$hb_subset" \
        --output-file="$tmpout" \
        --layout-features+=kern,liga,calt \
        --unicodes="U+0020-007F" \
        "$font" &>/dev/null || true
    done

    rm -f "$tmpout"
  fi

  # Phase 5: shape closure
  if [[ -n "$hb_ot_shape_closure" ]]; then
    echo "  -> Exercising hb-ot-shape-closure..."
    for font in "${fonts[@]:0:18}"; do
      for text in "${texts[@]:0:8}"; do
        "$hb_ot_shape_closure" "$font" "$text" &>/dev/null || true
      done
    done
  fi

  # Phase 6: raster/vector paths
  # Upstream 14.x ships the new GPU-oriented stack as libharfbuzz-raster.so
  # and libharfbuzz-vector.so, not libharfbuzz-gpu.so. hb-view is the stable
  # way to hit those paths from the build tree.
  if [[ -n "$hb_view" ]]; then
    echo "  -> Exercising hb-view (raster/vector paths)..."
    local tmp_png tmp_svg
    tmp_png=$(mktemp --suffix=.png)
    tmp_svg=$(mktemp --suffix=.svg)

    for font in "${fonts[@]:0:12}"; do
      for text in "${texts[@]:0:8}"; do
        "$hb_view" --output-file="$tmp_png" --font-size=24 "$font" "$text" &>/dev/null || true
        "$hb_view" --output-file="$tmp_png" --font-size=48 --margin=10 "$font" "$text" &>/dev/null || true
        "$hb_view" --output-file="$tmp_svg" --font-size=32 "$font" "$text" &>/dev/null || true
      done
    done

    rm -f "$tmp_png" "$tmp_svg"
  fi

  # Optional branch-only demo utility, if present
  if [[ -n "$hb_gpu" ]]; then
    echo "  -> Exercising optional hb-gpu demo..."
    for font in "${fonts[@]:0:15}"; do
      for text in "${texts[@]:0:8}"; do
        timeout -k 3s 8s \
          "$hb_gpu" --font="$font" --text="$text" --size=32 --output=/dev/null \
          &>/dev/null || true
      done
    done
  fi

  echo "==> PGO Training Run $run_num complete"
}

build() {
  cd "$srcdir"

  export CC=clang
  export CXX=clang++
  export LD=lld
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib
  export STRIP=llvm-strip
  export OBJCOPY=llvm-objcopy
  export OBJDUMP=llvm-objdump
  export READELF=llvm-readelf
  export HOSTCC=clang
  export HOSTCXX=clang++

  # HarfBuzz wants no exceptions
  CFLAGS="${CFLAGS//-fexceptions/}"
  CXXFLAGS="${CXXFLAGS//-fexceptions/}"

  local -a meson_args=(
    -D cpp_std=c++17
    -D cairo=enabled
    -D docs=disabled
    -D freetype=enabled
    -D glib=enabled
    -D gobject=enabled
    -D graphite2=enabled
    -D icu=enabled
  )

  local pgo_dir="$srcdir/pgo"
  local pgo_standard_dir="$pgo_dir/standard"
  local pgo_cs_dir="$pgo_dir/cs"

  rm -rf build build-pgo1 build-pgo2 "$pgo_dir"
  mkdir -p "$pgo_standard_dir" "$pgo_cs_dir"

  local pgo_instr_flags=(
    -Xclang -mllvm -Xclang -vp-counters-per-site=50
    -Xclang -mllvm -Xclang -runtime-counter-relocation
    -Xclang -mllvm -Xclang -enable-value-profiling
  )

  echo "=========================================================================="
  echo " Stage 1/3: Standard PGO instrumentation"
  echo "=========================================================================="

  local stage1_cflags="$CFLAGS ${pgo_instr_flags[*]} -fprofile-generate=$pgo_standard_dir"
  local stage1_cxxflags="$CXXFLAGS ${pgo_instr_flags[*]} -fprofile-generate=$pgo_standard_dir"
  local stage1_ldflags="$LDFLAGS -fprofile-generate=$pgo_standard_dir"

  arch-meson harfbuzz build-pgo1 \
    "${meson_args[@]}" \
    -D tests=enabled \
    -D b_ndebug=false \
    -D c_args="$stage1_cflags" \
    -D cpp_args="$stage1_cxxflags" \
    -D c_link_args="$stage1_ldflags" \
    -D cpp_link_args="$stage1_ldflags"

  meson compile -C build-pgo1

  LLVM_PROFILE_FILE="$pgo_standard_dir/%m-%p.profraw" \
    _run_training_workload build-pgo1 1

  local -a stage1_profraws=()
  shopt -s nullglob
  stage1_profraws=("$pgo_standard_dir"/*.profraw)
  shopt -u nullglob

  if (( ${#stage1_profraws[@]} == 0 )); then
    echo "ERROR: no standard PGO profile data generated" >&2
    return 1
  fi

  llvm-profdata merge \
    --output="$pgo_dir/standard.profdata" \
    "${stage1_profraws[@]}"

  [[ -s "$pgo_dir/standard.profdata" ]] || {
    echo "ERROR: failed to create standard.profdata" >&2
    return 1
  }

  echo "=========================================================================="
  echo " Stage 2/3: Context-sensitive PGO"
  echo "=========================================================================="

  local stage2_cflags="$CFLAGS ${pgo_instr_flags[*]} -fprofile-use=$pgo_dir/standard.profdata -fcs-profile-generate=$pgo_cs_dir"
  local stage2_cxxflags="$CXXFLAGS ${pgo_instr_flags[*]} -fprofile-use=$pgo_dir/standard.profdata -fcs-profile-generate=$pgo_cs_dir"
  local stage2_ldflags="$LDFLAGS -fprofile-use=$pgo_dir/standard.profdata -fcs-profile-generate=$pgo_cs_dir"

  arch-meson harfbuzz build-pgo2 \
    "${meson_args[@]}" \
    -D tests=enabled \
    -D b_ndebug=false \
    -D c_args="$stage2_cflags" \
    -D cpp_args="$stage2_cxxflags" \
    -D c_link_args="$stage2_ldflags" \
    -D cpp_link_args="$stage2_ldflags"

  meson compile -C build-pgo2

  LLVM_PROFILE_FILE="$pgo_cs_dir/%m-%p.profraw" \
    _run_training_workload build-pgo2 2

  local -a stage2_profraws=()
  shopt -s nullglob
  stage2_profraws=("$pgo_cs_dir"/*.profraw)
  shopt -u nullglob

  if (( ${#stage2_profraws[@]} == 0 )); then
    echo "ERROR: no context-sensitive PGO profile data generated" >&2
    return 1
  fi

  llvm-profdata merge \
    --output="$pgo_dir/merged.profdata" \
    "$pgo_dir/standard.profdata" \
    "${stage2_profraws[@]}"

  [[ -s "$pgo_dir/merged.profdata" ]] || {
    echo "ERROR: failed to create merged.profdata" >&2
    return 1
  }

  echo "=========================================================================="
  echo " Stage 3/3: Final PGO-optimized build"
  echo "=========================================================================="

  local final_cflags="$CFLAGS -fprofile-use=$pgo_dir/merged.profdata -fprofile-correction"
  local final_cxxflags="$CXXFLAGS -fprofile-use=$pgo_dir/merged.profdata -fprofile-correction"
  local final_ldflags="$LDFLAGS -fprofile-use=$pgo_dir/merged.profdata"

  arch-meson harfbuzz build \
    "${meson_args[@]}" \
    -D tests=disabled \
    -D b_ndebug=true \
    -D c_args="$final_cflags" \
    -D cpp_args="$final_cxxflags" \
    -D c_link_args="$final_ldflags" \
    -D cpp_link_args="$final_ldflags"

  meson compile -C build
}

package_harfbuzz-git() {
  depends=(
    cairo
    freetype2
    glib2
    graphite
    libpng
    zlib
  )

  provides=(
    harfbuzz
    harfbuzz-cairo
    libharfbuzz.so
    libharfbuzz-cairo.so
    libharfbuzz-gobject.so
    libharfbuzz-subset.so
    libharfbuzz-raster.so
    libharfbuzz-vector.so
  )

  conflicts=(
    harfbuzz
    harfbuzz-cairo
  )

  rm -rf "$srcdir/hb-icu"

  meson install -C build --destdir "$pkgdir" --no-rebuild

  (
    cd "$pkgdir"
    shopt -s nullglob

    local icu_libs=(usr/lib/libharfbuzz-icu*)
    (( ${#icu_libs[@]} )) && _pick hb-icu "${icu_libs[@]}"

    [[ -e usr/lib/pkgconfig/harfbuzz-icu.pc ]] && _pick hb-icu usr/lib/pkgconfig/harfbuzz-icu.pc
    [[ -e usr/include/harfbuzz/hb-icu.h ]] && _pick hb-icu usr/include/harfbuzz/hb-icu.h
  )

  # Keep package split minimal: do not ship utils/docs.
  rm -rf \
    "$pkgdir"/usr/bin \
    "$pkgdir"/usr/share/man \
    "$pkgdir"/usr/share/gtk-doc

  install -Dm644 "$srcdir/harfbuzz/COPYING" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

package_harfbuzz-icu-git() {
  pkgdesc="OpenType text shaping engine (ICU integration)"

  depends=(
    harfbuzz-git
    icu
  )

  provides=(
    harfbuzz-icu
    libharfbuzz-icu.so
  )

  conflicts=(harfbuzz-icu)

  [[ -d "$srcdir/hb-icu" ]] || {
    echo "ERROR: split package directory '$srcdir/hb-icu' is missing" >&2
    return 1
  }

  cp -a "$srcdir/hb-icu/." "$pkgdir/"

  install -Dm644 "$srcdir/harfbuzz/COPYING" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
