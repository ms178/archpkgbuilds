pkgbase=harfbuzz-git
pkgname=(
  harfbuzz-git
  harfbuzz-icu-git
)
pkgver=14.2.0.r20.gf90bc29
pkgrel=1
pkgdesc="OpenType text shaping engine (PGO + CS-PGO optimized)"
url="https://harfbuzz.github.io/"
arch=(x86_64)
license=(MIT)

makedepends=(
  cairo
  chafa
  clang
  freetype2
  git
  glew
  glfw
  glib2
  gobject-introspection
  graphite
  help2man
  icu
  lld
  llvm
  libgl
  libpng
  meson
  python
  python-fonttools
  python-setuptools
  ragel
  zlib
  noto-fonts
  noto-fonts-cjk
  ttf-dejavu
)

source=("git+https://github.com/harfbuzz/harfbuzz.git#branch=main")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/harfbuzz"
  if git describe --long --tags --abbrev=7 --match '[0-9]*' >/dev/null 2>&1; then
    git describe --long --tags --abbrev=7 --match '[0-9]*' \
      | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
  else
    printf '0.r%s.g%s\n' \
      "$(git rev-list --count HEAD)" \
      "$(git rev-parse --short=7 HEAD)"
  fi
}

_pick() {
  local p="$1" f d
  shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

_find_build_tool() {
  local build_dir="$1"
  local tool="$2"
  local cand

  for cand in \
    "$build_dir/util/$tool" \
    "$build_dir/$tool"
  do
    [[ -x "$cand" ]] && { printf '%s\n' "$cand"; return 0; }
  done
  return 1
}

_merge_profdata_safely() {
  local out="$1"
  local in_dir="$2"

  # Fast path: merge directory directly (avoids ARG_MAX blowups).
  if llvm-profdata merge --output="$out" "$in_dir" 2>/dev/null; then
    [[ -s "$out" ]] && return 0
  fi

  # Fallback path: chunked merge.
  local -a files chunk chunks
  local idx=0 chunk_idx=0
  local tmpdir="$in_dir/.prof-merge"

  rm -rf "$tmpdir"
  mkdir -p "$tmpdir"

  shopt -s nullglob
  files=("$in_dir"/*.profraw)
  shopt -u nullglob
  (( ${#files[@]} > 0 )) || return 1

  while (( idx < ${#files[@]} )); do
    chunk=("${files[@]:idx:500}")
    llvm-profdata merge --output="$tmpdir/chunk-$chunk_idx.profdata" "${chunk[@]}"
    ((idx += 500, chunk_idx++))
  done

  shopt -s nullglob
  chunks=("$tmpdir"/*.profdata)
  shopt -u nullglob
  (( ${#chunks[@]} > 0 )) || return 1

  llvm-profdata merge --output="$out" "${chunks[@]}"
}

_run_training_workload() {
  local build_dir="$1"
  local run_num="$2"

  local hb_shape='' hb_subset='' hb_view='' hb_ot_shape_closure='' hb_gpu=''
  hb_shape=$(_find_build_tool "$build_dir" hb-shape 2>/dev/null || true)
  hb_subset=$(_find_build_tool "$build_dir" hb-subset 2>/dev/null || true)
  hb_view=$(_find_build_tool "$build_dir" hb-view 2>/dev/null || true)
  hb_ot_shape_closure=$(_find_build_tool "$build_dir" hb-ot-shape-closure 2>/dev/null || true)
  hb_gpu=$(_find_build_tool "$build_dir" hb-gpu 2>/dev/null || true)

  echo "==> PGO Training Run $run_num"

  meson test -C "$build_dir" --print-errorlogs --no-rebuild --num-processes "$(nproc)" || true
  meson test -C "$build_dir" --print-errorlogs --no-rebuild --num-processes 1 || true

  local -a fonts=()
  local -a font_paths=(
    /usr/share/fonts/noto
    /usr/share/fonts/noto-cjk
    /usr/share/fonts/TTF
    /usr/share/fonts/OTF
    /usr/share/fonts/truetype/dejavu
    /usr/share/fonts/truetype/noto
  )
  local fp
  for fp in "${font_paths[@]}"; do
    [[ -d "$fp" ]] || continue
    while IFS= read -r -d '' f; do
      fonts+=("$f")
      (( ${#fonts[@]} >= 90 )) && break 2
    done < <(
      LC_ALL=C find "$fp" -maxdepth 3 -type f \
        \( -name '*.ttf' -o -name '*.otf' \) -print0 2>/dev/null \
        | sort -z \
        | head -z -n 220
    )
  done

  (( ${#fonts[@]} > 0 )) || {
    echo "  -> Warning: no fonts found, skipping extended training"
    return 0
  }

  local -a texts=(
    "The quick brown fox jumps over the lazy dog. fi fl ffi ffl"
    "ÀÁÂÃÄÅÆÇÈÉÊË àáâãäåæçèéêë ñÑøØœŒßÿ Příliš žluťoučký kůň"
    "Съешь ещё этих мягких французских булок, да выпей чаю."
    "Ξεσκεπάζω τὴν ψυχοφθόρα βδελυγμία."
    "صِف خَلقَ خَودٍ كَمِثلِ الشَّمسِ إِذ بَزَغَت"
    "דג סקרן שט בים מאוכזב ולפתע מצא חברה"
    "ऋषियों को सताने वाले दुष्ट राक्षसों के राजा रावण"
    "เป็นมนุษย์สุดประเสริฐเลิศคุณค่า"
    "天地玄黄宇宙洪荒日月盈昃辰宿列张"
    "日本語テキスト。ひらがなカタカナ漢字"
    "한국어 텍스트 샘플입니다 가나다라마바사"
    "😀🎉🚀💻🔥✨🌍🎨📚🔧 ©®™ →←↑↓ ★☆"
  )
  local -a features=(
    "+kern,+liga"
    "+calt,+clig,+liga"
    "-liga,-kern"
    "+smcp"
    "+onum,+pnum"
    "+tnum,+lnum"
    "+dlig,+hlig"
  )
  local -a dirs=(ltr rtl ttb)
  local -a scripts=(Latn Arab Cyrl Grek Deva Hebr Hani Hang Kana)
  local -a langs=(en ar ru el hi he ja ko zh)

  if [[ -n "$hb_shape" ]]; then
    local font text feat dir scr lang cl
    for font in "${fonts[@]}"; do
      for text in "${texts[@]}"; do
        "$hb_shape" "$font" "$text" >/dev/null 2>&1 || true
        for feat in "${features[@]}"; do
          "$hb_shape" --features="$feat" "$font" "$text" >/dev/null 2>&1 || true
        done
        for dir in "${dirs[@]}"; do
          "$hb_shape" --direction="$dir" "$font" "$text" >/dev/null 2>&1 || true
        done
      done
      for scr in "${scripts[@]}"; do
        for lang in "${langs[@]}"; do
          "$hb_shape" --script="$scr" --language="$lang" --features="+kern,+liga" \
            "$font" "${texts[0]}" >/dev/null 2>&1 || true
        done
      done
      for cl in 0 1 2; do
        "$hb_shape" --cluster-level="$cl" "$font" "${texts[0]}" >/dev/null 2>&1 || true
      done
      "$hb_shape" --shapers=ot "$font" "${texts[1]}" >/dev/null 2>&1 || true
      "$hb_shape" --shapers=graphite2 "$font" "${texts[2]}" >/dev/null 2>&1 || true
    done
  fi

  if [[ -n "$hb_subset" ]]; then
    local tmpout range font text
    local -a ranges=(
      "U+0020-007F" "U+0080-00FF" "U+0100-017F" "U+0400-04FF" "U+0600-06FF"
      "U+0900-097F" "U+3040-30FF" "U+4E00-9FFF" "U+AC00-D7AF"
    )
    tmpout=$(mktemp --suffix=.ttf)
    for font in "${fonts[@]:0:40}"; do
      for range in "${ranges[@]}"; do
        "$hb_subset" --output-file="$tmpout" --unicodes="$range" "$font" >/dev/null 2>&1 || true
        "$hb_subset" --output-file="$tmpout" --unicodes="$range" --retain-gids "$font" >/dev/null 2>&1 || true
        "$hb_subset" --output-file="$tmpout" --unicodes="$range" --desubroutinize "$font" >/dev/null 2>&1 || true
        "$hb_subset" --output-file="$tmpout" --unicodes="$range" --no-hinting "$font" >/dev/null 2>&1 || true
      done
      for text in "${texts[@]:0:10}"; do
        "$hb_subset" --output-file="$tmpout" --text="$text" "$font" >/dev/null 2>&1 || true
      done
      "$hb_subset" --output-file="$tmpout" --layout-features+=kern,liga,calt \
        --unicodes="U+0020-007F" "$font" >/dev/null 2>&1 || true
    done
    rm -f "$tmpout"
  fi

  if [[ -n "$hb_ot_shape_closure" ]]; then
    local font text
    for font in "${fonts[@]:0:30}"; do
      for text in "${texts[@]:0:10}"; do
        "$hb_ot_shape_closure" "$font" "$text" >/dev/null 2>&1 || true
      done
    done
  fi

  if [[ -n "$hb_view" ]]; then
    local tmp_png tmp_svg font text
    tmp_png=$(mktemp --suffix=.png)
    tmp_svg=$(mktemp --suffix=.svg)
    for font in "${fonts[@]:0:24}"; do
      for text in "${texts[@]:0:10}"; do
        "$hb_view" --output-file="$tmp_png" --font-size=24 "$font" "$text" >/dev/null 2>&1 || true
        "$hb_view" --output-file="$tmp_png" --font-size=48 --margin=12 "$font" "$text" >/dev/null 2>&1 || true
        "$hb_view" --output-file="$tmp_svg" --font-size=32 "$font" "$text" >/dev/null 2>&1 || true
      done
    done
    rm -f "$tmp_png" "$tmp_svg"
  fi

  if [[ -n "$hb_gpu" ]]; then
    local font text
    for font in "${fonts[@]:0:20}"; do
      for text in "${texts[@]:0:10}"; do
        timeout -k 3s 8s \
          "$hb_gpu" --font="$font" --text="$text" --size=32 --output=/dev/null \
          >/dev/null 2>&1 || true
      done
    done
  fi

  echo "==> PGO Training Run $run_num complete"
}

build() {
  cd "$srcdir"

  export CC=clang
  export CXX=clang++
  export LD=lld
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib
  export STRIP=llvm-strip
  export OBJCOPY=llvm-objcopy
  export OBJDUMP=llvm-objdump
  export READELF=llvm-readelf
  export HOSTCC=clang
  export HOSTCXX=clang++

  CFLAGS="${CFLAGS//-fexceptions/}"
  CXXFLAGS="${CXXFLAGS//-fexceptions/}"

  local build_pgo1="$srcdir/build-pgo1"
  local build_pgo2="$srcdir/build-pgo2"
  local build_final="$srcdir/build"
  local pgo_dir="$srcdir/pgo"
  local pgo_standard_dir="$pgo_dir/standard"
  local pgo_cs_dir="$pgo_dir/cs"

  rm -rf "$build_final" "$build_pgo1" "$build_pgo2" "$pgo_dir"
  mkdir -p "$pgo_standard_dir" "$pgo_cs_dir"

  # Profile/training build config.
  local -a meson_profile_args=(
    -Dcpp_std=c++17
    -Dcairo=enabled
    -Dchafa=enabled
    -Dfreetype=enabled
    -Dglib=enabled
    -Dgobject=enabled
    -Dgraphite2=enabled
    -Dicu=enabled
    -Dpng=enabled
    -Dzlib=enabled
    -Draster=enabled
    -Dvector=enabled
    -Dgpu=enabled
    -Dgpu_demo=auto
    -Dsubset=enabled
    -Dicu_builtin=false
    -Ddocs=disabled
    -Dintrospection=disabled
    -Dbenchmark=disabled
    -Dutilities=enabled
  )

  # Final package build config.
  local -a meson_final_args=(
    -Dcpp_std=c++17
    -Dcairo=enabled
    -Dchafa=enabled
    -Dfreetype=enabled
    -Dglib=enabled
    -Dgobject=enabled
    -Dgraphite2=enabled
    -Dicu=enabled
    -Dpng=enabled
    -Dzlib=enabled
    -Draster=enabled
    -Dvector=enabled
    -Dgpu=enabled
    -Dgpu_demo=disabled
    -Dsubset=enabled
    -Dicu_builtin=false
    -Ddocs=disabled
    -Dintrospection=disabled
    -Dbenchmark=disabled
    -Dutilities=disabled
  )

  # LLVM profile quality tuning.
  local pgo_common_flags="-mllvm -enable-value-profiling -fprofile-update=atomic"
  local stage1_vp_flags="$pgo_common_flags -mllvm -vp-counters-per-site=8192"
  local stage2_vp_flags="$pgo_common_flags -mllvm -vp-counters-per-site=32768"

  echo "=========================================================================="
  echo " Stage 1/3: Standard PGO instrumentation"
  echo "=========================================================================="

  local stage1_cflags="$CFLAGS $stage1_vp_flags -fprofile-generate=$pgo_standard_dir"
  local stage1_cxxflags="$CXXFLAGS $stage1_vp_flags -fprofile-generate=$pgo_standard_dir"
  local stage1_ldflags="$LDFLAGS -fprofile-generate=$pgo_standard_dir -fprofile-update=atomic"

  arch-meson harfbuzz "$build_pgo1" \
    "${meson_profile_args[@]}" \
    -Dtests=enabled \
    -Db_ndebug=false \
    -Dc_args="$stage1_cflags" \
    -Dcpp_args="$stage1_cxxflags" \
    -Dc_link_args="$stage1_ldflags" \
    -Dcpp_link_args="$stage1_ldflags"

  meson compile -C "$build_pgo1"

  export LLVM_PROFILE_FILE="$pgo_standard_dir/default_%m.profraw"
  export LLVM_PROFILE_MERGE_POOL_SIZE=8
  _run_training_workload "$build_pgo1" 1
  unset LLVM_PROFILE_FILE LLVM_PROFILE_MERGE_POOL_SIZE

  _merge_profdata_safely "$pgo_dir/standard.profdata" "$pgo_standard_dir" || {
    echo "ERROR: failed to create standard.profdata" >&2
    return 1
  }

  echo "=========================================================================="
  echo " Stage 2/3: Context-sensitive PGO"
  echo "=========================================================================="

  local stage2_cflags="$CFLAGS $stage2_vp_flags -fprofile-use=$pgo_dir/standard.profdata -fcs-profile-generate=$pgo_cs_dir -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  local stage2_cxxflags="$CXXFLAGS $stage2_vp_flags -fprofile-use=$pgo_dir/standard.profdata -fcs-profile-generate=$pgo_cs_dir -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  local stage2_ldflags="$LDFLAGS -fprofile-use=$pgo_dir/standard.profdata -fcs-profile-generate=$pgo_cs_dir -fprofile-update=atomic"

  arch-meson harfbuzz "$build_pgo2" \
    "${meson_profile_args[@]}" \
    -Dtests=enabled \
    -Db_ndebug=false \
    -Dc_args="$stage2_cflags" \
    -Dcpp_args="$stage2_cxxflags" \
    -Dc_link_args="$stage2_ldflags" \
    -Dcpp_link_args="$stage2_ldflags"

  meson compile -C "$build_pgo2"

  export LLVM_PROFILE_FILE="$pgo_cs_dir/default_%m.profraw"
  export LLVM_PROFILE_MERGE_POOL_SIZE=8
  _run_training_workload "$build_pgo2" 2
  unset LLVM_PROFILE_FILE LLVM_PROFILE_MERGE_POOL_SIZE

  _merge_profdata_safely "$pgo_dir/cs.profdata" "$pgo_cs_dir" || {
    echo "ERROR: failed to create cs.profdata" >&2
    return 1
  }

  llvm-profdata merge \
    --output="$pgo_dir/merged.profdata" \
    "$pgo_dir/standard.profdata" \
    "$pgo_dir/cs.profdata"

  [[ -s "$pgo_dir/merged.profdata" ]] || {
    echo "ERROR: failed to create merged.profdata" >&2
    return 1
  }

  echo "=========================================================================="
  echo " Stage 3/3: Final PGO-optimized build"
  echo "=========================================================================="

  local final_cflags="$CFLAGS -fprofile-use=$pgo_dir/merged.profdata -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  local final_cxxflags="$CXXFLAGS -fprofile-use=$pgo_dir/merged.profdata -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  local final_ldflags="$LDFLAGS -fprofile-use=$pgo_dir/merged.profdata"

  arch-meson harfbuzz "$build_final" \
    "${meson_final_args[@]}" \
    -Dtests=disabled \
    -Db_ndebug=true \
    -Dc_args="$final_cflags" \
    -Dcpp_args="$final_cxxflags" \
    -Dc_link_args="$final_ldflags" \
    -Dcpp_link_args="$final_ldflags"

  meson compile -C "$build_final"
}

package_harfbuzz-git() {
  depends=(
    cairo
    freetype2
    glib2
    graphite
    libpng
    zlib
  )

  provides=(
    harfbuzz
    harfbuzz-cairo
    libharfbuzz.so
    libharfbuzz-cairo.so
    libharfbuzz-gobject.so
    libharfbuzz-subset.so
    libharfbuzz-raster.so
    libharfbuzz-vector.so
  )

  conflicts=(
    harfbuzz
    harfbuzz-cairo
  )

  rm -rf "$srcdir/hb-icu"
  meson install -C "$srcdir/build" --destdir "$pkgdir" --no-rebuild

  (
    cd "$pkgdir"
    shopt -s nullglob
    local icu_libs=(usr/lib/libharfbuzz-icu*)
    (( ${#icu_libs[@]} )) && _pick hb-icu "${icu_libs[@]}"
    [[ -e usr/lib/pkgconfig/harfbuzz-icu.pc ]] && _pick hb-icu usr/lib/pkgconfig/harfbuzz-icu.pc
    [[ -e usr/include/harfbuzz/hb-icu.h ]] && _pick hb-icu usr/include/harfbuzz/hb-icu.h
  )

  rm -rf \
    "$pkgdir"/usr/bin \
    "$pkgdir"/usr/share/man \
    "$pkgdir"/usr/share/gtk-doc

  install -Dm644 "$srcdir/harfbuzz/COPYING" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

package_harfbuzz-icu-git() {
  pkgdesc="OpenType text shaping engine (ICU integration)"

  depends=(
    harfbuzz-git
    icu
  )

  provides=(
    harfbuzz-icu
    libharfbuzz-icu.so
  )

  conflicts=(harfbuzz-icu)

  [[ -d "$srcdir/hb-icu" ]] || {
    echo "ERROR: split package directory '$srcdir/hb-icu' is missing" >&2
    return 1
  }

  cp -a "$srcdir/hb-icu/." "$pkgdir/"

  install -Dm644 "$srcdir/harfbuzz/COPYING" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
