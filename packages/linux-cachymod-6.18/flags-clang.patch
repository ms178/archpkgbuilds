Ensure Polly and internal -mllvm flags are guarded with cc-option
so DKMS module builds succeed with any clang version. Also guard
LTO linker flags with ld-option for the same reason.

Ensure the do_nanosleep function is not inlined

  "bpfland-next is setting a kprobe on do_nanosleep to detect tasks
  that are calling sleep explicititly and it keeps those on the same
  CPU, if the kprobe fails, nothing bad happens, but it's a small
  optimization"  -- arighi, CachyOS sched-ext discord

  $ sudo grep do_nanosleep /proc/kallsyms
  0000000000000000 t __pfx_do_nanosleep
  0000000000000000 t do_nanosleep

Ensure the setup_net function is not inlined, needed by bpftune

Signed-off-by: Mario Roy <>

diff -uarp a/Makefile b/Makefile
--- a/Makefile
+++ b/Makefile
@@ -891,6 +891,26 @@ KBUILD_CFLAGS += $(call cc-option,-fmodu
 KBUILD_RUSTFLAGS += -Cdebug-assertions=$(if $(CONFIG_RUST_DEBUG_ASSERTIONS),y,n)
 KBUILD_RUSTFLAGS += -Coverflow-checks=$(if $(CONFIG_RUST_OVERFLOW_CHECKS),y,n)
 
+ifdef CONFIG_CC_IS_CLANG
+KBUILD_CFLAGS	+= -fmerge-all-constants
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm=-enable-pipeliner)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm=-inline-threshold=420)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm=-enable-dfa-jump-thread=1)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm -polly-tiling=true)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm -polly-prevect-width=256)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm -polly-vectorizer=stripmine)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm -polly-invariant-load-hoisting)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm -polly-loopfusion-greedy)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm -polly-run-inliner)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm=-unroll-threshold=50)
+KBUILD_CFLAGS	+= $(call cc-option,-mllvm=-always-rename-promoted-locals=false)
+ifdef CONFIG_LTO_CLANG
+KBUILD_LDFLAGS	+= $(call ld-option,--lto-O3)
+KBUILD_LDFLAGS	+= $(call ld-option,--lto-CGO2)
+KBUILD_LDFLAGS	+= $(call ld-option,--lto-whole-program-visibility)
+endif
+endif
+
 # Tell gcc to never replace conditional load with a non-conditional one
 ifdef CONFIG_CC_IS_GCC
 # gcc-10 renamed --param=allow-store-data-races=0 to
diff -uarp a/kernel/time/hrtimer.c b/kernel/time/hrtimer.c
--- a/kernel/time/hrtimer.c
+++ b/kernel/time/hrtimer.c
@@ -2104,7 +2104,7 @@ int nanosleep_copyout(struct restart_blo
 	return -ERESTART_RESTARTBLOCK;
 }
 
-static int __sched do_nanosleep(struct hrtimer_sleeper *t, enum hrtimer_mode mode)
+static noinline int __sched do_nanosleep(struct hrtimer_sleeper *t, enum hrtimer_mode mode)
 {
 	struct restart_block *restart;
 
