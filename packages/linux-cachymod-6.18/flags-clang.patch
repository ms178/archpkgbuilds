diff --git a/init/initramfs.c b/init/initramfs.c
index 6ddbfb17fb8f1b42f7a937defc9e017c75539ae5..55035e9d1376a158a019d14c6a19aa65dcac8e2e 100644
--- a/init/initramfs.c
+++ b/init/initramfs.c
@@ -149,6 +149,29 @@ struct dir_entry {
 	char name[];
 };
 
+static __always_inline __init void initramfs_list_add(struct list_head *new)
+{
+	struct list_head *head = &dir_list;
+	struct list_head *next = head->next;
+
+	/*
+	 * Keep the initramfs-only list insertion in .init.text.  With Clang
+	 * full-LTO plus hot/cold splitting, the generic inline list_add() can be
+	 * materialized as a .text.hot local helper that directly references the
+	 * __initdata dir_list head, which is correct after inlining but trips
+	 * modpost section checking when outlined.  This is list_add()'s exact
+	 * sequence for insertion after @head, including list hardening, forced
+	 * inline into the __init caller.
+	 */
+	if (!__list_add_valid(new, head, next))
+		return;
+
+	next->prev = new;
+	new->next = next;
+	new->prev = head;
+	WRITE_ONCE(head->next, new);
+}
+
 static void __init dir_add(const char *name, size_t nlen, time64_t mtime)
 {
 	struct dir_entry *de;
@@ -159,7 +182,7 @@ static void __init dir_add(const char *name, size_t nlen, time64_t mtime)
 	INIT_LIST_HEAD(&de->list);
 	strscpy(de->name, name, nlen);
 	de->mtime = mtime;
-	list_add(&de->list, &dir_list);
+	initramfs_list_add(&de->list);
 }
 
 static void __init dir_utime(void)
