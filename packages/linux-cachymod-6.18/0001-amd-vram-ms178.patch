From 2a0ab11998407312c873b4edba30b283f22e7f2e Mon Sep 17 00:00:00 2001
From: Audit <audit@local>
Date: Wed, 3 Jun 2026 09:52:56 +0000
Subject: [PATCH 7/7] cgroup/dmem,drm/ttm: audit fixups

Five bugs identified in this rebase audit, all fixed here as a single
follow-up commit on top of Natalie Vock's series:

  A) dmem_cgroup_get_common_ancestor used cgroup_e_css() + plain css_get().
     cgroup_e_css()'s contract explicitly says the returned css is "not
     guaranteed to be online, and therefore it is the callers
     responsibility to try get a reference for it" -- i.e. css_tryget_online,
     not css_get.  A plain css_get on a css that has started going offline
     races against cgroup destruction.

  B) Same code path was missing rcu_read_lock around the cgroup_e_css
     ancestor walk.  cgroup_e_css follows cgroup_parent links under RCU.

  C) The NULL return from cgroup_e_css (when !CGROUP_HAS_SUBSYS_CONFIG)
     was not checked.

  Both A, B, and C are resolved by calling cgroup_get_e_css() instead:
  it takes RCU internally, uses css_tryget_online, and only returns NULL
  in the !CGROUP_HAS_SUBSYS_CONFIG case, which we now check.

  D) get_cg_pool_unlocked() can return ERR_PTR(-ENOMEM) on allocation
     failure and ERR_PTR(-ENODEV) if the region has been unregistered.
     dmem_cgroup_get_common_ancestor returned that error pointer directly
     to the caller.  In ttm_bo_evict_cb, the caller's `if (ancestor)`
     test is true for error pointers, so the error pointer would be
     passed to dmem_cgroup_state_evict_valuable() and
     dmem_cgroup_pool_state_put(), both of which dereference it.
     This is a kernel oops under memory pressure or device hotplug.
     Fixed with IS_ERR() check and ref drop on failure.

  E) ttm_bo_evict_cb's "skip same cgroup" rule under !may_try_low
     compared bo->resource->css == alloc_state->charge_pool by raw
     pointer.  When both are NULL (uncharged BO under uncharged
     allocation, e.g. system-memory paths) the equality succeeds and
     the BO is incorrectly skipped.  Added an explicit non-NULL check
     so that NULL != NULL for skip-decision purposes.

  Bugs A, B, C, D are in patch 2 of the series (cgroup,cgroup/dmem: Add
  (dmem_)cgroup_common_ancestor helper).  Bug E is in patch 6 (drm/ttm:
  Use common ancestor of evictor and evictee as limit pool).  They are
  consolidated here to keep the original patches' authorship and review
  trail intact; squashing into the originals would require Natalie to
  re-sign.

  See amd-vram-audit/tests/test_logic.py for the algorithmic test suite
  that demonstrates each bug.

Signed-off-by: Audit reviewer <audit@local>
---
 drivers/gpu/drm/ttm/ttm_bo.c |  7 +++++++
 kernel/cgroup/dmem.c         | 40 +++++++++++++++++++++++++++++++++---
 2 files changed, 44 insertions(+), 3 deletions(-)

diff --git a/drivers/gpu/drm/ttm/ttm_bo.c b/drivers/gpu/drm/ttm/ttm_bo.c
index 3b0f5ad..9264159 100644
--- a/drivers/gpu/drm/ttm/ttm_bo.c
+++ b/drivers/gpu/drm/ttm/ttm_bo.c
@@ -638,8 +638,15 @@ static s64 ttm_bo_evict_cb(struct ttm_lru_walk *walk, struct ttm_buffer_object *
 	 * buffers belonging to the same cgroup here - that cgroup is definitely protected,
 	 * even though dmem_cgroup_state_evict_valuable would allow the eviction because a
 	 * cgroup is always allowed to evict from itself even if it is protected.
+	 *
+	 * The bo->resource->css non-NULL check is required so that we don't treat
+	 * an uncharged BO (no cgroup) as "same cgroup" as an uncharged allocation
+	 * (charge_pool == NULL).  Without this check, system-memory evictions
+	 * would be incorrectly skipped whenever the allocator itself is not
+	 * cgroup-charged.
 	 */
 	if (!evict_walk->alloc_state->may_try_low &&
+			bo->resource->css &&
 			bo->resource->css == evict_walk->alloc_state->charge_pool)
 		return 0;
 
diff --git a/kernel/cgroup/dmem.c b/kernel/cgroup/dmem.c
index f1a3585..f2d0345 100644
--- a/kernel/cgroup/dmem.c
+++ b/kernel/cgroup/dmem.c
@@ -771,18 +771,52 @@ struct dmem_cgroup_pool_state *dmem_cgroup_get_common_ancestor(struct dmem_cgrou
 {
 	struct cgroup *ancestor_cgroup;
 	struct cgroup_subsys_state *ancestor_css;
+	struct dmem_cgroup_pool_state *pool;
 
 	if (!a || !b)
 		return NULL;
 
+	/*
+	 * cgroup_common_ancestor walks the ancestors[] arrays of @a and @b.
+	 * Both cgroups are kept alive for the duration of this call by the
+	 * caller's pool references (each pool holds a css ref on its cgroup).
+	 */
 	ancestor_cgroup = cgroup_common_ancestor(a->cs->css.cgroup, b->cs->css.cgroup);
 	if (!ancestor_cgroup)
 		return NULL;
 
-	ancestor_css = cgroup_e_css(ancestor_cgroup, &dmem_cgrp_subsys);
-	css_get(ancestor_css);
+	/*
+	 * Use cgroup_get_e_css() rather than cgroup_e_css() + css_get():
+	 *  - cgroup_e_css() returns an unreferenced css that the caller is
+	 *    explicitly told to acquire via css_tryget_online() (the css
+	 *    may have already started going offline).  A plain css_get()
+	 *    here can race against cgroup destruction.
+	 *  - cgroup_e_css() also requires the caller to hold rcu_read_lock
+	 *    or the cgroup mutex while walking parents.
+	 * cgroup_get_e_css() handles both of those concerns internally and
+	 * returns either an online css with an incremented refcount, or NULL
+	 * if no subsys is configured (impossible when dmem itself is enabled,
+	 * but checked defensively).
+	 */
+	ancestor_css = cgroup_get_e_css(ancestor_cgroup, &dmem_cgrp_subsys);
+	if (!ancestor_css)
+		return NULL;
 
-	return get_cg_pool_unlocked(css_to_dmemcs(ancestor_css), a->region);
+	/*
+	 * get_cg_pool_unlocked() can return ERR_PTR(-ENOMEM) on allocation
+	 * failure or ERR_PTR(-ENODEV) if the region was unregistered between
+	 * the cgroup lookup and the pool lookup.  Treat both as "no common
+	 * ancestor available" by returning NULL; the caller falls back to
+	 * the default (limit_pool == NULL) behaviour, which is equivalent to
+	 * the pre-patch eviction semantics.
+	 */
+	pool = get_cg_pool_unlocked(css_to_dmemcs(ancestor_css), a->region);
+	if (IS_ERR(pool)) {
+		css_put(ancestor_css);
+		return NULL;
+	}
+
+	return pool;
 }
 EXPORT_SYMBOL_GPL(dmem_cgroup_get_common_ancestor);
 
-- 
