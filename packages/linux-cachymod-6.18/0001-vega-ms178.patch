+	case AMDGPU_CHUNK_ID_SYNCOBJ_OUT:
+	case AMDGPU_CHUNK_ID_SCHEDULED_DEPENDENCIES:
+	case AMDGPU_CHUNK_ID_SYNCOBJ_TIMELINE_WAIT:
+	case AMDGPU_CHUNK_ID_SYNCOBJ_TIMELINE_SIGNAL:
+	default:
+		return length_dw;
+	}
+}
+
+static int amdgpu_cs_chunk_num_elems(const struct amdgpu_cs_chunk *chunk,
+				     size_t elem_size, unsigned int *num_elems)
+{
+	size_t bytes;
+	size_t count;
+
+	if (!elem_size)
+		return -EINVAL;
+
+	bytes = (size_t)chunk->length_dw * sizeof(uint32_t);
+	if (bytes % elem_size)
+		return -EINVAL;
+
+	count = bytes / elem_size;
+	if (count > UINT_MAX)
+		return -EINVAL;
+
+	*num_elems = (unsigned int)count;
+	return 0;
+}
