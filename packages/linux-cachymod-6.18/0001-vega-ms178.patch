+	case AMDGPU_CHUNK_ID_BO_HANDLES:
+		return sizeof(struct drm_amdgpu_bo_list_in) / sizeof(uint32_t);
+	case AMDGPU_CHUNK_ID_CP_GFX_SHADOW:
+		return sizeof(struct drm_amdgpu_cs_chunk_cp_gfx_shadow) / sizeof(uint32_t);
+	case AMDGPU_CHUNK_ID_DEPENDENCIES:
