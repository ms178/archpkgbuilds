@@ -0,0 +1,14 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * nap_nn_native.c -- build-local native NAP NN implementation
+ *
+ * This TU intentionally reuses the audited 8-wide AVX2/FMA kernel and lets
+ * -march=native expose all build-CPU instructions.  On the target Raptor Lake
+ * system this means the AVX2 path gets the full native scheduler/tuning and
+ * scalar instruction set.  On AVX-512-capable native builds, Clang may choose
+ * AVX-512VL/opmask encodings where they are profitable.
+ */
+
+#define nap_nn_forward_avx2 nap_nn_forward_native
+#define nap_nn_learn_avx2   nap_nn_learn_native
+#include "nap_nn_avx2.c"
diff --git a/drivers/cpuidle/governors/nap/nap_nn_sse2.c b/drivers/cpuidle/governors/nap/nap_nn_sse2.c
new file mode 100644
index 0000000000000000000000000000000000000000..af524704da5eb34823b14d572b3fcb63700c0ac1
--- /dev/null
+++ b/drivers/cpuidle/governors/nap/nap_nn_sse2.c
@@ -0,0 +1,150 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * nap_nn_sse2.c — SSE2 forward and backward for the NAP MLP
+ *
+ * 8 → 8 → 1 scalar regression.  Baseline path used whenever AVX2+FMA
+ * is not present (almost no current x86_64 CPU is missing both, but
+ * we keep the SSE2 path because it's the kernel-wide x86_64 baseline
+ * ISA).
+ *
+ * Must be called only from within kernel_fpu_begin()/end().
+ * Compiled with: -msse2 (see Makefile).
+ *
+ * Audit notes:
+ *   B19: Horizontal sum is now shuf+add (4 instructions) rather than
+ *   4 scalar element extracts + 3 scalar adds (~12 cycles → ~6).
+ */
+
+#include "nap.h"
+
+static inline v4sf v4sf_load(const float *p)
+{
+	return *(const v4sf *)p;
+}
+
+static inline void v4sf_store(float *p, v4sf v)
+{
+	*(v4sf *)p = v;
+}
+
+/* ================================================================
+ * Forward pass
+ *
+ * Hidden layer: 8 outputs split across two xmm accumulators.
+ *
+ * Estimated cost (Raptor Lake P-core, SSE2 throughput 2 mulps + 2
+ * addps per cycle, latency 4 cycles each):
+ *   - 8 inputs × 2 (mulps + addps) per accumulator pair: ~28 cycles
+ *     latency-bound on the dependent addps chain
+ *   - 2× vmaxps (ReLU): 4 cycles
+ *   - output mul + horizontal reduce: ~10 cycles
+ *   Total: ~45 cycles.  Static estimate; not measured.
+ * ================================================================ */
+
+void nap_nn_forward_sse2(const float *input,
+			 float *output,
+			 float *hidden_save,
+			 const struct nap_weights *w)
+{
+	v4sf acc0 = v4sf_load(&w->b_h1[0]);
+	v4sf acc1 = v4sf_load(&w->b_h1[4]);
+	const v4sf zero = V4SF_SET1(0.0f);
+	v4sf p0, p1, sum, t;
+	int j;
+
+	for (j = 0; j < NAP_INPUT_SIZE; j++) {
+		v4sf x = V4SF_SET1(input[j]);
+
+		acc0 += v4sf_load(&w->w_h1[j][0]) * x;
+		acc1 += v4sf_load(&w->w_h1[j][4]) * x;
+	}
+
+	acc0 = __builtin_ia32_maxps(acc0, zero);
+	acc1 = __builtin_ia32_maxps(acc1, zero);
+	v4sf_store(&hidden_save[0], acc0);
+	v4sf_store(&hidden_save[4], acc1);
+
+	p0  = v4sf_load(&w->w_out[0]) * acc0;
+	p1  = v4sf_load(&w->w_out[4]) * acc1;
+	sum = p0 + p1;
+
+	/* Horizontal reduce: 2 shufps + 2 addps */
+	t   = __builtin_ia32_shufps(sum, sum, 0x4E); /* swap halves */
+	sum = sum + t;
+	t   = __builtin_ia32_shufps(sum, sum, 0xB1); /* swap pairs */
+	sum = sum + t;
+
+	*output = sum[0] + w->b_out;
+}
+
+/* ================================================================
+ * Online learning (backprop)
+ * ================================================================ */
+
+void nap_nn_learn_sse2(struct nap_cpu_data *d)
+{
+	const float d_out_scalar = d->learn_d_out;
+	const float lr           = d->learn_lr;
+	const float clamp_val    =
+		(float)d->max_grad_norm_millths / 1000.0f;
+
+	const v4sf v_lr     = V4SF_SET1(lr);
+	const v4sf v_cl_hi  = V4SF_SET1(clamp_val);
+	const v4sf v_cl_lo  = V4SF_SET1(-clamp_val);
+	const v4sf vd       = V4SF_SET1(d_out_scalar);
+	const v4sf zero     = V4SF_SET1(0.0f);
+
+	v4sf dh0, dh1;
+	int i;
+
+	/*
+	 * Hidden gradient.  Must be computed before output weight
+	 * update, because it uses the pre-update w_out.
+	 */
+	{
+		v4sf h, g;
+		v4si m;
+
+		h = v4sf_load(&d->hidden_out[0]);
+		g = v4sf_load(&d->active_w->w_out[0]) * vd;
+		m = (v4si)(h > zero);
+		dh0 = v4si_as_v4sf(v4sf_as_v4si(g) & m);
+		v4sf_store(&d->learn_d_hid[0], dh0);
+
+		h = v4sf_load(&d->hidden_out[4]);
+		g = v4sf_load(&d->active_w->w_out[4]) * vd;
+		m = (v4si)(h > zero);
+		dh1 = v4si_as_v4sf(v4sf_as_v4si(g) & m);
+		v4sf_store(&d->learn_d_hid[4], dh1);
+	}
+
+	/* Output weight update */
+	{
+		v4sf *w = (v4sf *)&d->active_w->w_out[0];
+
+		w[0] -= v_lr * v4sf_clamp(v4sf_load(&d->hidden_out[0]) * vd,
+					  v_cl_lo, v_cl_hi);
+		w[1] -= v_lr * v4sf_clamp(v4sf_load(&d->hidden_out[4]) * vd,
+					  v_cl_lo, v_cl_hi);
+	}
+
+	d->active_w->b_out -= lr * fclampf(d_out_scalar,
+					    -clamp_val, clamp_val);
+
+	/* Hidden weight update */
+	for (i = 0; i < NAP_INPUT_SIZE; i++) {
+		v4sf  vf = V4SF_SET1(d->features_f32[i]);
+		v4sf *w  = (v4sf *)&d->active_w->w_h1[i][0];
+
+		w[0] -= v_lr * v4sf_clamp(vf * dh0, v_cl_lo, v_cl_hi);
+		w[1] -= v_lr * v4sf_clamp(vf * dh1, v_cl_lo, v_cl_hi);
+	}
+
+	/* Hidden bias update */
+	{
+		v4sf *b = (v4sf *)&d->active_w->b_h1[0];
+
+		b[0] -= v_lr * v4sf_clamp(dh0, v_cl_lo, v_cl_hi);
+		b[1] -= v_lr * v4sf_clamp(dh1, v_cl_lo, v_cl_hi);
+	}
+}
