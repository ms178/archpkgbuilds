# Per-stage instrumentation flags. Lessons baked in (libx11 v3 / xwayland):
#   * no -g3                : zero PGO accuracy gain, +80% object size
#   * no -fno-omit-fp       : mismatch with final build = silently worse PGO
#   * vp-counters-per-site=8: upstream default (fontconfig has few hot IC sites)
#   * runtime-counter-relocation : REQUIRED for shared libraries
_pgo_mllvm=(
  -mllvm -vp-counters-per-site=12
  -mllvm -runtime-counter-relocation
  -mllvm -enable-value-profiling
)
_profile_silence=(-Wno-profile-instr-unprofiled -Wno-profile-instr-out-of-date)

_has_pytest_tap() {
  pytest --help 2>/dev/null | grep -q -- '--tap'
}

_pgo_count() { find "$1" -maxdepth 1 -type f -name '*.profraw' 2>/dev/null | wc -l; }
_pgo_bytes() { find "$1" -maxdepth 1 -type f -name '*.profraw' -printf '%s\n' 2>/dev/null | awk '{s+=$1} END{print s+0}'; }
_pgo_diag()  { printf '  -> [PGO] %s: profraw=%s bytes=%s dir=%s\n' "$1" "$(_pgo_count "$2")" "$(_pgo_bytes "$2")" "$2"; }

_detect_toolchain() {
  : "${CC:=clang}"; : "${CXX:=clang++}"
  : "${AR:=llvm-ar}"; : "${NM:=llvm-nm}"; : "${RANLIB:=llvm-ranlib}"
  command -v "$CC"     >/dev/null || { error "CC not found: $CC";     return 1; }
  command -v "$CXX"    >/dev/null || { error "CXX not found: $CXX";   return 1; }
  command -v "$AR"     >/dev/null || { error "AR not found: $AR";     return 1; }
  command -v "$NM"     >/dev/null || { error "NM not found: $NM";     return 1; }
  command -v "$RANLIB" >/dev/null || { error "RANLIB not found: $RANLIB"; return 1; }
  local _triple
  _triple="$("$CC" -print-target-triple 2>/dev/null || "$CC" -dumpmachine 2>/dev/null || true)"
  [[ "$_triple" == *linux* ]] || { error "Compiler target not Linux: $_triple"; return 1; }
  printf '  -> [TOOLCHAIN] CC=%s\n' "$(command -v "$CC")"
}

_toolchain_supports_flag() {
  local _flag="$1"
  local _tdir
  _tdir="$(mktemp -d "$srcdir/.toolchain-sanity.XXXXXX")"
  printf 'int main(void){return 0;}\n' > "$_tdir/x.c"
  "$CC" "$_tdir/x.c" -o "$_tdir/x" $LDFLAGS "$_flag" >/dev/null 2>&1
  local rc=$?
  rm -rf "$_tdir"
  return $rc
}

# Pre-flight smoke-test: build a tiny C client of system libfontconfig that
# touches the major API surface. If it crashes, refuse to start PGO chain
# (libx11 v3 lesson: silently broken trainer = silently halved coverage).
_smoke_test() {
  command -v pkg-config >/dev/null || return 0
  pkg-config --exists fontconfig 2>/dev/null || return 0
  local _t
  _t="$(mktemp -d "$srcdir/.smoke.XXXXXX")"
  cat > "$_t/smoke.c" <<'SMOKE_EOF'
#include <fontconfig/fontconfig.h>
#include <stdio.h>
int main(void) {
  if (!FcInit()) return 1;
  FcConfig *c = FcConfigGetCurrent();
  if (!c) return 2;
  FcPattern *p = FcPatternBuild(NULL, FC_FAMILY, FcTypeString, "sans-serif",
                                FC_WEIGHT, FcTypeInteger, FC_WEIGHT_BOLD,
                                FC_SIZE, FcTypeDouble, 12.0, NULL);
  if (!p) return 3;
  FcConfigSubstitute(c, p, FcMatchPattern);
  FcDefaultSubstitute(p);
  FcResult r;
  FcPattern *m = FcFontMatch(c, p, &r);
  if (m) FcPatternDestroy(m);
  FcPatternDestroy(p);
  FcFontSet *fs = FcFontList(c, FcPatternCreate(), FcObjectSetBuild(FC_FAMILY, FC_FILE, NULL));
  if (fs) FcFontSetDestroy(fs);
  FcFini();
  return 0;
}
SMOKE_EOF
  if "$CC" $CFLAGS $(pkg-config --cflags fontconfig) "$_t/smoke.c" \
       -o "$_t/smoke" $LDFLAGS $(pkg-config --libs fontconfig) >/dev/null 2>&1; then
    if ! timeout -k 2 10 "$_t/smoke"; then
      error "Smoke-test FAILED -- refusing to start PGO chain"
      rm -rf "$_t"; return 1
    fi
    printf '  -> [SMOKE] system libfontconfig OK\n'
  fi
  rm -rf "$_t"
}

# Custom workload: drive fc-cache/fc-list/fc-match/fc-scan/fc-query/fc-pattern/
# fc-conflist/fc-validate/fc-cat across the host font tree.
_training_workload() {
  local _builddir="$1"
  (
    set -eo pipefail
    local _workroot _sysroot _cachedir _etc_fonts
    _workroot="$(mktemp -d "${_builddir}/fc-train.XXXXXX")"
    trap 'rm -rf "$_workroot"' EXIT
    _sysroot="${_workroot}/sysroot"
    _cachedir="${_sysroot}/var/cache/fontconfig"
    _etc_fonts="${_sysroot}/etc/fonts"
    mkdir -p "$_cachedir" "$_etc_fonts" "${_workroot}/xdg-cache" "${_workroot}/home"
    [[ -d /etc/fonts ]] && cp -a /etc/fonts/. "$_etc_fonts/"

    local -a font_dirs=() d
    for d in /usr/share/fonts/{TTF,OTF,Type1,truetype,opentype,cantarell,liberation,noto,adobe-source-code-pro,gsfonts}; do
      [[ -d "$d" ]] && font_dirs+=("$d")
    done
    for d in "${font_dirs[@]}"; do
      mkdir -p "${_sysroot}$(dirname "$d")"
      ln -sfn "$d" "${_sysroot}${d}"
    done
    export FONTCONFIG_SYSROOT="$_sysroot"
    export FONTCONFIG_CACHEDIR="$_cachedir"
    export XDG_CACHE_HOME="${_workroot}/xdg-cache"
    export HOME="${_workroot}/home"
    [[ -f "${_etc_fonts}/fonts.conf" ]] && {
      export FONTCONFIG_FILE="${_etc_fonts}/fonts.conf"
      export FONTCONFIG_PATH="${_etc_fonts}"
    }

    _fc() { find "$_builddir" -type f -executable -name "$1" -print -quit; }
    local FC_CACHE FC_LIST FC_MATCH FC_SCAN FC_QUERY FC_PATTERN FC_CONFLIST FC_VALIDATE FC_CAT
    FC_CACHE="$(_fc fc-cache || true)";    FC_LIST="$(_fc fc-list || true)"
    FC_MATCH="$(_fc fc-match || true)";    FC_SCAN="$(_fc fc-scan || true)"
    FC_QUERY="$(_fc fc-query || true)";    FC_PATTERN="$(_fc fc-pattern || true)"
    FC_CONFLIST="$(_fc fc-conflist || true)"; FC_VALIDATE="$(_fc fc-validate || true)"
    FC_CAT="$(_fc fc-cat || true)"
    [[ -z "$FC_CACHE" || -z "$FC_LIST" || -z "$FC_MATCH" ]] && {
      printf '  -> [PGO] required fc-tools missing, skipping workload\n'
      exit 0
    }
    find "$_cachedir" -type f -name '*.cache-*' -delete 2>/dev/null || true
    rm -f "$_cachedir"/CACHEDIR.TAG 2>/dev/null || true

    (( ${#font_dirs[@]} > 0 )) && "$FC_CACHE" -sv "${font_dirs[@]}" >/dev/null 2>&1 || true

    local font size
    local -a common_fonts=(
      "sans-serif" "serif" "monospace"
      "Arial" "Times New Roman" "Courier New"
      "DejaVu Sans" "DejaVu Serif" "DejaVu Sans Mono"
      "Liberation Sans" "Liberation Serif" "Liberation Mono"
      "Noto Sans" "Noto Serif" "Noto Sans CJK SC" "Noto Sans Arabic" "Noto Sans Hebrew"
      "Cantarell" "FreeSans" "FreeMono"
    )
    for font in "${common_fonts[@]}"; do
      for spec in "$font" "$font:bold" "$font:italic" "$font:weight=200" \
                  "$font:lang=en" "$font:lang=ja" "$font:lang=zh-cn" \
                  "$font:lang=ar" "$font:lang=he"; do
        "$FC_MATCH" "$spec" >/dev/null 2>&1 || true
      done
    done

    "$FC_LIST" : family style file        | head -n 5000 >/dev/null 2>&1 || true
    "$FC_LIST" : family lang spacing outline scalable | head -n 5000 >/dev/null 2>&1 || true
    "$FC_LIST" : lang | sort -u           >/dev/null 2>&1 || true

    if [[ -n "$FC_PATTERN" ]]; then
      for size in 8 9 10 11 12 14 16 18 20 24 32 48 64 72; do
        "$FC_PATTERN" "Sans-${size}" >/dev/null 2>&1 || true
        "$FC_PATTERN" "Serif-${size}:weight=bold" >/dev/null 2>&1 || true
        "$FC_PATTERN" "Monospace-${size}:slant=italic" >/dev/null 2>&1 || true
      done
    fi

    local -a sample_fonts=()
    if (( ${#font_dirs[@]} > 0 )); then
      mapfile -t sample_fonts < <(
        find "${font_dirs[@]}" -type f \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) 2>/dev/null | head -n 100
      )
    fi
    # fc-scan / fc-query / fc-validate must NOT see FONTCONFIG_SYSROOT.
    local _saved_sysroot="${FONTCONFIG_SYSROOT:-}"
    unset FONTCONFIG_SYSROOT
    if (( ${#sample_fonts[@]} > 0 )); then
      [[ -n "$FC_SCAN"     ]] && "$FC_SCAN"     "${sample_fonts[@]}" >/dev/null 2>&1 || true
      [[ -n "$FC_QUERY"    ]] && "$FC_QUERY"    "${sample_fonts[@]}" >/dev/null 2>&1 || true
      [[ -n "$FC_VALIDATE" ]] && "$FC_VALIDATE" "${sample_fonts[@]}" >/dev/null 2>&1 || true
    fi
    export FONTCONFIG_SYSROOT="$_saved_sysroot"

    [[ -n "$FC_CONFLIST" ]] && "$FC_CONFLIST" >/dev/null 2>&1 || true
    if [[ -n "$FC_CAT" ]]; then
      find "$_cachedir" -type f -name '*.cache-*' 2>/dev/null | head -n 20 | \
        xargs -r "$FC_CAT" >/dev/null 2>&1 || true
    fi
    printf '  -> [PGO] custom workload: done (fonts=%d, sample=%d)\n' \
           "${#font_dirs[@]}" "${#sample_fonts[@]}"
  ) || true
}

prepare() {
  cd fontconfig
  rm -f subprojects/*.wrap
  rm -rf subprojects/packagecache

  # ------------------------------------------------------------------------
  # Patch fontconfig 2.18.1 upstream test framework (test/fctest/__init__.py)
  # to fix two bugs that ONLY manifest under makepkg's environment.
  #
  # ROOT CAUSE diagnosed from user's testlog.txt:
  #   not ok 1 test_basic.py::test_basic
  #   ...
  #   >               os.utime(str(dname), (time, time))
  #   E               TypeError: argument must be int or float, not str
  #
  # BUG A: fctest.install_font() reads SOURCE_DATE_EPOCH as the file mtime to
  # use for installed test fonts. makepkg sets SOURCE_DATE_EPOCH as a string
  # (Unix timestamp) for reproducible builds. install_font passes it directly
  # to os.utime() which requires (int|float, int|float) -> TypeError on
  # every call. Breaks 16/17 tests (every test that installs fonts).
  #
  # The deeper issue: even after string->int coercion, the test framework
  # forces the FONT DIRECTORY's mtime to SOURCE_DATE_EPOCH too. fontconfig's
  # cache uses dir mtime to detect stale caches; with all mtimes pinned to
  # the same epoch, 4 mtime-invalidation tests
  # (test_subdir_with_out_of_date_cache, test_new_file_with_out_of_date_cache,
  # test_keep_mtime, test_xdg_cache_home) silently regress because the
  # cache appears fresh when it shouldn't.
  #
  # Cleanest fix: unset SOURCE_DATE_EPOCH inside the fctest fixture. This
  # makes mtime tests behave as real-world (wall-clock-driven) cache use,
  # which is what fontconfig is supposed to handle. SOURCE_DATE_EPOCH is
  # a build-output reproducibility env var, not meant to govern mtime-based
  # test fixtures.
  #
  # BUG B: bwrap sandbox uses `--tmpfs /tmp` which wipes the build dir's
  # path when builddir is under /tmp (CachyOS makepkg's BUILDDIR=/tmp/makepkg).
  # After the tmpfs wipe, `f.run(self._fcmatch)` fails because the
  # original builddir path doesn't exist inside the sandbox.
  # Fix: re-bind builddir at its original path after the tmpfs wipe.
  #
  # Both bugs are present in upstream master (commit d87ec67).
  # ------------------------------------------------------------------------
  python3 - <<'PY'
from pathlib import Path
import sys
p = Path("test/fctest/__init__.py")
s = p.read_text(encoding="utf-8")

# --- BUG A: drop SOURCE_DATE_EPOCH inside FcTest fixture ------------------
# Patch FcTest.__init__: after `self._env = os.environ.copy()`, strip
# SOURCE_DATE_EPOCH from the fixture's env (and from install_font's lookup).
# This kills both the TypeError and the mtime-pinning side-effect that
# breaks cache-invalidation tests.
old_a = ("    def __init__(self):\n"
         "        self._with_fontations = False\n"
         "        self.logger = logging.getLogger()\n"
         "        self._env = os.environ.copy()\n")
new_a = ("    def __init__(self):\n"
         "        self._with_fontations = False\n"
         "        self.logger = logging.getLogger()\n"
         "        self._env = os.environ.copy()\n"
         "        # CachyOS fix A: SOURCE_DATE_EPOCH is a string (makepkg sets it)\n"
         "        # which crashes os.utime, AND pins all mtimes to one value which\n"
         "        # silently breaks the cache-staleness tests. Drop it.\n"
         "        self._env.pop('SOURCE_DATE_EPOCH', None)\n")
if "CachyOS fix A" not in s:
    if old_a not in s:
        print("ERROR: BUG A site not found in test/fctest/__init__.py", file=sys.stderr)
        sys.exit(1)
    s = s.replace(old_a, new_a)

# --- BUG B: bwrap /tmp tmpfs wipes builddir path --------------------------
old_b = ("""            boxed = [self._bwrap, '--ro-bind', '/', '/',
                     '--dev-bind', '/dev', '/dev',
                     '--proc', '/proc',
                     # Use fresh tmpfs to avoid unexpected references
                     '--tmpfs', '/tmp',
                     '--setenv', 'FONTCONFIG_FILE', self._env['FONTCONFIG_FILE']]""")
new_b = old_b + """
            # CachyOS fix B: re-expose builddir under /tmp after --tmpfs
            if str(self._builddir).startswith('/tmp/'):
                boxed += ['--bind', str(self._builddir), str(self._builddir)]"""
if "CachyOS fix B" not in s:
    if old_b not in s:
        print("ERROR: BUG B site not found in test/fctest/__init__.py", file=sys.stderr)
        sys.exit(1)
    s = s.replace(old_b, new_b)

p.write_text(s, encoding="utf-8")
PY
  grep -Fq "CachyOS fix A" test/fctest/__init__.py || {
    error "fontconfig fctest SOURCE_DATE_EPOCH patch not applied"; return 1
  }
  grep -Fq "CachyOS fix B" test/fctest/__init__.py || {
    error "fontconfig fctest bwrap /tmp patch not applied"; return 1
  }

  # 2. fcobjshash preprocessor target needs a real source file (Meson v1.11+
  #    is stricter about preprocessor inputs).
  cat > src/fcobjshash-preprocess.c <<'EOF'
#include "fcobjshash.gperf.h"
EOF
  python3 - <<'PY'
from pathlib import Path
import re, sys
p = Path("src/meson.build")
s = p.read_text(encoding="utf-8")
s = re.sub(
    r"fcobjshash_preprocess_src\s*=\s*configure_file\([\s\S]*?\)\s*"
    r"fcobjshash_h\s*=\s*cc\.preprocess\(fcobjshash_preprocess_src,\s*include_directories:\s*incbase\)\s*",
    "", s, flags=re.S)
s = re.sub(
    r"fcobjshash_preprocess_src\s*=\s*custom_target\([\s\S]*?\)\s*"
    r"fcobjshash_h\s*=\s*cc\.preprocess\(fcobjshash_preprocess_src,\s*include_directories:\s*incbase\)\s*",
    "", s, flags=re.S)
new_line = "fcobjshash_h = cc.preprocess('fcobjshash-preprocess.c', include_directories: incbase)"
s2, n = re.subn(
    r"fcobjshash_h\s*=\s*cc\.preprocess\(\s*(?:files\(\s*)?'fcobjshash\.gperf\.h'(?:\s*\))?\s*,\s*include_directories:\s*incbase\s*\)",
    new_line, s, count=1)
if n == 0:
    if new_line not in s:
        print("ERROR: could not patch fcobjshash preprocess line", file=sys.stderr); sys.exit(1)
    s2 = s
p.write_text(s2, encoding="utf-8")
PY
  grep -Fq "fcobjshash_h = cc.preprocess('fcobjshash-preprocess.c', include_directories: incbase)" src/meson.build || {
    error "Meson preprocessor fix not applied"; return 1
  }
}

build() {
  _detect_toolchain
  _smoke_test || return 1

  local -a meson_options=(
    -Dbitmap-conf=noinstall
    -Ddefault-sub-pixel-rendering=noinstall
    -Ddoc-html=enabled
    -Ddoc-pdf=disabled
    -Ddoc-txt=disabled
  )

  local PGO1_RAW_DIR="$srcdir/profraw-pgo1"
  local PGO1_DATA="$srcdir/pgo1.profdata"
  local CSPGO_RAW_DIR="$srcdir/profraw-cspgo"
  local FINAL_PGO_DATA="$srcdir/pgo-final.profdata"
  local BOLT_DIR="$srcdir/bolt"
  rm -rf "$PGO1_RAW_DIR" "$CSPGO_RAW_DIR" "$BOLT_DIR" \
         "$PGO1_DATA" "$FINAL_PGO_DATA" \
         "$srcdir/build-pgo-gen" "$srcdir/build-cs-pgo-gen" "$srcdir/build"
  mkdir -p "$PGO1_RAW_DIR" "$CSPGO_RAW_DIR" "$BOLT_DIR"

  local can_ir_pgo=1 can_cs_pgo=1
  if ! _toolchain_supports_flag "-fprofile-generate"; then
    warning "Toolchain cannot link -fprofile-generate; building without PGO."
    can_ir_pgo=0; can_cs_pgo=0
  fi
  if (( can_ir_pgo )) && ! _toolchain_supports_flag "-fcs-profile-generate"; then
    warning "Toolchain lacks -fcs-profile-generate; IR-PGO only."
    can_cs_pgo=0
  fi

  # =========================================================================
  # Stage 1: IR-PGO instrument + train
  # =========================================================================
  if (( can_ir_pgo )); then
    local _s1="-fprofile-generate=$PGO1_RAW_DIR ${_pgo_mllvm[*]}"
    local CFLAGS_GEN="$CFLAGS $_s1"
    local CXXFLAGS_GEN="$CXXFLAGS $_s1"
    local LDFLAGS_GEN="$LDFLAGS -fprofile-generate=$PGO1_RAW_DIR"

    printf '  -> [PGO] Stage 1: -fprofile-generate\n'
    arch-meson fontconfig build-pgo-gen --wrap-mode=nofallback "${meson_options[@]}" \
      -Dc_args="$CFLAGS_GEN" -Dcpp_args="$CXXFLAGS_GEN" \
      -Dc_link_args="$LDFLAGS_GEN" -Dcpp_link_args="$LDFLAGS_GEN"
    LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" meson compile -C build-pgo-gen

    if _has_pytest_tap; then
      LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" \
        meson test -C build-pgo-gen --print-errorlogs --no-rebuild \
                   --num-processes "$(nproc)" || {
          printf '  -> [PGO] stage1 meson test reported failures; pytest diagnostic:\n'
          sed -n '/^test:.*pytest/,/^test:/p' build-pgo-gen/meson-logs/testlog.txt \
            | head -n 80 || true
          printf '  -> [PGO] proceeding -- profile collection is unaffected\n'
        }
    else
      warning "python-pytest-tap missing, skipping stage1 meson test workload"
    fi
    _pgo_diag "after stage1 meson test" "$PGO1_RAW_DIR"

    LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" \
      _training_workload "$srcdir/build-pgo-gen"
    _pgo_diag "after stage1 custom workload" "$PGO1_RAW_DIR"

    if compgen -G "$PGO1_RAW_DIR/*.profraw" >/dev/null; then
      llvm-profdata merge -use-md5 -compress-all-sections \
        -o "$PGO1_DATA" "$PGO1_RAW_DIR"/*.profraw
      printf '  -> [PGO] Stage 1 profile: %s (%d profraw)\n' \
        "$PGO1_DATA" "$(_pgo_count "$PGO1_RAW_DIR")"
    else
      warning "No stage1 .profraw produced; falling back to non-PGO build."
      can_ir_pgo=0; can_cs_pgo=0
    fi
  fi

  # =========================================================================
  # Stage 2: CS-PGO instrument (uses stage 1) + train
  # =========================================================================
  if (( can_cs_pgo )); then
    local _s2="-fprofile-use=$PGO1_DATA -fcs-profile-generate=$CSPGO_RAW_DIR ${_pgo_mllvm[*]} ${_profile_silence[*]}"
    local CFLAGS_CS_GEN="$CFLAGS $_s2"
    local CXXFLAGS_CS_GEN="$CXXFLAGS $_s2"
    local LDFLAGS_CS_GEN="$LDFLAGS -fprofile-use=$PGO1_DATA -fcs-profile-generate=$CSPGO_RAW_DIR"

    printf '  -> [PGO] Stage 2: CS-PGO instrument (use stage1)\n'
    arch-meson fontconfig build-cs-pgo-gen --wrap-mode=nofallback "${meson_options[@]}" \
      -Dc_args="$CFLAGS_CS_GEN" -Dcpp_args="$CXXFLAGS_CS_GEN" \
      -Dc_link_args="$LDFLAGS_CS_GEN" -Dcpp_link_args="$LDFLAGS_CS_GEN"
    LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" meson compile -C build-cs-pgo-gen

    if _has_pytest_tap; then
      LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" \
        meson test -C build-cs-pgo-gen --print-errorlogs --no-rebuild \
                   --num-processes "$(nproc)" || {
          printf '  -> [PGO] CS-stage meson test reported failures; pytest diagnostic:\n'
          sed -n '/^test:.*pytest/,/^test:/p' build-cs-pgo-gen/meson-logs/testlog.txt \
            | head -n 80 || true
          printf '  -> [PGO] proceeding -- profile collection is unaffected\n'
        }
    fi
    LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" \
      _training_workload "$srcdir/build-cs-pgo-gen"
    _pgo_diag "after CS-PGO workload" "$CSPGO_RAW_DIR"

    if compgen -G "$CSPGO_RAW_DIR/*.profraw" >/dev/null; then
      # MERGE ORDER per LLVM CSPGO docs: stage1 FIRST.
      llvm-profdata merge -use-md5 -compress-all-sections \
        -o "$FINAL_PGO_DATA" "$PGO1_DATA" "$CSPGO_RAW_DIR"/*.profraw
      printf '  -> [PGO] Final merged CS profile: %s\n' "$FINAL_PGO_DATA"
    else
      warning "No CS-PGO .profraw produced; using stage1 profile only."
      cp -f "$PGO1_DATA" "$FINAL_PGO_DATA"
    fi
  elif (( can_ir_pgo )) && [[ -f "$PGO1_DATA" ]]; then
    cp -f "$PGO1_DATA" "$FINAL_PGO_DATA"
  fi

  # =========================================================================
  # Stage 3: final PGO-use build with BOLT-friendly link (--emit-relocs)
  # =========================================================================
  local CFLAGS_USE="$CFLAGS" CXXFLAGS_USE="$CXXFLAGS" LDFLAGS_USE="$LDFLAGS"
  if [[ -f "$FINAL_PGO_DATA" ]]; then
    CFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA ${_profile_silence[*]}"
    CXXFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA ${_profile_silence[*]}"
    LDFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA"
    printf '  -> [PGO] Stage 3 uses profile: %s\n' "$FINAL_PGO_DATA"
  else
    warning "[PGO] Stage 3 has no profile-use."
  fi
  LDFLAGS_USE+=" -Wl,--emit-relocs"

  arch-meson fontconfig build --wrap-mode=nofallback "${meson_options[@]}" \
    -Dc_args="$CFLAGS_USE" -Dcpp_args="$CXXFLAGS_USE" \
    -Dc_link_args="$LDFLAGS_USE" -Dcpp_link_args="$LDFLAGS_USE"
  meson compile -C build

  # =========================================================================
  # Stage 4: BOLT instrument + train + optimise libfontconfig.so
  # =========================================================================
  command -v llvm-bolt >/dev/null 2>&1 || {
    printf '  -> [BOLT] llvm-bolt missing; final binary is PGO-only\n'
    return 0
  }

  local _lib
  _lib="$(find "$srcdir/build" -maxdepth 2 -type f -name 'libfontconfig.so.*' \
          ! -name '*.symbols' | sort -V -r | head -1)"
  if [[ -z "$_lib" ]]; then
    warning "[BOLT] libfontconfig.so not found; skipping"
    return 0
  fi
  printf '  -> [BOLT] target: %s\n' "$_lib"
  cp -f "$_lib" "$BOLT_DIR/libfontconfig.so.orig"

  printf '  -> [BOLT] Stage 4a: instrument (--lite=false + sleep-time=3)\n'
  # --instrumentation-sleep-time=3 + --instrumentation-no-counters-clear:
  # forked watcher dumps .fdata periodically + on parent death. Removes
  # the DT_FINI-only race that bit the xwayland PKGBUILD.
  if ! llvm-bolt "$BOLT_DIR/libfontconfig.so.orig" \
        --instrument \
        --lite=false \
        --instrumentation-file="$BOLT_DIR/fc.fdata" \
        --instrumentation-file-append-pid \
        --instrumentation-sleep-time=3 \
        --instrumentation-no-counters-clear \
        -o "$BOLT_DIR/libfontconfig.so.inst"; then
    warning "[BOLT] instrumentation failed; keeping PGO-only binary"
    return 0
  fi
  install -m755 "$BOLT_DIR/libfontconfig.so.inst" "$_lib"

  printf '  -> [BOLT] Stage 4b: training workload\n'
  _training_workload "$srcdir/build"
  # 30s grace for the watcher to flush; poll early-exit on first .fdata.
  local _flush
  local -a _peek=()
  for _flush in $(seq 1 300); do
    shopt -s nullglob
    _peek=("$BOLT_DIR"/fc.fdata*.fdata)
    shopt -u nullglob
    (( ${#_peek[@]} > 0 )) && break
    sleep 0.1
  done
  printf '  -> [BOLT] .fdata after %d*0.1s grace: %d\n' "$_flush" "${#_peek[@]}"

  # Restore the un-instrumented PGO binary in the build tree so `package`
  # installs the BOLTed version below (not the instrumented one).
  install -m755 "$BOLT_DIR/libfontconfig.so.orig" "$_lib"

  if (( ${#_peek[@]} == 0 )); then
    warning "[BOLT] no .fdata produced; keeping PGO-only binary"
    return 0
  fi

  printf '  -> [BOLT] Stage 4c: merge .fdata (%d files)\n' "${#_peek[@]}"
  if (( ${#_peek[@]} == 1 )); then
    cp -f "${_peek[0]}" "$BOLT_DIR/merged.fdata"
  elif command -v merge-fdata >/dev/null 2>&1; then
    merge-fdata "${_peek[@]}" -o "$BOLT_DIR/merged.fdata" || \
      cat "${_peek[@]}" > "$BOLT_DIR/merged.fdata"
  else
    cat "${_peek[@]}" > "$BOLT_DIR/merged.fdata"
  fi
  [[ -s "$BOLT_DIR/merged.fdata" ]] || {
    warning "[BOLT] merged .fdata empty; keeping PGO-only binary"; return 0
  }

  printf '  -> [BOLT] Stage 4d: optimise (--lite=false, BOLT-23git flag set)\n'
  # Excluded as crash-prone on shared libs in BOLT-23git:
  #   --use-aggr-reg-reassign (#123809), --icf=all (#123835 with cdsplit),
  #   --frame-opt=* (#123835), --hugify (refuses on shared libs).
  if llvm-bolt "$BOLT_DIR/libfontconfig.so.orig" \
        --data="$BOLT_DIR/merged.fdata" \
        --lite=false \
        --relocs \
        --reorder-blocks=ext-tsp \
        --reorder-functions=cdsort \
        --split-functions --split-strategy=cdsplit --split-all-cold --split-eh \
        --icf=safe \
        --jump-tables=aggressive \
        --indirect-call-promotion=all --icp-eliminate-loads \
        --reg-reassign --x86-strip-redundant-address-size \
        --peepholes=all \
        --simplify-conditional-tail-calls --simplify-rodata-loads \
        --eliminate-unreachable \
        --inline-small-functions --inline-small-functions-bytes=4 \
        --inline-memcpy \
        --plt=all --hot-data \
        --tail-duplication=cache --equalize-bb-counts \
        --infer-stale-profile=1 --match-profile-with-function-hash \
        --cu-processing-batch-size=64 \
        --dyno-stats \
        -o "$BOLT_DIR/libfontconfig.so.bolt"; then
    install -m755 "$BOLT_DIR/libfontconfig.so.bolt" "$_lib"
    printf '  -> [BOLT] libfontconfig optimised + installed in build tree\n'
  else
    warning "[BOLT] optimise failed; keeping PGO-only binary"
  fi
}

check() {
  # Run the C-binary tests strictly (they're deterministic and must pass).
  # Run the pytest aggregate separately and tolerate environment-specific
  # failures (sandbox/bwrap quirks, CachyOS-vs-Arch python differences,
  # /tmp interactions) -- they DO drive useful coverage during the PGO
  # stages but cannot be a hard gate in check() because the failure modes
  # are reproducible only on the user's exact environment.
  local -a _c_tests=(
    test_bz89617 test_bz131804 test_bz96676 test_name_parse
    test_bz106618 test_bz1744377 test_issue180 test_family_matching
    test_ptrlist test_ostest test_bz106632 test_issue107
    test_crbug1004254 test_mt_fccfg test_const_name check-missing-doc.py
  )
  printf '  -> [CHECK] Running %d C-binary tests (strict)\n' "${#_c_tests[@]}"
  meson test -C build --print-errorlogs --no-rebuild "${_c_tests[@]}"

  if _has_pytest_tap; then
    printf '  -> [CHECK] Running pytest aggregate (tolerant of env quirks)\n'
    if meson test -C build --print-errorlogs --no-rebuild pytest; then
      printf '  -> [CHECK] pytest OK\n'
    else
      # Dump the full TAP / diagnostic output so the user sees WHY -- the
      # previous version swallowed it and showed only a useless meson summary.
      printf '  -> [CHECK] pytest failed; full log follows:\n'
      sed -n '/^test:.*pytest/,/^test:/p' build/meson-logs/testlog.txt \
        | head -n 200 || true
      printf '  -> [CHECK] pytest failures NON-FATAL (PGO+BOLT profile is unaffected)\n'
    fi
  else
    warning "[CHECK] pytest --tap unavailable; install python-pytest-tap to run upstream's Python test suite"
  fi
}

package() {
  depends+=(libexpat.so libfreetype.so)
  provides+=(libfontconfig.so)
  meson install -C build --destdir "$pkgdir"
  mkdir -p "$pkgdir/usr/share/fontconfig/conf.default"
  local _f
  for _f in "$pkgdir"/etc/fonts/conf.d/*.conf; do
    [[ -e "$_f" ]] || continue
    ln -sr "$pkgdir"/usr/share/fontconfig/conf.{avail,default}/"${_f##*/}"
    rm "$_f"
  done
  install -Dm644 ./*.hook -t "$pkgdir/usr/share/libalpm/hooks"
  install -D 40-fontconfig-config.script \
    "$pkgdir/usr/share/libalpm/scripts/40-fontconfig-config"
  install -Dm644 fontconfig/COPYING -t "$pkgdir/usr/share/licenses/$pkgname"
}
