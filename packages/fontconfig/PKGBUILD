_has_pytest_tap() {
  pytest --help 2>/dev/null | grep -q -- '--tap'
}

_detect_toolchain() {
  # Respect user-selected toolchain via CC/CXX/PATH.
  : "${CC:=clang}"
  : "${CXX:=clang++}"
  : "${AR:=llvm-ar}"
  : "${NM:=llvm-nm}"
  : "${RANLIB:=llvm-ranlib}"

  command -v "$CC" >/dev/null || { error "CC not found: $CC"; return 1; }
  command -v "$CXX" >/dev/null || { error "CXX not found: $CXX"; return 1; }
  command -v "$AR" >/dev/null || { error "AR not found: $AR"; return 1; }
  command -v "$NM" >/dev/null || { error "NM not found: $NM"; return 1; }
  command -v "$RANLIB" >/dev/null || { error "RANLIB not found: $RANLIB"; return 1; }

  local _triple
  _triple="$("$CC" -print-target-triple 2>/dev/null || true)"
  [[ "$_triple" == *linux* ]] || {
    error "Active compiler target is not Linux: ${_triple:-unknown}"
    return 1
  }

  msg2 "Using toolchain:"
  msg2 "  CC=$(command -v "$CC")"
  msg2 "  CXX=$(command -v "$CXX")"
}

_toolchain_supports_pgo_generate() {
  local _tdir="$srcdir/.pgo-sanity"
  rm -rf "$_tdir"
  mkdir -p "$_tdir"

  cat >"$_tdir/sanity.c" <<'EOF'
int main(void) { return 0; }
EOF

  "$CC" ${CFLAGS} "$_tdir/sanity.c" -o "$_tdir/sanity" \
    ${LDFLAGS} -fprofile-generate >/dev/null 2>&1
}

# Comprehensive training workload to drive PGO without modifying host config.
_training_workload() {
  local _builddir="$1"
  (
    set -euo pipefail

    local _sysroot="${_builddir}/fc-sysroot"
    local _cachedir="${_sysroot}/var/cache/fontconfig"
    mkdir -p "${_cachedir}" "${_sysroot}/etc/fonts"

    if [[ -f /etc/fonts/fonts.conf ]]; then
      install -m644 /etc/fonts/fonts.conf "${_sysroot}/etc/fonts/"
    fi

    local d
    for d in conf.d conf.avail; do
      [[ -d "/etc/fonts/${d}" ]] && cp -a "/etc/fonts/${d}" "${_sysroot}/etc/fonts/" || true
    done

    export FONTCONFIG_SYSROOT="${_sysroot}"
    export FONTCONFIG_CACHEDIR="${_cachedir}"
    export XDG_CACHE_HOME="${_sysroot}/.cache"
    export HOME="${_sysroot}"

    _fc() { find "${_builddir}" -type f -executable -name "$1" -print -quit; }

    local FC_CACHE FC_LIST FC_MATCH FC_SCAN FC_QUERY FC_PATTERN
    FC_CACHE="$(_fc fc-cache || true)"
    FC_LIST="$(_fc fc-list || true)"
    FC_MATCH="$(_fc fc-match || true)"
    FC_SCAN="$(_fc fc-scan || true)"
    FC_QUERY="$(_fc fc-query || true)"
    FC_PATTERN="$(_fc fc-pattern || true)"

    [[ -z "${FC_CACHE}" || -z "${FC_LIST}" || -z "${FC_MATCH}" ]] && exit 0

    local -a font_dirs=()
    for d in \
      /usr/share/fonts/TTF \
      /usr/share/fonts/OTF \
      /usr/share/fonts/Type1 \
      /usr/share/fonts/truetype \
      /usr/share/fonts/opentype \
      /usr/share/fonts/cantarell \
      /usr/share/fonts/liberation \
      /usr/share/fonts/noto \
      /usr/share/fonts/adobe-source-code-pro \
      /usr/share/fonts/gsfonts
    do
      [[ -d "$d" ]] && font_dirs+=("$d")
    done

    (( ${#font_dirs[@]} > 0 )) && "${FC_CACHE}" -fsv "${font_dirs[@]}" || true

    local -a common_fonts=(
      "sans-serif" "serif" "monospace"
      "Arial" "Times New Roman" "Courier New"
      "DejaVu Sans" "Liberation Mono" "Noto Sans"
      "Cantarell" "FreeSans" "FreeMono"
    )

    local font size
    for font in "${common_fonts[@]}"; do
      "${FC_MATCH}" "$font" >/dev/null 2>&1 || true
      "${FC_MATCH}" "$font:bold" >/dev/null 2>&1 || true
      "${FC_MATCH}" "$font:italic" >/dev/null 2>&1 || true
      "${FC_MATCH}" "$font:weight=200" >/dev/null 2>&1 || true
    done

    "${FC_LIST}" : family style | head -n 2000 >/dev/null 2>&1 || true
    "${FC_LIST}" : lang | sort -u >/dev/null 2>&1 || true

    if [[ -n "${FC_PATTERN}" ]]; then
      for size in 8 9 10 11 12 14 16 18 20 24 32 48; do
        "${FC_PATTERN}" "Sans-${size}" >/dev/null 2>&1 || true
        "${FC_PATTERN}" "Serif-${size}:weight=bold" >/dev/null 2>&1 || true
      done
    fi

    if [[ -n "${FC_SCAN}" && ${#font_dirs[@]} -gt 0 ]]; then
      mapfile -t _scan_fonts < <(
        find "${font_dirs[@]}" -type f \( -name '*.ttf' -o -name '*.otf' \) 2>/dev/null | head -n 20
      )
      (( ${#_scan_fonts[@]} > 0 )) && "${FC_SCAN}" "${_scan_fonts[@]}" >/dev/null 2>&1 || true
    fi

    if [[ -n "${FC_QUERY}" && ${#font_dirs[@]} -gt 0 ]]; then
      mapfile -t _query_fonts < <(
        find "${font_dirs[@]}" -type f \( -name '*.ttf' -o -name '*.otf' \) 2>/dev/null | head -n 20
      )
      (( ${#_query_fonts[@]} > 0 )) && "${FC_QUERY}" "${_query_fonts[@]}" >/dev/null 2>&1 || true
    fi
  ) || true
}

prepare() {
  cd fontconfig

  # Avoid Meson WrapDB v1 deprecation warnings by enforcing system deps only.
  rm -f subprojects/*.wrap
  rm -rf subprojects/packagecache

  # Meson >= 1.11 warns about an empty preprocessor target in this code path.
  # Force an explicit file object to keep preprocessor target well-defined.
  sed -i "s|cc.preprocess('fcobjshash.gperf.h', include_directories: incbase)|cc.preprocess(files('fcobjshash.gperf.h'), include_directories: incbase)|" \
    src/meson.build
}

build() {
  _detect_toolchain

  local -a meson_options=(
    -Dbitmap-conf=noinstall
    -Ddefault-sub-pixel-rendering=noinstall
    -Ddoc-html=enabled
    -Ddoc-pdf=disabled
    -Ddoc-txt=disabled
  )

  local PGO_RAW_DIR="$srcdir/profraw"
  local PGO_DATA="$srcdir/pgo.profdata"
  local use_pgo=1

  rm -rf "$PGO_RAW_DIR" "$PGO_DATA"
  mkdir -p "$PGO_RAW_DIR"

  if ! _toolchain_supports_pgo_generate; then
    warning "Active toolchain cannot link with -fprofile-generate; falling back to non-PGO build."
    warning "Compiler: $("$CC" --version | head -n1)"
    use_pgo=0
  fi

  if (( use_pgo )); then
    local CFLAGS_GEN="$CFLAGS -fprofile-generate"
    local CXXFLAGS_GEN="$CXXFLAGS -fprofile-generate"
    local LDFLAGS_GEN="$LDFLAGS -fprofile-generate"

    arch-meson fontconfig build-pgo-gen --wrap-mode=nofallback "${meson_options[@]}" \
      -Dc_args="$CFLAGS_GEN" \
      -Dcpp_args="$CXXFLAGS_GEN" \
      -Dc_link_args="$LDFLAGS_GEN" \
      -Dcpp_link_args="$LDFLAGS_GEN"

    LLVM_PROFILE_FILE="$PGO_RAW_DIR/%p-%m.profraw" meson compile -C build-pgo-gen

    if _has_pytest_tap; then
      LLVM_PROFILE_FILE="$PGO_RAW_DIR/%p-%m.profraw" \
        meson test -C build-pgo-gen --print-errorlogs --no-rebuild --num-processes "$(nproc)" || true
    else
      warning "python-pytest-tap missing, skipping stage1 meson test workload"
    fi

    LLVM_PROFILE_FILE="$PGO_RAW_DIR/%p-%m.profraw" _training_workload "$srcdir/build-pgo-gen"

    if compgen -G "$PGO_RAW_DIR/*.profraw" >/dev/null; then
      llvm-profdata merge -use-md5 -compress-all-sections -o "$PGO_DATA" "$PGO_RAW_DIR"/*.profraw
    else
      warning "No profile data produced, continuing without -fprofile-use"
      use_pgo=0
    fi
  fi

  local CFLAGS_USE="$CFLAGS"
  local CXXFLAGS_USE="$CXXFLAGS"
  local LDFLAGS_USE="$LDFLAGS"

  if (( use_pgo )) && [[ -f "$PGO_DATA" ]]; then
    CFLAGS_USE+=" -fprofile-use=$PGO_DATA"
    CXXFLAGS_USE+=" -fprofile-use=$PGO_DATA"
    LDFLAGS_USE+=" -fprofile-use=$PGO_DATA"
  fi

  arch-meson fontconfig build --wrap-mode=nofallback "${meson_options[@]}" \
    -Dc_args="$CFLAGS_USE" \
    -Dcpp_args="$CXXFLAGS_USE" \
    -Dc_link_args="$LDFLAGS_USE" \
    -Dcpp_link_args="$LDFLAGS_USE"

  meson compile -C build
}

check() {
  _has_pytest_tap || {
    error "pytest --tap support missing. Install checkdepends: python-pytest-tap"
    return 1
  }
  meson test -C build --print-errorlogs
}

package() {
  depends+=(
    libexpat.so
    libfreetype.so
  )
  provides+=(libfontconfig.so)

  meson install -C build --destdir "$pkgdir"

  # Keep user-selected conf.d symlinks managed by hook, avoid config drift.
  mkdir -p "$pkgdir/usr/share/fontconfig/conf.default"
  local _f
  for _f in "$pkgdir"/etc/fonts/conf.d/*.conf; do
    [[ -e "$_f" ]] || continue
    ln -sr "$pkgdir"/usr/share/fontconfig/conf.{avail,default}/"${_f##*/}"
    rm "$_f"
  done

  install -Dm644 ./*.hook -t "$pkgdir/usr/share/libalpm/hooks"
  install -D 40-fontconfig-config.script \
    "$pkgdir/usr/share/libalpm/scripts/40-fontconfig-config"
  install -Dm644 fontconfig/COPYING -t "$pkgdir/usr/share/licenses/$pkgname"
}
