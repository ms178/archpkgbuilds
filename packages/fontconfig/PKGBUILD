# Per-stage instrumentation flags. Important details:
#   * keep instrumentation/final frame-pointer policy identical to makepkg CFLAGS
#   * runtime-counter-relocation is required for reliable shared-library PGO
#   * value profiling matters for fontconfig's matcher/object/cache dispatch sites
_pgo_mllvm=(
  -mllvm -vp-counters-per-site=12
  -mllvm -runtime-counter-relocation
  -mllvm -enable-value-profiling
)
_profile_silence=(
  -Wno-profile-instr-unprofiled
  -Wno-profile-instr-out-of-date
)

_has_pytest_tap() {
  pytest --help 2>/dev/null | grep -q -- '--tap'
}

_pgo_count() {
  find "$1" -maxdepth 1 -type f -name '*.profraw' 2>/dev/null | wc -l
}

_pgo_bytes() {
  find "$1" -maxdepth 1 -type f -name '*.profraw' -printf '%s\n' 2>/dev/null | awk '{s+=$1} END{print s+0}'
}

_pgo_diag() {
  printf '  -> [PGO] %s: profraw=%s bytes=%s dir=%s\n' \
    "$1" "$(_pgo_count "$2")" "$(_pgo_bytes "$2")" "$2"
}

_jobs() {
  nproc
}

_detect_toolchain() {
  : "${CC:=clang}"
  : "${CXX:=clang++}"
  : "${AR:=llvm-ar}"
  : "${NM:=llvm-nm}"
  : "${RANLIB:=llvm-ranlib}"
  export CC CXX AR NM RANLIB

  command -v "$CC" >/dev/null || { error "CC not found: $CC"; return 1; }
  command -v "$CXX" >/dev/null || { error "CXX not found: $CXX"; return 1; }
  command -v "$AR" >/dev/null || { error "AR not found: $AR"; return 1; }
  command -v "$NM" >/dev/null || { error "NM not found: $NM"; return 1; }
  command -v "$RANLIB" >/dev/null || { error "RANLIB not found: $RANLIB"; return 1; }

  local _triple
  _triple="$($CC -print-target-triple 2>/dev/null || $CC -dumpmachine 2>/dev/null || true)"
  [[ "$_triple" == *linux* ]] || { error "Compiler target is not Linux: $_triple"; return 1; }

  command -v llvm-profdata >/dev/null || { error "llvm-profdata not found"; return 1; }

  printf '  -> [TOOLCHAIN] CC=%s CXX=%s target=%s\n' \
    "$(command -v "$CC")" "$(command -v "$CXX")" "$_triple"
}

_toolchain_supports_flags() {
  local _tdir
  _tdir="$(mktemp -d "$srcdir/.toolchain-sanity.XXXXXX")"
  printf 'int main(void){return 0;}\n' > "$_tdir/x.c"

  "$CC" $CFLAGS "$_tdir/x.c" -o "$_tdir/x" $LDFLAGS "$@" >/dev/null 2>&1
  local _rc=$?
  rm -rf "$_tdir"
  return "$_rc"
}

# Refuse to start an expensive profile chain if the installed system library is
# already unusable. This catches broken toolchain/runtime combinations early.
_smoke_test() {
  command -v pkg-config >/dev/null || return 0
  pkg-config --exists fontconfig 2>/dev/null || return 0

  local _t
  _t="$(mktemp -d "$srcdir/.smoke.XXXXXX")"
  cat > "$_t/smoke.c" <<'SMOKE_EOF'
#include <fontconfig/fontconfig.h>

int main(void) {
  if (!FcInit()) return 1;
  FcConfig *c = FcConfigGetCurrent();
  if (!c) return 2;

  FcPattern *p = FcPatternBuild(NULL,
                                FC_FAMILY, FcTypeString, "sans-serif",
                                FC_WEIGHT, FcTypeInteger, FC_WEIGHT_BOLD,
                                FC_SIZE, FcTypeDouble, 12.0,
                                NULL);
  if (!p) return 3;

  FcConfigSubstitute(c, p, FcMatchPattern);
  FcDefaultSubstitute(p);

  FcResult r;
  FcPattern *m = FcFontMatch(c, p, &r);
  if (m) FcPatternDestroy(m);

  FcPattern *list_pat = FcPatternCreate();
  FcObjectSet *os = FcObjectSetBuild(FC_FAMILY, FC_FILE, NULL);
  FcFontSet *fs = (list_pat && os) ? FcFontList(c, list_pat, os) : NULL;
  if (fs) FcFontSetDestroy(fs);
  if (os) FcObjectSetDestroy(os);
  if (list_pat) FcPatternDestroy(list_pat);

  FcPatternDestroy(p);
  FcFini();
  return 0;
}
SMOKE_EOF

  if "$CC" $CFLAGS $(pkg-config --cflags fontconfig) "$_t/smoke.c" \
       -o "$_t/smoke" $LDFLAGS $(pkg-config --libs fontconfig) >/dev/null 2>&1; then
    if ! timeout -k 2 10 "$_t/smoke"; then
      error "fontconfig smoke test failed; refusing to start PGO chain"
      rm -rf "$_t"
      return 1
    fi
    printf '  -> [SMOKE] system libfontconfig OK\n'
  fi

  rm -rf "$_t"
}

_training_tests() {
  local _builddir="$1"
  local _label="$2"

  printf '  -> [PGO] %s deterministic test workload\n' "$_label"
  meson test -C "$_builddir" --print-errorlogs --no-rebuild \
    --num-processes "$(_jobs)" "${_fc_deterministic_tests[@]}"

  if _has_pytest_tap; then
    printf '  -> [PGO] %s pytest workload\n' "$_label"
    meson test -C "$_builddir" --print-errorlogs --no-rebuild \
      --num-processes "$(_jobs)" pytest || {
        printf '  -> [PGO] %s pytest failed; first diagnostics follow:\n' "$_label"
        sed -n '/^test:.*pytest/,/^test:/p' "$_builddir/meson-logs/testlog.txt" | head -n 160 || true
        error "[PGO] $_label pytest failed; aborting rather than training on a broken build"
        return 1
      }
  else
    error "python-pytest-tap is required because pytest is part of the PGO training workload"
    return 1
  fi
}

# Drive the installed build-tree tools over realistic cache, match, list, scan,
# query, pattern, conf-list, validate, and cat paths. The sysroot isolates cache
# writes while preserving the host's actual font corpus as read-only input.
_training_workload() {
  local _builddir="$1"

  (
    set -eo pipefail

    local _workroot _sysroot _cachedir _etc_fonts
    _workroot="$(mktemp -d "${_builddir}/fc-train.XXXXXX")"
    trap 'rm -rf "$_workroot"' EXIT

    _sysroot="${_workroot}/sysroot"
    _cachedir="${_sysroot}/var/cache/fontconfig"
    _etc_fonts="${_sysroot}/etc/fonts"
    mkdir -p "$_cachedir" "$_etc_fonts" "${_workroot}/xdg-cache" "${_workroot}/home"

    [[ -d /etc/fonts ]] && cp -a /etc/fonts/. "$_etc_fonts/"

    local -a _font_dirs=()
    local _d
    # Bind only top-level font roots.  Binding both /usr/share/fonts and its
    # children would make later symlinks resolve through the first symlink and
    # attempt writes into the real host tree.
    for _d in /usr/share/fonts /usr/local/share/fonts; do
      [[ -d "$_d" ]] && _font_dirs+=("$_d")
    done

    for _d in "${_font_dirs[@]}"; do
      mkdir -p "${_sysroot}$(dirname "$_d")"
      ln -sfn "$_d" "${_sysroot}${_d}"
    done

    export FONTCONFIG_SYSROOT="$_sysroot"
    export FONTCONFIG_CACHEDIR="$_cachedir"
    export XDG_CACHE_HOME="${_workroot}/xdg-cache"
    export HOME="${_workroot}/home"
    if [[ -f "${_etc_fonts}/fonts.conf" ]]; then
      export FONTCONFIG_FILE="${_etc_fonts}/fonts.conf"
      export FONTCONFIG_PATH="${_etc_fonts}"
    fi

    _fc() { find "$_builddir" -type f -executable -name "$1" -print -quit; }

    local FC_CACHE FC_LIST FC_MATCH FC_SCAN FC_QUERY FC_PATTERN FC_CONFLIST FC_VALIDATE FC_CAT
    FC_CACHE="$(_fc fc-cache || true)"
    FC_LIST="$(_fc fc-list || true)"
    FC_MATCH="$(_fc fc-match || true)"
    FC_SCAN="$(_fc fc-scan || true)"
    FC_QUERY="$(_fc fc-query || true)"
    FC_PATTERN="$(_fc fc-pattern || true)"
    FC_CONFLIST="$(_fc fc-conflist || true)"
    FC_VALIDATE="$(_fc fc-validate || true)"
    FC_CAT="$(_fc fc-cat || true)"

    [[ -z "$FC_CACHE" || -z "$FC_LIST" || -z "$FC_MATCH" ]] && {
      printf '  -> [PGO] required fc-tools missing; skipping custom workload\n'
      exit 0
    }

    find "$_cachedir" -type f -name '*.cache-*' -delete 2>/dev/null || true
    rm -f "$_cachedir"/CACHEDIR.TAG 2>/dev/null || true

    (( ${#_font_dirs[@]} > 0 )) && "$FC_CACHE" -sv "${_font_dirs[@]}" >/dev/null 2>&1 || true

    local _font _spec _size
    local -a _common_fonts=(
      "sans-serif" "serif" "monospace"
      "Arial" "Times New Roman" "Courier New"
      "DejaVu Sans" "DejaVu Serif" "DejaVu Sans Mono"
      "Liberation Sans" "Liberation Serif" "Liberation Mono"
      "Noto Sans" "Noto Serif" "Noto Sans CJK SC" "Noto Sans Arabic" "Noto Sans Hebrew"
      "Cantarell" "FreeSans" "FreeMono" "Source Code Pro"
    )

    for _font in "${_common_fonts[@]}"; do
      for _spec in "$_font" "$_font:bold" "$_font:italic" "$_font:weight=200" \
                   "$_font:lang=en" "$_font:lang=ja" "$_font:lang=zh-cn" \
                   "$_font:lang=ar" "$_font:lang=he" "$_font:pixelsize=12"; do
        "$FC_MATCH" "$_spec" >/dev/null 2>&1 || true
      done
    done

    "$FC_LIST" : family style file | head -n 5000 >/dev/null 2>&1 || true
    "$FC_LIST" : family lang spacing outline scalable | head -n 5000 >/dev/null 2>&1 || true
    "$FC_LIST" : lang | sort -u >/dev/null 2>&1 || true

    if [[ -n "$FC_PATTERN" ]]; then
      for _size in 8 9 10 11 12 14 16 18 20 24 32 48 64 72; do
        "$FC_PATTERN" "Sans-${_size}" >/dev/null 2>&1 || true
        "$FC_PATTERN" "Serif-${_size}:weight=bold" >/dev/null 2>&1 || true
        "$FC_PATTERN" "Monospace-${_size}:slant=italic" >/dev/null 2>&1 || true
      done
    fi

    local -a _sample_fonts=()
    if (( ${#_font_dirs[@]} > 0 )); then
      mapfile -t _sample_fonts < <(
        find "${_font_dirs[@]}" -type f \( -iname '*.ttf' -o -iname '*.otf' -o -iname '*.ttc' -o -iname '*.pcf' \) 2>/dev/null | head -n 160
      )
    fi

    # fc-scan/fc-query/fc-validate take actual files; do not sysroot-prefix them.
    local _saved_sysroot="${FONTCONFIG_SYSROOT:-}"
    unset FONTCONFIG_SYSROOT
    if (( ${#_sample_fonts[@]} > 0 )); then
      [[ -n "$FC_SCAN" ]] && "$FC_SCAN" "${_sample_fonts[@]}" >/dev/null 2>&1 || true
      [[ -n "$FC_QUERY" ]] && "$FC_QUERY" "${_sample_fonts[@]}" >/dev/null 2>&1 || true
      [[ -n "$FC_VALIDATE" ]] && "$FC_VALIDATE" "${_sample_fonts[@]}" >/dev/null 2>&1 || true
    fi
    export FONTCONFIG_SYSROOT="$_saved_sysroot"

    [[ -n "$FC_CONFLIST" ]] && "$FC_CONFLIST" >/dev/null 2>&1 || true
    if [[ -n "$FC_CAT" ]]; then
      find "$_cachedir" -type f -name '*.cache-*' 2>/dev/null | head -n 32 | \
        xargs -r "$FC_CAT" >/dev/null 2>&1 || true
    fi

    printf '  -> [PGO] custom workload: done (font-dirs=%d, sampled-fonts=%d)\n' \
      "${#_font_dirs[@]}" "${#_sample_fonts[@]}"
  ) || true
}

_bolt_try_optimize() {
  local _input="$1"
  local _data="$2"
  local _output="$3"
  shift 3

  llvm-bolt "$_input" \
    --data="$_data" \
    --lite=false \
    --relocs \
    "$@" \
    -o "$_output"
}

prepare() {
  cd fontconfig

  rm -f subprojects/*.wrap
  rm -rf subprojects/packagecache

  # Root cause of the user's prepare() failure:
  # the old PKGBUILD searched for the pre-2.18.2 bwrap block in
  # test/fctest/__init__.py.  In 2.18.2 upstream has already changed that block
  # and already re-binds self._builddir after '--tmpfs /tmp', so the stale
  # exact-string patch quite correctly reports "BUG B site not found".  Do not
  # apply that obsolete patch.  Also, SOURCE_DATE_EPOCH is already int-coerced
  # upstream and the mtime-sensitive tests explicitly drop it where required.
  python3 - <<'PY'
from pathlib import Path
import sys
s = Path('test/fctest/__init__.py').read_text(encoding='utf-8')
if 'time = int(time)' not in s:
    print('ERROR: fctest SOURCE_DATE_EPOCH int conversion is missing', file=sys.stderr)
    sys.exit(1)
if "--tmpfs" in s and "self._builddir" not in s:
    print('ERROR: fctest bwrap builddir re-bind is missing', file=sys.stderr)
    sys.exit(1)
PY

  # Meson >= 1.11 warns that cc.preprocess() without a real source file was
  # never meant to be allowed and will become fatal.  Feed it a tiny C wrapper
  # instead of the raw header, preserving the generated content exactly.
  cat > src/fcobjshash-preprocess.c <<'EOF'
#include "fcobjshash.gperf.h"
EOF

  python3 - <<'PY'
from pathlib import Path
import re
import sys

p = Path('src/meson.build')
s = p.read_text(encoding='utf-8')
new_line = "fcobjshash_h = cc.preprocess('fcobjshash-preprocess.c', include_directories: incbase)"

if new_line not in s:
    patterns = [
        r"fcobjshash_h\s*=\s*cc\.preprocess\(\s*(?:files\(\s*)?'fcobjshash\.gperf\.h'(?:\s*\))?\s*,\s*include_directories\s*:\s*incbase\s*\)",
        r"fcobjshash_h\s*=\s*cc\.preprocess\([^\n]*fcobjshash\.gperf\.h[^\n]*\)",
    ]
    for pat in patterns:
        s2, n = re.subn(pat, new_line, s, count=1, flags=re.S)
        if n:
            s = s2
            break
    else:
        print('ERROR: could not patch fcobjshash preprocess line', file=sys.stderr)
        sys.exit(1)

p.write_text(s, encoding='utf-8')
PY

  grep -Fq "fcobjshash_h = cc.preprocess('fcobjshash-preprocess.c', include_directories: incbase)" src/meson.build || {
    error 'Meson preprocessor compatibility fix was not applied'
    return 1
  }
}

build() {
  _detect_toolchain
  _smoke_test || return 1

  local -a meson_options=(
    -Dbitmap-conf=noinstall
    -Ddefault-sub-pixel-rendering=noinstall
    -Ddoc-html=enabled
    -Ddoc-pdf=disabled
    -Ddoc-txt=disabled
    -Dtests=enabled
    -Dtests-bwrap=enabled
    # Arch/CachyOS package builds must be offline and reproducible.  In
    # fontconfig 2.18.x, leaving this at upstream's default "enabled" makes the
    # pytest collector instantiate FcExternalTestFont(); if fetch-testfonts.py
    # did not download anything, collection aborts before any tests run.  With
    # pytest-tap streaming that real collection exception is hidden behind
    # Meson's misleading "Too few tests run (expected 37, got 0)" TAP error.
    -Dtests-external-fonts=disabled
  )

  local PGO1_RAW_DIR="$srcdir/profraw-pgo1"
  local PGO1_DATA="$srcdir/pgo1.profdata"
  local CSPGO_RAW_DIR="$srcdir/profraw-cspgo"
  local FINAL_PGO_DATA="$srcdir/pgo-final.profdata"
  local BOLT_DIR="$srcdir/bolt"

  rm -rf "$PGO1_RAW_DIR" "$CSPGO_RAW_DIR" "$BOLT_DIR" \
         "$PGO1_DATA" "$FINAL_PGO_DATA" \
         "$srcdir/build-pgo-gen" "$srcdir/build-cs-pgo-gen" "$srcdir/build"
  mkdir -p "$PGO1_RAW_DIR" "$CSPGO_RAW_DIR" "$BOLT_DIR"

  local can_ir_pgo=1
  local can_cs_pgo=1

  if ! _toolchain_supports_flags -fprofile-generate="$PGO1_RAW_DIR" "${_pgo_mllvm[@]}"; then
    warning 'Toolchain cannot link Clang IR-PGO instrumentation; building without PGO.'
    can_ir_pgo=0
    can_cs_pgo=0
  fi
  if (( can_ir_pgo )) && ! _toolchain_supports_flags -fcs-profile-generate="$CSPGO_RAW_DIR" "${_pgo_mllvm[@]}"; then
    warning 'Toolchain lacks CS-PGO instrumentation; using IR-PGO only.'
    can_cs_pgo=0
  fi

  # Stage 1: IR-PGO instrument + train.
  if (( can_ir_pgo )); then
    local _s1="-fprofile-generate=$PGO1_RAW_DIR ${_pgo_mllvm[*]}"
    local CFLAGS_GEN="$CFLAGS $_s1"
    local CXXFLAGS_GEN="$CXXFLAGS $_s1"
    local LDFLAGS_GEN="$LDFLAGS -fprofile-generate=$PGO1_RAW_DIR"

    printf '  -> [PGO] Stage 1: IR-PGO instrumentation\n'
    arch-meson fontconfig build-pgo-gen --wrap-mode=nofallback "${meson_options[@]}" \
      -Dc_args="$CFLAGS_GEN" -Dcpp_args="$CXXFLAGS_GEN" \
      -Dc_link_args="$LDFLAGS_GEN" -Dcpp_link_args="$LDFLAGS_GEN"

    LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" meson compile -C build-pgo-gen
    LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" _training_tests build-pgo-gen 'stage1'
    _pgo_diag 'after stage1 tests' "$PGO1_RAW_DIR"
    LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" _training_workload "$srcdir/build-pgo-gen"
    _pgo_diag 'after stage1 custom workload' "$PGO1_RAW_DIR"

    if compgen -G "$PGO1_RAW_DIR/*.profraw" >/dev/null; then
      llvm-profdata merge -use-md5 -compress-all-sections -o "$PGO1_DATA" "$PGO1_RAW_DIR"/*.profraw
      printf '  -> [PGO] Stage 1 profile: %s (%s profraw)\n' "$PGO1_DATA" "$(_pgo_count "$PGO1_RAW_DIR")"
    else
      warning 'No stage1 .profraw produced; falling back to non-PGO build.'
      can_ir_pgo=0
      can_cs_pgo=0
    fi
  fi

  # Stage 2: CS-PGO instrument using the stage-1 profile + train.
  if (( can_cs_pgo )); then
    local _s2="-fprofile-use=$PGO1_DATA -fcs-profile-generate=$CSPGO_RAW_DIR ${_pgo_mllvm[*]} ${_profile_silence[*]}"
    local CFLAGS_CS_GEN="$CFLAGS $_s2"
    local CXXFLAGS_CS_GEN="$CXXFLAGS $_s2"
    local LDFLAGS_CS_GEN="$LDFLAGS -fprofile-use=$PGO1_DATA -fcs-profile-generate=$CSPGO_RAW_DIR"

    printf '  -> [PGO] Stage 2: CS-PGO instrumentation\n'
    arch-meson fontconfig build-cs-pgo-gen --wrap-mode=nofallback "${meson_options[@]}" \
      -Dc_args="$CFLAGS_CS_GEN" -Dcpp_args="$CXXFLAGS_CS_GEN" \
      -Dc_link_args="$LDFLAGS_CS_GEN" -Dcpp_link_args="$LDFLAGS_CS_GEN"

    LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" meson compile -C build-cs-pgo-gen
    LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" _training_tests build-cs-pgo-gen 'CS-stage'
    LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" _training_workload "$srcdir/build-cs-pgo-gen"
    _pgo_diag 'after CS-PGO workload' "$CSPGO_RAW_DIR"

    if compgen -G "$CSPGO_RAW_DIR/*.profraw" >/dev/null; then
      # LLVM expects the base IR profile first, then the context-sensitive raw profiles.
      llvm-profdata merge -use-md5 -compress-all-sections \
        -o "$FINAL_PGO_DATA" "$PGO1_DATA" "$CSPGO_RAW_DIR"/*.profraw
      printf '  -> [PGO] Final merged CS profile: %s\n' "$FINAL_PGO_DATA"
    else
      warning 'No CS-PGO .profraw produced; using stage1 profile only.'
      cp -f "$PGO1_DATA" "$FINAL_PGO_DATA"
    fi
  elif (( can_ir_pgo )) && [[ -f "$PGO1_DATA" ]]; then
    cp -f "$PGO1_DATA" "$FINAL_PGO_DATA"
  fi

  # Stage 3: final PGO-use build with relocation records retained for BOLT.
  local CFLAGS_USE="$CFLAGS"
  local CXXFLAGS_USE="$CXXFLAGS"
  local LDFLAGS_USE="$LDFLAGS"

  if [[ -f "$FINAL_PGO_DATA" ]]; then
    CFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA ${_profile_silence[*]}"
    CXXFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA ${_profile_silence[*]}"
    LDFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA"
    printf '  -> [PGO] Stage 3 uses profile: %s\n' "$FINAL_PGO_DATA"
  else
    warning '[PGO] Stage 3 has no profile-use.'
  fi
  LDFLAGS_USE+=" -Wl,--emit-relocs"

  arch-meson fontconfig build --wrap-mode=nofallback "${meson_options[@]}" \
    -Dc_args="$CFLAGS_USE" -Dcpp_args="$CXXFLAGS_USE" \
    -Dc_link_args="$LDFLAGS_USE" -Dcpp_link_args="$LDFLAGS_USE"
  meson compile -C build

  # Stage 4: optional BOLT instrumentation + training + optimization.
  command -v llvm-bolt >/dev/null 2>&1 || {
    printf '  -> [BOLT] llvm-bolt missing; final binary is PGO-only\n'
    return 0
  }

  local _lib
  _lib="$(find "$srcdir/build" -maxdepth 2 -type f -name 'libfontconfig.so.*' ! -name '*.symbols' | sort -V -r | head -n 1)"
  if [[ -z "$_lib" ]]; then
    warning '[BOLT] libfontconfig.so not found; skipping'
    return 0
  fi

  printf '  -> [BOLT] target: %s\n' "$_lib"
  cp -f "$_lib" "$BOLT_DIR/libfontconfig.so.orig"

  printf '  -> [BOLT] Stage 4a: instrumentation\n'
  if ! llvm-bolt "$BOLT_DIR/libfontconfig.so.orig" \
        --instrument \
        --lite=false \
        --instrumentation-file="$BOLT_DIR/fc.fdata" \
        --instrumentation-file-append-pid \
        --instrumentation-sleep-time=3 \
        --instrumentation-no-counters-clear \
        -o "$BOLT_DIR/libfontconfig.so.inst"; then
    warning '[BOLT] instrumentation failed; keeping PGO-only binary'
    return 0
  fi

  install -m755 "$BOLT_DIR/libfontconfig.so.inst" "$_lib"
  printf '  -> [BOLT] Stage 4b: training workload\n'
  _training_workload "$srcdir/build"

  local _flush
  local -a _fdata=()
  for _flush in $(seq 1 300); do
    shopt -s nullglob
    _fdata=("$BOLT_DIR"/fc.fdata*.fdata)
    shopt -u nullglob
    (( ${#_fdata[@]} > 0 )) && break
    sleep 0.1
  done
  printf '  -> [BOLT] .fdata after %d*0.1s grace: %d\n' "$_flush" "${#_fdata[@]}"

  install -m755 "$BOLT_DIR/libfontconfig.so.orig" "$_lib"
  if (( ${#_fdata[@]} == 0 )); then
    warning '[BOLT] no .fdata produced; keeping PGO-only binary'
    return 0
  fi

  printf '  -> [BOLT] Stage 4c: merge .fdata (%d files)\n' "${#_fdata[@]}"
  if (( ${#_fdata[@]} == 1 )); then
    cp -f "${_fdata[0]}" "$BOLT_DIR/merged.fdata"
  elif command -v merge-fdata >/dev/null 2>&1; then
    merge-fdata "${_fdata[@]}" -o "$BOLT_DIR/merged.fdata" || cat "${_fdata[@]}" > "$BOLT_DIR/merged.fdata"
  else
    cat "${_fdata[@]}" > "$BOLT_DIR/merged.fdata"
  fi
  [[ -s "$BOLT_DIR/merged.fdata" ]] || {
    warning '[BOLT] merged .fdata empty; keeping PGO-only binary'
    return 0
  }

  printf '  -> [BOLT] Stage 4d: optimize\n'
  local -a _bolt_full=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions --split-strategy=cdsplit --split-all-cold --split-eh
    --icf=safe
    --jump-tables=aggressive
    --indirect-call-promotion=all --icp-eliminate-loads
    --reg-reassign --x86-strip-redundant-address-size
    --peepholes=all
    --simplify-conditional-tail-calls --simplify-rodata-loads
    --eliminate-unreachable
    --inline-small-functions --inline-small-functions-bytes=4
    --inline-memcpy
    --plt=all --hot-data
    --tail-duplication=cache --equalize-bb-counts
    --infer-stale-profile=1 --match-profile-with-function-hash
    --cu-processing-batch-size=64
    --dyno-stats
  )
  local -a _bolt_safe=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions --split-all-cold
    --icf=safe
    --dyno-stats
  )

  if _bolt_try_optimize "$BOLT_DIR/libfontconfig.so.orig" "$BOLT_DIR/merged.fdata" \
        "$BOLT_DIR/libfontconfig.so.bolt" "${_bolt_full[@]}" || \
     _bolt_try_optimize "$BOLT_DIR/libfontconfig.so.orig" "$BOLT_DIR/merged.fdata" \
        "$BOLT_DIR/libfontconfig.so.bolt" "${_bolt_safe[@]}"; then
    install -m755 "$BOLT_DIR/libfontconfig.so.bolt" "$_lib"
    readelf -d "$_lib" | grep -q 'SONAME.*libfontconfig.so' || {
      warning '[BOLT] optimized library failed SONAME sanity check; restoring PGO-only binary'
      install -m755 "$BOLT_DIR/libfontconfig.so.orig" "$_lib"
      return 0
    }
    printf '  -> [BOLT] libfontconfig optimized in build tree\n'
  else
    warning '[BOLT] optimization failed; keeping PGO-only binary'
  fi
}

check() {
  printf '  -> [CHECK] Running deterministic upstream tests (%d)\n' "${#_fc_deterministic_tests[@]}"
  meson test -C build --print-errorlogs --no-rebuild --num-processes "$(_jobs)" "${_fc_deterministic_tests[@]}"

  if _has_pytest_tap; then
    printf '  -> [CHECK] Running pytest aggregate\n'
    meson test -C build --print-errorlogs --no-rebuild --num-processes "$(_jobs)" pytest || {
      printf '  -> [CHECK] pytest failed; diagnostics follow:\n'
      sed -n '/^test:.*pytest/,/^test:/p' build/meson-logs/testlog.txt | head -n 240 || true
      error '[CHECK] pytest failed'
      return 1
    }
    printf '  -> [CHECK] pytest OK\n'
  else
    error '[CHECK] pytest --tap unavailable; python-pytest-tap is required'
    return 1
  fi
}

package() {
  depends+=(
    libexpat.so
    libfreetype.so
  )
  provides+=(libfontconfig.so)

  meson install -C build --no-rebuild --destdir "$pkgdir"

  # Handle conf.d through the pacman hook to avoid overwriting symlinks on upgrade.
  mkdir -p "$pkgdir/usr/share/fontconfig/conf.default"
  local _f
  for _f in "$pkgdir"/etc/fonts/conf.d/*.conf; do
    [[ -e "$_f" ]] || continue
    ln -sr "$pkgdir"/usr/share/fontconfig/conf.{avail,default}/"${_f##*/}"
    rm "$_f"
  done

  install -Dm644 ./*.hook -t "$pkgdir/usr/share/libalpm/hooks"
  install -D 40-fontconfig-config.script \
    "$pkgdir/usr/share/libalpm/scripts/40-fontconfig-config"
  install -Dm644 fontconfig/COPYING -t "$pkgdir/usr/share/licenses/$pkgname"
}

