pkgname=irqbalance-git
pkgver=1.9.5.r3.g48ab93a
pkgrel=2
pkgdesc="A daemon to help balance the CPU load generated by interrupts across all of a systems CPUs (PGO+CS-PGO+BOLT optimized)"
arch=('x86_64')
url="https://irqbalance.github.io/irqbalance/"
license=('GPL')
options=(!strip)

depends=(
  'glib2'
  'glibc'
  'libcap-ng'
  'numactl'
  'systemd-libs'
)

makedepends=(
  'git'
  'autoconf'
  'automake'
  'libtool'
  'pkgconf'
  'glib2'
  'libcap-ng'
  'ncurses'
  'systemd'
  'stress-ng'
  'fio'
  'clang'
  'llvm'
  'lld'
)

provides=('irqbalance')
conflicts=('irqbalance')
backup=('etc/irqbalance.env')

source=(
  "git+https://github.com/Irqbalance/irqbalance.git"
  "ms178.patch"
)

sha256sums=(
  'SKIP'
  'SKIP'
)

pkgver() {
  cd "$srcdir/irqbalance"
  git describe --long --tags --abbrev=7 | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd "$srcdir/irqbalance"

  if [[ -f "$srcdir/ms178.patch" ]]; then
    if patch --dry-run -Np1 -N -i "$srcdir/ms178.patch" >/dev/null 2>&1; then
      echo "Applying patch: ms178.patch"
      patch -Np1 -N -i "$srcdir/ms178.patch"
    else
      echo "Skipping patch: ms178.patch already applied or not applicable"
    fi
  fi

  cat > "$srcdir/training-workload.sh" << 'EOF'
#!/usr/bin/env bash
set -u

NUM_CPUS=$(nproc)
DURATION=180
TEMP_DIR=$(mktemp -d /tmp/irqbalance-train.XXXXXX)

cleanup() {
  pkill -P $$ 2>/dev/null || true
  jobs -p | xargs -r kill 2>/dev/null || true
  pkill -9 -P $$ 2>/dev/null || true
  rm -rf "$TEMP_DIR" 2>/dev/null || true
}

trap cleanup EXIT INT TERM

echo "=== Starting IRQ training workload ==="
echo "Duration: ${DURATION}s, CPUs: ${NUM_CPUS}, temp: ${TEMP_DIR}"

if [[ -x "./irqbalance" ]]; then
  stdbuf -oL -eL ./irqbalance --foreground 2>&1 | \
    sed -u '/Cannot change IRQ/d;/affinity is now unmanaged/d;/permission denied/d' >/dev/null &
elif [[ -x "./irqbalance.inst" ]]; then
  stdbuf -oL -eL ./irqbalance.inst --foreground 2>&1 | \
    sed -u '/Cannot change IRQ/d;/affinity is now unmanaged/d;/permission denied/d' >/dev/null &
else
  echo "ERROR: irqbalance binary not found"
  exit 1
fi

IRQ_PID=$!
echo "Started irqbalance PID=${IRQ_PID}"
sleep 3

if command -v stress-ng >/dev/null 2>&1; then
  stress-ng \
    --cpu $(( NUM_CPUS > 2 ? NUM_CPUS - 2 : 1 )) \
    --cpu-method all \
    --vm 2 --vm-bytes 512M \
    --switch $(( NUM_CPUS * 4 )) \
    --timeout "${DURATION}s" &
fi

if command -v fio >/dev/null 2>&1; then
  fio --name=game-read \
      --directory="$TEMP_DIR" \
      --ioengine=libaio \
      --rw=randread \
      --bs=64k \
      --size=500m \
      --numjobs=4 \
      --iodepth=32 \
      --runtime=$(( DURATION - 10 )) \
      --time_based \
      --group_reporting >/dev/null 2>&1 &

  fio --name=game-rw \
      --directory="$TEMP_DIR" \
      --ioengine=libaio \
      --rw=randrw \
      --rwmixread=70 \
      --bsrange=4k-16k \
      --size=200m \
      --numjobs=2 \
      --iodepth=16 \
      --runtime=$(( DURATION - 10 )) \
      --time_based >/dev/null 2>&1 &
fi

if command -v ping >/dev/null 2>&1; then
  for _i in $(seq 1 4); do
    ping -n -c 20000 -i 0.002 127.0.0.1 >/dev/null 2>&1 || true &
  done
fi

for _i in $(seq 1 12); do
  (
    while :; do
      sync
      sleep 0.02
    done
  ) &
done

for _i in $(seq 1 "$NUM_CPUS"); do
  (
    while :; do
      find /usr/lib -type f -name '*.so*' -exec head -c 4096 {} \; >/dev/null 2>&1
      sleep 0.1
    done
  ) &
done

for _i in $(seq 1 3); do
  dd if=/dev/zero of="$TEMP_DIR/dd-${_i}.bin" bs=1M count=100 conv=fdatasync status=none >/dev/null 2>&1 &
done

(
  for burst in $(seq 1 10); do
    for _i in $(seq 1 100); do
      dd if=/dev/urandom of="$TEMP_DIR/burst.bin" bs=4K count=1 conv=fdatasync status=none >/dev/null 2>&1 || true
    done
    sleep $(( DURATION / 10 ))
  done
) &

for _i in $(seq 1 $(( NUM_CPUS * 2 ))); do
  (
    while :; do
      sleep 0.001
    done
  ) &
done

for step in $(seq 1 $(( DURATION / 10 ))); do
  if [[ -f /proc/interrupts ]]; then
    TOTAL_IRQS=$(awk 'NR > 1 {for (i = 2; i <= NF; i++) if ($i ~ /^[0-9]+$/) sum += $i} END {print sum + 0}' /proc/interrupts 2>/dev/null || echo 0)
    echo "[$(( step * 10 ))s] Total interrupts: $TOTAL_IRQS"
  fi
  sleep 10
done

echo "=== Training workload completed ==="
EOF

  chmod +x "$srcdir/training-workload.sh"

  autoreconf -fi
}

build() {
  cd "$srcdir/irqbalance"

  export CC=clang
  export CXX=clang++
  export LD=ld.lld
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib
  export STRIP=llvm-strip

  local BASE_CFLAGS="$CFLAGS -flto -fuse-ld=lld"
  local BASE_CXXFLAGS="$CXXFLAGS -flto -fuse-ld=lld"
  local BASE_LDFLAGS="$LDFLAGS -flto -fuse-ld=lld -Wl,--lto-O3"

  configure_irqbalance() {
    ./configure \
      --prefix=/usr \
      --sbindir=/usr/bin \
      --with-systemd \
      --disable-debug
  }

  ###########################################################################
  # Stage 1: Standard PGO
  ###########################################################################
  echo "=== Stage 1: PGO Instrumentation ==="

  rm -rf "$srcdir/pgo-data"
  mkdir -p "$srcdir/pgo-data"

  unset LLVM_PROFILE_FILE
  export LLVM_PROFILE_FILE="$srcdir/pgo-data/irqbalance-%p-%m.profraw"

  export CFLAGS="$BASE_CFLAGS -fprofile-generate=$srcdir/pgo-data -fno-omit-frame-pointer -mllvm -vp-counters-per-site=100 -mllvm -enable-value-profiling"
  export CXXFLAGS="$BASE_CXXFLAGS -fprofile-generate=$srcdir/pgo-data -fno-omit-frame-pointer -mllvm -vp-counters-per-site=100 -mllvm -enable-value-profiling"
  export LDFLAGS="$BASE_LDFLAGS -fprofile-generate=$srcdir/pgo-data"

  configure_irqbalance
  make -j1

  echo "=== Running PGO training workload ==="
  "$srcdir/training-workload.sh"

  echo "Merging PGO profiles..."
  local PROFILE_COUNT
  PROFILE_COUNT=$(find "$srcdir/pgo-data" -name '*.profraw' -size +1k 2>/dev/null | wc -l)
  if [[ "$PROFILE_COUNT" -eq 0 ]]; then
    echo "ERROR: No valid PGO profiles generated"
    exit 1
  fi
  echo "Found $PROFILE_COUNT PGO profile files"

  llvm-profdata merge \
    -output="$srcdir/pgo-data/default.profdata" \
    "$srcdir"/pgo-data/*.profraw

  local PROFILE_SIZE
  PROFILE_SIZE=$(stat -c%s "$srcdir/pgo-data/default.profdata")
  echo "PGO profile size: $(( PROFILE_SIZE / 1024 ))KB"

  rm -f "$srcdir"/pgo-data/*.profraw
  make clean

  ###########################################################################
  # Stage 2: CS-PGO
  ###########################################################################
  echo "=== Stage 2: CS-PGO Instrumentation ==="

  rm -rf "$srcdir/cspgo-data"
  mkdir -p "$srcdir/cspgo-data"

  unset LLVM_PROFILE_FILE
  export LLVM_PROFILE_FILE="$srcdir/cspgo-data/irqbalance-%p-%m.profraw"

  export CFLAGS="$BASE_CFLAGS -fprofile-use=$srcdir/pgo-data/default.profdata -fcs-profile-generate=$srcdir/cspgo-data -fno-omit-frame-pointer -mllvm -vp-counters-per-site=100"
  export CXXFLAGS="$BASE_CXXFLAGS -fprofile-use=$srcdir/pgo-data/default.profdata -fcs-profile-generate=$srcdir/cspgo-data -fno-omit-frame-pointer -mllvm -vp-counters-per-site=100"
  export LDFLAGS="$BASE_LDFLAGS -fprofile-use=$srcdir/pgo-data/default.profdata -fcs-profile-generate=$srcdir/cspgo-data"

  configure_irqbalance
  make -j1

  echo "=== Running CS-PGO training workload ==="
  "$srcdir/training-workload.sh"

  echo "Merging CS-PGO profiles..."
  PROFILE_COUNT=$(find "$srcdir/cspgo-data" -name '*.profraw' -size +1k 2>/dev/null | wc -l)
  if [[ "$PROFILE_COUNT" -eq 0 ]]; then
    echo "ERROR: No valid CS-PGO profiles generated"
    exit 1
  fi
  echo "Found $PROFILE_COUNT CS-PGO profile files"

  llvm-profdata merge \
    -output="$srcdir/cspgo-data/cs.profdata" \
    "$srcdir"/cspgo-data/*.profraw

  PROFILE_SIZE=$(stat -c%s "$srcdir/cspgo-data/cs.profdata")
  echo "CS-PGO profile size: $(( PROFILE_SIZE / 1024 ))KB"

  rm -f "$srcdir"/cspgo-data/*.profraw
  make clean

  ###########################################################################
  # Stage 3: Final optimized build
  ###########################################################################
  echo "=== Stage 3: Final PGO/CS-PGO build ==="

  unset LLVM_PROFILE_FILE

  export CFLAGS="$BASE_CFLAGS -fprofile-use=$srcdir/cspgo-data/cs.profdata -fprofile-correction -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export CXXFLAGS="$BASE_CXXFLAGS -fprofile-use=$srcdir/cspgo-data/cs.profdata -fprofile-correction -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  export LDFLAGS="$BASE_LDFLAGS -fprofile-use=$srcdir/cspgo-data/cs.profdata -Wl,--emit-relocs"

  configure_irqbalance
  make -j1

  ###########################################################################
  # Stage 4: BOLT Optimization
  ###########################################################################
  echo "=== Stage 4: BOLT Optimization ==="

  rm -rf "$srcdir/bolt-data"
  mkdir -p "$srcdir/bolt-data"

  cp irqbalance irqbalance.cspgo

  if ! llvm-bolt irqbalance.cspgo \
      --instrument \
      --instrumentation-file-append-pid \
      --instrumentation-file="$srcdir/bolt-data/irqbalance.fdata" \
      -o irqbalance.bolt.inst; then
    echo "WARNING: BOLT instrumentation failed, keeping CS-PGO binary"
    cp irqbalance.cspgo irqbalance
    return 0
  fi

  chmod +x irqbalance.bolt.inst
  cp irqbalance.bolt.inst irqbalance

  echo "=== Running BOLT training workload ==="
  "$srcdir/training-workload.sh" || true

  local BOLT_PROFILE_COUNT
  BOLT_PROFILE_COUNT=$(find "$srcdir/bolt-data" -name 'irqbalance.fdata.*' -size +1k 2>/dev/null | wc -l)

  if [[ "$BOLT_PROFILE_COUNT" -eq 0 ]]; then
    echo "WARNING: No BOLT profiles generated, keeping CS-PGO binary"
    cp irqbalance.cspgo irqbalance
    return 0
  fi

  echo "Found $BOLT_PROFILE_COUNT BOLT profile files"

  if ! command -v merge-fdata >/dev/null 2>&1; then
    echo "WARNING: merge-fdata not found, keeping CS-PGO binary"
    cp irqbalance.cspgo irqbalance
    return 0
  fi

  if ! merge-fdata "$srcdir"/bolt-data/irqbalance.fdata.* > "$srcdir/bolt-data/merged.fdata" 2>/dev/null; then
    echo "WARNING: BOLT profile merge failed, keeping CS-PGO binary"
    cp irqbalance.cspgo irqbalance
    return 0
  fi

  local MERGED_SIZE
  MERGED_SIZE=$(stat -c%s "$srcdir/bolt-data/merged.fdata" 2>/dev/null || echo 0)
  if [[ "$MERGED_SIZE" -lt 1000 ]]; then
    echo "WARNING: BOLT profile too small, keeping CS-PGO binary"
    cp irqbalance.cspgo irqbalance
    return 0
  fi

  echo "BOLT merged profile size: $(( MERGED_SIZE / 1024 ))KB"

  if ! llvm-bolt irqbalance.cspgo \
      --data "$srcdir/bolt-data/merged.fdata" \
      --dyno-stats \
      --lite=false \
      --icf=all \
      --plt=all \
      --hugify \
      --peepholes=all \
      --x86-strip-redundant-address-size \
      --indirect-call-promotion=all \
      --reorder-blocks=ext-tsp \
      --reorder-functions=cdsort \
      --split-all-cold \
      --split-eh \
      --split-functions \
      --split-strategy=cdsplit \
      --align-functions=32 \
      --align-blocks \
      --block-alignment=16 \
      -o irqbalance.bolt; then
    echo "WARNING: BOLT optimization failed, keeping CS-PGO binary"
    cp irqbalance.cspgo irqbalance
    return 0
  fi

  local ORIG_SIZE
  local BOLT_SIZE
  ORIG_SIZE=$(stat -c%s irqbalance.cspgo)
  BOLT_SIZE=$(stat -c%s irqbalance.bolt)

  if [[ "$BOLT_SIZE" -lt 10000 ]]; then
    echo "WARNING: BOLT binary suspiciously small, keeping CS-PGO binary"
    cp irqbalance.cspgo irqbalance
    return 0
  fi

  echo "BOLT optimization successful: ${ORIG_SIZE} -> ${BOLT_SIZE} bytes"
  cp irqbalance.bolt irqbalance
}

check() {
  cd "$srcdir/irqbalance"

  ./irqbalance --version >/dev/null
  ./irqbalance --oneshot >/dev/null 2>&1 || true
}

package() {
  cd "$srcdir/irqbalance"

  make DESTDIR="$pkgdir" install

  install -Dm644 "misc/irqbalance.env" \
    "$pkgdir/etc/irqbalance.env"
  install -Dm644 "misc/irqbalance.service" \
    "$pkgdir/usr/lib/systemd/system/irqbalance.service"

  if [[ -f "$pkgdir/usr/bin/irqbalance" ]] && file "$pkgdir/usr/bin/irqbalance" | grep -q ELF; then
    llvm-strip --strip-unneeded "$pkgdir/usr/bin/irqbalance" 2>/dev/null || \
      llvm-strip --strip-all "$pkgdir/usr/bin/irqbalance" 2>/dev/null || true
  fi

  install -dm755 "$pkgdir/usr/share/doc/irqbalance"
  {
    echo "Build optimizations: PGO + CS-PGO + BOLT + LTO"
    [[ -f "$srcdir/pgo-data/default.profdata" ]] && \
      echo "PGO profile: $(stat -c%s "$srcdir/pgo-data/default.profdata") bytes"
    [[ -f "$srcdir/cspgo-data/cs.profdata" ]] && \
      echo "CS-PGO profile: $(stat -c%s "$srcdir/cspgo-data/cs.profdata") bytes"
    [[ -f "$srcdir/bolt-data/merged.fdata" ]] && \
      echo "BOLT profile: $(stat -c%s "$srcdir/bolt-data/merged.fdata") bytes"
  } > "$pkgdir/usr/share/doc/irqbalance/OPTIMIZATIONS.txt"
}
