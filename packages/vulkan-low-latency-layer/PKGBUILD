# Maintainer: You

pkgname=vulkan-layer-low-latency-layer
pkgver=0.1.0
pkgrel=2
pkgdesc="Hardware-agnostic Vulkan implicit layer for input latency reduction (Reflex/Anti-Lag bridge)"
arch=('x86_64')
url="https://github.com/Korthos-Software/low_latency_layer"
license=('MIT')
depends=(
  'vulkan-icd-loader'
  'vulkan-utility-libraries'
)
makedepends=(
  'cmake'
)
options=('!debug')
source=(
  "${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz"
)
sha256sums=('SKIP')

prepare() {
  cd "low_latency_layer-${pkgver}"

  # Upstream hardcodes -g and -O2 in target_compile_options; remove them
  sed -i \
    -e '/^[[:space:]]*-g$/d' \
    -e '/^[[:space:]]*-O2$/d' \
    CMakeLists.txt
}

build() {
  # Force host-tuned optimization, no debug symbols
  export CFLAGS="${CFLAGS}"
  export CXXFLAGS="${CXXFLAGS}"

  cmake -S "low_latency_layer-${pkgver}" -B build \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_C_FLAGS_RELEASE="${CFLAGS}" \
    -DCMAKE_CXX_FLAGS_RELEASE="${CXXFLAGS}"

  cmake --build build
}

package() {
  DESTDIR="${pkgdir}" cmake --install build

  install -Dm644 "low_latency_layer-${pkgver}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
