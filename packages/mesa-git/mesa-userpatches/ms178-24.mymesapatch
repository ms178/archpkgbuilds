+static bool
+radv_amdgpu_add_va_gap_size(uint64_t va_size, uint64_t va_gap_size, uint64_t *total_size)
+{
+   if (va_size > ~0ull - va_gap_size)
+      return false;
+
+   *total_size = va_size + va_gap_size;
+   return true;
+}
