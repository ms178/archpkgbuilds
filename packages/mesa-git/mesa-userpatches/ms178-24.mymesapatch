+static RADV_ALWAYS_INLINE __attribute__((const)) uint32_t
+radv_hash_bo(uint32_t bo_handle)
+{
+   uint32_t h = bo_handle;
+   h ^= h >> 16;
+   h *= 0x85ebca6bu;
+   h ^= h >> 13;
+   h *= 0xc2b2ae35u;
+   h ^= h >> 16;
+   return h;
+}
