diff --git a/src/amd/compiler/aco_assembler.cpp b/src/amd/compiler/aco_assembler.cpp
index 5f53145..e7a5f8c 100644
--- a/src/amd/compiler/aco_assembler.cpp
+++ b/src/amd/compiler/aco_assembler.cpp
@@ -1431,12 +1431,52 @@ emit_instruction(asm_context& ctx, std::vector<uint32_t>& out, Instruction* inst
    }
 }
 
+static void
+insert_code(asm_context& ctx, std::vector<uint32_t>& out, unsigned insert_before,
+            const std::vector<uint32_t>& code);
+
+static bool
+is_gfx9_fetch_align_candidate(const Instruction* instr, unsigned emitted_dwords)
+{
+   /* GFX9 fetches 32-byte instruction-buffer windows. A long run of 8-byte VALU
+    * instructions that starts on an odd dword makes every fourth instruction
+    * straddle a fetch window. Shifting the run by one SOPP dword avoids that
+    * recurring front-end bubble. Restrict this to true 8-byte VALU encodings:
+    * VOP1/VOP2/VOPC 32-bit encodings and literals do not have the straddle
+    * pattern, while memory/SALU/branch instructions break the VALU issue run.
+    */
+   return emitted_dwords == 2 && instr->isVALU();
+}
+
 void
 emit_block(asm_context& ctx, std::vector<uint32_t>& out, Block& block)
 {
+   static const std::vector<uint32_t> s_nop_0 = {0xbf800000u};
+   static constexpr unsigned gfx9_fetch_align_min_valu_run = 8;
+
    block.offset = out.size();
    ctx.block_emit_order.push_back(block.index);
 
+   const bool align_gfx9_valu_runs = ctx.gfx_level == GFX9 && block.loop_nest_depth > 0;
+   unsigned run_start = 0;
+   unsigned run_length = 0;
+
+   auto finish_run = [&]() {
+      if (run_length >= gfx9_fetch_align_min_valu_run && (run_start & 1)) {
+         const bool starts_block = run_start == block.offset;
+         insert_code(ctx, out, run_start, s_nop_0);
+
+         /* The padding is part of this block, not bytes before it. Keep branch
+          * targets pointing at the s_nop when the run starts at the label.
+          */
+         if (starts_block)
+            block.offset--;
+      }
+
+      run_start = 0;
+      run_length = 0;
+   };
+
    for (aco_ptr<Instruction>& instr : block.instructions) {
 #if 0
       int start_idx = out.size();
@@ -1444,12 +1484,26 @@ emit_block(asm_context& ctx, std::vector<uint32_t>& out, Block& block)
       aco_print_instr(&*instr, stderr);
       std::cerr << std::endl;
 #endif
+      const unsigned instr_start = out.size();
       emit_instruction(ctx, out, instr.get());
+      const unsigned emitted_dwords = out.size() - instr_start;
+
+      if (align_gfx9_valu_runs &&
+          is_gfx9_fetch_align_candidate(instr.get(), emitted_dwords)) {
+         if (!run_length)
+            run_start = instr_start;
+         run_length++;
+      } else if (align_gfx9_valu_runs) {
+         finish_run();
+      }
 #if 0
       for (int i = start_idx; i < out.size(); i++)
          std::cerr << "encoding: " << "0x" << std::setfill('0') << std::setw(8) << std::hex << out[i] << std::endl;
 #endif
    }
+
+   if (align_gfx9_valu_runs)
+      finish_run();
 }
 
 void
