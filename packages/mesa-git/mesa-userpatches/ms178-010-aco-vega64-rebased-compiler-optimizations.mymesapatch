+
+BEGIN_TEST(assembler.gfx9_align_valu_run)
+   if (!setup_cs(NULL, GFX9))
+      return;
+
+   //! BB0:
+   //! s_branch BB1                                                ; bf820000
+   bld.sopp(aco_opcode::s_branch, 1);
+
+   bld.reset(program->create_and_insert_block());
+   program->blocks[1].linear_preds.push_back(0u);
+   program->blocks[1].loop_nest_depth = 1;
+
+   Definition dst(PhysReg(256), v1);
+   Operand src0(PhysReg(256), v1);
+   Operand src1(PhysReg(257), v1);
+
+   //! BB1:
+   //! s_nop 0                                                     ; bf800000
+   //! v_min3_f32 v0, v0, v1, v0                                   ; d1d00000 04020300
+   //! (then repeated 9 times)
+   for (unsigned i = 0; i < 10; i++)
+      bld.vop3(aco_opcode::v_min3_f32, dst, src0, src1, src0);
+
+   finish_assembler_test();
+END_TEST
+
+BEGIN_TEST(assembler.gfx9_align_valu_run.below_threshold)
+   if (!setup_cs(NULL, GFX9))
+      return;
+
+   //! BB0:
+   //! s_branch BB1                                                ; bf820000
+   bld.sopp(aco_opcode::s_branch, 1);
+
+   bld.reset(program->create_and_insert_block());
+   program->blocks[1].linear_preds.push_back(0u);
+   program->blocks[1].loop_nest_depth = 1;
+
+   Definition dst(PhysReg(256), v1);
+   Operand src0(PhysReg(256), v1);
+   Operand src1(PhysReg(257), v1);
+
+   //! BB1:
+   //! v_min3_f32 v0, v0, v1, v0                                   ; d1d00000 04020300
+   //! (then repeated 6 times)
+   for (unsigned i = 0; i < 7; i++)
+      bld.vop3(aco_opcode::v_min3_f32, dst, src0, src1, src0);
+
+   finish_assembler_test();
+END_TEST
+
 BEGIN_TEST(assembler.long_jump.unconditional_forwards)
    if (!setup_cs(NULL, (amd_gfx_level)GFX10))
       return;
