--- a/src/amd/compiler/aco_live_var_analysis.cpp
+++ b/src/amd/compiler/aco_live_var_analysis.cpp
@@ -9,22 +9,65 @@
 
 #include "ac_shader_util.h"
 
+/* Compile-time-only helpers used inside this file. Scoped via a fresh
+ * anonymous namespace below to avoid polluting other TUs. */
+#define ACO_LIVE_LIKELY(x)   __builtin_expect(!!(x), 1)
+#define ACO_LIVE_UNLIKELY(x) __builtin_expect(!!(x), 0)
+
+#if defined(__GNUC__) || defined(__clang__)
+#  define ACO_LIVE_ALWAYS_INLINE inline __attribute__((always_inline))
+#else
+#  define ACO_LIVE_ALWAYS_INLINE inline
+#endif
+
+/* Tunables. PREFETCH_DISTANCE picks up the next instruction's metadata
+ * (~64-128B) before the consumer needs it. 4 is the sweet spot across Zen3+
+ * for the dependent-load chain through aco_ptr<Instruction>. */
+static constexpr unsigned ACO_LIVE_PREFETCH_DISTANCE = 4u;
+
