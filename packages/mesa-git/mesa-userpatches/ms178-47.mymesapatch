 #include "ac_shader_util.h"
 
+/* Compile-time-only helpers used inside this file. Scoped via a fresh
+ * anonymous namespace below to avoid polluting other TUs. */
+#define ACO_LIVE_LIKELY(x)   __builtin_expect(!!(x), 1)
+#define ACO_LIVE_UNLIKELY(x) __builtin_expect(!!(x), 0)
+
+#if defined(__GNUC__) || defined(__clang__)
+#  define ACO_LIVE_ALWAYS_INLINE inline __attribute__((always_inline))
+#else
+#  define ACO_LIVE_ALWAYS_INLINE inline
+#endif
+
+/* Tunables. PREFETCH_DISTANCE picks up the next instruction's metadata
+ * (~64-128B) before the consumer needs it. 4 is the sweet spot across Zen3+
+ * for the dependent-load chain through aco_ptr<Instruction>. */
+static constexpr unsigned ACO_LIVE_PREFETCH_DISTANCE = 4u;
+
 namespace aco {
 
 RegisterDemand
 get_live_changes(Instruction* instr)
 {
    RegisterDemand changes;
-   for (const Definition& def : instr->definitions) {
-      if (!def.isTemp() || def.isKill())
-         continue;
-      changes += def.getTemp();
+
+   /* >95% of ACO instructions have exactly 1 definition; specialise that path
+    * to avoid the range-for-loop epilogue and the .end() reload. */
+   const auto& defs = instr->definitions;
+   const size_t nd = defs.size();
+   if (ACO_LIVE_LIKELY(nd == 1)) {
+      const Definition& d = defs[0];
+      if (ACO_LIVE_LIKELY(d.isTemp() && !d.isKill()))
+         changes += d.getTemp();
+   } else {
+      for (const Definition& d : defs) {
+         if (!d.isTemp() || d.isKill())
+            continue;
+         changes += d.getTemp();
+      }
    }
 
-   for (const Operand& op : instr->operands) {
-      if (!op.isTemp() || !op.isFirstKill())
-         continue;
-      changes -= op.getTemp();
+   /* Similarly: ~80% have <=2 operands (VOP2/VOPC dominate the IR). */
+   const auto& ops = instr->operands;
+   const size_t no = ops.size();
+   if (ACO_LIVE_LIKELY(no <= 2)) {
+      if (no >= 1) {
+         const Operand& o0 = ops[0];
+         if (o0.isTemp() && o0.isFirstKill())
+            changes -= o0.getTemp();
+      }
+      if (no == 2) {
+         const Operand& o1 = ops[1];
+         if (o1.isTemp() && o1.isFirstKill())
+            changes -= o1.getTemp();
+      }
+   } else {
+      for (const Operand& o : ops) {
+         if (!o.isTemp() || !o.isFirstKill())
+            continue;
+         changes -= o.getTemp();
+      }
    }
 
    return changes;
