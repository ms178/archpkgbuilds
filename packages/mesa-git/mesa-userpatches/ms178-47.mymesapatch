+struct InstrCache {
+   uint8_t format;
+   uint8_t vcc;
+   uint8_t special;
+};
+
 struct live_ctx {
    monotonic_buffer_resource m;
    Program* program;
    int32_t worklist;
    uint32_t handled_once;
+   InstrCache* instr_cache = nullptr;
+   size_t cache_capacity = 0;
 };
 
