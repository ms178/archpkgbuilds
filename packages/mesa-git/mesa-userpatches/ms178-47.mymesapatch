    RegisterDemand demand_before;
    RegisterDemand demand_after;
 
-   for (Definition def : instr->definitions) {
-      if (def.isKill())
-         demand_after += def.getTemp();
-      else if (def.isTemp())
-         demand_before -= def.getTemp();
+   /* Fast path: no kill among definitions (the common case for VALU). One
+    * pass through, all subtracts. Saves the secondary range-for. */
+   bool has_kill = false;
+   for (const Definition& d : instr->definitions) {
+      if (ACO_LIVE_UNLIKELY(d.isKill())) {
+         has_kill = true;
+         break;
+      }
+   }
+   if (ACO_LIVE_LIKELY(!has_kill)) {
+      for (const Definition& d : instr->definitions) {
+         if (d.isTemp())
+            demand_before -= d.getTemp();
+      }
+   } else {
+      for (const Definition& d : instr->definitions) {
+         if (d.isKill())
+            demand_after += d.getTemp();
+         else if (d.isTemp())
+            demand_before -= d.getTemp();
+      }
    }
 
-   for (Operand op : instr->operands) {
+   for (const Operand& op : instr->operands) {
       if (op.isFirstKill() || op.isCopyKill()) {
          demand_before += op.getTemp();
-         if (op.isLateKill())
