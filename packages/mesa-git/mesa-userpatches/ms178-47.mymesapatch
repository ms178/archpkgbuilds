-         continue;
-      changes += def.getTemp();
+   const auto& defs = instr->definitions;
+   const size_t nd = defs.size();
+   if (LIKELY(nd == 1)) {
+      const Definition& d = defs[0];
+      if (LIKELY(d.isTemp() &&!d.isKill()))
+         changes += d.getTemp();
+   } else if (nd > 1) {
+      for (const Definition& d : defs) {
+         if (UNLIKELY(!d.isTemp() || d.isKill()))
+            continue;
+         changes += d.getTemp();
+      }
