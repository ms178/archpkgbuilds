             demand_after += op.getTemp();
-      } else if (op.isClobbered() && !op.isKill()) {
+      } else if (ACO_LIVE_UNLIKELY(op.isClobbered() && !op.isKill())) {
          demand_before += op.getTemp();
       }
    }
