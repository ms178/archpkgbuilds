-
-   return false;
+   if (!nir_intrinsic_has_image_dim(intr) ||
+       nir_intrinsic_image_dim(intr) != GLSL_SAMPLER_DIM_BUF)
+      return false;
+
+   if (!is_supported_buffer_image_load_intrinsic(intr->intrinsic))
+      return false;
+
+   b->cursor = nir_before_instr(&intr->instr);
