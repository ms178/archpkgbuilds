-      }                                                           \
-   } while (0)
+#define SWIZZLE_CONVERT(DST_TYPE, SRC_TYPE, CONV)                            \
+   do {                                                                      \
+      const uint8_t swizzle_x = swizzle[0];                                  \
+      const uint8_t swizzle_y = swizzle[1];                                  \
+      const uint8_t swizzle_z = swizzle[2];                                  \
+      const uint8_t swizzle_w = swizzle[3];                                  \
