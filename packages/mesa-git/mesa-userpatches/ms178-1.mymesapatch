+TEST_F(signed_bound_test, minmax_and_select)
+{
+   nir_def *unknown = nir_load_global(b, 1, 32, nir_undef(b, 1, 64));
+   nir_def *neg_four = nir_imm_int(b, -4);
+   nir_def *pos_four = nir_imm_int(b, 4);
+   nir_def *cond = nir_load_global(b, 1, 1, nir_undef(b, 1, 64));
+   nir_def *limited_negative = nir_imin(b, unknown, neg_four);
+   nir_def *limited_positive = nir_imax(b, unknown, pos_four);
+   nir_def *selected = nir_bcsel(b, cond, limited_negative, nir_imm_int(b, -2));
+
+   struct hash_table *upper_ht = _mesa_pointer_hash_table_create(NULL);
+   struct hash_table *lower_ht = _mesa_pointer_hash_table_create(NULL);
+
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht,
+                                   nir_get_scalar(limited_negative, 0)), -4);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht,
+                                   nir_get_scalar(limited_negative, 0)), INT32_MIN);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht,
+                                   nir_get_scalar(limited_positive, 0)), 4);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht,
+                                   nir_get_scalar(limited_positive, 0)), INT32_MAX);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht,
+                                   nir_get_scalar(selected, 0)), -2);
+
+   _mesa_hash_table_destroy(upper_ht, NULL);
+   _mesa_hash_table_destroy(lower_ht, NULL);
+}
+
+TEST_F(signed_bound_test, bit_size_extrema)
+{
+   struct hash_table *upper_ht = _mesa_pointer_hash_table_create(NULL);
+   struct hash_table *lower_ht = _mesa_pointer_hash_table_create(NULL);
+
+   nir_def *unknown8 = nir_undef(b, 1, 8);
+   nir_def *unknown16 = nir_undef(b, 1, 16);
+   nir_def *unknown32 = nir_undef(b, 1, 32);
+
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(unknown8, 0)), INT8_MIN);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(unknown8, 0)), INT8_MAX);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(unknown16, 0)), INT16_MIN);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(unknown16, 0)), INT16_MAX);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(unknown32, 0)), INT32_MIN);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(unknown32, 0)), INT32_MAX);
+
+   _mesa_hash_table_destroy(upper_ht, NULL);
+   _mesa_hash_table_destroy(lower_ht, NULL);
+}
+
+TEST_F(signed_bound_test, signed_output_domains)
+{
+   nir_def *unknown = nir_load_global(b, 1, 32, nir_undef(b, 1, 64));
+   nir_def *byte = nir_extract_i8(b, unknown, nir_imm_int(b, 0));
+   nir_def *halfword = nir_extract_i16(b, unknown, nir_imm_int(b, 0));
+   nir_def *bfe = nir_ibfe_imm(b, unknown, 0, 7);
+   nir_def *shift = nir_ishr_imm(b, unknown, 4);
+   nir_def *boolean = nir_b2i32(b, nir_load_global(b, 1, 1, nir_undef(b, 1, 64)));
+
+   struct hash_table *upper_ht = _mesa_pointer_hash_table_create(NULL);
+   struct hash_table *lower_ht = _mesa_pointer_hash_table_create(NULL);
+
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(byte, 0)), INT8_MIN);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(byte, 0)), INT8_MAX);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(halfword, 0)), INT16_MIN);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(halfword, 0)), INT16_MAX);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(bfe, 0)), -64);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(bfe, 0)), 63);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(shift, 0)), -134217728);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(shift, 0)), 134217727);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(boolean, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(boolean, 0)), 1);
+
+   _mesa_hash_table_destroy(upper_ht, NULL);
+   _mesa_hash_table_destroy(lower_ht, NULL);
+}
+
+TEST_F(signed_bound_test, additional_signed_output_domains)
+{
+   nir_def *unknown = nir_load_global(b, 1, 32, nir_undef(b, 1, 64));
+   nir_def *sign = nir_isign(b, unknown);
+   nir_def *move = nir_mov(b, sign);
+   nir_def *byte = nir_extract_u8_imm(b, unknown, 0);
+   nir_def *halfword = nir_extract_u16(b, unknown, nir_imm_int(b, 0));
+   nir_def *ubfe = nir_ubfe_imm(b, unknown, 0, 7);
+   nir_def *ubitfield = nir_ubitfield_extract_imm(b, unknown, 0, 7);
+   nir_def *ibitfield = nir_ibitfield_extract_imm(b, unknown, 0, 7);
+   nir_def *shift = nir_ushr_imm(b, unknown, 1);
+   nir_def *aligned_div = nir_udiv_aligned_4(b, unknown);
+   nir_def *carry = nir_uadd_carry(b, unknown, unknown);
+   nir_def *borrow = nir_usub_borrow(b, unknown, unknown);
+   nir_def *count = nir_bit_count(b, unknown);
+   nir_def *clz = nir_uclz(b, unknown);
+   nir_def *msb = nir_ufind_msb(b, unknown);
+   nir_def *signed_msb = nir_ifind_msb(b, unknown);
+   nir_def *lsb = nir_find_lsb(b, unknown);
+   nir_def *masked = nir_iand_imm(b, unknown, 0x7fff);
+   nir_def *negative = nir_ior_imm(b, unknown, 0x80001000);
+
+   struct hash_table *upper_ht = _mesa_pointer_hash_table_create(NULL);
+   struct hash_table *lower_ht = _mesa_pointer_hash_table_create(NULL);
+
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(move, 0)), -1);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(move, 0)), 1);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(byte, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(byte, 0)), UINT8_MAX);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(halfword, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(halfword, 0)), UINT16_MAX);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(ubfe, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(ubfe, 0)), 127);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(ubitfield, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(ubitfield, 0)), 127);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(ibitfield, 0)), -64);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(ibitfield, 0)), 63);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(shift, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(shift, 0)), INT32_MAX);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(aligned_div, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(aligned_div, 0)), 0x3fffffff);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(carry, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(carry, 0)), 1);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(borrow, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(borrow, 0)), 1);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(count, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(count, 0)), 32);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(clz, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(clz, 0)), 32);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(msb, 0)), -1);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(msb, 0)), 31);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(signed_msb, 0)), -1);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(signed_msb, 0)), 30);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(lsb, 0)), -1);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(lsb, 0)), 31);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(masked, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(masked, 0)), 0x7fff);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht, nir_get_scalar(negative, 0)),
+             INT32_MIN + 0x1000);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht, nir_get_scalar(negative, 0)), -1);
+
+   _mesa_hash_table_destroy(upper_ht, NULL);
+   _mesa_hash_table_destroy(lower_ht, NULL);
+}
+
+TEST_F(signed_bound_test, signed_and_unsigned_widening)
+{
+   nir_def *unknown8 = nir_load_global(b, 1, 8, nir_undef(b, 1, 64));
+   nir_def *signed_widen = nir_i2i32(b, unknown8);
+   nir_def *unsigned_widen = nir_u2u32(b, unknown8);
+
+   struct hash_table *upper_ht = _mesa_pointer_hash_table_create(NULL);
+   struct hash_table *lower_ht = _mesa_pointer_hash_table_create(NULL);
+
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht,
+                                   nir_get_scalar(signed_widen, 0)), INT8_MIN);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht,
+                                   nir_get_scalar(signed_widen, 0)), INT8_MAX);
+   EXPECT_EQ(nir_signed_lower_bound(b->shader, lower_ht,
+                                   nir_get_scalar(unsigned_widen, 0)), 0);
+   EXPECT_EQ(nir_signed_upper_bound(b->shader, upper_ht,
+                                   nir_get_scalar(unsigned_widen, 0)), UINT8_MAX);
+
+   _mesa_hash_table_destroy(upper_ht, NULL);
+   _mesa_hash_table_destroy(lower_ht, NULL);
+}
+
+TEST_F(signed_bound_test, opt_uub_signed_widening_compare)
+{
+   nir_def *unknown8 = nir_load_global(b, 1, 8, nir_undef(b, 1, 64));
+   nir_def *signed_widen = nir_i2i32(b, unknown8);
+   nir_def *unsigned_widen = nir_u2u32(b, unknown8);
+   nir_def *lt = nir_ilt(b, signed_widen, nir_imm_int(b, 128));
+   nir_def *ge = nir_ige(b, unsigned_widen, nir_imm_int(b, 0));
+   nir_def *lt_result = nir_bcsel(b, lt, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_def *ge_result = nir_bcsel(b, ge, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_alu_instr *lt_result_alu = nir_def_as_alu(lt_result);
+   nir_alu_instr *ge_result_alu = nir_def_as_alu(ge_result);
+
+   nir_opt_uub_options options = {};
+   EXPECT_TRUE(nir_opt_uub(b->shader, &options));
+   EXPECT_TRUE(nir_src_is_const(lt_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(lt_result_alu->src[0].src), 1u);
+   EXPECT_TRUE(nir_src_is_const(ge_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(ge_result_alu->src[0].src), 1u);
+}
+
+TEST_F(signed_bound_test, opt_uub_signed_output_domain_compare)
+{
+   nir_def *unknown = nir_load_global(b, 1, 32, nir_undef(b, 1, 64));
+   nir_def *bfe = nir_ibfe_imm(b, unknown, 0, 7);
+   nir_def *lt = nir_ilt(b, bfe, nir_imm_int(b, 64));
+   nir_def *ge = nir_ige(b, bfe, nir_imm_int(b, -64));
+   nir_def *lt_result = nir_bcsel(b, lt, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_def *ge_result = nir_bcsel(b, ge, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_alu_instr *lt_result_alu = nir_def_as_alu(lt_result);
+   nir_alu_instr *ge_result_alu = nir_def_as_alu(ge_result);
+
+   nir_opt_uub_options options = {};
+   EXPECT_TRUE(nir_opt_uub(b->shader, &options));
+   EXPECT_TRUE(nir_src_is_const(lt_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(lt_result_alu->src[0].src), 1u);
+   EXPECT_TRUE(nir_src_is_const(ge_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(ge_result_alu->src[0].src), 1u);
+}
+
+TEST_F(signed_bound_test, opt_uub_signed_boolean_output_domain)
+{
+   nir_def *unknown = nir_load_global(b, 1, 32, nir_undef(b, 1, 64));
+   nir_def *carry = nir_uadd_carry(b, unknown, unknown);
+   nir_def *lt = nir_ilt(b, carry, nir_imm_int(b, 2));
+   nir_def *equal = nir_ieq(b, carry, nir_imm_int(b, 2));
+   nir_def *lt_result = nir_bcsel(b, lt, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_def *equal_result = nir_bcsel(b, equal, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_alu_instr *lt_result_alu = nir_def_as_alu(lt_result);
+   nir_alu_instr *equal_result_alu = nir_def_as_alu(equal_result);
+
+   nir_opt_uub_options options = {};
+   EXPECT_TRUE(nir_opt_uub(b->shader, &options));
+   EXPECT_TRUE(nir_src_is_const(lt_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(lt_result_alu->src[0].src), 1u);
+   EXPECT_TRUE(nir_src_is_const(equal_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(equal_result_alu->src[0].src), 0u);
+}
+
+TEST_F(signed_bound_test, opt_uub_signed_minmax)
+{
+   nir_def *unknown = nir_load_global(b, 1, 32, nir_undef(b, 1, 64));
+   nir_def *limited_negative = nir_imin(b, unknown, nir_imm_int(b, -4));
+   nir_def *folded_min = nir_imin(b, limited_negative, nir_imm_int(b, -2));
+   nir_def *limited_positive = nir_imax(b, unknown, nir_imm_int(b, 4));
+   nir_def *folded_max = nir_imax(b, limited_positive, nir_imm_int(b, 2));
+   nir_def *use_min = nir_iadd_imm(b, folded_min, 1);
+   nir_def *use_max = nir_iadd_imm(b, folded_max, 1);
+   nir_alu_instr *use_min_alu = nir_def_as_alu(use_min);
+   nir_alu_instr *use_max_alu = nir_def_as_alu(use_max);
+
+   nir_opt_uub_options options = {};
+   EXPECT_TRUE(nir_opt_uub(b->shader, &options));
+   EXPECT_EQ(use_min_alu->src[0].src.ssa, limited_negative);
+   EXPECT_EQ(use_max_alu->src[0].src.ssa, limited_positive);
+}
+
+TEST_F(signed_bound_test, opt_uub_signed_compare)
+{
+   nir_def *unknown = nir_load_global(b, 1, 32, nir_undef(b, 1, 64));
+   nir_def *limited_negative = nir_imin(b, unknown, nir_imm_int(b, -4));
+   nir_def *limited_positive = nir_imax(b, unknown, nir_imm_int(b, 4));
+   nir_def *lt_zero = nir_ilt(b, limited_negative, nir_imm_int(b, 0));
+   nir_def *ge_zero = nir_ige(b, limited_positive, nir_imm_int(b, 0));
+   nir_def *lt_result = nir_bcsel(b, lt_zero, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_def *ge_result = nir_bcsel(b, ge_zero, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_alu_instr *lt_result_alu = nir_def_as_alu(lt_result);
+   nir_alu_instr *ge_result_alu = nir_def_as_alu(ge_result);
+
+   nir_opt_uub_options options = {};
+   EXPECT_TRUE(nir_opt_uub(b->shader, &options));
+   EXPECT_TRUE(nir_src_is_const(lt_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(lt_result_alu->src[0].src), 1u);
+   EXPECT_TRUE(nir_src_is_const(ge_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(ge_result_alu->src[0].src), 1u);
+}
+
+TEST_F(signed_bound_test, opt_uub_signed_operand_relations)
+{
+   nir_def *unknown8 = nir_load_global(b, 1, 8, nir_undef(b, 1, 64));
+   nir_def *unknown32 = nir_load_global(b, 1, 32, nir_undef(b, 1, 64));
+   nir_def *low = nir_i2i32(b, unknown8);
+   nir_def *high = nir_imax(b, unknown32, nir_imm_int(b, 256));
+   nir_def *higher = nir_imax(b, unknown32, nir_imm_int(b, 2));
+   nir_def *sign = nir_isign(b, unknown32);
+   nir_def *less = nir_ilt(b, low, high);
+   nir_def *greater_equal = nir_ige(b, high, low);
+   nir_def *equal = nir_ieq(b, sign, higher);
+   nir_def *not_equal = nir_ine(b, sign, higher);
+   nir_def *minimum = nir_imin(b, low, high);
+   nir_def *maximum = nir_imax(b, low, high);
+   nir_def *less_result = nir_bcsel(b, less, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_def *greater_equal_result =
+      nir_bcsel(b, greater_equal, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_def *equal_result = nir_bcsel(b, equal, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_def *not_equal_result = nir_bcsel(b, not_equal, nir_imm_int(b, 1), nir_imm_int(b, 0));
+   nir_def *minimum_use = nir_iadd_imm(b, minimum, 1);
+   nir_def *maximum_use = nir_iadd_imm(b, maximum, 1);
+   nir_alu_instr *less_result_alu = nir_def_as_alu(less_result);
+   nir_alu_instr *greater_equal_result_alu = nir_def_as_alu(greater_equal_result);
+   nir_alu_instr *equal_result_alu = nir_def_as_alu(equal_result);
+   nir_alu_instr *not_equal_result_alu = nir_def_as_alu(not_equal_result);
+   nir_alu_instr *minimum_use_alu = nir_def_as_alu(minimum_use);
+   nir_alu_instr *maximum_use_alu = nir_def_as_alu(maximum_use);
+
+   nir_opt_uub_options options = {};
+   EXPECT_TRUE(nir_opt_uub(b->shader, &options));
+   EXPECT_TRUE(nir_src_is_const(less_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(less_result_alu->src[0].src), 1u);
+   EXPECT_TRUE(nir_src_is_const(greater_equal_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(greater_equal_result_alu->src[0].src), 1u);
+   EXPECT_TRUE(nir_src_is_const(equal_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(equal_result_alu->src[0].src), 0u);
+   EXPECT_TRUE(nir_src_is_const(not_equal_result_alu->src[0].src));
+   EXPECT_EQ(nir_src_as_uint(not_equal_result_alu->src[0].src), 1u);
+   EXPECT_EQ(minimum_use_alu->src[0].src.ssa, low);
+   EXPECT_EQ(maximum_use_alu->src[0].src.ssa, high);
+}
