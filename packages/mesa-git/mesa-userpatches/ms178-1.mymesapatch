+   const uint32_t old_size = vector->size;
+   const uint32_t size = old_size * 2;
+   void *data = malloc(size);
+   if (data == NULL)
+      return NULL;
+
+   const uint32_t src_tail = vector->tail & (old_size - 1);
+   const uint32_t dst_tail = vector->tail & (size - 1);
+   if (src_tail == 0) {
+      memcpy((char *)data + dst_tail, vector->data, old_size);
+   } else {
+      const uint32_t split = align(vector->tail, old_size);
+      assert(vector->tail <= split && split < vector->head);
+      memcpy((char *)data + dst_tail, (char *)vector->data + src_tail,
