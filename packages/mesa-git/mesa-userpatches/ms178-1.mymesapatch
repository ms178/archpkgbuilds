+static void
+radv_emit_descriptor_heaps_per_stage(const struct radv_physical_device *pdev, struct radv_cmd_stream *cs,
+                                     const struct radv_shader *shader, uint32_t dirty_valid_heaps,
+                                     uint64_t descriptor_heaps[RADV_MAX_HEAPS])
+{
+   const struct radv_userdata_locations *locs = &shader->info.user_sgprs_locs;
+   const uint32_t sh_base = shader->info.user_data_0;
+   unsigned mask = locs->descriptor_heaps_enabled & dirty_valid_heaps;
+
+   while (mask) {
+      int start, count;
+
+      u_bit_scan_consecutive_range(&mask, &start, &count);
+
+      const struct radv_userdata_info *loc = &locs->descriptor_heaps[start];
+      const unsigned sh_offset = sh_base + (unsigned)loc->sgpr_idx * 4u;
+
+      radeon_begin(cs);
+      if (pdev->info.gfx_level >= GFX12) {
+         for (int i = 0; i < count; i++) {
+            const uint64_t va = descriptor_heaps[start + i];
+            gfx12_push_sh_reg(sh_offset + (unsigned)i * 4u, va);
+         }
+      } else {
+         radeon_set_sh_reg_seq(sh_offset, count);
+
+         for (int i = 0; i < count; i++) {
+            const uint64_t va = descriptor_heaps[start + i];
+            radeon_emit(va);
+         }
+      }
+      radeon_end();
+   }
+}
+
+ALWAYS_INLINE static void
+radv_flush_descriptor_heaps(struct radv_cmd_buffer *cmd_buffer, VkShaderStageFlags stages,
+                            VkPipelineBindPoint bind_point)
+{
+   struct radv_descriptor_state *descriptors_state = radv_get_descriptors_state(cmd_buffer, bind_point);
+   struct radv_device *device = radv_cmd_buffer_device(cmd_buffer);
+   const struct radv_physical_device *pdev = radv_device_physical(device);
+   struct radv_cmd_stream *cs = cmd_buffer->cs;
+   const uint32_t dirty_valid_heaps = descriptors_state->dirty_heaps & descriptors_state->valid_heaps;
+
+   if (!dirty_valid_heaps)
+      return;
+
+   const struct radv_shader *task_shader =
+      stages & VK_SHADER_STAGE_TASK_BIT_EXT ? cmd_buffer->state.shaders[MESA_SHADER_TASK] : NULL;
+   const bool task_uses_dirty_heaps =
+      task_shader && (task_shader->info.user_sgprs_locs.descriptor_heaps_enabled & dirty_valid_heaps);
+
+   ASSERTED unsigned cdw_max = radeon_check_space(device->ws, cs->b,
+                                                  RADV_MAX_HEAPS * MESA_VULKAN_SHADER_STAGES * 4);
+   assert(!task_uses_dirty_heaps || cmd_buffer->gang.cs);
+
+   if (stages & VK_SHADER_STAGE_COMPUTE_BIT) {
+      const struct radv_shader *compute_shader = bind_point == VK_PIPELINE_BIND_POINT_COMPUTE
+                                                    ? cmd_buffer->state.shaders[MESA_SHADER_COMPUTE]
+                                                    : cmd_buffer->state.rt_prolog;
+
+      if (compute_shader->info.user_sgprs_locs.descriptor_heaps_enabled & dirty_valid_heaps)
+         radv_emit_descriptor_heaps_per_stage(pdev, cs, compute_shader, dirty_valid_heaps,
+                                              cmd_buffer->descriptor_heaps);
+   } else {
+      radv_foreach_stage (stage, stages & ~VK_SHADER_STAGE_TASK_BIT_EXT) {
+         const struct radv_shader *shader = cmd_buffer->state.shaders[stage];
+         if (!shader || !(shader->info.user_sgprs_locs.descriptor_heaps_enabled & dirty_valid_heaps))
+            continue;
+
+         radv_emit_descriptor_heaps_per_stage(pdev, cs, shader, dirty_valid_heaps, cmd_buffer->descriptor_heaps);
+      }
+
+      if (task_uses_dirty_heaps) {
+         assert(cmd_buffer->gang.cs);
+         radv_emit_descriptor_heaps_per_stage(pdev, cmd_buffer->gang.cs, task_shader, dirty_valid_heaps,
+                                              cmd_buffer->descriptor_heaps);
+      }
+   }
+
+   assert(cs->b->cdw <= cdw_max);
+}
