+static bool
+is_smem_load(aco_opcode opcode)
+{
+   switch (opcode) {
+   case aco_opcode::s_load_dword: case aco_opcode::s_load_dwordx2:
+   case aco_opcode::s_load_dwordx3: case aco_opcode::s_load_dwordx4:
+   case aco_opcode::s_load_dwordx8: case aco_opcode::s_load_dwordx16:
+   case aco_opcode::s_buffer_load_dword: case aco_opcode::s_buffer_load_dwordx2:
+   case aco_opcode::s_buffer_load_dwordx3: case aco_opcode::s_buffer_load_dwordx4:
+   case aco_opcode::s_buffer_load_dwordx8: case aco_opcode::s_buffer_load_dwordx16:
+      return true;
+   default: return false;
+   }
+}
