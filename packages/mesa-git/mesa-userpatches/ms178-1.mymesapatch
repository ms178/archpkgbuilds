+   memcpy(&a0, a + 0,  sizeof(a0));
+   memcpy(&a1, a + 8,  sizeof(a1));
+   memcpy(&a2, a + 16, sizeof(a2));
+   memcpy(&a3, a + 24, sizeof(a3));
+   memcpy(&b0, b + 0,  sizeof(b0));
