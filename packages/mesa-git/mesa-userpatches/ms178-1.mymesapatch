+void
+finish_spill_test(unsigned sgpr_limit, unsigned vgpr_limit)
+{
+   finish_program(program.get(), true, true);
+   if (!aco::validate_ir(program.get())) { fail_test("Validation before spilling failed"); return; }
+   program->workgroup_size = program->wave_size;
+   program->min_waves = 1;
+   if (sgpr_limit) program->dev.sgpr_limit = sgpr_limit;
+   if (vgpr_limit) program->dev.vgpr_limit = vgpr_limit;
+   aco::live_var_analysis(program.get());
+   if (program->num_waves != 0) { fail_test("Insufficient test pressure"); return; }
+   aco::spill(program.get());
+   if (!aco::validate_ir(program.get())) { fail_test("Validation after spilling failed"); return; }
+   aco_print_program(program.get(), output);
+}
