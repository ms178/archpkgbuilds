diff --git a/src/amd/common/nir/ac_nir_lower_global_access.c b/src/amd/common/nir/ac_nir_lower_global_access.c
index 5ef1783eb6b26152dd1d7808000951d4e3b087aa..50263385a71b042a001848d2488de78bac1a17cb 100644
--- a/src/amd/common/nir/ac_nir_lower_global_access.c
+++ b/src/amd/common/nir/ac_nir_lower_global_access.c
@@ -239,6 +239,17 @@ process_instr(nir_builder *b, nir_intrinsic_instr *intrin, void *s)
 
    state->b = b;
    uint32_t bit_size = op == nir_intrinsic_store_global_amd ? intrin->src[0].ssa->bit_size : intrin->def.bit_size;
+   const unsigned bytes_needed = intrin->num_components * bit_size / 8;
+
+   /* Scalar byte/halfword loads exist only on GFX12+. Do not carry SMEM
+    * selection through this late global lowering on older hardware: an
+    * address rewrite can expose a sub-dword load after the earlier generic
+    * memory-bit-size pass has already run. Keep it as a legal VMEM access
+    * rather than creating an unencodable ACO SMEM opcode. A multi-component
+    * 16-bit load totaling a dword remains a legal SMEM dword load. */
+   if (is_smem && state->gfx_level < GFX12 && bytes_needed < 4)
+      is_smem = false;
+
    state->required_align = !is_smem ? 1 : bit_size >= 32 ? 4 : bit_size / 8;
