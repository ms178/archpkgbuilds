+BEGIN_TEST(assembler.gfx9_fetch_align.loop_run)
+   if (!setup_cs(NULL,GFX9)) return;
+   program->blocks[0].loop_nest_depth=1;
+   //! BB0:
+   //! s_nop 0 ; bf800000
+   //!(then repeated 1 times)
+   bld.sopp(aco_opcode::s_nop,0);
+   //! v_bfi_b32 v0, v1, v2, v3 ; d1ca0000 040e0501
+   //!(then repeated 7 times)
+   for(unsigned i=0;i<8;i++) bld.vop3(aco_opcode::v_bfi_b32,Definition(PhysReg(256),v1),Operand(PhysReg(257),v1),Operand(PhysReg(258),v1),Operand(PhysReg(259),v1));
+   finish_assembler_test();
+END_TEST
+
+BEGIN_TEST(assembler.gfx9_fetch_align.branch_target)
+   if (!setup_cs(NULL,GFX9)) return;
+   //! BB0:
+   //! s_branch BB1 ; bf820000
+   bld.sopp(aco_opcode::s_branch,1);bld.reset(program->create_and_insert_block());program->blocks[1].linear_preds.push_back(0);program->blocks[1].loop_nest_depth=1;
+   //! BB1:
+   //! s_nop 0 ; bf800000
+   //! v_bfi_b32 v0, v1, v2, v3 ; d1ca0000 040e0501
+   //!(then repeated 7 times)
+   for(unsigned i=0;i<8;i++) bld.vop3(aco_opcode::v_bfi_b32,Definition(PhysReg(256),v1),Operand(PhysReg(257),v1),Operand(PhysReg(258),v1),Operand(PhysReg(259),v1));
+   finish_assembler_test();
+END_TEST
+
+BEGIN_TEST(assembler.gfx9_fetch_align.non_loop)
+   if (!setup_cs(NULL,GFX9)) return;
+   //! BB0:
+   //! s_nop 0 ; bf800000
+   bld.sopp(aco_opcode::s_nop,0);
+   //! v_bfi_b32 v0, v1, v2, v3 ; d1ca0000 040e0501
+   //!(then repeated 7 times)
+   for(unsigned i=0;i<8;i++) bld.vop3(aco_opcode::v_bfi_b32,Definition(PhysReg(256),v1),Operand(PhysReg(257),v1),Operand(PhysReg(258),v1),Operand(PhysReg(259),v1));
+   finish_assembler_test();
+END_TEST
+
 BEGIN_TEST(assembler.branch_3f)
    if (!setup_cs(NULL, (amd_gfx_level)GFX10))
       return;
