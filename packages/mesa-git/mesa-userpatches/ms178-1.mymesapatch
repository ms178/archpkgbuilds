diff --git a/bin/symbols-check.py b/bin/symbols-check.py
index 5a14fa8b24e79c1195f70dc8b5daab0f31eebfde..8c1258c7679c6a932826c27d3449337376a55db6 100644
--- a/bin/symbols-check.py
+++ b/bin/symbols-check.py
@@ -88,7 +88,11 @@ def get_symbols_nm(nm, lib):
         if line.startswith(' '):
             continue
         fields = line.split()
-        if len(fields) >= 2 and fields[1] == 'U':
+        # Skip undefined symbols. Besides the regular 'U', nm may print
+        # weak undefined symbols as lowercase 'w' or 'v' (for example optional
+        # trace hooks pulled from static compression libraries by LLVM). These
+        # are imports, not exported ABI.
+        if len(fields) >= 2 and fields[1] in ['U', 'w', 'v']:
             continue
         symbol_name = fields[0]
         if platform_name == 'Linux' or platform_name == 'GNU' or platform_name.startswith('GNU/'):
