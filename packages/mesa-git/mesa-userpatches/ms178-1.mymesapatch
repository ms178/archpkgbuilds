+BEGIN_TEST(isel.gfx9_signed_mul24_range)
+   if (!set_variant(GFX9))
+      return;
+
+   QoShaderModuleCreateInfo cs = qoShaderModuleCreateInfoGLSL(COMPUTE,
+      layout(local_size_x = 64) in;
+      layout(std430, binding = 0) readonly buffer In {
+         int value[];
+      } src;
+      layout(std430, binding = 1) buffer Out {
+         int value[];
+      } dst;
+      void main() {
+         uint index = gl_LocalInvocationID.x;
+         int x = clamp(src.value[2 * index], -32, 32);
+         int y = clamp(src.value[2 * index + 1], -32, 32);
+         //>> v1: %mul = v_mul_i32_i24 (kill)%_, (kill)%_
+         dst.value[index] = x * y;
+      }
+   );
+
+   PipelineBuilder pbld(get_vk_device(GFX9));
+   pbld.add_cs(cs);
+   pbld.print_ir(VK_SHADER_STAGE_COMPUTE_BIT, "ACO IR", true);
+   pbld.print_ir(VK_SHADER_STAGE_COMPUTE_BIT, "Assembly", true);
+END_TEST
+
