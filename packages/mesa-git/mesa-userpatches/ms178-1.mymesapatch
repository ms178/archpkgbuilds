+BEGIN_TEST(isel.shfr.const16.scalar_pack_gfx9)
+   for (amd_gfx_level gfx : {GFX9, GFX10}) {
+      if (!setup_nir_cs(gfx))
+         continue;
+
+      nir_def* src0 = nir_unit_test_uniform_input(nb, 1, 32, 0);
+      nir_def* src1 = nir_unit_test_uniform_input(nb, 1, 32, 1);
+
+      //>> p_startpgm
+      //>> s1: %src0 = p_unit_test 0
+      //! s1: %src1 = p_unit_test 1
+      //>> s1: %res0 = s_pack_ll_b32_b16 0x1234, %src0
+      //! p_unit_test 2, %res0
+      nir_def* res0 = nir_build_alu3(nb, nir_op_shfr, src0, nir_imm_int(nb, 0x12345678),
+                                     nir_imm_int(nb, 16));
+      nir_unit_test_output(nb, res0, 2);
+
+      //>> s1: %res1 = s_pack_hh_b32_b16 %src1, 0xcdef0000
+      //! p_unit_test 3, %res1
+      nir_def* res1 = nir_build_alu3(nb, nir_op_shfr, nir_imm_int(nb, 0x89abcdef), src1,
+                                     nir_imm_int(nb, 16));
+      nir_unit_test_output(nb, res1, 3);
+
+      //>> s_endpgm
+      finish_isel_test();
+   }
+END_TEST
