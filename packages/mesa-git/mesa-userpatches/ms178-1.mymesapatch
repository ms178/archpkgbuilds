+static void
+replace_with_copy(opt_ctx& ctx, aco_ptr<Instruction>& instr, Operand src)
+{
+   for (const Operand& op : instr->operands) {
+      if (op.isTemp())
+         ctx.uses[op.tempId()]--;
+   }
+   if (src.isTemp())
+      ctx.uses[src.tempId()]++;
+
+   aco_ptr<Instruction> copy{create_instruction(aco_opcode::p_parallelcopy, Format::PSEUDO, 1, 1)};
+   copy->operands[0] = src;
+   copy->definitions[0] = instr->definitions[0];
+   copy->pass_flags = instr->pass_flags;
+   instr = std::move(copy);
+   ctx.info[instr->definitions[0].tempId()].parent_instr = instr.get();
+}
+
+static void
+replace_with_minmax(opt_ctx& ctx, aco_ptr<Instruction>& instr, aco_opcode new_opcode, Operand a,
+                    Operand b)
+{
+   for (const Operand& op : instr->operands) {
+      if (op.isTemp())
+         ctx.uses[op.tempId()]--;
+   }
+   if (a.isTemp())
+      ctx.uses[a.tempId()]++;
+   if (b.isTemp())
+      ctx.uses[b.tempId()]++;
+
+   aco_ptr<Instruction> new_instr{create_instruction(new_opcode, Format::VOP2, 2, 1)};
+   new_instr->operands[0] = a;
+   new_instr->operands[1] = b;
+   new_instr->definitions[0] = instr->definitions[0];
+   new_instr->pass_flags = instr->pass_flags;
+   instr = std::move(new_instr);
+   ctx.info[instr->definitions[0].tempId()].parent_instr = instr.get();
+}
+
+static aco_opcode
+minmax2_opcode(aco_opcode opcode)
+{
+   switch (opcode) {
+   case aco_opcode::v_min3_u32: return aco_opcode::v_min_u32;
+   case aco_opcode::v_max3_u32: return aco_opcode::v_max_u32;
+   case aco_opcode::v_min3_i32: return aco_opcode::v_min_i32;
+   case aco_opcode::v_max3_i32: return aco_opcode::v_max_i32;
+   default: return aco_opcode::num_opcodes;
+   }
+}
+
+static bool
+operand_is_u32_constant(const Operand& op, uint32_t value)
+{
+   return op.isConstant() && op.constantValue() == value;
+}
+
+static bool
+copy_if_operand_is_constant(aco_ptr<Instruction>& instr, uint32_t constant, unsigned value_idx)
+{
+   if (operand_is_u32_constant(instr->operands[0], constant) && !instr->operands[1].isConstant())
+      return value_idx == 1;
+   if (operand_is_u32_constant(instr->operands[1], constant) && !instr->operands[0].isConstant())
+      return value_idx == 0;
+   return false;
+}
+
+static bool
+constant_if_any_operand(aco_ptr<Instruction>& instr, uint32_t constant)
+{
+   return operand_is_u32_constant(instr->operands[0], constant) ||
+          operand_is_u32_constant(instr->operands[1], constant);
+}
+
+/* Replace a 2-src VALU multiply with v_lshlrev_b32 (full-rate on Vega).
+ * Decrements use counts of all original operands and increments the kept value.
+ */
+static void
+replace_with_lshl(opt_ctx& ctx, aco_ptr<Instruction>& instr, Operand value, uint32_t shift)
+{
+   for (const Operand& op : instr->operands) {
+      if (op.isTemp())
+         ctx.uses[op.tempId()]--;
+   }
+   if (value.isTemp())
+      ctx.uses[value.tempId()]++;
+
+   aco_ptr<Instruction> new_instr{create_instruction(aco_opcode::v_lshlrev_b32, Format::VOP2, 2, 1)};
+   new_instr->operands[0] = Operand::c32(shift);
+   new_instr->operands[1] = value;
+   new_instr->definitions[0] = instr->definitions[0];
+   new_instr->pass_flags = instr->pass_flags;
+   instr = std::move(new_instr);
+   ctx.info[instr->definitions[0].tempId()].parent_instr = instr.get();
+}
+
+/* v_mul_lo_u32 is quarter-rate on all GCN/RDNA generations through GFX11.  A power-of-two
+ * multiplier is an exact left shift, which is full-rate VOP2 on Vega.  Catching this late
+ * matters when constant propagation only reveals the power-of-two after earlier ACO passes.
+ */
+static bool
+operand_u32_constant_value(opt_ctx& ctx, Operand op, uint32_t* value)
+{
+   if (op.isConstant()) {
+      *value = op.constantValue();
+      return true;
+   }
+
+   if (!op.isTemp())
+      return false;
+
+   /* Follow temp/constant labels so SGPR parallelcopies of large immediates still fold. */
+   unsigned id = op.tempId();
+   if (ctx.info[id].is_temp())
+      id = ctx.info[id].temp.id();
+
+   if (!ctx.info[id].is_constant())
+      return false;
+
+   *value = (uint32_t)ctx.info[id].val;
+   return true;
+}
+
+static bool
+try_mul_power_of_two_to_lshl(opt_ctx& ctx, aco_ptr<Instruction>& instr)
+{
+   if (instr->operands.size() != 2 || instr->isDPP() || instr->isSDWA())
+      return false;
+
+   if (instr->isVALU() && instr->valu().usesModifiers())
+      return false;
+
+   uint32_t factor0 = 0, factor1 = 0;
+   const bool c0 = operand_u32_constant_value(ctx, instr->operands[0], &factor0);
+   const bool c1 = operand_u32_constant_value(ctx, instr->operands[1], &factor1);
+
+   Operand value;
+   uint32_t factor = 0;
+   if (c0 && !c1) {
+      factor = factor0;
+      value = instr->operands[1];
+   } else if (c1 && !c0) {
+      factor = factor1;
+      value = instr->operands[0];
+   } else {
+      return false;
+   }
+
+   /* Only positive powers of two in [2, 2^31].  factor==1 is handled by the identity path;
+    * factor==0 is handled by the zero path.  2^31 is a valid unsigned left shift by 31.
+    */
+   if (factor < 2 || !util_is_power_of_two_nonzero(factor))
+      return false;
+
+   replace_with_lshl(ctx, instr, value, util_logbase2(factor));
+   return true;
+}
+
+/* Vega-targeted late VALU peepholes.
+ *
+ * Keep these transforms semantics-proof. Bitwise identities, cndmask(a, a, cond), unsigned/integer
+ * subtraction x - x, integer min/max/median duplicate collapses, and bitwise/shift/add/multiply
+ * identities with constants are exact. Avoid floating-point x - x/min/max/median folds here: NaN and
+ * signed-zero preservation require more context than this late peephole has.
+ *
+ * On Vega/GFX9 this is more than cosmetic: v_mul_{lo,hi}_u32 are quarter-rate VALU instructions,
+ * while the bitwise/shift/add identities remove ordinary VALU issue pressure and free VGPR live
+ * ranges before RA.
+ */
+static void
+try_peephole_salu_mul_shift(opt_ctx& ctx, aco_ptr<Instruction>& instr)
+{
+   if (!instr.get() || !instr->isSALU())
+      return;
+   if (instr->opcode != aco_opcode::s_mul_i32 || instr->operands.size() != 2)
+      return;
+   /* s_mul_i32 has a single definition (no SCC). s_lshl_b32 writes SCC as well, so only
+    * convert when we can allocate a dead SCC temp or when the mul already has room.
+    */
+   uint32_t factor0 = 0, factor1 = 0;
+   const bool c0 = operand_u32_constant_value(ctx, instr->operands[0], &factor0);
+   const bool c1 = operand_u32_constant_value(ctx, instr->operands[1], &factor1);
+   Operand value;
+   uint32_t factor = 0;
+   if (c0 && !c1) {
+      factor = factor0;
+      value = instr->operands[1];
+   } else if (c1 && !c0) {
+      factor = factor1;
+      value = instr->operands[0];
+   } else {
+      return;
+   }
+   if (factor < 2 || !util_is_power_of_two_nonzero(factor))
+      return;
+
+   for (const Operand& op : instr->operands) {
+      if (op.isTemp())
+         ctx.uses[op.tempId()]--;
+   }
+   if (value.isTemp())
+      ctx.uses[value.tempId()]++;
+
+   Temp scc_tmp = ctx.program->allocateTmp(s1);
+   if (ctx.info.size() <= scc_tmp.id()) {
+      ctx.info.resize(scc_tmp.id() + 1);
+      ctx.uses.resize(scc_tmp.id() + 1);
+   }
+   ctx.uses[scc_tmp.id()] = 0;
+
+   aco_ptr<Instruction> shl{
+      create_instruction(aco_opcode::s_lshl_b32, Format::SOP2, 2, 2)};
+   /* s_lshl_b32: src0=value, src1=shift */
+   shl->operands[0] = value;
+   shl->operands[1] = Operand::c32(util_logbase2(factor));
+   shl->definitions[0] = instr->definitions[0];
+   shl->definitions[1] = Definition(scc_tmp, scc);
+   shl->pass_flags = instr->pass_flags;
+   instr = std::move(shl);
+   ctx.info[instr->definitions[0].tempId()].parent_instr = instr.get();
+   ctx.info[instr->definitions[1].tempId()].parent_instr = instr.get();
+}
+
+static void
+try_peephole_redundant(opt_ctx& ctx, aco_ptr<Instruction>& instr)
+{
+   if (!instr.get())
+      return;
+   if (instr->isSALU()) {
+      try_peephole_salu_mul_shift(ctx, instr);
+      return;
+   }
+   if (!instr->isVALU())
+      return;
+
+   if (instr->isDPP() || instr->isSDWA())
+      return;
+
+   VALU_instruction& valu = instr->valu();
+   if (valu.clamp || valu.omod)
+      return;
+
+   auto no_mod = [&](unsigned idx) { return !valu.neg[idx] && !valu.abs[idx]; };
+   auto all_no_mod = [&]() {
+      for (unsigned i = 0; i < instr->operands.size(); ++i) {
+         if (!no_mod(i))
+            return false;
+      }
+      return true;
+   };
+
+   if (!all_no_mod())
+      return;
+
+   switch (instr->opcode) {
+   case aco_opcode::v_and_b32:
+      if (instr->operands.size() == 2 && instr->operands[0] == instr->operands[1]) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      } else if (instr->operands.size() == 2 && constant_if_any_operand(instr, 0)) {
+         replace_with_copy(ctx, instr, Operand::zero(instr->definitions[0].bytes()));
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, UINT32_MAX, 0)) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, UINT32_MAX, 1)) {
+         replace_with_copy(ctx, instr, instr->operands[1]);
+      }
+      break;
+
+   case aco_opcode::v_or_b32:
+      if (instr->operands.size() == 2 && instr->operands[0] == instr->operands[1]) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      } else if (instr->operands.size() == 2 && constant_if_any_operand(instr, UINT32_MAX)) {
+         replace_with_copy(ctx, instr, Operand::c32(UINT32_MAX));
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, 0, 0)) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, 0, 1)) {
+         replace_with_copy(ctx, instr, instr->operands[1]);
+      }
+      break;
+
+   case aco_opcode::v_xor_b32:
+      if (instr->operands.size() == 2 && instr->operands[0] == instr->operands[1]) {
+         replace_with_copy(ctx, instr, Operand::zero(instr->definitions[0].bytes()));
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, 0, 0)) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, 0, 1)) {
+         replace_with_copy(ctx, instr, instr->operands[1]);
+      }
+      break;
+
+   case aco_opcode::v_add_u32:
+      if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, 0, 0)) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, 0, 1)) {
+         replace_with_copy(ctx, instr, instr->operands[1]);
+      }
+      break;
+
+   case aco_opcode::v_sub_u32:
+      if (instr->operands.size() == 2 && instr->operands[0] == instr->operands[1]) {
+         replace_with_copy(ctx, instr, Operand::zero(instr->definitions[0].bytes()));
+      } else if (instr->operands.size() == 2 && operand_is_u32_constant(instr->operands[1], 0)) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      }
+      break;
+
+   case aco_opcode::v_subrev_u32:
+      if (instr->operands.size() == 2 && instr->operands[0] == instr->operands[1]) {
+         replace_with_copy(ctx, instr, Operand::zero(instr->definitions[0].bytes()));
+      } else if (instr->operands.size() == 2 && operand_is_u32_constant(instr->operands[0], 0)) {
+         replace_with_copy(ctx, instr, instr->operands[1]);
+      }
+      break;
+
+   case aco_opcode::v_lshlrev_b32:
+   case aco_opcode::v_lshrrev_b32:
+   case aco_opcode::v_ashrrev_i32:
+      if (instr->operands.size() == 2 && operand_is_u32_constant(instr->operands[0], 0))
+         replace_with_copy(ctx, instr, instr->operands[1]);
+      break;
+
+   case aco_opcode::v_mul_lo_u32:
+   case aco_opcode::v_mul_lo_i32:
+      if (instr->operands.size() == 2 && constant_if_any_operand(instr, 0)) {
+         replace_with_copy(ctx, instr, Operand::zero(instr->definitions[0].bytes()));
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, 1, 0)) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      } else if (instr->operands.size() == 2 && copy_if_operand_is_constant(instr, 1, 1)) {
+         replace_with_copy(ctx, instr, instr->operands[1]);
+      } else if (try_mul_power_of_two_to_lshl(ctx, instr)) {
+         /* Quarter-rate mul replaced by full-rate lshl. */
+      }
+      break;
+
+   case aco_opcode::v_mul_hi_u32:
+      if (instr->operands.size() == 2 &&
+          (constant_if_any_operand(instr, 0) || constant_if_any_operand(instr, 1)))
+         replace_with_copy(ctx, instr, Operand::zero(instr->definitions[0].bytes()));
+      break;
+
+   case aco_opcode::v_cndmask_b32:
+   case aco_opcode::v_cndmask_b16:
+      if (instr->operands.size() == 3 && instr->operands[0] == instr->operands[1])
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      break;
+
+   case aco_opcode::v_min_u32:
+   case aco_opcode::v_max_u32:
+   case aco_opcode::v_min_i32:
+   case aco_opcode::v_max_i32:
+      if (instr->operands.size() == 2 && instr->operands[0] == instr->operands[1])
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      break;
+
+   case aco_opcode::v_min3_u32:
+   case aco_opcode::v_max3_u32:
+   case aco_opcode::v_min3_i32:
+   case aco_opcode::v_max3_i32: {
+      if (instr->operands.size() != 3)
+         break;
+
+      if (instr->operands[0] == instr->operands[1] && instr->operands[0] == instr->operands[2]) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+         break;
+      }
+
+      const aco_opcode opcode = minmax2_opcode(instr->opcode);
+      assert(opcode != aco_opcode::num_opcodes);
+      if (instr->operands[0] == instr->operands[1]) {
+         replace_with_minmax(ctx, instr, opcode, instr->operands[0], instr->operands[2]);
+      } else if (instr->operands[0] == instr->operands[2]) {
+         replace_with_minmax(ctx, instr, opcode, instr->operands[0], instr->operands[1]);
+      } else if (instr->operands[1] == instr->operands[2]) {
+         replace_with_minmax(ctx, instr, opcode, instr->operands[0], instr->operands[1]);
+      }
+      break;
+   }
+
+   case aco_opcode::v_med3_u32:
+   case aco_opcode::v_med3_i32:
+      if (instr->operands.size() != 3)
+         break;
+      if (instr->operands[0] == instr->operands[1] || instr->operands[0] == instr->operands[2]) {
+         replace_with_copy(ctx, instr, instr->operands[0]);
+      } else if (instr->operands[1] == instr->operands[2]) {
+         replace_with_copy(ctx, instr, instr->operands[1]);
+      }
+      break;
+
+   default:
+      break;
+   }
+}
