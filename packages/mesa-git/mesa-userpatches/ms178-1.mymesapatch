    get_phi_query(state, q, result, src, max2, bitmask(q.scalar.def->bit_size));
 }
 
+static int32_t
+signed_bound_default(unsigned bit_size, bool upper)
+{
+   assert(bit_size <= 32);
+   if (bit_size == 32)
+      return upper ? INT32_MAX : INT32_MIN;
+
+   const int32_t bound = 1 << (bit_size - 1);
+   return upper ? bound - 1 : -bound;
+}
+
+static uint32_t
+signed_min(uint32_t a, uint32_t b)
+{
+   return (int32_t)a < (int32_t)b ? a : b;
+}
+
+static uint32_t
+signed_max(uint32_t a, uint32_t b)
+{
+   return (int32_t)a > (int32_t)b ? a : b;
+}
+
+static bool
+get_alu_const_src(nir_scalar scalar, nir_scalar *constant)
+{
+   const nir_op op = nir_scalar_alu_op(scalar);
+
+   for (unsigned i = 0; i < nir_op_infos[op].num_inputs; i++) {
+      nir_scalar src = nir_scalar_chase_alu_src(scalar, i);
+      if (nir_scalar_is_const(src)) {
+         *constant = src;
+         return true;
+      }
+   }
+
+   return false;
+}
+
+/* Conservative signed one-sided bounds.  Keep this deliberately small: every
+ * transfer function below is exact under NIR's integer semantics, while an
+ * unsupported operation returns the signed type extrema. */
+static void
+get_alu_signed_bound(struct analysis_state *state, struct scalar_query q, uint32_t *result,
+                     const uint32_t *src, bool upper)
+{
+   const nir_op op = nir_scalar_alu_op(q.scalar);
+
+   switch (op) {
+   case nir_op_mov:
+   case nir_op_imin:
+   case nir_op_imax:
+   case nir_op_bcsel:
+   case nir_op_b32csel:
+      break;
+   case nir_op_extract_u8:
+      if (q.scalar.def->bit_size > 8)
+         *result = upper ? UINT8_MAX : 0;
+      return;
+   case nir_op_extract_i8:
+      *result = (uint32_t)signed_bound_default(8, upper);
+      return;
+   case nir_op_extract_u16:
+      if (q.scalar.def->bit_size > 16)
+         *result = upper ? UINT16_MAX : 0;
+      return;
+   case nir_op_extract_i16:
+      *result = (uint32_t)signed_bound_default(16, upper);
+      return;
+   case nir_op_isign:
+      *result = upper ? 1 : -1;
+      return;
+   case nir_op_uadd_carry:
+   case nir_op_usub_borrow:
+      *result = upper ? 1 : 0;
+      return;
+   case nir_op_udiv_aligned_4:
+      *result = upper ? bitmask(q.scalar.def->bit_size > 2 ? q.scalar.def->bit_size - 2 : 0) : 0;
+      return;
+   case nir_op_ubitfield_extract:
+   case nir_op_ibitfield_extract: {
+      nir_scalar bits_src = nir_scalar_chase_alu_src(q.scalar, 2);
+      if (!nir_scalar_is_const(bits_src))
+         return;
+
+      const int32_t bits = nir_scalar_as_int(bits_src);
+      if (bits <= 0) {
+         *result = 0;
+      } else if ((unsigned)bits < q.scalar.def->bit_size) {
+         *result = op == nir_op_ubitfield_extract
+                      ? (upper ? bitmask(bits) : 0)
+                      : (uint32_t)signed_bound_default(bits, upper);
+      }
+      return;
+   }
+   case nir_op_bit_count:
+   case nir_op_uclz:
+      *result = upper ? nir_scalar_chase_alu_src(q.scalar, 0).def->bit_size : 0;
+      return;
+   case nir_op_ufind_msb:
+   case nir_op_find_lsb:
+      *result = upper ? nir_scalar_chase_alu_src(q.scalar, 0).def->bit_size - 1 : -1;
+      return;
+   case nir_op_ifind_msb:
+      *result = upper ? q.scalar.def->bit_size - 2 : -1;
+      return;
+   case nir_op_ifind_msb_rev:
+      *result = upper ? q.scalar.def->bit_size - 1 : -1;
+      return;
+   case nir_op_iand: {
+      nir_scalar constant;
+      if (!get_alu_const_src(q.scalar, &constant))
+         return;
+
+      const uint32_t mask = nir_scalar_as_uint(constant);
+      if (!(mask & (1u << (q.scalar.def->bit_size - 1))) &&
+          q.scalar.def->bit_size > 1) {
+         *result = upper ? mask : 0;
+      }
+      return;
+   }
+   case nir_op_ior: {
+      nir_scalar constant;
+      if (!get_alu_const_src(q.scalar, &constant))
+         return;
+
+      const uint32_t mask = nir_scalar_as_uint(constant);
+      if (mask & (1u << (q.scalar.def->bit_size - 1)))
+         *result = upper ? -1 : util_sign_extend(mask, q.scalar.def->bit_size);
+      return;
+   }
+   case nir_op_b2i8:
+   case nir_op_b2i16:
+   case nir_op_b2i32:
+      *result = upper ? 1 : 0;
+      return;
+   case nir_op_i2i8:
+   case nir_op_i2i16:
+   case nir_op_i2i32: {
+      nir_scalar src = nir_scalar_chase_alu_src(q.scalar, 0);
+      if (src.def->bit_size < q.scalar.def->bit_size)
+         *result = (uint32_t)signed_bound_default(src.def->bit_size, upper);
+      return;
+   }
+   case nir_op_u2u8:
+   case nir_op_u2u16:
+   case nir_op_u2u32: {
+      nir_scalar src = nir_scalar_chase_alu_src(q.scalar, 0);
+      if (src.def->bit_size < q.scalar.def->bit_size)
+         *result = upper ? bitmask(src.def->bit_size) : 0;
+      return;
+   }
+   case nir_op_ibfe: {
+      nir_scalar bits_src = nir_scalar_chase_alu_src(q.scalar, 2);
+      if (!nir_scalar_is_const(bits_src))
+         return;
+
+      const unsigned bits = MIN2(nir_scalar_as_uint(bits_src), q.scalar.def->bit_size);
+      *result = bits ? (uint32_t)signed_bound_default(bits, upper) : 0;
+      return;
+   }
+   case nir_op_ubfe: {
+      nir_scalar bits_src = nir_scalar_chase_alu_src(q.scalar, 2);
+      if (!nir_scalar_is_const(bits_src))
+         return;
+
+      /* SM5 ubfe uses only the low five bits of its width operand. */
+      const unsigned bits = nir_scalar_as_uint(bits_src) & 0x1f;
+      *result = upper ? bitmask(bits) : 0;
+      return;
+   }
+   case nir_op_ushr: {
+      nir_scalar shift_src = nir_scalar_chase_alu_src(q.scalar, 1);
+      if (!nir_scalar_is_const(shift_src))
+         return;
+
+      const unsigned shift = nir_scalar_as_uint(shift_src) & (q.scalar.def->bit_size - 1);
+      if (shift)
+         *result = upper ? bitmask(q.scalar.def->bit_size - shift) : 0;
+      return;
+   }
+   case nir_op_ishr: {
+      nir_scalar shift_src = nir_scalar_chase_alu_src(q.scalar, 1);
+      if (!nir_scalar_is_const(shift_src))
+         return;
+
+      const unsigned shift = nir_scalar_as_uint(shift_src) & (q.scalar.def->bit_size - 1);
+      *result = (uint32_t)signed_bound_default(q.scalar.def->bit_size - shift, upper);
+      return;
+   }
+   default:
+      return;
+   }
+
+   if (!q.head.pushed_queries) {
+      for (unsigned i = 0; i < nir_op_infos[op].num_inputs; i++)
+         push_scalar_query(state, nir_scalar_chase_alu_src(q.scalar, i));
+      return;
+   }
+
+   switch (op) {
+   case nir_op_mov:
+      *result = src[0];
+      break;
+   case nir_op_imin:
+      *result = signed_min(src[0], src[1]);
+      break;
+   case nir_op_imax:
+      *result = signed_max(src[0], src[1]);
+      break;
+   case nir_op_bcsel:
+   case nir_op_b32csel:
+      *result = upper ? signed_max(src[1], src[2]) : signed_min(src[1], src[2]);
+      break;
+   default:
+      UNREACHABLE("unhandled signed bound opcode");
+   }
+}
+
+static void
+get_phi_signed_bound(struct analysis_state *state, struct scalar_query q, uint32_t *result,
+                     const uint32_t *src, bool upper)
+{
+   get_phi_query(state, q, result, src, upper ? signed_max : signed_min,
+                 (uint32_t)signed_bound_default(q.scalar.def->bit_size, upper));
+}
+
+static void
+process_signed_bound_query(struct analysis_state *state, struct analysis_query *aq, uint32_t *result,
+                           const uint32_t *src, bool upper)
+{
+   const struct scalar_query q = *(struct scalar_query *)aq;
+   *result = (uint32_t)signed_bound_default(q.scalar.def->bit_size, upper);
+
+   if (nir_scalar_is_const(q.scalar)) {
+      *result = (uint32_t)nir_scalar_as_int(q.scalar);
+   } else if (nir_scalar_is_alu(q.scalar)) {
+      get_alu_signed_bound(state, q, result, src, upper);
+   } else if (nir_def_instr_type(q.scalar.def) == nir_instr_type_phi) {
+      get_phi_signed_bound(state, q, result, src, upper);
+   }
+}
+
+static void
+process_signed_upper_bound_query(struct analysis_state *state, struct analysis_query *aq,
+                                 uint32_t *result, const uint32_t *src)
+{
+   process_signed_bound_query(state, aq, result, src, true);
+}
+
+static void
+process_signed_lower_bound_query(struct analysis_state *state, struct analysis_query *aq,
+                                 uint32_t *result, const uint32_t *src)
+{
+   process_signed_bound_query(state, aq, result, src, false);
+}
+
+static int32_t
+signed_bound(nir_shader *shader, struct hash_table *range_ht, nir_scalar scalar,
+             void (*process_query)(struct analysis_state *, struct analysis_query *, uint32_t *,
+                                   const uint32_t *))
+{
+   struct scalar_query query_alloc[16];
+   uint32_t result_alloc[16];
+
+   struct analysis_state state = {
+      .shader = shader,
+      .range_ht = range_ht,
+      .query_size = sizeof(struct scalar_query),
+      .get_key = &get_scalar_key,
+      .lookup = &scalar_lookup,
+      .insert = &scalar_insert,
+      .process_query = process_query,
+   };
+   util_dynarray_init_from_stack(&state.query_stack, query_alloc, sizeof(query_alloc));
+   util_dynarray_init_from_stack(&state.result_stack, result_alloc, sizeof(result_alloc));
+
+   push_scalar_query(&state, scalar);
+   return (int32_t)perform_analysis(&state);
+}
+
+int32_t
+nir_signed_upper_bound(nir_shader *shader, struct hash_table *range_ht, nir_scalar scalar)
+{
+   return signed_bound(shader, range_ht, scalar, process_signed_upper_bound_query);
+}
+
+int32_t
+nir_signed_lower_bound(nir_shader *shader, struct hash_table *range_ht, nir_scalar scalar)
+{
+   return signed_bound(shader, range_ht, scalar, process_signed_lower_bound_query);
+}
+
 static void
 process_uub_query(struct analysis_state *state, struct analysis_query *aq, uint32_t *result,
                   const uint32_t *src)
