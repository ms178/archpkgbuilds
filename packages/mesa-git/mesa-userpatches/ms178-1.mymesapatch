 END_TEST
+
+BEGIN_TEST(optimize.sdwa.from_vop3_vcc_gfx9)
+   //>> v1: %a:v[0], v1: %b:v[1], s2: %cond:s[0-1] = p_startpgm
+   if (!setup_cs("v1 v1 s2", GFX9))
+      return;
+
+   //! v1: %res_add, s2: %_:vcc = v_add_co_u32 %a, %b dst_sel:dword src0_sel:dword src1_sel:ubyte0
+   //! p_unit_test 0, %res_add
+   Temp byte0_b = bld.pseudo(aco_opcode::p_extract, bld.def(v1), inputs[1], Operand::zero(),
+                              Operand::c32(8), Operand::zero());
+   Temp res_add = bld.vop2_e64(aco_opcode::v_add_co_u32, bld.def(v1), bld.def(bld.lm, vcc),
+                               inputs[0], byte0_b);
+   writeout(0, res_add);
+
+   //! v1: %res_cndmask = v_cndmask_b32 %a, %b, %cond:vcc dst_sel:dword src0_sel:dword src1_sel:ubyte0
+   //! p_unit_test 1, %res_cndmask
+   byte0_b = bld.pseudo(aco_opcode::p_extract, bld.def(v1), inputs[1], Operand::zero(),
+                         Operand::c32(8), Operand::zero());
+   Temp res_cndmask = bld.vop2_e64(aco_opcode::v_cndmask_b32, bld.def(v1), inputs[0], byte0_b,
+                                   bld.vcc(inputs[2]));
+   writeout(1, res_cndmask);
+
+   finish_opt_test();
+END_TEST
