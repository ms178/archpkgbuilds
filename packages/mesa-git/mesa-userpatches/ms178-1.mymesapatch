- * \author This \c matmul was contributed by Thomas Malik
- */
+/* product may alias a. b must not alias product. */
 static void matmul4( GLfloat *product, const GLfloat *a, const GLfloat *b )
 {
    GLint i;
@@ -149,14 +209,7 @@ static void matmul4( GLfloat *product, const GLfloat *a, const GLfloat *b )
    }
 }
 
-/**
- * Multiply two matrices known to occupy only the top three rows, such
- * as typical model matrices, and orthogonal matrices.
- *
- * \param a matrix.
- * \param b matrix.
- * \param product will receive the product of \p a and \p b.
- */
+/* product may alias a. b must not alias product. */
 static void matmul34( GLfloat *product, const GLfloat *a, const GLfloat *b )
 {
    GLint i;
@@ -176,6 +229,7 @@ static void matmul34( GLfloat *product, const GLfloat *a, const GLfloat *b )
 #undef A
 #undef B
 #undef P
+#endif /* AVX2+FMA matmul */
 
 /* "m" must be a 4x4 matrix. Set it to the identity matrix. */
 static void
@@ -1279,11 +1333,13 @@ _math_matrix_loadf( GLmatrix *mat, const GLfloat *m )
 void
 _math_matrix_ctr( GLmatrix *m )
 {
-   memset(m, 0, sizeof(*m));
-   matrix_set_identity(m->m);
-   matrix_set_identity(m->inv);
-   m->type = MATRIX_IDENTITY;
-   m->flags = 0;
+   if (likely(m != NULL)) {
+      memset(m, 0, sizeof(*m));
+      matrix_set_identity(m->m);
+      matrix_set_identity(m->inv);
+      m->type = MATRIX_IDENTITY;
+      m->flags = 0;
+   }
 }
 
 /*@}*/
