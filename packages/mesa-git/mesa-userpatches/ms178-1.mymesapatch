+
+      //! p_unit_test 3
+      //! v1: %0:v[0] = v_mov_b32 0x34560012
+      bld.pseudo(aco_opcode::p_unit_test, Operand::c32(3));
+      bld.pseudo(aco_opcode::p_create_vector, Definition(v0_lo, v1), Operand::c8(0x12),
+                 Operand(v1b), Operand::c16(0x3456));
+
+      //! p_unit_test 4
+      //! v1: %0:v[0] = v_mov_b32 0x120000
+      bld.pseudo(aco_opcode::p_unit_test, Operand::c32(4));
+      bld.pseudo(aco_opcode::p_create_vector, Definition(v0_lo, v1), Operand(v2b),
+                 Operand::c8(0x12), Operand(v1b));
+
+      finish_to_hw_instr_test();
+   }
+END_TEST
+
