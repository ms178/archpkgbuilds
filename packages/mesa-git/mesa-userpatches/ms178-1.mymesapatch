+
+         /* Rotate right by 1: (x >> 1) | (x << 15) */
+         __m256i lo = _mm256_slli_epi16(in, 15);
+         __m256i hi = _mm256_srli_epi16(in, 1);
+         __m256i out = _mm256_or_si256(lo, hi);
