+
+   const VkRect2D scissor = {
+      .offset = {.x = x, .y = y},
+      .extent = {.width = (uint32_t)width, .height = (uint32_t)height},
+   };
+
+   const VkCommandBuffer handle = radv_cmd_buffer_to_handle(cmd_buffer);
+   radv_CmdSetViewport(handle, 0, 1, &viewport);
+   radv_CmdSetScissor(handle, 0, 1, &scissor);
