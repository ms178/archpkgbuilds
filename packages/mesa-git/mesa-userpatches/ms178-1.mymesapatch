+
+   //! v1: %res1 = p_parallelcopy 0
+   //! p_unit_test 1, %res1
+   writeout(1, bld.vop2(aco_opcode::v_xor_b32, bld.def(v1), b, b));
+
+   //! v1: %res2 = p_parallelcopy 0
+   //! p_unit_test 2, %res2
+   writeout(2, bld.vop2(aco_opcode::v_sub_u32, bld.def(v1), a, a));
+
+   //! v1: %res3 = p_parallelcopy %b
+   //! p_unit_test 3, %res3
+   writeout(3, bld.vop2(aco_opcode::v_cndmask_b32, bld.def(v1), b, b, cond));
+
+   //! v1: %res4 = p_parallelcopy %a
+   //! p_unit_test 4, %res4
+   writeout(4, bld.vop2(aco_opcode::v_min_u32, bld.def(v1), a, a));
+
+   //! v1: %res5 = v_min_u32 %a, %b
+   //! p_unit_test 5, %res5
+   writeout(5, bld.vop3(aco_opcode::v_min3_u32, bld.def(v1), a, a, b));
+
+   //! v1: %res6 = p_parallelcopy %a
+   //! p_unit_test 6, %res6
+   writeout(6, bld.vop3(aco_opcode::v_med3_i32, bld.def(v1), a, b, a));
+
+   //! v1: %res7 = v_max_i32 %a, %b
+   //! p_unit_test 7, %res7
+   writeout(7, bld.vop3(aco_opcode::v_max3_i32, bld.def(v1), a, b, b));
+
+   //! v1: %res8 = v_sub_f32 %a, %a
+   //! p_unit_test 8, %res8
+   writeout(8, bld.vop2(aco_opcode::v_sub_f32, bld.def(v1), a, a));
+
+   //! v1: %res9 = v_med3_f32 %a, %b, %a
+   //! p_unit_test 9, %res9
+   writeout(9, bld.vop3(aco_opcode::v_med3_f32, bld.def(v1), a, b, a));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.p_extract_constant)
+   //>> s1: %a:s[0] = p_startpgm
+   if (!setup_cs("s1", GFX9))
+      return;
+
+   Temp constant = bld.copy(bld.def(s1), Operand::c32(0x89abcdefu));
+
+   //! p_unit_test 0, 0xcdef
+   writeout(0, bld.pseudo(aco_opcode::p_extract, bld.def(s1), bld.def(s1, scc), constant,
+                          Operand::c32(0), Operand::c32(16u), Operand::c32(false)));
+
+   //! p_unit_test 1, 0xffff89ab
+   writeout(1, bld.pseudo(aco_opcode::p_extract, bld.def(s1), bld.def(s1, scc), constant,
+                          Operand::c32(1), Operand::c32(16u), Operand::c32(true)));
+
+   //! p_unit_test 2, 0xab
+   writeout(2, bld.pseudo(aco_opcode::p_extract, bld.def(s1), bld.def(s1, scc), constant,
+                          Operand::c32(2), Operand::c32(8u), Operand::c32(false)));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_integer_identity_constants)
+   //>> v1: %a:v[0], v1: %b:v[1] = p_startpgm
+   if (!setup_cs("v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   //! v1: %res0 = p_parallelcopy %b
+   //! p_unit_test 0, %res0
+   writeout(0, bld.vop2(aco_opcode::v_add_u32, bld.def(v1), Operand::zero(), b));
+
+   //! v1: %res1 = p_parallelcopy %b
+   //! p_unit_test 1, %res1
+   writeout(1, bld.vop2(aco_opcode::v_subrev_u32, bld.def(v1), Operand::zero(), b));
+
+   //! v1: %res2 = p_parallelcopy %a
+   //! p_unit_test 2, %res2
+   writeout(2, bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::zero(), a));
+
+   //! v1: %res3 = p_parallelcopy %a
+   //! p_unit_test 3, %res3
+   writeout(3, bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::zero(), a));
+
+   //! v1: %res4 = p_parallelcopy %a
+   //! p_unit_test 4, %res4
+   writeout(4, bld.vop2(aco_opcode::v_ashrrev_i32, bld.def(v1), Operand::zero(), a));
+
+   //! v1: %res5 = p_parallelcopy 0
+   //! p_unit_test 5, %res5
+   writeout(5, bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::zero(), a));
+
+   //! v1: %res6 = p_parallelcopy %a
+   //! p_unit_test 6, %res6
+   writeout(6, bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(UINT32_MAX), a));
+
+   //! v1: %res7 = p_parallelcopy %a
+   //! p_unit_test 7, %res7
+   writeout(7, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), Operand::zero(), a));
+
+   //! v1: %res8 = p_parallelcopy -1
+   //! p_unit_test 8, %res8
+   writeout(8, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), Operand::c32(UINT32_MAX), a));
+
+   //! v1: %res9 = p_parallelcopy %a
+   //! p_unit_test 9, %res9
+   writeout(9, bld.vop2(aco_opcode::v_xor_b32, bld.def(v1), Operand::zero(), a));
+
+   //! v1: %res10 = v_sub_u32 0, %a
+   //! p_unit_test 10, %res10
+   writeout(10, bld.vop2(aco_opcode::v_sub_u32, bld.def(v1), Operand::zero(), a));
+
+   //! v1: %res11 = v_lshlrev_b32 1, %a
+   //! p_unit_test 11, %res11
+   writeout(11, bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(1), a));
+
+   finish_opt_test();
+END_TEST
+
+
+BEGIN_TEST(optimizer.gfx9_quarter_rate_mul_identity)
+   //>> v1: %a:v[0], v1: %b:v[1] = p_startpgm
+   if (!setup_cs("v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   //! v1: %res0 = p_parallelcopy 0
+   //! p_unit_test 0, %res0
+   writeout(0, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), a, Operand::zero()));
+
+   //! v1: %res1 = p_parallelcopy 0
+   //! p_unit_test 1, %res1
+   writeout(1, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), Operand::zero(), b));
+
+   //! v1: %res2 = p_parallelcopy %a
+   //! p_unit_test 2, %res2
+   writeout(2, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), a, Operand::c32(1)));
+
+   //! v1: %res3 = p_parallelcopy %b
+   //! p_unit_test 3, %res3
+   writeout(3, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), Operand::c32(1), b));
+
+   //! v1: %res4 = p_parallelcopy 0
+   //! p_unit_test 4, %res4
+   writeout(4, bld.vop3(aco_opcode::v_mul_hi_u32, bld.def(v1), a, Operand::zero()));
+
+   //! v1: %res5 = p_parallelcopy 0
+   //! p_unit_test 5, %res5
+   writeout(5, bld.vop3(aco_opcode::v_mul_hi_u32, bld.def(v1), Operand::zero(), b));
+
+   //! v1: %res6 = p_parallelcopy 0
+   //! p_unit_test 6, %res6
+   writeout(6, bld.vop3(aco_opcode::v_mul_hi_u32, bld.def(v1), a, Operand::c32(1)));
+
+   //! v1: %res7 = p_parallelcopy 0
+   //! p_unit_test 7, %res7
+   writeout(7, bld.vop3(aco_opcode::v_mul_hi_u32, bld.def(v1), Operand::c32(1), b));
+
+   //! v1: %res8 = v_lshlrev_b32 1, %a
+   //! p_unit_test 8, %res8
+   writeout(8, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), Operand::c32(2), a));
+
+   //! v1: %res9 = v_mul_hi_u32 2, %b
+   //! p_unit_test 9, %res9
+   writeout(9, bld.vop3(aco_opcode::v_mul_hi_u32, bld.def(v1), Operand::c32(2), b));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimize.vop3p_inline_half_constant)
+   /* A VOP3P half-select can consume a 16-bit inline constant directly. */
+   if (!setup_cs("v1", GFX9))
+      return;
+
+   //>> v1: %a:v[0] = p_startpgm
+   //! v1: %high_half_one = p_parallelcopy 0x3c000000
+   //! v1: %low = v_mad_f32 %a, 1.0, 0
+   //! v1: %high = v_fma_mix_f32 %a, %high_half_one, 0
+   //! p_unit_test 0, %low
+   //! p_unit_test 1, %high
+   //! s_endpgm
+
+   Temp low_half_one = bld.copy(bld.def(v1), Operand::c32(0x00003c00));
+   Temp high_half_one = bld.copy(bld.def(v1), Operand::c32(0x3c000000));
+   Temp low = bld.vop3p(aco_opcode::v_fma_mix_f32, bld.def(v1), inputs[0], low_half_one,
+                         Operand::c32(0), 0x0, 0x2);
+   Temp high = bld.vop3p(aco_opcode::v_fma_mix_f32, bld.def(v1), inputs[0], high_half_one,
+                          Operand::c32(0), 0x0, 0x0);
+   writeout(0, low);
+   writeout(1, high);
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_ds_word_high_byte_extract)
+   //>> v1: %addr:v[0] = p_startpgm
+   if (!setup_cs("v1", GFX9))
+      return;
+
+   //; insert_pattern('v1: %unsigned = ds_read_u8 %addr offset0:13')
+   //; insert_pattern('v1: %signed = ds_read_i8 %addr offset0:17')
+   //; insert_pattern('v1: %from_signed_word = ds_read_u8 %addr offset0:21')
+   //; insert_pattern('v1: %overflow_word = ds_read_u16 %addr offset0:65535')
+   //; insert_pattern('v1: %overflow = p_extract %overflow_word, 1, 8, 0')
+   //; insert_pattern('p_unit_test 0, %unsigned')
+   //; insert_pattern('p_unit_test 1, %signed')
+   //; insert_pattern('p_unit_test 2, %from_signed_word')
+   //; insert_pattern('p_unit_test 3, %overflow')
+   //; insert_pattern('s_endpgm')
+   Temp word_unsigned = bld.ds(aco_opcode::ds_read_u16, bld.def(v1), inputs[0], 12);
+   Temp word_signed = bld.ds(aco_opcode::ds_read_u16, bld.def(v1), inputs[0], 16);
+   Temp signed_word = bld.ds(aco_opcode::ds_read_i16, bld.def(v1), inputs[0], 20);
+   Temp overflow_word = bld.ds(aco_opcode::ds_read_u16, bld.def(v1), inputs[0], UINT16_MAX);
+   Temp unsigned_byte = bld.pseudo(aco_opcode::p_extract, bld.def(v1), word_unsigned,
+                                   Operand::c32(1), Operand::c32(8), Operand::zero());
+   Temp signed_byte = bld.pseudo(aco_opcode::p_extract, bld.def(v1), word_signed,
+                                 Operand::c32(1), Operand::c32(8), Operand::c32(1));
+   Temp from_signed_word = bld.pseudo(aco_opcode::p_extract, bld.def(v1), signed_word,
+                                       Operand::c32(1), Operand::c32(8), Operand::zero());
+   Temp overflow = bld.pseudo(aco_opcode::p_extract, bld.def(v1), overflow_word,
+                              Operand::c32(1), Operand::c32(8), Operand::zero());
+   writeout(0, unsigned_byte);
+   writeout(1, signed_byte);
+   writeout(2, from_signed_word);
+   writeout(3, overflow);
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_ds_dword_extract)
+   //>> v1: %addr:v[0] = p_startpgm
+   if (!setup_cs("v1", GFX9))
+      return;
+
+   //; insert_pattern('v1: %unsigned_byte = ds_read_u8 %addr offset0:35')
+   //; insert_pattern('v1: %signed_byte = ds_read_i8 %addr offset0:41')
+   //; insert_pattern('v1: %halfword = ds_read_u16 %addr offset0:50')
+   //; insert_pattern('v1: %signed_halfword = ds_read_i16 %addr offset0:54')
+   //; insert_pattern('p_unit_test 0, %unsigned_byte')
+   //; insert_pattern('p_unit_test 1, %signed_byte')
+   //; insert_pattern('p_unit_test 2, %halfword')
+   //; insert_pattern('p_unit_test 3, %signed_halfword')
+   //; insert_pattern('s_endpgm')
+   Temp dword_unsigned = bld.ds(aco_opcode::ds_read_b32, bld.def(v1), inputs[0], 32);
+   Temp dword_signed = bld.ds(aco_opcode::ds_read_b32, bld.def(v1), inputs[0], 40);
+   Temp dword_halfword = bld.ds(aco_opcode::ds_read_b32, bld.def(v1), inputs[0], 48);
+   Temp dword_signed_halfword = bld.ds(aco_opcode::ds_read_b32, bld.def(v1), inputs[0], 52);
+   Temp unsigned_byte = bld.pseudo(aco_opcode::p_extract, bld.def(v1), dword_unsigned,
+                                   Operand::c32(3), Operand::c32(8), Operand::zero());
+   Temp signed_byte = bld.pseudo(aco_opcode::p_extract, bld.def(v1), dword_signed,
+                                 Operand::c32(1), Operand::c32(8), Operand::c32(1));
+   Temp halfword = bld.pseudo(aco_opcode::p_extract, bld.def(v1), dword_halfword,
+                              Operand::c32(1), Operand::c32(16), Operand::zero());
+   Temp signed_halfword = bld.pseudo(aco_opcode::p_extract, bld.def(v1), dword_signed_halfword,
+                                     Operand::c32(1), Operand::c32(16), Operand::c32(1));
+   writeout(0, unsigned_byte);
+   writeout(1, signed_byte);
+   writeout(2, halfword);
+   writeout(3, signed_halfword);
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_ds_qword_extract)
+   //>> v1: %addr:v[0] = p_startpgm
+   if (!setup_cs("v1", GFX9))
+      return;
+
+   //; insert_pattern('v1: %byte = ds_read_u8 %addr offset0:67')
+   //; insert_pattern('v1: %halfword = ds_read_u16 %addr offset0:70')
+   //; insert_pattern('p_unit_test 0, %byte')
+   //; insert_pattern('p_unit_test 1, %halfword')
+   //; insert_pattern('s_endpgm')
+   Temp qword_byte = bld.ds(aco_opcode::ds_read_b64, bld.def(v2), inputs[0], 60);
+   Temp qword_halfword = bld.ds(aco_opcode::ds_read_b64, bld.def(v2), inputs[0], 64);
+   Temp byte = bld.pseudo(aco_opcode::p_extract, bld.def(v1), qword_byte,
+                           Operand::c32(7), Operand::c32(8), Operand::zero());
+   Temp halfword = bld.pseudo(aco_opcode::p_extract, bld.def(v1), qword_halfword,
+                               Operand::c32(3), Operand::c32(16), Operand::zero());
+   writeout(0, byte);
+   writeout(1, halfword);
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_smem_load_extract)
+   //>> s2: %base:s[0-1], s4: %desc:s[2-5] = p_startpgm
+   if (!setup_cs("s2 s4", GFX9))
+      return;
+
+   //; search_re('s1: %.* = s_buffer_load_dword .*40')
+   //; search_re('s1: %.* = p_extract %.*, 3, 8, 0')
+   //; search_re('s1: %.* = s_load_dword .*0x44')
+   //; search_re('s1: %.* = s_buffer_load_dword .*48')
+   //; search_re('s1: %.* = p_extract %.*, 1, 16, 0')
+   //; search_re('s1: %.* = s_buffer_load_dword .*0xfffff')
+   //; search_re('s1: %.* = p_extract %.*, 3, 8, 0')
+   //; search_re('p_unit_test 0, %.*')
+   //; search_re('p_unit_test 1, %.*')
+   //; search_re('p_unit_test 2, %.*')
+   //; search_re('p_unit_test 3, %.*')
+   //; insert_pattern('s_endpgm')
+   Temp word = bld.smem(aco_opcode::s_buffer_load_dword, bld.def(s1), inputs[1], Operand::c32(40u));
+   Temp byte = bld.pseudo(aco_opcode::p_extract, bld.def(s1), bld.def(s1, scc), word,
+                          Operand::c32(3), Operand::c32(8), Operand::zero());
+
+   Temp qword = bld.smem(aco_opcode::s_load_dwordx2, bld.def(s2), inputs[0], Operand::c32(64u));
+   Temp hi = bld.pseudo(aco_opcode::p_extract_vector, bld.def(s1), qword, Operand::c32(1));
+
+   Temp halfword_src = bld.smem(aco_opcode::s_buffer_load_dword, bld.def(s1), inputs[1], Operand::c32(48u));
+   Temp halfword = bld.pseudo(aco_opcode::p_extract, bld.def(s1), bld.def(s1, scc), halfword_src,
+                              Operand::c32(1), Operand::c32(16), Operand::zero());
+
+   Temp overflow_src =
+      bld.smem(aco_opcode::s_buffer_load_dword, bld.def(s1), inputs[1], Operand::c32(1048575u));
+   Temp overflow = bld.pseudo(aco_opcode::p_extract, bld.def(s1), bld.def(s1, scc), overflow_src,
+                              Operand::c32(3), Operand::c32(8), Operand::zero());
+
+   writeout(0, byte);
+   writeout(1, hi);
+   writeout(2, overflow);
+   writeout(3, halfword);
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_mubuf_load_extract)
+   //>> s4: %desc:s[0-3], v1: %addr:v[0] = p_startpgm
+   if (!setup_cs("s4 v1", GFX9))
+      return;
+
+   //; search_re('v1: %.* = buffer_load_ushort .*offset:14')
+   //; search_re('v1: %.* = buffer_load_dword .*offset:24')
+   //; search_re('v2: %.* = buffer_load_dwordx2 .*offset:8388607')
+   //; search_re('v1: %.* = p_extract %.*, 1, 16, 0')
+   //; search_re('p_unit_test 0, %.*')
+   //; search_re('p_unit_test 1, %.*')
+   //; search_re('p_unit_test 2, %.*')
+   //; insert_pattern('s_endpgm')
+   Temp dword = bld.mubuf(aco_opcode::buffer_load_dword, bld.def(v1), inputs[0], inputs[1],
+                          Operand::zero(), 12, false);
+   Temp halfword = bld.pseudo(aco_opcode::p_extract, bld.def(v1), dword,
+                              Operand::c32(1), Operand::c32(16), Operand::zero());
+
+   Temp qword = bld.mubuf(aco_opcode::buffer_load_dwordx2, bld.def(v2), inputs[0], inputs[1],
+                          Operand::zero(), 20, false);
+   Temp hi = bld.pseudo(aco_opcode::p_extract_vector, bld.def(v1), qword, Operand::c32(1));
+
+   Temp overflow_src = bld.mubuf(aco_opcode::buffer_load_dwordx2, bld.def(v2), inputs[0], inputs[1],
+                                 Operand::zero(), 0x7fffff, false);
+   Temp overflow = bld.pseudo(aco_opcode::p_extract, bld.def(v1), overflow_src,
+                              Operand::c32(1), Operand::c32(16), Operand::zero());
+
+   writeout(0, halfword);
+   writeout(1, hi);
+   writeout(2, overflow);
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_mul_power_of_two_to_lshl)
+   //>> v1: %a:v[0], v1: %b:v[1] = p_startpgm
+   if (!setup_cs("v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   /* GFX9 VOP3 cannot take true literals; only use inline constants (2..64).
+    * Quarter-rate v_mul_lo_* (x, 2^k) must become full-rate v_lshlrev_b32.
+    */
+   //! v1: %res0 = v_lshlrev_b32 1, %a
+   //! p_unit_test 0, %res0
+   writeout(0, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), a, Operand::c32(2)));
+
+   //! v1: %res1 = v_lshlrev_b32 2, %b
+   //! p_unit_test 1, %res1
+   writeout(1, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), Operand::c32(4), b));
+
+   //! v1: %res2 = v_lshlrev_b32 3, %a
+   //! p_unit_test 2, %res2
+   writeout(2, bld.vop3(aco_opcode::v_mul_lo_i32, bld.def(v1), a, Operand::c32(8)));
+
+   //! v1: %res3 = v_lshlrev_b32 4, %b
+   //! p_unit_test 3, %res3
+   writeout(3, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), Operand::c32(16), b));
+
+   //! v1: %res4 = v_lshlrev_b32 5, %a
+   //! p_unit_test 4, %res4
+   writeout(4, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), a, Operand::c32(32)));
+
+   //! v1: %res5 = v_lshlrev_b32 6, %b
+   //! p_unit_test 5, %res5
+   writeout(5, bld.vop3(aco_opcode::v_mul_lo_i32, bld.def(v1), Operand::c32(64), b));
+
+   /* Non-power-of-two must remain a multiply. */
+   //! v1: %res6 = v_mul_lo_u32 3, %a
+   //! p_unit_test 6, %res6
+   writeout(6, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), Operand::c32(3), a));
+
+   //! v1: %res7 = v_mul_lo_u32 %b, 6
+   //! p_unit_test 7, %res7
+   writeout(7, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), b, Operand::c32(6)));
+
+   /* Identity paths still win over the shift fold. */
+   //! v1: %res8 = p_parallelcopy %a
+   //! p_unit_test 8, %res8
+   writeout(8, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), a, Operand::c32(1)));
+
+   //! v1: %res9 = p_parallelcopy 0
+   //! p_unit_test 9, %res9
+   writeout(9, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), a, Operand::zero()));
+
+   //! v1: %res10 = p_parallelcopy %b
+   //! p_unit_test 10, %res10
+   writeout(10, bld.vop3(aco_opcode::v_mul_lo_i32, bld.def(v1), Operand::c32(1), b));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_mul_power_of_two_via_sgpr_literal)
+   /* Large power-of-two factors that are not inline constants arrive through a
+    * parallelcopy SGPR/VGPR and must still fold once constant-propagated.
+    */
+   //>> v1: %a:v[0] = p_startpgm
+   if (!setup_cs("v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+
+   //! v1: %res0 = v_lshlrev_b32 10, %a
+   //! p_unit_test 0, %res0
+   Temp c1024 = bld.copy(bld.def(s1), Operand::c32(1024u));
+   writeout(0, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), a, bld.as_uniform(c1024)));
+
+   //! v1: %res1 = v_lshlrev_b32 31, %a
+   //! p_unit_test 1, %res1
+   Temp c31 = bld.copy(bld.def(s1), Operand::c32(0x80000000u));
+   writeout(1, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), bld.as_uniform(c31), a));
+
+   //! s1: %c768 = p_parallelcopy 0x300
+   //! v1: %res2 = v_mul_lo_u32 %c768, %a
+   //! p_unit_test 2, %res2
+   Temp c768 = bld.copy(bld.def(s1), Operand::c32(0x300u));
+   writeout(2, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), bld.as_uniform(c768), a));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_s_bfe_from_lshr_and)
+   //>> s1: %a:s[0], s1: %b:s[1] = p_startpgm
+   if (!setup_cs("s1 s1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   /* s_and(s_lshr(x, shift), mask) -> s_bfe_u32(x, width<<16 | shift) */
+   //! s1: %res0,  s1: %_:scc = s_bfe_u32 %a, 0x50007
+   //! p_unit_test 0, %res0
+   Temp shr0 = bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), a, Operand::c32(7));
+   writeout(0, bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), shr0,
+                        Operand::c32(0x1f)));
+
+   /* Commuted mask/value order on the AND. */
+   //! s1: %res1,  s1: %_:scc = s_bfe_u32 %a, 0x80003
+   //! p_unit_test 1, %res1
+   Temp shr1 = bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), a, Operand::c32(3));
+   writeout(1, bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), Operand::c32(0xff),
+                        shr1));
+
+   /* Pre-mask form: s_lshr(s_and(x, mask<<shift), shift) -> s_bfe_u32 */
+   //! s1: %res2,  s1: %_:scc = s_bfe_u32 %b, 0x60009
+   //! p_unit_test 2, %res2
+   Temp and2 = bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), b,
+                        Operand::c32(0x7e00));
+   writeout(2, bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), and2,
+                        Operand::c32(9)));
+
+   /* Pre-mask with commuted AND operands. */
+   //! s1: %res3,  s1: %_:scc = s_bfe_u32 %b, 0x40005
+   //! p_unit_test 3, %res3
+   Temp and3 = bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), Operand::c32(0x1e0),
+                        b);
+   writeout(3, bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), and3,
+                        Operand::c32(5)));
+
+   /* Byte extract at offset 0 via post-mask form. */
+   //! s1: %res4,  s1: %_:scc = s_bfe_u32 %a, 0x80000
+   //! p_unit_test 4, %res4
+   Temp shr4 = bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), a, Operand::c32(0));
+   writeout(4, bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), shr4,
+                        Operand::c32(0xff)));
+
+   /* Full 16-bit field. */
+   //! s1: %res5,  s1: %_:scc = s_bfe_u32 %a, 0x100008
+   //! p_unit_test 5, %res5
+   Temp shr5 = bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), a, Operand::c32(8));
+   writeout(5, bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), shr5,
+                        Operand::c32(0xffff)));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_s_bfe_negative_cases)
+   //>> s1: %a:s[0], s1: %b:s[1] = p_startpgm
+   if (!setup_cs("s1 s1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   /* Zero-shift pre-mask form is not profitable as BFE; keep the AND (lshr by 0
+    * remains as a separate identity SALU or is left alone by the fold guard). */
+   //! s1: %and0,  s1: %_:scc = s_and_b32 %a, 0xff
+   //! s1: %res0,  s1: %_:scc = s_lshr_b32 %and0, 0
+   //! p_unit_test 0, %res0
+   Temp and0 = bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), a,
+                        Operand::c32(0xff));
+   writeout(0, bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), and0,
+                        Operand::c32(0)));
+
+   /* Non-contiguous mask must not fold. */
+   //! s1: %shr1,  s1: %_:scc = s_lshr_b32 %b, 4
+   //! s1: %res1,  s1: %_:scc = s_and_b32 %shr1, 0x55
+   //! p_unit_test 1, %res1
+   Temp shr1 = bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), b, Operand::c32(4));
+   writeout(1, bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), shr1,
+                        Operand::c32(0x55)));
+
+   /* Mask too wide for remaining bits after shift (shift 28, width 8). */
+   //! s1: %shr2,  s1: %_:scc = s_lshr_b32 %a, 28
+   //! s1: %res2,  s1: %_:scc = s_and_b32 %shr2, 0xff
+   //! p_unit_test 2, %res2
+   Temp shr2 = bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), a, Operand::c32(28));
+   writeout(2, bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), shr2,
+                        Operand::c32(0xff)));
+
+   /* Pre-mask with holes in the field (0xaa00 >> 8 = 0xaa is not a low mask). */
+   //! s1: %and3,  s1: %_:scc = s_and_b32 %b, 0xaa00
+   //! s1: %res3,  s1: %_:scc = s_lshr_b32 %and3, 8
+   //! p_unit_test 3, %res3
+   Temp and3 = bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), b,
+                        Operand::c32(0xaa00));
+   writeout(3, bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), and3,
+                        Operand::c32(8)));
+
+   /* Multi-use shifted value must not be consumed into BFE. */
+   //! s1: %shr4,  s1: %_:scc = s_lshr_b32 %a, 4
+   //! s1: %res4a,  s1: %_:scc = s_and_b32 %shr4, 15
+   //! s1: %res4b,  s1: %_:scc = s_add_u32 %shr4, %b
+   //! p_unit_test 4, %res4a, %res4b
+   Temp shr4 = bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), a, Operand::c32(4));
+   Temp res4a =
+      bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), shr4, Operand::c32(0xf));
+   Temp res4b = bld.sop2(aco_opcode::s_add_u32, bld.def(s1), bld.def(s1, scc), shr4, b);
+   writeout(4, Operand(res4a), Operand(res4b));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_alignbyte_lshr_lshl_commuted)
+   /* Cover the lshr|lshl commute path that is easy to get operand-order wrong on. */
+   //>> v1: %a:v[0], v1: %b:v[1] = p_startpgm
+   if (!setup_cs("v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   //! v1: %res0 = v_alignbyte_b32 %a, %b, 2
+   //! p_unit_test 0, %res0
+   Temp shl0 = bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(16), a);
+   Temp shr0 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(16), b);
+   writeout(0, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), shr0, shl0));
+
+   //! v1: %res1 = v_alignbit_b32 %b, %a, 7
+   //! p_unit_test 1, %res1
+   Temp shl1 = bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(7), a);
+   Temp shr1 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(25), b);
+   writeout(1, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), shr1, shl1));
+
+   //! v1: %res2 = v_alignbyte_b32 %b, %a, 1
+   //! p_unit_test 2, %res2
+   Temp shl2 = bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(24), b);
+   Temp shr2 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(8), a);
+   writeout(2, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), shl2, shr2));
+
+   //! v1: %res3 = v_alignbit_b32 %a, %b, 11
+   //! p_unit_test 3, %res3
+   Temp shr3 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(21), a);
+   Temp shl3 = bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(11), b);
+   writeout(3, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), shl3, shr3));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_align_negative_cases)
+   //>> v1: %a:v[0], v1: %b:v[1], v1: %c:v[2] = p_startpgm
+   if (!setup_cs("v1 v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+   Temp c = inputs[2];
+
+   /* Shifts that do not sum to 32 must not become align*. */
+   //! v1: %shl0 = v_lshlrev_b32 8, %a
+   //! v1: %shr0 = v_lshrrev_b32 16, %b
+   //! v1: %res0 = v_or3_b32 %shl0, %shr0, %c
+   //! p_unit_test 0, %res0
+   Temp shl0 = bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(8), a);
+   Temp shr0 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(16), b);
+   writeout(0, bld.vop3(aco_opcode::v_or3_b32, bld.def(v1), shl0, shr0, c));
+
+   /* Multi-use of the lshr blocks align*; lshl_or may still combine the single-use lshl. */
+   //! v1: %shr1 = v_lshrrev_b32 24, %b
+   //! v1: %res1a = v_lshl_or_b32 %a, 8, %shr1
+   //! v1: %res1b = v_xor_b32 %shr1, %c
+   //! p_unit_test 1, %res1a, %res1b
+   Temp shl1 = bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(8), a);
+   Temp shr1 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(24), b);
+   Temp res1a = bld.vop2(aco_opcode::v_or_b32, bld.def(v1), shl1, shr1);
+   Temp res1b = bld.vop2(aco_opcode::v_xor_b32, bld.def(v1), shr1, c);
+   writeout(1, Operand(res1a), Operand(res1b));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_v_bfe_exhaustive)
+   //>> v1: %a:v[0], v1: %b:v[1] = p_startpgm
+   if (!setup_cs("v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   /* VOP2 literals must sit in src0. */
+   //! v1: %res0 = v_bfe_u32 %a, 0, 8
+   //! p_unit_test 0, %res0
+   Temp shr0 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(0), a);
+   writeout(0, bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xff), shr0));
+
+   //! v1: %res1 = v_bfe_u32 %a, 16, 16
+   //! p_unit_test 1, %res1
+   Temp shr1 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(16), a);
+   writeout(1, bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xffff), shr1));
+
+   //! v1: %res2 = v_bfe_u32 %b, 3, 1
+   //! p_unit_test 2, %res2
+   Temp and2 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0x8), b);
+   writeout(2, bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(3), and2));
+
+   //! v1: %res3 = v_bfe_u32 %b, 12, 12
+   //! p_unit_test 3, %res3
+   Temp and3 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0x00fff000u), b);
+   writeout(3, bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(12), and3));
+
+   //! v1: %res4 = v_bfe_u32 %a, 4, 4
+   //! p_unit_test 4, %res4
+   Temp shr4 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(4), a);
+   writeout(4, bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xf), shr4));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx10_v_bfi_literal_masks)
+   /* GFX10+ allows VOP3 literals, so wide bitfield masks fold cleanly.
+    * Match order may select either complementary mask; both are semantically identical.
+    */
+   //>> v1: %a:v[0], v1: %b:v[1], v1: %c:v[2] = p_startpgm
+   if (!setup_cs("v1 v1 v1", GFX10))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+   Temp c = inputs[2];
+
+   //; search_re('v_bfi_b32 0xff')
+   //; search_re('p_unit_test 0')
+   //; search_re('v_bfi_b32 0xffff')
+   //; search_re('p_unit_test 1')
+   //; search_re('v_bfi_b32 0xf0f0f0f')
+   //; search_re('p_unit_test 2')
+   //; insert_pattern('s_endpgm')
+   Temp mi0 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xff), a);
+   Temp mb0 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xffffff00u), b);
+   writeout(0, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), mi0, mb0));
+
+   Temp mb1 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0x0000ffffu), a);
+   Temp mi1 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xffff0000u), c);
+   writeout(1, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), mb1, mi1));
+
+   Temp mi2 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0x0f0f0f0fu), b);
+   Temp mb2 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xf0f0f0f0u), c);
+   writeout(2, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), mi2, mb2));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_load_extract_ds_vector_lane)
+   //>> v1: %addr:v[0] = p_startpgm
+   if (!setup_cs("v1", GFX9))
+      return;
+
+   /* p_extract_vector lane1 of ds_read_b64 should shrink to ds_read_b32 with folded offset. */
+   //; insert_pattern('v1: %lane = ds_read_b32 %addr offset0:12')
+   //; insert_pattern('p_unit_test 0, %lane')
+   //; insert_pattern('s_endpgm')
+   Temp q = bld.ds(aco_opcode::ds_read_b64, bld.def(v2), inputs[0], 8);
+   writeout(0, bld.pseudo(aco_opcode::p_extract_vector, bld.def(v1), q, Operand::c32(1)));
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx10_s_bfe_from_lshr_and)
+   /* SALU s_bfe fold is profitable on all GCN/RDNA generations. */
+   //>> s1: %a:s[0] = p_startpgm
+   if (!setup_cs("s1", GFX10))
+      return;
+
+   Temp a = inputs[0];
+   //! s1: %res0,  s1: %_:scc = s_bfe_u32 %a, 0x50007
+   //! p_unit_test 0, %res0
+   Temp shr0 = bld.sop2(aco_opcode::s_lshr_b32, bld.def(s1), bld.def(s1, scc), a, Operand::c32(7));
+   writeout(0, bld.sop2(aco_opcode::s_and_b32, bld.def(s1), bld.def(s1, scc), shr0,
+                        Operand::c32(0x1f)));
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx10_mul_power_of_two_still_folds)
+   /* Power-of-two mul->lshl is profitable on every generation with quarter-rate mul. */
+   //>> v1: %a:v[0] = p_startpgm
+   if (!setup_cs("v1", GFX10))
+      return;
+
+   Temp a = inputs[0];
+   //! v1: %res0 = v_lshlrev_b32 3, %a
+   //! p_unit_test 0, %res0
+   writeout(0, bld.vop3(aco_opcode::v_mul_lo_u32, bld.def(v1), a, Operand::c32(8)));
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_bfi_wide_mask_sgpr_materialize)
+   /* Wide masks that are not inline constants must still fold on GFX9 by materializing
+    * the mask into an SGPR (never a bare VOP3 literal — that hangs Vega compute). */
+   //>> v1: %a:v[0], v1: %b:v[1] = p_startpgm
+   if (!setup_cs("v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   //; search_re('p_parallelcopy 0xff')
+   //; search_re('v_bfi_b32')
+   //; search_re('p_unit_test 0')
+   //; insert_pattern('s_endpgm')
+   Temp mi = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xff), a);
+   Temp mb = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xffffff00u), b);
+   writeout(0, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), mi, mb));
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_s_mul_power_of_two_to_lshl)
+   //>> s1: %a:s[0] = p_startpgm
+   if (!setup_cs("s1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   //! s1: %res0,  s1: %_:scc = s_lshl_b32 %a, 3
+   //! p_unit_test 0, %res0
+   writeout(0, bld.sop2(aco_opcode::s_mul_i32, bld.def(s1), a, Operand::c32(8)));
+
+   //! s1: %res1,  s1: %_:scc = s_lshl_b32 %a, 4
+   //! p_unit_test 1, %res1
+   writeout(1, bld.sop2(aco_opcode::s_mul_i32, bld.def(s1), Operand::c32(16), a));
+
+   //! s1: %res2 = s_mul_i32 %a, 3
+   //! p_unit_test 2, %res2
+   writeout(2, bld.sop2(aco_opcode::s_mul_i32, bld.def(s1), a, Operand::c32(3)));
+   finish_opt_test();
+END_TEST
diff --git a/src/amd/compiler/tests/test_optimizer_postRA.cpp b/src/amd/compiler/tests/test_optimizer_postRA.cpp
index f924a7e24218b699dd08af1cbbb20fda3b837265..6ee9361675907b274144089e849428d7d53aafe5 100644
--- a/src/amd/compiler/tests/test_optimizer_postRA.cpp
+++ b/src/amd/compiler/tests/test_optimizer_postRA.cpp
@@ -910,3 +910,128 @@ BEGIN_TEST(optimizer_postRA.scc_nocmp_across_cf_partially_overwritten)
 
    finish_optimizer_postRA_test();
 END_TEST
+
+BEGIN_TEST(optimizer_postRA.dead_exec_writes)
+   for (amd_gfx_level lvl : {GFX9, GFX10}) {
+      PhysReg reg_v0(256);
+
+      //>> v1: %a:v[0] = p_startpgm
+      if (!setup_cs("v1", lvl))
+         continue;
+
+      Temp v_in = inputs[0];
+
+      {
+         /* Multiple EXEC-only writes are dead before the full VCC-to-EXEC copy. */
+         //~gfx9! s2: %b:vcc, s2: %0:exec = v_cmpx_eq_u32 0, %a:v[0]
+         //~gfx10! s2: %0:exec = v_cmpx_eq_u32 0, %a:v[0]
+         //~gfx10! s2: %b:vcc = p_parallelcopy %0:exec
+         //! p_cbranch_z %0:exec
+         //! p_unit_test 0
+         auto vcmp = bld.vopc(aco_opcode::v_cmp_eq_u32, bld.def(bld.lm, vcc), Operand::zero(),
+                              Operand(v_in, reg_v0));
+         bld.sop1(Builder::s_mov, Definition(exec, bld.lm), Operand::c32(42u));
+         bld.sop1(Builder::s_mov, Definition(exec, bld.lm), Operand::c32(17u));
+         bld.pseudo(aco_opcode::p_parallelcopy, Definition(exec, bld.lm), bld.vcc(vcmp));
+         bld.branch(aco_opcode::p_cbranch_z, Operand(exec, bld.lm));
+         writeout(0);
+      }
+
+      //; del b
+
+      {
+         /* An EXEC copy that reads EXEC cannot discard the intervening write. */
+         //! s2: %b:vcc = v_cmp_eq_u32 0, %a:v[0]
+         //! s2: %0:exec = s_mov_b64 42
+         //! s2: %0:exec, s2: %c:s[0-1] = p_parallelcopy %b:vcc, %0:exec
+         //! p_cbranch_z %0:exec
+         //! p_unit_test 1
+         auto vcmp = bld.vopc(aco_opcode::v_cmp_eq_u32, bld.def(bld.lm, vcc), Operand::zero(),
+                              Operand(v_in, reg_v0));
+         bld.sop1(Builder::s_mov, Definition(exec, bld.lm), Operand::c32(42u));
+         bld.pseudo(aco_opcode::p_parallelcopy, Definition(exec, bld.lm),
+                    bld.def(bld.lm, PhysReg(0)), bld.vcc(vcmp), Operand(exec, bld.lm));
+         bld.branch(aco_opcode::p_cbranch_z, Operand(exec, bld.lm));
+         writeout(1);
+      }
+
+      //; del b, c
+
+      {
+         /* A dead SCC side definition can be removed together with its EXEC write. */
+         //~gfx9! s2: %b:vcc, s2: %0:exec = v_cmpx_eq_u32 0, %a:v[0]
+         //~gfx10! s2: %0:exec = v_cmpx_eq_u32 0, %a:v[0]
+         //~gfx10! s2: %b:vcc = p_parallelcopy %0:exec
+         //! p_cbranch_z %0:exec
+         //! p_unit_test 2
+         auto vcmp = bld.vopc(aco_opcode::v_cmp_eq_u32, bld.def(bld.lm, vcc), Operand::zero(),
+                              Operand(v_in, reg_v0));
+         bld.sop2(Builder::s_and, Definition(exec, bld.lm), bld.def(s1, scc), Operand::c32(3u),
+                  Operand::c32(5u));
+         bld.pseudo(aco_opcode::p_parallelcopy, Definition(exec, bld.lm), bld.vcc(vcmp));
+         bld.branch(aco_opcode::p_cbranch_z, Operand(exec, bld.lm));
+         writeout(2);
+      }
+
+      //; del b
+
+      {
+         /* A live SCC side definition must retain its EXEC-writing instruction. */
+         //! s2: %b:vcc = v_cmp_eq_u32 0, %a:v[0]
+         //! s2: %0:exec, s1: %c:scc = s_and_b64 3, 5
+         //! s1: %d:s[4] = p_parallelcopy %c:scc
+         //! s2: %0:exec = p_parallelcopy %b:vcc
+         //! p_cbranch_z %0:exec
+         //! p_unit_test 5, %d
+         Temp scc_val = bld.tmp(s1);
+         auto vcmp = bld.vopc(aco_opcode::v_cmp_eq_u32, bld.def(bld.lm, vcc), Operand::zero(),
+                              Operand(v_in, reg_v0));
+         bld.sop2(Builder::s_and, Definition(exec, bld.lm), Definition(scc_val, scc), Operand::c32(3u),
+                  Operand::c32(5u));
+         Temp saved_scc = bld.tmp(s1);
+         bld.pseudo(aco_opcode::p_parallelcopy, Definition(saved_scc, PhysReg(4)), Operand(scc_val, scc));
+         bld.pseudo(aco_opcode::p_parallelcopy, Definition(exec, bld.lm), bld.vcc(vcmp));
+         bld.branch(aco_opcode::p_cbranch_z, Operand(exec, bld.lm));
+         writeout(5, saved_scc);
+      }
+
+      //; del b
+
+      {
+         /* A partial EXEC write cannot be replaced by a full EXEC write. */
+         //! s1: %b:s[4] = s_mov_b32 1
+         //! s2: %0:exec = s_mov_b64 42
+         //! s1: %0:exec_lo = p_parallelcopy %b:s[4]
+         //! p_cbranch_z %0:exec
+         //! p_unit_test 3
+         Temp s_val = bld.tmp(s1);
+         bld.sop1(aco_opcode::s_mov_b32, Definition(s_val, PhysReg(4)), Operand::c32(1u));
+         bld.sop1(Builder::s_mov, Definition(exec, bld.lm), Operand::c32(42u));
+         bld.pseudo(aco_opcode::p_parallelcopy, Definition(exec_lo, s1), Operand(s_val, PhysReg(4)));
+         bld.branch(aco_opcode::p_cbranch_z, Operand(exec, bld.lm));
+         writeout(3);
+      }
+
+      //; del b, c
+
+      {
+         /* A live explicit EXEC read between the writes inhibits the rewrite. */
+         //! s2: %b:vcc = v_cmp_eq_u32 0, %a:v[0]
+         //! s2: %0:exec = s_mov_b64 42
+         //! s2: %c:s[4-5] = s_mov_b64 %0:exec
+         //! s2: %0:exec = p_parallelcopy %b:vcc
+         //! p_cbranch_z %0:exec
+         //! p_unit_test 4, %c
+         auto vcmp = bld.vopc(aco_opcode::v_cmp_eq_u32, bld.def(bld.lm, vcc), Operand::zero(),
+                              Operand(v_in, reg_v0));
+         bld.sop1(Builder::s_mov, Definition(exec, bld.lm), Operand::c32(42u));
+         Temp saved_exec = bld.tmp(bld.lm);
+         bld.sop1(Builder::s_mov, Definition(saved_exec, PhysReg(4)), Operand(exec, bld.lm));
+         bld.pseudo(aco_opcode::p_parallelcopy, Definition(exec, bld.lm), bld.vcc(vcmp));
+         bld.branch(aco_opcode::p_cbranch_z, Operand(exec, bld.lm));
+         writeout(4, saved_exec);
+      }
+
+      finish_optimizer_postRA_test();
+   }
+END_TEST
diff --git a/src/amd/compiler/tests/test_scheduler.cpp b/src/amd/compiler/tests/test_scheduler.cpp
index 314007f999a2e91c4903df211f598a77b42ed34b..2043aada63acdf8c5262ee549615536aeb1d83b8 100644
--- a/src/amd/compiler/tests/test_scheduler.cpp
+++ b/src/amd/compiler/tests/test_scheduler.cpp
@@ -7,6 +7,38 @@
 
 using namespace aco;
 
+
+BEGIN_TEST(scheduler.gfx9_lds_latency_hiding)
+   if (!setup_cs("v1 v1", GFX9)) return;
+   //>> p_logical_start
+   //! v1: %lds = ds_read_b32 %addr storage:shared
+   //! v1: %independent = v_mul_f32 %source, %source
+   //! p_unit_test 0, %independent
+   //! v1: %use = v_add_u32 %lds, %source
+   bld.pseudo(aco_opcode::p_logical_start);
+   Temp independent=bld.vop2(aco_opcode::v_mul_f32,bld.def(v1),inputs[1],inputs[1]);
+   Builder::Result r=bld.ds(aco_opcode::ds_read_b32,bld.def(v1),inputs[0]); r.instr->ds().sync=memory_sync_info(storage_shared); Temp lds=r;
+   bld.vop2(aco_opcode::v_add_u32,bld.def(v1),lds,inputs[1]); writeout(0,independent);
+   bld.pseudo(aco_opcode::p_logical_end); finish_schedule_test();
+END_TEST
+
+BEGIN_TEST(scheduler.gfx9_lds_release_barrier)
+   if (!setup_cs("v1 v1", GFX9)) return;
+   //>> p_logical_start
+   //! v1: %independent = v_mul_f32 %source, %source
+   //! p_barrier_signal storage:shared semantics:release scope:workgroup exec_scope:workgroup
+   //! v1: %lds = ds_read_b32 %addr storage:shared
+   //! p_unit_test 0, %independent
+   //! v1: %use = v_add_u32 %lds, %source
+   //! p_unit_test 1, %use
+   bld.pseudo(aco_opcode::p_logical_start);
+   Temp independent=bld.vop2(aco_opcode::v_mul_f32,bld.def(v1),inputs[1],inputs[1]);
+   bld.barrier(aco_opcode::p_barrier_signal,memory_sync_info(storage_shared,semantic_release,scope_workgroup),scope_workgroup);
+   Builder::Result r=bld.ds(aco_opcode::ds_read_b32,bld.def(v1),inputs[0]); r.instr->ds().sync=memory_sync_info(storage_shared); Temp lds=r;
+   Temp use=bld.vop2(aco_opcode::v_add_u32,bld.def(v1),lds,inputs[1]); writeout(0,independent);writeout(1,use);
+   bld.pseudo(aco_opcode::p_logical_end); finish_schedule_test();
+END_TEST
+
 BEGIN_TEST(vopd_sched.commutative)
    if (!setup_cs(NULL, GFX11, CHIP_UNKNOWN, "", 32))
       return;
