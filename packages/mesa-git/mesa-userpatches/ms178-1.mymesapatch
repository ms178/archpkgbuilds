+      return false;
+
+   info.opcode = aco_opcode::v_bfe_u32;
+   info.operands[1] = {Operand::c32(shift)};
+   info.operands[2] = {Operand::c32(width)};
+   return true;
+}
+
+/* v_lshrrev_b32(shift, v_and_b32(x, ((1 << width) - 1) << shift))
+ *    -> v_bfe_u32(x, shift, width).
+ *
+ * This catches the equally common C lowering for bitfield extracts where NIR/earlier ACO leaves
+ * the mask before the shift.  Keep the same GFX9-only profitability model as the post-shift form:
+ * Vega replaces two dependent VALU instructions with one VOP3 VALU instruction.  Require a
+ * non-zero constant shift so we do not trade a single AND for a larger VOP3 encoding.
+ */
+static bool
+fold_and_lshr_to_bfe_u32_cb(opt_ctx& ctx, alu_opt_info& info)
+{
+   if (info.operands.size() != 3)
+      return false;
+
+   uint32_t shift = 0;
+   if (!get_u32_constant(ctx, info.operands[1], &shift) || shift == 0 || shift >= 32)
+      return false;
+
+   uint32_t mask = 0;
+   unsigned value_idx = 0;
+   if (get_u32_constant(ctx, info.operands[2], &mask)) {
+      value_idx = 0;
+   } else if (get_u32_constant(ctx, info.operands[0], &mask)) {
+      value_idx = 2;
+   } else {
+      return false;
+   }
+
+   const uint32_t low = mask >> shift;
+   unsigned width = 0;
+   if (!is_low_mask(low, &width) || shift + width > 32)
+      return false;
+
+   const uint64_t expected = uint64_t(BITFIELD_MASK(width)) << shift;
+   if (uint64_t(mask) != expected)
+      return false;
+
+   info.opcode = aco_opcode::v_bfe_u32;
+   info.operands[0] = info.operands[value_idx];
+   info.operands[1] = {Operand::c32(shift)};
+   info.operands[2] = {Operand::c32(width)};
+   return true;
+}
+
+/* Extract (mask, value) from a 2-src AND expressed as two alu_opt_op entries.
+ * mask_op receives the original operand that carried the constant so GFX9 VOP3 can keep a
+ * non-literal form when the constant lives in a temporary.
+ */
+static bool
+split_and_mask_value(opt_ctx& ctx, const alu_opt_op& op0, const alu_opt_op& op1, uint32_t* mask,
+                     alu_opt_op* value, alu_opt_op* mask_op)
+{
+   if (get_u32_constant(ctx, op0, mask)) {
+      *value = op1;
+      *mask_op = op0;
+   } else if (get_u32_constant(ctx, op1, mask)) {
+      *value = op0;
+      *mask_op = op1;
+   } else {
+      return false;
+   }
+   return *mask != 0 && *mask != UINT32_MAX;
+}
+
+/* Encode a BFI mask for VOP3 safely:
+ *  - prefer an inline constant (legal on every GFX)
+ *  - else keep a temp/SGPR that already holds the constant (legal on GFX9)
+ *  - else allow a bare literal only on GFX10+ (VOP3 literal bus)
+ *
+ * Agent A's Cyberpunk hang on Vega was caused by forcing Operand::c32(wide_mask) onto VOP3
+ * on GFX9, which ACO IR rejects and the hardware encoding path must not see as a free
+ * VOP3 literal. Never reintroduce that.
+ */
+static bool
+encode_bfi_mask_operand(opt_ctx& ctx, uint32_t mask, const alu_opt_op& preferred_mask_op,
+                        Operand* out)
+{
+   Operand inline_mask = Operand::get_const(ctx.program->gfx_level, mask, 4);
+   if (!inline_mask.isUndefined() && !inline_mask.isLiteral()) {
+      *out = inline_mask;
+      return true;
+   }
+
+   if (preferred_mask_op.op.isTemp() ||
+       (preferred_mask_op.op.isConstant() && !preferred_mask_op.op.isLiteral())) {
+      *out = preferred_mask_op.op;
+      return true;
+   }
+
+   /* GFX10+: VOP3 may take a true 32-bit literal on the constant bus. */
+   if (ctx.program->gfx_level >= GFX10) {
+      *out = Operand::c32(mask);
+      return true;
+   }
+
+   /* GFX9 (and below): materialize the mask into an SGPR with p_parallelcopy. VOP3 may
+    * consume that SGPR; it must not consume a bare literal (Agent A Cyberpunk hang).
+    * The copy is queued on ctx.pending_before and emitted just before the BFI.
+    */
+   Temp mask_tmp = ctx.program->allocateTmp(s1);
+   if (ctx.info.size() <= mask_tmp.id()) {
+      ctx.info.resize(mask_tmp.id() + 1);
+      ctx.uses.resize(mask_tmp.id() + 1);
+   }
+   /* Start at 0 uses; the combine path that installs the BFI increments uses for each
+    * operand temp, so seeding 1 would double-count and trip validate_opt_ctx.
+    */
+   ctx.uses[mask_tmp.id()] = 0;
+   ctx.info[mask_tmp.id()] = ssa_info{};
+
+   aco_ptr<Instruction> copy{
+      create_instruction(aco_opcode::p_parallelcopy, Format::PSEUDO, 1, 1)};
+   copy->operands[0] = Operand::c32(mask);
+   copy->definitions[0] = Definition(mask_tmp);
+   ctx.info[mask_tmp.id()].parent_instr = copy.get();
+   ctx.info[mask_tmp.id()].set_constant(mask);
+   ctx.pending_before.emplace_back(std::move(copy));
+
+   *out = Operand(mask_tmp);
+   return true;
+}
+
+/* Build v_bfi_b32(mask, insert, base) from two complementary masked values.
+ * insert comes from the AND that used `mask`; base comes from the AND that used ~mask.
+ */
+static bool
+build_bfi_from_masked_pair(opt_ctx& ctx, uint32_t lhs_mask, const alu_opt_op& lhs_val,
+                           const alu_opt_op& lhs_mask_op, uint32_t rhs_mask,
+                           const alu_opt_op& rhs_val, const alu_opt_op& rhs_mask_op,
+                           alu_opt_info& info)
+{
+   if ((lhs_mask ^ rhs_mask) != UINT32_MAX)
+      return false;
+
+   /* Either side can be the insert mask; both encode the same bitfield insert.
+    * Prefer the side whose mask is an inline constant so we avoid an extra SGPR move
+    * (and keep code size down) when one of the complementary masks is inline-encodable.
+    */
+   Operand mask_op;
+   alu_opt_op insert = lhs_val;
+   alu_opt_op base = rhs_val;
+   Operand lhs_try = Operand::get_const(ctx.program->gfx_level, lhs_mask, 4);
+   Operand rhs_try = Operand::get_const(ctx.program->gfx_level, rhs_mask, 4);
+   const bool lhs_inline = !lhs_try.isUndefined() && !lhs_try.isLiteral();
+   const bool rhs_inline = !rhs_try.isUndefined() && !rhs_try.isLiteral();
+   if (rhs_inline && !lhs_inline) {
+      if (!encode_bfi_mask_operand(ctx, rhs_mask, rhs_mask_op, &mask_op))
+         return false;
+      insert = rhs_val;
+      base = lhs_val;
+   } else if (!encode_bfi_mask_operand(ctx, lhs_mask, lhs_mask_op, &mask_op)) {
+      if (!encode_bfi_mask_operand(ctx, rhs_mask, rhs_mask_op, &mask_op))
+         return false;
+      insert = rhs_val;
+      base = lhs_val;
+   }
+
+   info.opcode = aco_opcode::v_bfi_b32;
+   info.operands.resize(3);
+   info.operands[0] = {mask_op};
+   info.operands[1] = insert;
+   info.operands[2] = base;
+   return true;
+}
+
+/* Pattern-callback path: after match_and_apply_patterns expands one AND into the OR
+ * (swizzle "120"), info.operands is [and_src0, and_src1, other_or_src].
+ */
+static bool
+fold_or_and_to_bfi_cb(opt_ctx& ctx, alu_opt_info& info)
+{
+   if (ctx.program->gfx_level < GFX9 || info.operands.size() != 3)
+      return false;
+
+   uint32_t lhs_mask = 0;
+   alu_opt_op lhs_val, lhs_mask_op;
+   if (!split_and_mask_value(ctx, info.operands[0], info.operands[1], &lhs_mask, &lhs_val,
+                             &lhs_mask_op))
+      return false;
+
+   if (!can_match_op(ctx, info.operands[2].op, info.pass_flags))
+      return false;
+
+   Temp other_tmp = info.operands[2].op.getTemp();
+   if (ctx.uses[other_tmp.id()] != 1)
+      return false;
+
+   Instruction* other_instr = ctx.info[other_tmp.id()].parent_instr;
+   if (!can_fold_plain_vop2_bitwise(other_instr, aco_opcode::v_and_b32))
+      return false;
+
+   alu_opt_info other_info;
+   if (!alu_opt_gather_info(ctx, other_instr, other_info) || other_info.operands.size() != 2)
+      return false;
+
+   uint32_t rhs_mask = 0;
+   alu_opt_op rhs_val, rhs_mask_op;
+   if (!split_and_mask_value(ctx, other_info.operands[0], other_info.operands[1], &rhs_mask,
+                             &rhs_val, &rhs_mask_op))
+      return false;
+
+   return build_bfi_from_masked_pair(ctx, lhs_mask, lhs_val, lhs_mask_op, rhs_mask, rhs_val,
+                                     rhs_mask_op, info);
+}
+
+/* Direct dual-AND path (Agent A insight): both OR sources are single-use plain v_and_b32 with
+ * complementary constant masks. This fires before pattern matching and does not depend on which
+ * AND is expanded first. Encoding still goes through encode_bfi_mask_operand — never raw c32 on
+ * GFX9 VOP3.
+ */
+static bool
+fold_or_and_operands_to_bfi(opt_ctx& ctx, alu_opt_info& info)
+{
+   if (ctx.program->gfx_level < GFX9 || info.operands.size() != 2)
+      return false;
+
+   if (!can_match_op(ctx, info.operands[0].op, info.pass_flags) ||
+       !can_match_op(ctx, info.operands[1].op, info.pass_flags))
+      return false;
+
+   Temp lhs_tmp = info.operands[0].op.getTemp();
+   Temp rhs_tmp = info.operands[1].op.getTemp();
+   if (ctx.uses[lhs_tmp.id()] != 1 || ctx.uses[rhs_tmp.id()] != 1)
+      return false;
+
+   Instruction* lhs_instr = ctx.info[lhs_tmp.id()].parent_instr;
+   Instruction* rhs_instr = ctx.info[rhs_tmp.id()].parent_instr;
+   if (!can_fold_plain_vop2_bitwise(lhs_instr, aco_opcode::v_and_b32) ||
+       !can_fold_plain_vop2_bitwise(rhs_instr, aco_opcode::v_and_b32))
+      return false;
+
+   alu_opt_info lhs_info, rhs_info;
+   if (!alu_opt_gather_info(ctx, lhs_instr, lhs_info) ||
+       !alu_opt_gather_info(ctx, rhs_instr, rhs_info) || lhs_info.operands.size() != 2 ||
+       rhs_info.operands.size() != 2)
+      return false;
+
+   uint32_t lhs_mask = 0, rhs_mask = 0;
+   alu_opt_op lhs_val, rhs_val, lhs_mask_op, rhs_mask_op;
+   if (!split_and_mask_value(ctx, lhs_info.operands[0], lhs_info.operands[1], &lhs_mask, &lhs_val,
+                             &lhs_mask_op) ||
+       !split_and_mask_value(ctx, rhs_info.operands[0], rhs_info.operands[1], &rhs_mask, &rhs_val,
+                             &rhs_mask_op))
+      return false;
+
+   return build_bfi_from_masked_pair(ctx, lhs_mask, lhs_val, lhs_mask_op, rhs_mask, rhs_val,
+                                     rhs_mask_op, info);
+}
+
+/* s_and_b32(s_lshr_b32(x, shift), (1 << width) - 1) -> s_bfe_u32(x, width<<16 | shift).
+ *
+ * Mirrors the VALU v_bfe_u32 fold for the scalar unit.  On Vega the SALU is a scarce shared
+ * resource across the CU; collapsing two dependent SALU ops into one s_bfe reduces issue
+ * pressure and shortens scalar dependency chains feeding VMEM address math.
+ *
+ * Encoding: s_bfe packs offset in bits [5:0] and width in bits [22:16] of the second operand.
+ */
+static bool
+fold_s_lshr_and_to_bfe_u32_cb(opt_ctx& ctx, alu_opt_info& info)
+{
+   if (info.operands.size() != 3)
+      return false;
+
+   uint32_t mask = 0;
+   unsigned width = 0;
+   if (!get_u32_constant(ctx, info.operands[2], &mask) || !is_low_mask(mask, &width))
+      return false;
+
+   uint32_t shift = 0;
+   if (!get_u32_constant(ctx, info.operands[1], &shift) || shift >= 32 || shift + width > 32)
+      return false;
+
+   info.opcode = aco_opcode::s_bfe_u32;
+   /* s_bfe_u32(src0=value, src1=packed): keep value at [0], pack width/offset into [1]. */
+   info.operands[1] = {Operand::c32((width << 16) | shift)};
+   info.operands.resize(2);
+   return true;
+}
+
+/* s_lshr_b32(s_and_b32(x, ((1 << width) - 1) << shift), shift) -> s_bfe_u32(x, width<<16 | shift).
+ * Pre-mask form of the scalar bitfield extract.  Require non-zero shift so we do not replace a
+ * single AND with a denser encoding for a pure low-mask.
+ */
+static bool
+fold_s_and_lshr_to_bfe_u32_cb(opt_ctx& ctx, alu_opt_info& info)
+{
+   if (info.operands.size() != 3)
+      return false;
+
+   uint32_t shift = 0;
+   if (!get_u32_constant(ctx, info.operands[1], &shift) || shift == 0 || shift >= 32)
+      return false;
+
+   uint32_t mask = 0;
+   unsigned value_idx = 0;
+   if (get_u32_constant(ctx, info.operands[2], &mask)) {
+      value_idx = 0;
+   } else if (get_u32_constant(ctx, info.operands[0], &mask)) {
+      value_idx = 2;
+   } else {
+      return false;
+   }
+
+   const uint32_t low = mask >> shift;
+   unsigned width = 0;
+   if (!is_low_mask(low, &width) || shift + width > 32)
+      return false;
+
+   const uint64_t expected = uint64_t(BITFIELD_MASK(width)) << shift;
+   if (uint64_t(mask) != expected)
+      return false;
+
+   info.opcode = aco_opcode::s_bfe_u32;
+   info.operands[0] = info.operands[value_idx];
+   info.operands[1] = {Operand::c32((width << 16) | shift)};
+   info.operands.resize(2);
+   return true;
+}
+
+template <unsigned idx, uint32_t expected>
+bool
+check_const_cb(opt_ctx& ctx, alu_opt_info& info)
+{
+   return check_constant(ctx, info, idx, expected);
+}
+
+template <uint32_t expected>
+bool
+remove_const_cb(opt_ctx& ctx, alu_opt_info& info)
+{
+   if (!check_constant(ctx, info, info.operands.size() - 1, expected))
+      return false;
+   info.operands.pop_back();
+   return true;
+}
+
+template <unsigned idx, uint32_t constant>
+bool
+insert_const_cb(opt_ctx& ctx, alu_opt_info& info)
+{
+   assert(idx <= info.operands.size());
+   info.operands.insert(info.operands.begin() + idx, {Operand::c32(constant)});
+   return true;
+}
+
+template <combine_instr_callback func1, combine_instr_callback func2>
+bool
+and_cb(opt_ctx& ctx, alu_opt_info& info)
+{
+   return func1(ctx, info) && func2(ctx, info);
+}
+
+void
+combine_instruction(opt_ctx& ctx, aco_ptr<Instruction>& instr)
+{
+   if (instr->definitions.empty() || is_dead(ctx.uses, instr.get()))
+      return;
+
+   if (instr->opcode == aco_opcode::p_split_vector && instr->operands[0].size() == 1) {
+      /* If all except the first definition still have their extract label, we will likely
+       * eliminate the whole split instruction after copy propagating the first one.
+       * Unconditional copy propagation would mean we end up with more splits
+       * that don't kill their operands.
+       */
+      bool will_be_removed = true;
+      for (unsigned i = 1; i < instr->definitions.size(); i++)
+         will_be_removed &= ctx.info[instr->definitions[i].tempId()].is_extract();
+
+      if (will_be_removed)
+         ctx.info[instr->definitions[0].tempId()].set_temp(instr->operands[0].getTemp());
+   }
+
+   if (instr->isVALU() || instr->isSALU()) {
+      /* Apply SDWA. Do this after label_instruction() so it can remove
+       * label_extract if not all instructions can take SDWA. */
+      alu_propagate_temp_const(ctx, instr, true);
+   } else if (instr->isPseudo()) {
+      /* PSEUDO: propagate temporaries/constants */
+      for (unsigned i = 0; i < instr->operands.size(); i++) {
+         Operand op = instr->operands[i];
+         if (!op.isTemp())
+            continue;
+
+         ssa_info info = ctx.info[op.tempId()];
+         while (info.is_temp()) {
+            if (pseudo_propagate_temp(ctx, instr, info.temp, i)) {
+               ctx.uses[info.temp.id()]++;
+               decrease_and_dce(ctx, op.getTemp());
+               op = instr->operands[i];
+            }
+            info = ctx.info[info.temp.id()];
+         }
+      }
+   }
+
+   if (instr->isDPP())
+      return;
+
+   if (!instr->isVALU() && !instr->isSALU() && !instr->isPseudo())
+      return;
+
+   if (apply_output(ctx, instr))
+      return;
+
+   alu_opt_info info;
+   if (!alu_opt_gather_info(ctx, instr.get(), info))
+      return;
+
+   aco::small_vec<combine_instr_pattern, 8> patterns;
+
+/* Variadic macro to make callback optional and to allow templates<a, b>. */
+#define add_opt(src_op, res_op, mask, swizzle, ...)                                                \
+   patterns.push_back(                                                                             \
+      combine_instr_pattern{aco_opcode::src_op, aco_opcode::res_op, mask, swizzle, __VA_ARGS__})
+
+   if (info.opcode == aco_opcode::v_add_f32) {
       if (ctx.program->dev.has_mad32 && ctx.fp_mode.denorm32 == 0) {
          add_opt(v_mul_f32, v_mad_f32, 0x3, "120");
          add_opt(v_mul_legacy_f32, v_mad_legacy_f32, 0x3, "120");
@@ -4511,11 +5213,42 @@ combine_instruction(opt_ctx& ctx, aco_ptr<Instruction>& instr)
       else
          add_opt(v_mul_lo_u16_e64, v_pk_mad_u16, 0x3, "120");
    } else if (info.opcode == aco_opcode::v_or_b32) {
+      /* Dual-AND BFI before pattern matching (safe mask encoding). */
+      {
+         alu_opt_info direct_info = info;
+         if (fold_or_and_operands_to_bfi(ctx, direct_info) &&
+             alu_opt_info_is_valid(ctx, direct_info)) {
+            info = std::move(direct_info);
+            for (const alu_opt_op& op_info : info.operands) {
+               if (op_info.op.isTemp())
+                  ctx.uses[op_info.op.tempId()]++;
+            }
+            for (const Operand& op : instr->operands) {
+               if (op.isTemp())
+                  decrease_and_dce(ctx, op.getTemp());
+            }
+            ctx.pre_combine_instrs.emplace_back(std::move(instr));
+            instr.reset(alu_opt_info_to_instr(ctx, info, nullptr));
+            ctx.info[instr->definitions[0].tempId()].set_combined(ctx.pre_combine_instrs.size() - 1);
+            return;
+         }
+      }
       add_opt(v_not_b32, v_bfi_b32, 0x3, "10", insert_const_cb<2, UINT32_MAX>, true);
       add_opt(s_not_b32, v_bfi_b32, 0x3, "10", insert_const_cb<2, UINT32_MAX>, true);
       if (ctx.program->gfx_level >= GFX9) {
+         add_opt(v_and_b32, v_bfi_b32, 0x3, "120", fold_or_and_to_bfi_cb);
          add_opt(v_or_b32, v_or3_b32, 0x3, "012", nullptr, true);
          add_opt(s_or_b32, v_or3_b32, 0x3, "012", nullptr, true);
+         if (ctx.program->gfx_level == GFX9) {
+            add_opt(v_lshlrev_b32, v_alignbyte_b32, 0x3, "012",
+                    fold_lshl_lshr_to_alignbyte_cb, true);
+            add_opt(v_lshrrev_b32, v_alignbyte_b32, 0x3, "012",
+                    fold_lshr_lshl_to_alignbyte_cb, true);
+            add_opt(v_lshlrev_b32, v_alignbit_b32, 0x3, "012",
+                    fold_lshl_lshr_to_alignbit_cb, true);
+            add_opt(v_lshrrev_b32, v_alignbit_b32, 0x3, "012",
+                    fold_lshr_lshl_to_alignbit_cb, true);
+         }
          add_opt(v_lshlrev_b32, v_lshl_or_b32, 0x3, "210", nullptr, true);
          add_opt(s_lshl_b32, v_lshl_or_b32, 0x3, "120", nullptr, true);
          add_opt(v_and_b32, v_and_or_b32, 0x3, "120", nullptr, true);
@@ -4634,11 +5367,24 @@ combine_instruction(opt_ctx& ctx, aco_ptr<Instruction>& instr)
       add_opt(v_add_u32, v_add_lshl_u32, 0x2, "120", nullptr, true);
       add_opt(s_add_u32, v_add_lshl_u32, 0x2, "120", nullptr, true);
       add_opt(s_add_i32, v_add_lshl_u32, 0x2, "120", nullptr, true);
+   } else if (info.opcode == aco_opcode::v_lshrrev_b32) {
+      /* v_bfe_u32 is full-rate VOP3 vs two dependent VOP2s — profitable on all GCN/RDNA. */
+      add_opt(v_and_b32, v_bfe_u32, 0x2, "201", fold_and_lshr_to_bfe_u32_cb, true);
    } else if (info.opcode == aco_opcode::v_and_b32) {
+      add_opt(v_lshrrev_b32, v_bfe_u32, 0x3, "210", fold_lshr_and_to_bfe_u32_cb, true);
       add_opt(v_not_b32, v_bfi_b32, 0x3, "10", insert_const_cb<1, 0>, true);
       add_opt(s_not_b32, v_bfi_b32, 0x3, "10", insert_const_cb<1, 0>, true);
    } else if (info.opcode == aco_opcode::s_and_b32) {
+      /* s_lshr is (value, shift) unlike v_lshrrev which is (shift, value). Use "120".
+       * SALU s_bfe is available across GCN/RDNA; folding is always a throughput win.
+       */
+      add_opt(s_lshr_b32, s_bfe_u32, 0x3, "120", fold_s_lshr_and_to_bfe_u32_cb, true);
       add_opt(s_not_b32, s_andn2_b32, 0x3, "01");
+   } else if (info.opcode == aco_opcode::s_lshr_b32) {
+      /* Match s_and only on the value operand (bit 0). Swizzle "102" yields
+       * [and_src0, lshr_shift, and_src1] for the pre-mask BFE callback.
+       */
