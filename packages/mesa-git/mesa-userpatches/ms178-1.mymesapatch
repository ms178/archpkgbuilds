+                        Operand::c32(16u), Operand::c32(false));
+
+   /* s_pack_hh is unavailable before GFX9, so the original form must remain. */
+   //! s1: %hi0, s1: %_:scc = p_extract %b, 1, 16, 0
+   //! s1: %res0 = s_pack_ll_b32_b16 %hi0, 0x1234
+   //! p_unit_test 0, %res0
+   writeout(0, bld.sop2(aco_opcode::s_pack_ll_b32_b16, bld.def(s1), hi, Operand::c32(0x1234u)));
