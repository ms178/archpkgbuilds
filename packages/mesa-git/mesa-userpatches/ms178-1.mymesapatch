-/* Remove superfluous extract after ds_read like so:
- * p_extract(ds_read_uN(), 0, N, 0) -> ds_read_uN()
+bool
+try_rewrite_load_extract_offset(opt_ctx& ctx, Instruction* load, uint64_t byte_offset)
+{
+   if (load->isDS()) {
+      if (load->ds().offset1 != 0)
+         return false;
+
+      const uint64_t max_extra_offset = UINT16_MAX - (uint64_t)load->ds().offset0;
+      if (byte_offset > max_extra_offset)
+         return false;
+
+      load->ds().offset0 += (uint16_t)byte_offset;
+      return true;
+   }
+
+   if (load->isSMEM()) {
+      if (!load->operands[1].isConstant())
+         return false;
+
+      const uint64_t offset = load->operands[1].constantValue();
+      if (offset + byte_offset > ctx.program->dev.smem_offset_max)
+         return false;
+
+      load->operands[1] = Operand::c32(offset + byte_offset);
+      return true;
+   }
+
+   if (load->isMUBUF()) {
+      if (load->mubuf().offset > 0x7fffffu - byte_offset)
+         return false;
+
+      load->mubuf().offset += (uint32_t)byte_offset;
+      return true;
+   }
+
+   if (load->isFlatLike()) {
+      constexpr int32_t flat_offset_max = (1 << 23) - 1;
+      if (load->flatlike().offset > flat_offset_max - (int32_t)byte_offset)
+         return false;
+
+      load->flatlike().offset += (int32_t)byte_offset;
+      return true;
+   }
+
+   return false;
+}
+
+/* Remove superfluous extract after loads like so:
+ * p_extract(load_uN(), 0, N, 0) -> load_uN()
+ * p_extract(load_dwordx2(), 1, 32, 0) -> load_dword() with a folded byte offset
  */
