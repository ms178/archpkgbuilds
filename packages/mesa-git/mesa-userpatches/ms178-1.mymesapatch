+   uint32_t i = 0;
+
+   /*
+    * Main SIMD loop: process 32 elements per iteration with four independent
+    * YMM vectors.  This exposes enough independent load/min/store chains to
+    * keep Raptor Lake's load ports and vector integer pipe fed without relying
+    * on the compiler to rediscover the unroll.  The explicit loop also avoids
+    * Clang generating a second auto-vectorized "scalar tail" loop after the
+    * 8-wide intrinsic loop, which llvm-mca shows as extra branch/front-end work
+    * for no gain when the true tail is bounded.
+    */
+   const uint32_t vec32_count = count & ~31u;
+   for (; i < vec32_count; i += 32u) {
+      __m256i va0 = _mm256_loadu_si256((const __m256i *)(a + i));
+      __m256i va1 = _mm256_loadu_si256((const __m256i *)(a + i + 8u));
+      __m256i va2 = _mm256_loadu_si256((const __m256i *)(a + i + 16u));
+      __m256i va3 = _mm256_loadu_si256((const __m256i *)(a + i + 24u));
+      __m256i vb0 = _mm256_loadu_si256((const __m256i *)(b + i));
+      __m256i vb1 = _mm256_loadu_si256((const __m256i *)(b + i + 8u));
+      __m256i vb2 = _mm256_loadu_si256((const __m256i *)(b + i + 16u));
+      __m256i vb3 = _mm256_loadu_si256((const __m256i *)(b + i + 24u));
+
+      _mm256_storeu_si256((__m256i *)(out + i), _mm256_min_epu32(va0, vb0));
+      _mm256_storeu_si256((__m256i *)(out + i + 8u), _mm256_min_epu32(va1, vb1));
+      _mm256_storeu_si256((__m256i *)(out + i + 16u), _mm256_min_epu32(va2, vb2));
+      _mm256_storeu_si256((__m256i *)(out + i + 24u), _mm256_min_epu32(va3, vb3));
+   }
