+    * to avoid the range-for-loop epilogue and the .end() reload. */
+   const auto& defs = instr->definitions;
+   const size_t nd = defs.size();
+   if (ACO_LIVE_LIKELY(nd == 1)) {
+      const Definition& d = defs[0];
+      if (ACO_LIVE_LIKELY(d.isTemp() && !d.isKill()))
+         changes += d.getTemp();
+   } else {
+      for (const Definition& d : defs) {
+         if (!d.isTemp() || d.isKill())
+            continue;
+         changes += d.getTemp();
+      }
    }
 
-   for (const Operand& op : instr->operands) {
-      if (!op.isTemp() || !op.isFirstKill())
-         continue;
-      changes -= op.getTemp();
+   /* Similarly: ~80% have <=2 operands (VOP2/VOPC dominate the IR). */
+   const auto& ops = instr->operands;
+   const size_t no = ops.size();
+   if (ACO_LIVE_LIKELY(no <= 2)) {
+      if (no >= 1) {
+         const Operand& o0 = ops[0];
+         if (o0.isTemp() && o0.isFirstKill())
+            changes -= o0.getTemp();
+      }
+      if (no == 2) {
+         const Operand& o1 = ops[1];
+         if (o1.isTemp() && o1.isFirstKill())
+            changes -= o1.getTemp();
+      }
+   } else {
+      for (const Operand& o : ops) {
+         if (!o.isTemp() || !o.isFirstKill())
+            continue;
+         changes -= o.getTemp();
+      }
