-   wl_global_destroy(drm->wl_drm_global);
+   /* Destroy global (prevents new client binds) */
+   if (drm->wl_drm_global != NULL) {
+      wl_global_destroy(drm->wl_drm_global);
+   }
+
+   /* Free device name string */
+   free(drm->device_name);
 
+   /* Free the wl_drm object itself */
    free(drm);
 }
diff --git a/src/egl/wayland/wayland-drm/wayland-drm.h b/src/egl/wayland/wayland-drm/wayland-drm.h
index 6997e0d583513e0833ec44faa81bd497d8b06c13..21f5ffea965beedb822020a2083249a7eba06f7d 100644
--- a/src/egl/wayland/wayland-drm/wayland-drm.h
+++ b/src/egl/wayland/wayland-drm/wayland-drm.h
@@ -1,23 +1,114 @@
+/*
