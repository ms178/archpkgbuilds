+      //~gfx11! v2b: %0:v[0][0:16] = v_mov_b16 0x4200
+      bld.pseudo(aco_opcode::p_unit_test, Operand::zero());
+      bld.pseudo(aco_opcode::p_create_vector, Definition(v0_lo, v2b), Operand(v1b),
+                 Operand::c8(0x42));
+
+      //! p_unit_test 1
+      //! v1: %0:v[0] = v_mov_b32 0x42050000
+      bld.pseudo(aco_opcode::p_unit_test, Operand::c32(1));
+      bld.pseudo(aco_opcode::p_create_vector, Definition(v0_lo, v4b), Operand(v2b),
+                 Operand::c16(0x4205));
+
+      //! p_unit_test 2
