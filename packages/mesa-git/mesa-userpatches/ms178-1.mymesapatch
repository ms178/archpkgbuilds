-   for (uint32_t i = 0; i < count; i++) {
-      out[i] = MIN2(a[i], b[i]);
-   }
+   /*
+    * CRITICAL FIX: Original code used signed `1 << level` which is undefined
+    * behavior for level >= 31 (signed integer overflow, C17 §6.5.7).
+    * Using `1u << level` ensures well-defined unsigned shift.
+    */
+   assert(level < 32u);
+   return 1u << level;
