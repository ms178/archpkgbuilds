index b4ca8c0d44695791d9c2245b2e7fa040246c949a..e18c0a7d834a801e2ef7a2b5988766fcac6a914b 100644
--- a/src/compiler/nir/tests/loop_analyze_tests.cpp
+++ b/src/compiler/nir/tests/loop_analyze_tests.cpp
@@ -2011,6 +2011,122 @@ TWO_TERMINATOR_INEXACT_COUNT_TEST(input_unsigned_limit_j_limit, false, true, fal
