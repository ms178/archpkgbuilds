+static nir_loop *
+loop_builder_signed_range_limit(nir_builder *b)
+{
+   /*
+    * int i = 0;
+    * int limit = int8_t(load_global());
+    * while (true) {
+    *    if (limit < i)
+    *       break;
+    *    i++;
+    * }
+    */
+   nir_def *zero = nir_imm_int(b, 0);
+   nir_def *one = nir_imm_int(b, 1);
+   nir_def *unknown8 = nir_load_global(b, 1, 8, nir_undef(b, 1, 64));
+   nir_def *limit = nir_i2i32(b, unknown8);
+   nir_phi_instr *phi = nir_phi_instr_create(b->shader);
+
+   nir_loop *loop = nir_push_loop(b);
+   {
+      nir_def_init(&phi->instr, &phi->def, 1, 32);
+      nir_phi_instr_add_src(phi, nir_def_block(zero), zero);
+
+      nir_def *i = &phi->def;
+      nir_def *cond = nir_ilt(b, limit, i);
+      nir_if *nif = nir_push_if(b, cond);
+      {
+         nir_jump_instr *jump =
+            nir_jump_instr_create(b->shader, nir_jump_break);
+         nir_builder_instr_insert(b, &jump->instr);
+      }
+      nir_pop_if(b, nif);
+
+      nir_def *next = nir_iadd(b, i, one);
+      nir_phi_instr_add_src(phi, nir_def_block(next), next);
+   }
+   nir_pop_loop(b, loop);
+
+   b->cursor = nir_before_block(nir_loop_first_block(loop));
+   nir_builder_instr_insert(b, &phi->instr);
+
+   return loop;
+}
+
+TEST_F(nir_loop_analyze_test, signed_range_limit)
+{
+   nir_loop *loop = loop_builder_signed_range_limit(&b);
+
+   nir_validate_shader(b.shader, "input");
+   nir_loop_analyze_impl(b.impl, nir_var_all, false);
+
+   ASSERT_NE((void *)0, loop->info);
+   ASSERT_NE((void *)0, loop->info->limiting_terminator);
+   EXPECT_EQ(128, loop->info->max_trip_count);
+   EXPECT_FALSE(loop->info->exact_trip_count_known);
+   EXPECT_TRUE(loop->info->limiting_terminator->exact_trip_count_unknown);
+}
+
+static nir_loop *
+loop_builder_signed_lower_range_limit(nir_builder *b)
+{
+   /*
+    * int i = 8;
+    * int limit = int8_t(load_global());
+    * while (true) {
+    *    if (i < limit)
+    *       break;
+    *    i--;
+    * }
+    */
+   nir_def *eight = nir_imm_int(b, 8);
+   nir_def *minus_one = nir_imm_int(b, -1);
+   nir_def *unknown8 = nir_load_global(b, 1, 8, nir_undef(b, 1, 64));
+   nir_def *limit = nir_i2i32(b, unknown8);
+   nir_phi_instr *phi = nir_phi_instr_create(b->shader);
+
+   nir_loop *loop = nir_push_loop(b);
+   {
+      nir_def_init(&phi->instr, &phi->def, 1, 32);
+      nir_phi_instr_add_src(phi, nir_def_block(eight), eight);
+
+      nir_def *i = &phi->def;
+      nir_def *cond = nir_ilt(b, i, limit);
+      nir_if *nif = nir_push_if(b, cond);
+      {
+         nir_jump_instr *jump =
+            nir_jump_instr_create(b->shader, nir_jump_break);
+         nir_builder_instr_insert(b, &jump->instr);
+      }
+      nir_pop_if(b, nif);
+
+      nir_def *next = nir_iadd(b, i, minus_one);
+      nir_phi_instr_add_src(phi, nir_def_block(next), next);
+   }
+   nir_pop_loop(b, loop);
+
+   b->cursor = nir_before_block(nir_loop_first_block(loop));
+   nir_builder_instr_insert(b, &phi->instr);
+
+   return loop;
+}
+
+TEST_F(nir_loop_analyze_test, signed_lower_range_limit)
+{
+   nir_loop *loop = loop_builder_signed_lower_range_limit(&b);
+
+   nir_validate_shader(b.shader, "input");
+   nir_loop_analyze_impl(b.impl, nir_var_all, false);
+
+   ASSERT_NE((void *)0, loop->info);
+   ASSERT_NE((void *)0, loop->info->limiting_terminator);
+   EXPECT_EQ(137, loop->info->max_trip_count);
+   EXPECT_FALSE(loop->info->exact_trip_count_known);
+   EXPECT_TRUE(loop->info->limiting_terminator->exact_trip_count_unknown);
+}
