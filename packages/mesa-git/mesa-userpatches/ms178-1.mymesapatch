+   case 6: out[i + 5] = MIN2(a[i + 5], b[i + 5]); FALLTHROUGH;
+   case 5: out[i + 4] = MIN2(a[i + 4], b[i + 4]); FALLTHROUGH;
+   case 4: out[i + 3] = MIN2(a[i + 3], b[i + 3]); FALLTHROUGH;
+   case 3: out[i + 2] = MIN2(a[i + 2], b[i + 2]); FALLTHROUGH;
+   case 2: out[i + 1] = MIN2(a[i + 1], b[i + 1]); FALLTHROUGH;
