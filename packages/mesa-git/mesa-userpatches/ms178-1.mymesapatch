+BEGIN_TEST(optimizer.gfx9_alignbit_bfe)
+   //>> v1: %a:v[0], v1: %b:v[1], v1: %c:v[2] = p_startpgm
+   if (!setup_cs("v1 v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+   Temp c = inputs[2];
+
+   //! v1: %res0 = v_alignbyte_b32 %a, %b, 3
+   //! p_unit_test 0, %res0
+   Temp shl0 = bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(8), a);
+   Temp shr0 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(24), b);
+   writeout(0, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), shl0, shr0));
+
+   //! v1: %res1 = v_alignbit_b32 %a, %b, 5
+   //! p_unit_test 1, %res1
+   Temp shr1 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(27), a);
+   Temp shl1 = bld.vop2(aco_opcode::v_lshlrev_b32, bld.def(v1), Operand::c32(5), b);
+   writeout(1, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), shr1, shl1));
+
+   //! v1: %res2 = v_bfe_u32 %a, 7, 5
+   //! p_unit_test 2, %res2
+   Temp shr2 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(7), a);
+   writeout(2, bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0x1f), shr2));
+
+   //! v1: %res3 = v_bfe_u32 %b, 9, 6
+   //! p_unit_test 3, %res3
+   Temp and3 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0x7e00), b);
+   writeout(3, bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(9), and3));
+
+   //! v1: %shr4 = v_lshrrev_b32 25, %c
+   //! v1: %res4 = v_and_b32 0xff, %shr4
+   //! p_unit_test 4, %res4
+   Temp shr4 = bld.vop2(aco_opcode::v_lshrrev_b32, bld.def(v1), Operand::c32(25), c);
+   writeout(4, bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xff), shr4));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.gfx9_bfi_or_and)
+   /* Inline-mask BFI on GFX9. Match order may pick either complementary mask. */
+   //>> v1: %a:v[0], v1: %b:v[1] = p_startpgm
+   if (!setup_cs("v1 v1", GFX9))
+      return;
+
+   Temp a = inputs[0];
+   Temp b = inputs[1];
+
+   //; search_re('v_bfi_b32 1')
+   //; search_re('p_unit_test 0')
+   //; search_re('v_bfi_b32 63')
+   //; search_re('p_unit_test 1')
+   //; insert_pattern('s_endpgm')
+   Temp masked_insert0 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(1), a);
+   Temp masked_base0 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xfffffffeu), b);
+   writeout(0, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), masked_insert0, masked_base0));
+
+   Temp masked_base1 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0xffffffc0u), a);
+   Temp masked_insert1 = bld.vop2(aco_opcode::v_and_b32, bld.def(v1), Operand::c32(0x3f), b);
+   writeout(1, bld.vop2(aco_opcode::v_or_b32, bld.def(v1), masked_base1, masked_insert1));
+
+   finish_opt_test();
+END_TEST
+
+BEGIN_TEST(optimizer.redundant_integer_bitwise)
+   //>> v1: %a:v[0], v1: %b:v[1], s2: %cond:s[0-1] = p_startpgm
+   if (!setup_cs("v1 v1 s2", GFX9))
