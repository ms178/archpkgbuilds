+static int
+radv_linear_search_bo(const struct drm_amdgpu_bo_list_entry *handles,
+                      unsigned count, uint32_t target)
+{
+   unsigned i = 0u;
+
+   for (; i + 4u <= count; i += 4u) {
+      if (unlikely(handles[i + 0].bo_handle == target))
+         return (int)(i + 0);
+      if (unlikely(handles[i + 1].bo_handle == target))
+         return (int)(i + 1);
+      if (unlikely(handles[i + 2].bo_handle == target))
+         return (int)(i + 2);
+      if (unlikely(handles[i + 3].bo_handle == target))
+         return (int)(i + 3);
+   }
+
+   for (; i < count; ++i) {
+      if (handles[i].bo_handle == target)
+         return (int)i;
+   }
+
+   return -1;
+}
