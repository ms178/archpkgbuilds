-         jit_tex->mip_offsets[j] = mip_offsets[j];
-         jit_tex->row_stride[j] = row_stride[j];
-         jit_tex->img_stride[j] = img_stride[j];
+      assert(first_level <= last_level);
+      assert(first_level < PIPE_MAX_TEXTURE_LEVELS);
+      assert(last_level < PIPE_MAX_TEXTURE_LEVELS);
+      if (first_level > last_level || first_level >= PIPE_MAX_TEXTURE_LEVELS ||
+          last_level >= PIPE_MAX_TEXTURE_LEVELS)
+         return;
+
+      for (unsigned level = 0; level < PIPE_MAX_TEXTURE_LEVELS; level++) {
+         if (level >= first_level && level <= last_level) {
+            jit_tex->mip_offsets[level] = mip_offsets[level];
+            jit_tex->row_stride[level] = row_stride[level];
+            jit_tex->img_stride[level] = img_stride[level];
+         }
       }
    }
 }
