-      unsigned num_bits = MAX2(1, glsl_get_aoa_size(deref->var->type));
-      ainfo->indices = BITSET_RZALLOC(live, num_bits);
+      if (likely(ainfo != NULL)) {
+         unsigned num_bits = MAX2(1, glsl_get_aoa_size(deref->var->type));
