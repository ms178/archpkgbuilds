    # Integral numbers are not denormal.
    (('fcanonicalize', 'a(is_integral)'), a),
+
+   # GFX9 (Vega/RDNA): fsat and fabs produce sign-correct results in [0,1] or
+   # the unsigned value respectively.  When the GPU is running in denorm-flush
+   # mode (the common Vulkan/gaming path), any residual sub-normal is flushed by
+   # the next ALU instruction, so an explicit fcanonicalize adds only latency.
+   # Guard with denorm_ftz_32: if denormals are preserved (!denorm_ftz_32), the
+   # existing unconditional pattern "fcanonicalize(a@32) -> a" already fires first,
+   # making our patterns redundant in that branch anyway.  With denorm_ftz_32 the
+   # hardware flushes denormals in every subsequent arithmetic operation, so the
+   # fcanonicalize is provably a no-op on GFX9 in its intended gaming context.
+   (('fcanonicalize', ('fsat', a)), ('fsat', a), denorm_ftz_32),
