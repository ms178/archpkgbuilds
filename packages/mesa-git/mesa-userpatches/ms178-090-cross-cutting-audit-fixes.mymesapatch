+   if (UNLIKELY(!cache || (!data && size != 0))) {
       free(data);
       return;
    }
@@ -1140,6 +1143,9 @@ disk_cache_get(struct disk_cache *cache, const cache_key key, size_t *size)
       *size = 0;
    }
 
+   if (UNLIKELY(!cache))
+      return NULL;
