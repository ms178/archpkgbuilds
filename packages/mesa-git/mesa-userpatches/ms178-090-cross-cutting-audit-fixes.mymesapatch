 #else
 #  define U_VECTOR_ASSUME_ALIGNED_PTR(p) (p)
@@ -83,7 +89,7 @@ static void u_vector_aligned_free(void *ptr);
 ATTRIBUTE_COLD static bool u_vector_realloc_buffer(struct u_vector *vector, uint32_t new_size);
