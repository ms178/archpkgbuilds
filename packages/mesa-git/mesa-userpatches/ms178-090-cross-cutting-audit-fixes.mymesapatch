+      if (unlikely(!u_vector_rebase(vector)))
+         return NULL;
    }
 
+   const uint32_t mask = vector->size - 1;
+   const uint32_t offset = vector->tail & mask;
    vector->tail += vector->element_size;
 
 #if U_VECTOR_PREFETCH
diff --git a/src/util/u_vector.h b/src/util/u_vector.h
index 544b570d..9ca62d53 100644
--- a/src/util/u_vector.h
+++ b/src/util/u_vector.h
@@ -28,6 +28,9 @@
 #include <stdint.h>
 #include <stdlib.h>
 #include <string.h>
+#if defined(_WIN32)
+#include <malloc.h>
+#endif
 
 #include "util/macros.h"
 #include "util/u_math.h"
@@ -61,7 +64,14 @@ extern "C" {
  * 1. 'data' at offset 0 eliminates displacement bytes in hot-path loads.
  * 2. Aligned to 64 bytes to ensure this vector owns its cache line.
  */
-struct __attribute__((aligned(U_VECTOR_CACHE_LINE_SIZE))) u_vector {
+#if defined(_MSC_VER)
+__declspec(align(U_VECTOR_CACHE_LINE_SIZE))
+#endif
+struct
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__((aligned(U_VECTOR_CACHE_LINE_SIZE)))
+#endif
+u_vector {
    void *data;             /* offset 0:  base pointer (hot)           */
    uint32_t head;          /* offset 8:  producer index (hot)         */
    uint32_t tail;          /* offset 12: consumer index (hot)         */
@@ -125,7 +135,11 @@ u_vector_tail(struct u_vector *U_VECTOR_RESTRICT q) /* oldest element */
 static inline void
 u_vector_finish(struct u_vector *q)
 {
+#if defined(_WIN32)
+   _aligned_free(q->data);
+#else
    free(q->data);
+#endif
    memset(q, 0, sizeof(*q));
 }
 
