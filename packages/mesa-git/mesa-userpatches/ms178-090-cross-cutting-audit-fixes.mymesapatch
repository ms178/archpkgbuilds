-   (void)u_vector_realloc_buffer(vector, vector->size);
+   /* Re-allocate to same size effectively linearizes the buffer.  This is a
+    * rare overflow-avoidance path; if allocation fails, callers must fail
+    * rather than wrap head/tail and corrupt queue state. */
+   return u_vector_realloc_buffer(vector, vector->size);
 }
 
