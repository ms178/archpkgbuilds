+static ALWAYS_INLINE bool u_vector_rebase(struct u_vector *vector);
 
 /* -------------------------------  ALLOC HELPERS  ------------------------------ */
 
@@ -105,22 +111,13 @@ u_vector_aligned_alloc(size_t alignment, size_t size)
    if (posix_memalign(&ptr, alignment, size) != 0)
       ptr = NULL;
 #elif defined(_ISOC11_SOURCE) || (__STDC_VERSION__ >= 201112L)
-   if (size % alignment == 0) {
-      ptr = aligned_alloc(alignment, size);
-   } else {
-      if (posix_memalign(&ptr, alignment, size) != 0)
-         ptr = NULL;
-   }
+   size_t aligned_size = (size + alignment - 1) & ~(alignment - 1);
+   ptr = aligned_alloc(alignment, aligned_size);
 #else
-   /* Portable fallback */
-   void *raw = malloc(size + alignment - 1 + sizeof(void *));
-   if (!raw)
-      return NULL;
-
-   uintptr_t adj  = (uintptr_t)raw + sizeof(void *) + (alignment - 1);
-   uintptr_t base = adj & ~((uintptr_t)alignment - 1);
-   ptr            = (void *)base;
-   *((void **)ptr - 1) = raw;
+   /* Last-resort fallback: keep the pointer free()-compatible.  We deliberately
+    * do not use a hidden over-allocation header here because u_vector_finish()
+    * is an inline public helper and must be able to release the allocation. */
+   ptr = malloc(size);
 #endif
 
    return ptr;
@@ -134,10 +131,8 @@ u_vector_aligned_free(void *ptr)
 
 #if defined(_WIN32)
    _aligned_free(ptr);
-#elif defined(HAVE_POSIX_MEMALIGN) || defined(_ISOC11_SOURCE) || (__STDC_VERSION__ >= 201112L)
-   free(ptr);
 #else
-   free(*((void **)ptr - 1));
+   free(ptr);
 #endif
 }
 
@@ -230,11 +225,13 @@ u_vector_grow(struct u_vector *vector)
  * Fixes rare counter overflow by moving data to the start of the buffer
  * and resetting head/tail. Previous implementation was broken (data corruption).
  */
-static ALWAYS_INLINE void
+static ALWAYS_INLINE bool
 u_vector_rebase(struct u_vector *vector)
 {
