       buf = disk_cache_load_item_foz(cache->foz_ro_cache, key, size);
    }
@@ -1190,12 +1196,18 @@ _Static_assert(CACHE_KEY_SIZE == 32,
 
 #if (defined(__x86_64__) || defined(_M_X64))
 
+#if defined(__GNUC__) || defined(__clang__)
+#define CACHE_KEY_HAS_RUNTIME_AVX2 1
+#elif defined(__AVX2__)
+#define CACHE_KEY_HAS_RUNTIME_AVX2 1
+#else
+#define CACHE_KEY_HAS_RUNTIME_AVX2 0
+#endif
+
 /*
- * AVX2 path: single 256-bit comparison - optimal for 32-byte keys
- * Per Agner Fog's tables: vpcmpeqb ymm has 1 cycle latency on Haswell+
- * vpmovmskb ymm has 3 cycle latency on Raptor Lake P-cores
- * Total: ~4 cycles vs ~10+ for memcmp with function call overhead
+ * AVX2 path: single 256-bit comparison - optimal for 32-byte keys.
  */
+#if CACHE_KEY_HAS_RUNTIME_AVX2
 #if defined(__GNUC__) || defined(__clang__)
 __attribute__((target("avx2")))
 #endif
@@ -1210,6 +1222,8 @@ cache_key_equals_avx2(const unsigned char *a, const unsigned char *b)
    return is_zero != 0;
 }
 
+#endif /* CACHE_KEY_HAS_RUNTIME_AVX2 */
+
 static inline bool
 cache_key_equals_sse2(const unsigned char *a, const unsigned char *b)
 {
@@ -1246,13 +1260,15 @@ cache_key_equals_fast(const unsigned char *a, const unsigned char *b)
       __cpuidex(info, 7, 0);
       has_avx2 = (info[1] & (1 << 5)) != 0;
 #endif
-      state = has_avx2 ? 2u : 1u;
+      state = (CACHE_KEY_HAS_RUNTIME_AVX2 && has_avx2) ? 2u : 1u;
       p_atomic_set(&avx2_support_state, state);
    }
 
+#if CACHE_KEY_HAS_RUNTIME_AVX2
    if (state == 2) {
       return cache_key_equals_avx2(a, b);
    }
+#endif
    return cache_key_equals_sse2(a, b);
 }
 
diff --git a/src/util/u_vector.c b/src/util/u_vector.c
