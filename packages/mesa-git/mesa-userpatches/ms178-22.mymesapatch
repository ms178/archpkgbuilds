+ALWAYS_INLINE static int32_t
+radv_ceilf_to_i32_sat(float v)
+{
+   const double d = ceil((double)v);
+   if (d <= (double)INT32_MIN)
+      return INT32_MIN;
+   if (d >= (double)INT32_MAX)
+      return INT32_MAX;
+   return (int32_t)d;
