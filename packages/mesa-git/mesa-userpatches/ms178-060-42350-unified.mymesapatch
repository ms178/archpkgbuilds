diff --git a/docs/features.txt b/docs/features.txt
index ad47599..162ff53 100644
--- a/docs/features.txt
+++ b/docs/features.txt
@@ -730,7 +730,7 @@ Khronos extensions that are not part of any Vulkan version:
   VK_ARM_shader_core_builtins                           DONE (panvk/v9+)
   VK_ARM_shader_core_properties                         DONE (panvk/v10+)
   VK_GOOGLE_decorate_string                             DONE (anv, hasvk, hk, kk, lvp, nvk, panvk, radv, tu, vn)
-  VK_GOOGLE_display_timing                              DONE (anv, panvk, pvr, radv, tu, v3dv)
+  VK_GOOGLE_display_timing                              DONE (anv, hk, nvk, panvk, pvr, radv, tu, v3dv)
   VK_GOOGLE_hlsl_functionality1                         DONE (anv, hasvk, hk, kk, lvp, nvk, panvk, radv, tu, vn)
   VK_GOOGLE_user_type                                   DONE (anv, hasvk, hk, kk, lvp, nvk, panvk, radv, tu, vn)
   VK_IMG_filter_cubic                                   DONE (tu/a650+, vn)
diff --git a/docs/relnotes/new_features.txt b/docs/relnotes/new_features.txt
index b084548..2b5c0a5 100644
--- a/docs/relnotes/new_features.txt
+++ b/docs/relnotes/new_features.txt
@@ -23,7 +23,7 @@ VK_{KHR,EXT}_index_type_uint8 on pvr
 VK_EXT_debug_marker in vulkan runtime
 VK_EXT_mesh_shader on NVK
 VK_KHR_device_fault on RADV
-VK_GOOGLE_display_timing for KHR_display on anv, panvk, pvr, radv, tu, v3dv
+VK_GOOGLE_display_timing for KHR_display (and opt-in for x11, wayland) on anv, hk, nvk, panvk, pvr, radv, tu, v3dv
 VK_KHR_shader_abort on RADV
 VK_KHR_shader_fma on panvk
 VK_NV_shader_atomic_float16_vector on NVK
diff --git a/src/amd/vulkan/radv_instance.c b/src/amd/vulkan/radv_instance.c
index d75b724..9b54b74 100644
--- a/src/amd/vulkan/radv_instance.c
+++ b/src/amd/vulkan/radv_instance.c
@@ -183,16 +183,37 @@ static const struct debug_control trace_options[] = {
 static void
 radv_init_dri_options(struct radv_instance *instance)
 {
+   /*
+    * LTO SAFETY: Memory barriers prevent GCC/LTO from optimizing away the
+    * drirc parsing result. Without barriers, the compiler may incorrectly
+    * determine that the parsed options are unused and eliminate the code.
+    */
+#if defined(__GNUC__) || defined(__clang__)
+#define RADV_DRIRC_BARRIER() __asm__ __volatile__("" ::: "memory")
+#else
+#define RADV_DRIRC_BARRIER() ((void)0)
+#endif
+
    struct radv_drirc *drirc = &instance->drirc;
 
+   /* Barrier: ensure no reordering before parsing */
+   RADV_DRIRC_BARRIER();
+
+   /* Parse drirc files using the existing generated function.
+    * The barriers ensure LTO doesn't optimize away the parsing result.
+    */
    radv_parse_dri_options(drirc, &(driConfigFileParseParams){
                                     .driverName = "radv",
+                                    .kernelDriverName = "amdgpu",
                                     .applicationName = instance->vk.app_info.app_name,
                                     .applicationVersion = instance->vk.app_info.app_version,
                                     .engineName = instance->vk.app_info.engine_name,
                                     .engineVersion = instance->vk.app_info.engine_version,
                                  });
 
+   /* Barrier: ensure parsing is complete before any code reads options */
+   RADV_DRIRC_BARRIER();
+
    if (instance->vk.app_info.engine_name && !strcmp(instance->vk.app_info.engine_name, "DXVK")) {
       /* Since 2.3.1+, DXVK uses the application version to notify the driver about D3D9. */
       const bool is_d3d9 = instance->vk.app_info.app_version & 0x1;
