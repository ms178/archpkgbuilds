+ * Marked static inline for zero-overhead abstraction.
+ *
+ * Example usage:
+ *   struct wl_drm_buffer *buffer = wayland_drm_buffer_get(drm, resource);
+ *   if (buffer) {
+ *      // Safe to access buffer->driver_buffer
+ *   }
