+    * release store in AntiLagUpdateAMD.                              */
+   if (atomic_load_explicit(&ctx->enabled, memory_order_acquire)) {
+      queue_context *qctx = get_queue_context(ctx, queue);
+      if (LIKELY(qctx))
+         atomic_store_explicit(&qctx->latency_sensitive, true, memory_order_release);
