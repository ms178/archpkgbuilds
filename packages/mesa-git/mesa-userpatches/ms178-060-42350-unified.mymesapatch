+static inline uint64_t
+wsi_vrr_ewma_update(uint64_t prev, uint64_t sample, unsigned shift)
+{
+   if (sample == 0)
+      return prev;
+   if (prev == 0)
+      return sample;
+
+   int64_t delta = (int64_t)sample - (int64_t)prev;
+   return prev + (uint64_t)(delta >> shift);
+}
+
+static inline uint64_t
+wsi_vrr_guard_ns(const struct wsi_display_connector *connector)
+{
+   const uint64_t commit = connector->vrr_commit_ewma_ns ? connector->vrr_commit_ewma_ns : 350000ULL;
+   const uint64_t wake = connector->vrr_wakeup_ewma_ns ? connector->vrr_wakeup_ewma_ns : 200000ULL;
+   uint64_t guard = commit + wake + 200000ULL; /* extra safety margin */
+
+   guard = MAX2(guard, 250000ULL);   /* 0.25 ms floor */
+   guard = MIN2(guard, 3000000ULL);  /* 3.00 ms cap */
+
+   return guard;
+}
+
 /**
  * libdrm callback for when we get a DRM_EVENT_PAGE_FLIP in response to our
  * atomic commit with DRM_MODE_PAGE_FLIP_EVENT.  That event can happen at any
@@ -2044,6 +2119,18 @@ wsi_display_page_flip_handler2(int fd,
    chain->last_presented_nsec = nsec;
    connector->last_nsec = nsec;
 
+   if (connector->last_commit_submit_ns && nsec > connector->last_commit_submit_ns) {
+      uint64_t commit_latency = nsec - connector->last_commit_submit_ns;
+      if (commit_latency < 50000000ULL)
+         connector->vrr_commit_ewma_ns = wsi_vrr_ewma_update(connector->vrr_commit_ewma_ns, commit_latency, 3);
+   }
+
+   if (image->minimum_ns && nsec >= image->minimum_ns) {
