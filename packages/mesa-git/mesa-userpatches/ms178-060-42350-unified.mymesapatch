+static VkResult
+wsi_wl_surface_get_query_display(struct wsi_wl_surface *wsi_wl_surface,
+                                 struct wsi_device *wsi_device,
+                                 struct wsi_wl_display **display_out)
+{
+   /* Reuse the surface's persistent display when one exists. This avoids an
+    * extra wl_display registry roundtrip on every format/present-mode query,
+    * which is on the hot path during swapchain (re)creation. */
+   if (wsi_wl_surface->display) {
+      *display_out = wsi_wl_surface->display;
+      return VK_SUCCESS;
+   }
+
+   struct wsi_wayland *wsi =
+      (struct wsi_wayland *)wsi_device->wsi[VK_ICD_WSI_PLATFORM_WAYLAND];
+   struct wsi_wl_display *display =
+      vk_alloc(wsi->alloc, sizeof(*display), 8,
+               VK_SYSTEM_ALLOCATION_SCOPE_COMMAND);
+   if (!display)
+      return VK_ERROR_OUT_OF_HOST_MEMORY;
+
+   VkResult result = wsi_wl_display_init(wsi, display, wsi_wl_surface->base.display,
+                                         true, wsi_device->sw,
+                                         "mesa wl surface query");
+   if (result != VK_SUCCESS) {
+      vk_free(wsi->alloc, display);
+      return result;
+   }
+
+   *display_out = display;
+   return VK_SUCCESS;
+}
+
+static void
+wsi_wl_surface_release_query_display(struct wsi_wl_surface *wsi_wl_surface,
+                                     struct wsi_wl_display *display)
+{
+   /* Never tear down the surface's persistent display here. */
+   if (display == wsi_wl_surface->display)
+      return;
+
+   struct wsi_wayland *wsi = display->wsi_wl;
+   wsi_wl_display_finish(display);
+   vk_free(wsi->alloc, display);
+}
