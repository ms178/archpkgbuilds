+         new_entry = tmp;
+         dist = entry_dist;
+         hash = new_entry.hash_cached;  /* probe from displaced entry's home slot */
+      }
+
+      dist++;
+
+      /* Critical: prevent infinite loop on full table */
+      if (unlikely(dist >= cs->buffer_hash_table_size)) {
+         cs->status = VK_ERROR_OUT_OF_HOST_MEMORY;
+         return;
+      }
+   }
