+   const uint32_t heap_bit = 1u << heap_idx;
+   for (unsigned i = 0; i < MAX_BIND_POINTS; i++) {
+      cmd_buffer->descriptors[i].dirty_heaps |= heap_bit;
+      cmd_buffer->descriptors[i].valid_heaps |= heap_bit;
+   }
+}
