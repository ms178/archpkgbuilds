+static inline bool
+radv_cp_dma_predicating_enabled(const struct radv_cmd_buffer *cmd_buffer)
+{
+   /* The old cmd_buffer->state.cond_render path was removed from current RADV
+    * internals. Keep CP DMA emission valid without depending on private fields.
+    * Rewire this helper to the new predication API/state if your branch exposes one.
+    */
+   (void)cmd_buffer;
+   return false;
+}
