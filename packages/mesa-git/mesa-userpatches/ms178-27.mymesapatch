-   /* make it aligned for optimal performance */
-   return max & ~(SI_CPDMA_ALIGNMENT - 1);
+   /* Make it aligned for optimal performance. */
+   return max & ~(SI_CPDMA_ALIGNMENT - 1u);
 }
 
