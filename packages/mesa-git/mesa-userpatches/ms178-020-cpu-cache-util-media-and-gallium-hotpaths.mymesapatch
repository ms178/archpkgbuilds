+         case 3: SWIZZLE_CONVERT_LOOP(DST_TYPE, 4, SRC_TYPE, 3, CONV); break;\
+         case 4: SWIZZLE_CONVERT_LOOP(DST_TYPE, 4, SRC_TYPE, 4, CONV); break;\
+         } break;                                                            \
+      }                                                                      \
+   } while (0)
 
