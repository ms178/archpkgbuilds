+   #define MESA_UNLIKELY(x)   __builtin_expect(!!(x), 0)
+#else
+   #define MESA_ALWAYS_INLINE inline
+   #define MESA_LIKELY(x)     (x)
+   #define MESA_UNLIKELY(x)   (x)
+#endif
+
+/* Detect AVX2 support at compile time */
