+
+static void
+ac_maybe_parse_ib_and_exit(const struct radeon_info *info)
+{
+   const char *ib_filename = debug_get_option("AMD_PARSE_IB", NULL);
+   if (!ib_filename)
+      return;
+
+   FILE *f = fopen(ib_filename, "rb");
+   if (!f)
+      return;
+
+   if (fseek(f, 0, SEEK_END) != 0) {
+      fclose(f);
+      fprintf(stderr, "failed to seek '%s'\n", ib_filename);
+      exit(1);
+   }
+
+   const long file_len = ftell(f);
+   if (file_len < 0) {
+      fclose(f);
+      fprintf(stderr, "failed to determine size of '%s'\n", ib_filename);
+      exit(1);
+   }
+
+   if ((file_len & 3L) != 0) {
+      fclose(f);
+      fprintf(stderr, "invalid IB size in '%s': %ld (must be dword-aligned)\n", ib_filename, file_len);
+      exit(1);
+   }
+
+   if (fseek(f, 0, SEEK_SET) != 0) {
+      fclose(f);
+      fprintf(stderr, "failed to rewind '%s'\n", ib_filename);
+      exit(1);
+   }
+
+   const size_t size = (size_t)file_len;
+   uint32_t *ib = malloc(size);
+   if (!ib) {
+      fclose(f);
+      fprintf(stderr, "failed to allocate %zu bytes for '%s'\n", size, ib_filename);
+      exit(1);
+   }
+
+   const size_t n_read = fread(ib, 1, size, f);
+   fclose(f);
+
+   if (n_read != size) {
+      free(ib);
+      fprintf(stderr, "failed to read %zu bytes from '%s'\n", size, ib_filename);
+      exit(1);
+   }
+
+   struct ac_ib_parser ib_parser = {
+      .f = stdout,
+      .ib = ib,
+      .num_dw = size / 4,
+      .gfx_level = info->gfx_level,
+      .family = info->family,
+      .ip_type = AMD_IP_GFX,
+   };
+
+   ac_parse_ib(&ib_parser, "IB");
+   free(ib);
+   exit(0);
+}
