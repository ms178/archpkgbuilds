--- a/src/amd/vulkan/radv_descriptors.c	2026-04-13 18:26:25.834790911 +0200
+++ b/src/amd/vulkan/radv_descriptors.c	2026-04-13 18:40:05.556951922 +0200
@@ -13,9 +13,36 @@
 #include "radv_image_view.h"
 #include "radv_sampler.h"
 
+#include <string.h>
+
 static_assert(RADV_SAMPLER_DESC_SIZE == 16 && RADV_BUFFER_DESC_SIZE == 16 && RADV_ACCEL_STRUCT_DESC_SIZE == 16,
               "Sampler/buffer/acceleration structure descriptor sizes must match.");
 
+static inline uint32_t
+radv_descriptor_size_for_type(const struct radv_physical_device *pdev, VkDescriptorType type)
+{
+   switch (type) {
+   case VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER:
+   case VK_DESCRIPTOR_TYPE_STORAGE_BUFFER:
+   case VK_DESCRIPTOR_TYPE_UNIFORM_TEXEL_BUFFER:
+   case VK_DESCRIPTOR_TYPE_STORAGE_TEXEL_BUFFER:
+      return RADV_BUFFER_DESC_SIZE;
+   case VK_DESCRIPTOR_TYPE_SAMPLER:
+      return RADV_SAMPLER_DESC_SIZE;
+   case VK_DESCRIPTOR_TYPE_STORAGE_IMAGE:
+      return RADV_STORAGE_IMAGE_DESC_SIZE;
+   case VK_DESCRIPTOR_TYPE_INPUT_ATTACHMENT:
+   case VK_DESCRIPTOR_TYPE_SAMPLED_IMAGE:
+      return radv_get_sampled_image_desc_size(pdev);
+   case VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER:
+      return radv_get_combined_image_sampler_desc_size(pdev);
+   case VK_DESCRIPTOR_TYPE_ACCELERATION_STRUCTURE_KHR:
+      return RADV_ACCEL_STRUCT_DESC_SIZE;
+   default:
+      return 0;
