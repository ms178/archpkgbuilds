-      if (a->format != b->format)
-         return false;
-      if (a->opcode != b->opcode)
-         return false;
-      if (a->operands.size() != b->operands.size() ||
-          a->definitions.size() != b->definitions.size())
-         return false; /* possible with pseudo-instructions */
+      if (__builtin_expect(a->format != b->format || a->opcode != b->opcode ||
+                           a->operands.size() != b->operands.size() ||
+                           a->definitions.size() != b->definitions.size(), 0))
+         return false; /* possible with pseudo-instructions or mismatch */
       for (unsigned i = 0; i < a->operands.size(); i++) {
          if (a->operands[i].isConstant()) {
             if (!b->operands[i].isConstant())
