pkgver() {
  cd "${srcdir}/${_pkgname}"
  git describe --tags --long | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

_die() {
  error "$*"
  exit 1
}

_add_missing_unistd_includes() {
  # getpid(2) is declared by <unistd.h>.
  # Patch the source instead of forcing a global compiler include: this is the
  # correct zero-runtime-cost portability fix and does not pollute all TUs.
  local _file
  for _file in \
    src/platform/systemd/service.cpp \
    src/platform/linux/debug.cpp \
    src/platform/linux/process.cpp; do
    grep -q '^#include <unistd.h>' "${_file}" || sed -i '1i#include <unistd.h>' "${_file}"
  done
}

_apply_process_listener_fix() {
  # Upstreamable correctness/performance fix:
  # - BPF is the production listener, but keep the netlink fallback safe too.
  # - Do not resolve /proc/<pid>/cmdline in event-reader callbacks/threads.
  # - Batch-drain netlink after each blocking recv() and enlarge its receive buffer.
  # - sched_process_fork must report the child PID, not the current parent PID.
  if grep -q 'netlink_program_get_pids' libananicycpp_netlink/include/netlink_program_utils.h && \
     grep -q '^[[:space:]]*u32 pid = ctx->child_pid;' libananicycpp_bpf/src/ananicy_cpp.bpf.c; then
    msg2 "process-listener overrun fix already present; skipping patch"
    return 0
  fi

  patch -Np1 --forward <<'PATCH'
