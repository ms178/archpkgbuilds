+static void tune_netlink_socket(int32_t nl_sock) {
+  /*
+   * The proc connector is a best-effort multicast channel. During login,
+   * builds, browser/game launchers, Wine prefixes, package transactions, etc.
+   * fork/exec/comm events can arrive in bursts that are much larger than the
+   * kernel default receive buffer. If that queue overflows, recv(2) returns
+   * ENOBUFS and at least one process event has already been dropped.
+   *
+   * First try SO_RCVBUFFORCE (not capped by net.core.rmem_max) for units whose
+   * capability policy permits it. If a hardened/unit/capability setup denies
+   * it, fall back to regular SO_RCVBUF. Linux doubles the requested
+   * value internally; the exact resulting size is intentionally not relied on.
+   */
+  const int32_t rcvbuf = 4 * 1024 * 1024;
+  if (setsockopt(nl_sock, SOL_SOCKET, SO_RCVBUFFORCE, &rcvbuf,
+                 sizeof(rcvbuf)) == -1) {
+    (void)setsockopt(nl_sock, SOL_SOCKET, SO_RCVBUF, &rcvbuf,
+                     sizeof(rcvbuf));
+  }
+}
+
 int32_t connect_netlink_socket() {
   int32_t nl_sock = socket(PF_NETLINK, SOCK_DGRAM, NETLINK_CONNECTOR);
   if (nl_sock == -1) {
@@ -29,6 +52,8 @@ int32_t connect_netlink_socket() {
     return -1;
   }

+  tune_netlink_socket(nl_sock);
+
   struct sockaddr_nl sa_nl = {
       .nl_family = AF_NETLINK,
       .nl_pid = getpid(),
@@ -128,3 +153,56 @@ pid_t netlink_program_get_pid(ananicy_cpp_netlink_t* obj) {
 ssize_t netlink_program_pool_message(ananicy_cpp_netlink_t* obj) {
   return recv(obj->nl_sock, &obj->nl_cn_msg, sizeof(obj->nl_cn_msg), 0);
 }
+
+ssize_t netlink_program_get_pids(ananicy_cpp_netlink_t* obj, pid_t* pids,
+                                 size_t max_pids) {
+  if (!obj || !pids || max_pids == 0) {
+    errno = EINVAL;
+    return -1;
+  }
+
+  ssize_t status;
+  do {
+    status = recv(obj->nl_sock, &obj->nl_cn_msg, sizeof(obj->nl_cn_msg), 0);
+  } while (status == -1 && errno == EINTR);
+
+  if (status <= 0) {
+    return status;
+  }
+
+  size_t count = 0;
+  pid_t pid = netlink_program_get_pid(obj);
+  if (pid != 0) {
+    pids[count++] = pid;
+  }
+
+  /*
+   * Drain the receive queue after the blocking read above. This keeps the
+   * kernel socket queue short under fork storms while preserving the normal
+   * 500 ms idle timeout behaviour for the outer event loop.
+   */
+  for (; count < max_pids;) {
+    status = recv(obj->nl_sock, &obj->nl_cn_msg, sizeof(obj->nl_cn_msg),
+                  MSG_DONTWAIT);
+    if (status == -1) {
+      if (errno == EAGAIN || errno == EWOULDBLOCK) {
+        errno = 0;
+        break;
+      }
+      if (errno == EINTR) {
+        continue;
+      }
+      return -1;
+    }
+    if (status == 0) {
+      break;
+    }
+
+    pid = netlink_program_get_pid(obj);
+    if (pid != 0) {
+      pids[count++] = pid;
+    }
+  }
+
+  return (ssize_t)count;
+}
