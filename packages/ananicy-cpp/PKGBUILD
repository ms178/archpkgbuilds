PATCH
}

_create_training_ruleset() {
  # Do not call this variable "confdir": makepkg/pacman may expose a readonly
  # global named confdir, and "local confdir=..." fails inside PKGBUILD funcs.
  local _training_confdir="${srcdir}/ananicy-cpp-training.d"

  rm -rf "${_training_confdir}"
  install -dm755 "${_training_confdir}"

  cat > "${_training_confdir}/ananicy.conf" <<'EOF'
apply_nice = true
apply_sched = true
apply_ionice = true
apply_oom_score_adj = true
apply_latnice = true
apply_cgroup = false
apply_cpuset = false
cgroup_load = true
type_load = true
rule_load = true
cgroup_realtime_workaround = true
log_applied_rule = false
loglevel = error
check_freq = 60
x3d_mode = auto
EOF

  cat > "${_training_confdir}/00-training.types" <<'EOF'
{ "type": "BG_CPUIntensive", "nice": 19, "latency_nice": 19, "ioclass": "idle", "ionice": 7 }
{ "type": "LowLatency_RT", "nice": -10, "latency_nice": -10, "ioclass": "best-effort", "ionice": 0 }
{ "type": "Service", "nice": 5, "latency_nice": 5, "ioclass": "best-effort", "ionice": 4 }
EOF

  cat > "${_training_confdir}/00-training.rules" <<'EOF'
{ "name": "ananicy-cpp", "type": "Service" }
{ "name": "clang", "type": "BG_CPUIntensive" }
{ "name": "clang++", "type": "BG_CPUIntensive" }
{ "name": "ld.lld", "type": "BG_CPUIntensive" }
{ "name": "kwin_wayland", "type": "LowLatency_RT" }
{ "name": "pipewire", "type": "LowLatency_RT", "name_regex": "^(pipewire|wireplumber)$" }
EOF

  cat > "${_training_confdir}/00-training.cgroups" <<'EOF'
{ "cgroup": "ananicy-training", "CPUQuota": 100 }
EOF
}

prepare() {
  cd "${srcdir}/${_pkgname}"

  _add_missing_unistd_includes
  _apply_process_listener_fix
  _apply_cxx_compatibility_fix
  _create_training_ruleset

  rm -rf build-* pgo-data cspgo-data bolt-data bolt-binary
}

_env_train() {
  env \
    ANANICY_CPP_CONFDIR="${srcdir}/ananicy-cpp-training.d" \
    ANANICY_CPP_CONF="${srcdir}/ananicy-cpp-training.d/ananicy.conf" \
    "$@"
}

_exercise_main_binary() {
  local binary="$1"
  local stage_name="${2:-training}"

  [[ -x "$binary" ]] || _die "[$stage_name] binary not found: $binary"

  msg2 "[$stage_name] exercising ananicy-cpp hot paths"

  # ── Existing training ──
  "$binary" --help >/dev/null 2>&1 || true

  local subcmd
  for subcmd in rules types cgroups proc autogroup rules proc types; do
    _env_train "$binary" dump "$subcmd" >/dev/null 2>&1 || true
  done

  # ── NEW: Exercise JSON rule parsing and chrono formatting ──
  # These hit nlohmann::json, fmt::chrono, and spdlog formatting paths
  # that are completely cold right now.
  _env_train "$binary" dump rules   >/dev/null 2>&1 || true
  _env_train "$binary" dump types   >/dev/null 2>&1 || true
  _env_train "$binary" dump cgroups >/dev/null 2>&1 || true

  # ── NEW: Long enough for the event loop to process real events ──
  # This exercises signal handling, config reload, worker loop
  timeout --signal=SIGTERM 15 env \
    ANANICY_CPP_CONFDIR="${srcdir}/ananicy-cpp-training.d" \
    ANANICY_CPP_CONF="${srcdir}/ananicy-cpp-training.d/ananicy.conf" \
    "$binary" start >/dev/null 2>&1 || true
}

_configure_stage() {
  local build_dir="$1"
  shift

  cmake -S . -B "$build_dir" \
    -G Ninja \
    -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DUSE_EXTERNAL_SPDLOG=ON \
    -DUSE_EXTERNAL_JSON=ON \
    -DUSE_EXTERNAL_FMTLIB=ON \
    -DENABLE_SYSTEMD=ON \
    -DENABLE_REGEX_SUPPORT=ON \
    -DUSE_BPF_PROC_IMPL=ON \
    -DUSE_EXPERIMENTAL_IMPL=OFF \
    -DBPF_BUILD_LIBBPF=OFF \
    -DBPF_BUILD_BPFTOOL=OFF \
    -DENABLE_ANANICY_TESTS=OFF \
    -DENABLE_ANANICY_BENCHMARKS=OFF \
    "$@"
}

_build_stage() {
  local build_dir="$1"
  cmake --build "$build_dir" --target ananicy-cpp
}

_merge_profraw() {
  local profile_dir="$1"
  local output="$2"

  if ! find "$profile_dir" -name '*.profraw' -print -quit | grep -q .; then
    warning "no raw profile data found in $profile_dir"
    return 1
  fi

  llvm-profdata merge -output="$output" "$profile_dir"/*.profraw || return 1
  [[ -s "$output" ]] || return 1
  rm -f "$profile_dir"/*.profraw
}

_maybe_with_mimalloc() {
  if [[ -r /usr/lib/mimalloc.so ]]; then
    env LD_PRELOAD=/usr/lib/mimalloc.so "$@"
  else
    "$@"
  fi
}

_instrument_bolt_binary() {
  local input="$1"
  local fdata="$2"
  local output="$3"

  install -dm755 "$(dirname "$output")" "$(dirname "$fdata")"
  _maybe_with_mimalloc llvm-bolt "$input" \
    --instrument \
    --instrumentation-file="$fdata" \
    --instrumentation-file-append-pid \
    --lite=false \
    -o "$output"
  chmod 755 "$output"
}

_merge_bolt_profiles() {
  local data_dir="$1"
  local output="$2"
  local fdata_files=()

  while IFS= read -r -d $'\0' file; do
    fdata_files+=("$file")
  done < <(find "$data_dir" -maxdepth 1 -type f -name '*.fdata*' -print0)

  (( ${#fdata_files[@]} > 0 )) || return 1
  _maybe_with_mimalloc merge-fdata "${fdata_files[@]}" > "$output"
  [[ -s "$output" ]]
}

_optimize_with_bolt() {
  local input="$1"
  local profile="$2"
  local output="$3"

  local bolt_args=(
    "$input"
    --data "$profile"
    -o "$output"
    --dyno-stats
    --update-debug-sections
    --lite=false
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions
    --split-strategy=cdsplit
    --split-all-cold
    --split-eh
    --icf=all
    --plt=all
    --peepholes=all
    --indirect-call-promotion=all
    --jump-tables=aggressive
    --x86-strip-redundant-address-size
  )

  _maybe_with_mimalloc llvm-bolt "${bolt_args[@]}"
  [[ -s "$output" ]]
}

build() {
  cd "${srcdir}/${_pkgname}"

  export CC=clang
  export CXX=clang++
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  local base_cflags="${CFLAGS} -Wno-c2y-extensions -Wno-error=c2y-extensions -Wno-profile-instr-unprofiled -Wno-profile-instr-out-of-date"
  local base_cxxflags="${CXXFLAGS} -Wno-c2y-extensions -Wno-error=c2y-extensions -Wno-profile-instr-unprofiled -Wno-profile-instr-out-of-date"
  local base_ldflags="${LDFLAGS}"
  local instr_mllvm="-mllvm -vp-counters-per-site=150 -mllvm -runtime-counter-relocation -mllvm -enable-value-profiling"

  local pgo_dir="${srcdir}/${_pkgname}/pgo-data"
  local cspgo_dir="${srcdir}/${_pkgname}/cspgo-data"
  local bolt_data_dir="${srcdir}/${_pkgname}/bolt-data"
  local bolt_binary_dir="${srcdir}/${_pkgname}/bolt-binary"
  local build_pgo="${srcdir}/${_pkgname}/build-pgo-instr"
  local build_cspgo="${srcdir}/${_pkgname}/build-cspgo-instr"
  local build_final="${srcdir}/${_pkgname}/build-final"

  install -dm755 "$pgo_dir" "$cspgo_dir" "$bolt_data_dir" "$bolt_binary_dir"

  local pgo_profdata=""
  local cs_profdata=""
  local final_profdata=""

  msg "Stage 1/7: building instrumentation binary for standard PGO"
  local pgo_gen="-fprofile-generate=$pgo_dir"
  _configure_stage "$build_pgo" \
    "-DCMAKE_C_FLAGS=$base_cflags $pgo_gen $instr_mllvm" \
    "-DCMAKE_CXX_FLAGS=$base_cxxflags $pgo_gen $instr_mllvm" \
    "-DCMAKE_EXE_LINKER_FLAGS=$base_ldflags $pgo_gen" \
    "-DCMAKE_SHARED_LINKER_FLAGS=$base_ldflags $pgo_gen" \
    "-DCMAKE_MODULE_LINKER_FLAGS=$base_ldflags $pgo_gen"
  _build_stage "$build_pgo"

  msg "Stage 2/7: training standard PGO"
  export LLVM_PROFILE_FILE="$pgo_dir/default-%m.profraw"
  _exercise_main_binary "$build_pgo/ananicy-cpp" "PGO"
  unset LLVM_PROFILE_FILE

  if _merge_profraw "$pgo_dir" "$pgo_dir/default.profdata"; then
    pgo_profdata="$pgo_dir/default.profdata"
    msg2 "standard PGO profile ready: $pgo_profdata"
  else
    warning "standard PGO profile generation failed; final build can still continue without it"
  fi

  if [[ -n "$pgo_profdata" ]]; then
    msg "Stage 3/7: building instrumentation binary for context-sensitive PGO"
    local cs_gen="-fprofile-use=$pgo_profdata -fcs-profile-generate=$cspgo_dir"
    if _configure_stage "$build_cspgo" \
      "-DCMAKE_C_FLAGS=$base_cflags $cs_gen $instr_mllvm" \
      "-DCMAKE_CXX_FLAGS=$base_cxxflags $cs_gen $instr_mllvm" \
      "-DCMAKE_EXE_LINKER_FLAGS=$base_ldflags $cs_gen" \
      "-DCMAKE_SHARED_LINKER_FLAGS=$base_ldflags $cs_gen" \
      "-DCMAKE_MODULE_LINKER_FLAGS=$base_ldflags $cs_gen" && \
      _build_stage "$build_cspgo"; then

      msg "Stage 4/7: training context-sensitive PGO"
      export LLVM_PROFILE_FILE="$cspgo_dir/cs-%m.profraw"
      _exercise_main_binary "$build_cspgo/ananicy-cpp" "CS-PGO"
      unset LLVM_PROFILE_FILE

      if _merge_profraw "$cspgo_dir" "$cspgo_dir/cs.profdata"; then
        cs_profdata="$cspgo_dir/cs.profdata"
        msg2 "CS-PGO profile ready: $cs_profdata"
      else
        warning "CS-PGO profile generation failed; falling back to standard PGO"
      fi
    else
      warning "CS-PGO instrumentation build failed; falling back to standard PGO"
    fi
  fi

  if [[ -n "$cs_profdata" ]]; then
    final_profdata="$cs_profdata"
  elif [[ -n "$pgo_profdata" ]]; then
    final_profdata="$pgo_profdata"
  fi

  msg "Stage 5/7: building final optimized binary"
  local final_extra_args=(
    -DBUILD_WITH_RELOCS=ON
  )
  if [[ -n "$final_profdata" ]]; then
    msg2 "using profile: $final_profdata"
    local pgo_use="-fprofile-use=$final_profdata"
    final_extra_args+=(
      "-DCMAKE_C_FLAGS=$base_cflags $pgo_use"
      "-DCMAKE_CXX_FLAGS=$base_cxxflags $pgo_use"
      "-DCMAKE_EXE_LINKER_FLAGS=$base_ldflags $pgo_use"
      "-DCMAKE_SHARED_LINKER_FLAGS=$base_ldflags $pgo_use"
      "-DCMAKE_MODULE_LINKER_FLAGS=$base_ldflags $pgo_use"
    )
  else
    warning "building final binary without PGO profile"
    final_extra_args+=(
      "-DCMAKE_C_FLAGS=$base_cflags"
      "-DCMAKE_CXX_FLAGS=$base_cxxflags"
      "-DCMAKE_EXE_LINKER_FLAGS=$base_ldflags"
      "-DCMAKE_SHARED_LINKER_FLAGS=$base_ldflags"
      "-DCMAKE_MODULE_LINKER_FLAGS=$base_ldflags"
    )
  fi
  _configure_stage "$build_final" "${final_extra_args[@]}"
  _build_stage "$build_final"

  local final_binary="$build_final/ananicy-cpp"
  [[ -x "$final_binary" ]] || _die "final binary missing: $final_binary"

  msg "Stage 6/7: collecting BOLT profile for final binary"
  if command -v llvm-bolt >/dev/null 2>&1 && command -v merge-fdata >/dev/null 2>&1; then
    if _instrument_bolt_binary "$final_binary" "$bolt_data_dir/ananicy-cpp.fdata" "$bolt_binary_dir/ananicy-cpp"; then
      _exercise_main_binary "$bolt_binary_dir/ananicy-cpp" "BOLT"
      sync

      local merged_bolt_profile="$bolt_data_dir/bolt-merged.fdata"
      if _merge_bolt_profiles "$bolt_data_dir" "$merged_bolt_profile"; then
        msg "Stage 7/7: optimizing final binary with BOLT"
        local bolt_output="$bolt_binary_dir/ananicy-cpp.bolt"
        if _optimize_with_bolt "$final_binary" "$merged_bolt_profile" "$bolt_output"; then
          install -m755 "$bolt_output" "$final_binary"
          msg2 "BOLT optimization applied"
        else
          warning "BOLT optimization failed; keeping PGO/non-BOLT final binary"
        fi
      else
        warning "BOLT profile merge failed; keeping PGO/non-BOLT final binary"
      fi
    else
      warning "BOLT instrumentation failed; keeping PGO/non-BOLT final binary"
    fi
  else
    warning "llvm-bolt or merge-fdata not found; skipping BOLT"
  fi
}

check() {
  cd "${srcdir}/${_pkgname}"
  _exercise_main_binary "${srcdir}/${_pkgname}/build-final/ananicy-cpp" "check"
}

package() {
  local build_final="${srcdir}/${_pkgname}/build-final"

  [[ -d "$build_final" ]] || _die "final build directory missing: $build_final"
  DESTDIR="${pkgdir}" cmake --install "$build_final" --component Runtime
  install -dm755 "${pkgdir}/etc/ananicy.d"
}

