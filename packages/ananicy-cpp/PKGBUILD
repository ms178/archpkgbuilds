_apply_cxx_compatibility_fix() {
  # C++20 with recent libstdc++ (GCC ≥15) no longer transitively pulls C library
  # symbols (int32_t, strerror, memset) into namespace std.  The idiomatic,
  # upstreamable fix is including the standard C++ wrapper headers <cstdint> and
  # <cstring>, which the standard guarantees will declare their names in std::.
  #
  # Files fixed:
  #   src/platform/linux/backtrace.cpp        – std::int32_t  → needs <cstdint>
  #   src/platform/linux/singleton_process.cpp – std::strerror,
  #                                              std::memset   → needs <cstring>
  #   src/utility/argument_parsing/argument.cpp – std::memset   → needs <cstring>
  if grep -q '^#include <cstdint>'  src/platform/linux/backtrace.cpp && \
     grep -q '^#include <cstring>'  src/platform/linux/singleton_process.cpp && \
     grep -q '^#include <cstring>'  src/utility/argument_parsing/argument.cpp; then
    msg2 "C++ compatibility includes already present; skipping patch"
    return 0
  fi

  patch -Np1 --forward <<'PATCH'
diff --git a/src/platform/linux/backtrace.cpp b/src/platform/linux/backtrace.cpp
--- a/src/platform/linux/backtrace.cpp
+++ b/src/platform/linux/backtrace.cpp
@@ -1,5 +1,6 @@
 #include "utility/backtrace.hpp"

+#include <cstdint>
 #include <cstdlib>    // for free
 #include <cxxabi.h>   // for abi::__cxa_demangle
 #include <execinfo.h> // for backtrace, backtrace_symbols

diff --git a/src/platform/linux/singleton_process.cpp b/src/platform/linux/singleton_process.cpp
--- a/src/platform/linux/singleton_process.cpp
+++ b/src/platform/linux/singleton_process.cpp
@@ -3,7 +3,8 @@
 #include <cerrno>
 #include <chrono>
+#include <cstring>
 #include <fcntl.h> /* For O_* constants */
 #include <sys/ipc.h>
 #include <sys/mman.h>
 #include <sys/shm.h>
 #include <sys/stat.h> /* For mode constants */

diff --git a/src/utility/argument_parsing/argument.cpp b/src/utility/argument_parsing/argument.cpp
--- a/src/utility/argument_parsing/argument.cpp
+++ b/src/utility/argument_parsing/argument.cpp
@@ -2,7 +2,8 @@

