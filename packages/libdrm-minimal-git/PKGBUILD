pkgname=libdrm-minimal-git
_pkgname=libdrm
pkgver=2.4.134.r0.ge984d448
pkgrel=1
pkgdesc="Userspace interface to kernel DRM services (Clang/LLVM PGO + BOLT optimized)"
arch=(i686 x86_64)
license=('custom')
url="https://dri.freedesktop.org/"
provides=('libdrm' 'libdrm-git')
conflicts=('libdrm')
depends=('libpciaccess')
makedepends=('git' 'meson' 'ninja' 'clang' 'lld' 'llvm' 'vulkan-tools' 'glmark2' 'bolt')
source=("$pkgname::git+https://gitlab.freedesktop.org/mesa/drm.git"
        'COPYING'
        'ms178-1.patch')
sha512sums=('SKIP'
            'b0ca349b882a4326b19f81f22804fabdb6fb7aef31cdc7b16b0a7ae191bfbb50c7daddb2fc4e6af06d060a273de36f6f3412ea326f16fa4309fda660'
            'SKIP')

pkgver() {
  cd "$pkgname"
  git describe --long --tags --abbrev=8 | sed -r 's/^libdrm-//;s/([^-]*-g)/r\1/;s/-/./g'
}

prepare() {
  local src

  cd "$srcdir"
  for src in "${source[@]}"; do
    src="${src%%::*}"
    src="${src##*/}"
    [[ $src = *.patch ]] || continue
    echo "Applying patch $src..."
    patch --directory="$pkgname" --forward --strip=1 < "$src"
  done
}

_quote_meson_array() {
  local arg
  local first=1

  for arg in "$@"; do
    if (( first )); then
      first=0
    else
      printf ', '
    fi
    printf "'%s'" "${arg//\'/\'\\\'\'}"
  done
}

_sanitized_cflags() {
  # Preserve caller-provided Clang/LLVM flags verbatim.
  # The target build host is expected to provide a Clang/LLVM revision that
  # accepts those flags. This intentionally does not filter
  # -fgnuc-version=16.1.1 or -mllvm -always-rename-promoted-locals=false.
  printf '%s\n' "$1"
}

_resolve_tool() {
  local var_name="$1"
  local fallback="$2"
  local value="${!var_name:-}"
  local llvm_bin="${LLVM_BIN:-}"

  if [[ -z $value ]]; then
    if [[ -n $llvm_bin && -x ${llvm_bin%/}/$fallback ]]; then
      value="${llvm_bin%/}/$fallback"
    else
      value="$fallback"
    fi
  fi

  if [[ $value = */* ]]; then
    printf '%s\n' "$value"
  else
    command -v "$value"
  fi
}

_setup_toolchain() {
  TOOL_CC="$(_resolve_tool CC clang)"
  TOOL_CXX="$(_resolve_tool CXX clang++)"
  TOOL_AR="$(_resolve_tool AR llvm-ar)"
  TOOL_NM="$(_resolve_tool NM llvm-nm)"
  TOOL_STRIP="$(_resolve_tool STRIP llvm-strip)"
  TOOL_OBJCOPY="$(_resolve_tool OBJCOPY llvm-objcopy)"
  TOOL_OBJDUMP="$(_resolve_tool OBJDUMP llvm-objdump)"
  TOOL_READELF="$(_resolve_tool READELF llvm-readelf)"
  TOOL_RANLIB="$(_resolve_tool RANLIB llvm-ranlib)"
  TOOL_LLVM_PROFDATA="$(_resolve_tool LLVM_PROFDATA llvm-profdata)"
  TOOL_LLVM_BOLT="$(_resolve_tool LLVM_BOLT llvm-bolt)"
  TOOL_MERGE_FDATA="$(_resolve_tool MERGE_FDATA merge-fdata)"

  export CC="$TOOL_CC"
  export CXX="$TOOL_CXX"
  export AR="$TOOL_AR"
  export NM="$TOOL_NM"
  export STRIP="$TOOL_STRIP"
  export OBJCOPY="$TOOL_OBJCOPY"
  export OBJDUMP="$TOOL_OBJDUMP"
  export READELF="$TOOL_READELF"
  export RANLIB="$TOOL_RANLIB"

  echo "Using C compiler:       $TOOL_CC"
  echo "Using C++ compiler:     $TOOL_CXX"
  echo "Using llvm-profdata:    $TOOL_LLVM_PROFDATA"
  echo "Using llvm-bolt:        $TOOL_LLVM_BOLT"
  echo "Using merge-fdata:      $TOOL_MERGE_FDATA"
}

generate_meson_native_file() {
  local c_flags="$1"
  local cpp_flags="$2"
  local ld_flags="$3"
  local ndebug_val="$4"

  cat > meson-native-flags.ini <<EOF
[built-in options]
c_args = [$c_flags]
cpp_args = [$cpp_flags]
c_link_args = [$ld_flags]
cpp_link_args = [$ld_flags]
b_pie = false
b_ndebug = '$ndebug_val'
b_lto = true
b_lto_mode = 'thin'

[binaries]
c = '$TOOL_CC'
cpp = '$TOOL_CXX'
ar = '$TOOL_AR'
nm = '$TOOL_NM'
strip = '$TOOL_STRIP'
objcopy = '$TOOL_OBJCOPY'
objdump = '$TOOL_OBJDUMP'
readelf = '$TOOL_READELF'
ranlib = '$TOOL_RANLIB'
EOF
}

run_workloads() {
  local libdir="$1"
  local modetest_bin="${2:-}"

  ulimit -s unlimited 2>/dev/null || true

  if command -v vulkaninfo >/dev/null 2>&1; then
    echo "  -> Running vulkaninfo..."
    timeout 12s env LD_LIBRARY_PATH="$libdir" vulkaninfo --summary || true
  fi

  if command -v vkcube >/dev/null 2>&1; then
    echo "  -> Running vkcube..."
    timeout 25s env LD_LIBRARY_PATH="$libdir" vkcube --c 80 --wsi xlib || true
  fi

  if command -v glmark2 >/dev/null 2>&1; then
    echo "  -> Running glmark2 off-screen..."
    timeout 20s env LD_LIBRARY_PATH="$libdir" glmark2 --off-screen || true
    echo "  -> Running glmark2 shading off-screen..."
    timeout 18s env LD_LIBRARY_PATH="$libdir" glmark2 -b shading --off-screen || true
  fi

  if [[ -n $modetest_bin && -x $modetest_bin ]]; then
    echo "  -> Running built modetest..."
    timeout 12s env LD_LIBRARY_PATH="$libdir" "$modetest_bin" -c || true
  elif command -v modetest >/dev/null 2>&1; then
    echo "  -> Running system modetest..."
    timeout 12s env LD_LIBRARY_PATH="$libdir" modetest -c || true
  fi
}

build() {
  ulimit -s unlimited

  _setup_toolchain
  export ASFLAGS="${ASFLAGS:-}"

  local clean_cflags clean_cxxflags clean_ldflags
  clean_cflags="$(_sanitized_cflags "${CFLAGS:-}")"
  clean_cxxflags="$(_sanitized_cflags "${CXXFLAGS:-${CFLAGS:-}}")"
  clean_ldflags="$(_sanitized_cflags "${LDFLAGS:-}")"

  local -a common_meson_options=(
    --prefix=/usr
    -Dudev=false
    -Dpython.bytecompile=2
    -Db_pie=false
    -Dc_std=gnu2x
    -Dvalgrind=disabled
    -Dfreedreno=disabled
    -Dvc4=disabled
    -Dvmwgfx=disabled
    -Detnaviv=disabled
    -Dexynos=disabled
    -Dtegra=disabled
    -Damdgpu=enabled
    -Dradeon=enabled
    -Dintel=disabled
    -Dnouveau=disabled
    -Dman-pages=disabled
    -Dtests=true
    -Dinstall-test-programs=false
    --wrap-mode=nofallback
    --buildtype=plain
  )

  rm -rf "$srcdir/pgo_raw" "$srcdir/cs_pgo_raw" "$srcdir/profdata1.profdata" \
         "$srcdir/profdata2.profdata" "$srcdir/bolt_failed" \
         build-instr build-cs-instr build-final

  echo "--> Stage 1.1: Building with frontend PGO instrumentation..."
  local pgo_instr_flags="-fprofile-generate=$srcdir/pgo_raw"
  generate_meson_native_file \
    "$(_quote_meson_array $clean_cflags $pgo_instr_flags)" \
    "$(_quote_meson_array $clean_cxxflags $pgo_instr_flags)" \
    "$(_quote_meson_array $clean_ldflags $pgo_instr_flags)" \
    false
  meson setup "$pkgname" build-instr "${common_meson_options[@]}" --native-file=meson-native-flags.ini
  meson compile -C build-instr

  local instr_install_dir="$srcdir/instr_install"
  rm -rf "$instr_install_dir" "$srcdir/pgo_raw"
  mkdir -p "$srcdir/pgo_raw"
  DESTDIR="$instr_install_dir" meson install -C build-instr --no-rebuild
  LLVM_PROFILE_FILE="$srcdir/pgo_raw/%m-%p.profraw" \
    run_workloads "$instr_install_dir/usr/lib" "$PWD/build-instr/tests/modetest/modetest"

  if compgen -G "$srcdir/pgo_raw/*.profraw" >/dev/null; then
    "$TOOL_LLVM_PROFDATA" merge -output="$srcdir/profdata1.profdata" "$srcdir"/pgo_raw/*.profraw
  else
    echo "Warning: no frontend PGO profiles generated."
  fi

  echo "--> Stage 2.1: Building with CS-PGO instrumentation..."
  local cs_pgo_flags="-fcs-profile-generate=$srcdir/cs_pgo_raw"
  if [[ -f $srcdir/profdata1.profdata ]]; then
    cs_pgo_flags="-fprofile-use=$srcdir/profdata1.profdata $cs_pgo_flags"
  fi
  generate_meson_native_file \
    "$(_quote_meson_array $clean_cflags $cs_pgo_flags)" \
    "$(_quote_meson_array $clean_cxxflags $cs_pgo_flags)" \
    "$(_quote_meson_array $clean_ldflags $cs_pgo_flags)" \
    false
  meson setup "$pkgname" build-cs-instr "${common_meson_options[@]}" --native-file=meson-native-flags.ini
  meson compile -C build-cs-instr

  local cs_instr_install_dir="$srcdir/cs_instr_install"
  rm -rf "$cs_instr_install_dir" "$srcdir/cs_pgo_raw"
  mkdir -p "$srcdir/cs_pgo_raw"
  DESTDIR="$cs_instr_install_dir" meson install -C build-cs-instr --no-rebuild
  LLVM_PROFILE_FILE="$srcdir/cs_pgo_raw/%m-%p.profraw" \
    run_workloads "$cs_instr_install_dir/usr/lib" "$PWD/build-cs-instr/tests/modetest/modetest"

  if compgen -G "$srcdir/cs_pgo_raw/*.profraw" >/dev/null; then
    if [[ -f $srcdir/profdata1.profdata ]]; then
      "$TOOL_LLVM_PROFDATA" merge -output="$srcdir/profdata2.profdata" \
        "$srcdir"/cs_pgo_raw/*.profraw "$srcdir/profdata1.profdata"
    else
      "$TOOL_LLVM_PROFDATA" merge -output="$srcdir/profdata2.profdata" "$srcdir"/cs_pgo_raw/*.profraw
    fi
  else
    echo "Warning: no CS-PGO profiles generated."
  fi

  echo "--> Stage 3: Building final optimized binary with relocs for BOLT..."
  local final_pgo_flags=""
  if [[ -f $srcdir/profdata2.profdata ]]; then
    final_pgo_flags="-fprofile-use=$srcdir/profdata2.profdata"
  elif [[ -f $srcdir/profdata1.profdata ]]; then
    final_pgo_flags="-fprofile-use=$srcdir/profdata1.profdata"
  fi

  local final_ld_flags="$clean_ldflags $final_pgo_flags -Wl,--emit-relocs"
  generate_meson_native_file \
    "$(_quote_meson_array $clean_cflags $final_pgo_flags)" \
    "$(_quote_meson_array $clean_cxxflags $final_pgo_flags)" \
    "$(_quote_meson_array $final_ld_flags)" \
    true
  meson setup "$pkgname" build-final "${common_meson_options[@]}" --native-file=meson-native-flags.ini
  meson compile -C build-final

  local final_install_dir="$srcdir/final_install"
  local bolt_instr_dir="$srcdir/bolt_instr"
  local bolt_profiles_dir="$srcdir/bolt_profiles"
  local bolt_lib_dir="$srcdir/bolt_lib"
  local bolt_opt_dir="$srcdir/bolt_opt"
  local -a libs_to_bolt
  local lib_path lib_basename profile_glob merged_profile

  rm -rf "$final_install_dir" "$bolt_instr_dir" "$bolt_profiles_dir" "$bolt_lib_dir" "$bolt_opt_dir"
  mkdir -p "$bolt_instr_dir" "$bolt_profiles_dir" "$bolt_lib_dir" "$bolt_opt_dir"
  DESTDIR="$final_install_dir" meson install -C build-final --no-rebuild
  cp -a "$final_install_dir/usr/lib/." "$bolt_lib_dir/"

  mapfile -t libs_to_bolt < <(find "$final_install_dir/usr/lib" -type f -name 'libdrm*.so.*' | sort)
  if (( ${#libs_to_bolt[@]} == 0 )); then
    echo "Warning: no libdrm shared objects found for BOLT."
    touch "$srcdir/bolt_failed"
  else
    echo "--> Stage 4.1: Instrumenting libraries for BOLT..."
    for lib_path in "${libs_to_bolt[@]}"; do
      lib_basename="$(basename "$lib_path")"
      echo "Instrumenting $lib_basename"
      if ! "$TOOL_LLVM_BOLT" "$lib_path" \
          --instrument \
          --lite=true \
          --instrumentation-file-append-pid \
          --instrumentation-file="$bolt_profiles_dir/${lib_basename}.fdata" \
          -o "$bolt_instr_dir/$lib_basename"; then
        echo "BOLT instrumentation failed for $lib_basename"
        touch "$srcdir/bolt_failed"
        break
      fi
      cp "$bolt_instr_dir/$lib_basename" "$bolt_lib_dir/$lib_basename"
      chmod +x "$bolt_lib_dir/$lib_basename"
    done
  fi

  if [[ ! -f $srcdir/bolt_failed ]]; then
    echo "--> Stage 4.2: Running workloads for BOLT profiles..."
    run_workloads "$bolt_lib_dir" "$PWD/build-final/tests/modetest/modetest"

    echo "--> Stage 5: Applying per-library BOLT optimizations..."
    for lib_path in "${libs_to_bolt[@]}"; do
      lib_basename="$(basename "$lib_path")"
      profile_glob="$bolt_profiles_dir/${lib_basename}.fdata"'*'
      merged_profile="$srcdir/${lib_basename}.merged.fdata"

      if ! compgen -G "$profile_glob" >/dev/null; then
        echo "Warning: no BOLT profile for $lib_basename; using non-BOLT library."
        cp "$lib_path" "$bolt_opt_dir/$lib_basename"
        continue
      fi

      "$TOOL_MERGE_FDATA" $profile_glob > "$merged_profile"
      echo "Optimizing $lib_basename with BOLT"
      if "$TOOL_LLVM_BOLT" "$lib_path" \
          --data="$merged_profile" \
          --lite=true \
          --relocs \
          --reorder-blocks=ext-tsp \
          --reorder-functions=cdsort \
          --eliminate-unreachable \
          --frame-opt=all \
          --hot-data \
          --icf=all \
          --indirect-call-promotion=all \
          --jump-tables=aggressive \
          --peepholes=all \
          --plt=hot \
          --dyno-stats \
          -o "$bolt_opt_dir/$lib_basename" 2>&1 | tee "$srcdir/bolt_${lib_basename}.log"; then
        chmod +x "$bolt_opt_dir/$lib_basename"
      else
        echo "BOLT optimization failed for $lib_basename; using final PGO library."
        cp "$lib_path" "$bolt_opt_dir/$lib_basename"
      fi
    done
  fi
}

package() {
  DESTDIR="$pkgdir" meson install -C build-final --no-rebuild

  if [[ ! -f $srcdir/bolt_failed && -d $srcdir/bolt_opt ]] && compgen -G "$srcdir/bolt_opt/libdrm*.so.*" >/dev/null; then
    echo "--> Installing BOLT-optimized libraries..."
    find "$srcdir/bolt_opt" -type f -name 'libdrm*.so.*' -exec install -Dm755 '{}' -t "$pkgdir/usr/lib/" \;
  else
    echo "Installing CS-PGO optimized version; BOLT was skipped or failed."
  fi

  install -Dm644 "$srcdir/COPYING" -t "$pkgdir/usr/share/licenses/$pkgname/"
  local strip_tool

  strip_tool="$(_resolve_tool STRIP llvm-strip)"
  find "$pkgdir" -type f -name '*.so*' -exec "$strip_tool" --strip-unneeded '{}' +
}
