pkgname=ffmpeg
pkgver=8.1.2.r0.g38b88335f9
pkgrel=1
epoch=2
_tag=38b88335f99e76ed89ff3c93f877fdefce736c13
pkgdesc='Complete solution to record, convert and stream audio and video'
arch=(x86_64)
url='https://ffmpeg.org'
license=(GPL-3.0-only)

depends=(
