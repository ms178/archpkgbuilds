sha256sums=('SKIP')

# === GCC 2-stage-PGO REBUILD :: libxi-git =================================
# Emergency GCC rebuild after the clang 'llvm-ultimate' toolchain miscompiled
# the X/Wayland stack (Xwayland SIGSEGV at 0x10 via ffi_call ->
# wl_display_dispatch, crash4.txt). Toolchain pinned to gcc/g++ + GNU binutils;
# inherited clang-only flags scrubbed (_gcc_pgo_init). MANDATORY GCC 2-stage
# PGO: -fprofile-generate  ->  representative training workload (run headless on
# a private Xvfb)  ->  -fprofile-use (+ -fprofile-correction
# -fprofile-partial-training). No GCC 2-stage PGO / BOLT: GCC has no equivalent; a clean
# 2-stage PGO is the correct, stable GCC path. If training yields no profile the
# build ABORTS (PGO is required). Rename this file to 'PKGBUILD' before use.
# =====================================================================


# ============================================================================
# GCC 2-stage PGO scaffold (shared preamble)  —  CachyOS xorg emergency GCC set
# ----------------------------------------------------------------------------
# WHY THIS EXISTS
#   /etc/makepkg.conf on this box points CC/CXX/*FLAGS at the clang
#   "llvm-ultimate" toolchain (clang 24 + ThinLTO/Polly/BOLT). That toolchain
#   miscompiled the X/Wayland stack (Xwayland SIGSEGV at 0x10 through
#   ffi_call -> wl_display_dispatch). These are the GCC emergency rebuilds.
#   They MUST pin GCC and MUST scrub clang-only flags, else the fix is void.
#
# WHAT IT PROVIDES
#   _gcc_pgo_init      : pin gcc/g++ + GNU binutils; sanitize inherited flags.
#   _gcc_pgo_xvfb_run  : run a training command on a private Xvfb (auto ports,
#                        robust wait, always tears the server down).
#   _gcc_pgo_merge_ok  : verify .gcda were produced (PGO is MANDATORY; the build
#                        aborts if training generated no profile).
#   Stage flags:  ${_PGO_GEN[@]}  (stage 1)   ${_PGO_USE[@]} (stage 2, needs dir)
#
#   GCC has no context-sensitive PGO and no BOLT; a clean, correct 2-stage PGO
#   (-fprofile-generate -> -fprofile-use, +correction +partial-training) is the
#   right, stable GCC equivalent. Per the GCC manual, -fprofile-correction and
#   -fprofile-partial-training make profile-use robust to multithreaded and
#   partially-covered training runs (both true here).
# ============================================================================

# Stage-1 instrumentation flags. The profile directory is passed EXPLICITLY via
# -fprofile-generate=<dir> so the .gcda live OUT of tree and survive the
# `make clean` / fresh meson dir between stage 1 and stage 2 (an in-tree default
# location would be wiped). -fprofile-update=atomic is REQUIRED: the X libraries
# and servers are multi-threaded (XCB i/o thread, input thread) and non-atomic
# counters corrupt under concurrent updates. -fprofile-generate at LINK time is
# needed so the instrumented runtime (-lgcov) is pulled in.
_gcc_pgo_gen() {  # $1 = profile dir -> stage-1 compile flags
  # -Wno-error: PGO instrumentation legitimately perturbs codegen and can trip
  # upstream -Werror=array-bounds / -Werror=maybe-uninitialized false positives
  # (e.g. libxcb's generated xinput.c). Instrumented objects are throwaway; we
  # must never let a warning promotion abort the profiling build.
  printf '%s' "-fprofile-generate=$1 -fprofile-update=atomic -Wno-error"
}
# Back-compat array (dir-less) kept for callers that set the dir themselves.
_PGO_GEN=(-fprofile-generate -fprofile-update=atomic)

_gcc_pgo_use() {  # $1 = profile dir  -> echoes stage-2 flags
  # -Wno-error for the same reason as the gen stage: -fprofile-use changes inlining
  # and block layout, which can surface new upstream -Werror= promotions on code
  # that is otherwise correct. The final objects are still fully optimized.
  printf '%s' "-fprofile-use=$1 -fprofile-correction -fprofile-partial-training -Wno-missing-profile -Wno-coverage-mismatch -Wno-error"
}

_gcc_pgo_init() {
  # These are GCC-specific rebuilds: the clang 'llvm-ultimate' toolchain
  # miscompiled the X stack (Xwayland SIGSEGV at 0x10 via ffi_call ->
  # wl_display_dispatch). Pin the GNU toolchain so the build is GCC regardless
  # of what CC/CXX /etc/makepkg.conf exports. gcc-ar/gcc-nm/gcc-ranlib are the
  # LTO-safe binutils wrappers (correct even if your makepkg.conf enables -flto).
  export CC=gcc CXX=g++
  export AR=gcc-ar NM=gcc-nm RANLIB=gcc-ranlib
  export CCACHE_DISABLE=1

  # HONOR /etc/makepkg.conf flags VERBATIM. This PKGBUILD injects ONLY the PGO
  # flags (see _gcc_pgo_gen / _gcc_pgo_use); it deliberately does NOT add
  # -march / -O / -fuse-ld / hardening / LTO — those come from your makepkg.conf.
  # NOTE: since the toolchain is pinned to GCC, your makepkg.conf CFLAGS/CXXFLAGS/
  # LDFLAGS must be GCC-compatible (no clang-only tokens such as -mllvm/-Xclang/
  # -flto=thin/-fuse-ld=lld-with-clang-plugins). That is the expected setup for a
  # GCC rebuild set.
  _ORIG_CFLAGS="${CFLAGS:-}"
  _ORIG_CXXFLAGS="${CXXFLAGS:-}"
  _ORIG_LDFLAGS="${LDFLAGS:-}"
}

# _gcc_pgo_xvfb_run <cmd...> : run cmd on a private Xvfb; returns cmd's status,
# 0 if no Xvfb/display is available (training is best-effort but profiles are
# still required — see _gcc_pgo_require).
_gcc_pgo_xvfb_run() {
  local d rc=0 xvfb_pid=""
  if ! command -v Xvfb >/dev/null 2>&1; then
    "$@"; return $?
  fi
  for d in 99 101 123 137 151; do
    [[ -e "/tmp/.X11-unix/X$d" ]] && continue
    Xvfb ":$d" -screen 0 1280x1024x24 -nolisten tcp >/dev/null 2>&1 &
    xvfb_pid=$!
    local ok=0 i
    for i in $(seq 1 80); do
      if command -v xdpyinfo >/dev/null 2>&1; then
        DISPLAY=":$d" xdpyinfo >/dev/null 2>&1 && { ok=1; break; }
      else
        kill -0 "$xvfb_pid" 2>/dev/null && { sleep 0.5; ok=1; break; }
      fi
      sleep 0.1
    done
    if (( ok )); then
      DISPLAY=":$d" "$@"; rc=$?
      kill "$xvfb_pid" 2>/dev/null; wait "$xvfb_pid" 2>/dev/null
      return $rc
    fi
    kill "$xvfb_pid" 2>/dev/null; wait "$xvfb_pid" 2>/dev/null
    xvfb_pid=""
  done
  # No Xvfb could start; run headless (some libs train without a display).
  "$@"; return $?
}

# _gcc_pgo_require <dir> : hard requirement that PGO training produced data.
_gcc_pgo_require() {
  local dir="$1" n
  n=$(find "$dir" -name '*.gcda' 2>/dev/null | wc -l)
  if (( n == 0 )); then
    echo "FATAL: PGO training produced no .gcda in $dir (PGO is mandatory)." >&2
    return 1
  fi
  echo "PGO: $n .gcda profile file(s) collected."
}

pkgver() {
  cd "libxi"
  git describe --long --tags | sed 's/^libXi-//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd "libxi"
  autoreconf -vfi

  cat > "${srcdir}/xi_pgo_workload.c" << 'EOF'
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>
#include <unistd.h>
#include <X11/Xlib.h>
#include <X11/Xatom.h>
#include <X11/extensions/XInput2.h>

static int ignore_xerror(Display *dpy, XErrorEvent *ev) {
  (void)dpy;
  (void)ev;
  return 0;
}

static inline void maybe_sync(Display *dpy, int i, int interval) {
  if (interval > 0 && (i % interval) == 0) XSync(dpy, False);
}

static void train_extension(Display *dpy, int loops) {
  int xi_opcode = 0, event = 0, error = 0;
  int major = 2, minor = 4;
  volatile uint64_t sink = 0;

  for (int i = 0; i < loops; ++i) {
    XQueryExtension(dpy, "XInputExtension", &xi_opcode, &event, &error);
    major = 2; minor = 4;
    XIQueryVersion(dpy, &major, &minor);
    sink += (uint64_t)xi_opcode + (uint64_t)event + (uint64_t)error + (uint64_t)major + (uint64_t)minor;
    maybe_sync(dpy, i, 64);
  }

  if (sink == 0xabcdefULL) fprintf(stderr, "sink=%llu\n", (unsigned long long)sink);
}

static void train_devices_and_classes(Display *dpy, int loops) {
  volatile uint64_t sink = 0;

  for (int i = 0; i < loops; ++i) {
    int ndev = 0;
    XIDeviceInfo *devs = XIQueryDevice(dpy, XIAllDevices, &ndev);
    if (devs) {
      for (int d = 0; d < ndev; ++d) {
        XIDeviceInfo *di = &devs[d];
        sink += (uint64_t)di->deviceid + (uint64_t)di->use + (uint64_t)di->attachment;
        sink += (uint64_t)di->enabled + (uint64_t)di->num_classes;
        if (di->name) sink += (uint64_t)strlen(di->name);

        for (int c = 0; c < di->num_classes; ++c) {
          XIAnyClassInfo *cl = di->classes[c];
          sink += (uint64_t)cl->type + (uint64_t)cl->sourceid;

          switch (cl->type) {
            case XIKeyClass: {
              XIKeyClassInfo *k = (XIKeyClassInfo *)cl;
              sink += (uint64_t)k->num_keycodes;
              break;
            }
            case XIButtonClass: {
              XIButtonClassInfo *b = (XIButtonClassInfo *)cl;
              sink += (uint64_t)b->num_buttons;
              break;
            }
            case XIValuatorClass: {
              XIValuatorClassInfo *v = (XIValuatorClassInfo *)cl;
              sink += (uint64_t)v->number + (uint64_t)v->resolution + (uint64_t)v->mode;
              break;
            }
            case XIScrollClass: {
              XIScrollClassInfo *s = (XIScrollClassInfo *)cl;
              sink += (uint64_t)s->number + (uint64_t)s->scroll_type + (uint64_t)s->flags;
              break;
            }
            case XITouchClass: {
              XITouchClassInfo *t = (XITouchClassInfo *)cl;
              sink += (uint64_t)t->mode + (uint64_t)t->num_touches;
              break;
            }
            default:
              break;
          }
        }
      }
      XIFreeDeviceInfo(devs);
    }

    if ((i & 1) == 0) {
      int nm = 0;
      XIDeviceInfo *m = XIQueryDevice(dpy, XIAllMasterDevices, &nm);
      if (m) XIFreeDeviceInfo(m);
    }

    maybe_sync(dpy, i, 32);
  }

  if (sink == 0x123456ULL) fprintf(stderr, "sink=%llu\n", (unsigned long long)sink);
}

static void train_per_device_queries(Display *dpy, int loops) {
  int ndev = 0;
  XIDeviceInfo *devs = XIQueryDevice(dpy, XIAllDevices, &ndev);
  if (!devs || ndev <= 0) return;

  for (int i = 0; i < loops; ++i) {
    int limit = ndev < 16 ? ndev : 16;
    for (int d = 0; d < limit; ++d) {
      int cnt = 0;
      XIDeviceInfo *one = XIQueryDevice(dpy, devs[d].deviceid, &cnt);
      if (one) XIFreeDeviceInfo(one);
    }
    maybe_sync(dpy, i, 20);
  }

  XIFreeDeviceInfo(devs);
}

static void train_properties(Display *dpy, int loops) {
  int ndev = 0;
  XIDeviceInfo *devs = XIQueryDevice(dpy, XIAllDevices, &ndev);
  if (!devs || ndev <= 0) return;

  for (int i = 0; i < loops; ++i) {
    int limit = ndev < 10 ? ndev : 10;
    for (int d = 0; d < limit; ++d) {
      int nprops = 0;
      Atom *props = XIListProperties(dpy, devs[d].deviceid, &nprops);

      if (props && nprops > 0) {
        int pmax = nprops < 8 ? nprops : 8;
        for (int p = 0; p < pmax; ++p) {
          Atom type = None;
          int format = 0;
          unsigned long nitems = 0, bytes_after = 0;
          unsigned char *data = NULL;

          XIGetProperty(dpy, devs[d].deviceid, props[p], 0, 256, False, AnyPropertyType,
                        &type, &format, &nitems, &bytes_after, &data);
          if (data) XFree(data);
        }
        XFree(props);
      }
    }
    maybe_sync(dpy, i, 16);
  }

  XIFreeDeviceInfo(devs);
}

static void train_event_masks(Display *dpy, Window root, int loops) {
  XIEventMask mask;
  unsigned char global_mask[XIMaskLen(XI_LASTEVENT)];
  unsigned char perdev_mask[XIMaskLen(XI_LASTEVENT)];
  unsigned char clear_mask[XIMaskLen(XI_LASTEVENT)];

  memset(global_mask, 0, sizeof(global_mask));
  memset(perdev_mask, 0, sizeof(perdev_mask));
  memset(clear_mask, 0, sizeof(clear_mask));

  XISetMask(global_mask, XI_Motion);
  XISetMask(global_mask, XI_ButtonPress);
  XISetMask(global_mask, XI_ButtonRelease);
  XISetMask(global_mask, XI_KeyPress);
  XISetMask(global_mask, XI_KeyRelease);
  XISetMask(global_mask, XI_Enter);
  XISetMask(global_mask, XI_Leave);
  XISetMask(global_mask, XI_FocusIn);
  XISetMask(global_mask, XI_FocusOut);
  XISetMask(global_mask, XI_HierarchyChanged);
  XISetMask(global_mask, XI_PropertyEvent);

  XISetMask(perdev_mask, XI_Motion);
  XISetMask(perdev_mask, XI_ButtonPress);
  XISetMask(perdev_mask, XI_ButtonRelease);
  XISetMask(perdev_mask, XI_KeyPress);
  XISetMask(perdev_mask, XI_KeyRelease);
  XISetMask(perdev_mask, XI_Enter);
  XISetMask(perdev_mask, XI_Leave);

  int nm = 0;
  XIDeviceInfo *masters = XIQueryDevice(dpy, XIAllMasterDevices, &nm);

  for (int i = 0; i < loops; ++i) {
    mask.deviceid = XIAllDevices;
    mask.mask_len = sizeof(global_mask);
    mask.mask = global_mask;
    XISelectEvents(dpy, root, &mask, 1);

    if (masters && nm > 0) {
      int lim = nm < 4 ? nm : 4;
      for (int m = 0; m < lim; ++m) {
        mask.deviceid = masters[m].deviceid;
        mask.mask_len = sizeof(perdev_mask);
        mask.mask = perdev_mask;
        XISelectEvents(dpy, root, &mask, 1);
      }
    }

    int nmasks = 0;
    XIEventMask *selected = XIGetSelectedEvents(dpy, root, &nmasks);
    if (selected) XFree(selected);

    mask.deviceid = XIAllDevices;
    mask.mask_len = sizeof(clear_mask);
    mask.mask = clear_mask;
    XISelectEvents(dpy, root, &mask, 1);

    maybe_sync(dpy, i, 8);
  }

  if (masters) XIFreeDeviceInfo(masters);
}

static void train_pointer_focus_client(Display *dpy, Window root, int loops) {
  int nm = 0;
  XIDeviceInfo *masters = XIQueryDevice(dpy, XIAllMasterDevices, &nm);
  if (!masters || nm <= 0) return;

  for (int i = 0; i < loops; ++i) {
    int client_ptr = 0;
    XIGetClientPointer(dpy, None, &client_ptr);

    for (int m = 0; m < nm; ++m) {
      int devid = masters[m].deviceid;
      if (masters[m].use == XIMasterKeyboard) {
        Window focus = None;
        XIGetFocus(dpy, devid, &focus);
      } else if (masters[m].use == XIMasterPointer) {
        Window root_return = None, child_return = None;
        double root_x = 0.0, root_y = 0.0, win_x = 0.0, win_y = 0.0;
        XIButtonState buttons = {0};
        XIModifierState mods = {0};
        XIGroupState group = {0};

        XIQueryPointer(dpy, devid, root, &root_return, &child_return,
                       &root_x, &root_y, &win_x, &win_y,
                       &buttons, &mods, &group);
        if (buttons.mask) XFree(buttons.mask);
      }
    }

    maybe_sync(dpy, i, 16);
  }

  XIFreeDeviceInfo(masters);
}

static void run_profile(Display *dpy, int base) {
  Window root = RootWindow(dpy, DefaultScreen(dpy));
  train_extension(dpy, base * 160);
  train_devices_and_classes(dpy, base * 90);
  train_per_device_queries(dpy, base * 40);
  train_properties(dpy, base * 36);
  train_event_masks(dpy, root, base * 26);
  train_pointer_focus_client(dpy, root, base * 60);
}

int main(int argc, char **argv) {
  int base = (argc > 1) ? atoi(argv[1]) : 6;
  if (base < 2) base = 2;

  Display *dpy = XOpenDisplay(NULL);
  if (!dpy) return 0;

  XSetErrorHandler(ignore_xerror);

  int opcode = 0, event = 0, error = 0;
  int major = 2, minor = 2;
  if (!XQueryExtension(dpy, "XInputExtension", &opcode, &event, &error)) {
    XCloseDisplay(dpy);
    return 0;
  }
  if (XIQueryVersion(dpy, &major, &minor) != Success) {
    XCloseDisplay(dpy);
    return 0;
  }

  run_profile(dpy, base);
  usleep(12000);
  run_profile(dpy, base + 2);
  usleep(12000);
  run_profile(dpy, base + 4);

  XSync(dpy, False);
  XCloseDisplay(dpy);
  return 0;
}
EOF
}


build() {
  _gcc_pgo_init
  local _src="$srcdir/libxi"
  local _pgo="$srcdir/pgo-data"
  rm -rf "$_pgo"; mkdir -p "$_pgo"

  # --- write the embedded training workload -------------------------------
  base64 -d > "$srcdir/wl_libxi.c" <<'__WL_B64__'

__WL_B64__

  # ---- STAGE 1: instrumented build --------------------------------------
  cd "$_src"
  autoreconf -vfi
  ./configure --prefix=/usr --disable-static --disable-docs --without-xmlto
  local _gen; _gen="$(_gcc_pgo_gen "$_pgo")"
  make -j"$(nproc)" \
    CFLAGS="$_ORIG_CFLAGS $_gen" \
    CXXFLAGS="$_ORIG_CXXFLAGS $_gen" \
    LDFLAGS="$_ORIG_LDFLAGS -fprofile-generate=$_pgo"

  # ---- STAGE 1 training: build the workload against the in-tree lib ------
  _train() {
    local wlbin="$srcdir/wl_libxi.runner"
    # Bind the trainer to the freshly-built INSTRUMENTED lib. Use the top-level
    # libtool archive (NOT the internal .libs/*.la copy) so libtool resolves the
    # in-tree .so and emits a wrapper that sets the right rpath automatically.
    local la
    # Pick the MAIN library archive (libXi.la), not the first .la found
    # (libx11 etc. ship many helper/module .la files; the alphabetically-first
    # is wrong and would leave the real library untrained). Fall back to the
    # largest top-level .la if the exact name is not present.
    la="$(find "$_src" -name 'libXi.la' -not -path '*/.libs/*' | head -1)"
    if [[ -z "$la" ]]; then
      la="$(find "$_src" -maxdepth 3 -name '*.la' -not -path '*/.libs/*' -printf '%s %p\n' \
            | sort -rn | head -1 | cut -d' ' -f2-)"
    fi
    if [[ -n "$la" && -x ./libtool ]]; then
      if ! CFLAGS="$_ORIG_CFLAGS" ./libtool --tag=CC --mode=link "$CC" \
             "$srcdir/wl_libxi.c" -o "$wlbin" \
             -I"$_src/include" -I"$_src" "$la" -lX11; then
        echo "warn: trainer libtool-link failed; skipping training" >&2
        return 0
      fi
    else
      local sodir
      sodir="$(find "$_src" -name 'libXi*.so*' -printf '%h\n' 2>/dev/null | head -1)"
      [[ -z "$sodir" ]] && sodir="$_src/src/.libs"
      if ! "$CC" $_ORIG_CFLAGS "$srcdir/wl_libxi.c" -o "$wlbin" \
             -lXi -lX11 -L"$sodir" -Wl,-rpath,"$sodir"; then
        echo "warn: trainer link failed; skipping training" >&2
        return 0
      fi
    fi
    _gcc_pgo_xvfb_run "$wlbin" || true
    rm -f "$wlbin"
  }
  _train

  _gcc_pgo_require "$_pgo" || return 1

  # ---- STAGE 2: profile-use rebuild -------------------------------------
  make clean
  local _use; _use="$(_gcc_pgo_use "$_pgo")"
  make -j"$(nproc)" \
    CFLAGS="$_ORIG_CFLAGS $_use" \
    CXXFLAGS="$_ORIG_CXXFLAGS $_use" \
    LDFLAGS="$_ORIG_LDFLAGS"
}

package() {
  cd "${srcdir}/libxi"
  make DESTDIR="${pkgdir}" install
  install -Dm644 "COPYING" -t "${pkgdir}/usr/share/licenses/libxi"
}

# =====================================================================
# PACKAGE NAME: libxi-git
# Rename this file to 'PKGBUILD' inside the 'libxi-git' package directory.
# =====================================================================
