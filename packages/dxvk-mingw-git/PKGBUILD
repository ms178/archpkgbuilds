pkgname=dxvk-mingw-git
pkgver=2.7.1.r837.g8c3eaf980
pkgrel=1
pkgdesc='Vulkan-based D3D9/10/11 for Linux / Wine, MingW version (unified ms178 patch)'
arch=('x86_64')
url="https://github.com/doitsujin/dxvk"
license=('zlib/libpng')
makedepends=('ninja' 'meson' 'glslang' 'git' 'mingw-w64-gcc')
provides=('dxvk' 'd9vk' "dxvk=$pkgver")
conflicts=('dxvk' 'd9vk')
options=(!lto !staticlibs !buildflags)
source=(
  "git+https://github.com/doitsujin/dxvk.git"
  "ms178-1.patch"
  "setup_dxvk.sh"
  "setup_dxvk"
)

pkgver() {
  cd dxvk
  git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g;s/v//g'
}

prepare() {
  cd dxvk
  git remote set-url origin https://github.com/doitsujin/dxvk.git
  git submodule update --init --filter=tree:0 --recursive

  patch -p1 -i "$srcdir"/ms178-1.patch

  export CFLAGS="-O3 -march=native -mtune=native \
    -falign-functions=32 -funroll-loops \
    -fno-semantic-interposition -fcf-protection=none -mharden-sls=none \
    -fomit-frame-pointer -mprefer-vector-width=256 \
    -flto -fwhole-program-vtables -fsplit-lto-unit \
    -fdata-sections -ffunction-sections -fno-unique-section-names \
    -D_WIN32_WINNT=0xA00 -fprofile-use=/home/marcus/Downloads/all3.profdata -w \
    -mfpmath=sse -fwrapv -fno-strict-aliasing"
  export CXXFLAGS="$CFLAGS -Wp,-U_GLIBCXX_ASSERTIONS"
  export LDFLAGS="-Wl,-O3,--as-needed -flto -fwhole-program-vtables \
    -Wl,--gc-sections -fprofile-use=/home/marcus/Downloads/all3.profdata -Wl,--file-alignment,4096"

  local cross_ldflags="$LDFLAGS"
  local cross_cflags="$CFLAGS -mcmodel=small"
  local cross_cxxflags="$CXXFLAGS -mcmodel=small"
  sed -i build-win64.txt \
    -e "s|@CARGS@|\'${cross_cflags// /\',\'}\'|g" \
    -e "s|@CXXARGS@|\'${cross_cxxflags// /\',\'}\'|g" \
    -e "s|@LDARGS@|\'${cross_ldflags// /\',\'}\'|g"

  local cross_cflags="$CFLAGS -mstackrealign"
  local cross_cxxflags="$CXXFLAGS -mstackrealign"
  sed -i build-win32.txt \
    -e "s|@CARGS@|\'${cross_cflags// /\',\'}\'|g" \
    -e "s|@CXXARGS@|\'${cross_cxxflags// /\',\'}\'|g" \
    -e "s|@LDARGS@|\'${cross_ldflags// /\',\'}\'|g"
}

build() {
  meson setup dxvk "build/x64" \
    --cross-file dxvk/build-win64.txt \
    --prefix "/usr/share/dxvk/x64" \
    --bindir "" --libdir "" \
    --buildtype "release" \
    -D b_ndebug=true \
    -D python.bytecompile=2 \
    -D b_pie=false \
    --strip
  ninja -C "build/x64" -v

  meson setup dxvk "build/x32" \
    --cross-file dxvk/build-win32.txt \
    --prefix "/usr/share/dxvk/x32" \
    --bindir "" --libdir "" \
    --buildtype "release" \
    -D b_ndebug=true \
    -D python.bytecompile=2 \
    -D b_pie=false \
    --strip
  ninja -C "build/x32" -v
}

package() {
  depends=('vulkan-icd-loader' 'lib32-vulkan-icd-loader' 'wine' 'bash')
  DESTDIR="$pkgdir" ninja -C "build/x32" install
  DESTDIR="$pkgdir" ninja -C "build/x64" install
  install -Dm 755 -t "$pkgdir/usr/share/dxvk" setup_dxvk.sh
  install -Dm 644 -t "$pkgdir/usr/share/dxvk" dxvk/dxvk.conf
  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname" dxvk/README.md
  install -Dm 644 -t "$pkgdir/usr/share/licenses/$pkgname" dxvk/LICENSE
  install -Dm 755 -t "$pkgdir/usr/bin" setup_dxvk
}

sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')
