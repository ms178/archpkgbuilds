# Maintainer: ms178
pkgname=dxvk-mingw-git
pkgver=3.0.r36.g031a33b3b
pkgrel=1
pkgdesc='Vulkan-based D3D9/10/11 for Linux / Wine, MingW version (ms178 optimized)'
arch=('x86_64')
url="https://github.com/doitsujin/dxvk"
license=('zlib')
makedepends=('ninja' 'meson>=0.58' 'glslang' 'git'
             'llvm-mingw-ms178')
provides=('dxvk' 'd9vk' "dxvk=$pkgver")
conflicts=('dxvk' 'd9vk')
options=(!lto !staticlibs !buildflags strip)
source=(
  "git+https://github.com/doitsujin/dxvk.git"
  "ms178-1.patch"
)
sha256sums=('SKIP' 'SKIP')

pkgver() {
  cd dxvk
  git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g;s/v//g'
}

prepare() {
  cd dxvk
  git submodule update --init --filter=tree:0 --recursive
  patch -Np1 -i "$srcdir/ms178-1.patch"
}

build() {

  local PGO_FLAGS=""

  local common_flags=(
    -O3 -march=native -mtune=native
    -falign-functions=32
    -fomit-frame-pointer -mprefer-vector-width=256
    -fdata-sections -ffunction-sections -fno-unique-section-names
    -fno-semantic-interposition -fcf-protection=none -mharden-sls=none
    -w
  )
  if [[ -n "$PGO_FLAGS" ]]; then
    common_flags+=($PGO_FLAGS)
  fi

  local c_args_64=("${common_flags[@]}" -mcmodel=small)
  local cxx_args_64=("${common_flags[@]}" -mcmodel=small -Wp,-U_GLIBCXX_ASSERTIONS)
  local c_args_32=("${common_flags[@]}" -mstackrealign)
  local cxx_args_32=("${common_flags[@]}" -mstackrealign -Wp,-U_GLIBCXX_ASSERTIONS)

  local link_args=(-Wl,--gc-sections -Wl,--file-alignment,4096)
  if [[ -n "$PGO_FLAGS" ]]; then
    link_args+=($PGO_FLAGS)
  fi

  # Helper: turn bash array into meson array string: ['-O3','-march=native',...]
  meson_array() {
    local sep=""
    printf "["
    for arg in "$@"; do
      printf "%s'%s'" "$sep" "${arg//\'/\'\\\'\'}"
      sep=","
    done
    printf "]"
  }

  local c_args_64_s=$(meson_array "${c_args_64[@]}")
  local cxx_args_64_s=$(meson_array "${cxx_args_64[@]}")
  local c_args_32_s=$(meson_array "${c_args_32[@]}")
  local cxx_args_32_s=$(meson_array "${cxx_args_32[@]}")
  local link_args_s=$(meson_array "${link_args[@]}")

  # 64-bit
  meson setup dxvk build/x64 \
    --cross-file dxvk/build-win64.txt \
    --prefix "/usr/share/dxvk/x64" \
    --bindir "" --libdir "" \
    --buildtype release \
    -D b_ndebug=true \
    -D b_pie=false \
    -D b_lto=true \
    -D b_lto_mode=default \
    -D build_id=false \
    -D c_args="$c_args_64_s" \
    -D cpp_args="$cxx_args_64_s" \
    -D c_link_args="$link_args_s" \
    -D cpp_link_args="$link_args_s" \
    --strip

  ninja -C build/x64

  # 32-bit
  meson setup dxvk build/x32 \
    --cross-file dxvk/build-win32.txt \
    --prefix "/usr/share/dxvk/x32" \
    --bindir "" --libdir "" \
    --buildtype release \
    -D b_ndebug=true \
    -D b_pie=false \
    -D b_lto=true \
    -D b_lto_mode=default \
    -D build_id=false \
    -D c_args="$c_args_32_s" \
    -D cpp_args="$cxx_args_32_s" \
    -D c_link_args="$link_args_s" \
    -D cpp_link_args="$link_args_s" \
    --strip

  ninja -C build/x32
}

package() {
  depends=('vulkan-icd-loader' 'lib32-vulkan-icd-loader' 'wine')
  DESTDIR="$pkgdir" ninja -C build/x32 install
  DESTDIR="$pkgdir" ninja -C build/x64 install
  install -Dm644 -t "$pkgdir/usr/share/doc/$pkgname" dxvk/README.md
  install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" dxvk/LICENSE
}
