+    };
+
+    struct ShaderKeyEq {
+      bool operator () (const DxvkGplAsyncShaderKey& a, const DxvkGplAsyncShaderKey& b) const {
+        return a.eq(b);
+      }
+    };
+
+    DxvkDevice*                         m_device      = nullptr;
