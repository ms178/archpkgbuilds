+
+    void mapEntryLocked(const DxvkGplAsyncCacheEntry& entry, size_t entryId);
+    void mapShaderToPipelineLocked(const DxvkGplAsyncShaderKey& shader, const DxvkGplAsyncPipelineKey& key);
