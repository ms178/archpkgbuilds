+    bool readCacheEntry(std::istream& stream, DxvkGplAsyncCacheEntry& entry) const;
+    void writeCacheEntry(std::ostream& stream, const DxvkGplAsyncCacheEntry& entry) const;
+
+    void workerFunc();
