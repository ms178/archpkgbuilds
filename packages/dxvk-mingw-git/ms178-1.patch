diff --git a/src/dxvk/dxvk_gpl_async_cache.cpp b/src/dxvk/dxvk_gpl_async_cache.cpp
new file mode 100644
index 00000000..d2a29bc1
--- /dev/null
+++ b/src/dxvk/dxvk_gpl_async_cache.cpp
@@ -0,0 +1,575 @@
+#include "dxvk_device.h"
+#include "dxvk_gpl_async_cache.h"
+#include "dxvk_pipemanager.h"
+
+#include "../util/sha1/sha1_util.h"
+#include "../util/util_env.h"
+
+#include <fstream>
+#include <sstream>
+
+namespace dxvk {
+
+  DxvkGplAsyncCache::DxvkGplAsyncCache(
+      DxvkDevice*           device,
+      DxvkPipelineManager*  pipeManager,
+      DxvkPipelineWorkers*  pipeWorkers)
+  : m_device     (device),
+    m_pipeManager(pipeManager),
+    m_pipeWorkers(pipeWorkers) {
+    std::string useCache = env::getEnvVar("DXVK_GPL_ASYNC_CACHE");
+
+    if (useCache.empty())
+      useCache = env::getEnvVar("DXVK_GPLASYNCCACHE");
+
+    if (useCache.empty())
+      useCache = env::getEnvVar("DXVK_GPLASYNC");
+
+    m_enable = useCache != "0"
+            && useCache != "disable"
+            && m_device->config().gplAsyncCache;
+
+    if (!m_enable)
+      return;
+
+    bool recreate = useCache == "reset";
+
+    if (!recreate)
+      recreate = !readCacheFile();
+
+    if (recreate) {
+      auto file = openCacheFileForWrite(true);
+
+      if (file) {
+        std::lock_guard<dxvk::mutex> lock(m_entryLock);
+
+        for (const auto& entry : m_entries)
+          writeCacheEntry(file, entry);
+      }
+    }
+  }
+
+
+  DxvkGplAsyncCache::~DxvkGplAsyncCache() {
+    stopWorkers();
+  }
+
+
+  void DxvkGplAsyncCache::addGraphicsPipeline(
+      const DxvkGraphicsPipelineShaders&    shaders,
+      const DxvkGraphicsPipelineStateInfo&  state) {
+    if (!m_enable)
+      return;
+
+    DxvkGplAsyncPipelineKey key = getPipelineKey(shaders);
+
+    if (key.vs.isNull())
+      return;
+
+    { std::lock_guard<dxvk::mutex> lock(m_entryLock);
+      auto range = m_entryMap.equal_range(key);
+
+      for (auto i = range.first; i != range.second; i++) {
+        if (m_entries[i->second].state.eq(state))
+          return;
+      }
+    }
+
+    DxvkGplAsyncCacheEntry entry = { };
+    entry.shaders = key;
+    entry.state   = state;
+
+    { std::lock_guard<dxvk::mutex> lock(m_writerLock);
+      m_writerQueue.push(std::move(entry));
+      createWriterLocked();
+    }
+
+    m_writerCond.notify_one();
+  }
+
+
+  void DxvkGplAsyncCache::registerShader(const Rc<DxvkShader>& shader) {
+    if (!m_enable || shader == nullptr)
+      return;
+
+    DxvkGplAsyncShaderKey shaderKey = getShaderKey(shader);
+
+    if (shaderKey.isNull())
+      return;
+
+    // Linear-scan dedup on the small readyPipelines vector instead of
+    // allocating a fresh unordered_set every call. The typical pipeline
+    // count per shader is 0-4; for n<=16 a linear scan over cache-resident
+    // 100-byte keys beats hash-set lookup overhead.
+    std::vector<WorkerItem> readyPipelines;
+
+    { std::lock_guard<dxvk::mutex> lock(m_entryLock);
+      m_shaderMap.insert_or_assign(shaderKey, shader);
+
+      const size_t pipelineCount = m_pipelineMap.count(shaderKey);
+
+      if (!pipelineCount)
+        return;
+
+      readyPipelines.reserve(pipelineCount);
+
+      auto range = m_pipelineMap.equal_range(shaderKey);
+
+      for (auto i = range.first; i != range.second; i++) {
+        const auto& candidateKey = i->second;
+
+        bool duplicate = false;
+        for (const auto& existing : readyPipelines) {
+          if (existing.key.eq(candidateKey)) {
+            duplicate = true;
+            break;
+          }
+        }
+
+        if (duplicate)
+          continue;
+
+        WorkerItem item;
+        item.key = candidateKey;
+
+        if (!getShaderByKeyLocked(item.key.vs,  item.shaders.vs)
+         || !getShaderByKeyLocked(item.key.tcs, item.shaders.tcs)
+         || !getShaderByKeyLocked(item.key.tes, item.shaders.tes)
+         || !getShaderByKeyLocked(item.key.gs,  item.shaders.gs)
+         || !getShaderByKeyLocked(item.key.fs,  item.shaders.fs))
+          continue;
+
+        readyPipelines.push_back(std::move(item));
+      }
+    }
+
+    if (readyPipelines.empty())
+      return;
+
+    bool queued = false;
+
+    { std::lock_guard<dxvk::mutex> lock(m_workerLock);
+      for (const auto& item : readyPipelines)
+        queued |= queuePipelineLocked(item.key, item.shaders);
+
+      if (queued)
+        createWorkerLocked();
+    }
+
+    if (queued)
+      m_workerCond.notify_one();
+  }
+
+
+  void DxvkGplAsyncCache::stopWorkers() {
+    // This method must be called while m_pipeManager and m_pipeWorkers are
+    // still alive. Today that is guaranteed because DxvkPipelineManager owns
+    // this object and tears down its own workers before its destructor
+    // returns. Do NOT move this object into a container whose destruction
+    // order is not strict-LIFO with the pipeline manager.
+    if (m_stopThreads.exchange(true, std::memory_order_acq_rel))
+      return;
+
+    // Wake both threads so they can observe the stop flag.
+    m_workerCond.notify_one();
+    m_writerCond.notify_one();
+
+    if (m_workerThread.joinable())
+      m_workerThread.join();
+
+    if (m_writerThread.joinable())
+      m_writerThread.join();
+  }
+
+
+  DxvkGplAsyncPipelineKey DxvkGplAsyncCache::getPipelineKey(
+      const DxvkGraphicsPipelineShaders& shaders) const {
+    DxvkGplAsyncPipelineKey key = { };
+    key.vs  = getShaderKey(shaders.vs);
+    key.tcs = getShaderKey(shaders.tcs);
+    key.tes = getShaderKey(shaders.tes);
+    key.gs  = getShaderKey(shaders.gs);
+    key.fs  = getShaderKey(shaders.fs);
+    return key;
+  }
+
+
+  DxvkGplAsyncShaderKey DxvkGplAsyncCache::getShaderKey(
+      const Rc<DxvkShader>& shader) const {
+    DxvkGplAsyncShaderKey key = { };
+
+    if (shader == nullptr)
+      return key;
+
+    // Memoise SHA1(debugName) on the per-process shader cookie. debugName()
+    // allocates an std::string and the SHA1 runs over ~30-80 bytes; both are
+    // wasted when the same shader is queried repeatedly (which is the common
+    // case from getPipelineKey, which calls this 5x per pipeline).
+    const size_t cookie = shader->getCookie();
+
+    if (cookie != 0u) {
+      std::lock_guard<dxvk::mutex> lock(m_shaderKeyCacheLock);
+      auto it = m_shaderKeyCache.find(cookie);
+      if (it != m_shaderKeyCache.end())
+        return it->second;
+    }
+
+    std::string name = shader->debugName();
+
+    if (name.empty())
+      return key;
+
+    Sha1Hash hash = Sha1Hash::compute(name.data(), name.size());
+    std::memcpy(key.hash.data(), hash.digest(), key.hash.size());
+
+    if (cookie != 0u) {
+      std::lock_guard<dxvk::mutex> lock(m_shaderKeyCacheLock);
+      m_shaderKeyCache.emplace(cookie, key);
+    }
+
+    return key;
+  }
+
+
+  bool DxvkGplAsyncCache::getShaderByKeyLocked(
+      const DxvkGplAsyncShaderKey& key,
+      Rc<DxvkShader>&              shader) const {
+    if (key.isNull())
+      return true;
+
+    auto entry = m_shaderMap.find(key);
+
+    if (entry == m_shaderMap.end())
+      return false;
+
+    shader = entry->second;
+    return true;
+  }
+
+
+  void DxvkGplAsyncCache::mapEntryLocked(
+      const DxvkGplAsyncCacheEntry& entry,
+      size_t                        entryId) {
+    m_entryMap.insert({ entry.shaders, entryId });
+
+    mapShaderToPipelineLocked(entry.shaders.vs,  entry.shaders);
+    mapShaderToPipelineLocked(entry.shaders.tcs, entry.shaders);
+    mapShaderToPipelineLocked(entry.shaders.tes, entry.shaders);
+    mapShaderToPipelineLocked(entry.shaders.gs,  entry.shaders);
+    mapShaderToPipelineLocked(entry.shaders.fs,  entry.shaders);
+  }
+
+
+  void DxvkGplAsyncCache::mapShaderToPipelineLocked(
+      const DxvkGplAsyncShaderKey&   shader,
+      const DxvkGplAsyncPipelineKey& key) {
+    if (!shader.isNull())
+      m_pipelineMap.insert({ shader, key });
+  }
+
+
+  bool DxvkGplAsyncCache::queuePipelineLocked(
+      const DxvkGplAsyncPipelineKey&    key,
+      const DxvkGraphicsPipelineShaders& shaders) {
+    if (!m_queuedPipelines.insert(key).second)
+      return false;
+
+    m_workerQueue.push({ key, shaders });
+    return true;
+  }
+
+
+  void DxvkGplAsyncCache::compilePipelines(const WorkerItem& item) {
+    DxvkGraphicsPipeline* pipeline = nullptr;
+    std::vector<DxvkGraphicsPipelineStateInfo> states;
+
+    { std::lock_guard<dxvk::mutex> lock(m_entryLock);
+      // Avoid the redundant unordered_multimap::count() pass over the
+      // bucket. count() walks the linked bucket once just to size the
+      // reservation, then equal_range walks it again. A small reserve
+      // covers the common 1-4-entry bucket; growth amortises.
+      auto range = m_entryMap.equal_range(item.key);
+      states.reserve(4u);
+
+      for (auto i = range.first; i != range.second; i++)
+        states.push_back(m_entries[i->second].state);
+    }
+
+    for (const auto& state : states) {
+      if (!pipeline)
+        pipeline = m_pipeManager->createGraphicsPipeline(item.shaders);
+
+      if (pipeline)
+        m_pipeWorkers->compileGraphicsPipeline(pipeline, state, DxvkPipelinePriority::Low);
+    }
+  }
+
+
+  bool DxvkGplAsyncCache::readCacheFile() {
+    std::ifstream file = openCacheFileForRead();
+
+    if (!file)
+      return true;
+
+    DxvkGplAsyncCacheHeader header;
+
+    if (!readCacheHeader(file, header)) {
+      Logger::warn("DXVK: Failed to read GPL async cache header");
+      return false;
+    }
+
+    // Pre-size containers to avoid incremental rehashing.
+    const std::streamoff dataBegin = std::streamoff(file.tellg());
+    file.seekg(0, std::ios_base::end);
+    const std::streamoff dataEnd = std::streamoff(file.tellg());
+    file.seekg(dataBegin, std::ios_base::beg);
+
+    if (dataBegin >= 0 && dataEnd > dataBegin) {
+      constexpr std::streamoff RecordSize = std::streamoff(
+        sizeof(DxvkGplAsyncCacheRecordHeader) + sizeof(DxvkGplAsyncCacheEntry));
+      const size_t estimatedEntries = size_t((dataEnd - dataBegin) / RecordSize);
+
+      m_entries.reserve(m_entries.size() + estimatedEntries);
+      m_entryMap.reserve(m_entryMap.size() + estimatedEntries);
+      m_pipelineMap.reserve(m_pipelineMap.size() + 5u * estimatedEntries);
+    }
+
+    uint32_t invalidEntries = 0u;
+
+    // Hold entryLock for the entire read loop to avoid interleaved inserts
+    // from registerShader() on another thread during startup.
+    { std::lock_guard<dxvk::mutex> lock(m_entryLock);
+      while (file) {
+        DxvkGplAsyncCacheEntry entry;
+
+        if (readCacheEntry(file, entry)) {
+          const size_t entryId = m_entries.size();
+          m_entries.push_back(entry);
+          mapEntryLocked(entry, entryId);
+        } else if (file) {
+          invalidEntries += 1u;
+        }
+      }
+    }
+
+    Logger::info(str::format("DXVK: Read ", m_entries.size(), " valid GPL async cache entries"));
+
+    if (invalidEntries) {
+      Logger::warn(str::format("DXVK: Skipped ", invalidEntries, " invalid GPL async cache entries"));
+      return false;
+    }
+
+    return true;
+  }
+
+
+  bool DxvkGplAsyncCache::readCacheHeader(
+      std::istream&             stream,
+      DxvkGplAsyncCacheHeader&  header) const {
+    DxvkGplAsyncCacheHeader expected;
+
+    if (!stream.read(reinterpret_cast<char*>(&header), sizeof(header)))
+      return false;
+
+    return std::memcmp(header.magic, expected.magic, sizeof(header.magic)) == 0
+        && header.version   == expected.version
+        && header.keySize   == expected.keySize
+        && header.stateSize == expected.stateSize;
+  }
+
+
+  bool DxvkGplAsyncCache::readCacheEntry(
+      std::istream&          stream,
+      DxvkGplAsyncCacheEntry& entry) const {
+    DxvkGplAsyncCacheRecordHeader header;
+
+    if (!stream.read(reinterpret_cast<char*>(&header), sizeof(header)))
+      return false;
+
+    if (header.dataSize != sizeof(entry)) {
+      if (header.dataSize > (1u << 20u)) {
+        stream.setstate(std::ios_base::failbit);
+      } else {
+        stream.seekg(std::streamoff(header.dataSize), std::ios_base::cur);
+      }
+
+      return false;
+    }
+
+    if (!stream.read(reinterpret_cast<char*>(&entry), sizeof(entry)))
+      return false;
+
+    Sha1Hash hash = Sha1Hash::compute(entry);
+    return std::memcmp(header.hash.data(), hash.digest(), header.hash.size()) == 0
+        && !entry.shaders.vs.isNull();
+  }
+
+
+  void DxvkGplAsyncCache::writeCacheEntry(
+      std::ostream&                stream,
+      const DxvkGplAsyncCacheEntry& entry) const {
+    DxvkGplAsyncCacheRecordHeader header;
+    Sha1Hash hash = Sha1Hash::compute(entry);
+    std::memcpy(header.hash.data(), hash.digest(), header.hash.size());
+
+    stream.write(reinterpret_cast<const char*>(&header), sizeof(header));
+    stream.write(reinterpret_cast<const char*>(&entry),  sizeof(entry));
+  }
+
+
+  void DxvkGplAsyncCache::workerFunc() {
+    env::setThreadName("dxvk-gplcache");
+
+    while (!m_stopThreads.load(std::memory_order_acquire)) {
+      WorkerItem item;
+
+      { std::unique_lock<dxvk::mutex> lock(m_workerLock);
+        m_workerCond.wait(lock, [this] {
+          return m_stopThreads.load(std::memory_order_acquire) || !m_workerQueue.empty();
+        });
+
+        if (m_stopThreads.load(std::memory_order_acquire) || m_workerQueue.empty())
+          break;
+
+        item = std::move(m_workerQueue.front());
+        m_workerQueue.pop();
+      }
+
+      compilePipelines(item);
+    }
+  }
+
+
+  void DxvkGplAsyncCache::writerFunc() {
+    env::setThreadName("dxvk-gplwrite");
+
+    std::ofstream file;
+
+    // Periodic flush so crashes don't lose more than a handful of entries.
+    // std::ofstream in binary|app mode is fully buffered; without a flush
+    // the kernel only sees data on close, which never happens on SIGKILL.
+    uint32_t unflushedEntries = 0u;
+    constexpr uint32_t FlushInterval = 8u;
+
+    while (true) {
+      DxvkGplAsyncCacheEntry entry;
+      bool drainStop = false;
+
+      { std::unique_lock<dxvk::mutex> lock(m_writerLock);
+        m_writerCond.wait(lock, [this] {
+          return m_stopThreads.load(std::memory_order_acquire) || !m_writerQueue.empty();
+        });
+
+        if (m_writerQueue.empty()) {
+          drainStop = true;
+        } else {
+          entry = std::move(m_writerQueue.front());
+          m_writerQueue.pop();
+        }
+      }
+
+      if (drainStop) {
+        if (file && unflushedEntries)
+          file.flush();
+        break;
+      }
+
+      { std::lock_guard<dxvk::mutex> lock(m_entryLock);
+        auto range = m_entryMap.equal_range(entry.shaders);
+        bool exists = false;
+
+        for (auto i = range.first; i != range.second && !exists; i++)
+          exists = m_entries[i->second].state.eq(entry.state);
+
+        if (exists)
+          continue;
+
+        const size_t entryId = m_entries.size();
+        m_entries.push_back(entry);
+        mapEntryLocked(entry, entryId);
+      }
+
+      if (!file.is_open())
+        file = openCacheFileForWrite(false);
+
+      if (file) {
+        writeCacheEntry(file, entry);
+        if (++unflushedEntries >= FlushInterval) {
+          file.flush();
+          unflushedEntries = 0u;
+        }
+      }
+    }
+  }
+
+
+  void DxvkGplAsyncCache::createWorkerLocked() {
+    if (!m_workerThread.joinable())
+      m_workerThread = dxvk::thread([this] { workerFunc(); });
+  }
+
+
+  void DxvkGplAsyncCache::createWriterLocked() {
+    if (!m_writerThread.joinable())
+      m_writerThread = dxvk::thread([this] { writerFunc(); });
+  }
+
+
+  str::path_string DxvkGplAsyncCache::getCacheFileName() const {
+    std::string path = getCacheDir();
+
+    if (!path.empty() && path.back() != '/')
+      path += '/';
+
+    std::string baseName = env::getExeBaseName();
+
+    if (baseName.empty())
+      baseName = "dxvk";
+
+    path += baseName + ".dxvk-gplasync-cache";
+    return str::topath(path.c_str());
+  }
+
+
+  std::ifstream DxvkGplAsyncCache::openCacheFileForRead() const {
+    return std::ifstream(getCacheFileName().c_str(), std::ios_base::binary);
+  }
+
+
+  std::ofstream DxvkGplAsyncCache::openCacheFileForWrite(bool recreate) const {
+    const auto fileName = getCacheFileName();
+    std::ofstream file;
+
+    if (!recreate)
+      recreate = !openCacheFileForRead();
+
+    if (recreate) {
+      file = std::ofstream(fileName.c_str(), std::ios_base::binary | std::ios_base::trunc);
+
+      std::string cacheDir = getCacheDir();
+
+      if (!file && !cacheDir.empty() && env::createDirectory(cacheDir))
+        file = std::ofstream(fileName.c_str(), std::ios_base::binary | std::ios_base::trunc);
+    } else {
+      file = std::ofstream(fileName.c_str(), std::ios_base::binary | std::ios_base::app);
+    }
+
+    if (file && recreate) {
+      DxvkGplAsyncCacheHeader header;
+      file.write(reinterpret_cast<const char*>(&header), sizeof(header));
+    }
+
+    return file;
+  }
+
+
+  std::string DxvkGplAsyncCache::getCacheDir() const {
+    std::string result = env::getEnvVar("DXVK_GPL_ASYNC_CACHE_PATH");
+
+    if (result.empty())
+      result = env::getEnvVar("DXVK_STATE_CACHE_PATH");
+
+    return result;
+  }
+
+}
