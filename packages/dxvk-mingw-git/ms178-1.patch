 #include "dxvk_descriptor_pool.h"
 #include "dxvk_device.h"
 
@@ -26,8 +28,66 @@ namespace dxvk {
     const DxvkPipelineLayout*       layout,
           uint32_t                  setMask,
           VkDescriptorSet*          sets) {
-    for (auto setIndex : bit::BitMask(setMask))
-      sets[setIndex] = alloc(trackingId, layout->getDescriptorSetLayout(setIndex));
+    // Fast out when no set is dirty. The mask is zero in the majority
+    // of D3D11 draw calls (state stays sticky between draws), and the
+    // BitMask iterator setup + scalar loop below is not free.
+    if (likely(!setMask))
+      return;
+
+    // Gather all layouts up front and issue ONE vkAllocateDescriptorSets
+    // call instead of one per bit. RADV's allocator amortises pool book-
+    // keeping across the batch (see radv_descriptor_set.c:radv_descriptor_pools_alloc)
+    // and Vulkan drivers in general are optimised for batched allocation;
+    // per-set calls repeat validation, layout resolution, and pool traversal.
+    //
+    // setMask is a 32-bit mask, so the batch is bounded by 32 sets. In
+    // practice DXVK pipeline layouts use at most a handful of sets, so
+    // stack storage of MaxBatch entries is trivial.
+    constexpr uint32_t MaxBatch = 32u;
+
+    std::array<VkDescriptorSetLayout, MaxBatch> setLayouts;
+    std::array<uint32_t,              MaxBatch> setIndices;
+    std::array<VkDescriptorSet,       MaxBatch> outSets;
+
+    uint32_t count = 0u;
+
+    for (auto setIndex : bit::BitMask(setMask)) {
+      setLayouts[count] = layout->getDescriptorSetLayout(setIndex)->getSetLayout();
+      setIndices[count] = setIndex;
+      count += 1u;
+    }
+
+    auto vk = m_device->vkd();
+    const VkDevice device = vk->device();
+
+    VkDescriptorSetAllocateInfo info = { VK_STRUCTURE_TYPE_DESCRIPTOR_SET_ALLOCATE_INFO };
+    info.descriptorPool     = m_pool.second.pool;
+    info.descriptorSetCount = count;
+    info.pSetLayouts        = setLayouts.data();
+
+    VkResult vr = VK_ERROR_OUT_OF_POOL_MEMORY;
+
+    if (likely(info.descriptorPool != VK_NULL_HANDLE))
+      vr = vk->vkAllocateDescriptorSets(device, &info, outSets.data());
+
+    if (unlikely(vr != VK_SUCCESS)) {
+      // Batched vkAllocateDescriptorSets is all-or-nothing; on OOP we
+      // spill to a fresh pool. A batch of <=32 sets always fits in a
+      // freshly-created pool (MaxSets == 1024, see createDescriptorPool).
+      m_pool = getNextPool();
+      info.descriptorPool = m_pool.second.pool;
+
+      vr = vk->vkAllocateDescriptorSets(device, &info, outSets.data());
+
+      if (unlikely(vr != VK_SUCCESS))
+        throw DxvkError(str::format("Failed to allocate descriptor sets: ", vr));
+    }
+
+    m_pool.second.trackingId = trackingId;
+    m_setsAllocated += count;
+
+    for (uint32_t i = 0u; i < count; i++)
+      sets[setIndices[i]] = outSets[i];
   }
 
 
