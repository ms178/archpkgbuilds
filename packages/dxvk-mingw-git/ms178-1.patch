diff --git a/src/dxvk/dxvk_descriptor_pool.cpp b/src/dxvk/dxvk_descriptor_pool.cpp
index 9fb418a..71a6c9c 100644
--- a/src/dxvk/dxvk_descriptor_pool.cpp
+++ b/src/dxvk/dxvk_descriptor_pool.cpp
@@ -1,3 +1,5 @@
+#include <array>
