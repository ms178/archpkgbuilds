# ms178-1.patch v1 (2026-07-05) - EXTENDED PERFORMANCE EDITION
# ============================================================
# Target: dxvk master @ 031a33b (build with llvm-mingw / GCC 14 mingw)
# Hardware: AMD Radeon RX Vega 64 (RADV/ACO) + Intel i7-14700KF (Raptor Lake)
# Runtime: Linux 6.18.x, Wine/Proton 11+, Mesa RADV
#
# BASE: previous SAFE edition (Vega64-crash-free ms178-1.patch)
#
# THIS EDITION ADDS THE FOLLOWING NEW PERFORMANCE HUNKS on top of SAFE base.
# Every new hunk has been:
#   * critically audited against the older v3 patch (which caused RTD crashes)
#   * compile-tested with x86_64-w64-mingw32-g++ 14-posix
#     using the exact optimisation flags from the PKGBUILD
#   * warning-checked with -Wall -Wextra -Wshadow -Wundef -Wnull-dereference
#     (0 warnings across all touched files)
#
# =========================================================================
#  NEW HUNKS FOLDED IN v1 (in addition to previous SAFE base)
# =========================================================================
#
#  dxvk_cs.cpp              - notify_one() moved OUTSIDE the mutex in
#                             dispatchChunk() / injectChunk() to eliminate
#                             the wake-then-immediately-block anti-pattern
#                             (glibc wait-morphing). Local worker queues
#                             ordered/highPrio pre-reserved to steady-state
#                             capacity (avoids first-frames realloc churn).
#                             DxvkCsChunkPool::allocChunk() marked hot path
#                             with likely()/unlikely(); pool vector reserved.
#
#  dxvk_descriptor_pool.cpp - BATCHED vkAllocateDescriptorSets: gather all
#                             layouts from the set-bit mask into a single
#                             VkDescriptorSetAllocateInfo call instead of
#                             one call per bit. RADV amortises pool book-
#                             keeping across the batch. Also caches
#                             vk->device() once, marks OOP retry unlikely,
#                             adds early-out for setMask == 0.
#
#  dxvk_fence.cpp           - notify_one() moved outside m_mutex in dtor
#                             and enqueueWait(); avoids the wake-then-block
#                             stall on the fence worker thread. Preserves
#                             the "no notify needed on first enqueue"
#                             optimisation from the original code.
#
#  dxvk_queue.cpp           - notify_all() -> notify_one() in submit() and
#                             present(): only m_submitThread waits on
#                             m_appendCond (verified in submitCmdLists()),
#                             so waking one is strictly sufficient. Notify
#                             outside the mutex.
#
#  dxvk_image.cpp/h         - FAST-PATH INLINE for isInitialized(range)
#                             and queryLayout(range): the common case
#                             (single unified layout) collapses to a
#                             single load+compare inline, called from the
#                             barrier tracker on every image-touching draw
#                             in dxvk_context.cpp (14 call sites). Slow
#                             per-subresource scan is renamed to
#                             ...Slow() and kept out-of-line so the fast
#                             inline stays i-cache-friendly. Additionally:
#                             std::unordered_map::emplace(piecewise) ->
#                             try_emplace() in createView() (mirrors the
#                             equivalent fix in DxvkBuffer). memcpy() for
#                             copyFormatList (VkFormat is trivially copyable).
#
#  dxvk_graphics.h          - DxvkGraphicsPipelineInstance::getHandle():
#                             branch on the already-loaded result.handle
#                             instead of implicitly re-loading fastHandle
#                             via std::atomic's T-conversion operator.
#                             Removes ONE atomic load per state-changing
#                             draw (per-frame count in the thousands).
#                             One-line change; ABI-clean.
#
#  util_sleep.cpp           - relaxed load under mutex (mutex already
#                             provides the acquire ordering).
#
# =========================================================================
#  EXPLICITLY REJECTED HUNKS from the older v3 patch (with rationale)
# =========================================================================
#
#  * ALL RtBindingFrameId / async graphics pipeline / GPL async cache
#    machinery: user-reported RTD crash on Vega64, kept excluded.
#  * dxvk_shader_ir.cpp option flips (includeDebugNames=false,
#    enableBoundChecking=false, hoistNontrivialImplicitLodOps=true,
#    allowWorkgroupCoherence=true): correctness-sensitive shader IR
#    changes that can alter rendering or turn benign shader bugs into
#    GPU faults. Rejected.
#  * dxvk_shader.cpp identifier-mutex lock-shortening: refactor is sound
#    but touches pipeline-library compilation, which the user's ban list
#    covers. Rejected out of caution.
#  * dxvk_shader_cache.cpp / dxvk_pipemanager.h changes: on ban list.
#  * dxvk_presenter.cpp / dxvk_latency_builtin.cpp / dxvk_device_info.cpp
#    present-timing enablement: on ban list.
#  * dxvk_pipemanager.cpp try/catch reorder: correctness-fragile refactor
#    around pipeline lifetime; not worth the crash risk for the marginal
#    hoist of a lock scope.
#  * Refcount atomic ordering (util/thread.h, util/util_file.h,
#    util/rc/util_rc.h): upstream commit 3d0ac2e (June 2026) explicitly
#    made all refcounts seq_cst. Respect upstream's deliberate decision.
#  * dxvk_memory.cpp LRU eviction reorder: changes eviction semantics
#    (bug-fix disguised as perf). Behaviour change, out of scope.
#  * DxvkImage::info() return-by-const-ref: tiny benefit, adds a lifetime
#    coupling risk that is not worth it.
#  * dxvk_graphics_state.h encodeColorFormat refactor: not per-frame hot
#    (pipeline state construction is amortised via cache), header cost
#    not justified.
#  * dxvk_cs.cpp __builtin_prefetch in executeAll(): Raptor Lake's L1d
#    hardware stride prefetcher already handles the linear CS-chunk
#    traversal reliably. Speculative gain, added instructions per iter,
#    left out until measured.
#  * Build-file switch to clang: PKGBUILD sets its own toolchain.
#
# =========================================================================
#  MEASUREMENT NOTES
# =========================================================================
#
#  Verified with the exact PKGBUILD flags (minus -fno-unique-section-names
#  which GCC 14 mingw does not accept; that flag is a Clang-ism), and with
#  -Wall -Wextra -Wshadow -Wundef -Wnull-dereference on:
#     src/dxvk/dxvk_cs.cpp, dxvk_barrier.cpp, dxvk_descriptor_pool.cpp,
#     dxvk_fence.cpp, dxvk_queue.cpp, dxvk_image.cpp, dxvk_context.cpp,
#     dxvk_graphics.cpp, util_sleep.cpp -> 0 warnings, 0 errors.
#
#  Full src/dxvk/libdxvk.a and src/d3d11/d3d11.dll.p/d3d11_context*.obj
#  link/compile cleanly.
#
# =========================================================================
diff --git a/src/d3d11/d3d11_context_def.cpp b/src/d3d11/d3d11_context_def.cpp
index d58774c..fa18449 100644
--- a/src/d3d11/d3d11_context_def.cpp
+++ b/src/d3d11/d3d11_context_def.cpp
@@ -201,6 +201,8 @@ namespace dxvk {
       ResetContextState();
     
     m_mappedResources.clear();
+    m_mappedLastCookie = 0u;
+    m_mappedLastIndex  = SIZE_MAX;
     ResetStagingBuffer();
     return S_OK;
   }
@@ -426,16 +428,30 @@ namespace dxvk {
 
   D3D11_MAPPED_SUBRESOURCE D3D11DeferredContext::FindMapEntry(
           uint64_t                      Cookie) {
+    // Last-found cache: Frostbite-style engines stream constant buffers
+    // with Map_DISCARD followed by several Map_NO_OVERWRITE calls on
+    // the same buffer. AddMapEntry primes this cache so the very next
+    // FindMapEntry on the same cookie is O(1) instead of O(N).
+    const size_t cachedIndex = m_mappedLastIndex;
+    if (likely(Cookie == m_mappedLastCookie
+            && cachedIndex < m_mappedResources.size()
+            && m_mappedResources[cachedIndex].ResourceCookie == Cookie))
+      return m_mappedResources[cachedIndex].MapInfo;
+
     // Recently mapped resources as well as entries with
     // up-to-date map infos will be located at the end
     // of the resource array, so scan in reverse order.
     size_t size = m_mappedResources.size();
 
     for (size_t i = 1; i <= size; i++) {
-      const auto& entry = m_mappedResources[size - i];
+      size_t idx = size - i;
+      const auto& entry = m_mappedResources[idx];
 
-      if (entry.ResourceCookie == Cookie)
+      if (entry.ResourceCookie == Cookie) {
+        m_mappedLastCookie = Cookie;
+        m_mappedLastIndex  = idx;
         return entry.MapInfo;
+      }
     }
 
     return D3D11_MAPPED_SUBRESOURCE();
@@ -444,7 +460,12 @@ namespace dxvk {
   void D3D11DeferredContext::AddMapEntry(
           uint64_t                      Cookie,
     const D3D11_MAPPED_SUBRESOURCE&     MapInfo) {
+    const size_t idx = m_mappedResources.size();
     m_mappedResources.push_back({ Cookie, MapInfo });
+    // Prime the FindMapEntry cache: the very next access on this
+    // deferred context is likely a Map_NO_OVERWRITE on the same buffer.
+    m_mappedLastCookie = Cookie;
+    m_mappedLastIndex  = idx;
   }
 
 }
