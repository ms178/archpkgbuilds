+    VkResult vr = vk->vkAllocateDescriptorSets(device, &info, &set);
+
+    if (unlikely(vr != VK_SUCCESS))
+      throw DxvkError(str::format("Failed to allocate descriptor set: ", vr));
+
+    m_pool.second.trackingId = trackingId;
     m_setsAllocated++;
     return set;
   }
