diff --git a/subprojects/dxbc-spirv/tests/test_vega64.cpp b/subprojects/dxbc-spirv/tests/test_vega64.cpp
new file mode 100644
index 0000000..014ff3d
--- /dev/null
+++ b/subprojects/dxbc-spirv/tests/test_vega64.cpp
@@ -0,0 +1,295 @@
+// ms178 Vega 64 / Raptor Lake performance-patch verification suite.
+//
+// This file exists to give the ms178 dxvk patch a permanent, in-tree
+// regression test that is run as part of `test_dxbc_spv` on every build.
+// It specifically targets the three compiler-throughput optimizations
+// applied in this patch set:
+//
+//   1. Container<T>::LayerBits reduced from 12 to 8 (ir_container.h).
+//   2. small_vector<T,...> memcpy fast paths for trivially copyable T
+//      (util_small_vector.h: reserve()/move()/copy()).
+//   3. Reserve() hints for CsePass::m_defs and RemoveUnusedPass::run()'s
+//      local vector, sized from Builder::getDefCount().
+//
+// Every check here is a *correctness* check (not just "does it compile"):
+// each one independently re-derives the expected result using a path that
+// does not depend on the optimization being tested, so a regression in
+// the memcpy fast path, in Container's layer indexing at 2^8-element
+// boundaries, or in the various reserve() hints becoming stale would be
+// caught by a mismatch here, not just by chance.
+//
+// A wall-clock A/B micro-benchmark is included at the end purely for
+// human-readable telemetry (printed to stderr); it does not affect the
+// pass/fail result of the test binary and is intentionally excluded from
+// g_testState's pass/fail bookkeeping for that reason - wall-clock timing
+// on a shared CI/dev machine is not a reliable correctness oracle.
+#include <chrono>
+#include <cstring>
+#include <iostream>
+#include <vector>
+
+#include "./test_common.h"
+
+#include "../ir/ir_builder.h"
+#include "../ir/ir_legalize.h"
+#include "../ir/ir_container.h"
+
+#include "../spirv/spirv_builder.h"
+#include "../spirv/spirv_mapping.h"
+
+#include "../util/util_small_vector.h"
+
+namespace dxbc_spv::tests {
+
+using namespace dxbc_spv::util;
+
+namespace {
+
+// ---------------------------------------------------------------------
+// 1. small_vector memcpy fast-path correctness
+// ---------------------------------------------------------------------
+//
+// BasicType and Operand (the two trivially-copyable payload types that
+// actually flow through the optimized reserve()/move()/copy() paths in
+// production) are exercised directly here, at every size that matters:
+// empty, partially filled while still embedded, exactly at the embedded/
+// heap boundary, and safely past it - since pick_capacity() doubles
+// capacity, "past the boundary" needs at least EmbeddedCapacity+1
+// elements to force a heap allocation.
+
+void testSmallVectorTriviallyCopyableGrowCorrectness() {
+  using ir::BasicType;
+  using ir::ScalarType;
+
+  constexpr size_t N = small_vector<BasicType, 4>::EmbeddedCapacity;
+  static_assert(N == 4, "test assumes embedded capacity of 4");
+
+  for (size_t count = 0; count <= 2u * N + 1u; count++) {
+    small_vector<BasicType, N> v;
+
+    for (size_t i = 0; i < count; i++)
+      v.push_back(BasicType(ScalarType::eF32, uint32_t(1u + (i % 4u))));
+
+    ok(v.size() == count);
+
+    for (size_t i = 0; i < count; i++) {
+      auto expected = BasicType(ScalarType::eF32, uint32_t(1u + (i % 4u)));
+      ok(v[i].getBaseType() == expected.getBaseType());
+      ok(v[i].getVectorSize() == expected.getVectorSize());
+    }
+
+    // Copy-construct: must reproduce every element bit-for-bit,
+    // regardless of whether the memcpy fast path or the fallback
+    // per-element path is taken (embedded vs. heap-backed source).
+    small_vector<BasicType, N> copy(v);
+    ok(copy.size() == v.size());
+    for (size_t i = 0; i < count; i++)
+      ok(std::memcmp(&copy[i], &v[i], sizeof(BasicType)) == 0);
+
+    // Move-construct from a fresh duplicate: the moved-from vector must
+    // end up empty, and the destination must exactly match what the
+    // source had before the move.
+    small_vector<BasicType, N> moveSrc(v);
+    small_vector<BasicType, N> moveDst(std::move(moveSrc));
+    ok(moveSrc.size() == 0u);
+    ok(moveDst.size() == count);
+    for (size_t i = 0; i < count; i++)
+      ok(std::memcmp(&moveDst[i], &v[i], sizeof(BasicType)) == 0);
+
+    // Copy-assign onto a vector that already holds data forces copy()'s
+    // clear()-then-copy() path.
+    small_vector<BasicType, N> assignDst;
+    assignDst.push_back(BasicType(ScalarType::eU32, 1u));
+    assignDst = v;
+    ok(assignDst.size() == count);
+    for (size_t i = 0; i < count; i++)
+      ok(std::memcmp(&assignDst[i], &v[i], sizeof(BasicType)) == 0);
+  }
+}
+
+
+void testSmallVectorOperandGrowCorrectness() {
+  using ir::Operand;
+  using ir::SsaDef;
+
+  constexpr size_t N = small_vector<Operand, 8>::EmbeddedCapacity;
+
+  for (size_t count = 0; count <= 2u * N + 1u; count++) {
+    small_vector<Operand, N> v;
+
+    for (size_t i = 0; i < count; i++)
+      v.push_back(Operand(SsaDef(uint32_t(i + 1u))));
+
+    small_vector<Operand, N> copy(v);
+    ok(copy.size() == count);
+
+    for (size_t i = 0; i < count; i++) {
+      ok(uint64_t(v[i]) == uint64_t(copy[i]));
+      ok(uint64_t(v[i]) == uint64_t(i + 1u));
+    }
+
+    // Cross-N copy: constructing from a small_vector with a *different*
+    // embedded capacity must still produce identical contents. This
+    // specifically exercises the templated copy<N_, Allocator_>() and
+    // move<N_, Allocator_>() overloads, which are separate code paths
+    // from the same-type copy()/move() used above.
+    small_vector<Operand, N * 2u> widerCopy(v);
+    ok(widerCopy.size() == count);
+    for (size_t i = 0; i < count; i++)
+      ok(uint64_t(widerCopy[i]) == uint64_t(v[i]));
+  }
+}
+
+
+// ---------------------------------------------------------------------
+// 2. Container<T> correctness around the 2^8 layer boundary
+// ---------------------------------------------------------------------
+//
+// LayerBits was reduced from 12 to 8, i.e. layers now hold 256 elements
+// instead of 4096. The most likely regression from getting the shift/
+// mask arithmetic wrong is silent data corruption exactly at a layer
+// boundary (index 255/256, 511/512, etc.), so this test writes a unique,
+// derivable value into a few thousand consecutive SsaDefs (spanning many
+// layer boundaries at the new, smaller layer size) and reads every one
+// of them back.
+
+void testContainerLayerBoundaryCorrectness() {
+  struct Payload {
+    uint32_t tag = 0xDEADBEEFu;
+    uint64_t value = 0u;
+  };
+
+  ir::Container<Payload> container;
+
+  constexpr uint32_t kCount = 4200u; // > 16 layers at 2^8 elements/layer
+
+  for (uint32_t i = 1u; i <= kCount; i++) {
+    ir::SsaDef def(i);
+    container.ensure(def);
+    container.at(def).value = uint64_t(i) * 0x9E3779B97F4A7C15ull;
+  }
+
+  ok(container.getMaxValidDef().getId() == kCount);
+
+  for (uint32_t i = 1u; i <= kCount; i++) {
+    ir::SsaDef def(i);
+    ok(container.at(def).tag == 0xDEADBEEFu);
+    ok(container.at(def).value == uint64_t(i) * 0x9E3779B97F4A7C15ull);
+  }
+
+  // Also verify the const operator[] fallback for an out-of-range def
+  // returns the (default-constructed) null-def slot rather than
+  // reading garbage or crashing.
+  const auto& constContainer = container;
+  ir::SsaDef farOutOfRange(kCount + 100000u);
+  ok(constContainer[farOutOfRange].tag == 0u);
+}
+
+
+// ---------------------------------------------------------------------
+// 3. End-to-end shader compile determinism after all three optimizations
+// ---------------------------------------------------------------------
+//
+// Compiles the same small shader twice via completely independent
+// Builder/CompileOptions instances and checks that the resulting SPIR-V
+// binaries are byte-for-byte identical. This is a coarse but effective
+// safety net: legalizeIr()'s CsePass and RemoveUnusedPass reserve()
+// hints, and the Container<T> layer resize, must not introduce any
+// order-dependence or uninitialized-read-driven nondeterminism.
+
+ir::SsaDef setupSimpleFunction(ir::Builder& builder, ir::ShaderStage stage) {
+  auto fn = builder.add(ir::Op::Function(ir::Type()));
+  builder.add(ir::Op::FunctionEnd());
+  auto entryPoint = builder.add(ir::Op::EntryPoint(fn, stage));
+  builder.add(ir::Op::DebugName(fn, "main"));
+  builder.setCursor(fn);
+  return entryPoint;
+}
+
+std::vector<char> compileSimpleComputeShader() {
+  ir::Builder builder;
+  auto entryPoint = setupSimpleFunction(builder, ir::ShaderStage::eCompute);
+  builder.add(ir::Op::SetCsWorkgroupSize(entryPoint, 8u, 8u, 1u));
+
+  auto bufType = ir::Type(ir::ScalarType::eF32).addArrayDimension(4u).addArrayDimension(0u);
+  auto srv = builder.add(ir::Op::DclSrv(bufType, entryPoint, 0u, 0u, 1u, ir::ResourceKind::eBufferStructured));
+  auto uav = builder.add(ir::Op::DclUav(bufType, entryPoint, 0u, 0u, 1u, ir::ResourceKind::eBufferStructured, ir::UavFlag::eWriteOnly));
+
+  auto srvDesc = builder.add(ir::Op::DescriptorLoad(ir::ScalarType::eSrv, srv, builder.makeConstant(0u)));
+  auto uavDesc = builder.add(ir::Op::DescriptorLoad(ir::ScalarType::eUav, uav, builder.makeConstant(0u)));
+
+  auto addr = builder.add(ir::Op::CompositeConstruct(ir::Type(ir::ScalarType::eU32, 2u), builder.makeConstant(0u), builder.makeConstant(0u)));
+  auto value = builder.add(ir::Op::BufferLoad(ir::Type(ir::ScalarType::eF32, 4u), srvDesc, addr, 4u));
+
+  auto doubled = builder.add(ir::Op::FAdd(ir::Type(ir::ScalarType::eF32, 4u), value, value));
+  builder.add(ir::Op::BufferStore(uavDesc, addr, doubled, 4u));
+
+  builder.add(ir::Op::Return());
+
+  ir::CompileOptions options = { };
+  options.cseOptions.relocateDescriptorLoad = true;
+  options.descriptorIndexing.optimizeDescriptorIndexing = true;
+  ir::legalizeIr(builder, options);
+
+  spirv::BasicResourceMapping mapping;
+  spirv::SpirvBuilder::Options spvOptions = { };
+  spvOptions.includeDebugNames = false;
+
+  spirv::SpirvBuilder spvBuilder(builder, mapping, spvOptions);
+  spvBuilder.buildSpirvBinary();
+
+  size_t size = 0u;
+  spvBuilder.getSpirvBinary(size, nullptr);
+
+  std::vector<char> data(size);
+  spvBuilder.getSpirvBinary(size, data.data());
+  return data;
+}
+
+
+void testShaderCompileDeterminism() {
+  auto a = compileSimpleComputeShader();
+  auto b = compileSimpleComputeShader();
+
+  ok(!a.empty());
+  ok(a.size() == b.size());
+  ok(a == b);
+}
+
+
+// ---------------------------------------------------------------------
+// 4. Wall-clock telemetry (informational only, not part of pass/fail)
+// ---------------------------------------------------------------------
+
+void runCompileThroughputTelemetry() {
+  std::cerr << "=== ms178 Vega 64 / Raptor Lake compile-throughput telemetry ===" << std::endl;
+
+  constexpr int kIterations = 2000;
+
+  auto start = std::chrono::high_resolution_clock::now();
+  for (int i = 0; i < kIterations; i++)
+    compileSimpleComputeShader();
+  auto end = std::chrono::high_resolution_clock::now();
+
+  auto totalUs = std::chrono::duration_cast<std::chrono::microseconds>(end - start).count();
+
+  std::cerr << kIterations << " compute-shader compiles (legalizeIr + SPIR-V lowering) took "
+            << totalUs << " us total (" << (double(totalUs) / kIterations) << " us/compile)."
+            << std::endl;
+  std::cerr << "Note: this number is informational only; it depends heavily on host CPU, "
+            << "compiler, and load, and is not used to determine pass/fail." << std::endl;
+}
+
+}
+
+
+void runVega64Benchmarks() {
+  RUN_TEST(testSmallVectorTriviallyCopyableGrowCorrectness);
+  RUN_TEST(testSmallVectorOperandGrowCorrectness);
+  RUN_TEST(testContainerLayerBoundaryCorrectness);
+  RUN_TEST(testShaderCompileDeterminism);
+
+  runCompileThroughputTelemetry();
+}
+
+}
