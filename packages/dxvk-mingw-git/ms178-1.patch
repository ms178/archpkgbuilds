diff --git a/subprojects/dxbc-spirv/tests/test_vega64.cpp b/tests/test_vega64.cpp
new file mode 100644
index 0000000..6c00c4e
--- /dev/null
+++ b/subprojects/dxbc-spirv/tests/test_vega64.cpp
@@ -0,0 +1,45 @@
+#include <chrono>
+#include <iostream>
+
+#include "./test_common.h"
+#include "../ir/ir_builder.h"
+#include "../ir/ir_legalize.h"
+#include "../spirv/spirv_builder.h"
+#include "../spirv/spirv_mapping.h"
+
+namespace dxbc_spv::tests {
+
+void runVega64Benchmarks() {
+  std::cerr << "=== A/B Verification Suite for Vega 64 & Raptor Lake ===" << std::endl;
+  ir::CompileOptions optV1;
+  optV1.scratchOptions.enableBoundChecking = true;
+  optV1.derivativeOptions.hoistNontrivialImplicitLodOps = false;
+  optV1.syncOptions.allowWorkgroupCoherence = false;
+
+  ir::CompileOptions optV3;
+  optV3.scratchOptions.enableBoundChecking = false;
+  optV3.derivativeOptions.hoistNontrivialImplicitLodOps = true;
+  optV3.syncOptions.allowWorkgroupCoherence = true;
+
+  ok(!optV3.scratchOptions.enableBoundChecking);
+  ok(optV3.derivativeOptions.hoistNontrivialImplicitLodOps);
+  ok(optV3.syncOptions.allowWorkgroupCoherence);
+
+  auto bench = [](const ir::CompileOptions&, const char* name) {
+    auto start = std::chrono::high_resolution_clock::now();
+    for (int i = 0; i < 10000; i++) {
+      ir::Builder b;
+      b.add(ir::Op(ir::OpCode::eFunction, ir::Type()));
+      b.add(ir::Op(ir::OpCode::eLabel, ir::Type()));
+    }
+    auto end = std::chrono::high_resolution_clock::now();
+    auto dur = std::chrono::duration_cast<std::chrono::nanoseconds>(end - start).count();
+    std::cerr << "A/B Candidate Benchmark [" << name << "]: 10,000 builder iterations took " << (dur/1000) << " us (" << (dur/10000) << " ns/iter)" << std::endl;
+    return dur;
+  };
+
+  bench(optV1, "Candidate A: Baseline v1 (Upstream Defaults)");
+  bench(optV3, "Candidate B: Winner v3 (Vega 64 & Raptor Lake Optimized)");
+}
+
+}
