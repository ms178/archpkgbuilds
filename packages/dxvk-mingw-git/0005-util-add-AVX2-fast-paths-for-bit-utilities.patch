--- a/src/util/sync/sync_spinlock.h
+++ b/src/util/sync/sync_spinlock.h
@@ -63,7 +63,7 @@ namespace dxvk::sync {
     }
     
     bool try_lock() {
-      return likely(!m_lock.load())
