diff --git a/src/util/sync/sync_ticketlock.h b/src/util/sync/sync_ticketlock.h
index 1c47f83..999b9fb 100644
--- a/src/util/sync/sync_ticketlock.h
+++ b/src/util/sync/sync_ticketlock.h
@@ -3,6 +3,7 @@
 #include <atomic>
 
 #include "../thread.h"
+#include "../util_bit.h"
 
 namespace dxvk::sync {
   
@@ -19,14 +20,19 @@ namespace dxvk::sync {
   public:
 
     void lock() {
-      uint32_t ticket = m_counter.fetch_add(1);
-
-      while (m_serving.load(std::memory_order_acquire) != ticket)
-        continue;
+      uint32_t ticket = m_counter.fetch_add(1u, std::memory_order_relaxed);
+
+      while (m_serving.load(std::memory_order_acquire) != ticket) {
+        #if defined(DXVK_ARCH_X86)
+        _mm_pause();
+        #elif defined(DXVK_ARCH_ARM64)
+        __asm__ __volatile__ ("yield");
+        #endif
+      }
     }
 
     void unlock() {
-      uint32_t serveNext = m_serving.load() + 1;
+      uint32_t serveNext = m_serving.load(std::memory_order_relaxed) + 1u;
       m_serving.store(serveNext, std::memory_order_release);
     }
 
diff --git a/src/util/thread.h b/src/util/thread.h
