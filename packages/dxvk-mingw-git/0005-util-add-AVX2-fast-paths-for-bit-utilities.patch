diff --git a/src/util/util_string.h b/src/util/util_string.h
index ffae983..5c22eea 100644
--- a/src/util/util_string.h
+++ b/src/util/util_string.h
@@ -242,9 +242,12 @@ namespace dxvk::str {
 
   /** Compares ASCII characters in a case-insensitive way */
   inline bool compareCharsCaseInsensitive(char a, char b) {
-    if (a >= 'A' && a <= 'Z') a += 'a' - 'A';
-    if (b >= 'A' && b <= 'Z') b += 'a' - 'A';
-    return a == b;
+    uint32_t ua = uint8_t(a);
+    uint32_t ub = uint8_t(b);
+
+    ua |= (ua - uint32_t('A')) <= uint32_t('Z' - 'A') ? 0x20u : 0u;
+    ub |= (ub - uint32_t('A')) <= uint32_t('Z' - 'A') ? 0x20u : 0u;
+    return ua == ub;
   }
 
   /** Compare ASCII string in a case-insensitive way */
@@ -259,9 +262,9 @@ namespace dxvk::str {
 
   /** Converts ASCII string to lower case */
