 namespace dxvk::bit {
 
+#if defined(DXVK_ARCH_X86_64) && (defined(__GNUC__) || defined(__clang__)) && !defined(__e2k__)
+  #define DXVK_BIT_HAS_AVX2_TARGET 1
+#else
+  #define DXVK_BIT_HAS_AVX2_TARGET 0
+#endif
+
+#if DXVK_BIT_HAS_AVX2_TARGET
+  inline bool supportsAvx2() {
+    static const bool supported = [] {
+      __builtin_cpu_init();
+      return __builtin_cpu_supports("avx2") != 0;
+    }();
+
+    return supported;
+  }
+
+
+  __attribute__((target("avx2")))
+  inline bool bcmpeqAvx2(const void* a, const void* b, size_t size) {
+    auto ai = reinterpret_cast<const char*>(a);
+    auto bi = reinterpret_cast<const char*>(b);
+
+    size_t index = 0u;
+
+    while (index + 32u <= size) {
+      const __m256i av = _mm256_loadu_si256(reinterpret_cast<const __m256i*>(ai + index));
+      const __m256i bv = _mm256_loadu_si256(reinterpret_cast<const __m256i*>(bi + index));
+      const __m256i eq = _mm256_cmpeq_epi8(av, bv);
+
+      if (_mm256_movemask_epi8(eq) != -1) {
+        _mm256_zeroupper();
+        return false;
+      }
+
+      index += 32u;
+    }
+
+    while (index + 16u <= size) {
+      const __m128i av = _mm_loadu_si128(reinterpret_cast<const __m128i*>(ai + index));
+      const __m128i bv = _mm_loadu_si128(reinterpret_cast<const __m128i*>(bi + index));
+      const __m128i eq = _mm_cmpeq_epi8(av, bv);
+
+      if (_mm_movemask_epi8(eq) != 0xffff) {
+        _mm256_zeroupper();
+        return false;
+      }
+
+      index += 16u;
+    }
+
+    bool result = true;
+
+    while (index < size) {
+      result &= ai[index] == bi[index];
+      index += 1u;
+    }
+
+    _mm256_zeroupper();
+    return result;
+  }
+
+
+  __attribute__((target("avx2")))
+  inline uint32_t bcndcpyAvx2(void* dstData, const void* srcData, uint32_t count) {
+    auto srcPtr = reinterpret_cast<const char*>(srcData);
+    auto dstPtr = reinterpret_cast<      char*>(dstData);
+
+    uint32_t mask = 0u;
+    uint32_t index = 0u;
+
+    while (index + 8u <= count) {
+      auto src = reinterpret_cast<const __m256i*>(srcPtr + index * sizeof(uint32_t));
+      auto dst = reinterpret_cast<      __m256i*>(dstPtr + index * sizeof(uint32_t));
+
+      const __m256i srcValue = _mm256_loadu_si256(src);
+      const __m256i dstValue = _mm256_loadu_si256(dst);
+      const __m256i eqMask = _mm256_cmpeq_epi32(dstValue, srcValue);
+
+      mask |= uint32_t(_mm256_movemask_ps(_mm256_castsi256_ps(eqMask)) ^ 0xffu) << index;
+      _mm256_storeu_si256(dst, srcValue);
+
+      index += 8u;
+    }
+
+    while (index + 4u <= count) {
+      auto src = reinterpret_cast<const __m128i*>(srcPtr + index * sizeof(uint32_t));
+      auto dst = reinterpret_cast<      __m128i*>(dstPtr + index * sizeof(uint32_t));
+
+      const __m128i srcValue = _mm_loadu_si128(src);
+      const __m128i dstValue = _mm_loadu_si128(dst);
+      const __m128i eqMask = _mm_cmpeq_epi32(dstValue, srcValue);
+
+      mask |= uint32_t(_mm_movemask_ps(_mm_castsi128_ps(eqMask)) ^ 0xfu) << index;
+      _mm_storeu_si128(dst, srcValue);
+
+      index += 4u;
+    }
+
+    while (index < count) {
+      auto src = srcPtr + index * sizeof(uint32_t);
+      auto dst = dstPtr + index * sizeof(uint32_t);
+
+      bool dirty = std::memcmp(dst, src, sizeof(uint32_t));
+      mask |= dirty ? 1u << index : 0u;
+
+      std::memcpy(dst, src, sizeof(uint32_t));
+      index += 1u;
+    }
+
+    _mm256_zeroupper();
+    return mask;
+  }
+#endif
+
+
   template<typename T, typename J>
   T cast(const J& src) {
     static_assert(sizeof(T) == sizeof(J));
@@ -265,6 +380,46 @@ namespace dxvk::bit {
   template<typename T>
   bool bcmpeq(const T* a, const T* b) {
     static_assert(alignof(T) >= 16);
+
+    #if defined(__AVX2__) && DXVK_BIT_HAS_AVX2_TARGET
+    if constexpr (sizeof(T) >= 32u) {
+      auto ai8 = reinterpret_cast<const char*>(a);
+      auto bi8 = reinterpret_cast<const char*>(b);
+
+      size_t byteIndex = 0u;
+
+      for (; byteIndex + 32u <= sizeof(T); byteIndex += 32u) {
+        const __m256i av = _mm256_loadu_si256(reinterpret_cast<const __m256i*>(ai8 + byteIndex));
+        const __m256i bv = _mm256_loadu_si256(reinterpret_cast<const __m256i*>(bi8 + byteIndex));
+        const __m256i eq = _mm256_cmpeq_epi8(av, bv);
+
+        if (_mm256_movemask_epi8(eq) != -1)
+          return false;
+      }
+
+      for (; byteIndex + 16u <= sizeof(T); byteIndex += 16u) {
+        const __m128i av = _mm_loadu_si128(reinterpret_cast<const __m128i*>(ai8 + byteIndex));
+        const __m128i bv = _mm_loadu_si128(reinterpret_cast<const __m128i*>(bi8 + byteIndex));
+        const __m128i eq = _mm_cmpeq_epi8(av, bv);
+
+        if (_mm_movemask_epi8(eq) != 0xffff)
+          return false;
+      }
+
+      for (; byteIndex < sizeof(T); byteIndex++) {
+        if (ai8[byteIndex] != bi8[byteIndex])
+          return false;
+      }
+
+      return true;
+    }
+    #elif DXVK_BIT_HAS_AVX2_TARGET
+    if constexpr (sizeof(T) >= 32u) {
+      if (likely(supportsAvx2()))
+        return bcmpeqAvx2(a, b, sizeof(T));
+    }
+    #endif
+
     #if defined(DXVK_ARCH_X86) && (defined(__GNUC__) || defined(__clang__) || defined(_MSC_VER))
     auto ai = reinterpret_cast<const __m128i*>(a);
     auto bi = reinterpret_cast<const __m128i*>(b);
@@ -317,12 +472,33 @@ namespace dxvk::bit {
    * \returns Mask of dwords actually changed and copied
    */
   inline uint32_t bcndcpy(void* dstData, const void* srcData, uint32_t count) {
+    #if !defined(__AVX2__) && DXVK_BIT_HAS_AVX2_TARGET
+    if (count >= 8u && likely(supportsAvx2()))
+      return bcndcpyAvx2(dstData, srcData, count);
+    #endif
+
     auto srcPtr = reinterpret_cast<const char*>(srcData);
     auto dstPtr = reinterpret_cast<      char*>(dstData);
 
     uint32_t mask = 0u;
     uint32_t index = 0u;
 
+    #if defined(__AVX2__) && DXVK_BIT_HAS_AVX2_TARGET
+    while (index + 8u <= count) {
+      auto src = reinterpret_cast<const __m256i*>(srcPtr + index * sizeof(uint32_t));
+      auto dst = reinterpret_cast<      __m256i*>(dstPtr + index * sizeof(uint32_t));
+
+      const __m256i srcValue = _mm256_loadu_si256(src);
+      const __m256i dstValue = _mm256_loadu_si256(dst);
+      const __m256i eqMask = _mm256_cmpeq_epi32(dstValue, srcValue);
+
+      mask |= uint32_t(_mm256_movemask_ps(_mm256_castsi256_ps(eqMask)) ^ 0xffu) << index;
+      _mm256_storeu_si256(dst, srcValue);
+
+      index += 8u;
+    }
+    #endif
+
     #if defined(DXVK_ARCH_X86) && (defined(__GNUC__) || defined(__clang__) || defined(_MSC_VER))
     while (index + 4u <= count) {
       auto src = reinterpret_cast<const __m128i*>(srcPtr + index * sizeof(uint32_t));
