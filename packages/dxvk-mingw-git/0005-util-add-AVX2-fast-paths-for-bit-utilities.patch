diff --git a/src/util/rc/util_rc.h b/src/util/rc/util_rc.h
index b92cf00..ea974a2 100644
--- a/src/util/rc/util_rc.h
+++ b/src/util/rc/util_rc.h
@@ -18,7 +18,7 @@ namespace dxvk {
      * \returns New reference count
      */
     force_inline uint32_t incRef() {
-      return ++m_refCount;
+      return m_refCount.fetch_add(1u, std::memory_order_relaxed) + 1u;
     }
     
     /**
@@ -26,7 +26,12 @@ namespace dxvk {
      * \returns New reference count
      */
     force_inline uint32_t decRef() {
-      return --m_refCount;
+      const uint32_t refCount = m_refCount.fetch_sub(1u, std::memory_order_release) - 1u;
+
+      if (unlikely(!refCount))
+        std::atomic_thread_fence(std::memory_order_acquire);
+
+      return refCount;
     }
     
   private:
diff --git a/src/util/sync/sync_signal.h b/src/util/sync/sync_signal.h
index e463610..c7f892f 100644
--- a/src/util/sync/sync_signal.h
+++ b/src/util/sync/sync_signal.h
@@ -101,8 +101,11 @@ namespace dxvk::sync {
     }
 
     void signal(uint64_t value) {
-      std::unique_lock<dxvk::mutex> lock(m_mutex);
-      m_value.store(value, std::memory_order_release);
+      {
+        std::unique_lock<dxvk::mutex> lock(m_mutex);
+        m_value.store(value, std::memory_order_release);
+      }
+
       m_cond.notify_all();
     }
     
@@ -146,18 +149,26 @@ namespace dxvk::sync {
     }
 
     void signal(uint64_t value) {
-      std::unique_lock<dxvk::mutex> lock(m_mutex);
-      m_value.store(value, std::memory_order_release);
-      m_cond.notify_all();
-
-      for (auto i = m_callbacks.begin(); i != m_callbacks.end(); ) {
-        if (value >= i->first) {
-          i->second();
-          i = m_callbacks.erase(i);
-        } else {
-          i++;
+      std::list<std::function<void ()>> callbacks;
+
+      {
+        std::unique_lock<dxvk::mutex> lock(m_mutex);
+        m_value.store(value, std::memory_order_release);
+
+        for (auto i = m_callbacks.begin(); i != m_callbacks.end(); ) {
+          if (value >= i->first) {
+            callbacks.push_back(std::move(i->second));
+            i = m_callbacks.erase(i);
+          } else {
+            i++;
+          }
         }
       }
+
+      m_cond.notify_all();
+
+      for (auto& callback : callbacks)
+        callback();
     }
 
     void wait(uint64_t value) {
diff --git a/src/util/sync/sync_spinlock.h b/src/util/sync/sync_spinlock.h
