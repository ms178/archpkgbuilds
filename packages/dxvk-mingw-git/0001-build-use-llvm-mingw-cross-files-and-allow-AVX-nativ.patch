From d5df60298aab49199a53447dabd63e525c4c3c9d Mon Sep 17 00:00:00 2001
From: Arena Agent <agent@example.invalid>
Date: Wed, 17 Jun 2026 09:45:47 +0000
Subject: [PATCH 1/3] build: use llvm-mingw cross files and allow AVX native
 builds

---
 build-win32.txt     | 10 ++++++++--
 build-win64.txt     | 10 ++++++++--
 src/util/util_bit.h |  8 +++++---
 3 files changed, 21 insertions(+), 7 deletions(-)

diff --git a/build-win32.txt b/build-win32.txt
index 40e9d47..d8e76a1 100644
--- a/build-win32.txt
+++ b/build-win32.txt
@@ -1,10 +1,16 @@
 [binaries]
-c = 'i686-w64-mingw32-gcc'
-cpp = 'i686-w64-mingw32-g++'
+c = 'i686-w64-mingw32-clang'
+cpp = 'i686-w64-mingw32-clang++'
 ar = 'i686-w64-mingw32-ar'
 strip = 'i686-w64-mingw32-strip'
 windres = 'i686-w64-mingw32-windres'
 
+[built-in options]
+c_args = [@CARGS@]
+cpp_args = [@CXXARGS@]
+c_link_args = [@LDARGS@]
+cpp_link_args = [@LDARGS@]
+
 [properties]
 needs_exe_wrapper = true
 
diff --git a/build-win64.txt b/build-win64.txt
index 8eb1b29..ef76f55 100644
--- a/build-win64.txt
+++ b/build-win64.txt
@@ -1,10 +1,16 @@
 [binaries]
-c = 'x86_64-w64-mingw32-gcc'
-cpp = 'x86_64-w64-mingw32-g++'
+c = 'x86_64-w64-mingw32-clang'
+cpp = 'x86_64-w64-mingw32-clang++'
 ar = 'x86_64-w64-mingw32-ar'
 strip = 'x86_64-w64-mingw32-strip'
 windres = 'x86_64-w64-mingw32-windres'
 
+[built-in options]
+c_args = [@CARGS@]
+cpp_args = [@CXXARGS@]
+c_link_args = [@LDARGS@]
+cpp_link_args = [@LDARGS@]
+
 [properties]
 needs_exe_wrapper = true
 
diff --git a/src/util/util_bit.h b/src/util/util_bit.h
index 11e20d1..0af7d28 100644
--- a/src/util/util_bit.h
+++ b/src/util/util_bit.h
@@ -12,9 +12,11 @@
 
 #ifdef DXVK_ARCH_X86
   #ifndef _MSC_VER
-    #if defined(_WIN32) && (defined(__AVX__) || defined(__AVX2__))
-      #error "AVX-enabled builds not supported due to stack alignment issues."
-    #endif
+    // Allow llvm-mingw x86-64-v3 and explicit -march=native builds.
+    // Older Wine versions had 32-bit AVX stack-alignment issues, but the
+    // package cross file adds -mstackrealign for i686 and the target runtime
+    // is Wine/Proton 11+, so rejecting AVX at preprocessing time breaks the
+    // supported toolchain without adding runtime safety.
     #if defined(__WINE__) && defined(__clang__)
       #pragma push_macro("_WIN32")
       #undef _WIN32
-- 
2.47.3

