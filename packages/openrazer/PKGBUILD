pkgbase=openrazer
pkgname=(
  python-openrazer
  openrazer-daemon
  openrazer-driver-dkms
  openrazer-meta
)
pkgver=3.12.0
pkgrel=9
pkgdesc='Community-led effort to support Razer peripherals on Linux'
arch=('any')
url='https://openrazer.github.io'
license=('GPL-2.0-or-later')

makedepends=(
  python
  python-build
  python-installer
  python-setuptools
  python-wheel
)

source=(
  "https://github.com/openrazer/openrazer/releases/download/v${pkgver}/openrazer-${pkgver}.tar.xz"
)
sha256sums=('387b4a0bcc196ebbb3694b79d90abee19351774a1162d8250880b69d8b1a3023')

_prepare_source_tree() {
  cd "$srcdir/${pkgbase}-${pkgver}"

  find . -type d -name '__pycache__' -prune -exec rm -rf {} + 2>/dev/null || true
  find . -type f \( -name '*.pyc' -o -name '*.pyo' \) -delete 2>/dev/null || true
  rm -rf build dist ./*.egg-info daemon/build daemon/dist daemon/*.egg-info 2>/dev/null || true
}

_find_python_project_dir() {
  local root="$1"
  local module="$2"
  local outvar="$3"

  local best=''
  local best_len=0
  local file dir len

  while IFS= read -r -d '' file; do
    dir=${file%/*}
    [[ -d "$dir/$module" || -f "$dir/${module}.py" ]] || continue
    len=${#dir}
    if [[ -z "$best" || $len -lt $best_len ]]; then
      best="$dir"
      best_len=$len
    fi
  done < <(find "$root" -type f \( -name setup.py -o -name pyproject.toml \) -print0 2>/dev/null)

  if [[ -z "$best" ]]; then
    echo "ERROR: Could not find Python project directory for module '$module' under $root" >&2
    return 1
  fi

  printf -v "$outvar" '%s' "$best"
}

_patch_openrazer_group() {
  cd "$srcdir/${pkgbase}-${pkgver}"

  sed -i \
    -e 's/_check_plugdev_group/_check_openrazer_group/g' \
    -e 's/plugdev/openrazer/g' \
    -e 's/and then reboot!/and then log out and back in!/g' \
    daemon/openrazer_daemon/daemon.py \
    install_files/udev/99-razer.rules \
    install_files/udev/razer_mount
}

_patch_python_metadata() {
  local root="$srcdir/${pkgbase}-${pkgver}"
  local file

  while IFS= read -r -d '' file; do
    sed -i \
      -e 's/GPLv2+/GPL-2.0-or-later/g' \
      -e 's/GPL-2.0+/GPL-2.0-or-later/g' \
      -e '/License :: /d' \
      "$file"
  done < <(find "$root" -type f \( -name setup.py -o -name setup.cfg -o -name pyproject.toml \) -print0 2>/dev/null)
}

_patch_daemon_makefile_install() {
  cd "$srcdir/${pkgbase}-${pkgver}"

  [[ -f daemon/Makefile ]] || return 0

  # Keep upstream daemon file installation logic, but strip the deprecated
  # setup.py install invocation. Python modules are installed from wheels instead.
  sed -i '/setup\.py install/d' daemon/Makefile
}

_patch_dkms_aggressive_flags() {
  cd "$srcdir/${pkgbase}-${pkgver}"

  [[ -f driver/dkms.conf ]] || return 0

  # Keep the aggressive march=native idea, but inject it into upstream MAKE[0]
  # instead of replacing upstream logic wholesale.
  if grep -q '^MAKE\[0\]="make ' driver/dkms.conf; then
    sed -i \
      "s|^MAKE\\[0\\]=\"make |MAKE[0]=\"make -j\$(nproc) KCFLAGS='-O3 -march=native -mtune=native -flto' |" \
      driver/dkms.conf
  elif ! grep -q '^MAKE\[0\]=' driver/dkms.conf; then
    printf '%s\n' \
      'MAKE[0]="make -j$(nproc) KCFLAGS='\''-O3 -march=native -mtune=native -flto'\'' all"' \
      >> driver/dkms.conf
  fi
}

_python_env() {
  env \
    -u PYTHONPATH \
    -u PYTHONHOME \
    -u PYTHONUSERBASE \
    PATH=/usr/bin:/bin \
    PYTHONNOUSERSITE=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    "$@"
}

_build_wheel() {
  local srcpath="$1"
  local outdir="$2"

  rm -rf "$outdir"
  mkdir -p "$outdir"

  (
    cd "$srcpath"
    _python_env python -m build --wheel --no-isolation --outdir "$outdir"
  )
}

_install_wheel() {
  local wheel_dir="$1"
  local -a wheels=()

  shopt -s nullglob
  wheels=("$wheel_dir"/*.whl)
  shopt -u nullglob

  (( ${#wheels[@]} )) || {
    echo "ERROR: No wheel found in $wheel_dir" >&2
    return 1
  }

  _python_env python -m installer --destdir="$pkgdir" "${wheels[@]}"
}

_make_install() {
  _python_env make PREFIX=/usr DESTDIR="$pkgdir" "$@"
}

_install_license() {
  local _dest_pkgname="$1"
  local _license_file=''

  cd "$srcdir/${pkgbase}-${pkgver}"

  for _license_file in LICENSE COPYING COPYING.txt; do
    [[ -f $_license_file ]] || continue
    install -Dm644 "$_license_file" "$pkgdir/usr/share/licenses/${_dest_pkgname}/${_license_file##*/}"
    return 0
  done

  return 0
}

prepare() {
  _prepare_source_tree
  _patch_openrazer_group
  _patch_python_metadata
  _patch_daemon_makefile_install
  _patch_dkms_aggressive_flags
}

build() {
  local pylib_src=''
  local daemon_py_src=''

  _find_python_project_dir "$srcdir/${pkgbase}-${pkgver}" openrazer pylib_src
  _find_python_project_dir "$srcdir/${pkgbase}-${pkgver}" openrazer_daemon daemon_py_src

  _build_wheel "$pylib_src" "$srcdir/wheel-python-openrazer"
  _build_wheel "$daemon_py_src" "$srcdir/wheel-openrazer-daemon"
}

package_python-openrazer() {
  pkgdesc='Library for interacting with the OpenRazer daemon'
  depends=(
    openrazer-daemon
    python
    python-numpy
  )

  _install_wheel "$srcdir/wheel-python-openrazer"
  _install_license python-openrazer
}

package_openrazer-daemon() {
  pkgdesc='Userspace daemon that abstracts access to the kernel driver. Provides a DBus service for applications to use'
  depends=(
    dbus-python
    openrazer-driver-dkms
    python
    python-daemonize
    python-gobject
    python-pyudev
    python-setproctitle
    xautomation
  )
  optdepends=(
    'libnotify: battery notifier support'
  )
  install=openrazer-daemon.install

  cd "$srcdir/${pkgbase}-${pkgver}"
  _make_install -C daemon install
  _install_wheel "$srcdir/wheel-openrazer-daemon"
  _install_license openrazer-daemon
}

package_openrazer-driver-dkms() {
  pkgdesc='OpenRazer kernel modules sources'
  depends=(
    dkms
    udev
  )
  optdepends=(
    'linux-headers: build the module for the stock Arch kernel'
  )
  install=openrazer-driver-dkms.install

  cd "$srcdir/${pkgbase}-${pkgver}"
  _make_install setup_dkms udev_install

  install -Dm644 /dev/stdin "$pkgdir/usr/lib/sysusers.d/openrazer.conf" <<'EOF'
g openrazer - -
EOF

  _install_license openrazer-driver-dkms
}

package_openrazer-meta() {
  pkgdesc='Meta package for openrazer (driver, daemon, Python library)'
  depends=(
    openrazer-driver-dkms
    openrazer-daemon
    python-openrazer
  )
  optdepends=(
    'polychromatic: GUI frontend'
    'razergenie: Qt frontend'
    'razercommander: GTK frontend'
  )

  _install_license openrazer-meta
}
