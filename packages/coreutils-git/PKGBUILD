# Maintainer: ms178
# PGO + BOLT optimized coreutils-git.
#
# This revision fixes the SIGILL regression caused by BOLT miscompiling
# sparsely-profiled binaries:
#   (1) The training workload (_exercise_binaries) now drives EVERY BOLTed tool
#       with many realistic invocations, including option-parsing and error
#       paths, repeated in a loop, so BOLT profile coverage is high instead of
#       the previous ~14-32%.
#   (2) BOLT runs with a conservative, correctness-preserving flag set, and
#       every optimized binary is SELF-TESTED before it is kept; any binary that
#       does not run is discarded and the PGO-only binary is shipped instead
#       (Option A).  A broken binary can therefore never reach the package.

pkgname=coreutils-git
pkgver=9.11.r95.dfb89db15
pkgrel=1
pkgdesc="Basic file, shell and text manipulation utilities of the GNU operating system"
arch=('x86_64')
url="https://www.gnu.org/software/coreutils/coreutils.html"
license=('GPL-3.0-or-later')
depends=('glibc' 'acl' 'attr' 'gmp' 'libcap' 'openssl')
makedepends=('git' 'gperf' 'perl' 'rsync' 'llvm' 'mold')
provides=('coreutils')
conflicts=('coreutils')
source=("git+https://github.com/coreutils/coreutils.git")
sha256sums=('SKIP')

# Excludes: groups, hostname, kill, uptime  (--enable-no-install-program)
_binary_list=(
  '['
  arch b2sum base32 base64 basenc basename cat chcon chgrp chmod chown
  chroot cksum comm cp csplit cut date dd df dir dircolors dirname du
  echo env expand expr factor false fmt fold head hostid id install
  join link ln logname ls md5sum mkdir mkfifo mknod mktemp mv nice nl
  nohup nproc numfmt od paste pathchk pinky pr printenv printf ptx pwd
  readlink realpath rm rmdir runcon seq sha1sum sha224sum sha256sum
  sha384sum sha512sum shred shuf sleep sort split stat stdbuf stty sum
  sync tac tail tee test timeout touch tr true truncate tsort tty uname
  unexpand uniq unlink users vdir wc who whoami yes
)

pkgver() {
  cd coreutils
  # v9.6-42-gabc123  ->  9.6.r42.abc123
  git describe --long --tags | sed -E 's/^v//;s/-([0-9]+)-g(.+)$/.r\1.\2/'
}

# ---------------------------------------------------------------------------
# Training workload (time-bounded: designed to finish well under 60 s).
#
# $1 = directory containing the binaries to exercise.
# $2 = mode: "serial" (default) or "parallel".
#
# Coverage strategy (unchanged from the high-coverage version):
#   * Touch every tool in _binary_list.
#   * For each tool, exercise distinct code paths: hot data path, option/argument
#     parsing, error/usage paths (the cold paths whose mis-modeling caused the
#     SIGILL), stdin paths, multi-file paths, and a multibyte/UTF-8 pass.
#
# Speed strategy (this revision):
#   * A code path is "covered" after a SINGLE traversal, so the whole suite runs
#     ONCE (no global repetition).  Only a small set of throughput kernels
#     (sort/checksums/tr/wc/uniq/...) get a tiny dedicated rep loop so their
#     inner loop accumulates enough samples for confident hot/cold layout.
#   * Input sizes are tuned to the smallest that still drives the inner loops
#     (e.g. a 40k-line sort still performs full merge passes; a 128 KiB checksum
#     still runs thousands of block iterations) — large inputs add time, not
#     coverage.
#   * PGO pass runs SERIAL (libgcov .gcda files are shared across tools via the
#     statically-linked gnulib objects; concurrent writers would contend on the
#     gcov flock).  The BOLT pass may run PARALLEL: instrumentation uses
#     per-PID .fdata shards, so concurrent tools never touch the same file.
#
# Everything is wrapped so failures never abort the build, and error paths are
# intentionally exercised (non-zero exits are expected).
# ---------------------------------------------------------------------------
_exercise_binaries() {
  local dir="$1"
  local mode="${2:-serial}"
  [[ -d "$dir" ]] || return 0

  # Sizes: small enough for speed, large enough to drive the hot loops.
  local _hot_reps="${COREUTILS_HOT_REPS:-2}"   # reps for throughput kernels only
  local _N_NUMS="${COREUTILS_N_NUMS:-40000}"   # lines for sort/shuf/tac/wc/...
  local _N_PROSE="${COREUTILS_N_PROSE:-600}"   # prose lines
  local _N_UTF8="${COREUTILS_N_UTF8:-200}"     # utf8 lines
  local _N_RAND="${COREUTILS_N_RAND:-131072}"  # bytes of random for checksums
  local _N_FACTOR="${COREUTILS_N_FACTOR:-1500}"
  local _N_YES="${COREUTILS_N_YES:-20000}"
  local _jobs; _jobs="$(nproc 2>/dev/null || echo 4)"

  local T
  T="$(mktemp -d)" || return 0
  trap 'rm -rf "$T" 2>/dev/null' RETURN

  pushd "$dir" >/dev/null || { rm -rf "$T"; return 0; }

  # run ./tool if present; swallow rc (error paths are intentional).
  _run() {
    local t="$1"; shift
    [[ -x "./$t" ]] || return 0
    "./$t" "$@" </dev/null >/dev/null 2>&1 || true
  }
  _run_in() {
    local t="$1" infile="$2"; shift 2
    [[ -x "./$t" ]] || return 0
    "./$t" "$@" <"$infile" >/dev/null 2>&1 || true
  }

  # ── build a compact but rich corpus ────────────────────────────
  printf 'a\nb\nc\n'                            > "$T/a"
  printf 'b\nc\nd\n'                            > "$T/b"
  printf 'field1 field2 field3\nx y z\n'        > "$T/cols"
  printf 'hello world\nfoo bar\nbaz qux\n'      > "$T/in"
  printf '3\n1\n4\n1\n5\n9\n2\n6\n5\n3\n5\n'    > "$T/unsorted"
  printf '1\n1\n2\n3\n3\n3\n4\n5\n5\n'          > "$T/dupes"
  printf 'key1\tval1\nkey2\tval2\nkey3\tval3\n' > "$T/tsv"
  printf '\t\tindented\n   spaces\n'            > "$T/ws"
  [[ -x ./seq ]] && ./seq 1 "$_N_NUMS" > "$T/big_nums" 2>/dev/null || seq 1 "$_N_NUMS" > "$T/big_nums"
  [[ -x ./seq ]] && ./seq "$_N_NUMS" -1 1 > "$T/rev_nums" 2>/dev/null || seq "$_N_NUMS" -1 1 > "$T/rev_nums"
  {
    _i=1
    while (( _i <= _N_PROSE )); do
      printf 'The quick brown fox %d jumps over the lazy dog line %d\n' "$_i" "$((_i * 7))"
      _i=$((_i + 1))
    done
  } > "$T/prose"
  {
    _i=1
    while (( _i <= _N_UTF8 )); do
      printf 'Zeile %d: Grüße schöne Größe — naïve café ☃ λ %d\n' "$_i" "$_i"
      _i=$((_i + 1))
    done
  } > "$T/utf8"
  head -c "$_N_RAND" /dev/urandom > "$T/rand.bin" 2>/dev/null || head -c "$_N_RAND" /dev/zero > "$T/rand.bin"
  base64 < "$T/rand.bin" > "$T/big_text" 2>/dev/null || cp "$T/prose" "$T/big_text"
  mkdir -p "$T/tree/a/b/c" "$T/tree/d" "$T/empty_dir"
  for _i in $(seq 1 60); do
    printf 'content line %d for file number %d\n' "$_i" "$_i" > "$T/tree/a/file$_i"
  done
  touch "$T/tree/d/x" "$T/tree/d/y" "$T/tree/d/z"
  ln -sf "$T/tree/a/file1" "$T/tree/a/link1" 2>/dev/null || true

  # =====================================================================
  # PASS 1 — usage / version / error path on EVERY tool (covered once).
  # These are the cold arg-parse / help / error paths.  In parallel mode we
  # fan them out across cores; each tool is independent and (under BOLT
  # instrumentation) writes its own per-PID shard, so this is race-free.
  # =====================================================================
  _usage_one() {
    local t="$1"
    [[ -x "./$t" ]] || return 0
    "./$t" --help                       </dev/null >/dev/null 2>&1 || true
    "./$t" --version                    </dev/null >/dev/null 2>&1 || true
    "./$t" --this-option-does-not-exist </dev/null >/dev/null 2>&1 || true
  }
  if [[ "$mode" == "parallel" ]]; then
    export -f _usage_one
    printf '%s\n' "${_binary_list[@]}" \
      | xargs -P "$_jobs" -n 1 -I {} bash -c '_usage_one "$@"' _ {} 2>/dev/null || true
  else
    local _t
    for _t in "${_binary_list[@]}"; do _usage_one "$_t"; done
  fi

  # =====================================================================
  # PASS 2 — one functional invocation set per tool (distinct paths).
  # Run ONCE; this is where the bulk of branch coverage comes from.
  # =====================================================================

  # trivial / identity
  _run true
  _run false
  _run echo "PGO/BOLT training string" with several args 1 2 3
  _run echo -n -e "tab\there\n"
  _run printf '%s %d %x %o %f %e %c\n' hello 42 255 64 3.14 2.7 A
  _run printf '%05d|%-10s|%+.3f\n' 7 left 1.5
  _run printenv HOME
  _run printenv

  # numeric / sequence
  _run seq 1 "$_N_NUMS"
  _run seq -w 0001 9999
  _run seq -f '%.4f' 0.0 0.05 50.0
  _run seq 1 2 99999
  _run factor 1234567890123
  [[ -x ./factor ]] && (seq 1 "$_N_FACTOR" | ./factor >/dev/null 2>&1 || true)
  _run numfmt --to=iec 1073741824
  [[ -x ./numfmt ]] && (seq 1000 1000 5000000 | ./numfmt --to=si >/dev/null 2>&1 || true)
  _run expr 12345 \* 6789
  _run expr length "abcdefghijklmnopqrstuvwxyz0123456789"
  _run expr substr "hello world foo bar" 1 9
  _run expr 100 % 7
  _run expr "abc" : "a\(b\)c"

  # file listing
  _run ls -laR "$T/tree"
  _run ls -lhSt --color=always "$T/tree/a"
  _run ls -1 --sort=size "$T/tree/a"
  _run ls -i --block-size=K "$T/tree"
  _run ls /nonexistent-path-xyz
  _run dir -la "$T/tree"
  _run vdir "$T/tree"
  _run dircolors --print-database
  _run dircolors --bourne-shell
  _run dircolors --c-shell

  # file operations
  _run cp -a "$T/tree" "$T/tree_cp"
  _run cp --reflink=auto "$T/big_text" "$T/bt_cp"
  _run cp -r --preserve=all "$T/tree/a" "$T/a_cp"
  _run mv "$T/bt_cp" "$T/bt_mv"
  _run mv "$T/bt_mv" "$T/bt_cp"
  _run rm -rf "$T/tree_cp" "$T/a_cp"
  _run mkdir -p "$T/new/deep/path/here"
  _run rmdir -p "$T/new/deep/path/here"
  _run ln -sf "$T/in" "$T/sym"
  _run ln "$T/in" "$T/hard"
  _run link "$T/in" "$T/hard2"
  _run unlink "$T/hard2"
  _run touch "$T/touched"
  _run touch -t 202401011200.00 "$T/touched"
  _run touch -d 'next Thursday' "$T/touched2"
  _run mktemp -u -p "$T"
  _run mktemp -d -p "$T"
  _run mkfifo "$T/fifo"
  _run mknod "$T/node_p" p
  _run install -Dm644 "$T/in" "$T/inst/installed"
  _run install -d "$T/inst/dir1" "$T/inst/dir2"
  _run shred -n 1 -z "$T/touched"
  _run truncate -s 8K "$T/touched"
  _run truncate -s +4K "$T/touched"
  [[ -x ./dd ]] && (./dd if=/dev/zero of="$T/dd_out" bs=8k count=128 2>/dev/null || true)
  _run sync "$T/dd_out"
  _run sync --data "$T/dd_out"

  # permissions / ownership (may fail unprivileged - harmless)
  _run chmod 644 "$T/in"
  _run chmod u+x,g-w,o=r "$T/in"
  _run chmod -R a+rX "$T/tree"
  _run chown "$(id -u):$(id -g)" "$T/in"
  _run chgrp "$(id -g)" "$T/in"
  _run chcon --reference="$T/in" "$T/a"
  _run runcon --help
  _run chroot --help

  # text: streaming / extraction
  _run cat "$T/big_text"
  _run cat -nA "$T/prose"
  _run cat -s -b "$T/in"
  _run tac "$T/big_nums"
  _run tac -s ' ' "$T/prose"
  _run head -n 8000 "$T/big_nums"
  _run head -c 16384 "$T/big_text"
  _run head -n -100 "$T/prose"
  _run head -q -n 5 "$T/a" "$T/b"
  _run tail -n 8000 "$T/big_nums"
  _run tail -c 16384 "$T/big_text"
  _run tail -n +50 "$T/prose"
  _run tail -q -n 5 "$T/a" "$T/b"
  _run split -l 2000 "$T/big_nums" "$T/sp."
  _run split -n 4 "$T/big_text" "$T/spn."
  _run csplit -sf "$T/cs." "$T/prose" '/fox 50 /' '{*}'
  _run nl -ba -nrz "$T/prose"
  _run pr -t -3 "$T/prose"
  _run pr -n -h HEADER "$T/in"

  # text: transformation
  _run_in tr "$T/big_text" 'a-z' 'A-Z'
  _run_in tr "$T/prose" -d '\n'
  _run_in tr "$T/prose" -s ' '
  _run_in tr "$T/prose" -cd 'a-zA-Z0-9\n'
  _run cut -c1-30 "$T/big_text"
  _run cut -d' ' -f1,3,5 "$T/prose"
  _run cut -d' ' -f2- "$T/prose"
  _run cut -f1 "$T/tsv"
  _run paste "$T/a" "$T/b"
  _run paste -sd',' "$T/big_nums"
  _run paste -d'\t' "$T/a" "$T/b" "$T/a"
  _run join "$T/a" "$T/b"
  _run join -a1 -a2 "$T/a" "$T/b"
  _run comm "$T/a" "$T/b"
  _run comm -12 "$T/a" "$T/b"
  _run comm -3 "$T/a" "$T/b"
  _run_in expand "$T/ws"
  _run_in expand "$T/ws" -t 4
  _run_in unexpand "$T/ws" --first-only
  _run_in unexpand "$T/ws" -a
  _run fold -w 40 "$T/prose"
  _run fold -s -w 50 "$T/prose"
  _run fmt -w 60 "$T/prose"
  _run fmt -u "$T/prose"

  # text: sorting / uniqueness (single pass here; repeated in hot loop below)
  _run sort "$T/big_nums"
  _run sort -t' ' -k5,5n -k1,1 "$T/prose"
  _run sort -k2 "$T/cols"
  _run sort -R "$T/unsorted"
  _run sort -m "$T/a" "$T/b"
  _run uniq "$T/dupes"
  _run uniq -c "$T/dupes"
  _run uniq -d "$T/dupes"
  _run uniq -u "$T/dupes"
  [[ -x ./tsort ]] && (printf 'a b\nb c\nc d\nd e\ne f\n' | ./tsort >/dev/null 2>&1 || true)
  _run shuf -n 1000 "$T/big_nums"
  _run shuf -i 1-100000
  _run shuf -e one two three four five

  # text: counting / analysis
  _run wc "$T/big_text"
  _run wc -l "$T/big_nums"
  _run wc -lwmc "$T/prose"
  _run wc -L "$T/prose"
  _run wc "$T/utf8"
  _run sum "$T/big_text"
  _run sum -s "$T/big_text"
  _run od -An -tx1 -N 4096 "$T/big_text"
  _run od -c -N 1024 "$T/prose"
  _run od -A x -t x4 -N 2048 "$T/rand.bin"
  _run ptx -w 50 "$T/in"

  # checksums / encoding (single pass here; repeated in hot loop below)
  local _h
  for _h in md5sum sha1sum sha224sum sha256sum sha384sum sha512sum b2sum cksum; do
    [[ -x "./$_h" ]] && (./"$_h" "$T/big_text" 2>/dev/null | ./"$_h" --check --status >/dev/null 2>&1 || true)
  done
  _run cksum -a crc "$T/rand.bin"
  _run cksum -a sm3 "$T/rand.bin"
  _run base64 "$T/rand.bin"
  [[ -x ./base64 ]] && (./base64 "$T/in" | ./base64 -d >/dev/null 2>&1 || true)
  _run base32 "$T/in"
  [[ -x ./base32 ]] && (./base32 "$T/in" | ./base32 -d >/dev/null 2>&1 || true)
  _run basenc --base64url "$T/in"
  _run basenc --base16 "$T/in"
  _run basenc --base2msbf "$T/in"

  # filesystem info
  _run stat "$T/in"
  _run stat -f "$T"
  _run stat -L "$T/sym"
  [[ -x ./stat ]] && (./stat --printf='%s %U %G %A %y\n' "$T"/tree/a/file* >/dev/null 2>&1 || true)
  _run df -h
  _run df -i .
  _run df -T --total
  _run du -sh "$T/tree"
  _run du -a "$T/tree"
  _run du --max-depth=2 "$T/tree"
  _run du -h --threshold=1K "$T/tree"

  # path utilities
  _run basename /usr/local/bin/test
  _run basename -s .txt /a/b/c.txt
  _run basename -a /x/y /p/q /m/n
  _run dirname /usr/local/bin/test
  _run dirname -z /a/b /c/d
  _run readlink -f "$T/sym"
  _run readlink -m "$T/tree/a/../d/x"
  _run realpath "$T/tree/a/../d"
  _run realpath -s --relative-to="$T" "$T/tree/a"
  _run pathchk "$T/in"
  _run pathchk -p "a/b/c"
  _run pwd
  _run pwd -P
  _run logname
  _run hostid

  # system info / identity
  _run uname -a
  _run uname -mrs
  _run arch
  _run nproc
  _run nproc --all
  _run id
  _run id -un
  _run id -Gn
  _run whoami
  _run tty
  _run who
  _run who -a
  _run users
  _run pinky
  _run pinky -l root

  # date / time
  _run date
  _run date -R
  _run date -u '+%Y-%m-%dT%H:%M:%S.%N%z'
  _run date -d '2024-06-15 12:00:00 UTC' '+%s'
  _run date -d '@1700000000'
  _run date --iso-8601=ns
  _run sleep 0
  _run sleep 0 0

  # process / env
  _run env
  _run env -i PATH=/usr/bin /usr/bin/true
  _run env FOO=bar BAZ=qux /usr/bin/printenv FOO
  _run env -u HOME /usr/bin/true
  _run nice -n 10 /usr/bin/true
  _run nohup /usr/bin/true
  _run timeout 5 /usr/bin/true
  _run timeout --preserve-status 5 /usr/bin/true
  _run_in stty /dev/null -a
  _run stdbuf -oL /usr/bin/true
  _run stdbuf -i0 -o0 -e0 /usr/bin/true

  # tee / pipeline
  [[ -x ./tee ]] && (seq 1 20000 | ./tee "$T/tee1" "$T/tee2" >/dev/null 2>&1 || true)
  [[ -x ./tee ]] && (seq 1 1000  | ./tee -a "$T/tee1" >/dev/null 2>&1 || true)

  # test / [ (operator classes)
  _run test -f "$T/in"
  _run test -d "$T/tree"
  _run test 100 -gt 50
  _run test -z ""
  _run test "abc" = "abc"
  _run test "abc" != "xyz"
  _run test -e "$T/in" -a -r "$T/in"
  [[ -x './[' ]] && ('./[' -f "$T/in" ']' || true)
  [[ -x './[' ]] && ('./[' 5 -lt 10 -o 2 -gt 9 ']' || true)

  # a single UTF-8 locale pass for the text-heavy tools (one locale; one pass)
  ( export LC_ALL=C.UTF-8
    _run sort "$T/utf8"
    _run sort -f "$T/utf8"
    _run_in tr "$T/utf8" 'a-z' 'A-Z'
    _run wc -m "$T/utf8"
    _run cut -c1-10 "$T/utf8"
    _run uniq "$T/utf8"
    _run cat -n "$T/utf8"
  ) 2>/dev/null || true

  # =====================================================================
  # PASS 3 — throughput kernels only, repeated a few times so their inner
  # loops get strong sample weight for confident hot-path layout.  This is
  # the ONLY repetition, and it touches just the handful of hot tools.
  # =====================================================================
  local _hr
  for _hr in $(seq 1 "$_hot_reps"); do
    _run sort "$T/big_nums"
    _run sort -n "$T/rev_nums"
    _run sort -u "$T/big_nums"
    _run sort -rn "$T/big_nums"
    _run shuf "$T/big_nums"
    _run tac "$T/big_nums"
    _run wc "$T/big_text"
    _run wc -l "$T/big_nums"
    _run_in tr "$T/big_text" 'a-z' 'A-Z'
    _run cut -c1-30 "$T/big_text"
    _run uniq "$T/big_nums"
    _run od -An -tx1 -N 8192 "$T/big_text"
    for _h in md5sum sha1sum sha256sum sha512sum b2sum cksum base64; do
      _run "$_h" "$T/rand.bin"
    done
  done

  popd >/dev/null || true
  rm -rf "$T" 2>/dev/null
  trap - RETURN
}

prepare() {
  cd coreutils

  # Wipe stale profiling / BOLT artefacts from any prior run.
  rm -f  "$srcdir"/*.profraw
  rm -rf "$srcdir"/{bolt_profile,bolt_opt,bolt_instrumented,pgo,pgo_bin}
  mkdir -p "$srcdir"/{bolt_profile,bolt_opt,bolt_instrumented,pgo,pgo_bin}

  export SHELL=/bin/sh CONFIG_SHELL=/bin/sh

  # Faster gnulib checkout via GitHub mirror.
  git submodule init
  git config submodule.gnulib.url "https://github.com/coreutils/gnulib.git"
  git submodule update --depth=1

  # Mirror submodule commits may differ from upstream - skip that check.
  printf 'local-checks-to-skip = public-submodule-commit\n' > Makefile.cfg

  ./bootstrap
}

build() {
  export SHELL=/bin/sh CONFIG_SHELL=/bin/sh
  export CC=gcc CXX=g++

  local _pkgdir="$srcdir/coreutils"
  cd "$_pkgdir"

  # Preserve the user / makepkg flags verbatim (minus the format-security
  # -Werror that breaks instrumented builds).
  local USER_CFLAGS="${CFLAGS/-Werror=format-security/}"
  local USER_CXXFLAGS="${CXXFLAGS/-Werror=format-security/}"
  local USER_LDFLAGS="$LDFLAGS"

  local LDFLAGS_MOLD="$USER_LDFLAGS -fuse-ld=mold"
  local PGO_DIR="$srcdir/pgo"

  # ── Stage-1 flags: generate profile counters ───────────────────
  # -fprofile-generate must also be in LDFLAGS so LTO link-time codegen emits
  # instrumentation and libgcov is linked.
  local CFLAGS_GEN="$USER_CFLAGS -fprofile-generate=$PGO_DIR"
  local CXXFLAGS_GEN="$USER_CXXFLAGS -fprofile-generate=$PGO_DIR"
  local LDFLAGS_GEN="$LDFLAGS_MOLD -fprofile-generate=$PGO_DIR"

  # ── Stage-2 flags: consume profiles; prepare for BOLT ──────────
  # -fno-reorder-blocks-and-partition: let BOLT own the hot/cold layout.
  # -Wl,--emit-relocs: BOLT needs static relocations to safely rewrite.
  local CFLAGS_USE="$USER_CFLAGS -fprofile-use=$PGO_DIR -fprofile-correction -fno-reorder-blocks-and-partition"
  local CXXFLAGS_USE="$USER_CXXFLAGS -fprofile-use=$PGO_DIR -fprofile-correction -fno-reorder-blocks-and-partition"
  local LDFLAGS_USE="$LDFLAGS_MOLD -fprofile-use=$PGO_DIR -fprofile-correction -Wl,--emit-relocs"

  local binary_dir="src"

  # ── configure (once, with neutral flags) ───────────────────────
  env CFLAGS="$USER_CFLAGS" CXXFLAGS="$USER_CXXFLAGS" LDFLAGS="$LDFLAGS_MOLD" \
    ./configure \
      --disable-gcc-warnings \
      --prefix=/usr \
      --libexecdir=/usr/lib \
      --with-openssl \
      --enable-no-install-program=groups,hostname,kill,uptime

  # ── STAGE 1: PGO instrumentation build ─────────────────────────
  echo ">>> STAGE 1: Building with PGO instrumentation..."
  make -j"$(nproc)" V=1 SHELL=/bin/sh \
    CFLAGS="$CFLAGS_GEN" CXXFLAGS="$CXXFLAGS_GEN" LDFLAGS="$LDFLAGS_GEN"

  echo ">>> Exercising instrumented binaries for PGO profiles (high coverage, serial)..."
  # SERIAL: PGO .gcda files are shared across tools via the statically-linked
  # gnulib objects; concurrent writers would contend on the gcov flock.
  _exercise_binaries "$_pkgdir/$binary_dir" serial

  # ── STAGE 2: PGO-optimised rebuild ─────────────────────────────
  echo ">>> STAGE 2: Rebuilding with PGO profile data..."
  make clean
  make -j"$(nproc)" V=1 SHELL=/bin/sh \
    CFLAGS="$CFLAGS_USE" CXXFLAGS="$CXXFLAGS_USE" LDFLAGS="$LDFLAGS_USE"

  # Preserve PGO-optimised binaries (BOLT input + safe fallback).
  echo ">>> Preserving PGO-optimised binaries..."
  local preserved=0 bin
  for bin in "${_binary_list[@]}"; do
    if [[ -x "$binary_dir/$bin" ]]; then
      install -Dm755 "$binary_dir/$bin" "$srcdir/pgo_bin/$bin"
      preserved=$((preserved + 1))
    fi
  done
  echo ">>> Preserved $preserved PGO-optimised binaries."
  if (( preserved == 0 )); then
    echo "FATAL: No PGO binaries preserved." >&2
    return 1
  fi

  # ── STAGE 3 + 4: BOLT (Option A: conservative + validated) ─────
  if ! command -v llvm-bolt >/dev/null 2>&1; then
    echo ">>> WARNING: llvm-bolt not found; shipping PGO-only binaries." >&2
    return 0
  fi

  # Stage 3: instrument each PGO binary and exercise it.  Instrumented copies
  # live in bolt_instrumented/; the build tree is not modified.
  echo ">>> STAGE 3: BOLT instrumentation..."
  local instrumented=0
  for bin in "${_binary_list[@]}"; do
    [[ -f "$srcdir/pgo_bin/$bin" ]] || continue
    if llvm-bolt "$srcdir/pgo_bin/$bin" \
        -o "$srcdir/bolt_instrumented/$bin" \
        --instrument \
        --instrumentation-file="$srcdir/bolt_profile/${bin}.fdata" \
        --instrumentation-file-append-pid \
        2>/dev/null; then
      instrumented=$((instrumented + 1))
    fi
  done
  echo ">>> BOLT-instrumented $instrumented binaries."

  echo ">>> Exercising BOLT-instrumented binaries for fdata (high coverage, parallel)..."
  # PARALLEL: BOLT instrumentation writes per-PID .fdata shards, so concurrent
  # tools never touch the same file -> race-free and uses all cores.
  _exercise_binaries "$srcdir/bolt_instrumented" parallel

  # Merge per-PID fdata shards into one file per tool (instrumentation with
  # --instrumentation-file-append-pid yields <name>.fdata.<pid>).  Every short
  # invocation in the workload produced a shard; merging them sums the counters
  # and is what gives us high BOLT coverage.
  echo ">>> Merging BOLT profile shards..."
  local merge_tool=""
  if command -v merge-fdata >/dev/null 2>&1; then
    merge_tool="merge-fdata"
  elif command -v llvm-bolt-merge-fdata >/dev/null 2>&1; then
    merge_tool="llvm-bolt-merge-fdata"
  fi
  for bin in "${_binary_list[@]}"; do
    local base="$srcdir/bolt_profile/${bin}.fdata"
    local -a shards=()
    shopt -s nullglob
    shards=( "$base".* )
    shopt -u nullglob
    (( ${#shards[@]} > 0 )) || continue
    if [[ -n "$merge_tool" ]]; then
      # Canonical merge (sums counters across shards).
      if ! "$merge_tool" "${shards[@]}" > "$base" 2>/dev/null; then
        # Fallback: concatenation.  BOLT's text fdata reader sums duplicate
        # keys for the same binary, so a plain cat preserves all coverage.
        cat "${shards[@]}" > "$base" 2>/dev/null || true
      fi
    else
      # No merge tool available: concatenate (valid, sums on read).
      cat "${shards[@]}" > "$base" 2>/dev/null || true
    fi
    rm -f "${shards[@]}" 2>/dev/null || true
  done

  # Stage 4: apply CONSERVATIVE BOLT optimisations, then SELF-TEST each binary.
  # Only validated binaries are kept; the rest fall back to PGO in package().
  echo ">>> STAGE 4: Applying BOLT optimisations (conservative + validated)..."

  # Tools that cannot be smoke-tested with --version/--help safely, mapped to a
  # known-harmless invocation that must succeed (exit 0) on a correct binary.
  _bolt_selftest() {
    local b="$1" exe="$2"
    case "$b" in
      true|':')        "$exe" ;;
      false)           "$exe"; [[ $? -eq 1 ]] ;;   # false must exit 1
      '[')             "$exe" 1 -eq 1 ']' ;;
      echo)            "$exe" selftest >/dev/null ;;
      printf)          "$exe" '%s\n' selftest >/dev/null ;;
      yes)             "$exe" --version >/dev/null ;;
      sleep)           "$exe" 0 ;;
      test)            "$exe" 1 -eq 1 ;;
      tty)             "$exe" >/dev/null 2>&1 || true; true ;;   # tty exit code is env-dependent
      sync)            "$exe" --help >/dev/null ;;
      *)               # Default: --version then --help; one must succeed.
                       "$exe" --version >/dev/null 2>&1 || "$exe" --help >/dev/null 2>&1 ;;
    esac
  }

  local bolt_ok=0 bolt_fail=0 bolt_reject=0
  # Conservative, correctness-preserving BOLT flags.  Removed (vs the previous,
  # crash-causing set): --jump-tables=aggressive, --frame-opt=all,
  # --frame-opt-rm-stores, --reg-reassign, --use-aggr-reg-reassign,
  # --peepholes=all, --indirect-call-promotion=all, --plt=all, --hot-data,
  # --split-all-cold, --split-strategy=cdsplit, --icf=all,
  # --x86-strip-redundant-address-size, --sctc-mode=heuristic.
  local -a BOLT_OPTS=(
    --dyno-stats
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions
    --split-strategy=profile2
    --split-eh
    --icf=safe
    --eliminate-unreachable
    --use-gnu-stack
    --update-debug-sections
  )

  for bin in "${_binary_list[@]}"; do
    local src_bin="$srcdir/pgo_bin/$bin"
    local fdata="$srcdir/bolt_profile/${bin}.fdata"
    local out_bin="$srcdir/bolt_opt/$bin"
    [[ -f "$src_bin" && -s "$fdata" ]] || continue

    if ! llvm-bolt "$src_bin" -o "$out_bin" --data="$fdata" "${BOLT_OPTS[@]}" 2>/dev/null; then
      echo ">>> BOLT failed for '$bin' -> will use PGO binary."
      rm -f "$out_bin"
      bolt_fail=$((bolt_fail + 1))
      continue
    fi

    # *** Self-test gate: a BOLTed binary that does not run is discarded. ***
    if _bolt_selftest "$bin" "$out_bin" >/dev/null 2>&1; then
      bolt_ok=$((bolt_ok + 1))
    else
      echo ">>> BOLT self-test FAILED for '$bin' -> discarding, will use PGO binary."
      rm -f "$out_bin"
      bolt_reject=$((bolt_reject + 1))
    fi
  done

  echo ">>> BOLT summary: $bolt_ok kept, $bolt_reject rejected (self-test), $bolt_fail failed."
  if (( bolt_ok == 0 )); then
    echo ">>> NOTE: no BOLT binaries kept; package will ship PGO-only binaries."
  fi
}

package() {
  cd coreutils
  export SHELL=/bin/sh CONFIG_SHELL=/bin/sh

  make DESTDIR="$pkgdir" SHELL=/bin/sh install

  # Overlay every binary: prefer validated BOLT+PGO, else PGO-only.
  # (BOLT binaries in bolt_opt/ have already passed the runtime self-test.)
  local bin_dir="$pkgdir/usr/bin"
  local bin used_bolt=0 used_pgo=0
  for bin in "${_binary_list[@]}"; do
    if [[ -f "$srcdir/bolt_opt/$bin" ]]; then
      install -Dm755 "$srcdir/bolt_opt/$bin" "$bin_dir/$bin"
      used_bolt=$((used_bolt + 1))
    elif [[ -f "$srcdir/pgo_bin/$bin" ]]; then
      install -Dm755 "$srcdir/pgo_bin/$bin" "$bin_dir/$bin"
      used_pgo=$((used_pgo + 1))
    fi
  done
  echo ">>> Packaged: $used_bolt BOLT+PGO, $used_pgo PGO-only binaries."
}
