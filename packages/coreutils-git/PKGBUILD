# Maintainer: ms178

pkgname=coreutils-git
pkgver=9.11.r1.ac7e11187
pkgrel=1
pkgdesc="Basic file, shell and text manipulation utilities of the GNU operating system"
arch=('x86_64')
url="https://www.gnu.org/software/coreutils/coreutils.html"
license=('GPL-3.0-or-later')
depends=('glibc' 'acl' 'attr' 'gmp' 'libcap' 'openssl')
makedepends=('git' 'gperf' 'perl' 'rsync' 'llvm' 'mold')
provides=('coreutils')
conflicts=('coreutils')
source=("git+https://github.com/coreutils/coreutils.git")
sha256sums=('SKIP')

# Excludes: groups, hostname, kill, uptime  (--enable-no-install-program)
_binary_list=(
  '['
  arch b2sum base32 base64 basenc basename cat chcon chgrp chmod chown
  chroot cksum comm cp csplit cut date dd df dir dircolors dirname du
  echo env expand expr factor false fmt fold head hostid id install
  join link ln logname ls md5sum mkdir mkfifo mknod mktemp mv nice nl
  nohup nproc numfmt od paste pathchk pinky pr printenv printf ptx pwd
  readlink realpath rm rmdir runcon seq sha1sum sha224sum sha256sum
  sha384sum sha512sum shred shuf sleep sort split stat stdbuf stty sum
  sync tac tail tee test timeout touch tr true truncate tsort tty uname
  unexpand uniq unlink users vdir wc who whoami yes
)

pkgver() {
  cd coreutils
  # v9.6-42-gabc123  →  9.6.r42.abc123
  git describe --long --tags | sed -E 's/^v//;s/-([0-9]+)-g(.+)$/.r\1.\2/'
}

_exercise_binaries() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0
  pushd "$dir" >/dev/null || return 0

  local T
  T="$(mktemp -d)"

  # small structured files (pre-sorted for join/comm)
  printf 'a\nb\nc\n'                > "$T/a"
  printf 'b\nc\nd\n'                > "$T/b"
  printf 'hello world\nfoo bar\n'   > "$T/in"
  printf '3\n1\n4\n1\n5\n9\n2\n6\n' > "$T/unsorted"
  printf '1\n1\n2\n3\n3\n3\n4\n'    > "$T/dupes"

  # large data for hot-loop coverage
  seq 1 100000                       > "$T/big_nums"
  seq 100000 -1 1                    > "$T/rev_nums"
  local _i
  for _i in $(seq 1 500); do
    printf 'The quick brown fox jumps over the lazy dog line %d\n' "$_i"
  done                               > "$T/prose"
  head -c 262144 /dev/urandom | base64 > "$T/big_text"

  # directory tree for fs utilities
  mkdir -p "$T/tree/a/b/c" "$T/tree/d" "$T/empty_dir"
  for _i in $(seq 1 50); do
    printf 'content %d\n' "$_i" > "$T/tree/a/file$_i"
  done
  touch "$T/tree/d/x" "$T/tree/d/y"
  ln -sf "$T/tree/a/file1" "$T/tree/a/link1" 2>/dev/null || true

  # ── trivial / identity ─────────────────────────────────────────
  [[ -x ./true      ]] && ./true || true
  [[ -x ./false     ]] && { ./false || true; }
  [[ -x ./echo      ]] && ./echo "PGO training string" >/dev/null || true
  [[ -x ./printf    ]] && ./printf '%s %d %x %f\n' hello 42 255 3.14 >/dev/null || true
  [[ -x ./printenv  ]] && ./printenv HOME >/dev/null 2>&1 || true
  [[ -x ./yes       ]] && ./yes | head -n 50000 >/dev/null 2>&1 || true

  # ── numeric / sequence ─────────────────────────────────────────
  [[ -x ./seq       ]] && ./seq 1 100000 >/dev/null || true
  [[ -x ./seq       ]] && ./seq -w 0001 9999 >/dev/null || true
  [[ -x ./seq       ]] && ./seq -f '%.4f' 0.0 0.01 100.0 >/dev/null || true
  [[ -x ./factor    ]] && echo 1234567890123 | ./factor >/dev/null || true
  [[ -x ./factor    ]] && seq 1 2000 | ./factor >/dev/null || true
  [[ -x ./numfmt    ]] && echo 1073741824 | ./numfmt --to=iec >/dev/null || true
  [[ -x ./numfmt    ]] && seq 1000 1000 10000000 | ./numfmt --to=si >/dev/null || true
  [[ -x ./expr      ]] && ./expr 12345 \* 6789 >/dev/null 2>&1 || true
  [[ -x ./expr      ]] && ./expr length "abcdefghijklmnopqrstuvwxyz" >/dev/null 2>&1 || true
  [[ -x ./expr      ]] && ./expr substr "hello world" 1 5 >/dev/null 2>&1 || true

  # ── file listing ───────────────────────────────────────────────
  [[ -x ./ls        ]] && ./ls -laR "$T/tree" >/dev/null || true
  [[ -x ./ls        ]] && ./ls -lhSt "$T/tree/a" >/dev/null || true
  [[ -x ./ls        ]] && ./ls --color=always -R /usr/bin >/dev/null 2>&1 || true
  [[ -x ./ls        ]] && ./ls -1 /usr/lib >/dev/null 2>&1 || true
  [[ -x ./dir       ]] && ./dir -la "$T/tree" >/dev/null || true
  [[ -x ./vdir      ]] && ./vdir "$T/tree" >/dev/null || true
  [[ -x ./dircolors ]] && ./dircolors --print-database >/dev/null || true
  [[ -x ./dircolors ]] && eval "$(./dircolors --bourne-shell)" 2>/dev/null || true

  # ── file operations ────────────────────────────────────────────
  [[ -x ./cp        ]] && ./cp -a "$T/tree" "$T/tree_cp" || true
  [[ -x ./cp        ]] && ./cp --reflink=auto "$T/big_text" "$T/big_text_cp" 2>/dev/null || true
  [[ -x ./mv        ]] && ./mv "$T/big_text_cp" "$T/big_text_mv" 2>/dev/null || true
  [[ -x ./mv        ]] && ./mv "$T/big_text_mv" "$T/big_text_cp" 2>/dev/null || true
  [[ -x ./rm        ]] && ./rm -rf "$T/tree_cp" || true
  [[ -x ./mkdir     ]] && ./mkdir -p "$T/new/deep/path/here" || true
  [[ -x ./rmdir     ]] && ./rmdir -p "$T/new/deep/path/here" 2>/dev/null || true
  [[ -x ./ln        ]] && ./ln -sf "$T/in" "$T/sym" || true
  [[ -x ./ln        ]] && ./ln "$T/in" "$T/hard" 2>/dev/null || true
  [[ -x ./link      ]] && ./link "$T/in" "$T/hard2" 2>/dev/null || true
  [[ -x ./unlink    ]] && ./unlink "$T/hard2" 2>/dev/null || true
  [[ -x ./touch     ]] && ./touch "$T/touched" || true
  [[ -x ./touch     ]] && ./touch -t 202401011200.00 "$T/touched" || true
  [[ -x ./mktemp    ]] && ./mktemp -u -p "$T" >/dev/null || true
  [[ -x ./mktemp    ]] && ./mktemp -d -p "$T" >/dev/null || true
  [[ -x ./mkfifo    ]] && ./mkfifo "$T/fifo" 2>/dev/null || true
  [[ -x ./mknod     ]] && ./mknod "$T/node_p" p 2>/dev/null || true
  [[ -x ./install   ]] && ./install -Dm644 "$T/in" "$T/inst/installed" || true
  [[ -x ./shred     ]] && ./shred -n 2 -z "$T/touched" 2>/dev/null || true
  [[ -x ./truncate  ]] && ./truncate -s 4K "$T/touched" || true
  [[ -x ./dd        ]] && ./dd if=/dev/zero of="$T/dd_out" bs=4k count=256 2>/dev/null || true
  [[ -x ./sync      ]] && ./sync "$T/dd_out" 2>/dev/null || true

  # ── permissions / ownership (may fail without root — harmless) ─
  [[ -x ./chmod     ]] && ./chmod 644 "$T/in" 2>/dev/null || true
  [[ -x ./chmod     ]] && ./chmod u+x,g-w "$T/in" 2>/dev/null || true
  [[ -x ./chown     ]] && ./chown "$(id -u):$(id -g)" "$T/in" 2>/dev/null || true
  [[ -x ./chgrp     ]] && ./chgrp "$(id -g)" "$T/in" 2>/dev/null || true
  [[ -x ./chcon     ]] && ./chcon --reference="$T/in" "$T/a" 2>/dev/null || true
  [[ -x ./runcon    ]] && ./runcon --help >/dev/null 2>&1 || true
  [[ -x ./chroot    ]] && ./chroot --help >/dev/null 2>&1 || true

  # ── text: streaming / extraction ───────────────────────────────
  [[ -x ./cat       ]] && ./cat "$T/big_text" >/dev/null || true
  [[ -x ./cat       ]] && ./cat -nA "$T/prose" >/dev/null || true
  [[ -x ./tac       ]] && ./tac "$T/big_nums" >/dev/null || true
  [[ -x ./head      ]] && ./head -n 5000 "$T/big_nums" >/dev/null || true
  [[ -x ./head      ]] && ./head -c 8192 "$T/big_text" >/dev/null || true
  [[ -x ./tail      ]] && ./tail -n 5000 "$T/big_nums" >/dev/null || true
  [[ -x ./tail      ]] && ./tail -c 8192 "$T/big_text" >/dev/null || true
  [[ -x ./split     ]] && ./split -l 1000 "$T/big_nums" "$T/sp_" || true
  [[ -x ./csplit    ]] && ./csplit -sf "$T/cs_" "$T/prose" '/fox.*50/' '{*}' 2>/dev/null || true
  [[ -x ./nl        ]] && ./nl -ba "$T/prose" >/dev/null || true
  [[ -x ./pr        ]] && ./pr -t -2 "$T/prose" >/dev/null 2>&1 || true

  # ── text: transformation ───────────────────────────────────────
  [[ -x ./tr        ]] && ./tr 'a-z' 'A-Z' < "$T/big_text" >/dev/null || true
  [[ -x ./tr        ]] && ./tr -d '\n'      < "$T/prose"    >/dev/null || true
  [[ -x ./tr        ]] && ./tr -s ' '       < "$T/prose"    >/dev/null || true
  [[ -x ./cut       ]] && ./cut -c1-20 "$T/big_text" >/dev/null || true
  [[ -x ./cut       ]] && ./cut -d' ' -f1,3,5 "$T/prose" >/dev/null || true
  [[ -x ./paste     ]] && ./paste "$T/a" "$T/b" >/dev/null || true
  [[ -x ./paste     ]] && ./paste -sd',' "$T/big_nums" >/dev/null || true
  [[ -x ./join      ]] && ./join "$T/a" "$T/b" >/dev/null || true
  [[ -x ./comm      ]] && ./comm "$T/a" "$T/b" >/dev/null || true
  [[ -x ./comm      ]] && ./comm -12 "$T/a" "$T/b" >/dev/null || true
  [[ -x ./expand    ]] && printf '\t\tindented\n' | ./expand >/dev/null || true
  [[ -x ./unexpand  ]] && printf '        X\n' | ./unexpand --first-only >/dev/null || true
  [[ -x ./fold      ]] && ./fold -w 40 "$T/prose" >/dev/null || true
  [[ -x ./fmt       ]] && ./fmt -w 60 "$T/prose" >/dev/null || true

  # ── text: sorting / uniqueness ─────────────────────────────────
  [[ -x ./sort      ]] && ./sort    "$T/big_nums" >/dev/null || true
  [[ -x ./sort      ]] && ./sort -n "$T/rev_nums" >/dev/null || true
  [[ -x ./sort      ]] && ./sort -u "$T/big_nums" >/dev/null || true
  [[ -x ./sort      ]] && ./sort -rn "$T/big_nums" >/dev/null || true
  [[ -x ./sort      ]] && ./sort -t' ' -k5,5n "$T/prose" >/dev/null || true
  [[ -x ./sort      ]] && ./sort --parallel="$(nproc)" -S 50% "$T/big_nums" >/dev/null || true
  [[ -x ./uniq      ]] && ./uniq    "$T/dupes" >/dev/null || true
  [[ -x ./uniq      ]] && ./uniq -c "$T/dupes" >/dev/null || true
  [[ -x ./tsort     ]] && printf 'a b\nb c\nc d\nd e\n' | ./tsort >/dev/null || true
  [[ -x ./shuf      ]] && ./shuf    "$T/big_nums" >/dev/null || true
  [[ -x ./shuf      ]] && ./shuf -n 500 "$T/big_nums" >/dev/null || true

  # ── text: counting / analysis ──────────────────────────────────
  [[ -x ./wc        ]] && ./wc    "$T/big_text" >/dev/null || true
  [[ -x ./wc        ]] && ./wc -l "$T/big_nums" >/dev/null || true
  [[ -x ./sum       ]] && ./sum "$T/big_text" >/dev/null || true
  [[ -x ./od        ]] && ./od -An -tx1 -N 512 "$T/big_text" >/dev/null || true
  [[ -x ./ptx       ]] && ./ptx "$T/prose" >/dev/null 2>&1 || true

  # ── checksums / encoding (crypto hot loops) ────────────────────
  [[ -x ./md5sum    ]] && ./md5sum    "$T/big_text" >/dev/null || true
  [[ -x ./sha1sum   ]] && ./sha1sum   "$T/big_text" >/dev/null || true
  [[ -x ./sha224sum ]] && ./sha224sum "$T/big_text" >/dev/null || true
  [[ -x ./sha256sum ]] && ./sha256sum "$T/big_text" >/dev/null || true
  [[ -x ./sha384sum ]] && ./sha384sum "$T/big_text" >/dev/null || true
  [[ -x ./sha512sum ]] && ./sha512sum "$T/big_text" >/dev/null || true
  [[ -x ./b2sum     ]] && ./b2sum     "$T/big_text" >/dev/null || true
  [[ -x ./cksum     ]] && ./cksum     "$T/big_text" >/dev/null || true
  [[ -x ./base64    ]] && ./base64    "$T/big_text" >/dev/null || true
  [[ -x ./base64    ]] && ./base64 "$T/in" | ./base64 -d >/dev/null 2>/dev/null || true
  [[ -x ./base32    ]] && ./base32    "$T/in" >/dev/null || true
  [[ -x ./basenc    ]] && ./basenc --base64url "$T/in" >/dev/null || true

  # ── filesystem info ────────────────────────────────────────────
  [[ -x ./stat      ]] && ./stat    "$T/in" >/dev/null || true
  [[ -x ./stat      ]] && ./stat -f "$T" >/dev/null || true
  [[ -x ./stat      ]] && ./stat --printf='%s %U %G %y\n' "$T"/tree/a/file* >/dev/null 2>&1 || true
  [[ -x ./df        ]] && ./df -h  >/dev/null || true
  [[ -x ./df        ]] && ./df -i . >/dev/null || true
  [[ -x ./du        ]] && ./du -sh "$T/tree" >/dev/null || true
  [[ -x ./du        ]] && ./du -a  "$T/tree" >/dev/null || true

  # ── path utilities ─────────────────────────────────────────────
  [[ -x ./basename  ]] && ./basename /usr/local/bin/test >/dev/null || true
  [[ -x ./dirname   ]] && ./dirname  /usr/local/bin/test >/dev/null || true
  [[ -x ./readlink  ]] && ./readlink -f "$T/sym" >/dev/null 2>&1 || true
  [[ -x ./realpath  ]] && ./realpath "$T/tree/a/../d" >/dev/null || true
  [[ -x ./pathchk   ]] && ./pathchk "$T/in" >/dev/null 2>&1 || true
  [[ -x ./pwd       ]] && ./pwd >/dev/null || true
  [[ -x ./logname   ]] && ./logname >/dev/null 2>&1 || true
  [[ -x ./hostid    ]] && ./hostid  >/dev/null || true

  # ── system info / identity ─────────────────────────────────────
  [[ -x ./uname     ]] && ./uname -a >/dev/null || true
  [[ -x ./arch      ]] && ./arch >/dev/null || true
  [[ -x ./nproc     ]] && ./nproc >/dev/null || true
  [[ -x ./id        ]] && ./id >/dev/null || true
  [[ -x ./id        ]] && ./id -un >/dev/null || true
  [[ -x ./whoami    ]] && ./whoami >/dev/null || true
  [[ -x ./tty       ]] && ./tty >/dev/null 2>&1 || true
  [[ -x ./who       ]] && ./who >/dev/null 2>&1 || true
  [[ -x ./users     ]] && ./users >/dev/null 2>&1 || true
  [[ -x ./pinky     ]] && ./pinky >/dev/null 2>&1 || true

  # ── date / time ────────────────────────────────────────────────
  [[ -x ./date      ]] && ./date >/dev/null || true
  [[ -x ./date      ]] && ./date -R >/dev/null || true
  [[ -x ./date      ]] && ./date -u '+%Y-%m-%dT%H:%M:%SZ' >/dev/null || true
  [[ -x ./date      ]] && ./date -d '2024-06-15 12:00:00 UTC' '+%s' >/dev/null 2>&1 || true
  [[ -x ./sleep     ]] && ./sleep 0.01 || true

  # ── process / env ──────────────────────────────────────────────
  [[ -x ./env       ]] && ./env -i PATH=/usr/bin /usr/bin/true >/dev/null 2>&1 || true
  [[ -x ./env       ]] && ./env FOO=bar /usr/bin/printenv FOO >/dev/null 2>&1 || true
  [[ -x ./nice      ]] && ./nice -n 10 /usr/bin/true 2>/dev/null || true
  [[ -x ./nohup     ]] && ./nohup /usr/bin/true >/dev/null 2>&1 || true
  [[ -x ./timeout   ]] && ./timeout 5 /usr/bin/true >/dev/null || true
  [[ -x ./stty      ]] && ./stty -a </dev/null >/dev/null 2>&1 || true
  [[ -x ./stdbuf    ]] && ./stdbuf -oL /usr/bin/true 2>/dev/null || true

  # ── tee / pipeline ────────────────────────────────────────────
  [[ -x ./tee       ]] && seq 1 20000 | ./tee "$T/tee1" "$T/tee2" >/dev/null || true

  # ── test / [ ───────────────────────────────────────────────────
  [[ -x ./test      ]] && ./test -f "$T/in"  || true
  [[ -x ./test      ]] && ./test -d "$T/tree" || true
  [[ -x ./test      ]] && ./test 100 -gt 50  || true
  [[ -x './['       ]] && './[' -f "$T/in" ']' || true

  # ── cleanup ────────────────────────────────────────────────────
  rm -rf "$T"
  popd >/dev/null || true
}

prepare() {
  cd coreutils

  # Wipe stale profiling / BOLT artefacts from any prior run
  rm -f "$srcdir"/*.profraw
  rm -rf "$srcdir"/{bolt_profile,bolt_opt,bolt_instrumented,pgo,pgo_bin}
  mkdir -p "$srcdir"/{bolt_profile,bolt_opt,bolt_instrumented,pgo,pgo_bin}

  export SHELL=/bin/sh CONFIG_SHELL=/bin/sh

  # Faster gnulib checkout via GitHub mirror
  git submodule init
  git config submodule.gnulib.url "https://github.com/coreutils/gnulib.git"
  git submodule update --depth=1

  # Mirror submodule commits may differ from upstream — skip that check
  printf 'local-checks-to-skip = public-submodule-commit\n' > Makefile.cfg

  ./bootstrap
}

build() {
  export SHELL=/bin/sh CONFIG_SHELL=/bin/sh
  export CC=gcc CXX=g++

  local _pkgdir="$srcdir/coreutils"
  cd "$_pkgdir"

  # Preserve the user / makepkg flags verbatim.
  local USER_CFLAGS="$CFLAGS"
  local USER_CXXFLAGS="$CXXFLAGS"
  local USER_LDFLAGS="$LDFLAGS"
  local LDFLAGS_MOLD="$USER_LDFLAGS -fuse-ld=mold"

  local PGO_DIR="$srcdir/pgo"

  # ── Stage-1 flags: generate profile counters ───────────────────
  # -fprofile-generate is required in LDFLAGS as well so that LTO
  # link-time codegen emits instrumentation and libgcov is linked.
  local CFLAGS_GEN="$USER_CFLAGS -fprofile-generate=$PGO_DIR"
  local CXXFLAGS_GEN="$USER_CXXFLAGS -fprofile-generate=$PGO_DIR"
  local LDFLAGS_GEN="$LDFLAGS_MOLD -fprofile-generate=$PGO_DIR"

  # ── Stage-2 flags: consume profiles; prepare for BOLT ──────────
  # -fprofile-use and -fprofile-correction in LDFLAGS for LTO.
  # -fno-reorder-blocks-and-partition: let BOLT do the layout.
  # -Wl,--emit-relocs: BOLT needs static relocations.
  local CFLAGS_USE="$USER_CFLAGS -fprofile-use=$PGO_DIR -fprofile-correction -fno-reorder-blocks-and-partition"
  local CXXFLAGS_USE="$USER_CXXFLAGS -fprofile-use=$PGO_DIR -fprofile-correction -fno-reorder-blocks-and-partition"
  local LDFLAGS_USE="$LDFLAGS_MOLD -fprofile-use=$PGO_DIR -fprofile-correction -Wl,--emit-relocs"

  local binary_dir="src"

  # ── configure (once, with neutral flags) ───────────────────────
  env CFLAGS="$USER_CFLAGS" CXXFLAGS="$USER_CXXFLAGS" LDFLAGS="$LDFLAGS_MOLD" \
    ./configure \
      --disable-gcc-warnings \
      --prefix=/usr \
      --libexecdir=/usr/lib \
      --with-openssl \
      --enable-no-install-program=groups,hostname,kill,uptime

  # ── STAGE 1: PGO instrumentation build ─────────────────────────
  echo ">>> STAGE 1: Building with PGO instrumentation..."
  make -j"$(nproc)" V=1 SHELL=/bin/sh \
    CFLAGS="$CFLAGS_GEN" CXXFLAGS="$CXXFLAGS_GEN" LDFLAGS="$LDFLAGS_GEN"

  echo ">>> Exercising instrumented binaries for PGO profiles..."
  _exercise_binaries "$_pkgdir/$binary_dir"

  # ── STAGE 2: PGO-optimised rebuild ─────────────────────────────
  echo ">>> STAGE 2: Rebuilding with PGO profile data..."
  make clean
  make -j"$(nproc)" V=1 SHELL=/bin/sh \
    CFLAGS="$CFLAGS_USE" CXXFLAGS="$CXXFLAGS_USE" LDFLAGS="$LDFLAGS_USE"

  # Preserve PGO-optimised binaries (BOLT input + fallback)
  echo ">>> Preserving PGO-optimised binaries..."
  local preserved=0
  local bin
  for bin in "${_binary_list[@]}"; do
    if [[ -x "$binary_dir/$bin" ]]; then
      install -Dm755 "$binary_dir/$bin" "$srcdir/pgo_bin/$bin"
      preserved=$((preserved + 1))
    fi
  done
  echo ">>> Preserved $preserved PGO-optimised binaries."
  if (( preserved == 0 )); then
    echo "FATAL: No PGO binaries preserved." >&2
    return 1
  fi

  # ── STAGE 3 + 4: BOLT ─────────────────────────────────────────
  if ! command -v llvm-bolt >/dev/null 2>&1; then
    echo ">>> WARNING: llvm-bolt not found; skipping BOLT stages." >&2
    return 0
  fi

  # Stage 3: instrument each PGO binary and exercise it.
  # Instrumented copies go to bolt_instrumented/; the build tree is
  # NOT modified, so make-install later picks up clean PGO binaries.
  echo ">>> STAGE 3: BOLT instrumentation..."
  for bin in "${_binary_list[@]}"; do
    [[ -f "$srcdir/pgo_bin/$bin" ]] || continue
    llvm-bolt "$srcdir/pgo_bin/$bin" \
      -o "$srcdir/bolt_instrumented/$bin" \
      --instrument \
      --instrumentation-file="$srcdir/bolt_profile/${bin}.fdata" \
      2>/dev/null || true
  done

  echo ">>> Exercising BOLT-instrumented binaries for fdata..."
  _exercise_binaries "$srcdir/bolt_instrumented"

  # Stage 4: apply BOLT optimisations using the collected fdata.
  echo ">>> STAGE 4: Applying BOLT optimisations..."
  local bolt_ok=0
  for bin in "${_binary_list[@]}"; do
    local src_bin="$srcdir/pgo_bin/$bin"
    local fdata="$srcdir/bolt_profile/${bin}.fdata"
    local out_bin="$srcdir/bolt_opt/$bin"
    [[ -f "$src_bin" && -s "$fdata" ]] || continue
    llvm-bolt "$src_bin" \
      -o "$out_bin" \
      --data="$fdata" \
      --dyno-stats \
      --cu-processing-batch-size=64 \
      --eliminate-unreachable \
      --frame-opt=all \
      --frame-opt-rm-stores \
      --icf=all \
      --indirect-call-promotion=all \
      --jump-tables=aggressive \
      --sctc-mode=heuristic \
      --plt=all \
      --peepholes=all \
      --hot-data \
      --hot-text \
      --x86-strip-redundant-address-size \
      --reg-reassign \
      --use-aggr-reg-reassign \
      --reorder-blocks=ext-tsp \
      --reorder-functions=cdsort \
      --split-all-cold \
      --split-eh \
      --split-functions \
      --split-strategy=cdsplit && bolt_ok=$((bolt_ok + 1)) || true
  done
  echo ">>> BOLT optimised $bolt_ok binaries."
}

package() {
  cd coreutils
  export SHELL=/bin/sh CONFIG_SHELL=/bin/sh

  make DESTDIR="$pkgdir" SHELL=/bin/sh install

  # Overlay every binary: prefer BOLT+PGO, fall back to PGO-only.
  local bin_dir="$pkgdir/usr/bin"
  local bin
  for bin in "${_binary_list[@]}"; do
    if [[ -f "$srcdir/bolt_opt/$bin" ]]; then
      install -Dm755 "$srcdir/bolt_opt/$bin" "$bin_dir/$bin"
    elif [[ -f "$srcdir/pgo_bin/$bin" ]]; then
      install -Dm755 "$srcdir/pgo_bin/$bin" "$bin_dir/$bin"
    fi
  done
}
