pkgver() {
  cd "${srcdir}/${_pkgname}"
  git describe --long --tags --abbrev=8 | sed 's/^v//;s/\([^-]*-\)g/r\1/;s/-/./g'
}

# ──────────────────────────────────────────────────────────────────────
# Toolchain
# ──────────────────────────────────────────────────────────────────────

setup_llvm_toolchain() {
  export CC="clang -fuse-ld=lld"
  export CXX="clang++ -fuse-ld=lld"
  export AR=llvm-ar
  export NM=llvm-nm
  export STRIP=llvm-strip
  export RANLIB=llvm-ranlib
  export READELF=llvm-readelf
  export OBJCOPY=llvm-objcopy
  export OBJDUMP=llvm-objdump
}

# ──────────────────────────────────────────────────────────────────────
# Utility helpers
# ──────────────────────────────────────────────────────────────────────

stage_slug() {
  printf '%s' "$1" | tr ' /' '__'
}

stage_install() {
  local builddir="$1"
  local destdir="$2"

  rm -rf "$destdir"
  mkdir -p "$destdir"
  DESTDIR="$destdir" meson install -C "$builddir" --no-rebuild

  if [[ -d "$destdir/usr/lib64" ]]; then
    mkdir -p "$destdir/usr/lib"
    cp -a "$destdir/usr/lib64"/. "$destdir/usr/lib"/
    rm -rf "$destdir/usr/lib64"
  fi
}

get_stage_libdir() {
  local instroot="$1"
  local outvar="$2"

  for d in "$instroot/usr/lib" "$instroot/usr/lib64"; do
    if [[ -d "$d" ]]; then
      printf -v "$outvar" '%s' "$d"
      return 0
    fi
  done
  return 1
}

verify_expected_sonames() {
  local libdir="$1"

  local -A expected_sonames=(
    [libEGL.so]=1
    [libGL.so]=1
    [libGLESv1_CM.so]=1
    [libGLESv2.so]=2
    [libGLX.so]=0
    [libGLdispatch.so]=0
    [libOpenGL.so]=0
  )

  local base major soname link target actual
  for base in "${!expected_sonames[@]}"; do
    major="${expected_sonames[$base]}"
    soname="${base}.${major}"
    link="${libdir}/${soname}"

    if [[ ! -e "$link" ]]; then
      echo "Error: expected SONAME link missing: $link" >&2
      return 1
    fi

    target="$(readlink -f "$link")"
    if [[ -z "$target" || ! -f "$target" ]]; then
      echo "Error: could not resolve real shared object for $link" >&2
      return 1
    fi

    actual="$("${READELF:-readelf}" -d "$target" 2>/dev/null | sed -n 's/.*SONAME.*\[\(.*\)\].*/\1/p' | head -n1)"
    if [[ "$actual" != "$soname" ]]; then
      echo "Error: SONAME mismatch for $target: expected $soname, got ${actual:-<none>}" >&2
      return 1
    fi
  done
}

show_generated_profiles() {
  local profdir="$1"
  local label="$2"
  local count

  count=$(find "$profdir" -maxdepth 1 -name '*.profraw' 2>/dev/null | wc -l)
  echo "  -> ${label}: generated ${count} raw profile file(s)"
  find "$profdir" -maxdepth 1 -name '*.profraw' -printf '     %f\n' 2>/dev/null | head -20 || true
}

show_bolt_fdata() {
  local bolt_dir="$1"
  local so_name="$2"

  echo "  -> BOLT fdata files for ${so_name}:"
  if compgen -G "${bolt_dir}/${so_name}.fdata*" >/dev/null; then
    ls -lh "${bolt_dir}/${so_name}.fdata"* 2>/dev/null || true
  else
    echo "     (none)"
  fi
}

collect_bolt_targets() {
  local buildroot="$1"
  local -n _out_ref="$2"
  _out_ref=()

  local -a patterns=(
    'libGLdispatch.so*'
    'libGLX.so*'
    'libOpenGL.so*'
    'libEGL.so*'
    'libGLESv1_CM.so*'
    'libGLESv2.so*'
    'libGL.so*'
  )

  local -A seen=()
  local pattern file

  for pattern in "${patterns[@]}"; do
    while IFS= read -r -d '' file; do
      [[ -L "$file" ]] && continue
      [[ -f "$file" ]] || continue
      "${READELF:-readelf}" -h "$file" >/dev/null 2>&1 || continue
      [[ -n "${seen[$file]:-}" ]] && continue
      seen["$file"]=1
      _out_ref+=("$file")
    done < <(find "$buildroot" -type f -name "$pattern" -print0 2>/dev/null)
  done

  echo "=== BOLT target discovery ==="
  local item
  for item in "${_out_ref[@]}"; do
    echo "  -> $item"
  done
  echo "=== End BOLT target discovery ==="
}

probe_c_feature() {
  local incdir="$1"
  local code="$2"

  printf '%s\n' "$code" | \
    clang -std=gnu17 -fsyntax-only -x c - \
      -I"$incdir" -I/usr/include \
      >/dev/null 2>&1
}

detect_glvnd_optional_apis() {
  local incdir="$1"
  local libdir="$2"
  local out_gles1="$3"

  local have_gles1=0

  if probe_c_feature "$incdir" '
    #include <GLES/gl.h>
    int main(void) { glClear(GL_COLOR_BUFFER_BIT); return 0; }
  '; then
    if find "$libdir" -maxdepth 1 \( -type f -o -type l \) -name 'libGLESv1_CM.so*' | grep -q .; then
      have_gles1=1
    fi
  fi

  printf -v "$out_gles1" '%d' "$have_gles1"
}

# ──────────────────────────────────────────────────────────────────────
# PGO / BOLT workload — comprehensive libglvnd dispatch exerciser
#
# Key insight: libglvnd is a DISPATCH library.  The performance-critical
# code is:
#   1. Dispatch table generation and patching (entrypoint stubs)
#   2. Thread-local dispatch table lookups (__glDispatch_*)
#   3. Vendor string / extension queries through the dispatch layer
#   4. glXGetProcAddress / eglGetProcAddress resolution
#   5. Dynamic vendor loading / context creation & destruction
#   6. Concurrent multi-threaded access to all of the above
#   7. dlopen/dlsym of the libraries themselves
#
# The previous workload only scratched #4 and #7 lightly.
# This version massively expands coverage of all 7 areas.
# ──────────────────────────────────────────────────────────────────────

create_glvnd_workload_source() {
  cat > "${srcdir}/glvnd_pgo_workload.c" <<'CEOF'
#define _GNU_SOURCE

#ifndef HAVE_GLES1_API
#define HAVE_GLES1_API 0
#endif

#include <stdbool.h>
#include <stdint.h>
#include <pthread.h>
#include <sched.h>
#include <X11/Xlib.h>
#include <X11/Xutil.h>
#include <GL/gl.h>
#include <GL/glx.h>
#include <EGL/egl.h>
#include <GLES2/gl2.h>
#if HAVE_GLES1_API
#include <GLES/gl.h>
#endif
#include <dlfcn.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <time.h>

#ifndef EGL_PLATFORM_SURFACELESS_MESA
#define EGL_PLATFORM_SURFACELESS_MESA 0x31DD
#endif

typedef EGLDisplay (*PFNEGLGETPLATFORMDISPLAYEXTPROC)(EGLenum, void*, const EGLint*);

/* ── Utility ────────────────────────────────────────────────────── */

static double now_sec(void) {
  struct timespec ts;
  clock_gettime(CLOCK_MONOTONIC, &ts);
  return (double)ts.tv_sec + (double)ts.tv_nsec * 1e-9;
}

static void print_loaded_libs(void) {
  Dl_info info;
  if (dladdr((void*)&glXQueryVersion,   &info) && info.dli_fname) printf("  libGLX:       %s\n", info.dli_fname);
  if (dladdr((void*)&eglInitialize,     &info) && info.dli_fname) printf("  libEGL:       %s\n", info.dli_fname);
  if (dladdr((void*)&glGetString,       &info) && info.dli_fname) printf("  libGL/disp:   %s\n", info.dli_fname);
  if (dladdr((void*)&glCreateShader,    &info) && info.dli_fname) printf("  libGLESv2:    %s\n", info.dli_fname);
#if HAVE_GLES1_API
  if (dladdr((void*)&glClearColorx,     &info) && info.dli_fname) printf("  libGLESv1:    %s\n", info.dli_fname);
#endif
}

/* ── 1. Massive dlopen/dlsym churn ──────────────────────────────
 * Each dlopen forces libglvnd to initialize its internal vendor
 * tracking, dispatch stubs, and TLS slots.  dlclose tears them
 * down.  This exercises the hottest constructor/destructor paths. */

static void ex_dlopen_churn(int loops) {
  static const char *libs[] = {
    "libGL.so.1",
    "libOpenGL.so.0",
    "libGLX.so.0",
    "libEGL.so.1",
    "libGLESv2.so.2",
    "libGLdispatch.so.0",
#if HAVE_GLES1_API
    "libGLESv1_CM.so.1",
#endif
  };
  static const int nlibs = sizeof(libs)/sizeof(libs[0]);

  /* Symbols to probe — covering every major dispatch category */
  static const char *syms[] = {
    /* GLX */
    "glXQueryVersion", "glXGetProcAddressARB", "glXChooseVisual",
    "glXCreateContext", "glXDestroyContext", "glXMakeCurrent",
    "glXSwapBuffers", "glXChooseFBConfig", "glXCreateNewContext",
    "glXCreatePbuffer", "glXDestroyPbuffer", "glXMakeContextCurrent",
    "glXGetCurrentContext", "glXGetCurrentDisplay", "glXGetCurrentDrawable",
    "glXQueryExtensionsString", "glXGetClientString", "glXQueryServerString",
    "glXIsDirect", "glXWaitGL", "glXWaitX", "glXGetFBConfigAttrib",
    "glXGetVisualFromFBConfig",
    /* EGL */
    "eglInitialize", "eglTerminate", "eglGetProcAddress",
    "eglGetDisplay", "eglChooseConfig", "eglCreateContext",
    "eglDestroyContext", "eglCreatePbufferSurface", "eglDestroySurface",
    "eglMakeCurrent", "eglSwapBuffers", "eglBindAPI",
    "eglQueryString", "eglGetError", "eglWaitGL", "eglWaitNative",
    "eglGetCurrentContext", "eglGetCurrentDisplay", "eglGetCurrentSurface",
    "eglReleaseThread", "eglCreateImage", "eglDestroyImage",
    /* GL core */
    "glGetString", "glGetIntegerv", "glGetFloatv", "glGetBooleanv",
    "glGetError", "glEnable", "glDisable", "glIsEnabled",
    "glViewport", "glScissor", "glClear", "glClearColor",
    "glFinish", "glFlush",
    /* Textures */
    "glGenTextures", "glDeleteTextures", "glBindTexture",
    "glTexImage2D", "glTexSubImage2D", "glTexParameteri",
    "glActiveTexture", "glGenerateMipmap",
    /* Buffers */
    "glGenBuffers", "glDeleteBuffers", "glBindBuffer",
    "glBufferData", "glBufferSubData", "glMapBuffer", "glUnmapBuffer",
    /* Shaders */
    "glCreateShader", "glDeleteShader", "glShaderSource", "glCompileShader",
    "glCreateProgram", "glDeleteProgram", "glAttachShader", "glDetachShader",
    "glLinkProgram", "glUseProgram", "glGetUniformLocation",
    "glUniform1f", "glUniform2f", "glUniform3f", "glUniform4f",
    "glUniform1i", "glUniformMatrix4fv",
    /* Vertex attribs */
    "glVertexAttribPointer", "glEnableVertexAttribArray",
    "glDisableVertexAttribArray", "glBindAttribLocation",
    /* Draw */
    "glDrawArrays", "glDrawElements", "glDrawArraysInstanced",
    "glDrawElementsInstanced",
    /* Framebuffers */
    "glGenFramebuffers", "glDeleteFramebuffers", "glBindFramebuffer",
    "glFramebufferTexture2D", "glCheckFramebufferStatus",
    "glBlitFramebuffer",
    /* Renderbuffers */
    "glGenRenderbuffers", "glDeleteRenderbuffers", "glBindRenderbuffer",
    "glRenderbufferStorage",
    /* Sync */
    "glFenceSync", "glDeleteSync", "glClientWaitSync", "glWaitSync",
    /* VAO */
    "glGenVertexArrays", "glDeleteVertexArrays", "glBindVertexArray",
    /* Queries */
    "glGenQueries", "glDeleteQueries", "glBeginQuery", "glEndQuery",
    "glGetQueryObjectiv", "glGetQueryObjectuiv",
    /* Blend / Stencil / Depth */
    "glBlendFunc", "glBlendFuncSeparate", "glBlendEquation",
    "glDepthFunc", "glDepthMask", "glStencilFunc", "glStencilOp",
    "glColorMask", "glCullFace", "glFrontFace", "glPolygonMode",
    "glPolygonOffset", "glLineWidth", "glPointSize",
    /* Sampler */
    "glGenSamplers", "glDeleteSamplers", "glBindSampler",
    "glSamplerParameteri",
    /* Transform feedback */
    "glBeginTransformFeedback", "glEndTransformFeedback",
    "glTransformFeedbackVaryings",
    /* Compute (may not resolve but the lookup itself exercises dispatch) */
    "glDispatchCompute", "glMemoryBarrier",
    /* Multi-bind (GL 4.4+) */
    "glBindBuffersBase", "glBindTextures", "glBindSamplers",
    /* DSA (GL 4.5+) */
    "glCreateBuffers", "glNamedBufferData", "glCreateTextures",
    "glTextureStorage2D", "glCreateFramebuffers",
    "glNamedFramebufferTexture",
  };
  static const int nsyms = sizeof(syms)/sizeof(syms[0]);

  printf("  dlopen-churn: %d loops x %d libs x %d syms\n", loops, nlibs, nsyms);

  for (int i = 0; i < loops; i++) {
    for (int l = 0; l < nlibs; l++) {
      void *h = dlopen(libs[l], RTLD_LAZY | RTLD_LOCAL);
      if (!h) continue;

      for (int s = 0; s < nsyms; s++)
        (void)dlsym(h, syms[s]);

      dlclose(h);
    }

    /* Also exercise RTLD_NOW which forces all relocations immediately */
    if ((i & 3) == 0) {
      for (int l = 0; l < nlibs; l++) {
        void *h = dlopen(libs[l], RTLD_NOW | RTLD_LOCAL);
        if (!h) continue;
        for (int s = 0; s < nsyms; s++)
          (void)dlsym(h, syms[s]);
        dlclose(h);
      }
    }

    /* Nested opens: open all at once, resolve cross-lib, close all */
    if ((i & 7) == 0) {
      void *handles[sizeof(libs)/sizeof(libs[0])] = {0};
      for (int l = 0; l < nlibs; l++)
        handles[l] = dlopen(libs[l], RTLD_LAZY | RTLD_GLOBAL);
      for (int l = 0; l < nlibs; l++) {
        if (!handles[l]) continue;
        for (int s = 0; s < nsyms; s++)
          (void)dlsym(handles[l], syms[s]);
      }
      /* Close in reverse order */
      for (int l = nlibs - 1; l >= 0; l--) {
        if (handles[l]) dlclose(handles[l]);
      }
    }
  }
}

/* ── 2. Massive GetProcAddress stress ───────────────────────────
 * This is the #1 hot path in libglvnd for any real application.
 * We hammer both glXGetProcAddressARB and eglGetProcAddress
 * from multiple threads with hundreds of symbol names. */

