};
static const int g_nprocaddr_syms = sizeof(g_procaddr_syms)/sizeof(g_procaddr_syms[0]);

struct procaddr_thread_arg {
  int loops;
  int thread_id;
};

static void *procaddr_thread_fn(void *arg) {
  struct procaddr_thread_arg *a = (struct procaddr_thread_arg *)arg;

  /* Each thread does lookups in a different order to create contention */
  int start = (a->thread_id * 37) % g_nprocaddr_syms;

  for (int i = 0; i < a->loops; i++) {
    for (int j = 0; j < g_nprocaddr_syms; j++) {
      int idx = (start + j) % g_nprocaddr_syms;
      (void)glXGetProcAddressARB((const GLubyte *)g_procaddr_syms[idx]);
      (void)eglGetProcAddress(g_procaddr_syms[idx]);
    }
  }

  return NULL;
}

static void ex_procaddr_stress(bool bolt_mode) {
  int nthreads = 8;
  int loops = bolt_mode ? 50 : 20;

  printf("  procaddr-stress: %d threads x %d loops x %d syms\n",
         nthreads, loops, g_nprocaddr_syms);

  pthread_t threads[8];
  struct procaddr_thread_arg args[8];

  for (int i = 0; i < nthreads; i++) {
    args[i].loops = loops;
    args[i].thread_id = i;
    pthread_create(&threads[i], NULL, procaddr_thread_fn, &args[i]);
  }

  for (int i = 0; i < nthreads; i++)
    pthread_join(threads[i], NULL);
}

/* ── 3. GLX context create/destroy churn ────────────────────────
 * Each glXCreateContext/glXDestroyContext pair exercises the
 * vendor dispatch lookup, TLS slot allocation, and dispatch table
 * patching in libglvnd. */

static void ex_glx_context_churn(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  if (!dpy) { printf("  glx-context-churn: no display\n"); return; }

  int screen = DefaultScreen(dpy);
  int loops = bolt_mode ? 500 : 200;

  int attribs[] = { GLX_RGBA, GLX_DEPTH_SIZE, 24, GLX_DOUBLEBUFFER, None };
  XVisualInfo *vi = glXChooseVisual(dpy, screen, attribs);
  if (!vi) { XCloseDisplay(dpy); printf("  glx-context-churn: no visual\n"); return; }

  printf("  glx-context-churn: %d create/destroy cycles\n", loops);

  for (int i = 0; i < loops; i++) {
    GLXContext ctx = glXCreateContext(dpy, vi, NULL, True);
    if (ctx) {
      /* Query before making current — exercises dispatch in "no context" state */
      (void)glXGetCurrentContext();
      (void)glXGetCurrentDisplay();

      glXDestroyContext(dpy, ctx);
    }
  }

  /* Also exercise shared contexts */
  GLXContext base = glXCreateContext(dpy, vi, NULL, True);
  if (base) {
    for (int i = 0; i < (bolt_mode ? 200 : 80); i++) {
      GLXContext shared = glXCreateContext(dpy, vi, base, True);
      if (shared) {
        glXDestroyContext(dpy, shared);
      }
    }
    glXDestroyContext(dpy, base);
  }

  XFree(vi);
  XCloseDisplay(dpy);
}

/* ── 4. GLX FBConfig enumeration and query ──────────────────────
 * Real apps iterate all FBConfigs and query their attributes.
 * This exercises the GLX dispatch layer's config handling. */

static void ex_glx_fbconfig_enumerate(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  if (!dpy) { printf("  glx-fbconfig-enum: no display\n"); return; }

  int screen = DefaultScreen(dpy);
  int loops = bolt_mode ? 100 : 40;

  printf("  glx-fbconfig-enum: %d full enumeration passes\n", loops);

  for (int i = 0; i < loops; i++) {
    int ncfg = 0;
    GLXFBConfig *cfgs = glXGetFBConfigs(dpy, screen, &ncfg);
    if (!cfgs) continue;

    /* Query every attribute of every config */
    static const int query_attrs[] = {
      GLX_FBCONFIG_ID, GLX_BUFFER_SIZE, GLX_LEVEL,
      GLX_DOUBLEBUFFER, GLX_STEREO,
      GLX_AUX_BUFFERS, GLX_RED_SIZE, GLX_GREEN_SIZE, GLX_BLUE_SIZE,
      GLX_ALPHA_SIZE, GLX_DEPTH_SIZE, GLX_STENCIL_SIZE,
      GLX_ACCUM_RED_SIZE, GLX_ACCUM_GREEN_SIZE,
      GLX_ACCUM_BLUE_SIZE, GLX_ACCUM_ALPHA_SIZE,
      GLX_RENDER_TYPE, GLX_DRAWABLE_TYPE,
      GLX_X_RENDERABLE, GLX_X_VISUAL_TYPE,
      GLX_CONFIG_CAVEAT, GLX_TRANSPARENT_TYPE,
      GLX_SAMPLE_BUFFERS, GLX_SAMPLES,
      GLX_MAX_PBUFFER_WIDTH, GLX_MAX_PBUFFER_HEIGHT, GLX_MAX_PBUFFER_PIXELS,
    };
    static const int nqattrs = sizeof(query_attrs)/sizeof(query_attrs[0]);

    for (int c = 0; c < ncfg; c++) {
      int val;
      for (int a = 0; a < nqattrs; a++) {
        glXGetFBConfigAttrib(dpy, cfgs[c], query_attrs[a], &val);
      }
      /* Also get the visual */
      XVisualInfo *xvi = glXGetVisualFromFBConfig(dpy, cfgs[c]);
      if (xvi) XFree(xvi);
    }

    XFree(cfgs);
  }

  XCloseDisplay(dpy);
}

/* ── 5. GLX rendering with context switching ────────────────────
 * Create multiple contexts and rapidly switch between them.
 * This is the hot path for multi-context renderers (compositors,
 * multi-viewport apps). */

static void ex_glx_context_switch(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  if (!dpy) { printf("  glx-ctx-switch: no display\n"); return; }

  int screen = DefaultScreen(dpy);
  int loops = bolt_mode ? 800 : 300;

  int attribs[] = {
    GLX_RENDER_TYPE, GLX_RGBA_BIT,
    GLX_DRAWABLE_TYPE, GLX_PBUFFER_BIT,
    GLX_DOUBLEBUFFER, False,
    None
  };
  int ncfg = 0;
  GLXFBConfig *cfgs = glXChooseFBConfig(dpy, screen, attribs, &ncfg);
  if (!cfgs || ncfg < 1) {
    if (cfgs) XFree(cfgs);
    XCloseDisplay(dpy);
    printf("  glx-ctx-switch: no fbconfig\n");
    return;
  }

  int pb_attrs[] = { GLX_PBUFFER_WIDTH, 64, GLX_PBUFFER_HEIGHT, 64, None };
  GLXPbuffer pb1 = glXCreatePbuffer(dpy, cfgs[0], pb_attrs);
  GLXPbuffer pb2 = glXCreatePbuffer(dpy, cfgs[0], pb_attrs);

  GLXContext ctx1 = glXCreateNewContext(dpy, cfgs[0], GLX_RGBA_TYPE, NULL, True);
  GLXContext ctx2 = glXCreateNewContext(dpy, cfgs[0], GLX_RGBA_TYPE, NULL, True);

  if (!ctx1 || !ctx2 || !pb1 || !pb2) {
    if (ctx1) glXDestroyContext(dpy, ctx1);
    if (ctx2) glXDestroyContext(dpy, ctx2);
    if (pb1) glXDestroyPbuffer(dpy, pb1);
    if (pb2) glXDestroyPbuffer(dpy, pb2);
    XFree(cfgs);
    XCloseDisplay(dpy);
    printf("  glx-ctx-switch: setup failed\n");
    return;
  }

  printf("  glx-ctx-switch: %d rapid switches\n", loops);

  for (int i = 0; i < loops; i++) {
    /* Switch to context 1 */
    glXMakeContextCurrent(dpy, pb1, pb1, ctx1);

    (void)glXGetCurrentContext();
    (void)glGetString(GL_VENDOR);
    (void)glGetString(GL_RENDERER);
    glViewport(0, 0, 64, 64);
    glClearColor(1.0f, 0.0f, 0.0f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT);

    /* Switch to context 2 */
    glXMakeContextCurrent(dpy, pb2, pb2, ctx2);

    (void)glXGetCurrentContext();
    (void)glGetString(GL_VENDOR);
    (void)glGetString(GL_VERSION);
    glViewport(0, 0, 64, 64);
    glClearColor(0.0f, 1.0f, 0.0f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT);

    /* Switch to no context */
    glXMakeContextCurrent(dpy, None, None, NULL);

    /* Verify dispatch table was cleared */
    (void)glXGetCurrentContext();
  }

  glXDestroyContext(dpy, ctx1);
  glXDestroyContext(dpy, ctx2);
  glXDestroyPbuffer(dpy, pb1);
  glXDestroyPbuffer(dpy, pb2);
  XFree(cfgs);
  XCloseDisplay(dpy);
}

/* ── 6. Full GLX rendering pipeline ────────────────────────────
 * Exercises the full GL dispatch path through libglvnd:
 * setup, clear, draw, state queries, swap. */

static void ex_glx_rendering(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  if (!dpy) { printf("  glx-rendering: no display\n"); return; }

  int screen = DefaultScreen(dpy);
  int loops = bolt_mode ? 1000 : 400;

  int attribs[] = { GLX_RGBA, GLX_DEPTH_SIZE, 24, GLX_DOUBLEBUFFER, None };
  XVisualInfo *vi = glXChooseVisual(dpy, screen, attribs);
  if (!vi) { XCloseDisplay(dpy); return; }

  GLXContext ctx = glXCreateContext(dpy, vi, NULL, True);
  if (!ctx) { XFree(vi); XCloseDisplay(dpy); return; }

  Window root = RootWindow(dpy, screen);
  Colormap cmap = XCreateColormap(dpy, root, vi->visual, AllocNone);
  XSetWindowAttributes swa = {0};
  swa.colormap = cmap;

  Window win = XCreateWindow(dpy, root, 0, 0, 320, 240, 0,
                             vi->depth, InputOutput, vi->visual,
                             CWColormap, &swa);
  XMapWindow(dpy, win);
  XSync(dpy, False);

  if (!glXMakeCurrent(dpy, win, ctx)) {
    glXDestroyContext(dpy, ctx);
    XDestroyWindow(dpy, win);
    XFreeColormap(dpy, cmap);
    XFree(vi);
    XCloseDisplay(dpy);
    return;
  }

  printf("  glx-rendering: %d frames\n", loops);

  for (int i = 0; i < loops; i++) {
    /* Extension string queries (exercises vendor dispatch) */
    (void)glXQueryExtensionsString(dpy, screen);
    (void)glXGetClientString(dpy, GLX_VENDOR);
    (void)glXGetClientString(dpy, GLX_VERSION);
    (void)glXGetClientString(dpy, GLX_EXTENSIONS);
    (void)glXQueryServerString(dpy, screen, GLX_VENDOR);
    (void)glXQueryServerString(dpy, screen, GLX_VERSION);
    (void)glXQueryServerString(dpy, screen, GLX_EXTENSIONS);

    /* ProcAddress lookups interspersed with rendering */
    (void)glXGetProcAddressARB((const GLubyte*)"glBindTexture");
    (void)glXGetProcAddressARB((const GLubyte*)"glFenceSync");
    (void)glXGetProcAddressARB((const GLubyte*)"glCreateShader");
    (void)glXGetProcAddressARB((const GLubyte*)"glBufferData");
    (void)glXGetProcAddressARB((const GLubyte*)"glVertexAttribPointer");
    (void)glXGetProcAddressARB((const GLubyte*)"glDrawElementsInstanced");
    (void)glXGetProcAddressARB((const GLubyte*)"glMapBufferRange");
    (void)glXGetProcAddressARB((const GLubyte*)"glGenVertexArrays");

    /* GL state queries */
    (void)glGetString(GL_VENDOR);
    (void)glGetString(GL_RENDERER);
    (void)glGetString(GL_VERSION);
    (void)glGetString(GL_SHADING_LANGUAGE_VERSION);
    (void)glGetString(GL_EXTENSIONS);

    GLint v = 0;
    glGetIntegerv(GL_MAX_TEXTURE_SIZE, &v);
    glGetIntegerv(GL_MAX_VIEWPORT_DIMS, &v);
    glGetIntegerv(GL_MAX_COMBINED_TEXTURE_IMAGE_UNITS, &v);
    glGetIntegerv(GL_MAX_VERTEX_ATTRIBS, &v);
    glGetIntegerv(GL_MAX_DRAW_BUFFERS, &v);
    glGetIntegerv(GL_MAX_COLOR_ATTACHMENTS, &v);
    glGetIntegerv(GL_MAX_RENDERBUFFER_SIZE, &v);
    glGetIntegerv(GL_MAX_SAMPLES, &v);
    glGetIntegerv(GL_VIEWPORT, &v);

    GLfloat fv[4] = {0};
    glGetFloatv(GL_COLOR_CLEAR_VALUE, fv);
    glGetFloatv(GL_DEPTH_CLEAR_VALUE, fv);
    glGetFloatv(GL_LINE_WIDTH_RANGE, fv);

    GLboolean bv = GL_FALSE;
    glGetBooleanv(GL_DEPTH_WRITEMASK, &bv);
    glGetBooleanv(GL_BLEND, &bv);

    /* State changes */
    glViewport(0, 0, 320, 240);
    glScissor(0, 0, 320, 240);
    glEnable(GL_DEPTH_TEST);
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glDepthFunc(GL_LESS);
    glCullFace(GL_BACK);
    glFrontFace(GL_CCW);

    glClearColor((float)(i & 1), 0.2f, 0.3f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT | GL_STENCIL_BUFFER_BIT);

    /* Legacy immediate mode (exercises different dispatch path) */
    glBegin(GL_TRIANGLES);
    glColor3f(1.f, 0.f, 0.f); glVertex3f(-0.5f, -0.5f, 0.0f);
    glColor3f(0.f, 1.f, 0.f); glVertex3f( 0.5f, -0.5f, 0.0f);
    glColor3f(0.f, 0.f, 1.f); glVertex3f( 0.0f,  0.5f, 0.0f);
    glEnd();

    glBegin(GL_QUADS);
    glColor3f(0.5f, 0.5f, 0.0f);
    glVertex2f(-0.8f, -0.8f);
    glVertex2f( 0.8f, -0.8f);
    glVertex2f( 0.8f,  0.8f);
    glVertex2f(-0.8f,  0.8f);
    glEnd();

    glBegin(GL_LINES);
    for (int j = 0; j < 10; j++) {
      float x = (float)j / 10.0f * 2.0f - 1.0f;
      glVertex2f(x, -1.0f);
      glVertex2f(x,  1.0f);
    }
    glEnd();

    glBegin(GL_POINTS);
    for (int j = 0; j < 20; j++) {
      glVertex2f((float)(j % 5) / 5.0f, (float)(j / 5) / 4.0f);
    }
    glEnd();

    glDisable(GL_DEPTH_TEST);
    glDisable(GL_BLEND);

    glXSwapBuffers(dpy, win);

    if ((i & 63) == 0) {
      glFinish();
      (void)glXIsDirect(dpy, ctx);
      glXWaitGL();
      glXWaitX();
    }
  }

  glXMakeCurrent(dpy, None, NULL);
  glXDestroyContext(dpy, ctx);
  XDestroyWindow(dpy, win);
  XFreeColormap(dpy, cmap);
  XFree(vi);
  XCloseDisplay(dpy);
}

/* ── 7. EGL full exerciser ──────────────────────────────────────
 * Context creation, queries, display enumeration, API switching */

static EGLDisplay open_egl_display(Display *x11_dpy) {
  EGLDisplay edpy = EGL_NO_DISPLAY;

  if (x11_dpy)
    edpy = eglGetDisplay((EGLNativeDisplayType)x11_dpy);

  if (edpy == EGL_NO_DISPLAY) {
    PFNEGLGETPLATFORMDISPLAYEXTPROC getpd =
      (PFNEGLGETPLATFORMDISPLAYEXTPROC)eglGetProcAddress("eglGetPlatformDisplayEXT");
    if (getpd)
      edpy = getpd(EGL_PLATFORM_SURFACELESS_MESA, NULL, NULL);
  }

  if (edpy == EGL_NO_DISPLAY)
    edpy = eglGetDisplay(EGL_DEFAULT_DISPLAY);

  return edpy;
}

static void ex_egl_context_churn(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  EGLDisplay edpy = open_egl_display(dpy);
  if (edpy == EGL_NO_DISPLAY) {
    if (dpy) XCloseDisplay(dpy);
    printf("  egl-ctx-churn: no display\n");
    return;
  }

  EGLint maj, min;
  if (!eglInitialize(edpy, &maj, &min)) {
    if (dpy) XCloseDisplay(dpy);
    printf("  egl-ctx-churn: init failed\n");
    return;
  }

  int loops = bolt_mode ? 400 : 150;

  /* Query strings extensively */
  for (int i = 0; i < (bolt_mode ? 200 : 80); i++) {
    (void)eglQueryString(edpy, EGL_VENDOR);
    (void)eglQueryString(edpy, EGL_VERSION);
    (void)eglQueryString(edpy, EGL_EXTENSIONS);
    (void)eglQueryString(edpy, EGL_CLIENT_APIS);
    (void)eglQueryString(EGL_NO_DISPLAY, EGL_EXTENSIONS);
    (void)eglGetError();
  }

  /* Context churn for OpenGL API */
  EGLConfig cfg;
  EGLint ncfg;
  EGLint gl_attrs[] = {
    EGL_SURFACE_TYPE, EGL_PBUFFER_BIT,
    EGL_RENDERABLE_TYPE, EGL_OPENGL_BIT,
    EGL_NONE
  };

  if (eglChooseConfig(edpy, gl_attrs, &cfg, 1, &ncfg) && ncfg > 0) {
    eglBindAPI(EGL_OPENGL_API);

    EGLint pb[] = { EGL_WIDTH, 64, EGL_HEIGHT, 64, EGL_NONE };
    EGLSurface surf = eglCreatePbufferSurface(edpy, cfg, pb);

    printf("  egl-ctx-churn (GL): %d cycles\n", loops);
    for (int i = 0; i < loops; i++) {
      EGLContext ctx = eglCreateContext(edpy, cfg, EGL_NO_CONTEXT, NULL);
      if (ctx != EGL_NO_CONTEXT) {
        if (surf != EGL_NO_SURFACE) {
          eglMakeCurrent(edpy, surf, surf, ctx);
          (void)glGetString(GL_VENDOR);
          (void)glGetString(GL_RENDERER);
          glViewport(0, 0, 64, 64);
          glClear(GL_COLOR_BUFFER_BIT);
          eglMakeCurrent(edpy, EGL_NO_SURFACE, EGL_NO_SURFACE, EGL_NO_CONTEXT);
        }
        eglDestroyContext(edpy, ctx);
      }
    }

    if (surf != EGL_NO_SURFACE) eglDestroySurface(edpy, surf);
  }

  /* Context churn for GLES2 API */
  EGLint es2_attrs[] = {
    EGL_SURFACE_TYPE, EGL_PBUFFER_BIT,
    EGL_RENDERABLE_TYPE, EGL_OPENGL_ES2_BIT,
    EGL_NONE
  };

  if (eglChooseConfig(edpy, es2_attrs, &cfg, 1, &ncfg) && ncfg > 0) {
    eglBindAPI(EGL_OPENGL_ES_API);

    EGLint pb[] = { EGL_WIDTH, 64, EGL_HEIGHT, 64, EGL_NONE };
    EGLSurface surf = eglCreatePbufferSurface(edpy, cfg, pb);
    EGLint ctx_attrs[] = { EGL_CONTEXT_CLIENT_VERSION, 2, EGL_NONE };

    printf("  egl-ctx-churn (ES2): %d cycles\n", loops);
    for (int i = 0; i < loops; i++) {
      EGLContext ctx = eglCreateContext(edpy, cfg, EGL_NO_CONTEXT, ctx_attrs);
      if (ctx != EGL_NO_CONTEXT) {
        if (surf != EGL_NO_SURFACE) {
          eglMakeCurrent(edpy, surf, surf, ctx);
          (void)glGetString(GL_VENDOR);
          glClear(GL_COLOR_BUFFER_BIT);
          eglMakeCurrent(edpy, EGL_NO_SURFACE, EGL_NO_SURFACE, EGL_NO_CONTEXT);
        }
        eglDestroyContext(edpy, ctx);
      }
    }

    if (surf != EGL_NO_SURFACE) eglDestroySurface(edpy, surf);
  }

  /* API binding churn */
  printf("  egl-api-switch: %d cycles\n", bolt_mode ? 2000 : 800);
  for (int i = 0; i < (bolt_mode ? 2000 : 800); i++) {
    eglBindAPI(EGL_OPENGL_API);
    (void)eglGetError();
    eglBindAPI(EGL_OPENGL_ES_API);
    (void)eglGetError();
    (void)eglGetCurrentContext();
    (void)eglGetCurrentDisplay();
    (void)eglGetCurrentSurface(EGL_READ);
    (void)eglGetCurrentSurface(EGL_DRAW);
  }

  /* Config enumeration */
  printf("  egl-config-enum: full enumeration\n");
  for (int pass = 0; pass < (bolt_mode ? 50 : 20); pass++) {
    EGLint total_configs = 0;
    eglGetConfigs(edpy, NULL, 0, &total_configs);

    if (total_configs > 0) {
      EGLConfig *all_cfgs = calloc(total_configs, sizeof(EGLConfig));
      if (all_cfgs) {
        EGLint got = 0;
        eglGetConfigs(edpy, all_cfgs, total_configs, &got);

        static const EGLint query_attrs[] = {
          EGL_CONFIG_ID, EGL_BUFFER_SIZE, EGL_RED_SIZE, EGL_GREEN_SIZE,
          EGL_BLUE_SIZE, EGL_ALPHA_SIZE, EGL_DEPTH_SIZE, EGL_STENCIL_SIZE,
          EGL_SURFACE_TYPE, EGL_RENDERABLE_TYPE, EGL_CONFORMANT,
          EGL_NATIVE_RENDERABLE, EGL_SAMPLE_BUFFERS, EGL_SAMPLES,
          EGL_MAX_PBUFFER_WIDTH, EGL_MAX_PBUFFER_HEIGHT, EGL_MAX_PBUFFER_PIXELS,
          EGL_TRANSPARENT_TYPE, EGL_LEVEL, EGL_CONFIG_CAVEAT,
          EGL_MIN_SWAP_INTERVAL, EGL_MAX_SWAP_INTERVAL,
          EGL_NATIVE_VISUAL_ID, EGL_NATIVE_VISUAL_TYPE,
          EGL_BIND_TO_TEXTURE_RGB, EGL_BIND_TO_TEXTURE_RGBA,
          EGL_LUMINANCE_SIZE, EGL_ALPHA_MASK_SIZE,
          EGL_COLOR_BUFFER_TYPE,
        };
        static const int nqa = sizeof(query_attrs)/sizeof(query_attrs[0]);

        for (EGLint c = 0; c < got; c++) {
          EGLint val;
          for (int a = 0; a < nqa; a++)
            eglGetConfigAttrib(edpy, all_cfgs[c], query_attrs[a], &val);
        }

        free(all_cfgs);
      }
    }
  }

  eglTerminate(edpy);
  if (dpy) XCloseDisplay(dpy);
}

/* ── 8. EGL + GL rendering ──────────────────────────────────── */

static void ex_egl_gl_rendering(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  EGLDisplay edpy = open_egl_display(dpy);
  if (edpy == EGL_NO_DISPLAY) {
    if (dpy) XCloseDisplay(dpy);
    printf("  egl-gl-render: no display\n");
    return;
  }

  EGLint maj, min;
  if (!eglInitialize(edpy, &maj, &min)) {
    if (dpy) XCloseDisplay(dpy);
    return;
  }

  int loops = bolt_mode ? 800 : 300;

  EGLConfig cfg; EGLint ncfg;
  EGLint attrs[] = {
    EGL_SURFACE_TYPE, EGL_PBUFFER_BIT,
    EGL_RENDERABLE_TYPE, EGL_OPENGL_BIT,
    EGL_NONE
  };

  if (!eglChooseConfig(edpy, attrs, &cfg, 1, &ncfg) || ncfg < 1) {
    eglTerminate(edpy); if (dpy) XCloseDisplay(dpy);
    printf("  egl-gl-render: no config\n"); return;
  }

  eglBindAPI(EGL_OPENGL_API);
  EGLint pb[] = { EGL_WIDTH, 320, EGL_HEIGHT, 240, EGL_NONE };
  EGLSurface surf = eglCreatePbufferSurface(edpy, cfg, pb);
  EGLContext ctx = eglCreateContext(edpy, cfg, EGL_NO_CONTEXT, NULL);

  if (ctx == EGL_NO_CONTEXT || surf == EGL_NO_SURFACE) {
    if (ctx != EGL_NO_CONTEXT) eglDestroyContext(edpy, ctx);
    if (surf != EGL_NO_SURFACE) eglDestroySurface(edpy, surf);
    eglTerminate(edpy); if (dpy) XCloseDisplay(dpy);
    printf("  egl-gl-render: setup failed\n"); return;
  }

  eglMakeCurrent(edpy, surf, surf, ctx);

  printf("  egl-gl-render: %d frames\n", loops);

  for (int i = 0; i < loops; i++) {
    (void)glGetString(GL_VENDOR);
    (void)glGetString(GL_RENDERER);
    (void)glGetString(GL_VERSION);
    (void)glGetString(GL_EXTENSIONS);

    GLint v;
    glGetIntegerv(GL_MAX_TEXTURE_SIZE, &v);
    glGetIntegerv(GL_MAX_VERTEX_ATTRIBS, &v);
    glGetIntegerv(GL_MAX_COMBINED_TEXTURE_IMAGE_UNITS, &v);

    (void)eglGetProcAddress("glFenceSync");
    (void)eglGetProcAddress("glCreateShader");
    (void)eglGetProcAddress("glMapBufferRange");
    (void)eglGetProcAddress("glBindVertexArray");

    glViewport(0, 0, 320, 240);
    glClearColor(0.1f, (float)(i & 1), 0.4f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);

    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);

    glBegin(GL_TRIANGLES);
    glColor4f(1,0,0,0.5f); glVertex2f(-0.5f,-0.5f);
    glColor4f(0,1,0,0.5f); glVertex2f( 0.5f,-0.5f);
    glColor4f(0,0,1,0.5f); glVertex2f( 0.0f, 0.5f);
    glEnd();

    glDisable(GL_BLEND);

    if ((i & 31) == 0) {
      eglWaitGL();
      eglWaitNative(EGL_CORE_NATIVE_ENGINE);
      glFinish();
    }
  }

  eglMakeCurrent(edpy, EGL_NO_SURFACE, EGL_NO_SURFACE, EGL_NO_CONTEXT);
  eglDestroyContext(edpy, ctx);
  eglDestroySurface(edpy, surf);
  eglTerminate(edpy);
  if (dpy) XCloseDisplay(dpy);
}

/* ── 9. EGL + GLES2 shader rendering ───────────────────────── */

static GLuint compile_shader(GLenum type, const char *src) {
  GLuint s = glCreateShader(type);
  glShaderSource(s, 1, &src, NULL);
  glCompileShader(s);
  return s;
}

static void ex_egl_gles2_rendering(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  EGLDisplay edpy = open_egl_display(dpy);
  if (edpy == EGL_NO_DISPLAY) {
    if (dpy) XCloseDisplay(dpy);
    printf("  egl-gles2-render: no display\n"); return;
  }

  EGLint maj, min;
  if (!eglInitialize(edpy, &maj, &min)) {
    if (dpy) XCloseDisplay(dpy);
    return;
  }

  int loops = bolt_mode ? 1000 : 400;

  EGLConfig cfg; EGLint ncfg;
  EGLint attrs[] = {
    EGL_SURFACE_TYPE, EGL_PBUFFER_BIT,
    EGL_RENDERABLE_TYPE, EGL_OPENGL_ES2_BIT,
    EGL_NONE
  };

  if (!eglChooseConfig(edpy, attrs, &cfg, 1, &ncfg) || ncfg < 1) {
    eglTerminate(edpy); if (dpy) XCloseDisplay(dpy);
    printf("  egl-gles2-render: no config\n"); return;
  }

  eglBindAPI(EGL_OPENGL_ES_API);
  EGLint pb[] = { EGL_WIDTH, 320, EGL_HEIGHT, 240, EGL_NONE };
  EGLSurface surf = eglCreatePbufferSurface(edpy, cfg, pb);
  EGLint ctx_a[] = { EGL_CONTEXT_CLIENT_VERSION, 2, EGL_NONE };
  EGLContext ctx = eglCreateContext(edpy, cfg, EGL_NO_CONTEXT, ctx_a);

  if (ctx == EGL_NO_CONTEXT || surf == EGL_NO_SURFACE) {
    if (ctx != EGL_NO_CONTEXT) eglDestroyContext(edpy, ctx);
    if (surf != EGL_NO_SURFACE) eglDestroySurface(edpy, surf);
    eglTerminate(edpy); if (dpy) XCloseDisplay(dpy);
    printf("  egl-gles2-render: setup failed\n"); return;
  }

  eglMakeCurrent(edpy, surf, surf, ctx);

  const char *vs =
    "attribute vec2 aPos;\n"
    "attribute vec3 aCol;\n"
    "varying vec3 vCol;\n"
    "void main() { gl_Position = vec4(aPos, 0.0, 1.0); vCol = aCol; }\n";
  const char *fs =
    "precision mediump float;\n"
    "varying vec3 vCol;\n"
    "void main() { gl_FragColor = vec4(vCol, 1.0); }\n";

  GLuint vsh = compile_shader(GL_VERTEX_SHADER, vs);
  GLuint fsh = compile_shader(GL_FRAGMENT_SHADER, fs);
  GLuint prog = glCreateProgram();
  glAttachShader(prog, vsh);
  glAttachShader(prog, fsh);
  glBindAttribLocation(prog, 0, "aPos");
  glBindAttribLocation(prog, 1, "aCol");
  glLinkProgram(prog);
  glUseProgram(prog);

  GLfloat verts[] = {
    /* pos        color */
    -0.5f,-0.5f,  1,0,0,
     0.5f,-0.5f,  0,1,0,
     0.0f, 0.5f,  0,0,1,
    -0.8f,-0.8f,  1,1,0,
     0.8f,-0.8f,  0,1,1,
     0.0f, 0.8f,  1,0,1,
  };

  printf("  egl-gles2-render: %d frames\n", loops);

  for (int i = 0; i < loops; i++) {
    glViewport(0, 0, 320, 240);
    glClearColor(0.1f * (i & 3), 0.1f, 0.2f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT);

    glVertexAttribPointer(0, 2, GL_FLOAT, GL_FALSE, 5*sizeof(float), verts);
    glVertexAttribPointer(1, 3, GL_FLOAT, GL_FALSE, 5*sizeof(float), verts+2);
    glEnableVertexAttribArray(0);
    glEnableVertexAttribArray(1);
    glDrawArrays(GL_TRIANGLES, 0, 6);
    glDisableVertexAttribArray(0);
    glDisableVertexAttribArray(1);

    (void)glGetString(GL_VENDOR);
    (void)glGetString(GL_RENDERER);
    (void)glGetString(GL_VERSION);
    (void)glGetString(GL_SHADING_LANGUAGE_VERSION);

    if ((i & 31) == 0) glFinish();
  }

  glDeleteProgram(prog);
  glDeleteShader(vsh);
  glDeleteShader(fsh);

  eglMakeCurrent(edpy, EGL_NO_SURFACE, EGL_NO_SURFACE, EGL_NO_CONTEXT);
  eglDestroyContext(edpy, ctx);
  eglDestroySurface(edpy, surf);
  eglTerminate(edpy);
  if (dpy) XCloseDisplay(dpy);
}

/* ── 10. GLES1 exerciser ─────────────────────────────────────── */
#if HAVE_GLES1_API
static void ex_egl_gles1_rendering(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  EGLDisplay edpy = open_egl_display(dpy);
  if (edpy == EGL_NO_DISPLAY) {
    if (dpy) XCloseDisplay(dpy);
    printf("  egl-gles1: no display\n"); return;
  }

  EGLint maj, min;
  if (!eglInitialize(edpy, &maj, &min)) {
    if (dpy) XCloseDisplay(dpy);
    return;
  }

  int loops = bolt_mode ? 600 : 200;

  EGLConfig cfg; EGLint ncfg;
  EGLint attrs[] = {
    EGL_SURFACE_TYPE, EGL_PBUFFER_BIT,
    EGL_RENDERABLE_TYPE, EGL_OPENGL_ES_BIT,
    EGL_NONE
  };

  if (!eglChooseConfig(edpy, attrs, &cfg, 1, &ncfg) || ncfg < 1) {
    eglTerminate(edpy); if (dpy) XCloseDisplay(dpy); return;
  }

  eglBindAPI(EGL_OPENGL_ES_API);
  EGLint pb[] = { EGL_WIDTH, 320, EGL_HEIGHT, 240, EGL_NONE };
  EGLSurface surf = eglCreatePbufferSurface(edpy, cfg, pb);
  EGLint ctx_a[] = { EGL_CONTEXT_CLIENT_VERSION, 1, EGL_NONE };
  EGLContext ctx = eglCreateContext(edpy, cfg, EGL_NO_CONTEXT, ctx_a);

  if (ctx == EGL_NO_CONTEXT || surf == EGL_NO_SURFACE) {
    if (ctx != EGL_NO_CONTEXT) eglDestroyContext(edpy, ctx);
    if (surf != EGL_NO_SURFACE) eglDestroySurface(edpy, surf);
    eglTerminate(edpy); if (dpy) XCloseDisplay(dpy); return;
  }

  eglMakeCurrent(edpy, surf, surf, ctx);

  GLfixed tri[] = { -32768,-32768, 32768,-32768, 0,32768 };

  printf("  egl-gles1: %d frames\n", loops);

  for (int i = 0; i < loops; i++) {
    glViewport(0, 0, 320, 240);
    glClearColorx(0x1000, 0x2000, 0x3000, 0x10000);
    glClear(GL_COLOR_BUFFER_BIT);
    glEnableClientState(GL_VERTEX_ARRAY);
    glVertexPointer(2, GL_FIXED, 0, tri);
    glDrawArrays(GL_TRIANGLES, 0, 3);
    glDisableClientState(GL_VERTEX_ARRAY);
    if ((i & 31) == 0) glFinish();
  }

  eglMakeCurrent(edpy, EGL_NO_SURFACE, EGL_NO_SURFACE, EGL_NO_CONTEXT);
  eglDestroyContext(edpy, ctx);
  eglDestroySurface(edpy, surf);
  eglTerminate(edpy);
  if (dpy) XCloseDisplay(dpy);
}
#endif

/* ── 11. Multi-threaded context + rendering ─────────────────── */

struct mt_render_arg {
  int thread_id;
  int loops;
  bool bolt_mode;
};

static void *mt_glx_render_thread(void *arg) {
  struct mt_render_arg *a = (struct mt_render_arg *)arg;

  Display *dpy = XOpenDisplay(NULL);
  if (!dpy) return NULL;

  int screen = DefaultScreen(dpy);
  int attribs[] = {
    GLX_RENDER_TYPE, GLX_RGBA_BIT,
    GLX_DRAWABLE_TYPE, GLX_PBUFFER_BIT,
    GLX_DOUBLEBUFFER, False,
    None
  };
  int ncfg = 0;
  GLXFBConfig *cfgs = glXChooseFBConfig(dpy, screen, attribs, &ncfg);
  if (!cfgs || ncfg < 1) {
    if (cfgs) XFree(cfgs);
    XCloseDisplay(dpy);
    return NULL;
  }

  int pb_attrs[] = { GLX_PBUFFER_WIDTH, 64, GLX_PBUFFER_HEIGHT, 64, None };
  GLXPbuffer pb = glXCreatePbuffer(dpy, cfgs[0], pb_attrs);
  GLXContext ctx = glXCreateNewContext(dpy, cfgs[0], GLX_RGBA_TYPE, NULL, True);

  if (!ctx || !pb) {
    if (ctx) glXDestroyContext(dpy, ctx);
    if (pb) glXDestroyPbuffer(dpy, pb);
    XFree(cfgs);
    XCloseDisplay(dpy);
    return NULL;
  }

  glXMakeContextCurrent(dpy, pb, pb, ctx);

  for (int i = 0; i < a->loops; i++) {
    (void)glGetString(GL_VENDOR);
    (void)glGetString(GL_RENDERER);

    glViewport(0, 0, 64, 64);
    glClearColor((float)a->thread_id / 8.0f, (float)(i & 1), 0.5f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT);

    /* ProcAddress from thread context */
    (void)glXGetProcAddressARB((const GLubyte*)"glCreateShader");
    (void)glXGetProcAddressARB((const GLubyte*)"glBufferData");
    (void)eglGetProcAddress("glFenceSync");

    GLint v;
    glGetIntegerv(GL_MAX_TEXTURE_SIZE, &v);

    if ((i & 15) == 0) glFinish();
  }

  glXMakeContextCurrent(dpy, None, None, NULL);
  glXDestroyContext(dpy, ctx);
  glXDestroyPbuffer(dpy, pb);
  XFree(cfgs);
  XCloseDisplay(dpy);

  return NULL;
}

static void ex_mt_glx_rendering(bool bolt_mode) {
  int nthreads = 8;
  int loops = bolt_mode ? 400 : 150;

  printf("  mt-glx-render: %d threads x %d loops\n", nthreads, loops);

  pthread_t threads[8];
  struct mt_render_arg args[8];

  for (int i = 0; i < nthreads; i++) {
    args[i].thread_id = i;
    args[i].loops = loops;
    args[i].bolt_mode = bolt_mode;
    pthread_create(&threads[i], NULL, mt_glx_render_thread, &args[i]);
  }

  for (int i = 0; i < nthreads; i++)
    pthread_join(threads[i], NULL);
}

/* ── 12. Multi-threaded EGL rendering ───────────────────────── */

static void *mt_egl_render_thread(void *arg) {
  struct mt_render_arg *a = (struct mt_render_arg *)arg;

  Display *dpy = XOpenDisplay(NULL);
  EGLDisplay edpy = open_egl_display(dpy);
  if (edpy == EGL_NO_DISPLAY) {
    if (dpy) XCloseDisplay(dpy);
    return NULL;
  }

  EGLint maj, min;
  if (!eglInitialize(edpy, &maj, &min)) {
    if (dpy) XCloseDisplay(dpy);
    return NULL;
  }

  EGLConfig cfg; EGLint ncfg;
  EGLint attrs[] = {
    EGL_SURFACE_TYPE, EGL_PBUFFER_BIT,
    EGL_RENDERABLE_TYPE, EGL_OPENGL_ES2_BIT,
    EGL_NONE
  };

  if (!eglChooseConfig(edpy, attrs, &cfg, 1, &ncfg) || ncfg < 1) {
    eglTerminate(edpy);
    if (dpy) XCloseDisplay(dpy);
    return NULL;
  }

  eglBindAPI(EGL_OPENGL_ES_API);
  EGLint pb[] = { EGL_WIDTH, 64, EGL_HEIGHT, 64, EGL_NONE };
  EGLSurface surf = eglCreatePbufferSurface(edpy, cfg, pb);
  EGLint ctx_a[] = { EGL_CONTEXT_CLIENT_VERSION, 2, EGL_NONE };
  EGLContext ctx = eglCreateContext(edpy, cfg, EGL_NO_CONTEXT, ctx_a);

  if (ctx == EGL_NO_CONTEXT || surf == EGL_NO_SURFACE) {
    if (ctx != EGL_NO_CONTEXT) eglDestroyContext(edpy, ctx);
    if (surf != EGL_NO_SURFACE) eglDestroySurface(edpy, surf);
    eglTerminate(edpy);
    if (dpy) XCloseDisplay(dpy);
    return NULL;
  }

  eglMakeCurrent(edpy, surf, surf, ctx);

  for (int i = 0; i < a->loops; i++) {
    (void)glGetString(GL_VENDOR);
    (void)glGetString(GL_RENDERER);

    glViewport(0, 0, 64, 64);
    glClearColor(0.5f, (float)a->thread_id / 8.0f, (float)(i & 1), 1.0f);
    glClear(GL_COLOR_BUFFER_BIT);

    (void)eglGetProcAddress("glCreateShader");
    (void)eglGetProcAddress("glBufferData");
    (void)eglGetProcAddress("glMapBufferRange");

    if ((i & 15) == 0) glFinish();
  }

  eglMakeCurrent(edpy, EGL_NO_SURFACE, EGL_NO_SURFACE, EGL_NO_CONTEXT);
  eglDestroyContext(edpy, ctx);
  eglDestroySurface(edpy, surf);
  eglTerminate(edpy);
  if (dpy) XCloseDisplay(dpy);

  return NULL;
}

static void ex_mt_egl_rendering(bool bolt_mode) {
  int nthreads = 8;
  int loops = bolt_mode ? 400 : 150;

  printf("  mt-egl-render: %d threads x %d loops\n", nthreads, loops);

  pthread_t threads[8];
  struct mt_render_arg args[8];

  for (int i = 0; i < nthreads; i++) {
    args[i].thread_id = i;
    args[i].loops = loops;
    args[i].bolt_mode = bolt_mode;
    pthread_create(&threads[i], NULL, mt_egl_render_thread, &args[i]);
  }

  for (int i = 0; i < nthreads; i++)
    pthread_join(threads[i], NULL);
}

/* ── 13. EGL + GLX interleaved (compositor-like) ────────────── */

static void ex_mixed_api_stress(bool bolt_mode) {
  Display *dpy = XOpenDisplay(NULL);
  if (!dpy) { printf("  mixed-api: no display\n"); return; }

  int loops = bolt_mode ? 300 : 120;
  int screen = DefaultScreen(dpy);

  EGLDisplay edpy = open_egl_display(dpy);
  if (edpy == EGL_NO_DISPLAY) {
    XCloseDisplay(dpy);
    printf("  mixed-api: no EGL display\n"); return;
  }

  EGLint maj, min;
  if (!eglInitialize(edpy, &maj, &min)) {
    XCloseDisplay(dpy);
    printf("  mixed-api: EGL init failed\n"); return;
  }

  /* Setup GLX pbuffer */
  int glx_attrs[] = {
    GLX_RENDER_TYPE, GLX_RGBA_BIT,
    GLX_DRAWABLE_TYPE, GLX_PBUFFER_BIT,
    GLX_DOUBLEBUFFER, False,
    None
  };
  int ncfg = 0;
  GLXFBConfig *glx_cfgs = glXChooseFBConfig(dpy, screen, glx_attrs, &ncfg);
  GLXPbuffer glx_pb = 0;
  GLXContext glx_ctx = NULL;

  if (glx_cfgs && ncfg > 0) {
    int pb_a[] = { GLX_PBUFFER_WIDTH, 64, GLX_PBUFFER_HEIGHT, 64, None };
    glx_pb = glXCreatePbuffer(dpy, glx_cfgs[0], pb_a);
    glx_ctx = glXCreateNewContext(dpy, glx_cfgs[0], GLX_RGBA_TYPE, NULL, True);
  }

  /* Setup EGL pbuffer */
  EGLConfig egl_cfg; EGLint encfg;
  EGLint egl_attrs[] = {
    EGL_SURFACE_TYPE, EGL_PBUFFER_BIT,
    EGL_RENDERABLE_TYPE, EGL_OPENGL_ES2_BIT,
    EGL_NONE
  };
  EGLSurface egl_surf = EGL_NO_SURFACE;
  EGLContext egl_ctx = EGL_NO_CONTEXT;

  if (eglChooseConfig(edpy, egl_attrs, &egl_cfg, 1, &encfg) && encfg > 0) {
    eglBindAPI(EGL_OPENGL_ES_API);
    EGLint pb[] = { EGL_WIDTH, 64, EGL_HEIGHT, 64, EGL_NONE };
    egl_surf = eglCreatePbufferSurface(edpy, egl_cfg, pb);
    EGLint ctx_a[] = { EGL_CONTEXT_CLIENT_VERSION, 2, EGL_NONE };
    egl_ctx = eglCreateContext(edpy, egl_cfg, EGL_NO_CONTEXT, ctx_a);
  }

  printf("  mixed-api: %d interleaved GLX/EGL cycles\n", loops);

  for (int i = 0; i < loops; i++) {
    /* GLX render */
    if (glx_ctx && glx_pb) {
      glXMakeContextCurrent(dpy, glx_pb, glx_pb, glx_ctx);
      (void)glGetString(GL_VENDOR);
      glClearColor(1,0,0,1);
      glClear(GL_COLOR_BUFFER_BIT);
      (void)glXGetProcAddressARB((const GLubyte*)"glFenceSync");
      glXMakeContextCurrent(dpy, None, None, NULL);
    }

    /* EGL render */
    if (egl_ctx != EGL_NO_CONTEXT && egl_surf != EGL_NO_SURFACE) {
      eglMakeCurrent(edpy, egl_surf, egl_surf, egl_ctx);
      (void)glGetString(GL_VENDOR);
      glClearColor(0,1,0,1);
      glClear(GL_COLOR_BUFFER_BIT);
      (void)eglGetProcAddress("glCreateShader");
      eglMakeCurrent(edpy, EGL_NO_SURFACE, EGL_NO_SURFACE, EGL_NO_CONTEXT);
    }

    if ((i & 15) == 0) {
      /* Query from no-context state */
      (void)glXGetCurrentContext();
      (void)eglGetCurrentContext();
      (void)eglGetCurrentDisplay();
    }
  }

  if (glx_ctx) glXDestroyContext(dpy, glx_ctx);
  if (glx_pb) glXDestroyPbuffer(dpy, glx_pb);
  if (glx_cfgs) XFree(glx_cfgs);
  if (egl_ctx != EGL_NO_CONTEXT) eglDestroyContext(edpy, egl_ctx);
  if (egl_surf != EGL_NO_SURFACE) eglDestroySurface(edpy, egl_surf);

  eglTerminate(edpy);
  XCloseDisplay(dpy);
}

/* ── 14. eglReleaseThread stress ─────────────────────────────── */

static void *release_thread_fn(void *arg) {
  int loops = *(int*)arg;

  for (int i = 0; i < loops; i++) {
    /* ProcAddress lookups generate TLS state */
    (void)eglGetProcAddress("glCreateShader");
    (void)glXGetProcAddressARB((const GLubyte*)"glBufferData");
    (void)eglGetProcAddress("eglCreateImage");

    /* Release TLS state */
    eglReleaseThread();
  }

  return NULL;
}

static void ex_release_thread_stress(bool bolt_mode) {
  int nthreads = 8;
  int loops = bolt_mode ? 500 : 200;

  printf("  release-thread: %d threads x %d loops\n", nthreads, loops);

  pthread_t threads[8];
  for (int i = 0; i < nthreads; i++)
    pthread_create(&threads[i], NULL, release_thread_fn, &loops);
  for (int i = 0; i < nthreads; i++)
    pthread_join(threads[i], NULL);
}

/* ── Main ────────────────────────────────────────────────────── */

int main(int argc, char **argv) {
  setvbuf(stdout, NULL, _IONBF, 0);
  setvbuf(stderr, NULL, _IONBF, 0);

  bool bolt_mode = false;
  if (argc > 1 && strcmp(argv[1], "--bolt-mode") == 0)
    bolt_mode = true;

  printf("glvnd PGO helper start\n");
  printf("  mode: %s\n", bolt_mode ? "bolt" : "normal");
  printf("  DISPLAY=%s\n", getenv("DISPLAY") ? getenv("DISPLAY") : "(unset)");
  printf("  symbols to probe: %d\n", g_nprocaddr_syms);

  /* Xlib thread safety — required for multi-threaded X11 usage */
  XInitThreads();

  print_loaded_libs();

  double t0 = now_sec();

  /* Phase 1: Library loading/unloading */
  ex_dlopen_churn(bolt_mode ? 400 : 150);

  /* Phase 2: GetProcAddress resolution (THE hottest path) */
  ex_procaddr_stress(bolt_mode);

  /* Phase 3: GLX dispatch paths */
  ex_glx_context_churn(bolt_mode);
  ex_glx_fbconfig_enumerate(bolt_mode);
  ex_glx_context_switch(bolt_mode);
  ex_glx_rendering(bolt_mode);

  /* Phase 4: EGL dispatch paths */
  ex_egl_context_churn(bolt_mode);
  ex_egl_gl_rendering(bolt_mode);
  ex_egl_gles2_rendering(bolt_mode);

#if HAVE_GLES1_API
  ex_egl_gles1_rendering(bolt_mode);
#else
  printf("  egl-gles1: unavailable at build time\n");
#endif

  /* Phase 5: Multi-threaded rendering (TLS dispatch contention) */
  ex_mt_glx_rendering(bolt_mode);
  ex_mt_egl_rendering(bolt_mode);

  /* Phase 6: Mixed API stress (compositor-like) */
  ex_mixed_api_stress(bolt_mode);

  /* Phase 7: Thread lifecycle stress */
  ex_release_thread_stress(bolt_mode);

  double elapsed = now_sec() - t0;
  printf("glvnd PGO helper end (%.2fs)\n", elapsed);

  return 0;
}
CEOF
}

# ──────────────────────────────────────────────────────────────────────
# Workload build and execution
# ──────────────────────────────────────────────────────────────────────

build_workload_helper() {
  local stage="$1"
  local incdir="$2"
  local libdir="$3"
  local outpath="$4"

  local have_gles1=0
  detect_glvnd_optional_apis "$incdir" "$libdir" have_gles1

  echo "  -> Building libglvnd workload helper: $outpath"
  echo "     optional APIs: gles1=$have_gles1"

  local -a link_libs=(
    -lGL -lGLX -lOpenGL -lEGL -lGLESv2
    -lX11 -lXext
    -ldl -lpthread -lm
  )
  (( have_gles1 )) && link_libs+=(-lGLESv1_CM)

  clang -std=gnu17 -O2 -pipe \
    -DHAVE_GLES1_API="$have_gles1" \
    -I"$incdir" -I/usr/include \
    "${srcdir}/glvnd_pgo_workload.c" \
    -L"$libdir" \
    -Wl,-rpath-link,"$libdir" \
    "${link_libs[@]}" \
    -o "$outpath"
}

run_glvnd_workload() {
  local stage="$1"
  local libdir="$2"
  local profdir="$3"
  local helper="$4"
  local mode="$5"
  local logfile="${srcdir}/glvnd-training-$(stage_slug "$stage").log"

  echo "-> ${stage}: Running libglvnd dispatch workload..."
  echo "  -> helper: $helper"
  echo "  -> mode: $mode"
  echo "  -> libdir: $libdir"

  (
    export LD_LIBRARY_PATH="$libdir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    export LD_BIND_NOW=1
    set -o pipefail

    if [[ "$mode" == bolt ]]; then
      "$helper" --bolt-mode 2>&1 | tee "$logfile"
    else
      "$helper" 2>&1 | tee "$logfile"
    fi
  ) || {
    echo "Error: workload failed during ${stage}." >&2
    return 1
  }

  # Supplemental tools — ONLY for PGO stages (not BOLT, where they segfault)
  if [[ "$mode" != bolt ]]; then
    run_tool_supplement "$stage" "$libdir" "$mode" 2>&1 | tee -a "$logfile" || true
  fi

  if [[ -n "$profdir" ]]; then
    show_generated_profiles "$profdir" "$stage"
  fi
}

run_tool_supplement() {
  local stage="$1"
  local libdir="$2"
  local mode="$3"

  export LD_LIBRARY_PATH="$libdir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
  export LD_BIND_NOW=1

  if [[ -n "${DISPLAY:-}" ]]; then
    if command -v glxinfo >/dev/null 2>&1; then
      echo "  -> ${stage}: supplemental glxinfo"
      timeout 6s glxinfo -B >/dev/null 2>&1 || true
      timeout 6s glxinfo >/dev/null 2>&1 || true
    fi
    if command -v glxgears >/dev/null 2>&1; then
      echo "  -> ${stage}: supplemental glxgears"
      timeout 3s glxgears >/dev/null 2>&1 || true
    fi
    if command -v glmark2 >/dev/null 2>&1; then
      echo "  -> ${stage}: supplemental glmark2"
      timeout 8s glmark2 --size 800x600 -b "build:duration=2000" >/dev/null 2>&1 || true
    fi
  fi
  if command -v eglinfo >/dev/null 2>&1; then
    echo "  -> ${stage}: supplemental eglinfo"
    timeout 6s eglinfo >/dev/null 2>&1 || true
  fi
}

# ──────────────────────────────────────────────────────────────────────
# Meson helpers
# ──────────────────────────────────────────────────────────────────────

meson_stage_setup() {
  local srcroot_local="$1"
  local builddir_local="$2"
  local cflags_local="$3"
  local cxxflags_local="$4"
  local ldflags_local="$5"

  rm -rf "$builddir_local"

  env \
    CC="$CC" CXX="$CXX" AR="$AR" NM="$NM" \
    RANLIB="$RANLIB" STRIP="$STRIP" \
    CFLAGS="$cflags_local" \
    CXXFLAGS="$cxxflags_local" \
    LDFLAGS="$ldflags_local" \
    meson setup "$builddir_local" "$srcroot_local" \
      --prefix=/usr \
      --libdir=lib \
      --buildtype=plain \
      --wrap-mode=nofallback \
      -Db_ndebug=true \
      -Db_pie=false
}

# ──────────────────────────────────────────────────────────────────────
# PKGBUILD functions
# ──────────────────────────────────────────────────────────────────────

prepare() {
  create_glvnd_workload_source
}

build() {
  setup_llvm_toolchain

  local srcroot="${srcdir}/${_pkgname}"
  local build_pgo="${srcdir}/build-pgo"
  local build_cs="${srcdir}/build-cs"
  local build_final="${srcdir}/build-final"

  local inst_pgo="${srcdir}/inst-pgo"
  local inst_cs="${srcdir}/inst-cs"
  local inst_final="${srcdir}/inst-final"
  local inst_bolt="${srcdir}/inst-bolt"
  local inst_verify="${srcdir}/inst-verify"

  local pgo_dir="${srcdir}/pgo"
  local cs_dir="${srcdir}/cspgo"
  local bolt_dir="${srcdir}/bolt"

  rm -rf "$build_pgo" "$build_cs" "$build_final"
  rm -rf "$inst_pgo" "$inst_cs" "$inst_final" "$inst_bolt" "$inst_verify"
  rm -rf "$pgo_dir" "$cs_dir" "$bolt_dir"
  mkdir -p "$pgo_dir" "$cs_dir" "$bolt_dir"

  local orig_cflags="$CFLAGS"
  local orig_cxxflags="$CXXFLAGS"
  local orig_ldflags="$LDFLAGS"

  local -a instr_flags=(
    -g3
    -fno-omit-frame-pointer
    -Xclang -mllvm -Xclang -vp-counters-per-site=64
    -Xclang -mllvm -Xclang -runtime-counter-relocation
    -Xclang -mllvm -Xclang -enable-value-profiling
  )

  local -a profile_warnings=(
    -Wno-profile-instr-out-of-date
    -Wno-profile-instr-unprofiled
  )

  local -a prefix_maps=(
    "-ffile-prefix-map=$srcdir=/usr/src/debug/$pkgname"
    "-fdebug-prefix-map=$srcdir=/usr/src/debug/$pkgname"
    "-fmacro-prefix-map=$srcdir=/usr/src/debug/$pkgname"
  )

  # ── Stage 1: PGO instrumented build ────────────────────────────
  echo "=== Stage 1: Standard PGO instrumentation ==="

  local cflags_s1="${orig_cflags} ${prefix_maps[*]} -fprofile-generate=${pgo_dir} ${instr_flags[*]}"
  local cxxflags_s1="${orig_cxxflags} ${prefix_maps[*]} -fprofile-generate=${pgo_dir} ${instr_flags[*]}"
  local ldflags_s1="${orig_ldflags} -fprofile-generate=${pgo_dir}"

  meson_stage_setup "$srcroot" "$build_pgo" "$cflags_s1" "$cxxflags_s1" "$ldflags_s1"
  meson compile -C "$build_pgo"
  stage_install "$build_pgo" "$inst_pgo"

  local pgo_incdir="${inst_pgo}/usr/include"
  local pgo_libdir
  get_stage_libdir "$inst_pgo" pgo_libdir || { echo "Error: Stage 1 libdir not found." >&2; return 1; }

  local helper_pgo="${srcdir}/glvnd-workload-stage1"
  build_workload_helper stage1 "$pgo_incdir" "$pgo_libdir" "$helper_pgo"

  export LLVM_PROFILE_FILE="${pgo_dir}/glvnd-%m-%p.profraw"
  run_glvnd_workload "Stage 1" "$pgo_libdir" "$pgo_dir" "$helper_pgo" normal || return 1
  unset LLVM_PROFILE_FILE

  local -a pgo_raws=()
  shopt -s nullglob; pgo_raws=("${pgo_dir}"/*.profraw); shopt -u nullglob
  (( ${#pgo_raws[@]} )) || { echo "Error: no Stage 1 profiles." >&2; return 1; }

  llvm-profdata merge -sparse -output="${srcdir}/standard.profdata" "${pgo_raws[@]}"

  # ── Stage 2: Context-Sensitive PGO ─────────────────────────────
  echo "=== Stage 2: Context-Sensitive PGO instrumentation ==="

  local cflags_s2="${orig_cflags} ${prefix_maps[*]} -fprofile-use=${srcdir}/standard.profdata -fcs-profile-generate=${cs_dir} ${profile_warnings[*]} ${instr_flags[*]}"
  local cxxflags_s2="${orig_cxxflags} ${prefix_maps[*]} -fprofile-use=${srcdir}/standard.profdata -fcs-profile-generate=${cs_dir} ${profile_warnings[*]} ${instr_flags[*]}"
  local ldflags_s2="${orig_ldflags} -fprofile-use=${srcdir}/standard.profdata -fcs-profile-generate=${cs_dir}"

  meson_stage_setup "$srcroot" "$build_cs" "$cflags_s2" "$cxxflags_s2" "$ldflags_s2"
  meson compile -C "$build_cs"
  stage_install "$build_cs" "$inst_cs"

  local cs_incdir="${inst_cs}/usr/include"
  local cs_libdir
  get_stage_libdir "$inst_cs" cs_libdir || { echo "Error: Stage 2 libdir not found." >&2; return 1; }

  local helper_cs="${srcdir}/glvnd-workload-stage2"
  build_workload_helper stage2 "$cs_incdir" "$cs_libdir" "$helper_cs"

  export LLVM_PROFILE_FILE="${cs_dir}/glvnd-cs-%m-%p.profraw"
  run_glvnd_workload "Stage 2" "$cs_libdir" "$cs_dir" "$helper_cs" normal || return 1
  unset LLVM_PROFILE_FILE

  local -a cs_raws=()
  shopt -s nullglob; cs_raws=("${cs_dir}"/*.profraw); shopt -u nullglob
  (( ${#cs_raws[@]} )) || { echo "Error: no Stage 2 profiles." >&2; return 1; }

  llvm-profdata merge -sparse \
    -output="${srcdir}/merged.profdata" \
    "${srcdir}/standard.profdata" "${cs_raws[@]}"

  # ── Stage 3: Final PGO-optimized build ─────────────────────────
  echo "=== Stage 3: Final optimized build ==="

  local cflags_s3="${orig_cflags} ${prefix_maps[*]} -fprofile-use=${srcdir}/merged.profdata ${profile_warnings[*]}"
  local cxxflags_s3="${orig_cxxflags} ${prefix_maps[*]} -fprofile-use=${srcdir}/merged.profdata ${profile_warnings[*]}"
  local ldflags_s3="${orig_ldflags} -fprofile-use=${srcdir}/merged.profdata -Wl,--emit-relocs"

  meson_stage_setup "$srcroot" "$build_final" "$cflags_s3" "$cxxflags_s3" "$ldflags_s3"
  meson compile -C "$build_final"
  stage_install "$build_final" "$inst_final"

  local final_libdir
  get_stage_libdir "$inst_final" final_libdir || { echo "Error: Stage 3 libdir not found." >&2; return 1; }
  verify_expected_sonames "$final_libdir" || return 1

  echo "=== Stage 3 complete ==="
  find "$build_final" -type f -name '*.so*' | sort

  # ── Stage 4: BOLT ──────────────────────────────────────────────
  if command -v llvm-bolt >/dev/null 2>&1; then
    echo "=== Stage 4: BOLT post-link optimization ==="

    local -a bolt_targets=()
    collect_bolt_targets "$build_final" bolt_targets

    if (( ${#bolt_targets[@]} )); then
      local target so_name bolt_any=0

      for target in "${bolt_targets[@]}"; do
        so_name="$(basename "$target")"
        echo "  -> Instrumenting ${so_name}..."
        cp -f "$target" "${bolt_dir}/${so_name}.orig"

        if llvm-bolt "${bolt_dir}/${so_name}.orig" \
            --instrument \
            --lite=true \
            --instrumentation-file-append-pid \
            --instrumentation-file="${bolt_dir}/${so_name}.fdata" \
            -o "${bolt_dir}/${so_name}.instr" 2>/dev/null; then
          cp -f "${bolt_dir}/${so_name}.instr" "$target"
          bolt_any=1
        else
          echo "  -> BOLT instrumentation failed for ${so_name}; restoring."
          cp -f "${bolt_dir}/${so_name}.orig" "$target"
        fi
      done

      if (( bolt_any )); then
        stage_install "$build_final" "$inst_bolt"

        local bolt_incdir="${inst_bolt}/usr/include"
        local bolt_libdir
        get_stage_libdir "$inst_bolt" bolt_libdir || { echo "Error: BOLT libdir not found." >&2; return 1; }

        local helper_bolt="${srcdir}/glvnd-workload-bolt"
        build_workload_helper bolt "$bolt_incdir" "$bolt_libdir" "$helper_bolt"

        # 5 BOLT training passes for maximum fdata coverage
        for pass in 1 2 3 4 5; do
          run_glvnd_workload "Stage 4 BOLT pass${pass}" "$bolt_libdir" "" "$helper_bolt" bolt || return 1
        done

        for target in "${bolt_targets[@]}"; do
          so_name="$(basename "$target")"
          show_bolt_fdata "$bolt_dir" "$so_name"

          local -a fdata_files=()
          shopt -s nullglob; fdata_files=("${bolt_dir}/${so_name}".fdata*); shopt -u nullglob

          if (( ! ${#fdata_files[@]} )); then
            echo "  -> No BOLT fdata for ${so_name}; restoring."
            cp -f "${bolt_dir}/${so_name}.orig" "$target"
            continue
          fi

          local merged_fdata="${bolt_dir}/${so_name}.merged.fdata"
          if command -v merge-fdata >/dev/null 2>&1; then
            merge-fdata "${fdata_files[@]}" > "$merged_fdata" 2>/dev/null || \
              cat "${fdata_files[@]}" > "$merged_fdata"
          else
            cat "${fdata_files[@]}" > "$merged_fdata"
          fi

          if [[ ! -s "$merged_fdata" ]]; then
            echo "  -> Empty fdata for ${so_name}; restoring."
            cp -f "${bolt_dir}/${so_name}.orig" "$target"
            continue
          fi

          echo "  -> Applying BOLT to ${so_name}..."

          if llvm-bolt "${bolt_dir}/${so_name}.orig" \
              --data="$merged_fdata" \
              --lite=true \
              --relocs \
              --reorder-blocks=ext-tsp \
              --reorder-functions=cdsort \
              --split-functions --split-all-cold --split-eh \
              --x86-strip-redundant-address-size \
              --split-strategy=cdsplit \
              --icf=all \
              --indirect-call-promotion=all \
              --jump-tables=aggressive \
              --peepholes=all \
              --plt=hot \
              --dyno-stats \
              -o "${bolt_dir}/${so_name}.bolt" 2>&1; then
            if [[ -s "${bolt_dir}/${so_name}.bolt" ]]; then
              cp -f "${bolt_dir}/${so_name}.bolt" "$target"
              echo "  -> BOLT successful for ${so_name}."
            else
              cp -f "${bolt_dir}/${so_name}.orig" "$target"
            fi
          else
            echo "  -> BOLT failed for ${so_name}; restoring."
            cp -f "${bolt_dir}/${so_name}.orig" "$target"
          fi
        done
      fi
    fi
  else
    echo "=== Stage 4: llvm-bolt not found; skipping ==="
  fi

  # ── Stage 5: Verification ─────────────────────────────────────
  echo "=== Stage 5: Final end-to-end verification ==="

  stage_install "$build_final" "$inst_verify"

  local verify_libdir
  get_stage_libdir "$inst_verify" verify_libdir || { echo "Error: verify libdir not found." >&2; return 1; }
  verify_expected_sonames "$verify_libdir" || return 1

  local helper_verify="${srcdir}/glvnd-workload-final"
  build_workload_helper final "${inst_verify}/usr/include" "$verify_libdir" "$helper_verify"
  run_glvnd_workload "Stage 5 verification" "$verify_libdir" "" "$helper_verify" normal || return 1

  echo "=== All stages completed successfully ==="
}

package() {
  DESTDIR="$pkgdir" meson install -C "${srcdir}/build-final" --no-rebuild

  if [[ -d "$pkgdir/usr/lib64" ]]; then
    mkdir -p "$pkgdir/usr/lib"
    cp -a "$pkgdir/usr/lib64"/. "$pkgdir/usr/lib"/
    rm -rf "$pkgdir/usr/lib64"
  fi

  verify_expected_sonames "$pkgdir/usr/lib"

  local lic_src=
  for licfile in LICENSE COPYING NOTICE README.md; do
    if [[ -f "${srcdir}/${_pkgname}/${licfile}" ]]; then
      lic_src="${srcdir}/${_pkgname}/${licfile}"
      break
    fi
  done

  if [[ -z "$lic_src" ]]; then
    echo "WARNING: No license file found!" >&2
    return 1
  fi

  install -Dm644 "$lic_src" "$pkgdir/usr/share/licenses/${pkgname}/LICENSE"
}
