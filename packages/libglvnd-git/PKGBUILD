)

_upstream_pkgver="${pkgver%%.r*}"
_shared_soname_provides=(
  'libEGL.so=1-64'
  'libGL.so=1-64'
  'libGLESv1_CM.so=1-64'
  'libGLESv2.so=2-64'
  'libGLX.so=0-64'
  'libGLdispatch.so=0-64'
  'libOpenGL.so=0-64'
)

provides=(
  'libglvnd'
  "libglvnd=${_upstream_pkgver}"
  'libgl'
