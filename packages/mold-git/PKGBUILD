pkgname=mold-git
pkgver=2.40.4_74_gf8da3457
pkgrel=1
pkgdesc="A Modern Linker"
arch=(x86_64)
url="https://github.com/rui314/mold"
license=("MIT")
# xxhash and mimalloc are bundled
depends=('gcc-libs' 'openssl' 'zlib' 'onetbb')
makedepends=('git' 'python' 'cmake' 'llvm')
checkdepends=('clang' 'libdwarf')
source=("mold::git+https://github.com/rui314/mold")
sha256sums=('SKIP')
provides=("mold=${pkgver}")
options=(!lto !strip)
conflicts=("mold")

pkgver() {
  cd mold
  git describe --long --tags | sed 's/^v//;s/-/_/g'
}

build() {
  local _pgo_dir="${srcdir}/pgo-profiles"
  local _bolt_dir="${srcdir}/bolt-profiles"

  mkdir -p "${_pgo_dir}" "${_bolt_dir}"

  local _common_cmake_args=(
    -S mold
    -B build
    -DCMAKE_BUILD_TYPE=Release
    -DCMAKE_INSTALL_PREFIX=/usr
    -DCMAKE_INSTALL_LIBEXECDIR=lib
    -DMOLD_USE_SYSTEM_MIMALLOC=OFF
    -DMOLD_USE_SYSTEM_TBB=ON
    -DCMAKE_C_STANDARD=23
    -DCMAKE_CXX_STANDARD=23
    -DMOLD_USE_MOLD=OFF
  )

  # === Stage 1: PGO Instrumentation Build ===
  cmake "${_common_cmake_args[@]}" \
    -DMOLD_LTO=OFF \
    -DCMAKE_C_FLAGS="${CFLAGS} -fprofile-generate=${_pgo_dir}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} -fprofile-generate=${_pgo_dir}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS}" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS}"

  cmake --build build

  # Generate PGO profile data via the test suite
  ctest --test-dir build --output-on-failure || true

  # === Stage 2: PGO-Optimized Build (with relocations for BOLT) ===
  cmake "${_common_cmake_args[@]}" \
    -DMOLD_LTO=ON \
    -DCMAKE_C_FLAGS="${CFLAGS} -fprofile-use=${_pgo_dir} -fprofile-correction -fno-reorder-blocks-and-partition" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} -fprofile-use=${_pgo_dir} -fprofile-correction -fno-reorder-blocks-and-partition" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} -Wl,--emit-relocs" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS}"

  cmake --build build

  # === Stage 3: BOLT Instrumentation ===
  llvm-bolt build/mold \
    --instrument \
    --instrumentation-file="${_bolt_dir}/prof" \
    --instrumentation-file-append-pid \
    -o build/mold.inst

  # Run the test suite with the instrumented binary to collect BOLT profile data
  mv build/mold build/mold.org
  cp build/mold.inst build/mold
  ctest --test-dir build --output-on-failure || true
  mv build/mold.org build/mold

  # Merge BOLT profile data
  merge-fdata "${_bolt_dir}"/prof*.fdata > "${_bolt_dir}/combined.fdata"

  # === Stage 4: BOLT Optimization ===
  llvm-bolt build/mold \
    --data="${_bolt_dir}/combined.fdata" \
    --dyno-stats \
    --eliminate-unreachable \
    --frame-opt=all \
    --icf=all \
    --jump-tables=aggressive \
    --plt=all \
    --hot-data \
    --hot-text \
    --peepholes=all \
    --infer-stale-profile=1 \
    --x86-strip-redundant-address-size \
    --indirect-call-promotion=all \
    --reorder-blocks=ext-tsp \
    --reorder-functions=cdsort \
    --split-all-cold \
    --split-functions \
    --split-strategy=cdsplit \
    --skip-funcs='_ZN4moldL14get_symbols_v1EPKviPNS_12PluginSymbolE/1*' \
    -o build/mold.bolt

  # Replace original binary with BOLTed version
  mv build/mold.bolt build/mold
}

check() {
  ctest --test-dir build --output-on-failure
}

package() {
  DESTDIR="${pkgdir}" cmake --install build

  install -Dm644 mold/LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  # Strip binaries and libraries
  find "${pkgdir}" -type f \( -name '*.so*' -o -name '*.a' -o -executable \) -print0 | while IFS= read -r -d '' file; do
    if llvm-strip --strip-unneeded "$file" 2>/dev/null || llvm-strip --strip-all "$file" 2>/dev/null; then
      echo "Stripped: $file"
    else
      echo "Skipping: $file (not a valid object file)" >&2
    fi
  done
}
