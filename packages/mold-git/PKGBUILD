# Maintainer: ms178
# A Modern Linker - GCC PGO + LLVM BOLT optimized for desktop.

pkgname=mold-git
pkgver=2.40.4_228_gc8d44d73
pkgrel=1
pkgdesc='A Modern Linker - GCC PGO + LLVM BOLT optimized for desktop'
arch=('x86_64')
url='https://github.com/rui314/mold'
license=('MIT')
depends=('gcc-libs' 'zlib' 'onetbb' 'zstd')
makedepends=('git' 'cmake' 'ninja' 'python' 'gcc' 'llvm' 'bolt')
checkdepends=('clang' 'libdwarf' 'libunwind')
source=('mold::git+https://github.com/rui314/mold.git')
sha256sums=('SKIP')
provides=("mold=${pkgver%%_*}")
conflicts=('mold')
# !strip: PGO/BOLT need debug+reloc sections intact through Stage 6; we strip
#         the FINAL validated binary ourselves in package().
# !lto:   we manage mold's own -DMOLD_LTO; keep makepkg from injecting -flto into
#         the instrumentation (Stage-1) build, which must NOT be LTO'd.
options=('!emptydirs' '!lto' '!strip' '!debug')

pkgver() {
  cd mold
  git describe --long --tags --abbrev=8 2>/dev/null | sed 's/^v//;s/-/_/g' \
    || printf 'r%s.%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short=8 HEAD)"
}

# -------------------------------------------------------------------------
# Job count: honor makepkg's MAKEFLAGS -j if present, else nproc.
# -------------------------------------------------------------------------
_jobs() {
  local _j
  _j="$(printf '%s\n' "${MAKEFLAGS:-}" | grep -oE '(-j|--jobs=)[0-9]+' | grep -oE '[0-9]+' | tail -1)"
  [[ -z "$_j" ]] && _j="$(nproc 2>/dev/null || printf '1')"
  printf '%s\n' "${_j:-1}"
}

# -------------------------------------------------------------------------
# Self-host mold using a given mold binary (exercises the linker hard).
# The result is intentionally discarded — its only purpose is to drive the
# instrumented/PGO mold through a large, realistic self-link.
# -------------------------------------------------------------------------
_build_mold_with_linker() {
  local _linker_bin; _linker_bin="$(realpath "$1")"
  local _name="$2"
  local _build_dir="${srcdir}/${_name}"
  local _wrapper_dir="${srcdir}/ld_wrapper_${_name}"

  msg2 "  -> Self-hosting mold using ${_linker_bin}..."

  rm -rf "${_build_dir}" "${_wrapper_dir}"
  mkdir -p "${_wrapper_dir}"
  ln -sfn "${_linker_bin}" "${_wrapper_dir}/ld.mold"
  ln -sfn "${_linker_bin}" "${_wrapper_dir}/mold"
  ln -sfn "${_linker_bin}" "${_wrapper_dir}/ld"

  PATH="${_wrapper_dir}:${PATH}" cmake \
    -G Ninja \
    -S "${srcdir}/mold" \
    -B "${_build_dir}" \
    -DCMAKE_BUILD_TYPE=release-simd \
    -DCMAKE_C_COMPILER=gcc \
    -DCMAKE_CXX_COMPILER=g++ \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_INSTALL_LIBEXECDIR=lib \
    -DCMAKE_CXX_STANDARD=20 \
    -DCMAKE_CXX_STANDARD_REQUIRED=ON \
    -DMOLD_USE_MOLD=OFF \
    -DMOLD_LTO=ON \
    -DMOLD_USE_MIMALLOC=ON \
    -DMOLD_USE_SYSTEM_MIMALLOC=OFF \
    -DMOLD_USE_SYSTEM_TBB=ON \
    -DMOLD_TARGETS='X86_64;I386' \
    -DCMAKE_C_FLAGS="${CFLAGS} -B${_wrapper_dir}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} -B${_wrapper_dir}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} -B${_wrapper_dir} -fuse-ld=mold" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS} -B${_wrapper_dir} -fuse-ld=mold" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS} -B${_wrapper_dir} -fuse-ld=mold" \
    >/dev/null

  PATH="${_wrapper_dir}:${PATH}" \
  LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD:-}" \
    cmake --build "${_build_dir}" -j "$(_jobs)" || true

  rm -rf "${_build_dir}" "${_wrapper_dir}"
}

# -------------------------------------------------------------------------
# Synthetic C/C++ link workload — a varied set of objects linked many times
# in different modes (exe, optimized exe, shared, relocatable) so the profile
# covers mold's hot paths.  force_exit preload ensures the profile is flushed
# (mold uses _exit() to skip teardown, which otherwise bypasses gcov/BOLT).
# -------------------------------------------------------------------------
_generate_and_run_workload() {
  local _linker_bin; _linker_bin="$(realpath "$1")"
  local _work_dir; _work_dir="$(mktemp -d "${srcdir}/workload.XXXXXX")"

  msg2 "  -> Generating synthetic C/C++ linker workload..."
  pushd "${_work_dir}" >/dev/null

  local i
  for i in {1..30}; do
    cat > "actor_${i}.cpp" <<EOF
#include <memory>
#include <stdexcept>
#include <string>
#include <vector>

template<int N> struct Deep {
    static int calc() {
        try {
            if (N % 2 == 0) throw std::runtime_error("even");
            return Deep<N - 1>::calc() + N;
        } catch (...) {
            return N;
        }
    }
};
template<> struct Deep<0> { static int calc() { return 0; } };

struct IEntity { virtual void tick() = 0; virtual ~IEntity() = default; };

struct Actor_${i} final : public IEntity {
    std::vector<std::string> data;
    void tick() override {
        data.push_back("Heavy_String_Data_Merge_Test_${i}");
        if (Deep<15>::calc() > 0) data.push_back("Exception_Handled_${i}");
    }
};

void run_actor_${i}() { std::make_unique<Actor_${i}>()->tick(); }
EOF
  done

  for i in {1..15}; do
    cat > "simple_${i}.c" <<EOF
#include <stdio.h>
const char *get_string_data_${i}(void) { return "string_merging_test_value_${i}"; }
int compute_data_${i}(int x) { return x * ${i}; }
EOF
  done

  cat > main.cpp <<EOF
$(for i in {1..30}; do printf 'extern void run_actor_%s();\n' "${i}"; done)
$(for i in {1..15}; do printf 'extern "C" const char *get_string_data_%s();\n' "${i}"; done)
$(for i in {1..15}; do printf 'extern "C" int compute_data_%s(int);\n' "${i}"; done)

int main() {
$(for i in {1..30}; do printf '    run_actor_%s();\n' "${i}"; done)
    int acc = 0;
$(for i in {1..15}; do printf '    acc += compute_data_%s(%s);\n' "${i}" "${i}"; done)
    return acc % 255;
}
EOF

  cat > Makefile <<'EOF'
CC := gcc
CXX := g++
WORK_CFLAGS := -O3 -march=native -g3 -pipe -fPIC -ffunction-sections -fdata-sections
WORK_CXXFLAGS := $(WORK_CFLAGS) -std=gnu++20

LTO_SRCS := $(wildcard actor_*.cpp) main.cpp
NON_LTO_SRCS := $(wildcard simple_*.c)
LTO_OBJS := $(LTO_SRCS:.cpp=.o)
NON_LTO_OBJS := $(NON_LTO_SRCS:.c=.o)

all: $(LTO_OBJS) $(NON_LTO_OBJS)

$(LTO_OBJS): %.o: %.cpp
	$(CXX) $(WORK_CXXFLAGS) -flto -c $< -o $@

$(NON_LTO_OBJS): %.o: %.c
	$(CC) $(WORK_CFLAGS) -fno-lto -c $< -o $@
EOF

  msg2 "  -> Compiling synthetic objects (LD_PRELOAD disabled for the compiler)..."
  env -u LD_PRELOAD make -j "$(_jobs)" || true

  msg2 "  -> Executing linker stress loop..."
  local _wrapper_dir="${_work_dir}/bin"
  mkdir -p "${_wrapper_dir}"
  ln -sfn "${_linker_bin}" "${_wrapper_dir}/ld.mold"
  ln -sfn "${_linker_bin}" "${_wrapper_dir}/mold"

  local -a _link_cmd=(g++ "-B${_wrapper_dir}" -fuse-ld=mold -O2 -g3 -pipe -fPIC)
  local iter
  for ((iter = 1; iter <= 40; iter++)); do
    LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD:-}" \
      "${_link_cmd[@]}" -flto -o game_engine ./*.o -lc -lstdc++ -lm || true

    LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD:-}" \
      "${_link_cmd[@]}" -flto \
      -Wl,-O1 -Wl,--as-needed -Wl,--gc-sections -Wl,--icf=all \
      -Wl,--compress-debug-sections=zstd \
      -Wl,-z,now -Wl,-z,relro -Wl,--pack-dyn-relocs=relr \
      -o game_engine_opt ./*.o -lc -lstdc++ -lm || true

    LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD:-}" \
      "${_link_cmd[@]}" -flto -shared -Wl,-z,defs \
      -o libgame_engine.so actor_1.o actor_2.o simple_1.o -lc -lstdc++ -lm || true

    # Direct mold invocation (relocatable link) — reliably flushes the profile.
    LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD:-}" \
      "${_linker_bin}" -r -o game_engine_partial.o simple_*.o || true

    rm -f game_engine game_engine_opt libgame_engine.so game_engine_partial.o
  done

  # A few direct invocations guarantee at least one clean BOLT/gcov flush even if
  # every driver-spawned child failed to inherit the preload.
  local k
  for k in {1..8}; do
    LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD:-}" "${_linker_bin}" --version >/dev/null 2>&1 || true
  done

  popd >/dev/null
  rm -rf "${_work_dir}"
}

# -------------------------------------------------------------------------
# Runtime self-test for a mold binary: must report a version AND successfully
# link a trivial program.  Returns 0 only if both pass.  This is the gate that
# prevents a miscompiled BOLT binary from shipping.
# -------------------------------------------------------------------------
_mold_selftest() {
  local _mold; _mold="$(realpath "$1")"
  local _t; _t="$(mktemp -d "${srcdir}/selftest.XXXXXX")" || return 1
  local _rc=0
  (
    cd "${_t}" || exit 1
    printf 'int main(void){return 0;}\n' > st.c
    gcc -c st.c -o st.o || exit 1
    local _w="${_t}/bin"; mkdir -p "${_w}"
    # -fuse-ld=mold finds the linker as <-B dir>/mold (also provide ld/ld.mold).
    ln -sfn "${_mold}" "${_w}/mold"
    ln -sfn "${_mold}" "${_w}/ld.mold"
    ln -sfn "${_mold}" "${_w}/ld"
    # 1) the candidate must run and report a version
    LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD:-}" "${_mold}" --version >/dev/null 2>&1 || exit 1
    # 2) it must actually link a program, and the output must exist + run
    gcc -B"${_w}" -fuse-ld=mold st.o -o st.out >/dev/null 2>&1 || exit 1
    [[ -x st.out ]] || exit 1
    ./st.out || exit 1
  ) || _rc=1
  rm -rf "${_t}"
  return "${_rc}"
}

# -------------------------------------------------------------------------
# Robust BOLT profile handling.
#
# Problem this solves (reported in the wild):
#   merge-fdata: '.../prof.336354.fdata': Malformed / corrupted entry type.
# merge-fdata aborts the ENTIRE merge if even ONE input shard is malformed.
# With --instrumentation-file-append-pid we get many per-PID shards, and any
# single bad one (a process killed mid-flush -> truncated file, a zero-byte
# file, or a profile in an unexpected sub-format such as the no-LBR form that
# merge-fdata's legacy reader rejects) takes down the whole profile and the
# build loses ALL the good data.
#
# Strategy (each step verified against llvm-bolt/merge-fdata 19):
#   1. VALIDATE every shard in isolation; keep only shards merge-fdata can read
#      on their own.  Drop empty/zero-byte and corrupt shards with a warning.
#   2. MERGE only the validated shards (legacy .fdata format).
#   3. CONVERT the merged profile to the modern dense YAML format via
#         llvm-bolt <binary> --data=<merged.fdata> -w <out.yaml>
#      YAML is upstream's recommended representation; it is more compact, more
#      resilient to small binary changes, and is the format that makes
#      --infer-stale-profile actually effective (legacy fdata gives it much less
#      to work with).
#   4. PICK the best usable profile: YAML if the conversion succeeded and the
#      file is non-empty, else the merged .fdata, else fail (caller ships PGO).
#
# Echoes the chosen profile path on stdout; returns non-zero if nothing usable
# could be produced.  Diagnostics go to stderr so they never pollute the path.
# -------------------------------------------------------------------------
_bolt_validate_shard() {
  # A shard is usable iff it is non-empty AND merge-fdata can parse it alone.
  local _f="$1"
  [[ -s "$_f" ]] || return 1
  merge-fdata "$_f" -o /dev/null >/dev/null 2>&1
}

_bolt_prepare_profile() {
  local _bin="$1" _bolt_dir="$2"
  local _merged="${_bolt_dir}/combined.fdata"
  local _yaml="${_bolt_dir}/combined.yaml"

  # Collect shards (append-pid layout: prof.<pid>.fdata) plus any plain prof.fdata.
  local -a _all=() _good=()
  shopt -s nullglob
  _all=( "${_bolt_dir}"/prof*.fdata "${_bolt_dir}"/prof.fdata )
  shopt -u nullglob
  if (( ${#_all[@]} == 0 )); then
    echo "  -> no BOLT profile shards found." >&2
    return 1
  fi

  local _f _dropped=0
  for _f in "${_all[@]}"; do
    [[ -e "$_f" ]] || continue
    if _bolt_validate_shard "$_f"; then
      _good+=( "$_f" )
    else
      _dropped=$(( _dropped + 1 ))
      echo "  -> dropping unusable BOLT shard: ${_f##*/} (empty or malformed)" >&2
    fi
  done

  if (( _dropped > 0 )); then
    echo "  -> ${#_good[@]} shard(s) usable, ${_dropped} dropped." >&2
  fi
  if (( ${#_good[@]} == 0 )); then
    echo "  -> all BOLT shards were unusable." >&2
    return 1
  fi

  # Merge only the validated shards.
  if ! merge-fdata "${_good[@]}" -o "${_merged}" >/dev/null 2>&1; then
    # Extremely defensive: if a shard passed solo validation but the *combined*
    # merge still trips (version skew), retry dropping shards one at a time.
    echo "  -> combined merge failed; retrying incrementally..." >&2
    local -a _accepted=()
    : > "${_merged}"
    for _f in "${_good[@]}"; do
      local -a _try=( "${_accepted[@]}" "$_f" )
      if merge-fdata "${_try[@]}" -o "${_merged}.try" >/dev/null 2>&1; then
        mv -f "${_merged}.try" "${_merged}"
        _accepted+=( "$_f" )
      else
        rm -f "${_merged}.try"
        echo "  -> shard incompatible in combination, skipped: ${_f##*/}" >&2
      fi
    done
    (( ${#_accepted[@]} > 0 )) || { echo "  -> no shards survived merge." >&2; return 1; }
  fi
  [[ -s "${_merged}" ]] || { echo "  -> merged profile is empty." >&2; return 1; }

  # Convert to modern YAML (best-effort).  Requires the matching binary.
  if llvm-bolt "${_bin}" --data="${_merged}" -w "${_yaml}" -o /dev/null >/dev/null 2>&1 \
     && [[ -s "${_yaml}" ]]; then
    echo "  -> using modern YAML profile format." >&2
    printf '%s\n' "${_yaml}"
    return 0
  fi

  echo "  -> YAML conversion unavailable; using legacy fdata profile." >&2
  printf '%s\n' "${_merged}"
  return 0
}

# -------------------------------------------------------------------------
# Build thin compiler wrappers that force `-fuse-ld=mold` and populate the
# global array _TEST_CC_ENV with the TEST_* assignments the mold suite honors.
#
# WHY THIS MUST WRAP EVERY ctest INVOCATION (training too, not just check()):
#   mold's tests link with `clang -B. -flto` and no -fuse-ld.  On a clang whose
#   DEFAULT linker is lld (e.g. -DCLANG_DEFAULT_LINKER=lld):
#     (a) `-B.` resolves to the system ld.lld instead of mold, and
#     (b) for -flto, clang omits the `-plugin` (LLVMgold) option because it
#         assumes lld's built-in LTO -- so even mold-as-ld.lld cannot read the
#         bitcode.
#   Forcing `-fuse-ld=mold` fixes BOTH: clang selects mold AND passes -plugin
#   (verified via `clang -###`).  Crucially, the PGO (Stage 2) and BOLT (Stage 5)
#   profile-collection runs ALSO run ctest; if they don't use these wrappers on
#   an lld-default toolchain, the LTO tests never exercise mold, so the training
#   profile MISSES mold's LTO code paths -- silently degrading PGO/BOLT quality
#   (and emitting the spurious comdat-mixed failure).  Hence one shared helper.
#
# `-fuse-ld=mold` is injected FIRST so a test that sets its own -fuse-ld later
# (e.g. run-clang.sh's -fuse-ld=/usr/bin/ld) still overrides it.
# -------------------------------------------------------------------------
_setup_test_cc_env() {
  local _build_dir="$1"
  local _wrap="${_build_dir}/.test-cc-wrappers"
  rm -rf "${_wrap}"; mkdir -p "${_wrap}"

  local _pair _name _tool _abs
  for _pair in cc:cc c++:c++ gcc:gcc g++:g++ clang:clang clang++:clang++; do
    _name="${_pair%%:*}"; _tool="${_pair##*:}"
    _abs="$(command -v "${_tool}" 2>/dev/null)" || continue
    {
      printf '#!/bin/sh\n'
      printf 'exec "%s" -B"%s" -fuse-ld=mold "$@"\n' "${_abs}" "${_build_dir}"
    } > "${_wrap}/${_name}"
    chmod +x "${_wrap}/${_name}"
  done

  # Ensure mold is discoverable under the name `-fuse-ld=mold` expects.  mold's
  # CMake already creates `${_build_dir}/ld -> mold`; add `ld.mold` too.
  [[ -e "${_build_dir}/mold" ]] && ln -sfn mold "${_build_dir}/ld.mold"

  # Exported as an array the callers prepend to ctest via `env`.  Only set knobs
  # whose wrapper was actually created (so a missing clang etc. is harmless).
  _TEST_CC_ENV=()
  [[ -x "${_wrap}/cc"     ]] && _TEST_CC_ENV+=( "TEST_CC=${_wrap}/cc" )
  [[ -x "${_wrap}/c++"    ]] && _TEST_CC_ENV+=( "TEST_CXX=${_wrap}/c++" )
  [[ -x "${_wrap}/gcc"    ]] && _TEST_CC_ENV+=( "TEST_GCC=${_wrap}/gcc" )
  [[ -x "${_wrap}/g++"    ]] && _TEST_CC_ENV+=( "TEST_GXX=${_wrap}/g++" )
  # TEST_CLANG is read by the clang-specific tests (e.g. the lto-comdat-mixed
  # one). The suite has no clang++ knob, so we don't set one.
  [[ -x "${_wrap}/clang"  ]] && _TEST_CC_ENV+=( "TEST_CLANG=${_wrap}/clang" )
}

build() {
  local _srcdir="${srcdir}/mold"
  local _build_dir="${srcdir}/build"
  local _pgo_dir="${srcdir}/pgo-profiles"
  local _bolt_dir="${srcdir}/bolt-profiles"

  export CMAKE_BUILD_PARALLEL_LEVEL="$(_jobs)"
  export MOLD_FORCE_EXIT_PRELOAD="${srcdir}/libforce_exit.so"

  msg2 "=============================================="
  msg2 "  PGO + BOLT optimized build for mold"
  msg2 "=============================================="

  rm -rf "${_build_dir}" "${_pgo_dir}" "${_bolt_dir}"
  mkdir -p "${_pgo_dir}" "${_bolt_dir}"

  # _exit/_Exit shim: mold deliberately calls _exit() to skip teardown, which
  # bypasses gcov AND BOLT instrumentation flushing.  Routing them through exit()
  # restores the atexit handlers so profiles are written.  (Verified necessary:
  # without this shim, zero .fdata/.gcda are produced.)
  cat > "${srcdir}/force_exit.c" <<'EOF'
#include <stdlib.h>
#include <unistd.h>
__attribute__((noreturn)) void _exit(int status) { exit(status); __builtin_unreachable(); }
__attribute__((noreturn)) void _Exit(int status) { exit(status); __builtin_unreachable(); }
EOF
  gcc -shared -fPIC -O2 "${srcdir}/force_exit.c" -o "${MOLD_FORCE_EXIT_PRELOAD}"

  local -a _common_cmake_args=(
    -G Ninja
    -S "${_srcdir}"
    -B "${_build_dir}"
    -DCMAKE_BUILD_TYPE=release-simd
    -DCMAKE_INSTALL_PREFIX=/usr
    -DCMAKE_INSTALL_LIBEXECDIR=lib
    -DCMAKE_C_COMPILER=gcc
    -DCMAKE_CXX_COMPILER=g++
    -DCMAKE_CXX_STANDARD=20
    -DCMAKE_CXX_STANDARD_REQUIRED=ON
    -DMOLD_TARGETS='X86_64;I386'
    -DMOLD_USE_MOLD=OFF
    -DMOLD_USE_MIMALLOC=ON
    -DMOLD_USE_SYSTEM_MIMALLOC=OFF
    -DMOLD_USE_SYSTEM_TBB=ON
  )

  # ====================================================================
  # Stage 1: GCC PGO instrumentation build (NO LTO — instrumentation must
  # be per-TU; LTO would defer/merge counters and slow profiling).
  # ====================================================================
  msg2 "=== Stage 1: GCC PGO profile-generation build ==="
  local _pgo_gen_flags="-fprofile-generate=${_pgo_dir} -fprofile-update=atomic"

  cmake "${_common_cmake_args[@]}" \
    -DMOLD_LTO=OFF \
    -DCMAKE_C_FLAGS="${CFLAGS} ${_pgo_gen_flags}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} ${_pgo_gen_flags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} ${_pgo_gen_flags}" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS} ${_pgo_gen_flags}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS} ${_pgo_gen_flags}"
  cmake --build "${_build_dir}"

  # ====================================================================
  # Stage 2: PGO profile collection (test suite + synthetic workload + self-link).
  # ====================================================================
  msg2 "=== Stage 2: PGO profile collection ==="
  # Force the test suite to link through mold (incl. the -flto tests) so the PGO
  # profile actually covers mold's LTO paths even on an lld-default clang.
  local -a _TEST_CC_ENV=()
  _setup_test_cc_env "${_build_dir}"
  LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD}" \
    env "${_TEST_CC_ENV[@]}" \
    ctest --test-dir "${_build_dir}" --output-on-failure -j "$(_jobs)" || true
  _generate_and_run_workload "${_build_dir}/mold"
  _build_mold_with_linker     "${_build_dir}/mold" "build_pgo_train"

  # ====================================================================
  # Stage 3: GCC PGO-use + LTO build, prepared for BOLT.
  #
  #  [P0-B] -fprofile-use MUST be on the link command: with LTO, final codegen
  #         happens at link time.  We append the full _pgo_use_flags to the
  #         linker flags (not just --emit-relocs).
  #  [P0-A] --plt=all (Stage 6) REQUIRES the input to be -z now.  We force
  #         -Wl,-z,now -Wl,-z,relro here so BOLT's --plt=all is always valid,
  #         independent of the user's makepkg LDFLAGS.
  #         -Wl,--emit-relocs: required for BOLT relocation mode.
  # ====================================================================
  msg2 "=== Stage 3: GCC PGO-use + LTO build (BOLT-ready) ==="
  rm -rf "${_build_dir}"

  local _pgo_use_flags="-fprofile-use=${_pgo_dir} -fprofile-correction \
-fno-reorder-blocks-and-partition -fno-peel-loops -fno-tracer \
-Wno-error=coverage-mismatch -Wno-error=missing-profile"
  local _bolt_link_flags="-Wl,--emit-relocs -Wl,-z,now -Wl,-z,relro"

  cmake "${_common_cmake_args[@]}" \
    -DMOLD_LTO=ON \
    -DCMAKE_C_FLAGS="${CFLAGS} ${_pgo_use_flags}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} ${_pgo_use_flags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} ${_pgo_use_flags} ${_bolt_link_flags}" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS} ${_pgo_use_flags} ${_bolt_link_flags}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS} ${_pgo_use_flags} ${_bolt_link_flags}"
  cmake --build "${_build_dir}"

  # Keep a pristine copy of the validated PGO binary — this is the BOLT input AND
  # the safe fallback if BOLT produces a broken result.
  cp -f "${_build_dir}/mold" "${srcdir}/mold.pgo"

  if ! _mold_selftest "${srcdir}/mold.pgo"; then
    error "PGO-built mold failed its self-test; aborting (this should never happen)."
    return 1
  fi

  # ====================================================================
  # Stage 4: BOLT instrumentation.
  # ====================================================================
  msg2 "=== Stage 4: BOLT instrumentation ==="
  llvm-bolt "${srcdir}/mold.pgo" \
    --instrument \
    --instrumentation-file="${_bolt_dir}/prof" \
    --instrumentation-file-append-pid \
    -o "${srcdir}/mold.inst"

  # ====================================================================
  # Stage 5: BOLT profile collection (run the INSTRUMENTED mold).
  # ====================================================================
  msg2 "=== Stage 5: BOLT profile collection ==="
  # The instrumented binary must be the one invoked.  We point the build tree's
  # mold at it ONLY for the duration of profiling, then restore.
  cp -f "${srcdir}/mold.inst" "${_build_dir}/mold"
  chmod +x "${_build_dir}/mold"

  # Same wrapper treatment as Stage 2 so the instrumented mold is exercised by
  # the LTO tests too -> richer BOLT profile.  (ld.mold now points at the
  # instrumented binary, which is exactly what we want to profile here.)
  local -a _TEST_CC_ENV=()
  _setup_test_cc_env "${_build_dir}"
  LD_PRELOAD="${MOLD_FORCE_EXIT_PRELOAD}" \
    env "${_TEST_CC_ENV[@]}" \
    ctest --test-dir "${_build_dir}" --output-on-failure -j "$(_jobs)" || true
  _generate_and_run_workload "${srcdir}/mold.inst"
  _build_mold_with_linker     "${srcdir}/mold.inst" "build_bolt_train"

  # Robustly merge the per-PID shards and convert to the modern YAML format.
  # This tolerates corrupt/truncated/empty shards (one bad shard no longer
  # aborts the whole merge) and prefers YAML over legacy fdata.  Echoes the
  # chosen profile path; empty on failure.
  msg2 "  -> Preparing BOLT profile (validate shards -> merge -> YAML)..."
  local _bolt_profile
  _bolt_profile="$(_bolt_prepare_profile "${srcdir}/mold.pgo" "${_bolt_dir}")" || _bolt_profile=""

  # Restore the pristine PGO binary as the BOLT input.
  cp -f "${srcdir}/mold.pgo" "${_build_dir}/mold"
  chmod +x "${_build_dir}/mold"

  if [[ -z "${_bolt_profile}" || ! -s "${_bolt_profile}" ]]; then
    warning "No usable BOLT profile could be produced; shipping the PGO binary."
    cp -f "${srcdir}/mold.pgo" "${_build_dir}/mold"
    chmod +x "${_build_dir}/mold"
    return 0
  fi
  msg2 "  -> BOLT profile ready: ${_bolt_profile##*/}"

  # ====================================================================
  # Stage 6: BOLT optimization.
  #
  #  [P0-C] Every flag/value is capability-probed against this llvm-bolt's
  #         --help[-hidden] before use, so a flag this BOLT version spells
  #         differently (e.g. --icf=all vs --icf=safe vs --icf=1) can never hard-
  #         fail the build.  Unknown flags are silently dropped.
  #  [P0-D] The result is self-tested; on failure we keep the PGO binary.
  #  [P0-E] The profile fed here is ${_bolt_profile} — produced by
  #         _bolt_prepare_profile, which validated/merged the shards and, when
  #         possible, converted them to the modern dense YAML format.  YAML is
  #         what makes --infer-stale-profile effective, so it is probed/enabled
  #         below as a resilience net against any profile<->binary skew.
  #
  #  Optimization posture is UNCHANGED from upstream (aggressive Class-B set).
  # ====================================================================
  msg2 "=== Stage 6: BOLT optimization ==="

  local _bhelp; _bhelp="$(llvm-bolt --help 2>&1; llvm-bolt --help-hidden 2>&1)"
  _bolt_has() { printf '%s\n' "${_bhelp}" | grep -q -- "$1"; }
  # _bolt_has_val <flag> <value>: true ONLY if <value> is a documented enum value
  # of THIS SPECIFIC flag.  We extract the flag's own block (its "=xxx" lines,
  # which are indented and immediately follow the "--flag=<value>" header, up to
  # the next "--option") and look for "=<value>" there.  A loose grep over the
  # whole help text is wrong: e.g. "=all" exists under --plt/--frame-opt even
  # though --icf is a BOOLEAN on some BOLT versions (where --icf=all hard-fails).
  _bolt_has_val() {
    printf '%s\n' "${_bhelp}" | awk -v f="$1" -v v="$2" '
      $0 ~ ("^[[:space:]]*"f"=")            { grab=1; next }
      grab && $0 ~ /^[[:space:]]*--[a-z]/   { grab=0 }
      grab && $0 ~ ("^[[:space:]]*="v"([[:space:]]|$)") { found=1 }
      END { exit(found?0:1) }
    '
  }

  local -a _bolt_opts=( --dyno-stats )

  # ------------------------------------------------------------------
  # Flag set tuned by an empirical sweep on a real PGO-style mold with
  # llvm-bolt 22.1.7 (see mold-audit/bolt-stats-analysis.md). Conclusion:
  # for mold, ALL the layout/perf win comes from the code-layout core PLUS
  # --plt=all; the other "aggressive" passes are measured NO-OPS on this
  # binary (it has 0 jump tables and 0 promotable indirect calls), so they
  # only add BOLT time (~25-30%) and miscompilation risk. They are therefore
  # OFF by default and gated behind MOLD_BOLT_AGGRESSIVE=1 for experimentation.
  # Every flag is still capability-probed so a version mismatch can't break
  # the build.
  # ------------------------------------------------------------------

  # Core: code layout + cleanup. This is where mold's win comes from
  # (taken-branches -57%, the I-cache/branch-predictor improvement).
  _bolt_has -- '--eliminate-unreachable'  && _bolt_opts+=( --eliminate-unreachable )
  _bolt_has -- '--reorder-blocks'         && _bolt_opts+=( --reorder-blocks=ext-tsp )
  _bolt_has -- '--reorder-functions'      && _bolt_opts+=( --reorder-functions=cdsort )
  _bolt_has -- '--split-functions'        && _bolt_opts+=( --split-functions )
  _bolt_has_val '--split-strategy' 'cdsplit' && _bolt_opts+=( --split-strategy=cdsplit )
  _bolt_has -- '--split-all-cold'         && _bolt_opts+=( --split-all-cold )
  _bolt_has -- '--split-eh'               && _bolt_opts+=( --split-eh )
  _bolt_has -- '--hot-text'               && _bolt_opts+=( --hot-text )

  # --plt=all: the ONE non-layout pass that measurably helps mold (executed
  # instructions -0.5% -> -2.5%, PLT calls -> 0). Requires -z now, which the
  # Stage-3 link guarantees.
  _bolt_has_val '--plt' 'all'             && _bolt_opts+=( --plt=all )

  # --icf: fold identical functions. Prefer 'safe' (only provably-identical
  # folds -> no correctness risk), then 'all', then boolean '1'.
  if   _bolt_has_val '--icf' 'safe'; then _bolt_opts+=( --icf=safe )
  elif _bolt_has_val '--icf' 'all';  then _bolt_opts+=( --icf=all )
  elif _bolt_has -- '--icf';         then _bolt_opts+=( --icf=1 )
  fi

  # --infer-stale-profile: cheap YAML-backed resilience net (no-op when the
  # profile is fresh, as it is here). Keep it.
  _bolt_has -- '--infer-stale-profile'    && _bolt_opts+=( --infer-stale-profile=1 )

  # Opt-in aggressive set: measured to add NOTHING on mold (kept for users who
  # want to re-test on a future mold/BOLT). Enable with MOLD_BOLT_AGGRESSIVE=1.
  if [[ "${MOLD_BOLT_AGGRESSIVE:-0}" == 1 ]]; then
    msg2 "  -> MOLD_BOLT_AGGRESSIVE=1: adding aggressive passes (measured no-op on mold)."
    _bolt_has_val '--frame-opt' 'all'               && _bolt_opts+=( --frame-opt=all )
    _bolt_has_val '--jump-tables' 'aggressive'      && _bolt_opts+=( --jump-tables=aggressive )
    _bolt_has_val '--indirect-call-promotion' 'all' && _bolt_opts+=( --indirect-call-promotion=all )
    _bolt_has_val '--peepholes' 'all'               && _bolt_opts+=( --peepholes=all )
    _bolt_has -- '--hot-data'                        && _bolt_opts+=( --hot-data )
    _bolt_has -- '--x86-strip-redundant-address-size' && _bolt_opts+=( --x86-strip-redundant-address-size )
    # --lite=false processes cold funcs too: measured to DOUBLE BOLT time and
    # grow the binary for ZERO dynostats gain on mold. Only with explicit opt-in.
    [[ "${MOLD_BOLT_NOLITE:-0}" == 1 ]] && _bolt_has -- '--lite' && _bolt_opts+=( --lite=false )
  fi

  # Protect mold's LTO-plugin callback from interprocedural-fragment rewriting
  # (BOLT warns about exactly this symbol on the real binary).
  local _skip='_ZN4moldL14get_symbols_v1EPKviPNS_12PluginSymbolE/1*'
  _bolt_has -- '--skip-funcs' && _bolt_opts+=( --skip-funcs="${_skip}" )

  msg2 "  -> BOLT flags: ${_bolt_opts[*]}"


  local _bolt_ok=0
  if llvm-bolt "${_build_dir}/mold" \
       --data="${_bolt_profile}" \
       "${_bolt_opts[@]}" \
       -o "${srcdir}/mold.bolt" 2>&1; then
    chmod +x "${srcdir}/mold.bolt"
    if _mold_selftest "${srcdir}/mold.bolt"; then
      _bolt_ok=1
    else
      warning "BOLT-optimized mold FAILED self-test; falling back to the PGO binary."
    fi
  else
    warning "llvm-bolt failed; falling back to the PGO binary."
  fi

  if (( _bolt_ok )); then
    msg2 "  -> BOLT optimization validated; installing BOLT binary."
    cp -f "${srcdir}/mold.bolt" "${_build_dir}/mold"
  else
    msg2 "  -> Using validated PGO binary (BOLT skipped/failed)."
    cp -f "${srcdir}/mold.pgo" "${_build_dir}/mold"
  fi
  chmod +x "${_build_dir}/mold"
}

check() {
  local _build_dir="${srcdir}/build"

  # The build/ tree's mold is the final (BOLT-or-PGO) validated binary.
  #
  # Force the suite to link through mold so it is actually exercised (and the
  # -flto tests get the LTO -plugin) even on a clang whose default linker is lld.
  # Same mechanism used by the Stage-2/5 training runs; see _setup_test_cc_env
  # for the full rationale.  Harmless if the host clang already defaults to ld.
  local -a _TEST_CC_ENV=()
  _setup_test_cc_env "${_build_dir}"

  env "${_TEST_CC_ENV[@]}" \
    ctest --test-dir "${_build_dir}" --output-on-failure -j "$(_jobs)"
}

package() {
  DESTDIR="${pkgdir}" cmake --install "${srcdir}/build"

  install -Dm644 "${srcdir}/mold/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  # Strip the FINAL binaries.  Verified safe on a BOLT-optimized mold (runs and
  # links correctly afterwards; saves ~1 MB).  Prefer llvm-strip, fall back to
  # binutils strip if unavailable.
  msg2 "Stripping installed binaries..."
  local _strip
  _strip="$(command -v llvm-strip || command -v strip || true)"
  if [[ -n "${_strip}" ]]; then
    local _file
    while IFS= read -r -d '' _file; do
      "${_strip}" --strip-unneeded "${_file}" 2>/dev/null || true
    done < <(find "${pkgdir}/usr/bin" "${pkgdir}/usr/lib" -type f -print0 2>/dev/null)
  fi
}
