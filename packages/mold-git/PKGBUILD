pkgname=mold-git
pkgver=2.40.4_105_ga91381b1
pkgrel=1
pkgdesc="A Modern Linker - PGO+BOLT Optimized for Desktop Gaming (Max Coverage)"
arch=('x86_64')
url="https://github.com/rui314/mold"
license=('MIT')
depends=('gcc-libs' 'openssl' 'zlib' 'onetbb' 'zstd')
makedepends=('git' 'python' 'cmake' 'llvm' 'gcc')
checkdepends=('clang' 'libdwarf' 'libunwind')
source=("mold::git+https://github.com/rui314/mold")
sha256sums=('SKIP')
provides=("mold=${pkgver}")
conflicts=('mold')
options=(!emptydirs !lto !strip)

pkgver() {
  cd mold
  git describe --long --tags | sed 's/^v//;s/-/_/g'
}

###########################################
# COMPREHENSIVE TRAINING WORKLOADS
###########################################

# Self-hosting mold to train real-world CMake/Make LTO linking paths
_build_mold_with_linker() {
  local _linker_bin="$(realpath "$1")"
  local _build_dir="$2"
  msg2 "  -> Self-hosting mold using ${_linker_bin}..."

  local _wrapper_dir="${srcdir}/ld_wrapper_${_build_dir}"
  mkdir -p "${_wrapper_dir}"
  ln -sf "${_linker_bin}" "${_wrapper_dir}/ld.mold"
  ln -sf "${_linker_bin}" "${_wrapper_dir}/mold"
  ln -sf "${_linker_bin}" "${_wrapper_dir}/ld"

  export PATH="${_wrapper_dir}:$PATH"

  local _custom_cxxflags="${CXXFLAGS} -B${_wrapper_dir}"
  local _custom_cflags="${CFLAGS} -B${_wrapper_dir}"

  cmake -S "${srcdir}/mold" -B "${_build_dir}" \
    -DCMAKE_BUILD_TYPE=Release \
    -DMOLD_USE_SYSTEM_TBB=ON \
    -DMOLD_USE_SYSTEM_MIMALLOC=OFF \
    -DMOLD_TARGETS='X86_64;I386' \
    -DCMAKE_C_COMPILER=gcc \
    -DCMAKE_CXX_COMPILER=g++ \
    -DCMAKE_C_FLAGS="${_custom_cflags}" \
    -DCMAKE_CXX_FLAGS="${_custom_cxxflags}" \
    -DCMAKE_EXE_LINKER_FLAGS="-B${_wrapper_dir} -fuse-ld=mold" \
    -DCMAKE_SHARED_LINKER_FLAGS="-B${_wrapper_dir} -fuse-ld=mold" >/dev/null 2>&1

  # LD_PRELOAD interceptor is already active in environment
  cmake --build "${_build_dir}" -j$(nproc) >/dev/null 2>&1
}

_generate_and_run_workload() {
  local _linker_bin="$(realpath "$1")"
  local _work_dir="${srcdir}/workload_$(date +%s)"
  mkdir -p "${_work_dir}"
  cd "${_work_dir}"

  msg2 "  -> Generating Massive AAA C++ Engine Mock..."

  # 1. Generate LTO actors (Stresses LTO Plugin, Virtuals, EH Frames, Deep Templates)
  for i in {1..30}; do
    cat > "actor_${i}.cpp" << EOF
#include <vector>
#include <string>
#include <map>
#include <memory>
#include <stdexcept>
template<int N> struct Deep {
    static int calc() {
        try { if (N % 2 == 0) throw std::runtime_error("even"); return Deep<N-1>::calc() + N; }
        catch (...) { return N; }
    }
};
template<> struct Deep<0> { static int calc() { return 0; } };

struct IEntity { virtual void tick() = 0; virtual ~IEntity() = default; };
struct Actor_${i} : public IEntity {
    std::vector<std::string> data;
    void tick() override {
        data.push_back("Heavy_String_Data_Merge_Test_${i}");
        if (Deep<15>::calc() > 0) data.push_back("Exception_Handled");
    }
    virtual ~Actor_${i}() = default;
};
void run_actor_${i}() { std::make_unique<Actor_${i}>()->tick(); }
EOF
  done

  # 2. Generate PURE C Non-LTO actors (Bypasses makepkg.conf LTO for pure ELF `-r` merging)
  for i in {1..15}; do
    cat > "simple_${i}.c" << EOF
#include <stdio.h>
const char* get_string_data_${i}() { return "string_merging_test_value_${i}"; }
int compute_data_${i}(int x) { return x * ${i}; }
EOF
  done

  cat > "main.cpp" << EOF
$(for i in {1..30}; do echo "extern void run_actor_${i}();"; done)
$(for i in {1..15}; do echo "extern \"C\" const char* get_string_data_${i}();"; done)
$(for i in {1..15}; do echo "extern \"C\" int compute_data_${i}(int x);"; done)
int main() {
    $(for i in {1..30}; do echo "run_actor_${i}();"; done)
    int acc = 0;
    $(for i in {1..15}; do echo "acc += compute_data_${i}(${i});"; done)
    return acc % 255;
}
EOF

  cat > Makefile << 'EOF'
LTO_SRCS := $(wildcard actor_*.cpp) main.cpp
NON_LTO_SRCS := $(wildcard simple_*.c)
LTO_OBJS := $(LTO_SRCS:.cpp=.o)
NON_LTO_OBJS := $(NON_LTO_SRCS:.c=.o)

all: $(LTO_OBJS) $(NON_LTO_OBJS)

$(LTO_OBJS): %.o: %.cpp
	$(CXX) $(CXXFLAGS) -O2 -g3 -flto -c $< -o $@

$(NON_LTO_OBJS): %.o: %.c
	$(CC) $(CFLAGS) -fno-lto -O2 -g3 -c $< -o $@
EOF

  msg2 "  -> Compiling Mock Objects (Parallel, LTO & Pure ELF)..."
  make -j$(nproc) >/dev/null 2>&1

  msg2 "  -> Executing Linker Stress Loop (Billions of Instructions)..."

  local _wrapper_dir="${_work_dir}/bin"
  mkdir -p "${_wrapper_dir}"
  ln -sf "${_linker_bin}" "${_wrapper_dir}/ld.mold"
  ln -sf "${_linker_bin}" "${_wrapper_dir}/mold"
  export PATH="${_wrapper_dir}:$PATH"

  local _link_cmd="g++ -B${_wrapper_dir} -fuse-ld=mold"

  # Hammer the linker to max out execution counts for precise BOLT block weights
  for iter in {1..40}; do
    # 1: Full Hybrid Link
    ${_link_cmd} ${CXXFLAGS} -flto -o game_engine *.o -lc -lstdc++ -lm

    # 2: Extreme CachyOS Optimization Link (RELR, ICF, GC, ZSTD, Now)
    ${_link_cmd} ${CXXFLAGS} -flto -Wl,-O1 -Wl,--as-needed -Wl,--gc-sections -Wl,--icf=all -Wl,--compress-debug-sections=zstd -Wl,-z,now -Wl,-z,relro -Wl,--pack-dyn-relocs=relr -o game_engine_opt *.o -lc -lstdc++ -lm

    # 3: Shared Library Creation
    ${_link_cmd} ${CXXFLAGS} -flto -shared -fPIC -Wl,-z,defs -o libgame_engine.so actor_1.o actor_2.o simple_1.o -lc -lstdc++ -lm

    # 4: Pure ELF Partial Linking
    "${_linker_bin}" -r -o game_engine_partial.o simple_*.o

    rm -f game_engine game_engine_opt libgame_engine.so game_engine_partial.o
  done

  cd "${srcdir}"
  rm -rf "${_work_dir}"
}

###########################################
# BUILD
###########################################

build() {
  local _srcdir="${srcdir}/mold"
  local _pgo_dir="${srcdir}/pgo-profiles"
  local _bolt_dir="${srcdir}/bolt-profiles"

  export MAKEFLAGS="-j$(nproc)"

  msg2 "=============================================="
  msg2 "  PGO+BOLT Optimized Build for mold"
  msg2 "=============================================="

  mkdir -p "${_pgo_dir}" "${_bolt_dir}"

  # =========================================================================
  # MAGIC FIX: Intercept mold's _exit(0) to force PGO/BOLT profile dumping
  # =========================================================================
  cat > "${srcdir}/force_exit.c" << 'EOF'
#include <stdlib.h>
void _exit(int status) { exit(status); }
void _Exit(int status) { exit(status); }
EOF
  gcc -shared -fPIC -O2 "${srcdir}/force_exit.c" -o "${srcdir}/libforce_exit.so"
  local _preload_env="${srcdir}/libforce_exit.so"

  local -a _common_cmake_args=(
    -S "${_srcdir}"
    -B build
    -DCMAKE_BUILD_TYPE=Release
    -DCMAKE_INSTALL_PREFIX=/usr
    -DCMAKE_INSTALL_LIBEXECDIR=lib
    -DMOLD_TARGETS='X86_64;I386'
    -DMOLD_USE_SYSTEM_MIMALLOC=OFF
    -DMOLD_USE_SYSTEM_TBB=ON
    -DCMAKE_C_STANDARD=23
    -DCMAKE_CXX_STANDARD=23
    -DMOLD_USE_MOLD=OFF
  )

  # =========================================================================
  # STAGE 1: GCC PGO Profile Generation
  # =========================================================================
  msg2 "=== Stage 1: PGO Profile Generation ==="

  local _pgo_gen_cflags="-fprofile-generate=${_pgo_dir} -fprofile-update=atomic -fno-peel-loops -fno-tracer"

  cmake "${_common_cmake_args[@]}" \
    -DMOLD_LTO=OFF \
    -DCMAKE_C_FLAGS="${CFLAGS} ${_pgo_gen_cflags}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} ${_pgo_gen_cflags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS}" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS}"

  cmake --build build

  # =========================================================================
  # STAGE 2: GCC PGO Profile Collection (WITH LD_PRELOAD)
  # =========================================================================
  msg2 "=== Stage 2: PGO Profile Collection ==="

  export LD_PRELOAD="${_preload_env}"
  ctest --test-dir build --output-on-failure -j$(nproc) >/dev/null 2>&1 || true
  _generate_and_run_workload "${srcdir}/build/mold"
  _build_mold_with_linker "${srcdir}/build/mold" "build_pgo_train"
  unset LD_PRELOAD

  # =========================================================================
  # STAGE 3: GCC PGO Optimized Build (LTO + Relocations for BOLT)
  # =========================================================================
  msg2 "=== Stage 3: PGO Optimized Build ==="

  rm -rf build

  local _pgo_use_cflags="-fprofile-use=${_pgo_dir} -fprofile-correction -fno-reorder-blocks-and-partition -fno-peel-loops -fno-tracer -Wno-error=coverage-mismatch"

  cmake "${_common_cmake_args[@]}" \
    -DMOLD_LTO=ON \
    -DCMAKE_C_FLAGS="${CFLAGS} ${_pgo_use_cflags}" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} ${_pgo_use_cflags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} -Wl,--emit-relocs" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS} -Wl,--emit-relocs" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS} -Wl,--emit-relocs"

  cmake --build build

  # =========================================================================
  # STAGE 4: BOLT Instrumentation
  # =========================================================================
  msg2 "=== Stage 4: BOLT Instrumentation ==="

  llvm-bolt build/mold \
    --instrument \
    --instrumentation-file="${_bolt_dir}/prof" \
    --instrumentation-file-append-pid \
    -o build/mold.inst

  # =========================================================================
  # STAGE 5: BOLT Profile Collection (WITH LD_PRELOAD)
  # =========================================================================
  msg2 "=== Stage 5: BOLT Profile Collection ==="

  mv build/mold build/mold.org
  cp build/mold.inst build/mold

  export LD_PRELOAD="${_preload_env}"
  ctest --test-dir build --output-on-failure -j$(nproc) >/dev/null 2>&1 || true
  _generate_and_run_workload "${srcdir}/build/mold"
  _build_mold_with_linker "${srcdir}/build/mold" "build_bolt_train"
  unset LD_PRELOAD

  merge-fdata "${_bolt_dir}"/prof*.fdata > "${_bolt_dir}/combined.fdata"
  mv build/mold.org build/mold

  # =========================================================================
  # STAGE 6: BOLT Optimization
  # =========================================================================
  msg2 "=== Stage 6: BOLT Optimization ==="

  llvm-bolt build/mold \
    --data="${_bolt_dir}/combined.fdata" \
    --dyno-stats \
    --eliminate-unreachable \
    --frame-opt=all \
    --icf=all \
    --jump-tables=aggressive \
    --plt=all \
    --hot-data \
    --hot-text \
    --peepholes=all \
    --infer-stale-profile=1 \
    --x86-strip-redundant-address-size \
    --indirect-call-promotion=all \
    --reorder-blocks=ext-tsp \
    --reorder-functions=cdsort \
    --split-all-cold \
    --split-functions \
    --split-strategy=cdsplit \
    --skip-funcs='_ZN4moldL14get_symbols_v1EPKviPNS_12PluginSymbolE/1*' \
    -o build/mold.bolt

  mv build/mold.bolt build/mold
}

check() {
  ctest --test-dir build --output-on-failure -j$(nproc) || true
}

package() {
  DESTDIR="${pkgdir}" cmake --install build

  install -Dm644 mold/LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  mkdir -p "${pkgdir}/usr/bin"
  ln -sf /usr/bin/mold "${pkgdir}/usr/bin/ld.mold"
  ln -sf /usr/bin/mold "${pkgdir}/usr/bin/ld64.mold"

  msg2 "Stripping binaries safely using llvm-strip..."
  find "${pkgdir}" -type f \( -name '*.so*' -o -name '*.a' -o -executable \) -print0 | while IFS= read -r -d '' file; do
    if llvm-strip --strip-unneeded "$file" 2>/dev/null || llvm-strip --strip-all "$file" 2>/dev/null; then
      echo "  Stripped: $file"
    fi
  done
}
