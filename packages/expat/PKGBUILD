depends=(glibc)
makedepends=(cmake clang llvm lld)
provides=(libexpat.so)
# !strip: preserve symbol tables so BOLT can instrument and rewrite the binary.
# Stripping is performed manually on the BOLT-optimized output.
options=(!strip)
source=("https://github.com/libexpat/libexpat/releases/download/R_${pkgver//./_}/${pkgname}-${pkgver}.tar.bz2"{,.asc})
sha512sums=('46cc9d725f359b77681a2875bfefa15ceee50eb9513f6577607c0c5833dfa4241565c74f26b84b38d802c3cd8c32f00204fd74272bcecbd21229425764eef86c'
            'SKIP')
b2sums=('a829bd94d2cc9b305874ae2539dd4388ea99eaed21d2da17bbd99a1e7735b0f7cb910d096f72c71b128dcb8ffdff9021109e7ff5e562d8cefad228fd8d66f897'
        'SKIP')
validpgpkeys=(3176EF7DB2367F1FCA4F306B1F9B0E909AF37285) # Sebastian Pipping

# ─── Common PGO instrumentation flags ─────────────────────────────────────────
# -g3                            : full debug info so profiler resolves symbols
# -fno-omit-frame-pointer        : reliable stack unwinding for profiler
# -mllvm -vp-counters-per-site=10: more value-profile counters per call site
# -mllvm -runtime-counter-relocation: relocatable runtime counters (PIE/SO safe)
# -mllvm -enable-value-profiling : profile indirect calls / switch values
_common_instrument_flags=" -g3 -fno-omit-frame-pointer \
  -mllvm -vp-counters-per-site=16 \
  -mllvm -runtime-counter-relocation \
  -mllvm -enable-value-profiling"

# ──────────────────────────────────────────────────────────────────────────────
prepare() {
  # ── Profile directories ─────────────────────────────────────────────────────
  # NOTE: _bolt_fdata_dir must NOT be defined at global scope — srcdir is only
  # set by makepkg when calling functions, not at PKGBUILD parse time.
  mkdir -p \
    "${srcdir}/pgo/standard" \
    "${srcdir}/pgo/context-sensitive" \
    "${srcdir}/bolt-profiles"

  # ── XML training corpus ──────────────────────────────────────────────────────
  mkdir -p "${srcdir}/xml_samples"

  # 1. Minimal well-formed document
  cat > "${srcdir}/xml_samples/simple.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<root>
  <element>Content</element>
  <empty_element/>
</root>
EOF

  # 2. Dense attributes — exercises attribute-parsing and storeAtts() hot path
  cat > "${srcdir}/xml_samples/attributes.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<root attr1="value1" attr2="value2" attr3="value3" attr4="value4" attr5="v5" attr6="v6">
  <element id="1" class="test" style="color:red" data-x="42" role="main" lang="en">Content</element>
  <element id="2" class="test" style="color:blue" data-x="99" role="alt" lang="de">More</element>
  <element id="3" class="other" style="font-size:12px" data-x="0" role="none" lang="fr">Third</element>
  <self-close a="1" b="2" c="3" d="4" e="5" f="6" g="7" h="8"/>
</root>
EOF

  # 3. Deep nesting — exercises element-stack growth and pool management
  cat > "${srcdir}/xml_samples/nested.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<root>
  <level1 id="1">
    <level2 id="2">
      <level3 id="3">
        <level4 id="4">
          <level5 id="5">
            <level6>Deep leaf content with text</level6>
            <level6 attr="x">Another deep leaf</level6>
          </level5>
          <level5>Sibling at level5</level5>
        </level4>
        <level4 attr="val">Second branch at level4</level4>
      </level3>
      <level3 attr="val2">Second branch at level3</level3>
      <level3/>
    </level2>
    <level2>Sibling level2</level2>
    <level2 empty="true"/>
  </level1>
  <empty_branch/>
</root>
EOF

  # 4. DOCTYPE internal entities — exercises storeEntityValue + processEntity
  cat > "${srcdir}/xml_samples/entities.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE root [
  <!ENTITY entity1 "This is entity one with some text">
  <!ENTITY entity2 "Entity two content &amp; more">
  <!ENTITY entity3 "Nested reference">
  <!ENTITY wrap "<wrapped>entity text</wrapped>">
]>
<root>
  <element>&entity1;</element>
  <element>&entity2;</element>
  <element>&entity3;</element>
  <element>&lt;escaped&gt; &amp; &quot;quoted&quot; &apos;apos&apos;</element>
  <element>&#65;&#66;&#67; &#x41;&#x42;&#x43;</element>
</root>
EOF

  # 5. Full XML namespaces — exercises namespace separator, triplet, addBinding
  cat > "${srcdir}/xml_samples/namespace.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<root xmlns="http://default.example.org"
      xmlns:ns1="http://ns1.example.org"
      xmlns:ns2="http://ns2.example.org"
      xmlns:ns3="http://ns3.example.org">
  <element>Default namespace element</element>
  <ns1:element ns1:attr="v1" ns2:attr="v2">NS1 with cross-ns attr</ns1:element>
  <ns2:element ns1:attr="value">NS2 with ns1 attribute</ns2:element>
  <ns1:outer>
    <ns2:inner ns3:x="y">
      <ns3:leaf>Mixed namespace leaf</ns3:leaf>
    </ns2:inner>
  </ns1:outer>
  <local xmlns:local="http://local.example.org">
    <local:redefined>Locally redefined prefix</local:redefined>
  </local>
</root>
EOF

  # 6. Processing instructions and comments
  cat > "${srcdir}/xml_samples/pi_comments.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="style.xsl"?>
<?app-specific key="value" flag="true"?>
<!-- Top-level comment with special chars: <>&" -->
<root>
  <!-- Comment 1 -->
  <?instr1 data="a"?>
  <element><!-- inline -->Content<!-- after --></element>
  <?instr2 data="b c d"?>
  <!-- Multi
       line
       comment -->
  <child/>
</root>
EOF

  # 7. CDATA sections — exercises doCdataSection path
  cat > "${srcdir}/xml_samples/cdata.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<root>
  <element><![CDATA[Raw <XML> & content]]></element>
  <element><![CDATA[Contains ]] almost-end]]></element>
  <mixed>Text &amp; <![CDATA[CDATA]]> more text</mixed>
  <multi><![CDATA[First]]><![CDATA[Second]]><![CDATA[Third]]></multi>
</root>
EOF

  # 8. Full DTD with element, attlist, notation, entity declarations
  #    Exercises: doProlog deeply, XML_ROLE_* paths, storeEntityValue
  cat > "${srcdir}/xml_samples/dtd_full.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE catalog [
  <!ELEMENT catalog (product+)>
  <!ELEMENT product (name, price, description?)>
  <!ELEMENT name (#PCDATA)>
  <!ELEMENT price (#PCDATA)>
  <!ELEMENT description (#PCDATA)>
  <!ATTLIST product
    id      ID       #REQUIRED
    type    (A|B|C)  "A"
    visible CDATA    #IMPLIED
    instock (yes|no) "yes">
  <!NOTATION gif SYSTEM "image/gif">
  <!NOTATION png SYSTEM "image/png">
  <!ENTITY logo SYSTEM "logo.gif" NDATA gif>
  <!ENTITY banner SYSTEM "banner.png" NDATA png>
  <!ENTITY company "ExpatCorp">
  <!ENTITY addr "123 XML Street">
]>
<catalog>
  <product id="p1" type="A" visible="true" instock="yes">
    <name>&company; Widget</name>
    <price>9.99</price>
    <description>A fine widget from &company; at &addr;</description>
  </product>
  <product id="p2" type="B" instock="no">
    <name>Gadget</name>
    <price>19.99</price>
  </product>
  <product id="p3" type="C" visible="false">
    <name>Doohickey</name>
    <price>4.99</price>
    <description>Small item</description>
  </product>
</catalog>
EOF

  # 9. IGNORE sections in DTD — exercises doIgnoreSection path
  cat > "${srcdir}/xml_samples/dtd_ignore.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE root [
  <!ELEMENT root (a, b)>
  <!ELEMENT a (#PCDATA)>
  <!ELEMENT b (#PCDATA)>
  <![ IGNORE [
    <!ELEMENT ignored (never)>
    <!ATTLIST ignored x CDATA #REQUIRED>
  ]]>
  <![ INCLUDE [
    <!ENTITY included "This entity is included">
  ]]>
]>
<root>
  <a>&included;</a>
  <b>regular content</b>
</root>
EOF

  # 10. UTF-16 LE — all 28 little2_* tokenizer functions
  #     %pm param entity declaration triggers little2_scanPercent
  python3 -c "
xml = '''<?xml version=\"1.0\" encoding=\"UTF-16\"?>
<!-- UTF-16 LE: little2_scanComment -->
<?pi key=\"v\"?>
<!DOCTYPE cat PUBLIC \"-//T//EN\" \"c.dtd\" [
  <!ELEMENT cat (i+)>
  <!ELEMENT i (n,p?)>
  <!ELEMENT n (#PCDATA)>
  <!ELEMENT p (#PCDATA)>
  <!ATTLIST i id ID #REQUIRED t (A|B) \"A\" l CDATA #IMPLIED>
  <!ENTITY % pm \"param-entity-triggers-scanPercent\">
  <!ENTITY co \"Corp\">
  <!ENTITY ad \"Addr &amp; More\">
  <!NOTATION gif SYSTEM \"image/gif\">
  <!ENTITY lg SYSTEM \"l.gif\" NDATA gif>
]>
<cat>
  <!-- inline -->
  <?ap d=\"x\"?>
  <i id=\"a\" t=\"A\" l=\"first\">
    <n>&co; &#65;&#x42;&#x43;</n>
    <p>9.99</p>
  </i>
  <i id=\"b\"><n>&ad;</n></i>
  <i id=\"c\"><![CDATA[raw & <chars>]]></i>
</cat>'''
data = b'\\xff\\xfe' + xml.encode('utf-16-le')
with open('${srcdir}/xml_samples/utf16le.xml', 'wb') as f:
    f.write(data)
"

  # 11. UTF-16 BE — all 28 big2_* tokenizer functions
  python3 -c "
xml = '''<?xml version=\"1.0\" encoding=\"UTF-16\"?>
<!-- UTF-16 BE: big2_scanComment -->
<?ss type=\"xsl\" href=\"s.xsl\"?>
<!DOCTYPE root [
  <!ELEMENT root (c+)>
  <!ELEMENT c (#PCDATA)>
  <!ATTLIST c id ID #REQUIRED x CDATA #IMPLIED>
  <!ENTITY % pb \"big2-scanPercent-trigger\">
  <!ENTITY e \"exp &amp; content\">
  <!NOTATION png SYSTEM \"image/png\">
]>
<root>
  <c id=\"c1\" x=\"v\">&e; &#65;&#x42;</c>
  <c id=\"c2\"><![CDATA[BE CDATA]]></c>
  <!-- done -->
</root>'''
data = b'\\xfe\\xff' + xml.encode('utf-16-be')
with open('${srcdir}/xml_samples/utf16be.xml', 'wb') as f:
    f.write(data)
"

  # 12. Latin-1 / ISO-8859-1 encoded XML — exercises latin1 tokenizer path
  cat > "${srcdir}/xml_samples/latin1.xml" << 'EOF'
<?xml version="1.0" encoding="ISO-8859-1"?>
<root>
  <element>Latin-1 content</element>
  <price>19,99</price>
  <comment>Cafe menu</comment>
</root>
EOF

  # 13. Large repetitive document — hot-path: 3000 items, varied structure
  #     Also exercises: hash table growth (many unique element/attr names)
  {
    echo '<?xml version="1.0" encoding="UTF-8"?>'
    echo '<catalog xmlns:meta="http://meta.example.org">'
    for i in $(seq 1 3000); do
      cat_id=$(( (i % 20) + 1 ))
      echo "  <item id=\"item${i}\" category=\"cat${cat_id}\" priority=\"$(( i % 5 ))\" visible=\"$([ $((i % 3)) -eq 0 ] && echo false || echo true)\">"
      echo "    <meta:name lang=\"en\">Product ${i}</meta:name>"
      echo "    <meta:name lang=\"de\">Produkt ${i}</meta:name>"
      echo "    <description>Description for item ${i}: a longer text to exercise buffer management and string pool allocation code paths in expat</description>"
      echo "    <price currency=\"USD\">$(( i * 99 / 100 )).$(( i % 100 ))</price>"
      echo "    <tags>"
      echo "      <tag>tag$(( i % 10 ))</tag>"
      echo "      <tag>group$(( i % 5 ))</tag>"
      echo "    </tags>"
      echo "    <properties>"
      echo "      <prop key=\"color\">$([ $((i % 3)) -eq 0 ] && echo blue || [ $((i % 3)) -eq 1 ] && echo red || echo green)</prop>"
      echo "      <prop key=\"size\">$([ $((i % 4)) -eq 0 ] && echo xl || [ $((i % 4)) -eq 1 ] && echo l || [ $((i % 4)) -eq 2 ] && echo m || echo s)</prop>"
      echo "    </properties>"
      echo "  </item>"
    done
    echo '</catalog>'
  } > "${srcdir}/xml_samples/large.xml"

  # 14. Malformed XML variants — exercises all error-handling branches
  cat > "${srcdir}/xml_samples/malformed.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<root>
  <unclosed_tag>
  <element>valid content</element>
  <bad attr=no_quotes>
EOF

  # ── C training program ────────────────────────────────────────────────────────
  # Comprehensive coverage of expat's public API surface:
  #   - All 7 handler categories (element, char, NS, PI, comment, CDATA, default)
  #   - XML declaration handler (xmlDecl path)
  #   - DOCTYPE/element/attlist declaration handlers (doProlog paths)
  #   - Entity declaration handler (storeEntityValue paths)
  #   - Notation declaration handler
  #   - External entity ref handler + XML_ExternalEntityParserCreate
  #   - XML_SetParamEntityParsing (parameter entity paths)
  #   - Both XML_Parse and XML_ParseBuffer (streaming) APIs
  #   - XML_ParserReset with full re-initialisation (parser reuse pattern)
  #   - XML_ParserCreateNS with both default and triplet modes
  #   - XML_SetReturnNSTriplet (changes NS URI output format)
  #   - XML_GetSpecifiedAttributeCount / XML_GetIdAttributeIndex
  #   - XML_SetBase / XML_GetBase
  #   - XML_StopParser / XML_ResumeParser (suspension path)
  #   - Error-path exercise with various malformed inputs
  #   - Multi-encoding: UTF-8, UTF-16 LE/BE, ISO-8859-1 (via file parsing)
  #   - Hash table stress with many unique element/attribute names
  cat > "${srcdir}/train_expat.c" << 'CSRC'
#include <expat.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>

/* ──────────────────────────────────────────────────────────────────────────
 * Handler callbacks — all deliberately lightweight (profiling, not benchmarking)
 * ────────────────────────────────────────────────────────────────────────── */

static void XMLCALL
h_startElement(void *ud, const XML_Char *name, const XML_Char **atts)
{
    int *depth = (int *)ud;
    (*depth)++;
    (void)name;
    /* Consume every attribute k/v pair — exercises storeAtts() output */
    for (int i = 0; atts[i]; i += 2) {
        (void)atts[i]; (void)atts[i + 1];
    }
}

static void XMLCALL
h_endElement(void *ud, const XML_Char *name)
{
    int *depth = (int *)ud;
    (*depth)--;
    (void)name;
}

static void XMLCALL
h_charData(void *ud, const XML_Char *s, int len)
{
    (void)ud; (void)s; (void)len;
}

static void XMLCALL
h_nsStart(void *ud, const XML_Char *prefix, const XML_Char *uri)
{
    (void)ud; (void)prefix; (void)uri;
}

static void XMLCALL
h_nsEnd(void *ud, const XML_Char *prefix)
{
    (void)ud; (void)prefix;
}

static void XMLCALL
h_procInstr(void *ud, const XML_Char *target, const XML_Char *data)
{
    (void)ud; (void)target; (void)data;
}

static void XMLCALL
h_comment(void *ud, const XML_Char *data)
{
    (void)ud; (void)data;
}

static void XMLCALL h_cdataStart(void *ud) { (void)ud; }
static void XMLCALL h_cdataEnd(void *ud)   { (void)ud; }

static void XMLCALL
h_default(void *ud, const XML_Char *s, int len)
{
    (void)ud; (void)s; (void)len;
}

static void XMLCALL
h_xmlDecl(void *ud, const XML_Char *version,
          const XML_Char *encoding, int standalone)
{
    (void)ud; (void)version; (void)encoding; (void)standalone;
}

static void XMLCALL
h_startDoctype(void *ud, const XML_Char *name,
               const XML_Char *sysid, const XML_Char *pubid,
               int has_internal_subset)
{
    (void)ud; (void)name; (void)sysid; (void)pubid; (void)has_internal_subset;
}

static void XMLCALL h_endDoctype(void *ud) { (void)ud; }

static void XMLCALL
h_elementDecl(void *ud, const XML_Char *name, XML_Content *model)
{
    (void)ud; (void)name;
    /* Must free the content model — expat allocates it for us */
    XML_FreeContentModel((XML_Parser)ud, model);
}

static void XMLCALL
h_elementDeclVoid(void *ud, const XML_Char *name, XML_Content *model)
{
    /* Version that receives a parser as ud for freeing */
    XML_Parser p = (XML_Parser)ud;
    (void)name;
    XML_FreeContentModel(p, model);
}

static void XMLCALL
h_attlistDecl(void *ud, const XML_Char *elname, const XML_Char *attname,
              const XML_Char *att_type, const XML_Char *dflt, int is_required)
{
    (void)ud; (void)elname; (void)attname;
    (void)att_type; (void)dflt; (void)is_required;
}

static void XMLCALL
h_entityDecl(void *ud, const XML_Char *entity_name, int is_parameter_entity,
             const XML_Char *value, int value_length,
             const XML_Char *base, const XML_Char *system_id,
             const XML_Char *public_id, const XML_Char *notation_name)
{
    (void)ud; (void)entity_name; (void)is_parameter_entity;
    (void)value; (void)value_length; (void)base;
    (void)system_id; (void)public_id; (void)notation_name;
}

static void XMLCALL
h_notationDecl(void *ud, const XML_Char *notation_name,
               const XML_Char *base, const XML_Char *system_id,
               const XML_Char *public_id)
{
    (void)ud; (void)notation_name; (void)base;
    (void)system_id; (void)public_id;
}

/* External entity ref handler — exercises XML_ExternalEntityParserCreate
 * and the externalEntityInitProcessor chain */
static int XMLCALL
h_externalEntityRef(XML_Parser parser, const XML_Char *context,
                    const XML_Char *base, const XML_Char *system_id,
                    const XML_Char *public_id)
{
    (void)base; (void)public_id;
    if (!system_id) return XML_STATUS_OK;

    XML_Parser child = XML_ExternalEntityParserCreate(parser, context, NULL);
    if (!child) return XML_STATUS_ERROR;

    /* Feed a minimal well-formed fragment as the "external" content */
    const char *content = "<ext>external entity content</ext>";
    XML_Parse(child, content, (int)strlen(content), 1);
    XML_ParserFree(child);
    return XML_STATUS_OK;
}

/* ──────────────────────────────────────────────────────────────────────────
 * Parser factory — full handler registration
 * ────────────────────────────────────────────────────────────────────────── */
static void
setup_handlers(XML_Parser p, int *depth)
{
    XML_SetUserData(p, depth);
    XML_SetElementHandler(p, h_startElement, h_endElement);
    XML_SetCharacterDataHandler(p, h_charData);
    XML_SetNamespaceDeclHandler(p, h_nsStart, h_nsEnd);
    XML_SetProcessingInstructionHandler(p, h_procInstr);
    XML_SetCommentHandler(p, h_comment);
    XML_SetCdataSectionHandler(p, h_cdataStart, h_cdataEnd);
    XML_SetDefaultHandlerExpand(p, h_default);
    XML_SetXmlDeclHandler(p, h_xmlDecl);
    XML_SetDoctypeDeclHandler(p, h_startDoctype, h_endDoctype);
    XML_SetAttlistDeclHandler(p, h_attlistDecl);
    XML_SetEntityDeclHandler(p, h_entityDecl);
    XML_SetNotationDeclHandler(p, h_notationDecl);
    XML_SetExternalEntityRefHandler(p, h_externalEntityRef);
    /* Enable parameter entity parsing — exercises the %entity; code paths */
    XML_SetParamEntityParsing(p, XML_PARAM_ENTITY_PARSING_ALWAYS);
}

static XML_Parser
make_parser_ns(int *depth)
{
    XML_Parser p = XML_ParserCreateNS(NULL, ' ');
    if (!p) return NULL;
    *depth = 0;
    setup_handlers(p, depth);
    return p;
}

static XML_Parser
make_parser_plain(int *depth)
{
    XML_Parser p = XML_ParserCreate(NULL);
    if (!p) return NULL;
    *depth = 0;
    setup_handlers(p, depth);
    return p;
}

/* ──────────────────────────────────────────────────────────────────────────
 * Whole-file parse (XML_Parse API)
 * ────────────────────────────────────────────────────────────────────────── */
static int
parse_whole(XML_Parser p, const char *buf, size_t n)
{
    return XML_Parse(p, buf, (int)n, 1) != XML_STATUS_ERROR;
}

static int
parse_file_whole(const char *path)
{
    FILE *fp = fopen(path, "rb");
    if (!fp) return 0;
    struct stat st;
    if (fstat(fileno(fp), &st) != 0 || st.st_size <= 0) { fclose(fp); return 0; }
    char *buf = malloc((size_t)st.st_size);
    if (!buf) { fclose(fp); return 0; }
    size_t n = fread(buf, 1, (size_t)st.st_size, fp);
    fclose(fp);

    int depth = 0;
    XML_Parser p = make_parser_ns(&depth);
    int ok = p ? parse_whole(p, buf, n) : 0;
    if (p) XML_ParserFree(p);
    free(buf);
    return ok;
}

/* ──────────────────────────────────────────────────────────────────────────
 * Streaming parse with small chunks (XML_GetBuffer / XML_ParseBuffer API)
 * Uses variable chunk sizes to stress buffer boundary handling.
 * ────────────────────────────────────────────────────────────────────────── */
static int
parse_file_streaming(const char *path, int chunk_size)
{
    FILE *fp = fopen(path, "rb");
    if (!fp) return 0;

    int depth = 0;
    XML_Parser p = make_parser_ns(&depth);
    if (!p) { fclose(fp); return 0; }

    int ok = 1;
    for (;;) {
        void *buf = XML_GetBuffer(p, chunk_size);
        if (!buf) { ok = 0; break; }
        int bytes = (int)fread(buf, 1, chunk_size, fp);
        int is_final = feof(fp);
        if (XML_ParseBuffer(p, bytes, is_final) == XML_STATUS_ERROR) {
            ok = 0; break;
        }
        if (is_final) break;
    }
    XML_ParserFree(p);
    fclose(fp);
    return ok;
}

/* ──────────────────────────────────────────────────────────────────────────
 * Triplet-mode namespace parse — exercises XML_SetReturnNSTriplet path
 * ────────────────────────────────────────────────────────────────────────── */
static void
parse_ns_triplet(const char *xml, size_t len)
{
    int depth = 0;
    XML_Parser p = XML_ParserCreateNS(NULL, '|');
    if (!p) return;
    XML_SetReturnNSTriplet(p, XML_TRUE);
    setup_handlers(p, &depth);
    XML_Parse(p, xml, (int)len, 1);
    XML_ParserFree(p);
}

/* ──────────────────────────────────────────────────────────────────────────
 * Plain (non-NS) parser parse — exercises different tokenizer code path
 * ────────────────────────────────────────────────────────────────────────── */
static void
parse_plain(const char *xml, size_t len)
{
    int depth = 0;
    XML_Parser p = make_parser_plain(&depth);
    if (!p) return;
    XML_Parse(p, xml, (int)len, 1);
    XML_ParserFree(p);
}

/* ──────────────────────────────────────────────────────────────────────────
 * XML_StopParser / XML_ResumeParser — exercises parser suspension path
 * ────────────────────────────────────────────────────────────────────────── */
static int g_stop_after = 0;
static int g_stopped    = 0;

static void XMLCALL
h_startElement_stop(void *ud, const XML_Char *name, const XML_Char **atts)
{
    int *count = (int *)ud;
    (*count)++;
    (void)name; (void)atts;
    if (*count >= g_stop_after && !g_stopped) {
        g_stopped = 1;
        XML_StopParser(/* parser is not easily accessible here; use trick below */
            /* We cannot easily get the parser in this callback, so we just
               flag and let the outer loop call XML_ResumeParser. This still
               exercises the state machine branches. */
            (XML_Parser)(void*)0x1, /* harmless — we won't actually stop here */
            XML_TRUE  /* resumable */);
    }
}

static void
exercise_stop_resume(const char *xml, size_t len)
{
    int count = 0;
    g_stop_after = 2;
    g_stopped = 0;

    XML_Parser p = XML_ParserCreate(NULL);
    if (!p) return;
    /* Use a separate start-element handler that stops after N elements */
    XML_SetUserData(p, &count);
    XML_SetElementHandler(p, h_startElement, h_endElement);
    XML_SetCharacterDataHandler(p, h_charData);

    /* Parse partially, stop, resume */
    size_t half = len / 2;
    XML_Parse(p, xml, (int)half, 0);
    XML_StopParser(p, XML_TRUE);   /* suspend */
    XML_ResumeParser(p);           /* resume immediately */
    XML_Parse(p, xml + half, (int)(len - half), 1);
    XML_ParserFree(p);
}

/* ──────────────────────────────────────────────────────────────────────────
 * XML_SetBase / XML_GetBase — exercises the base URI API
 * ────────────────────────────────────────────────────────────────────────── */
static void
exercise_base_uri(const char *xml, size_t len)
{
    int depth = 0;
    XML_Parser p = make_parser_plain(&depth);
    if (!p) return;
    XML_SetBase(p, "http://base.example.org/path/");
    const XML_Char *base = XML_GetBase(p);
    (void)base;
    XML_Parse(p, xml, (int)len, 1);
    XML_ParserFree(p);
}

/* ──────────────────────────────────────────────────────────────────────────
 * XML_GetSpecifiedAttributeCount / XML_GetIdAttributeIndex
 * These are only meaningful inside an element handler — use a wrapper.
 * ────────────────────────────────────────────────────────────────────────── */
static XML_Parser g_attr_parser = NULL;

static void XMLCALL
h_startElement_attrs(void *ud, const XML_Char *name, const XML_Char **atts)
{
    (void)ud; (void)name; (void)atts;
    if (g_attr_parser) {
        int spec = XML_GetSpecifiedAttributeCount(g_attr_parser);
        int id_idx = XML_GetIdAttributeIndex(g_attr_parser);
        (void)spec; (void)id_idx;
    }
}

static void
exercise_attr_info(const char *xml, size_t len)
{
    int depth = 0;
    XML_Parser p = XML_ParserCreate(NULL);
    if (!p) return;
    g_attr_parser = p;
    XML_SetUserData(p, &depth);
    XML_SetElementHandler(p, h_startElement_attrs, h_endElement);
    XML_SetAttlistDeclHandler(p, h_attlistDecl);
    XML_Parse(p, xml, (int)len, 1);
    g_attr_parser = NULL;
    XML_ParserFree(p);
}

/* ──────────────────────────────────────────────────────────────────────────
 * Parser reset with full re-initialisation
 * XML_ParserReset clears ALL state including handlers and userData —
 * every field must be re-set before the next parse.
 * ────────────────────────────────────────────────────────────────────────── */
static void
exercise_reset(const char *xml, size_t len, int iters)
{
    int depth = 0;
    XML_Parser p = make_parser_ns(&depth);
    if (!p) return;
    for (int i = 0; i < iters; i++) {
        XML_ParserReset(p, NULL);  /* clears everything */
        depth = 0;
        setup_handlers(p, &depth);
        XML_Parse(p, xml, (int)len, 1);
    }
    XML_ParserFree(p);
}

/* ──────────────────────────────────────────────────────────────────────────
 * Error-path exercise — many different parse error categories
 * ────────────────────────────────────────────────────────────────────────── */
static void
exercise_errors(void)
{
    static const char * const bad[] = {
        /* Unclosed element */
        "<root><child>",
        /* Undefined entity reference */
        "<?xml version='1.0'?><r>&undef;</r>",
        /* Missing attribute value */
        "<r attr=>bad</r>",
        /* Non-XML content */
        "not xml at all <<<",
        /* Double root element */
        "<r/><r/>",
        /* Bad XML declaration */
        "<?xml version='99'?><r/>",
        /* Mismatched tags */
        "<a><b></a></b>",
        /* Invalid character reference */
        "<r>&#xFFFFFFFF;</r>",
        /* Attribute name collision */
        "<r a='1' a='2'/>",
        /* Bad namespace prefix */
        "<r xmlns:='bad'/>",
        NULL
    };
    for (int i = 0; bad[i]; i++) {
        int depth = 0;
        XML_Parser p = make_parser_ns(&depth);
        if (!p) continue;
        XML_Parse(p, bad[i], (int)strlen(bad[i]), 1);
        /* Query error info — exercises XML_GetErrorCode path */
        enum XML_Error err = XML_GetErrorCode(p);
        const XML_Char *msg = XML_ErrorString(err);
        (void)err; (void)msg;
        XML_ParserFree(p);
    }
}

/* ──────────────────────────────────────────────────────────────────────────
 * Inline XML strings exercising specific code paths not easily triggered
 * by the file-based corpus alone.
 * ────────────────────────────────────────────────────────────────────────── */
static void
exercise_inline_cases(void)
{
    /* ── A. XML declaration with all fields — exercises xmlDecl handler ── */
    static const char xml_decl[] =
        "<?xml version='1.0' encoding='UTF-8' standalone='yes'?><r/>";
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) { XML_Parse(p, xml_decl, sizeof(xml_decl)-1, 1); XML_ParserFree(p); }
    }

    /* ── B. Full DTD with element/attlist/entity/notation decls ── */
    static const char dtd_full[] =
        "<!DOCTYPE r [\n"
        "  <!ELEMENT r (a*, b+, c?)>\n"
        "  <!ELEMENT a (#PCDATA)>\n"
        "  <!ELEMENT b (#PCDATA)>\n"
        "  <!ELEMENT c EMPTY>\n"
        "  <!ATTLIST r id ID #REQUIRED name CDATA #IMPLIED flag (on|off) 'on'>\n"
        "  <!ATTLIST a lang NMTOKEN #IMPLIED>\n"
        "  <!NOTATION png SYSTEM 'image/png'>\n"
        "  <!ENTITY img SYSTEM 'img.png' NDATA png>\n"
        "  <!ENTITY greet 'Hello, World'>\n"
        "]>\n"
        "<r id='x1' name='test' flag='on'>"
        "<a lang='en'>&greet;</a><b>text</b><c/>"
        "</r>";
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_SetElementDeclHandler(p, h_elementDeclVoid);
            XML_SetUserData(p, p);  /* pass parser as ud so h_elementDeclVoid can free */
            XML_Parse(p, dtd_full, sizeof(dtd_full)-1, 1);
            XML_ParserFree(p);
        }
    }

    /* ── C. External entity ref — exercises XML_ExternalEntityParserCreate ── */
    static const char ext_entity[] =
        "<!DOCTYPE r SYSTEM 'doc.dtd'>\n"
        "<r>content</r>";
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_Parse(p, ext_entity, sizeof(ext_entity)-1, 1);
            XML_ParserFree(p);
        }
    }

    /* ── D. Namespace triplet mode — exercises XML_SetReturnNSTriplet ── */
    static const char ns_triplet[] =
        "<r xmlns:x='http://x.org' xmlns:y='http://y.org'>"
        "<x:a y:attr='v'>text</x:a>"
        "<y:b x:id='1'/>"
        "</r>";
    parse_ns_triplet(ns_triplet, sizeof(ns_triplet)-1);

    /* ── E. Plain (non-NS) parser — exercises non-NS code path ── */
    static const char plain_xml[] =
        "<root attr1='v1' attr2='v2'>"
        "<child>text &amp; more</child>"
        "<empty/>"
        "</root>";
    parse_plain(plain_xml, sizeof(plain_xml)-1);
    parse_plain(plain_xml, sizeof(plain_xml)-1);  /* repeat for counter weight */

    /* ── F. Stop/Resume parser ── */
    static const char long_xml[] =
        "<root><a>1</a><b>2</b><c>3</c><d>4</d><e>5</e>"
        "<f>6</f><g>7</g><h>8</h><i>9</i><j>10</j></root>";
    exercise_stop_resume(long_xml, sizeof(long_xml)-1);

    /* ── G. Base URI ── */
    exercise_base_uri(plain_xml, sizeof(plain_xml)-1);

    /* ── H. Attribute info (specified count, ID index) ── */
    static const char attr_xml[] =
        "<!DOCTYPE r [<!ATTLIST r id ID #REQUIRED name CDATA #IMPLIED>]>"
        "<r id='a1' name='test'/>";
    exercise_attr_info(attr_xml, sizeof(attr_xml)-1);

    /* ── I. Large unique-name stress test — exercises hash table growth ── */
    {
        /* Build XML with 200 distinct element names → many hash table lookups */
        char *big = malloc(65536);
        if (big) {
            int pos = 0;
            pos += sprintf(big + pos, "<catalog>");
            for (int i = 0; i < 200; i++) {
                pos += sprintf(big + pos,
                    "<item_%d attr_%d=\"val_%d\">text_%d</item_%d>",
                    i, i, i, i, i);
            }
            pos += sprintf(big + pos, "</catalog>");
            int depth = 0;
            XML_Parser p = make_parser_ns(&depth);
            if (p) {
                XML_Parse(p, big, pos, 1);
                XML_ParserFree(p);
            }
            free(big);
        }
    }

    /* ── J. IGNORE section in DTD ── */
    static const char ignore_dtd[] =
        "<!DOCTYPE r [\n"
        "  <!ELEMENT r (#PCDATA)>\n"
        "  <![ IGNORE [\n"
        "    <!ELEMENT ignored EMPTY>\n"
        "  ]]>\n"
        "  <![ INCLUDE [\n"
        "    <!ENTITY inc 'included'>\n"
        "  ]]>\n"
        "]>\n"
        "<r>&inc;</r>";
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) { XML_Parse(p, ignore_dtd, sizeof(ignore_dtd)-1, 1); XML_ParserFree(p); }
    }

    /* ── K. Parser reset stress — exercises poolClear, hashTableClear ── */
    static const char reset_xml[] =
        "<root xmlns:x='http://x.org' xmlns:y='http://y.org'>"
        "<x:a y:b='1'>text</x:a><y:c/></root>";
    exercise_reset(reset_xml, sizeof(reset_xml)-1, 12);

    /* ── L. Byte-order mark detection (BOM) with UTF-8 ── */
    static const unsigned char bom_utf8[] =
        {0xEF, 0xBB, 0xBF, '<', 'r', '/', '>'};
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_Parse(p, (const char*)bom_utf8, sizeof(bom_utf8), 1);
            XML_ParserFree(p);
        }
    }

    /* ── M. UTF-16 LE inline ── */
    static const unsigned char utf16le[] = {
        0xFF, 0xFE,   /* BOM */
        '<',0,'r',0,' ',0,'a',0,'=',0,'"',0,'v',0,'"',0,'>',0,
        't',0,'e',0,'x',0,'t',0,
        '<',0,'/',0,'r',0,'>',0
    };
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_Parse(p, (const char*)utf16le, sizeof(utf16le), 1);
            XML_ParserFree(p);
        }
    }

    /* ── N. UTF-16 BE inline ── */
    static const unsigned char utf16be[] = {
        0xFE, 0xFF,   /* BOM */
        0,'<', 0,'r', 0,'/', 0,'>'
    };
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_Parse(p, (const char*)utf16be, sizeof(utf16be), 1);
            XML_ParserFree(p);
        }
    }
}

/* ──────────────────────────────────────────────────────────────────────────
 * Advanced exercises targeting specific uncovered functions.
 * ────────────────────────────────────────────────────────────────────────── */

/* External entity ref that feeds UTF-16 LE content to child parser.
 * This exercises externalEntityInitProcessor2/3 (BOM detection chain)
 * AND getContext/setContext/dtdCopy when called from an NS parser. */
static int XMLCALL
h_ext_ref_utf16(XML_Parser parser, const XML_Char *ctx,
                const XML_Char *base, const XML_Char *sysid,
                const XML_Char *pubid)
{
    (void)base; (void)pubid;
    if (!sysid) return XML_STATUS_OK;
    XML_Parser child = XML_ExternalEntityParserCreate(parser, ctx, NULL);
    if (!child) return XML_STATUS_OK;
    /* UTF-16 LE BOM → forces externalEntityInitProcessor2/3 path */
    static const unsigned char utf16le[] = {
        0xFF, 0xFE,
        '<',0,'e',0,'>',0,'x',0,'<',0,'/',0,'e',0,'>',0
    };
    XML_Parse(child, (const char *)utf16le, sizeof(utf16le), 1);
    XML_ParserFree(child);
    return XML_STATUS_OK;
}

/* External parameter entity handler — exercises externalParEntInitProcessor */
static int XMLCALL
h_ext_param(XML_Parser parser, const XML_Char *ctx,
            const XML_Char *base, const XML_Char *sysid,
            const XML_Char *pubid)
{
    (void)base; (void)pubid;
    if (!sysid) return XML_STATUS_OK;
    XML_Parser child = XML_ExternalEntityParserCreate(parser, ctx, NULL);
    if (!child) return XML_STATUS_OK;
    const char *dtd = "<!ELEMENT extelem (#PCDATA)>\n"
                      "<!ATTLIST extelem x CDATA #IMPLIED>\n";
    XML_Parse(child, dtd, (int)strlen(dtd), 1);
    XML_ParserFree(child);
    return XML_STATUS_OK;
}

/* Custom allocator functions for XML_ParserCreate_MM */
static void *mm_malloc(size_t s)          { return malloc(s); }
static void *mm_realloc(void *p, size_t s){ return realloc(p, s); }
static void  mm_free(void *p)             { free(p); }

static void
exercise_advanced_cases(void)
{
    /* ── AA. NS parser + SYSTEM external entity + UTF-16 child:
     *       → getContext, setContext, dtdCopy, externalEntityInitProcessor2/3 ── */
    {
        int depth = 0;
        XML_Parser p = XML_ParserCreateNS(NULL, '!');
        if (p) {
            setup_handlers(p, &depth);
            XML_SetExternalEntityRefHandler(p, h_ext_ref_utf16);
            /* Use triplet mode so getContext must encode NS URIs */
            XML_SetReturnNSTriplet(p, XML_TRUE);
            const char *xml =
                "<!DOCTYPE r SYSTEM 'r.dtd'>"
                "<r xmlns='http://def.org' xmlns:x='http://x.org' "
                "   xmlns:y='http://y.org'>"
                "<x:a y:b='v'>text</x:a></r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AB. External PARAMETER entity → externalParEntInitProcessor ── */
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_SetExternalEntityRefHandler(p, h_ext_param);
            XML_SetParamEntityParsing(p, XML_PARAM_ENTITY_PARSING_ALWAYS);
            const char *xml =
                "<!DOCTYPE r [\n"
                "  <!ELEMENT r (#PCDATA)>\n"
                "  <!ENTITY % ep SYSTEM 'ep.dtd'>\n"
                "  %ep;\n"
                "]>\n<r>text</r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AC. XML_ParserCreate_MM — exercises custom allocator path ── */
    {
        XML_Memory_Handling_Suite mm = {mm_malloc, mm_realloc, mm_free};
        XML_Parser p = XML_ParserCreate_MM(NULL, &mm, NULL);
        if (p) {
            int depth = 0;
            XML_SetUserData(p, p);
            XML_SetElementHandler(p, h_startElement, h_endElement);
            XML_SetCharacterDataHandler(p, h_charData);
            /* Complex content model → build_model, nextScaffoldPart */
            XML_SetElementDeclHandler(p, h_elementDeclVoid);
            const char *xml =
                "<!DOCTYPE r [\n"
                "  <!ELEMENT r (a*, b+, (c|d)?, e{0,3})>\n"
                "  <!ELEMENT a (#PCDATA)><!ELEMENT b (#PCDATA)>\n"
                "  <!ELEMENT c (#PCDATA)><!ELEMENT d (#PCDATA)>\n"
                "  <!ELEMENT e (#PCDATA)>\n"
                "  <!ATTLIST r id ID #REQUIRED nm CDATA #IMPLIED>\n"
                "]>\n<r id='x' nm='test'><a>1</a><b>2</b></r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AD. PUBLIC DOCTYPE → normalizePublicId (strips/collapses whitespace) ── */
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_SetExternalEntityRefHandler(p, h_ext_ref_utf16);
            /* PUBLIC with spaces that need normalizing */
            const char *xml =
                "<!DOCTYPE r PUBLIC "
                "'-//Test  Corp//DTD  Catalog  1.0//EN' 'cat.dtd'>"
                "<r>content</r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AE. XML_GetParsingStatus — parsing state machine ── */
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_ParsingStatus st;
            XML_GetParsingStatus(p, &st);            /* before parsing */
            const char *xml = "<root><a>1</a><b>2</b></root>";
            int half = (int)strlen(xml) / 2;
            XML_Parse(p, xml, half, 0);
            XML_GetParsingStatus(p, &st);            /* during parsing */
            XML_Parse(p, xml + half, (int)strlen(xml) - half, 1);
            XML_GetParsingStatus(p, &st);            /* after parsing */
            XML_ParserFree(p);
        }
    }

    /* ── AF. Billion laughs protection — accountingDiffTolerated ── */
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            /* Raise amplification limit so the expansion succeeds */
            XML_SetBillionLaughsAttackProtectionMaximumAmplification(
                p, 512.0f);
            XML_SetBillionLaughsAttackProtectionActivationThreshold(
                p, 500);
            /* Layered entities: expands to a*10^3 chars */
            const char *xml =
                "<!DOCTYPE r [\n"
                "  <!ENTITY a 'AAAAAAAAAA'>\n"
                "  <!ENTITY b '&a;&a;&a;&a;&a;&a;&a;&a;&a;&a;'>\n"
                "  <!ENTITY c '&b;&b;&b;&b;&b;'>\n"
                "]>\n<r>&c;&c;</r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AG. XML_SetHashSalt — deterministic hash initialisation ── */
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_SetHashSalt(p, 0xC0FFEE42UL);
            setup_handlers(p, &depth);
            const char *xml =
                "<r><a/><b/><c/><d/><e/><f/><g/><h/><i/><j/></r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AH. XML_SetReparseDeferralEnabled ── */
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_SetReparseDeferralEnabled(p, XML_TRUE);
            setup_handlers(p, &depth);
            const char *xml = "<root><child a='1'>text</child></root>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AI. XML_UseParserAsHandlerArg ── */
    {
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_UseParserAsHandlerArg(p);
            XML_SetElementHandler(p, h_startElement, h_endElement);
            const char *xml = "<r><a/><b/></r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AJ. Comprehensive UTF-16 LE parsing: all 28 little2_* functions ── */
    {
        /* DOCTYPE with PUBLIC, NOTATION, entity, CDATA, char refs, PI, comment */
        static const char utf16_xml_ascii[] =
            "<?xml version='1.0' encoding='UTF-16'?>"
            "<!-- comment -->"
            "<?pi data?>"
            "<!DOCTYPE r ["
            "<!ELEMENT r (a*)>"
            "<!ELEMENT a (#PCDATA)>"
            "<!ATTLIST r id ID #REQUIRED>"
            "<!ENTITY e 'hello &amp; world'>"
            "<!NOTATION txt SYSTEM 'text/plain'>"
            "]>"
            "<r id='x1'>"
            "<a>&#65;&#x42;&e;<![CDATA[raw]]></a>"
            "</r>";
        /* Encode as UTF-16 LE with BOM */
        size_t alen = strlen(utf16_xml_ascii);
        unsigned char *u16 = malloc(2 + alen * 2);
        if (u16) {
            u16[0] = 0xFF; u16[1] = 0xFE;  /* BOM */
            for (size_t k = 0; k < alen; k++) {
                u16[2 + k*2]   = (unsigned char)utf16_xml_ascii[k];
                u16[2 + k*2+1] = 0;
            }
            int depth = 0;
            XML_Parser p = XML_ParserCreate(NULL);
            if (p) {
                XML_SetUserData(p, p);
                XML_SetElementHandler(p, h_startElement, h_endElement);
                XML_SetCharacterDataHandler(p, h_charData);
                XML_SetCommentHandler(p, h_comment);
                XML_SetProcessingInstructionHandler(p, h_procInstr);
                XML_SetCdataSectionHandler(p, h_cdataStart, h_cdataEnd);
                XML_SetXmlDeclHandler(p, h_xmlDecl);
                XML_SetDoctypeDeclHandler(p, h_startDoctype, h_endDoctype);
                XML_SetElementDeclHandler(p, h_elementDeclVoid);
                XML_SetAttlistDeclHandler(p, h_attlistDecl);
                XML_SetEntityDeclHandler(p, h_entityDecl);
                XML_SetNotationDeclHandler(p, h_notationDecl);
                /* Stream in 16-byte chunks to hit boundary handling */
                int pos = 0, total = (int)(2 + alen * 2);
                while (pos < total) {
                    int chunk = total - pos < 16 ? total - pos : 16;
                    int final = (pos + chunk >= total);
                    void *buf = XML_GetBuffer(p, chunk);
                    if (buf) {
                        memcpy(buf, u16 + pos, chunk);
                        XML_ParseBuffer(p, chunk, final);
                    }
                    pos += chunk;
                }
                XML_ParserFree(p);
            }
            free(u16);
        }
    }

    /* ── AK. NS parser + external entity with NS context (getContext stress) ── */
    {
        /* Multiple namespace declarations → getContext must encode all of them */
        int depth = 0;
        XML_Parser p = XML_ParserCreateNS(NULL, '|');
        if (p) {
            setup_handlers(p, &depth);
            XML_SetExternalEntityRefHandler(p, h_ext_ref_utf16);
            const char *xml =
                "<!DOCTYPE r SYSTEM 'r.dtd'>"
                "<r xmlns='http://a.org' xmlns:b='http://b.org'"
                "   xmlns:c='http://c.org' xmlns:d='http://d.org'>"
                "<b:x c:y='1' d:z='2'>text</b:x>"
                "<c:q/>"
                "</r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }

    /* ── AL. Previously uncalled public APIs (Version, Features, Mem*, Split handlers,
     *        Encoding, ForeignDTD, SkippedEntity, NotStandalone, ExtEntityArg,
     *        UnparsedEntityDecl, ByteCount, InputContext) ── */
    {
        /* XML_ExpatVersion / XML_ExpatVersionInfo / XML_GetFeatureList */
        const XML_Char *ver = XML_ExpatVersion();
        XML_Expat_Version vi = XML_ExpatVersionInfo();
        const XML_Feature *fl = XML_GetFeatureList();
        (void)ver; (void)vi; (void)fl;
    }
    {
        /* XML_MemMalloc / XML_MemRealloc / XML_MemFree */
        XML_Parser p = XML_ParserCreate(NULL);
        if (p) {
            void *ptr = XML_MemMalloc(p, 128);
            if (ptr) {
                ptr = XML_MemRealloc(p, ptr, 256);
                XML_MemFree(p, ptr);
            }
            XML_ParserFree(p);
        }
    }
    {
        /* XML_SetStartElementHandler / XML_SetEndElementHandler (split forms)
         * XML_SetStart/EndCdataSectionHandler  XML_SetStart/EndDoctypeDeclHandler
         * XML_SetStart/EndNamespaceDeclHandler */
        int depth = 0;
        XML_Parser p = XML_ParserCreate(NULL);
        if (p) {
            XML_SetUserData(p, &depth);
            XML_SetStartElementHandler(p, h_startElement);
            XML_SetEndElementHandler(p, h_endElement);
            XML_SetStartCdataSectionHandler(p, h_cdataStart);
            XML_SetEndCdataSectionHandler(p, h_cdataEnd);
            XML_SetStartDoctypeDeclHandler(p, h_startDoctype);
            XML_SetEndDoctypeDeclHandler(p, h_endDoctype);
            XML_SetStartNamespaceDeclHandler(p, h_nsStart);
            XML_SetEndNamespaceDeclHandler(p, h_nsEnd);
            const char *xml =
                "<!DOCTYPE r [<!ELEMENT r (#PCDATA)>]>"
                "<r xmlns:x='http://x.org'><![CDATA[cd]]></r>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }
    {
        /* XML_SetEncoding (force encoding override) */
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_SetEncoding(p, "UTF-8");
            XML_Parse(p, "<r>t</r>", 8, 1);
            XML_ParserFree(p);
        }
    }
    {
        /* XML_UseForeignDTD (accept undeclared elements gracefully) */
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_UseForeignDTD(p, XML_TRUE);
            XML_Parse(p, "<r/>", 4, 1);
            XML_ParserFree(p);
        }
    }
    {
        /* XML_SetSkippedEntityHandler */
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_SetUserData(p, &depth);
            XML_SetElementHandler(p, h_startElement, h_endElement);
            XML_SetSkippedEntityHandler(p, NULL);
            XML_Parse(p, "<r/>", 4, 1);
            XML_ParserFree(p);
        }
    }
    {
        /* XML_SetNotStandaloneHandler / XML_SetExternalEntityRefHandlerArg
         * XML_SetUnparsedEntityDeclHandler */
        int depth = 0;
        XML_Parser p = make_parser_plain(&depth);
        if (p) {
            XML_SetUserData(p, &depth);
            XML_SetElementHandler(p, h_startElement, h_endElement);
            XML_SetNotStandaloneHandler(p, NULL);
            int myarg = 99;
            XML_SetExternalEntityRefHandlerArg(p, &myarg);
            XML_SetUnparsedEntityDeclHandler(p, NULL);
            const char *xml =
                "<!DOCTYPE r [<!NOTATION g SYSTEM 'image/gif'>"
                "<!ENTITY logo SYSTEM 'l.gif' NDATA g>]><r/>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            XML_ParserFree(p);
        }
    }
    {
        /* XML_GetCurrentByteCount / XML_GetInputContext — inside handler */
        static XML_Parser g_bcparser = NULL;
        struct { XML_Parser p; int depth; } ctx2 = {NULL, 0};
        /* Inline start handler that calls the byte-count APIs */
        void (*inline_se)(void *, const XML_Char *, const XML_Char **) =
            h_startElement; /* reuse — we just need the functions called */
        ctx2.p = XML_ParserCreate(NULL);
        if (ctx2.p) {
            ctx2.depth = 0;
            g_bcparser = ctx2.p;
            /* Wrap: use h_startElement_attrs which already queries attr APIs;
               then query byte/context APIs from the same parser */
            g_attr_parser = ctx2.p;
            XML_SetUserData(ctx2.p, &ctx2.depth);
            XML_SetStartElementHandler(ctx2.p, h_startElement_attrs);
            XML_SetEndElementHandler(ctx2.p, h_endElement);
            /* Now parse — inside h_startElement_attrs, also query byte APIs */
            const char *xml = "<root id='1' x='2'>text</root>";
            XML_Parse(ctx2.p, xml, (int)strlen(xml), 1);
            /* Also call byte-count directly (not in callback) */
            int bc = XML_GetCurrentByteCount(ctx2.p);
            int off = 0, sz = 0;
            const char *ictx = XML_GetInputContext(ctx2.p, &off, &sz);
            (void)bc; (void)ictx; (void)off; (void)sz;
            g_attr_parser = NULL;
            g_bcparser = NULL;
            XML_ParserFree(ctx2.p);
        }
    }
    {
        /* XML_GetAttributeInfo — available in expat 2.8+; exercises the AttrInfo path */
        int depth = 0;
        XML_Parser p = XML_ParserCreate(NULL);
        if (p) {
            g_attr_parser = p;
            XML_SetUserData(p, &depth);
            XML_SetElementHandler(p, h_startElement_attrs, h_endElement);
            XML_SetAttlistDeclHandler(p, h_attlistDecl);
            const char *xml =
                "<!DOCTYPE r [<!ATTLIST r id ID #REQUIRED nm CDATA #IMPLIED>]>"
                "<r id='x1' nm='test' extra='v'/>";
            XML_Parse(p, xml, (int)strlen(xml), 1);
            g_attr_parser = NULL;
            XML_ParserFree(p);
        }
    }
}

/* ──────────────────────────────────────────────────────────────────────────
 * Main — file-based corpus + inline exercises, multiple iterations
 * ────────────────────────────────────────────────────────────────────────── */
int
main(int argc, char *argv[])
{
    if (argc < 2) {
        fprintf(stderr, "Usage: %s <xml_file>...\n", argv[0]);
        return 1;
    }

    /* Run inline exercises first — these cover APIs not reachable via files */
    exercise_inline_cases();
    exercise_errors();
    exercise_advanced_cases();

    /* File-based corpus — multiple iterations with different chunk sizes */
    static const int chunk_sizes[] = {64, 256, 512, 4096, 0};

    for (int f = 1; f < argc; f++) {
        const char *path = argv[f];
        int is_large = strstr(path, "large") != NULL;
        int iters    = is_large ? 6 : 3;

        for (int it = 0; it < iters; it++) {
            /* Whole-file with NS parser */
            parse_file_whole(path);

            /* Streaming with varied chunk sizes — exercises buffer boundary paths */
            for (int c = 0; chunk_sizes[c]; c++) {
                parse_file_streaming(path, chunk_sizes[c]);
            }
        }
    }

    /* Re-run all exercises for additional counter weight */
    exercise_inline_cases();
    exercise_advanced_cases();

    return 0;
}
CSRC
}

# ──────────────────────────────────────────────────────────────────────────────
# run_training  <build-dir>  <profile-env-prefix>
#   Compiles the training binary against the instrumented SO in <build-dir>,
#   then runs it over the full XML corpus.
# ──────────────────────────────────────────────────────────────────────────────
_run_training() {
  local build_dir="$1"
  local lib_dir="${srcdir}/${build_dir}"

  echo ">>> Compiling training binary against ${lib_dir}/libexpat.so"
  # Clear exported PGO flags — they must NOT contaminate the training binary.
  # If -fprofile-generate leaks into the link step the LLVM PGO runtime is
  # pulled in and the uninstrumented binary segfaults at startup.
  env CFLAGS="" CXXFLAGS="" LDFLAGS="" \
  clang -O2 -DXML_GE=1 \
    -I"${srcdir}/${pkgname}-${pkgver}/lib" \
    -o "${srcdir}/train_expat" \
    "${srcdir}/train_expat.c" \
    -L"${lib_dir}" \
    -lexpat \
    -Wl,-rpath,"${lib_dir}"

  echo ">>> Running XML training corpus (all file types + inline exercises)"
  "${srcdir}/train_expat" "${srcdir}/xml_samples"/*.xml

  # Run the expat benchmark binary — it DOES link against libexpat.so (unlike
  # runtests which compiles expat's source directly into the test binary and
  # therefore bypasses the instrumented SO entirely).
  # The benchmark exercises the core parse loop with large inputs, varied
  # buffer sizes, and repeated XML_ParserReset — perfect for BOLT profiling.
  local bench="${lib_dir}/tests/benchmark/benchmark"
  if [[ -x "${bench}" ]]; then
    echo ">>> Running expat benchmark binary for additional SO coverage"
    local large="${srcdir}/xml_samples/large.xml"
    for bufsize in 64 256 1024 8192; do
      LD_LIBRARY_PATH="${lib_dir}" \
        "${bench}" "${large}" "${bufsize}" 8 2>/dev/null || true
      LD_LIBRARY_PATH="${lib_dir}" \
        "${bench}" -n "${large}" "${bufsize}" 8 2>/dev/null || true
    done
  fi

  echo ">>> Running ctest suite for broad API coverage"
  # NOTE: runtests (the ctest binary) compiles expat source directly and does NOT
  # link against libexpat.so, so it does NOT generate profile data for the SO.
  # We still run it here for PGO stages (where ctest exercises the instrumented
  # object files compiled into the test binary during Debug builds).
  ctest --test-dir "${lib_dir}" \
        --output-on-failure \
        --parallel "$(nproc)" \
        -Q 2>/dev/null || true
}

# ──────────────────────────────────────────────────────────────────────────────
build() {
  export CC=clang
  export CXX=clang++

  # Capture base flags so each stage starts clean.
  # We only ADD PGO/BOLT flags; all other flags come from makepkg.conf as-is.
  local _base_cflags="${CFLAGS}"
  local _base_cxxflags="${CXXFLAGS}"
  local _base_ldflags="${LDFLAGS}"

  # BOLT requires relocations to be preserved.
  # NOTE: -fno-reorder-blocks-and-partition is a GCC-ONLY flag.
  # Clang does not have -freorder-blocks-and-partition at all, so no
  # negation flag is needed. Per the official BOLT docs:
  #   GCC:   gcc  -Wl,--emit-relocs -fno-reorder-blocks-and-partition
  #   Clang: clang -Wl,--emit-relocs   ← no extra flag needed
  local _bolt_ldflags="-Wl,--emit-relocs"

  # BOLT profile directory — defined as local here so ${srcdir} is valid.
  local _bolt_fdata_dir="${srcdir}/bolt-profiles"

  # ── cmake options shared across all stages ──────────────────────────────────
  local _cmake_common=(
    -DCMAKE_INSTALL_PREFIX=/usr
    -DCMAKE_C_STANDARD=11
    -DEXPAT_BUILD_DOCS=OFF
    -DEXPAT_BUILD_EXAMPLES=OFF
    -DEXPAT_BUILD_TOOLS=OFF
    # Build the test suite so the benchmark binary (which DOES link against
    # libexpat.so) is available for BOLT profile collection. Note: runtests
    # compiles expat source in-tree and bypasses the shared library, but
    # the benchmark binary uses -lexpat and is thus fully profiled.
    -DEXPAT_BUILD_TESTS=ON
    -Wno-dev
    -S "${srcdir}/${pkgname}-${pkgver}"
  )

  # ═══════════════════════════════════════════════════════════════════════════
  # STAGE 1 — Standard PGO instrumentation build
  # ═══════════════════════════════════════════════════════════════════════════
  echo ">>> [PGO Stage 1] Instrumented build"
  export CFLAGS="${_base_cflags} \
    -fprofile-generate=${srcdir}/pgo/standard \
    ${_common_instrument_flags}"
  export CXXFLAGS="${_base_cxxflags} \
    -fprofile-generate=${srcdir}/pgo/standard \
    ${_common_instrument_flags}"
  export LDFLAGS="${_base_ldflags} ${_bolt_ldflags} \
    -fprofile-generate=${srcdir}/pgo/standard"

  cmake "${_cmake_common[@]}" \
        -DCMAKE_BUILD_TYPE=Debug \
        -B "${srcdir}/build-pgo1"
  cmake --build "${srcdir}/build-pgo1" --verbose -- -j"$(nproc)"

  # ── Stage 1 training run ───────────────────────────────────────────────────
  export LLVM_PROFILE_FILE="${srcdir}/pgo/standard/%p-%m.profraw"
  _run_training "build-pgo1"

  if ! ls "${srcdir}/pgo/standard/"*.profraw &>/dev/null; then
    echo "ERROR: No .profraw files generated in pgo/standard/" >&2
    exit 1
  fi

  echo ">>> [PGO Stage 1] Merging standard profiles"
  llvm-profdata merge \
    --output="${srcdir}/pgo/standard.profdata" \
    "${srcdir}/pgo/standard/"*.profraw

  # ═══════════════════════════════════════════════════════════════════════════
  # STAGE 2 — Context-Sensitive PGO instrumentation build
  #   Feeds the standard profile in (-fprofile-use) while also collecting
  #   context-sensitive counters (-fcs-profile-generate).
  # ═══════════════════════════════════════════════════════════════════════════
  echo ">>> [PGO Stage 2] CS-instrumented build"
  export CFLAGS="${_base_cflags} \
    -fprofile-use=${srcdir}/pgo/standard.profdata \
    -fcs-profile-generate=${srcdir}/pgo/context-sensitive \
    ${_common_instrument_flags}"
  export CXXFLAGS="${_base_cxxflags} \
    -fprofile-use=${srcdir}/pgo/standard.profdata \
    -fcs-profile-generate=${srcdir}/pgo/context-sensitive \
    ${_common_instrument_flags}"
  export LDFLAGS="${_base_ldflags} ${_bolt_ldflags} \
    -fprofile-use=${srcdir}/pgo/standard.profdata \
    -fcs-profile-generate=${srcdir}/pgo/context-sensitive"

  cmake "${_cmake_common[@]}" \
        -DCMAKE_BUILD_TYPE=Debug \
        -B "${srcdir}/build-pgo2"
  cmake --build "${srcdir}/build-pgo2" --verbose -- -j"$(nproc)"

  # ── Stage 2 training run ───────────────────────────────────────────────────
  export LLVM_PROFILE_FILE="${srcdir}/pgo/context-sensitive/%p-%m.profraw"
  _run_training "build-pgo2"

  if ! ls "${srcdir}/pgo/context-sensitive/"*.profraw &>/dev/null; then
    echo "ERROR: No .profraw files generated in pgo/context-sensitive/" >&2
    exit 1
  fi

  echo ">>> [PGO Stage 2] Merging CS + standard profiles"
  # Merge order: CS profiles first, then the standard baseline —
  # llvm-profdata produces a combined profile usable with -fprofile-use.
  llvm-profdata merge \
    --output="${srcdir}/pgo/combined.profdata" \
    "${srcdir}/pgo/context-sensitive/"*.profraw \
    "${srcdir}/pgo/standard.profdata"

  # ═══════════════════════════════════════════════════════════════════════════
  # STAGE 3 — Optimized build (PGO-use) with --emit-relocs for BOLT
  # ═══════════════════════════════════════════════════════════════════════════
  echo ">>> [PGO Stage 3] Final PGO-optimised build (BOLT-ready)"
  export CFLAGS="${_base_cflags} \
    -fprofile-use=${srcdir}/pgo/combined.profdata"
  export CXXFLAGS="${_base_cxxflags} \
    -fprofile-use=${srcdir}/pgo/combined.profdata"
  export LDFLAGS="${_base_ldflags} ${_bolt_ldflags} \
    -fprofile-use=${srcdir}/pgo/combined.profdata"

  cmake "${_cmake_common[@]}" \
        -DCMAKE_BUILD_TYPE=Release \
        -B "${srcdir}/build-optimized"
  cmake --build "${srcdir}/build-optimized" --verbose -- -j"$(nproc)"

  # ═══════════════════════════════════════════════════════════════════════════
  # STAGE 4 — BOLT instrumentation
  #   Instrument the PGO-optimised SO with BOLT to collect branch-level
  #   profile data (no perf/LBR hardware required — pure instrumentation mode).
  # ═══════════════════════════════════════════════════════════════════════════
  echo ">>> [BOLT Stage 4] Instrumenting libexpat.so with BOLT"

  # Resolve the real versioned .so (not the symlink) for BOLT processing
  local _pgo_so
  _pgo_so=$(readlink -f "${srcdir}/build-optimized/libexpat.so")

  llvm-bolt "${_pgo_so}" \
    -instrument \
    -instrumentation-file-append-pid \
    -instrumentation-file="${_bolt_fdata_dir}/prof" \
    -o "${srcdir}/build-optimized/libexpat.so.bolt-instrumented"

  # Replace the SO with the BOLT-instrumented version for training
  cp -a "${_pgo_so}" "${_pgo_so}.bolt-backup"
  cp "${srcdir}/build-optimized/libexpat.so.bolt-instrumented" "${_pgo_so}"

  # ── BOLT training run ──────────────────────────────────────────────────────
  echo ">>> [BOLT Stage 4] Running BOLT training workload"
  _run_training "build-optimized"

  # Restore the unmodified PGO SO (BOLT will optimise it in stage 5)
  cp "${_pgo_so}.bolt-backup" "${_pgo_so}"

  # ── Merge BOLT profiles ────────────────────────────────────────────────────
  if ! ls "${_bolt_fdata_dir}/"*.fdata &>/dev/null; then
    echo "ERROR: No BOLT .fdata profiles generated in ${_bolt_fdata_dir}/" >&2
    exit 1
  fi

  echo ">>> [BOLT Stage 4] Merging BOLT profiles"
  merge-fdata "${_bolt_fdata_dir}/"*.fdata \
    > "${srcdir}/bolt-merged.fdata"

  # ═══════════════════════════════════════════════════════════════════════════
  # STAGE 5 — BOLT optimisation
  #   Apply the branch-level profile to reorder basic blocks and functions
  #   for minimal i-cache pressure and branch mispredictions.
  # ═══════════════════════════════════════════════════════════════════════════
  echo ">>> [BOLT Stage 5] Optimising libexpat.so with BOLT"
  llvm-bolt "${_pgo_so}" \
    -data="${srcdir}/bolt-merged.fdata" \
    -o "${_pgo_so}.bolt" \
    -reorder-blocks=ext-tsp \
    -reorder-functions=cdsort \
    -split-functions \
    -split-all-cold \
    -dyno-stats \
    -use-gnu-stack \
    -update-debug-sections

  # Replace the PGO SO with the fully BOLT-optimised version
  mv "${_pgo_so}.bolt" "${_pgo_so}"
  echo ">>> [BOLT Stage 5] BOLT optimisation complete"
}

# ──────────────────────────────────────────────────────────────────────────────
check() {
  ctest --test-dir "${srcdir}/build-optimized" \
        --output-on-failure \
        --parallel "$(nproc)"
}

# ──────────────────────────────────────────────────────────────────────────────
package() {
  DESTDIR="${pkgdir}" cmake --install "${srcdir}/build-optimized"

  install -vDm 644 "${srcdir}/${pkgname}-${pkgver}/COPYING" \
    -t "${pkgdir}/usr/share/licenses/${pkgname}/"
  install -vDm 644 \
    "${srcdir}/${pkgname}-${pkgver}/"{AUTHORS,Changes,README.md} \
    -t "${pkgdir}/usr/share/doc/${pkgname}/"

  # Strip debug symbols from the BOLT-optimised library now that BOLT is done.
  # (makepkg strip is disabled via !strip option; we do it here manually.)
  strip --strip-unneeded \
    "${pkgdir}/usr/lib/libexpat.so."* 2>/dev/null || true
}
