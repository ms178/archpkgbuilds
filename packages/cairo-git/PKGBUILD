# Maintainer: CachyOS Team
# Triple-stage PGO+BOLT build: IR PGO → CS-PGO → BOLT
# Uses LLVM IR-level PGO (-fprofile-generate/-fprofile-use) — NOT frontend
# instrumentation (-fprofile-instr-generate). IR PGO is the only mode that
# composes correctly with -fcs-profile-generate for context-sensitive PGO.

pkgbase=cairo
pkgname=(cairo-git)
pkgver=1.18.4+109+g8e3ac5e40
pkgrel=1
pkgdesc="2D graphics library with IR PGO + CS-PGO + BOLT optimization"
url="https://cairographics.org/"
arch=(x86_64)
license=(LGPL MPL)
depends=(
  zlib
  libpng
  fontconfig
  freetype2
  libx11
