pkgbase=cairo
pkgname=(
  cairo-git
)
pkgver=1.18.4+94+gc85d74aa5
pkgrel=5
pkgdesc="2D graphics library with multi-stage IR PGO + CS-PGO + BOLT optimization"
url="https://cairographics.org/"
arch=(x86_64)
license=(LGPL MPL)
depends=(
  zlib
  libpng
  fontconfig
  freetype2
  libx11
  libxext
  libxrender
  libxcb
  glib2
  pixman
)
makedepends=(
  git
  meson
  clang
  llvm
  python
  bolt
  lld
  pkgconf
)
provides=(cairo)
conflicts=(cairo)
options=(!strip)
source=("git+https://gitlab.freedesktop.org/cairo/cairo.git")
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/cairo"
  git describe --tags | sed 's/-/+/g'
}

meson_array() {
  local out="["
  local arg
  for arg in "$@"; do
    arg=${arg//\\/\\\\}
    arg=${arg//\'/\\\'}
    out+="'$arg',"
  done
  out="${out%,}]"
  printf "%s" "$out"
}

filter_workload_flags() {
  local -n in="$1"
  local -n out="$2"
  out=()
  local f
  for f in "${in[@]}"; do
    case "$f" in
      -fprofile-generate*|-fprofile-use*|-fcs-profile-generate*|-fprofile-correction|-fprofile-instr-generate*|-fprofile-instr-use*|-fcoverage-mapping)
        continue
        ;;
    esac
    out+=("$f")
  done
}

prepare() {
  cd "${srcdir}/cairo"

  cat > "${srcdir}/cairo_workload.c" << 'EOF'
#include <cairo/cairo.h>
#include <cairo/cairo-pdf.h>
#include <cairo/cairo-ps.h>
#include <cairo/cairo-svg.h>

#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

#define W 2560
#define H 1440

static uint64_t rng_state = 0x9E3779B97F4A7C15ULL;

static inline uint32_t rng_u32(void) {
  uint64_t x = rng_state;
  x ^= x >> 12;
  x ^= x << 25;
  x ^= x >> 27;
  rng_state = x;
  return (uint32_t)((x * 0x2545F4914F6CDD1DULL) >> 32);
}

static inline double frand(double lo, double hi) {
  return lo + (hi - lo) * ((double)rng_u32() / (double)UINT32_MAX);
}

static void paint_bg(cairo_t *cr) {
  cairo_set_source_rgb(cr, 0.08, 0.09, 0.10);
  cairo_paint(cr);
}

static void mode_stroke_fill(cairo_t *cr, int n) {
  for (int i = 0; i < n; i++) {
    cairo_set_line_width(cr, frand(0.4, 8.0));
    cairo_set_operator(cr, (cairo_operator_t)(rng_u32() % 13));
    cairo_set_source_rgba(cr, frand(0, 1), frand(0, 1), frand(0, 1), frand(0.25, 1.0));

    int t = (int)(rng_u32() % 4);
    if (t == 0) {
      cairo_rectangle(cr, frand(0, W), frand(0, H), frand(6, 400), frand(6, 300));
    } else if (t == 1) {
      cairo_arc(cr, frand(0, W), frand(0, H), frand(4, 180), 0.0, 2.0 * M_PI);
    } else if (t == 2) {
      cairo_move_to(cr, frand(0, W), frand(0, H));
      for (int j = 0; j < 6; j++) {
        cairo_curve_to(cr, frand(0, W), frand(0, H), frand(0, W), frand(0, H), frand(0, W), frand(0, H));
      }
      cairo_close_path(cr);
    } else {
      cairo_move_to(cr, frand(0, W), frand(0, H));
      for (int j = 0; j < 10; j++) {
        cairo_line_to(cr, frand(0, W), frand(0, H));
      }
      cairo_close_path(cr);
    }

    if (rng_u32() & 1) {
      cairo_fill(cr);
    } else {
      cairo_stroke(cr);
    }
  }
}

static void mode_patterns(cairo_t *cr, int n) {
  for (int i = 0; i < n; i++) {
    cairo_pattern_t *p;
    if (rng_u32() & 1) {
      p = cairo_pattern_create_linear(frand(0, W), frand(0, H), frand(0, W), frand(0, H));
    } else {
      p = cairo_pattern_create_radial(frand(0, W), frand(0, H), frand(10, 60), frand(0, W), frand(0, H), frand(80, 600));
    }

    int stops = 2 + (rng_u32() % 5);
    for (int s = 0; s < stops; s++) {
      double t = (double)s / (double)(stops - 1);
      cairo_pattern_add_color_stop_rgba(p, t, frand(0, 1), frand(0, 1), frand(0, 1), frand(0.25, 1.0));
    }

    cairo_set_source(cr, p);
    cairo_rectangle(cr, frand(0, W), frand(0, H), frand(20, 900), frand(20, 700));
    cairo_fill(cr);
    cairo_pattern_destroy(p);
  }
}

static void mode_text(cairo_t *cr, int n) {
  const char *fonts[] = { "Sans", "Serif", "Monospace", "Arial", "Helvetica" };
  const char *words[] = { "cairo", "pgo", "cs-pgo", "vector", "raster", "glyph", "blend" };

  for (int i = 0; i < n; i++) {
    cairo_select_font_face(
      cr,
      fonts[rng_u32() % 5],
      (rng_u32() & 1) ? CAIRO_FONT_SLANT_ITALIC : CAIRO_FONT_SLANT_NORMAL,
      (rng_u32() & 1) ? CAIRO_FONT_WEIGHT_BOLD : CAIRO_FONT_WEIGHT_NORMAL
    );
    cairo_set_font_size(cr, frand(8.0, 96.0));
    cairo_set_source_rgba(cr, frand(0, 1), frand(0, 1), frand(0, 1), frand(0.35, 1.0));
    cairo_move_to(cr, frand(0, W), frand(0, H));
    cairo_show_text(cr, words[rng_u32() % 7]);
  }
}

static void mode_recording_replay(cairo_t *dst, int n) {
  cairo_rectangle_t ext = { 0, 0, W, H };
  cairo_surface_t *rec = cairo_recording_surface_create(CAIRO_CONTENT_COLOR_ALPHA, &ext);
  cairo_t *rcr = cairo_create(rec);

  paint_bg(rcr);
  mode_stroke_fill(rcr, n);
  mode_patterns(rcr, n / 2);
  mode_text(rcr, n / 3);

  cairo_set_source_surface(dst, rec, 0, 0);
  cairo_paint(dst);

  cairo_destroy(rcr);
  cairo_surface_destroy(rec);
}

static void render_mode(cairo_t *cr, const char *mode, int rounds) {
  for (int i = 0; i < rounds; i++) {
    paint_bg(cr);

    if (strcmp(mode, "stroke") == 0) {
      mode_stroke_fill(cr, 1200);
    } else if (strcmp(mode, "patterns") == 0) {
      mode_patterns(cr, 900);
    } else if (strcmp(mode, "text") == 0) {
      mode_text(cr, 1800);
    } else if (strcmp(mode, "record") == 0) {
      mode_recording_replay(cr, 900);
    } else if (strcmp(mode, "image") == 0) {
      mode_stroke_fill(cr, 800);
      mode_patterns(cr, 500);
      mode_text(cr, 700);
    } else {
      mode_stroke_fill(cr, 600);
      mode_patterns(cr, 400);
      mode_text(cr, 500);
      mode_recording_replay(cr, 450);
    }

    cairo_surface_flush(cairo_get_target(cr));
  }
}

static int run_backend_files(const char *base, int rounds) {
  char path[512];

  snprintf(path, sizeof(path), "%s.pdf", base);
  cairo_surface_t *pdf = cairo_pdf_surface_create(path, W, H);
  cairo_t *pcr = cairo_create(pdf);
  render_mode(pcr, "all", rounds);
  cairo_show_page(pcr);
  cairo_destroy(pcr);
  cairo_surface_destroy(pdf);

  snprintf(path, sizeof(path), "%s.svg", base);
  cairo_surface_t *svg = cairo_svg_surface_create(path, W, H);
  cairo_t *scr = cairo_create(svg);
  render_mode(scr, "all", rounds);
  cairo_show_page(scr);
  cairo_destroy(scr);
  cairo_surface_destroy(svg);

  snprintf(path, sizeof(path), "%s.ps", base);
  cairo_surface_t *ps = cairo_ps_surface_create(path, W, H);
  cairo_t *qcr = cairo_create(ps);
  render_mode(qcr, "all", rounds);
  cairo_show_page(qcr);
  cairo_destroy(qcr);
  cairo_surface_destroy(ps);

  return 0;
}

int main(int argc, char **argv) {
  const char *mode = "all";
  int rounds = 2;
  uint64_t seed = 0x123456789ULL;

  for (int i = 1; i < argc; i++) {
    if (!strcmp(argv[i], "--mode") && i + 1 < argc) {
      mode = argv[++i];
    } else if (!strcmp(argv[i], "--rounds") && i + 1 < argc) {
      rounds = atoi(argv[++i]);
    } else if (!strcmp(argv[i], "--seed") && i + 1 < argc) {
      seed = strtoull(argv[++i], NULL, 10);
    }
  }

  if (rounds < 1) {
    rounds = 1;
  }

  rng_state = seed;

  cairo_surface_t *img = cairo_image_surface_create(CAIRO_FORMAT_ARGB32, W, H);
  if (cairo_surface_status(img) != CAIRO_STATUS_SUCCESS) {
    fprintf(stderr, "failed to create image surface\n");
    return 1;
  }

  cairo_t *cr = cairo_create(img);
  if (cairo_status(cr) != CAIRO_STATUS_SUCCESS) {
    fprintf(stderr, "failed to create cairo context\n");
    cairo_surface_destroy(img);
    return 1;
  }

  if (!strcmp(mode, "backend")) {
    run_backend_files("/tmp/cairo-pgo-backend", rounds);
  } else {
    render_mode(cr, mode, rounds);
  }

  cairo_destroy(cr);
  cairo_surface_destroy(img);
  return 0;
}
EOF
}

build() {
  cd "${srcdir}/cairo"

  local -a orig_cflags=()
  local -a orig_cxxflags=()
  local -a orig_ldflags=()
  read -r -a orig_cflags <<< "${CFLAGS:-}"
  read -r -a orig_cxxflags <<< "${CXXFLAGS:-}"
  read -r -a orig_ldflags <<< "${LDFLAGS:-}"

  local PGO_DIR="${srcdir}/pgo-data"
  local IR_RAW_DIR="${PGO_DIR}/raw/ir"
  local CS_RAW_DIR="${PGO_DIR}/raw/cs"
  local PROF_DIR="${PGO_DIR}/profdata"
  local TEMP_INSTALL="${srcdir}/temp_install"

  rm -rf "${PGO_DIR}" "${TEMP_INSTALL}" "${srcdir}/build-ir" "${srcdir}/build-cs" "${srcdir}/build"
  mkdir -p \
    "${IR_RAW_DIR}/hot" "${IR_RAW_DIR}/broad" "${IR_RAW_DIR}/backend" \
    "${CS_RAW_DIR}/hot" "${CS_RAW_DIR}/broad" \
    "${PROF_DIR}"

  # Root-cause fix:
  # CS-PGO + LTO + static /usr/lib/liblzo2.a can trigger LLVM ProfileSummary conflicts.
  # Disable optional lzo backend to avoid linking static liblzo2 into LTO/CS-PGO stages.
  local -a meson_opts=(
    --buildtype=release
    -Ddefault_library=shared
    -Dtests=disabled
    -Dsymbol-lookup=disabled
    -Dspectre=disabled
    -Dlzo=disabled
  )

  build_workload_runner() {
    local install_root="$1"
    local out_bin="$2"
    shift 2

    local -a in_cflags=()
    local -a in_ldflags=()
    local mode=0
    local arg
    for arg in "$@"; do
      if [[ "$arg" == "--" ]]; then
        mode=1
        continue
      fi
      if (( mode == 0 )); then
        in_cflags+=("$arg")
      else
        in_ldflags+=("$arg")
      fi
    done

    local -a workload_cflags=()
    local -a workload_ldflags=()
    filter_workload_flags in_cflags workload_cflags
    filter_workload_flags in_ldflags workload_ldflags

    CFLAGS= CXXFLAGS= LDFLAGS= \
    clang "${workload_cflags[@]}" "${srcdir}/cairo_workload.c" -o "${out_bin}" \
      -I"${install_root}/usr/include" \
      -L"${install_root}/usr/lib" \
      -Wl,-rpath,"${install_root}/usr/lib" \
      -lcairo -lm "${workload_ldflags[@]}"
  }

  run_workload_mode() {
    local runner="$1"
    local install_root="$2"
    local raw_dir="$3"
    local phase="$4"
    local mode="$5"
    local rounds="$6"
    local seed="$7"

    mkdir -p "${raw_dir}" || return 1

    local before after
    before=$(find "${raw_dir}" -maxdepth 1 -name '*.profraw' 2>/dev/null | wc -l)

    LD_LIBRARY_PATH="${install_root}/usr/lib:${LD_LIBRARY_PATH}" \
    LLVM_PROFILE_FILE="${raw_dir}/${phase}-${mode}-%4m.profraw" \
    "${runner}" --mode "${mode}" --rounds "${rounds}" --seed "${seed}" || return 1

    after=$(find "${raw_dir}" -maxdepth 1 -name '*.profraw' 2>/dev/null | wc -l)
    (( after > before )) || return 1
  }

  merge_raw_to_profdata() {
    local raw_dir="$1"
    local out_prof="$2"

    shopt -s nullglob
    local raws=( "${raw_dir}"/*.profraw )
    shopt -u nullglob

    (( ${#raws[@]} > 0 )) || {
      error "No profraw files found in ${raw_dir}"
      return 1
    }

    llvm-profdata merge -sparse=true -output="${out_prof}" "${raws[@]}" || return 1
    [[ -s "${out_prof}" ]] || return 1
  }

  msg2 "Stage 1/6: IR PGO instrumented build"

  local -a ir_pgo_flags=(
    -fprofile-generate="${IR_RAW_DIR}/fallback"
    -fprofile-update=atomic
    -mllvm -enable-value-profiling
    -mllvm -vp-counters-per-site=16
  )
  local -a stage1_cflags=( "${orig_cflags[@]}" "${ir_pgo_flags[@]}" )
  local -a stage1_cxxflags=( "${orig_cxxflags[@]}" "${ir_pgo_flags[@]}" )
  local -a stage1_ldflags=( "${orig_ldflags[@]}" -fprofile-generate="${IR_RAW_DIR}/fallback" )

  arch-meson . "${srcdir}/build-ir" "${meson_opts[@]}" \
    -Dc_args="$(meson_array "${stage1_cflags[@]}")" \
    -Dcpp_args="$(meson_array "${stage1_cxxflags[@]}")" \
    -Dc_link_args="$(meson_array "${stage1_ldflags[@]}")" || return 1

  meson compile -C "${srcdir}/build-ir" || return 1
  DESTDIR="${TEMP_INSTALL}" meson install -C "${srcdir}/build-ir" || return 1

  msg2 "Stage 2/6: IR PGO workload training"
  local ir_runner="${srcdir}/cairo_workload_runner_ir"
  build_workload_runner "${TEMP_INSTALL}" "${ir_runner}" "${stage1_cflags[@]}" -- "${stage1_ldflags[@]}" || return 1

  run_workload_mode "${ir_runner}" "${TEMP_INSTALL}" "${IR_RAW_DIR}/hot" "ir" "image"   3 1111 || return 1
  run_workload_mode "${ir_runner}" "${TEMP_INSTALL}" "${IR_RAW_DIR}/hot" "ir" "text"    3 2222 || return 1
  run_workload_mode "${ir_runner}" "${TEMP_INSTALL}" "${IR_RAW_DIR}/broad" "ir" "stroke"   2 3333 || return 1
  run_workload_mode "${ir_runner}" "${TEMP_INSTALL}" "${IR_RAW_DIR}/broad" "ir" "patterns" 2 4444 || return 1
  run_workload_mode "${ir_runner}" "${TEMP_INSTALL}" "${IR_RAW_DIR}/broad" "ir" "record"   2 5555 || return 1
  run_workload_mode "${ir_runner}" "${TEMP_INSTALL}" "${IR_RAW_DIR}/backend" "ir" "backend" 2 6666 || return 1

  rm -f "${ir_runner}"

  msg2 "Stage 3/6: IR profdata merge"
  local ir_hot_prof="${PROF_DIR}/ir_hot.profdata"
  local ir_broad_prof="${PROF_DIR}/ir_broad.profdata"
  local ir_backend_prof="${PROF_DIR}/ir_backend.profdata"
  local ir_prof="${PROF_DIR}/ir.profdata"

  merge_raw_to_profdata "${IR_RAW_DIR}/hot" "${ir_hot_prof}" || return 1
  merge_raw_to_profdata "${IR_RAW_DIR}/broad" "${ir_broad_prof}" || return 1
  merge_raw_to_profdata "${IR_RAW_DIR}/backend" "${ir_backend_prof}" || return 1

  llvm-profdata merge -sparse=true \
    -output="${ir_prof}" \
    --weighted-input=7,"${ir_hot_prof}" \
    --weighted-input=3,"${ir_broad_prof}" \
    --weighted-input=2,"${ir_backend_prof}" || return 1

  [[ -s "${ir_prof}" ]] || {
    error "IR merged profdata is empty"
    return 1
  }

  msg2 "Stage 4/6: CS-PGO instrumented build + training"
  rm -rf "${TEMP_INSTALL}"

  local -a cs_pgo_flags=(
    -fprofile-use="${ir_prof}"
    -fcs-profile-generate="${CS_RAW_DIR}/fallback"
    -fprofile-update=atomic
    -mllvm -enable-value-profiling
    -mllvm -vp-counters-per-site=16
  )
  local -a stage2_cflags=( "${orig_cflags[@]}" "${cs_pgo_flags[@]}" )
  local -a stage2_cxxflags=( "${orig_cxxflags[@]}" "${cs_pgo_flags[@]}" )
  local -a stage2_ldflags=(
    "${orig_ldflags[@]}"
    -fprofile-use="${ir_prof}"
    -fcs-profile-generate="${CS_RAW_DIR}/fallback"
  )

  arch-meson . "${srcdir}/build-cs" "${meson_opts[@]}" \
    -Dc_args="$(meson_array "${stage2_cflags[@]}")" \
    -Dcpp_args="$(meson_array "${stage2_cxxflags[@]}")" \
    -Dc_link_args="$(meson_array "${stage2_ldflags[@]}")" || return 1

  meson compile -C "${srcdir}/build-cs" || return 1
  DESTDIR="${TEMP_INSTALL}" meson install -C "${srcdir}/build-cs" || return 1

  local cs_runner="${srcdir}/cairo_workload_runner_cs"
  build_workload_runner "${TEMP_INSTALL}" "${cs_runner}" "${stage2_cflags[@]}" -- "${stage2_ldflags[@]}" || return 1

  run_workload_mode "${cs_runner}" "${TEMP_INSTALL}" "${CS_RAW_DIR}/hot" "cs" "image" 2 7777 || return 1
  run_workload_mode "${cs_runner}" "${TEMP_INSTALL}" "${CS_RAW_DIR}/hot" "cs" "text"  2 8888 || return 1
  run_workload_mode "${cs_runner}" "${TEMP_INSTALL}" "${CS_RAW_DIR}/broad" "cs" "record"  1 9999 || return 1
  run_workload_mode "${cs_runner}" "${TEMP_INSTALL}" "${CS_RAW_DIR}/broad" "cs" "backend" 1 1010 || return 1

  rm -f "${cs_runner}"

  local cs_only_prof="${PROF_DIR}/cs_only.profdata"
  local cs_prof="${PROF_DIR}/cs.profdata"
  merge_raw_to_profdata "${CS_RAW_DIR}/hot" "${PROF_DIR}/cs_hot.profdata" || return 1
  merge_raw_to_profdata "${CS_RAW_DIR}/broad" "${PROF_DIR}/cs_broad.profdata" || return 1

  llvm-profdata merge -sparse=true \
    -output="${cs_only_prof}" \
    --weighted-input=6,"${PROF_DIR}/cs_hot.profdata" \
    --weighted-input=2,"${PROF_DIR}/cs_broad.profdata" || return 1

  llvm-profdata merge -sparse=true -output="${cs_prof}" "${ir_prof}" "${cs_only_prof}" || return 1
  [[ -s "${cs_prof}" ]] || {
    error "CS merged profdata is empty"
    return 1
  }

  msg2 "Stage 5/6: Final CS-PGO optimized build"

  local -a final_flags=( -fprofile-use="${cs_prof}" )
  local -a stage3_cflags=( "${orig_cflags[@]}" "${final_flags[@]}" )
  local -a stage3_cxxflags=( "${orig_cxxflags[@]}" "${final_flags[@]}" )
  local -a stage3_ldflags=( "${orig_ldflags[@]}" "${final_flags[@]}" -Wl,--emit-relocs )

  arch-meson . "${srcdir}/build" "${meson_opts[@]}" \
    -Dc_args="$(meson_array "${stage3_cflags[@]}")" \
    -Dcpp_args="$(meson_array "${stage3_cxxflags[@]}")" \
    -Dc_link_args="$(meson_array "${stage3_ldflags[@]}")" || return 1

  meson compile -C "${srcdir}/build" || return 1
}

package() {
  provides=(
    libcairo-gobject.so
    libcairo-script-interpreter.so
    libcairo.so
    cairo
    cairo-git
  )

  cd "${srcdir}/cairo"
  DESTDIR="${pkgdir}" meson install -C "${srcdir}/build" || return 1

  local lib_path
  lib_path="$(find "${pkgdir}/usr/lib" -maxdepth 1 -type f -name 'libcairo.so.*' | sort -V | tail -n1)"
  if [[ -z "${lib_path}" ]]; then
    error "Could not find installed libcairo shared object"
    return 1
  fi

  local lib_dir
  lib_dir="$(dirname "${lib_path}")"

  local BOLT_DIR="${srcdir}/bolt-data"
  rm -rf "${BOLT_DIR}"
  mkdir -p "${BOLT_DIR}"

  msg2 "Stage 6/6: BOLT optimize final libcairo"

  cp -f "${lib_path}" "${lib_path}.prebolt"

  if ! llvm-bolt "${lib_path}.prebolt" \
      --instrument \
      --instrumentation-file-append-pid \
      --instrumentation-file="${BOLT_DIR}/bolt.fdata" \
      -o "${lib_path}.inst"; then
    warning "BOLT instrumentation failed, keeping CS-PGO binary"
    rm -f "${lib_path}.inst"
    return 0
  fi

  mv -f "${lib_path}.inst" "${lib_path}"

  local -a pkg_cflags=()
  local -a pkg_ldflags=()
  read -r -a pkg_cflags <<< "${CFLAGS:-}"
  read -r -a pkg_ldflags <<< "${LDFLAGS:-}"

  local -a wl_cflags=()
  local -a wl_ldflags=()
  filter_workload_flags pkg_cflags wl_cflags
  filter_workload_flags pkg_ldflags wl_ldflags

  CFLAGS= CXXFLAGS= LDFLAGS= \
  clang "${wl_cflags[@]}" "${srcdir}/cairo_workload.c" -o "${srcdir}/cairo_workload_runner_bolt" \
    -I"${pkgdir}/usr/include" \
    -L"${lib_dir}" \
    -Wl,-rpath,"${lib_dir}" \
    -lcairo -lm "${wl_ldflags[@]}" || {
    warning "BOLT workload build failed, restoring CS-PGO binary"
    mv -f "${lib_path}.prebolt" "${lib_path}"
    return 0
  }

  local run_failed=0
  local mode
  for mode in image text stroke patterns record backend; do
    if ! LD_LIBRARY_PATH="${lib_dir}:${LD_LIBRARY_PATH}" \
         BOLT_PROFILE_FILE="${BOLT_DIR}/bolt.fdata" \
         "${srcdir}/cairo_workload_runner_bolt" --mode "${mode}" --rounds 2 --seed 424242; then
      run_failed=1
      break
    fi
  done

  rm -f "${srcdir}/cairo_workload_runner_bolt"

  if (( run_failed != 0 )); then
    warning "BOLT training run failed, restoring CS-PGO binary"
    mv -f "${lib_path}.prebolt" "${lib_path}"
    return 0
  fi

  shopt -s nullglob
  local fdata_files=( "${BOLT_DIR}"/bolt.fdata.* )
  shopt -u nullglob
  if (( ${#fdata_files[@]} == 0 )); then
    warning "No BOLT profile files generated, restoring CS-PGO binary"
    mv -f "${lib_path}.prebolt" "${lib_path}"
    return 0
  fi

  if ! command -v merge-fdata >/dev/null 2>&1; then
    warning "merge-fdata not found, restoring CS-PGO binary"
    mv -f "${lib_path}.prebolt" "${lib_path}"
    return 0
  fi

  if ! merge-fdata "${fdata_files[@]}" > "${BOLT_DIR}/bolt_merged.fdata" 2>/dev/null; then
    warning "BOLT profile merge failed, restoring CS-PGO binary"
    mv -f "${lib_path}.prebolt" "${lib_path}"
    return 0
  fi

  if [[ ! -s "${BOLT_DIR}/bolt_merged.fdata" ]]; then
    warning "Merged BOLT profile is empty, restoring CS-PGO binary"
    mv -f "${lib_path}.prebolt" "${lib_path}"
    return 0
  fi

  if ! llvm-bolt "${lib_path}.prebolt" \
      --data "${BOLT_DIR}/bolt_merged.fdata" \
      -o "${lib_path}" \
      --dyno-stats \
      --lite=false \
      --icf=all \
      --plt=all \
      --peepholes=all \
      --x86-strip-redundant-address-size \
      --indirect-call-promotion=all \
      --reorder-blocks=ext-tsp \
      --reorder-functions=cdsort \
      --split-all-cold \
      --split-eh \
      --split-functions \
      --split-strategy=cdsplit; then
    warning "BOLT optimize failed, restoring CS-PGO binary"
    mv -f "${lib_path}.prebolt" "${lib_path}"
    return 0
  fi

  rm -f "${lib_path}.prebolt"

  find "${pkgdir}" -type f \( -name '*.so*' -o -name '*.a' -o -perm -111 \) -print0 | while IFS= read -r -d '' file; do
    llvm-strip --strip-unneeded "$file" 2>/dev/null || llvm-strip --strip-all "$file" 2>/dev/null || true
  done
}
