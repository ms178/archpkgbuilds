pkgbase="dbus-broker-git"
pkgname=(
  "dbus-broker-git"
  "dbus-broker-units-git"
)
pkgdesc="Linux D-Bus Message Broker"
pkgver=37.67.g404f092
pkgrel=3
arch=(x86_64)
license=(Apache-2.0)
url="https://github.com/bus1/dbus-broker/wiki"
depends=(
  'audit>=3.0'
  'expat>=2.2'
  'libcap-ng>=0.6'
  'systemd-libs>=230'
)
makedepends=(
  git
  'meson>=0.60.0'
  systemd
  python-docutils
  clang
  lld
  llvm
  bolt
  procps-ng
)
source=(
  "$pkgbase::git+https://github.com/bus1/dbus-broker"
  "c-dvar-1::git+https://github.com/c-util/c-dvar#branch=v1"
  "c-ini-1::git+https://github.com/c-util/c-ini#branch=v1"
  "c-list-3::git+https://github.com/c-util/c-list#branch=v3"
  "c-rbtree-3::git+https://github.com/c-util/c-rbtree#branch=v3"
  "c-shquote-1::git+https://github.com/c-util/c-shquote#branch=v1"
  "c-stdaux-1::git+https://github.com/c-util/c-stdaux#branch=v1"
  "c-utf8-1::git+https://github.com/c-util/c-utf8#branch=v1"
  "0001-units-Enable-statically.patch"
)
sha256sums=(
  'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
)

_meson_setup() {
  local builddir="$1"

  rm -rf "${builddir}"
  meson setup "${builddir}" "${srcdir}/${pkgbase}" \
    --native-file="${srcdir}/meson-native.ini" \
    --prefix=/usr \
    --libdir=lib \
    --buildtype=plain \
    --wrap-mode=forcefallback \
    -Daudit=true \
    -Ddocs=false \
    -Dlinux-4-17=true \
    -Dsystem-console-users=gdm,sddm,lightdm,lxdm
}

_merge_profraw_dir() {
  local out="$1"
  local dir="$2"
  local profraws=()

  shopt -s nullglob
  profraws=("${dir}"/*.profraw)
  shopt -u nullglob

  (( ${#profraws[@]} > 0 )) || return 1
  llvm-profdata merge -output="${out}" "${profraws[@]}"
}

pkgver() {
  cd "${srcdir}/${pkgbase}"
  git describe --long --tags | sed 's/^v//;s/-/./g'
}

prepare() {
  cd "${srcdir}/${pkgbase}"
  git checkout "$(git rev-parse HEAD)"

  local sp
  for sp in dvar-1 ini-1 list-3 rbtree-3 shquote-1 stdaux-1 utf8-1; do
    ln -fs "$(realpath --relative-to "subprojects" "${srcdir}/c-${sp}")" "subprojects/libc${sp}"
  done

  patch -Np1 -i "${srcdir}/0001-units-Enable-statically.patch"
}

build() {
  cat > "${srcdir}/meson-native.ini" << 'EOF'
[binaries]
c = 'clang'
cpp = 'clang++'
ar = 'llvm-ar'
nm = 'llvm-nm'
ranlib = 'llvm-ranlib'
strip = 'llvm-strip'
EOF

  local _orig_cflags="${CFLAGS}"
  local _orig_cxxflags="${CXXFLAGS}"
  local _orig_ldflags="${LDFLAGS}"

  local _vp_flags="-Xclang -mllvm -Xclang -vp-counters-per-site=50 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling"

  local _pgo_dir="${srcdir}/dbus-broker-pgo"
  local _std_profraw="${_pgo_dir}/standard"
  local _cs_profraw="${_pgo_dir}/cs"
  local _std_profdata="${_pgo_dir}/standard.profdata"
  local _cs_profdata="${_pgo_dir}/cs.profdata"
  local _merged_profdata="${_pgo_dir}/merged.profdata"
  local _bolt_dir="${_pgo_dir}/bolt"
  local _bolt_fdata="${_bolt_dir}/prof.fdata"
  local _bolt_merged="${_bolt_dir}/merged.fdata"

  local _build_std="${srcdir}/_build_std_pgo"
  local _build_cs="${srcdir}/_build_cs_pgo"
  local _build_final="${srcdir}/build"

  local have_std_profile=0
  local have_cs_profile=0
  local final_profdata=''
  local binpath bin

  rm -rf "${_pgo_dir}" "${_build_std}" "${_build_cs}" "${_build_final}"
  mkdir -p "${_std_profraw}" "${_cs_profraw}" "${_bolt_dir}"

  ###########################################################################
  # Phase 1: Standard PGO instrumentation
  ###########################################################################
  msg2 "Phase 1: Building with standard PGO instrumentation..."

  export CFLAGS="${_orig_cflags} ${_vp_flags} -fprofile-generate=${_std_profraw} -fno-omit-frame-pointer"
  export CXXFLAGS="${_orig_cxxflags} ${_vp_flags} -fprofile-generate=${_std_profraw} -fno-omit-frame-pointer"
  export LDFLAGS="${_orig_ldflags} -fprofile-generate=${_std_profraw}"

  _meson_setup "${_build_std}"
  ninja -C "${_build_std}"

  msg2 "Phase 1: Running test suite for standard PGO profile..."
  LLVM_PROFILE_FILE="${_std_profraw}/%p-%m.profraw" \
    meson test -C "${_build_std}" \
      --no-rebuild \
      --print-errorlogs \
      --verbose \
      --timeout-multiplier 3 \
      --repeat 2 || \
    warning "Some tests failed during standard PGO training."

  if _merge_profraw_dir "${_std_profdata}" "${_std_profraw}"; then
    have_std_profile=1
  else
    warning "No standard PGO profile data collected; continuing without PGO."
  fi

  ###########################################################################
  # Phase 2: Context-sensitive PGO instrumentation
  ###########################################################################
  if (( have_std_profile )); then
    msg2 "Phase 2: Building with context-sensitive PGO instrumentation..."

    export CFLAGS="${_orig_cflags} ${_vp_flags} -fprofile-use=${_std_profdata} -fcs-profile-generate=${_cs_profraw} -fno-omit-frame-pointer"
    export CXXFLAGS="${_orig_cxxflags} ${_vp_flags} -fprofile-use=${_std_profdata} -fcs-profile-generate=${_cs_profraw} -fno-omit-frame-pointer"
    export LDFLAGS="${_orig_ldflags} -fprofile-use=${_std_profdata} -fcs-profile-generate=${_cs_profraw}"

    _meson_setup "${_build_cs}"
    ninja -C "${_build_cs}"

    msg2 "Phase 2: Running test suite for CS-PGO profile..."
    LLVM_PROFILE_FILE="${_cs_profraw}/%p-%m.profraw" \
      meson test -C "${_build_cs}" \
        --no-rebuild \
        --print-errorlogs \
        --verbose \
        --timeout-multiplier 3 \
        --repeat 2 || \
      warning "Some tests failed during CS-PGO training."

    if _merge_profraw_dir "${_cs_profdata}" "${_cs_profraw}"; then
      have_cs_profile=1
    else
      warning "No CS-PGO profile data collected; falling back to standard PGO."
    fi
  else
    msg2 "Phase 2: Skipping CS-PGO (no standard profile available)."
  fi

  if (( have_std_profile && have_cs_profile )); then
    if llvm-profdata merge -output="${_merged_profdata}" "${_std_profdata}" "${_cs_profdata}"; then
      final_profdata="${_merged_profdata}"
    else
      warning "Profile merge failed; falling back to standard PGO."
      final_profdata="${_std_profdata}"
    fi
  elif (( have_std_profile )); then
    final_profdata="${_std_profdata}"
  fi

  ###########################################################################
  # Phase 3: Final optimized PGO build
  ###########################################################################
  msg2 "Phase 3: Building final optimized binaries..."

  if [[ -n "${final_profdata}" && -f "${final_profdata}" ]]; then
    export CFLAGS="${_orig_cflags} -fprofile-use=${final_profdata}"
    export CXXFLAGS="${_orig_cxxflags} -fprofile-use=${final_profdata}"
    export LDFLAGS="${_orig_ldflags} -fprofile-use=${final_profdata} -Wl,--emit-relocs"
  else
    export CFLAGS="${_orig_cflags}"
    export CXXFLAGS="${_orig_cxxflags}"
    export LDFLAGS="${_orig_ldflags} -Wl,--emit-relocs"
  fi

  _meson_setup "${_build_final}"
  ninja -C "${_build_final}"

  ###########################################################################
  # Phase 4: BOLT instrumentation + training + apply
  ###########################################################################
  if command -v llvm-bolt >/dev/null 2>&1 && command -v merge-fdata >/dev/null 2>&1; then
    msg2 "Phase 4: BOLT instrumentation and training..."

    local _bolt_bins=(dbus-broker dbus-broker-launch)
    local _bolt_instrumented=()

    rm -f "${_bolt_fdata}" "${_bolt_fdata}".* "${_bolt_merged}"

    # ----------------------------------------------------------
    # 4a: Instrument ALL binaries with a SHARED fdata prefix.
    #     This is critical: both binaries write to prof.fdata.<PID>
    #     so the merged profile contains data from both, and BOLT
    #     silently ignores irrelevant functions when applying.
    # ----------------------------------------------------------
    for bin in "${_bolt_bins[@]}"; do
      binpath="${_build_final}/src/${bin}"
      [[ -f "${binpath}" ]] || continue

      cp -a "${binpath}" "${binpath}.orig"

      if llvm-bolt "${binpath}.orig" \
        --instrument \
        --instrumentation-file="${_bolt_fdata}" \
        --instrumentation-file-append-pid \
        -o "${binpath}.inst"; then
        mv -f "${binpath}.inst" "${binpath}"
        _bolt_instrumented+=("${bin}")
      else
        warning "BOLT instrumentation failed for ${bin}; it will remain PGO-only."
        mv -f "${binpath}.orig" "${binpath}"
        rm -f "${binpath}.inst"
      fi
    done

    # ----------------------------------------------------------
    # 4b: Run tests on the instrumented binaries.
    #     Both dbus-broker and dbus-broker-launch execute during
    #     tests (the launcher spawns the broker). Profile data
    #     from both accumulates under the shared fdata prefix.
    # ----------------------------------------------------------
    if (( ${#_bolt_instrumented[@]} > 0 )); then
      msg2 "Phase 4: Running test suite for BOLT profile collection..."
      meson test -C "${_build_final}" \
        --no-rebuild \
        --print-errorlogs \
        --verbose \
        --timeout-multiplier 5 \
        --repeat 2 || \
        warning "Some tests failed during BOLT training."

      sleep 2

      # ----------------------------------------------------------
      # 4c: Merge ALL fdata files and apply the SAME merged profile
      #     to EVERY binary. BOLT uses matching functions and ignores
      #     the rest (reported as "profile for N objects was ignored").
      # ----------------------------------------------------------
      if compgen -G "${_bolt_fdata}.*" >/dev/null; then
        if merge-fdata "${_bolt_fdata}".* -o "${_bolt_merged}" && [[ -s "${_bolt_merged}" ]]; then
          for bin in "${_bolt_bins[@]}"; do
            binpath="${_build_final}/src/${bin}"
            [[ -f "${binpath}.orig" ]] || continue

            msg2 "Applying BOLT optimizations to ${bin}..."
            if llvm-bolt "${binpath}.orig" \
              --data="${_bolt_merged}" \
              -o "${binpath}.bolt" \
              --dyno-stats \
              --lite=false \
              --split-functions \
              --split-all-cold \
              --split-eh \
              --split-strategy=cdsplit \
              --icf=all \
              --plt=all \
              --peepholes=all \
              --indirect-call-promotion=all \
              --reorder-blocks=ext-tsp \
              --reorder-functions=cdsort \
              --x86-strip-redundant-address-size \
              --eliminate-unreachable \
              --frame-opt=all \
              --jump-tables=aggressive \
              --use-gnu-stack; then
              mv -f "${binpath}.bolt" "${binpath}"
              rm -f "${binpath}.orig"
            else
              warning "BOLT optimization failed for ${bin}; restoring PGO binary."
              mv -f "${binpath}.orig" "${binpath}"
              rm -f "${binpath}.bolt"
            fi
          done
        else
          warning "BOLT profile merge failed or empty; restoring PGO binaries."
          for bin in "${_bolt_bins[@]}"; do
            binpath="${_build_final}/src/${bin}"
            [[ -f "${binpath}.orig" ]] && mv -f "${binpath}.orig" "${binpath}"
          done
        fi
      else
        warning "No BOLT profile data collected; restoring PGO binaries."
        for bin in "${_bolt_bins[@]}"; do
          binpath="${_build_final}/src/${bin}"
          [[ -f "${binpath}.orig" ]] && mv -f "${binpath}.orig" "${binpath}"
        done
      fi
    fi

    # Final safety: ensure no .orig files remain
    for bin in "${_bolt_bins[@]}"; do
      binpath="${_build_final}/src/${bin}"
      [[ -f "${binpath}.orig" ]] && mv -f "${binpath}.orig" "${binpath}"
    done
  else
    warning "BOLT tools unavailable; skipping BOLT optimization."
  fi

  ###########################################################################
  # Phase 5: Verification
  ###########################################################################
  msg2 "Phase 5: Verifying final output..."

  for bin in dbus-broker dbus-broker-launch; do
    binpath="${_build_final}/src/${bin}"
    if [[ -f "${binpath}" ]]; then
      if ! readelf -h "${binpath}" >/dev/null 2>&1; then
        error "Final ${bin} is not a valid ELF object"
        return 1
      fi
    fi
  done

  meson test -C "${_build_final}" \
    --no-rebuild \
    --print-errorlogs \
    --timeout-multiplier 3 || \
    warning "Some tests failed during final verification."

  export CFLAGS="${_orig_cflags}"
  export CXXFLAGS="${_orig_cxxflags}"
  export LDFLAGS="${_orig_ldflags}"
}

_pick() {
  local p="$1" f d
  shift
  for f; do
    d="${srcdir}/${p}/${f#${pkgdir}/}"
    mkdir -p "$(dirname "${d}")"
    mv "${f}" "${d}"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "${f}")" || true
  done
}

check() {
  [[ -d "${srcdir}/build" ]] || return 0
  meson test -C "${srcdir}/build" \
    --no-rebuild \
    --print-errorlogs \
    --timeout-multiplier 3 || \
    warning "Some tests failed during check()."
}

package_dbus-broker-git() {
  depends+=(libaudit.so libcap-ng.so libexpat.so libsystemd.so)
  provides=(dbus-broker)
  conflicts=(dbus-broker)

  meson install -C "${srcdir}/build" --destdir "${pkgdir}" --no-rebuild

  _pick unit "${pkgdir}"/usr/lib/systemd/{system,user}/dbus.service
}

package_dbus-broker-units-git() {
  pkgdesc+=" - Service units"
  depends=("dbus-broker-git=${pkgver}-${pkgrel}")
  provides=(dbus-broker-units dbus-units)
  conflicts=(dbus-broker-units dbus-daemon-units)

  install -d "${pkgdir}"
  mv "${srcdir}"/unit/* "${pkgdir}"
}
