_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

_detect_toolchain() {
  : "${CC:=clang}"
  : "${CXX:=clang++}"
  : "${AR:=llvm-ar}"
  : "${NM:=llvm-nm}"
  : "${RANLIB:=llvm-ranlib}"
  : "${LD:=ld.lld}"

  _has_cmd "$CC" || { error "CC not found: $CC"; return 1; }
  _has_cmd "$CXX" || { error "CXX not found: $CXX"; return 1; }
  _has_cmd "$AR" || { error "AR not found: $AR"; return 1; }
  _has_cmd "$NM" || { error "NM not found: $NM"; return 1; }
  _has_cmd "$RANLIB" || { error "RANLIB not found: $RANLIB"; return 1; }
  _has_cmd llvm-profdata || { error "llvm-profdata not found"; return 1; }

  local _triple
  _triple="$($CC -print-target-triple 2>/dev/null || $CC -dumpmachine 2>/dev/null || true)"
  [[ "$_triple" == *linux* ]] || {
    error "Compiler target is not Linux: ${_triple:-unknown}"
    return 1
  }

  printf '  -> [TOOLCHAIN] CC=%s\n' "$(command -v "$CC")"
  printf '  -> [TOOLCHAIN] CXX=%s\n' "$(command -v "$CXX")"
}

_toolchain_supports_flag() {
  local _flag="$1"
  local _dir="$srcdir/.flag-check-${_flag//[^[:alnum:]]/_}"
  rm -rf "$_dir"
  mkdir -p "$_dir"

  cat >"$_dir/test.c" <<'EOF'
int main(void) { return 0; }
EOF

  "$CC" "$_dir/test.c" -o "$_dir/test" "$_flag" >/dev/null 2>&1
}

_toolchain_supports_args() {
  local _tag="$1"
  shift
  local _dir="$srcdir/.args-check-${_tag//[^[:alnum:]]/_}"
  rm -rf "$_dir"
  mkdir -p "$_dir"

  cat >"$_dir/test.c" <<'EOF'
int main(void) { return 0; }
EOF

  "$CC" "$_dir/test.c" -o "$_dir/test" "$@" >/dev/null 2>&1
}

_pgo_profraw_count() {
  find "$1" -maxdepth 1 -type f -name '*.profraw' 2>/dev/null | wc -l
}

_pgo_profraw_bytes() {
  find "$1" -maxdepth 1 -type f -name '*.profraw' -printf '%s\n' 2>/dev/null | awk '{s+=$1} END{print s+0}'
}

_pgo_profraw_diag() {
  local _label="$1"
  local _dir="$2"
  printf '  -> [PGO] %s: files=%s bytes=%s dir=%s\n' "$_label" "$(_pgo_profraw_count "$_dir")" "$(_pgo_profraw_bytes "$_dir")" "$_dir"
}

_find_build_tool() {
  find "$1" -type f -executable -name "$2" -print -quit 2>/dev/null
}

_meson_list_test_names() {
  local _builddir="$1"
  local _line _name

  while IFS= read -r _line; do
    [[ -z "$_line" ]] && continue
    _name="${_line##* - }"
    printf '%s\n' "$_name"
  done < <(meson test -C "$_builddir" --list --no-rebuild 2>/dev/null || true)
}

_pgo_run_training_tests() {
  local _builddir="$1"

  local -a _tests=(
    glib:array-test
    glib:bytes
    glib:checksum
    glib:dataset
    glib:fileutils
    glib:hash
    glib:hmac
    glib:keyfile
    glib:list
    glib:markup-parse
    glib:option-context
    glib:pattern
    glib:queue
    glib:regex
    glib:string
    glib:strfuncs
    glib:unicode
    glib:uri
    glib:utils
    glib:g-file
    glib:g-file-info
    glib:converter
    glib:converter-stream
    glib:contenttype
    glib:data-input-stream
    glib:data-output-stream
    glib:dbus-appinfo
    glib:gdbus-message
    glib:gdbus-serialization
    glib:gschema-compile
    glib:resources
    glib:socket
    glib:gdbus-connection
    glib:gdbus-peer
    glib:gsubprocess
    glib:appinfo
  )

  local _available
  _available="$(_meson_list_test_names "$_builddir")"

  local -a _run=()
  local _t
  for _t in "${_tests[@]}"; do
    grep -Fxq "$_t" <<<"$_available" && _run+=("$_t")
  done

  if (( ${#_run[@]} == 0 )); then
    warning "[PGO] no matching training tests discovered in $_builddir"
    return 0
  fi

  LANG=C.UTF-8 LC_MESSAGES=C LC_TIME=C.UTF-8 TZ=UTC \
    meson test -C "$_builddir" --print-errorlogs --no-rebuild --num-processes 1 "${_run[@]}" || true
}

_training_workload() {
  local _builddir="$1"
  (
    set -eo pipefail

    local _workroot
    _workroot="$(mktemp -d "${_builddir}/glib-train.XXXXXX")"
    trap 'rm -rf "$_workroot"' EXIT

    local _gio _gdbus _gresource _gsettings _glib_schema
    _gio="$(_find_build_tool "$_builddir" gio || true)"
    _gdbus="$(_find_build_tool "$_builddir" gdbus || true)"
    _gresource="$(_find_build_tool "$_builddir" gresource || true)"
    _gsettings="$(_find_build_tool "$_builddir" gsettings || true)"
    _glib_schema="$(_find_build_tool "$_builddir" glib-compile-schemas || true)"

    printf '  -> [PGO] workload tools: gio=%s gdbus=%s gresource=%s\n' "${_gio:-missing}" "${_gdbus:-missing}" "${_gresource:-missing}"

    [[ -n "$_gio" ]] && {
      "$_gio" help >/dev/null 2>&1 || true
      "$_gio" info /usr >/dev/null 2>&1 || true
      "$_gio" mime text/plain >/dev/null 2>&1 || true
      "$_gio" list -a "standard::*" /usr/share >/dev/null 2>&1 || true
    }

    [[ -n "$_gdbus" ]] && {
      "$_gdbus" help >/dev/null 2>&1 || true
      "$_gdbus" introspect --system --dest org.freedesktop.DBus --object-path /org/freedesktop/DBus >/dev/null 2>&1 || true
    }

    [[ -n "$_gsettings" ]] && {
      GSETTINGS_SCHEMA_DIR=/usr/share/glib-2.0/schemas "$_gsettings" list-schemas >/dev/null 2>&1 || true
      GSETTINGS_SCHEMA_DIR=/usr/share/glib-2.0/schemas "$_gsettings" list-keys org.gnome.desktop.interface >/dev/null 2>&1 || true
    }

    if [[ -n "$_gresource" ]]; then
      cat >"$_workroot/demo.xml" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<gresources>
  <gresource prefix="/com/cachyos/pgo">
    <file>data.txt</file>
  </gresource>
</gresources>
EOF
      printf 'profile-guided-resource\n' >"$_workroot/data.txt"
      "$_gresource" list "$_workroot/demo.xml" >/dev/null 2>&1 || true
      "$_gresource" details "$_workroot/demo.xml" >/dev/null 2>&1 || true
    fi

    if [[ -n "$_glib_schema" ]]; then
      mkdir -p "$_workroot/schemas"
      cat >"$_workroot/schemas/org.cachyos.pgo.gschema.xml" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.cachyos.pgo" path="/org/cachyos/pgo/">
    <key name="enabled" type="b"><default>true</default></key>
  </schema>
</schemalist>
EOF
      "$_glib_schema" "$_workroot/schemas" >/dev/null 2>&1 || true
    fi

    printf '  -> [PGO] workload complete\n'
  ) || true
}

prepare() {
  cd glib

  git apply -3 ../0001-glib-compile-schemas-Remove-noisy-deprecation-warnin.patch
  git apply -3 ../0002-gdesktopappinfo-Add-more-known-terminals.patch

  git submodule init
  git submodule set-url subprojects/gvdb "$srcdir/gvdb"
  git -c protocol.file.allow=always -c protocol.allow=never submodule update
}

build() {
  _detect_toolchain

  local -a meson_options_pgo=(
    --default-library both
    -D documentation=false
    -D dtrace=disabled
    -D glib_debug=disabled
    -D introspection=disabled
    -D man-pages=disabled
    -D selinux=disabled
    -D sysprof=enabled
    -D systemtap=disabled
  )

  local -a meson_options_final=(
    --default-library both
    -D documentation=false
    -D dtrace=disabled
    -D glib_debug=disabled
    -D introspection=enabled
    -D man-pages=disabled
    -D selinux=disabled
    -D sysprof=enabled
    -D systemtap=disabled
  )

  local PGO1_RAW_DIR="$srcdir/profraw-pgo1"
  local PGO1_DATA="$srcdir/pgo1.profdata"
  local CSPGO_RAW_DIR="$srcdir/profraw-cspgo"
  local FINAL_PGO_DATA="$srcdir/pgo-final.profdata"

  rm -rf "$PGO1_RAW_DIR" "$CSPGO_RAW_DIR" "$PGO1_DATA" "$FINAL_PGO_DATA" \
         "$srcdir/build-pgo-gen" "$srcdir/build-cspgo-gen" "$srcdir/build"
  mkdir -p "$PGO1_RAW_DIR" "$CSPGO_RAW_DIR"

  local can_ir_pgo=1
  local can_cs_pgo=1
  local PGO_GEN_FLAGS="-fprofile-update=atomic"
  local PGO_USE_ENHANCED_FLAGS=""
  local PGO_USE_DIAG_FLAGS="-Wno-profile-instr-unprofiled -Wno-profile-instr-out-of-date"

  if _toolchain_supports_args "vp_gen" -mllvm -enable-value-profiling -mllvm -vp-counters-per-site=128; then
    PGO_GEN_FLAGS+=" -mllvm -enable-value-profiling -mllvm -vp-counters-per-site=128"
  else
    warning "Toolchain rejected enhanced VP generation flags; using baseline PGO generation flags."
  fi

  if _toolchain_supports_args "vp_use" -mllvm -enable-value-profiling -mllvm -icp-max-prom=3; then
    PGO_USE_ENHANCED_FLAGS="-mllvm -enable-value-profiling -mllvm -icp-max-prom=3"
  else
    warning "Toolchain rejected enhanced PGO use flags; using baseline profile-use flags."
  fi

  if ! _toolchain_supports_flag "-fprofile-generate"; then
    warning "Toolchain cannot use -fprofile-generate; falling back to non-PGO build."
    can_ir_pgo=0
    can_cs_pgo=0
  fi

  if (( can_ir_pgo )) && ! _toolchain_supports_flag "-fcs-profile-generate"; then
    warning "Toolchain does not support -fcs-profile-generate; using regular PGO."
    can_cs_pgo=0
  fi

  if (( can_ir_pgo )); then
    local CFLAGS_GEN="$CFLAGS -fprofile-generate $PGO_GEN_FLAGS"
    local CXXFLAGS_GEN="$CXXFLAGS -fprofile-generate $PGO_GEN_FLAGS"
    local LDFLAGS_GEN="$LDFLAGS -fprofile-generate"

    printf '  -> [PGO] stage1 generate\n'
    arch-meson glib build-pgo-gen "${meson_options_pgo[@]}" \
      -Dc_args="$CFLAGS_GEN" \
      -Dcpp_args="$CXXFLAGS_GEN" \
      -Dc_link_args="$LDFLAGS_GEN" \
      -Dcpp_link_args="$LDFLAGS_GEN"

    LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" meson compile -C build-pgo-gen
    LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" \
      _pgo_run_training_tests build-pgo-gen

    _pgo_profraw_diag "after stage1 tests" "$PGO1_RAW_DIR"
    LLVM_PROFILE_FILE="$PGO1_RAW_DIR/%p-%m.profraw" _training_workload "$srcdir/build-pgo-gen"

    if compgen -G "$PGO1_RAW_DIR/*.profraw" >/dev/null; then
      llvm-profdata merge -use-md5 -compress-all-sections -o "$PGO1_DATA" "$PGO1_RAW_DIR"/*.profraw
      printf '  -> [PGO] stage1 profile=%s\n' "$PGO1_DATA"
    else
      warning "No stage1 .profraw files generated; disabling profile-use stages."
      can_ir_pgo=0
      can_cs_pgo=0
    fi
  fi

  if (( can_cs_pgo )); then
    local CFLAGS_CS_GEN="$CFLAGS -fprofile-use=$PGO1_DATA -fcs-profile-generate $PGO_GEN_FLAGS $PGO_USE_ENHANCED_FLAGS $PGO_USE_DIAG_FLAGS"
    local CXXFLAGS_CS_GEN="$CXXFLAGS -fprofile-use=$PGO1_DATA -fcs-profile-generate $PGO_GEN_FLAGS $PGO_USE_ENHANCED_FLAGS $PGO_USE_DIAG_FLAGS"
    local LDFLAGS_CS_GEN="$LDFLAGS -fprofile-use=$PGO1_DATA -fcs-profile-generate $PGO_USE_DIAG_FLAGS"

    printf '  -> [PGO] stage2 cs-generate\n'
    arch-meson glib build-cspgo-gen "${meson_options_pgo[@]}" \
      -Dc_args="$CFLAGS_CS_GEN" \
      -Dcpp_args="$CXXFLAGS_CS_GEN" \
      -Dc_link_args="$LDFLAGS_CS_GEN" \
      -Dcpp_link_args="$LDFLAGS_CS_GEN"

    LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" meson compile -C build-cspgo-gen
    LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" \
      _pgo_run_training_tests build-cspgo-gen

    _pgo_profraw_diag "after cs stage tests" "$CSPGO_RAW_DIR"
    LLVM_PROFILE_FILE="$CSPGO_RAW_DIR/%p-%m.profraw" _training_workload "$srcdir/build-cspgo-gen"

    if compgen -G "$CSPGO_RAW_DIR/*.profraw" >/dev/null; then
      llvm-profdata merge -use-md5 -compress-all-sections -o "$FINAL_PGO_DATA" "$CSPGO_RAW_DIR"/*.profraw "$PGO1_DATA"
      printf '  -> [PGO] final cs profile=%s\n' "$FINAL_PGO_DATA"
    else
      warning "No CS-PGO .profraw generated; reusing stage1 profile."
      cp -f "$PGO1_DATA" "$FINAL_PGO_DATA"
    fi
  elif (( can_ir_pgo )) && [[ -f "$PGO1_DATA" ]]; then
    cp -f "$PGO1_DATA" "$FINAL_PGO_DATA"
  fi

  local CFLAGS_USE="$CFLAGS"
  local CXXFLAGS_USE="$CXXFLAGS"
  local LDFLAGS_USE="$LDFLAGS"

  if [[ -f "$FINAL_PGO_DATA" ]]; then
    CFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA $PGO_USE_ENHANCED_FLAGS $PGO_USE_DIAG_FLAGS"
    CXXFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA $PGO_USE_ENHANCED_FLAGS $PGO_USE_DIAG_FLAGS"
    LDFLAGS_USE+=" -fprofile-use=$FINAL_PGO_DATA $PGO_USE_DIAG_FLAGS"
    printf '  -> [PGO] final optimize stage uses=%s\n' "$FINAL_PGO_DATA"
  else
    warning "Building without profile-use; profile data missing."
  fi

  arch-meson glib build "${meson_options_final[@]}" \
    -Dc_args="$CFLAGS_USE" \
    -Dcpp_args="$CXXFLAGS_USE" \
    -Dc_link_args="$LDFLAGS_USE" \
    -Dcpp_link_args="$LDFLAGS_USE"

  meson compile -C build
}

check() {
  # Some dist setups run this check from builddir where tmpsample.xml is absent.
  if [[ -f glib/glib/tests/tmpsample.xml ]]; then
    install -Dm644 glib/glib/tests/tmpsample.xml build/glib/tests/tmpsample.xml
  fi

  local _available
  _available="$(_meson_list_test_names build)"

  local -a _skip=(
    glib:hook
    glib:spawn-test
    glib:gsettings
    glib:io-channel-basic
    glib:testing
    glib:gtester-xmllint-check
  )

  local -a _run=()
  local _t _drop _s
  while IFS= read -r _t; do
    [[ -z "$_t" ]] && continue
    _drop=0
    for _s in "${_skip[@]}"; do
      if [[ "$_t" == "$_s" ]]; then
        _drop=1
        break
      fi
    done
    (( _drop == 0 )) && _run+=("$_t")
  done <<<"$_available"

  if (( ${#_run[@]} == 0 )); then
    warning "No runnable tests discovered in build dir"
    return 0
  fi

  local _jobs
  _jobs="$(nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)"

  LANG=C.UTF-8 LC_ALL=C.UTF-8 LC_MESSAGES=C LC_TIME=C.UTF-8 TZ=UTC \
    meson test -C build --print-errorlogs --no-rebuild --num-processes "$_jobs" "${_run[@]}"
}

_pick() {
  local p="$1" f d
  shift
  for f in "$@"; do
    [[ -e "$f" ]] || continue
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

package_glib2() {
  depends+=(
    libffi.so
    libmount.so
  )
  provides+=(libg{lib,io,irepository,module,object,thread}-2.0.so)
  optdepends=(
    'dconf: GSettings storage backend'
    'glib2-devel: development tools'
    'gvfs: most gio functionality'
  )
  options+=(staticlibs)
  install=glib2.install

  meson install -C build --destdir "$pkgdir"
  install -Dt "$pkgdir/usr/share/libalpm/hooks" -m644 *.hook
  touch "$pkgdir/usr/lib/gio/modules/.keep"

  python -m compileall -d /usr/share/glib-2.0/codegen "$pkgdir/usr/share/glib-2.0/codegen"
  python -O -m compileall -d /usr/share/glib-2.0/codegen "$pkgdir/usr/share/glib-2.0/codegen"

  cd "$pkgdir"
  _pick devel usr/bin/gdbus-codegen
  _pick devel usr/bin/glib-{mkenums,genmarshal}
  _pick devel usr/bin/gresource
  _pick devel usr/bin/gtester{,-report}
  _pick devel usr/share/gdb/
  _pick devel usr/share/glib-2.0/gdb/
  _pick devel usr/share/glib-2.0/codegen/
  _pick devel usr/share/bash-completion/completions/gresource
}

package_glib2-devel() {
  pkgdesc+=" - development tools"
  depends=(
    glib2
    glibc
    libelf
    python
    python-packaging
  )

  [[ -d devel ]] && mv devel/* "$pkgdir"
}

