pkgbase=nss
pkgname=(
  nss
  ca-certificates-mozilla
)
pkgver=3.125
pkgrel=2.9
pkgdesc="Network Security Services"
url="https://developer.mozilla.org/en-US/docs/Mozilla/Projects/NSS"
arch=(x86_64)
license=(MPL-2.0)
depends=(
  glibc
  nspr
  p11-kit
  sqlite
  zlib
  ca-certificates-mozilla
)
makedepends=(
  gyp
  mercurial
  perl
  python
  llvm
  clang
)
source=(
  "hg+https://hg.mozilla.org/projects/nss#tag=NSS_${pkgver//./_}_RTM"
  bundle.sh
  certdata2pem.py
)
b2sums=(
  'SKIP'
  '4be5dd836c844fdd7b63302a6994d62149082c3bc81eef70f373f416fed80a61a923960e4390d1c391b81ab01b409370d788818a30ffdd3a4ed467b670f990f6'
  '6bb59dcc9289916dcbf8fb6d73db0c0cd7582dc12a3aa4e8be19ec62c9ede65fdd9470a2d92ec5a114506b78d2d21b8ae0a1b45a17dc1f90f7d75434a93da510'
)

prepare() {
  mkdir -p certs
  for file in nss/lib/ckfw/builtins/{certdata.txt,nssckbi.h}; do
    if [[ ! -f "$file" ]]; then
      error "Required file $file not found"
      return 1
    fi
  done
  ln -srft certs nss/lib/ckfw/builtins/{certdata.txt,nssckbi.h}

  # NSS 3.123.1 regression: ssl_gtests.sh used cwd-relative helper.
  local gtest_script="nss/tests/ssl_gtests/ssl_gtests.sh"
  [[ -f "$gtest_script" ]] || {
    error "Missing $gtest_script"
    return 1
  }

  if ! grep -q '^SSL_GTESTS_DIR=' "$gtest_script"; then
    sed -i '/^ssl_gtest_certs() {/i SSL_GTESTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"\n' "$gtest_script"
  fi

  sed -i \
    's|^\([[:space:]]*\)\./ssl_gtest_db\.sh "\${SSLGTESTDIR}" "\${BINDIR}/certutil" "\${R_NOISE_FILE}"|\1"${SSL_GTESTS_DIR}/ssl_gtest_db.sh" "${SSLGTESTDIR}" "${BINDIR}/certutil" "${R_NOISE_FILE}"|' \
    "$gtest_script"

  sed -i \
    's|^cd "$(dirname "$0")"$|cd "${SSL_GTESTS_DIR}"|' \
    "$gtest_script"
}

build() {
  local buildopts=(
    --enable-libpkix
    --opt
    --system-nspr
    --system-sqlite
    --target=x64
    --clang
  )

  cd certs
  ../certdata2pem.py
  cd ..
  ./bundle.sh

  local pgo_dir="$srcdir/pgo-data"
  local raw_ir="$pgo_dir/raw/ir"
  local raw_cs="$pgo_dir/raw/cs"
  local prof_dir="$pgo_dir/profdata"
  local fallback_ir="$pgo_dir/fallback/ir"
  local fallback_cs="$pgo_dir/fallback/cs"

  mkdir -p "$raw_ir" "$raw_cs" "$prof_dir" "$fallback_ir" "$fallback_cs"

  local orig_cflags="${CFLAGS:-}"
  local orig_cxxflags="${CXXFLAGS:-}"
  local orig_ldflags="${LDFLAGS:-}"

  # PGO-only quality tuning.
  local pgo_quality_flags="-fprofile-update=atomic -mllvm -enable-value-profiling -mllvm -vp-counters-per-site=8"

  pick_free_port_block() {
    local block_size="${1:-32}"
    python - "$block_size" <<'PY'
import random, socket, sys
b = int(sys.argv[1])

def ok(p):
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        s.bind(("127.0.0.1", p))
        return True
    except OSError:
        return False
    finally:
        s.close()

ports = list(range(20000, 55000))
random.shuffle(ports)
for base in ports:
    if base + b >= 65535:
        continue
    if all(ok(p) for p in range(base, base + b)):
        print(base)
        sys.exit(0)
sys.exit(1)
PY
  }

  count_profraw() {
    local d="$1"
    shopt -s nullglob
    local f=( "$d"/*.profraw )
    shopt -u nullglob
    echo "${#f[@]}"
  }

  merge_raw_dir() {
    local raw_dir="$1"
    local out_prof="$2"

    shopt -s nullglob
    local raws=( "$raw_dir"/*.profraw )
    shopt -u nullglob
    (( ${#raws[@]} > 0 )) || {
      error "No .profraw files in ${raw_dir}"
      return 1
    }

    llvm-profdata merge -sparse=true -output="$out_prof" "${raws[@]}" || return 1
    [[ -s "$out_prof" ]] || {
      error "Empty profdata generated: $out_prof"
      return 1
    }
  }

  run_fast_gtests_bundle() {
    # Root cause fix for flaky KeyLogFile*: run it isolated from env and separate from bulk pass.
    local phase="$1"      # ir|cs|final
    local raw_dir="$2"    # empty when final validation
    local need_profile="$3" # 1 or 0

    local port
    port="$(pick_free_port_block 32)" || {
      error "Could not allocate test port block"
      return 1
    }

    local t_home="$srcdir/nss-test-home/$phase"
    mkdir -p "$t_home" || return 1

    local before=0 after=0
    if [[ "$need_profile" -eq 1 ]]; then
      before="$(count_profraw "$raw_dir")"
    fi

    cd "$srcdir/nss/tests" || return 1

    # 1) Run almost all ssl_gtests (exclude KeyLogFile* from this pass).
    (
      unset SSLKEYLOGFILE NSS_SSLKEYLOGFILE MOZ_SSLKEYLOGFILE SSLKEYLOG_FILE SSLKEYLOGFILE_PATH
      export HOME="$t_home"
      export HOST="localhost"
      export DOMSUF="localdomain"
      export PORT="$port"
      export NSS_CYCLES="standard"
      export NSS_DEFAULT_DB_TYPE="sql"
      export LANG=C
      export LC_ALL=C
      if [[ "$need_profile" -eq 1 ]]; then
        export LLVM_PROFILE_FILE="$raw_dir/${phase}_bulk_%4m.profraw"
      fi
      export GTESTFILTER="-KeyLogFile*"
      bash ./ssl_gtests/ssl_gtests.sh
    ) || return 1

    # 2) Run only KeyLogFile* tests isolated (serial by filter path in script).
    (
      unset SSLKEYLOGFILE NSS_SSLKEYLOGFILE MOZ_SSLKEYLOGFILE SSLKEYLOG_FILE SSLKEYLOGFILE_PATH
      export HOME="$t_home"
      export HOST="localhost"
      export DOMSUF="localdomain"
      export PORT="$port"
      export NSS_CYCLES="standard"
      export NSS_DEFAULT_DB_TYPE="sql"
      export LANG=C
      export LC_ALL=C
      if [[ "$need_profile" -eq 1 ]]; then
        export LLVM_PROFILE_FILE="$raw_dir/${phase}_keylog_%4m.profraw"
      fi
      export GTESTFILTER="KeyLogFile*"
      bash ./ssl_gtests/ssl_gtests.sh
    ) || return 1

    # 3) Run non-SSL gtests.
    (
      unset SSLKEYLOGFILE NSS_SSLKEYLOGFILE MOZ_SSLKEYLOGFILE SSLKEYLOG_FILE SSLKEYLOGFILE_PATH
      export HOME="$t_home"
      export HOST="localhost"
      export DOMSUF="localdomain"
      export PORT="$port"
      export NSS_CYCLES="standard"
      export NSS_DEFAULT_DB_TYPE="sql"
      export LANG=C
      export LC_ALL=C
      if [[ "$need_profile" -eq 1 ]]; then
        export LLVM_PROFILE_FILE="$raw_dir/${phase}_gtests_%4m.profraw"
      fi
      bash ./gtests/gtests.sh
    ) || return 1

    cd "$srcdir/nss" || return 1

    if [[ "$need_profile" -eq 1 ]]; then
      after="$(count_profraw "$raw_dir")"
      if (( after <= before )); then
        error "No new .profraw files generated for phase ${phase} in ${raw_dir}"
        return 1
      fi
    fi
  }

  cd nss

  #
  # 1) IR-PGO instrumentation + lightweight training
  #
  msg2 "== Stage 1: IR-PGO instrumented build"

  local ir_gen_flag="-fprofile-generate=${fallback_ir}"
  export CFLAGS="${orig_cflags} ${ir_gen_flag} ${pgo_quality_flags}"
  export CXXFLAGS="${orig_cxxflags} ${ir_gen_flag} ${pgo_quality_flags}"
  export LDFLAGS="${orig_ldflags} ${ir_gen_flag}"

  ./build.sh -c "${buildopts[@]}" || return 1
  ./build.sh "${buildopts[@]}" || {
    error "IR instrumented build failed"
    return 1
  }

  [[ -d "$srcdir/dist/Release/bin" ]] || {
    error "Missing build output after IR stage"
    return 1
  }

  msg2 "== Stage 2: IR training (trimmed)"
  run_fast_gtests_bundle "ir" "$raw_ir" 1 || {
    error "IR training failed"
    return 1
  }

  local ir_prof="$prof_dir/ir.profdata"
  merge_raw_dir "$raw_ir" "$ir_prof" || {
    error "IR profile merge failed"
    return 1
  }

  #
  # 2) CS-PGO instrumentation + lightweight training
  #
  msg2 "== Stage 3: CS-PGO instrumented build"

  local ir_use_flag="-fprofile-use=${ir_prof}"
  local cs_gen_flag="-fcs-profile-generate=${fallback_cs}"
  export CFLAGS="${orig_cflags} ${ir_use_flag} ${cs_gen_flag} ${pgo_quality_flags}"
  export CXXFLAGS="${orig_cxxflags} ${ir_use_flag} ${cs_gen_flag} ${pgo_quality_flags}"
  export LDFLAGS="${orig_ldflags} ${ir_use_flag} ${cs_gen_flag}"

  ./build.sh -c "${buildopts[@]}" || return 1
  ./build.sh "${buildopts[@]}" || {
    error "CS instrumented build failed"
    return 1
  }

  [[ -d "$srcdir/dist/Release/bin" ]] || {
    error "Missing build output after CS stage"
    return 1
  }

  msg2 "== Stage 4: CS training (trimmed)"
  run_fast_gtests_bundle "cs" "$raw_cs" 1 || {
    error "CS training failed"
    return 1
  }

  local cs_prof="$prof_dir/cs.profdata"
  local merged_prof="$prof_dir/merged.profdata"
  merge_raw_dir "$raw_cs" "$cs_prof" || {
    error "CS profile merge failed"
    return 1
  }

  # Proper CS flow: combine baseline IR profile + CS profile.
  llvm-profdata merge -sparse=true -output="$merged_prof" "$ir_prof" "$cs_prof" || {
    error "Final merged profile creation failed"
    return 1
  }
  [[ -s "$merged_prof" ]] || {
    error "Merged profdata is empty"
    return 1
  }

  #
  # 3) Final optimized build
  #
  msg2 "== Stage 5: Final optimized build"

  local merged_use_flag="-fprofile-use=${merged_prof}"
  export CFLAGS="${orig_cflags} ${merged_use_flag}"
  export CXXFLAGS="${orig_cxxflags} ${merged_use_flag}"
  export LDFLAGS="${orig_ldflags} ${merged_use_flag}"

  ./build.sh -c "${buildopts[@]}" || return 1
  ./build.sh "${buildopts[@]}" || {
    error "Final optimized build failed"
    return 1
  }

  [[ -d "$srcdir/dist/Release/bin" ]] || {
    error "Missing final build output"
    return 1
  }

  #
  # 4) Final validation (same anti-flake handling, no profiling)
  #
  msg2 "== Stage 6: Final validation"
  run_fast_gtests_bundle "final" "/dev/null" 0 || {
    error "Final validation failed"
    return 1
  }

  export CFLAGS="${orig_cflags}"
  export CXXFLAGS="${orig_cxxflags}"
  export LDFLAGS="${orig_ldflags}"
}

package_nss() {
  local nsprver
  nsprver="$(pkg-config --modversion nspr)"
  local libdir=/usr/lib
  local includedir=/usr/include/nss

  if [[ ! -f nss/pkg/pkg-config/nss.pc.in ]]; then
    error "nss.pc.in not found"
    return 1
  fi
  sed nss/pkg/pkg-config/nss.pc.in \
    -e "s,%prefix%,/usr,g" \
    -e "s,%exec_prefix%,\${prefix},g" \
    -e "s,%libdir%,$libdir,g" \
    -e "s,%includedir%,$includedir,g" \
    -e "s,%NSPR_VERSION%,$nsprver,g" \
    -e "s,%NSS_VERSION%,$pkgver,g" |
    install -Dm644 /dev/stdin "$pkgdir$libdir/pkgconfig/nss.pc"

  ln -s nss.pc "$pkgdir$libdir/pkgconfig/mozilla-nss.pc"

  if [[ ! -d dist/Release/lib ]]; then
    error "dist/Release/lib not found"
    return 1
  fi
  install -Dt "$pkgdir$libdir" dist/Release/lib/*.so

  local vmajor vminor vpatch
  if [[ ! -f nss/lib/nss/nss.h ]]; then
    error "nss.h not found"
    return 1
  fi
  { read -r vmajor; read -r vminor; read -r vpatch; } \
    < <(awk '/#define.*NSS_V(MAJOR|MINOR|PATCH)/ {print $3}' nss/lib/nss/nss.h)

  if [[ ! -f nss/pkg/pkg-config/nss-config.in ]]; then
    error "nss-config.in not found"
    return 1
  fi
  sed nss/pkg/pkg-config/nss-config.in \
    -e "s,@prefix@,/usr,g" \
    -e "s,@exec_prefix@,/usr,g" \
    -e "s,@libdir@,$libdir,g" \
    -e "s,@includedir@,$includedir,g" \
    -e "s,@MOD_MAJOR_VERSION@,$vmajor,g" \
    -e "s,@MOD_MINOR_VERSION@,$vminor,g" \
    -e "s,@MOD_PATCH_VERSION@,$vpatch,g" |
    install -D /dev/stdin "$pkgdir/usr/bin/nss-config"

  if [[ ! -d dist/Release/bin ]]; then
    error "dist/Release/bin not found"
    return 1
  fi
  install -Dt "$pkgdir/usr/bin" \
    dist/Release/bin/{*util,shlibsign,signtool,signver,ssltap}

  if [[ ! -d dist/public/nss ]]; then
    error "dist/public/nss not found"
    return 1
  fi
  install -Dt "$pkgdir$includedir" -m644 dist/public/nss/*.h

  if [[ ! -d nss/doc/nroff ]]; then
    error "nss/doc/nroff not found"
    return 1
  fi
  install -Dt "$pkgdir/usr/share/man/man1" -m644 \
    nss/doc/nroff/{*util,signtool,signver,ssltap}.1

  ln -s /usr/lib/pkcs11/p11-kit-trust.so "$pkgdir$libdir/p11-kit-trust.so"
  ln -sf p11-kit-trust.so "$pkgdir$libdir/libnssckbi.so"
}

package_ca-certificates-mozilla() {
  pkgdesc="Mozilla's set of trusted CA certificates"
  depends=('ca-certificates-utils>=20181109-3')

  if [[ ! -f ca-bundle.trust.p11-kit ]]; then
    error "ca-bundle.trust.p11-kit not found"
    return 1
  fi
  install -Dm644 ca-bundle.trust.p11-kit \
    "$pkgdir/usr/share/ca-certificates/trust-source/mozilla.trust.p11-kit"
}
