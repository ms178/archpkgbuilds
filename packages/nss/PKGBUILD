prepare() {
  mkdir -p certs
  for file in nss/lib/ckfw/builtins/{certdata.txt,nssckbi.h}; do
    if [[ ! -f "$file" ]]; then
      error "Required file $file not found"
      return 1
    fi
  done
  ln -srft certs nss/lib/ckfw/builtins/{certdata.txt,nssckbi.h}

  # NSS 3.123.1 regression fix:
  # ssl_gtests.sh uses ./ssl_gtest_db.sh and assumes CWD.
  # Make it path-stable regardless of invocation directory.
  local gtest_script="nss/tests/ssl_gtests/ssl_gtests.sh"
  [[ -f "$gtest_script" ]] || {
    error "Missing $gtest_script"
    return 1
  }

  # Insert script-dir anchor once.
  if ! grep -q '^SSL_GTESTS_DIR=' "$gtest_script"; then
    sed -i '/^ssl_gtest_certs() {/i SSL_GTESTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"\n' "$gtest_script"
  fi

  # Use absolute helper path relative to script location.
  sed -i \
    's|^\([[:space:]]*\)\./ssl_gtest_db\.sh "\${SSLGTESTDIR}" "\${BINDIR}/certutil" "\${R_NOISE_FILE}"|\1"${SSL_GTESTS_DIR}/ssl_gtest_db.sh" "${SSLGTESTDIR}" "${BINDIR}/certutil" "${R_NOISE_FILE}"|' \
    "$gtest_script"

  # Force startup from anchored script dir.
  sed -i \
    's|^cd "$(dirname "$0")"$|cd "${SSL_GTESTS_DIR}"|' \
    "$gtest_script"
}

build() {
  local buildopts=(
    --enable-libpkix
    --opt
    --system-nspr
    --system-sqlite
    --target=x64
    --clang
  )

  cd certs
  ../certdata2pem.py
  cd ..
  ./bundle.sh

  local pgo_dir="$srcdir/pgo-data"
  mkdir -p "${pgo_dir}/standard" "${pgo_dir}/cs"

  local orig_cflags="${CFLAGS:-}"
  local orig_cxxflags="${CXXFLAGS:-}"
  local orig_ldflags="${LDFLAGS:-}"

  local unwind_ldflags=""
  if command -v gcc >/dev/null 2>&1; then
    local gcc_libgcc gcc_libunwind
    gcc_libgcc="$(gcc -print-file-name=libgcc_s.so 2>/dev/null || true)"
    if [[ -n "$gcc_libgcc" && -f "$gcc_libgcc" ]]; then
      unwind_ldflags+=" -lgcc_s"
    fi
    gcc_libunwind="$(gcc -print-file-name=libunwind.so 2>/dev/null || true)"
    if [[ -n "$gcc_libunwind" && -f "$gcc_libunwind" ]]; then
      unwind_ldflags+=" -lunwind"
    fi
  fi
  if [[ -z "$unwind_ldflags" ]]; then
    [[ -f /usr/lib/libgcc_s.so || -f /usr/lib64/libgcc_s.so ]] && unwind_ldflags+=" -lgcc_s"
    [[ -f /usr/lib/libunwind.so || -f /usr/lib64/libunwind.so ]] && unwind_ldflags+=" -lunwind"
  fi

  run_ssl_gtests() {
    local stage="$1"
    msg2 "Running NSS ssl_gtests for ${stage}"

    cd "$srcdir/nss/tests" || return 1
    export NSS_TESTS="ssl_gtests"
    export NSS_CYCLES="standard"
    export NSS_DEFAULT_DB_TYPE="sql"
    export HOST="localhost"
    export DOMSUF="localdomain"

    # Upstream-supported runner for NSS tests.
    if ! bash ./all.sh; then
      error "SSL tests failed for ${stage}"
      return 1
    fi

    cd "$srcdir/nss" || return 1
  }

  merge_profraw_dir() {
    local dir="$1"
    local out="$2"
    local profraw_files=()

    shopt -s nullglob
    profraw_files=("${dir}"/*.profraw)
    shopt -u nullglob

    if (( ${#profraw_files[@]} == 0 )); then
      error "No .profraw files found in ${dir}"
      return 1
    fi

    llvm-profdata merge -output="${out}" "${profraw_files[@]}"
  }

  cd nss

  #
  # 1) Standard PGO instrumentation
  #
  msg2 "== Building NSS with standard PGO instrumentation"

  export CFLAGS="${orig_cflags} -fprofile-generate=${pgo_dir}/standard -g3 -fno-omit-frame-pointer"
  export CXXFLAGS="${orig_cxxflags} -fprofile-generate=${pgo_dir}/standard -g3 -fno-omit-frame-pointer"
  export LDFLAGS="${orig_ldflags} -fprofile-generate=${pgo_dir}/standard${unwind_ldflags}"

  ./build.sh -c "${buildopts[@]}" || {
    error "Failed to clean before standard PGO build"
    return 1
  }
  ./build.sh "${buildopts[@]}" || {
    error "Failed to build NSS with standard PGO instrumentation"
    return 1
  }

  [[ -d "$srcdir/dist/Release/bin" ]] || {
    error "Build output not found, cannot generate standard PGO profile"
    return 1
  }

  export LLVM_PROFILE_FILE="${pgo_dir}/standard/default_%m.profraw"
  run_ssl_gtests "standard PGO profile" || return 1
  unset LLVM_PROFILE_FILE

  merge_profraw_dir "${pgo_dir}/standard" "${pgo_dir}/standard.profdata" || {
    error "Failed to merge standard PGO profile data"
    return 1
  }

  #
  # 2) Context-sensitive PGO instrumentation pass
  #
  msg2 "== Building NSS with context-sensitive PGO instrumentation"

  export CFLAGS="${orig_cflags} -fprofile-use=${pgo_dir}/standard.profdata -fcs-profile-generate=${pgo_dir}/cs -g3 -fno-omit-frame-pointer"
  export CXXFLAGS="${orig_cxxflags} -fprofile-use=${pgo_dir}/standard.profdata -fcs-profile-generate=${pgo_dir}/cs -g3 -fno-omit-frame-pointer"
  export LDFLAGS="${orig_ldflags} -fprofile-use=${pgo_dir}/standard.profdata -fcs-profile-generate=${pgo_dir}/cs${unwind_ldflags}"

  ./build.sh -c "${buildopts[@]}" || {
    error "Failed to clean before CS-PGO build"
    return 1
  }
  ./build.sh "${buildopts[@]}" || {
    error "Failed to build NSS with context-sensitive PGO instrumentation"
    return 1
  }

  [[ -d "$srcdir/dist/Release/bin" ]] || {
    error "Build output not found, cannot generate CS-PGO profile"
    return 1
  }

  export LLVM_PROFILE_FILE="${pgo_dir}/cs/default_%m.profraw"
  run_ssl_gtests "context-sensitive PGO profile" || return 1
  unset LLVM_PROFILE_FILE

  # Per Clang docs: merge pass1 profdata + CS raw profiles into one final profile.
  shopt -s nullglob
  local cs_profraw=( "${pgo_dir}"/cs/*.profraw )
  shopt -u nullglob
  if (( ${#cs_profraw[@]} == 0 )); then
    error "No CS-PGO .profraw files found in ${pgo_dir}/cs"
    return 1
  fi

  llvm-profdata merge \
    -output="${pgo_dir}/merged.profdata" \
    "${cs_profraw[@]}" \
    "${pgo_dir}/standard.profdata" || {
      error "Failed to merge context-sensitive PGO profile data"
      return 1
    }

  #
  # 3) Final optimized build using merged profile
  #
  msg2 "== Building final optimized NSS with merged PGO data"

  export CFLAGS="${orig_cflags} -fprofile-use=${pgo_dir}/merged.profdata"
  export CXXFLAGS="${orig_cxxflags} -fprofile-use=${pgo_dir}/merged.profdata"
  export LDFLAGS="${orig_ldflags} -fprofile-use=${pgo_dir}/merged.profdata"

  ./build.sh -c "${buildopts[@]}" || {
    error "Failed to clean before final optimized build"
    return 1
  }
  ./build.sh "${buildopts[@]}" || {
    error "Failed to build final optimized NSS"
    return 1
  }

  [[ -d "$srcdir/dist/Release/bin" ]] || {
    error "Final optimized build output not found"
    return 1
  }

  run_ssl_gtests "final optimized build" || return 1

  export CFLAGS="${orig_cflags}"
  export CXXFLAGS="${orig_cxxflags}"
  export LDFLAGS="${orig_ldflags}"
}

package_nss() {
  local nsprver
  nsprver="$(pkg-config --modversion nspr)"
  local libdir=/usr/lib
  local includedir=/usr/include/nss

  if [[ ! -f nss/pkg/pkg-config/nss.pc.in ]]; then
    error "nss.pc.in not found"
    return 1
  fi
  sed nss/pkg/pkg-config/nss.pc.in \
    -e "s,%prefix%,/usr,g" \
    -e "s,%exec_prefix%,\${prefix},g" \
    -e "s,%libdir%,$libdir,g" \
    -e "s,%includedir%,$includedir,g" \
    -e "s,%NSPR_VERSION%,$nsprver,g" \
    -e "s,%NSS_VERSION%,$pkgver,g" |
    install -Dm644 /dev/stdin "$pkgdir$libdir/pkgconfig/nss.pc"

  ln -s nss.pc "$pkgdir$libdir/pkgconfig/mozilla-nss.pc"

  if [[ ! -d dist/Release/lib ]]; then
    error "dist/Release/lib not found"
    return 1
  fi
  install -Dt "$pkgdir$libdir" dist/Release/lib/*.so

  local vmajor vminor vpatch
  if [[ ! -f nss/lib/nss/nss.h ]]; then
    error "nss.h not found"
    return 1
  fi
  { read -r vmajor; read -r vminor; read -r vpatch; } \
    < <(awk '/#define.*NSS_V(MAJOR|MINOR|PATCH)/ {print $3}' nss/lib/nss/nss.h)

  if [[ ! -f nss/pkg/pkg-config/nss-config.in ]]; then
    error "nss-config.in not found"
    return 1
  fi
  sed nss/pkg/pkg-config/nss-config.in \
    -e "s,@prefix@,/usr,g" \
    -e "s,@exec_prefix@,/usr,g" \
    -e "s,@libdir@,$libdir,g" \
    -e "s,@includedir@,$includedir,g" \
    -e "s,@MOD_MAJOR_VERSION@,$vmajor,g" \
    -e "s,@MOD_MINOR_VERSION@,$vminor,g" \
    -e "s,@MOD_PATCH_VERSION@,$vpatch,g" |
    install -D /dev/stdin "$pkgdir/usr/bin/nss-config"

  if [[ ! -d dist/Release/bin ]]; then
    error "dist/Release/bin not found"
    return 1
  fi
  install -Dt "$pkgdir/usr/bin" \
    dist/Release/bin/{*util,shlibsign,signtool,signver,ssltap}

  if [[ ! -d dist/public/nss ]]; then
    error "dist/public/nss not found"
    return 1
  fi
  install -Dt "$pkgdir$includedir" -m644 dist/public/nss/*.h

  if [[ ! -d nss/doc/nroff ]]; then
    error "nss/doc/nroff not found"
    return 1
  fi
  install -Dt "$pkgdir/usr/share/man/man1" -m644 \
    nss/doc/nroff/{*util,signtool,signver,ssltap}.1

  ln -s /usr/lib/pkcs11/p11-kit-trust.so "$pkgdir$libdir/p11-kit-trust.so"
  ln -sf p11-kit-trust.so "$pkgdir$libdir/libnssckbi.so"
}

package_ca-certificates-mozilla() {
  pkgdesc="Mozilla's set of trusted CA certificates"
  depends=('ca-certificates-utils>=20181109-3')

  if [[ ! -f ca-bundle.trust.p11-kit ]]; then
    error "ca-bundle.trust.p11-kit not found"
    return 1
  fi
  install -Dm644 ca-bundle.trust.p11-kit \
    "$pkgdir/usr/share/ca-certificates/trust-source/mozilla.trust.p11-kit"
}
