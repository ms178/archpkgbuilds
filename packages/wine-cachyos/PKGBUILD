conflicts=('wine' 'wine-mono' 'wine-gecko')
install=wine.install

_prepare_clang_wrappers() {
  local wrapdir="${srcdir}/clang-wrap"
  local host_clang="/usr/bin/clang"
  local host_clangxx="/usr/bin/clang++"
  local mingw32="$(command -v i686-w64-mingw32-clang)"
  local mingw32xx="$(command -v i686-w64-mingw32-clang++)"
  local mingw64="$(command -v x86_64-w64-mingw32-clang)"
  local mingw64xx="$(command -v x86_64-w64-mingw32-clang++)"

  [[ -x "${host_clang}" ]] || { error "Missing ${host_clang}"; return 1; }
  [[ -x "${host_clangxx}" ]] || { error "Missing ${host_clangxx}"; return 1; }
  [[ -x "${mingw32}" ]] || { error "Missing i686-w64-mingw32-clang in PATH"; return 1; }
  [[ -x "${mingw32xx}" ]] || { error "Missing i686-w64-mingw32-clang++ in PATH"; return 1; }
  [[ -x "${mingw64}" ]] || { error "Missing x86_64-w64-mingw32-clang in PATH"; return 1; }
  [[ -x "${mingw64xx}" ]] || { error "Missing x86_64-w64-mingw32-clang++ in PATH"; return 1; }

  rm -rf "${wrapdir}"
  mkdir -p "${wrapdir}"

  cat > "${wrapdir}/clang" <<EOF
#!/usr/bin/env bash
set -euo pipefail
orig=( "\$@" )
args=()
target=""
while (( \$# )); do
  case "\$1" in
    --no-default-config) shift ;;
    -target) target="\$2"; shift 2 ;;
    -target=*) target="\${1#-target=}"; shift ;;
    *) args+=("\$1"); shift ;;
  esac
done
case "\$target" in
  x86_64-windows*|x86_64-*-windows*|x86_64-w64-mingw32*)
    exec "${mingw64}" "\${args[@]}"
    ;;
  i[3-6]86-windows*|i[3-6]86-*-windows*|i686-w64-mingw32*)
    exec "${mingw32}" "\${args[@]}"
    ;;
  *)
    exec "${host_clang}" "\${orig[@]}"
    ;;
esac
EOF

  cat > "${wrapdir}/clang++" <<EOF
#!/usr/bin/env bash
set -euo pipefail
orig=( "\$@" )
args=()
target=""
while (( \$# )); do
  case "\$1" in
    --no-default-config) shift ;;
    -target) target="\$2"; shift 2 ;;
    -target=*) target="\${1#-target=}"; shift ;;
    *) args+=("\$1"); shift ;;
  esac
done
case "\$target" in
  x86_64-windows*|x86_64-*-windows*|x86_64-w64-mingw32*)
    exec "${mingw64xx}" "\${args[@]}"
    ;;
  i[3-6]86-windows*|i[3-6]86-*-windows*|i686-w64-mingw32*)
    exec "${mingw32xx}" "\${args[@]}"
    ;;
  *)
    exec "${host_clangxx}" "\${orig[@]}"
    ;;
esac
EOF

  chmod 755 "${wrapdir}/clang" "${wrapdir}/clang++"
  export PATH="${wrapdir}:${PATH}"
  hash -r
}

prepare() {
  rm -rf "${pkgname}-32-build" "${pkgname}-64-build"
  mkdir -p "${pkgname}-32-build" "${pkgname}-64-build"

  cd "${srcdir}/${pkgname}"
  git config user.email "wine@cachyos.org"
  git config user.name "wine cachyos"
  git tag "wine-${_srctag}" --annotate -m "${pkgver}" --force
  ./tools/make_requests
  ./dlls/winevulkan/make_vulkan -x vk.xml -X video.xml
  ./tools/make_specfiles
  autoreconf -fiv
  rm -rf autom4te.cache
}

build() {
  _prepare_clang_wrappers || return 1

  export CC="clang"
  export CXX="clang++"
  export AR="/usr/bin/llvm-ar"
  export NM="/usr/bin/llvm-nm"
  export RANLIB="/usr/bin/llvm-ranlib"
  export STRIP="/usr/bin/llvm-strip"
  export OBJCOPY="/usr/bin/llvm-objcopy"
  export DLLTOOL="/usr/bin/llvm-dlltool"

  local -a split=($CFLAGS)
  local -A flags
  local opt
  for opt in "${split[@]}"; do
    flags["${opt%%=*}"]="${opt##*=}"
  done

  local march="${flags["-march"]:-native}"
  local mtune="native"
  local march32="native"
  local mtune32="native"

  OPTIMIZE_FLAGS="-O3 -march=${march} -mtune=${mtune} -mfpmath=sse -fno-semantic-interposition -w -fdata-sections -ffunction-sections"
  OPTIMIZE_FLAGS_32="-O3 -march=${march32} -mtune=${mtune32} -mfpmath=sse -fno-semantic-interposition -w -fdata-sections -ffunction-sections -m32"
  SANITY_FLAGS="-fwrapv -fno-strict-aliasing -D_TIME_BITS=64 -D_FILE_OFFSET_BITS=64"
  WARNING_FLAGS="-Wno-error=incompatible-pointer-types -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"
  COMMON_FLAGS="${OPTIMIZE_FLAGS} ${SANITY_FLAGS} ${WARNING_FLAGS}"
  COMMON_FLAGS_32="${OPTIMIZE_FLAGS_32} ${SANITY_FLAGS} ${WARNING_FLAGS}"
  LTO_CFLAGS="-flto -D__LLD_LTO__"

  COMMON_LDFLAGS="-Wl,--lto-O3,-O3,-Bsymbolic-functions,--as-needed -Wl,--gc-sections"
  LTO_LDFLAGS="-flto -fuse-ld=lld"

  export preloader_CFLAGS="-flto"
  export wine64_preloader_LDFLAGS="-flto -Wl,--no-relax"
  export wine_preloader_LDFLAGS="-flto -Wl,--no-relax"

  cd "${srcdir}"

  msg2 "Configuring Wine-64..."
  export CFLAGS="${COMMON_FLAGS} -mcmodel=small -std=gnu18"
  export CXXFLAGS="${COMMON_FLAGS} -mcmodel=small -std=gnu++2a"
  export CROSSCFLAGS="${COMMON_FLAGS} -mcmodel=small"
  export CROSSCXXFLAGS="${COMMON_FLAGS} -mcmodel=small -std=gnu++2a"
  export LDFLAGS="-fuse-ld=lld"
  export CROSSLDFLAGS="-fuse-ld=lld -Wl,/FILEALIGN:4096"
  export PKG_CONFIG_PATH="/usr/lib/pkgconfig:/usr/share/pkgconfig"

  cd "${srcdir}/${pkgname}-64-build"
  ../${pkgname}/configure \
    --prefix=/usr \
    --libdir=/usr/lib \
    --with-x \
    --with-wayland \
    --with-gstreamer \
    --with-freetype \
    --with-alsa \
    --with-ffmpeg \
    --without-oss \
    --disable-lsteamclient \
    --disable-tests \
    --enable-win64 \
    --enable-build-id

  msg2 "Building Wine-64..."
  export CFLAGS="${COMMON_FLAGS} -mcmodel=small -std=gnu18 ${LTO_CFLAGS}"
  export CXXFLAGS="${COMMON_FLAGS} -mcmodel=small -std=gnu++2a ${LTO_CFLAGS}"
  export CROSSCFLAGS="${COMMON_FLAGS} -mcmodel=small ${LTO_CFLAGS}"
  export CROSSCXXFLAGS="${COMMON_FLAGS} -mcmodel=small -std=gnu++2a ${LTO_CFLAGS}"
  export LDFLAGS="${COMMON_LDFLAGS} ${LTO_LDFLAGS}"
  export CROSSLDFLAGS="-Wl,/FILEALIGN:4096,/OPT:REF,/OPT:ICF -fuse-ld=lld"
  make

  msg2 "Configuring Wine-32..."
  export CFLAGS="${COMMON_FLAGS_32} -mstackrealign -std=gnu18"
  export CXXFLAGS="${COMMON_FLAGS_32} -mstackrealign -std=gnu++2a"
  export CROSSCFLAGS="${COMMON_FLAGS_32} -mstackrealign"
  export CROSSCXXFLAGS="${COMMON_FLAGS_32} -mstackrealign -std=gnu++2a"
  export LDFLAGS="-fuse-ld=lld -m32"
  export CROSSLDFLAGS="-fuse-ld=lld -Wl,/FILEALIGN:4096"
  export PKG_CONFIG_PATH="/usr/lib32/pkgconfig:/usr/share/pkgconfig"

  cd "${srcdir}/${pkgname}-32-build"
  ../${pkgname}/configure \
    --prefix=/usr \
    --libdir=/usr/lib \
    --with-x \
    --with-wayland \
    --with-gstreamer \
    --with-freetype \
    --with-alsa \
    --without-ffmpeg \
    --without-oss \
    --disable-lsteamclient \
    --disable-tests \
    --with-wine64="${srcdir}/${pkgname}-64-build" \
    --enable-build-id

  msg2 "Building Wine-32..."
  export CFLAGS="${COMMON_FLAGS_32} -mstackrealign -std=gnu18 ${LTO_CFLAGS}"
  export CXXFLAGS="${COMMON_FLAGS_32} -mstackrealign -std=gnu++2a ${LTO_CFLAGS}"
  export CROSSCFLAGS="${COMMON_FLAGS_32} -mstackrealign ${LTO_CFLAGS}"
  export CROSSCXXFLAGS="${COMMON_FLAGS_32} -mstackrealign -std=gnu++2a ${LTO_CFLAGS}"
  export LDFLAGS="${COMMON_LDFLAGS} ${LTO_LDFLAGS}"
  export CROSSLDFLAGS="-Wl,/FILEALIGN:4096,/OPT:REF,/OPT:ICF -fuse-ld=lld"
  make
}

package() {
  msg2 "Packaging Wine-32..."
  cd "${srcdir}/${pkgname}-32-build"
  make prefix="${pkgdir}/usr" \
    libdir="${pkgdir}/usr/lib" \
    dlldir="${pkgdir}/usr/lib/wine" install

  msg2 "Packaging Wine-64..."
  cd "${srcdir}/${pkgname}-64-build"
  make prefix="${pkgdir}/usr" \
    libdir="${pkgdir}/usr/lib" \
    dlldir="${pkgdir}/usr/lib/wine" install

  install -d "${pkgdir}/usr/share/fontconfig/conf.avail" "${pkgdir}/usr/share/fontconfig/conf.default"
  install -m644 "${srcdir}/30-win32-aliases.conf" "${pkgdir}/usr/share/fontconfig/conf.avail/"
  ln -s ../conf.avail/30-win32-aliases.conf "${pkgdir}/usr/share/fontconfig/conf.default/30-win32-aliases.conf"
  install -Dm644 "${srcdir}/wine-binfmt.conf" "${pkgdir}/usr/lib/binfmt.d/wine.conf"
  install -Dm644 "${srcdir}/ntsync.conf" "${pkgdir}/usr/lib/modules-load.d/10-ntsync.conf"

  local -a pe32_files=()
  local -a pe64_files=()
  shopt -s nullglob
  pe32_files=("${pkgdir}"/usr/lib/wine/i386-windows/*.{dll,exe,cpl})
  pe64_files=("${pkgdir}"/usr/lib/wine/x86_64-windows/*.{dll,exe,cpl})
  shopt -u nullglob
  ((${#pe32_files[@]})) && /usr/bin/llvm-strip --strip-unneeded "${pe32_files[@]}"
  ((${#pe64_files[@]})) && /usr/bin/llvm-strip --strip-unneeded "${pe64_files[@]}"

  cd "${srcdir}"
  install -d -m755 "${pkgdir}/usr/share/wine/gecko"
  cp -a --no-preserve=ownership wine-gecko-${_geckover}-x86{,_64} "${pkgdir}/usr/share/wine/gecko/"

  install -d -m755 "${pkgdir}/usr/share/wine/mono"
  cp -a --no-preserve=ownership wine-mono-${_monover} "${pkgdir}/usr/share/wine/mono/"

  install -d -m755 "${pkgdir}/usr/share/xalia"
  unzip -q xalia-${_xaliaver}-net48-mono.zip -d "${pkgdir}/usr/share/xalia"
}

