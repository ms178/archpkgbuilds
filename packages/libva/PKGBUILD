# Maintainer: Maxime Gauduin <alucryd@archlinux.org>
# Contributor: Bartłomiej Piotrowski <bpiotrowski@archlinux.org>
# Contributor: Ionut Biru <ibiru@archlinux.org>
#
# Clang IR-PGO + CS-PGO + LLVM BOLT. The workload exercises the VA-API core,
# every enabled display backend, all available DRM render nodes, and the
# explicit RadeonSI path used by AMD Vega systems. It additionally uses vainfo
# when a real VA display/driver is available on the build host.
#
# Clang/LLVM 22.1.8 (or the active llvm-ultimate-compatible toolchain) remains
# the compiler and BOLT toolchain. GNU ld.bfd is selected deliberately because
# LLD's versioned-symbol representation prevents BOLT from processing libva.so.

pkgname=libva
pkgver=2.24.1
pkgrel=3.8
pkgdesc='Video Acceleration (VA) API for Linux (Clang PGO + CS-PGO + BOLT optimized)'
arch=(x86_64)
url='https://01.org/linuxmedia/vaapi'
license=(MIT)

depends=(
  libdrm
  libgl
  libx11
  libxext
  libxfixes
  wayland
)

makedepends=(
  binutils
  git
  libglvnd
  libva-utils
  libxcb
  mesa
  meson
  ninja
  pkgconf
)

optdepends=(
  'intel-media-driver: backend for Intel GPUs (>= Broadwell)'
  'libva-intel-driver: backend for Intel GPUs (<= Haswell)'
  'libva-mesa-driver: backend for AMD and Nvidia GPUs'
)

provides=(
  'libva-drm.so=2-64'
  'libva-glx.so=2-64'
  'libva-wayland.so=2-64'
  'libva-x11.so=2-64'
  'libva.so=2-64'
)

backup=(etc/libva.conf)
options=(strip)
source=(git+https://github.com/intel/libva.git#tag=${pkgver})
sha256sums=(SKIP)

pkgver() {
  cd "${srcdir}/libva"
  git describe --tags | sed 's/[^-]*-g/r&/;s/-/+/g'
}

# Resolve the complete LLVM toolchain from one prefix. This supports the
# llvm-ultimate layout used by the rest of the ms178 packages without adding
# a second system LLVM/BOLT dependency to the package.
_setup_llvm() {
  # The caller owns toolchain selection. In particular, do not guess a
  # toolchain path here: makepkg is expected to inherit the active
  # llvm-ultimate environment and PATH.
  _resolve_tool() {
    local _value="$1"
    if [[ "${_value}" == */* ]]; then
      printf '%s\n' "${_value}"
    else
      command -v "${_value}"
    fi
  }

  export CC="$(_resolve_tool "${CC:-clang}")"
  export CXX="$(_resolve_tool "${CXX:-clang++}")"
  export AR="$(_resolve_tool "${AR:-llvm-ar}")"
  export NM="$(_resolve_tool "${NM:-llvm-nm}")"
  export RANLIB="$(_resolve_tool "${RANLIB:-llvm-ranlib}")"
  export STRIP="$(_resolve_tool "${STRIP:-llvm-strip}")"
  export OBJCOPY="$(_resolve_tool "${OBJCOPY:-llvm-objcopy}")"
  export OBJDUMP="$(_resolve_tool "${OBJDUMP:-llvm-objdump}")"
  export READELF="$(_resolve_tool "${READELF:-llvm-readelf}")"
  if [[ "${LIBVA_BOLT_USE_BFD:-1}" == 1 ]]; then
    export LD="$(_resolve_tool "${LIBVA_BFD_LD:-ld.bfd}")"
  else
    export LD="$(_resolve_tool "${LD:-ld.lld}")"
  fi
  export LLVM_PROFDATA="$(_resolve_tool "${LLVM_PROFDATA:-llvm-profdata}")"
  export LLVM_BOLT="$(_resolve_tool "${LLVM_BOLT:-llvm-bolt}")"
  export MERGE_FDATA="$(_resolve_tool "${MERGE_FDATA:-merge-fdata}")"

  local _tool
  for _tool in "$CC" "$CXX" "$AR" "$NM" "$RANLIB" "$STRIP" "$OBJCOPY" \
      "$OBJDUMP" "$READELF" "$LD" "$LLVM_PROFDATA" "$LLVM_BOLT" "$MERGE_FDATA"; do
    [[ -n "$_tool" && -x "$_tool" ]] || {
      error "required active LLVM tool missing: ${_tool:-<unset>}"
      return 1
    }
  done

  msg2 "active LLVM bin: $(dirname "${CC}")"
  msg2 "clang: $CC"
  msg2 "linker: $LD"
  msg2 "llvm-profdata: $LLVM_PROFDATA"
  msg2 "llvm-bolt: $LLVM_BOLT"
}

_sanitize_link_flags() {
  local _flags="$1"
  local _use_bfd="${2:-0}"
  local -a _in _out _wl _kept
  local _flag _part _joined
  read -r -a _in <<< "$_flags"

  for _flag in "${_in[@]}"; do
    case "$_flag" in
      # The linker is selected explicitly by _TOOLCHAIN_LINK_FLAGS.
      -fuse-ld=*)
        continue
        ;;
      # These are compiler/backend flags accidentally placed in LDFLAGS by
      # aggressive toolchain profiles. They must never be forwarded to ld.
      -mllvm|-Wl,-mllvm)
        continue
        ;;
      -flto|-flto=*|-fwhole-program-vtables|-fsplit-lto-unit)
        [[ "$_use_bfd" == 1 ]] && continue
        _out+=("$_flag")
        ;;
      -Wl,*)
        IFS=',' read -r -a _wl <<< "${_flag#-Wl,}"
        _kept=()
        for _part in "${_wl[@]}"; do
          case "$_part" in
            # LLVM optimization passes are valid after -mllvm at compile
            # time, not as raw linker options.
            -extra-vectorizer-passes|-slp-*|-enable-*|-aggressive-ext-opt \
            |-adce-*|-unroll-*|-interleaved-*|-masked-interleaved-* \
            |-loop*|-gvn-*|-dfa-*|-polly*|-inline-*|-vp-*|-mllvm)
              continue
              ;;
            # LLD-only options cannot be passed to GNU ld.bfd.
            --icf=*|--lto*|--thinlto*|--plugin-opt=*)
              [[ "$_use_bfd" == 1 ]] && continue
              ;;
          esac
          _kept+=("$_part")
        done
        if (( ${#_kept[@]} > 0 )); then
          _joined="$(IFS=,; printf '%s' "${_kept[*]}")"
          _out+=("-Wl,${_joined}")
        fi
        ;;
      *)
        _out+=("$_flag")
        ;;
    esac
  done
  printf '%s' "${_out[*]}"
}

_strip_bfd_compile_flags() {
  local _flags="$1"
  local -a _in _out
  local _flag
  read -r -a _in <<< "$_flags"
  for _flag in "${_in[@]}"; do
    case "$_flag" in
      -flto|-flto=*|-fwhole-program-vtables|-fsplit-lto-unit|-fuse-ld=*)
        continue
        ;;
      *)
        _out+=("$_flag")
        ;;
    esac
  done
  printf '%s' "${_out[*]}"
}

_filter_clang_flags() {
  local _flags="$1"
  local _probe="${srcdir}/libva-clang-flag-probe.c"
  local -a _in _out
  local _i=0 _flag _mllvm_arg

  printf 'int libva_clang_flag_probe;\n' >"${_probe}"
  read -r -a _in <<< "${_flags}"
  while (( _i < ${#_in[@]} )); do
    _flag="${_in[_i]}"
    if [[ "${_flag}" == -mllvm && $(( _i + 1 )) -lt ${#_in[@]} ]]; then
      _mllvm_arg="${_in[_i + 1]}"
      if "${CC}" -x c -c "${_probe}" -o /dev/null \
          -mllvm "${_mllvm_arg}" >/dev/null 2>&1; then
        _out+=("-mllvm" "${_mllvm_arg}")
      else
        printf 'WARNING: dropping unsupported active-Clang LLVM option: -mllvm %s\n' \
          "${_mllvm_arg}" >&2
      fi
      _i=$(( _i + 2 ))
    else
      _out+=("${_flag}")
      _i=$(( _i + 1 ))
    fi
  done
  rm -f "${_probe}"
  printf '%s' "${_out[*]}"
}

_meson_common_args() {
  local _lto=true
  [[ "${LIBVA_NO_LTO:-0}" == 1 || "${LIBVA_BOLT_USE_BFD:-1}" == 1 ]] && _lto=false

  _meson_args=(
    --buildtype=plain
    --prefix=/usr
    -Db_ndebug=true
    -Db_pie=false
    -Db_lto="${_lto}"
    -Db_lto_mode=default
    -Dc_std=gnu2x
    -Dcpp_std=gnu++2a
    -Ddriverdir=/usr/lib/dri
    --wrap-mode=nofallback
    -Ddisable_drm=false
    # Build every Linux backend explicitly; the workload and provides list
    # cover DRM, X11/GLX and Wayland.
    -Dwith_x11=yes
    -Dwith_glx=yes
    -Dwith_wayland=yes
    -Dwith_win32=no
    -Denable_docs=false)
}

_meson_setup() {
  local _builddir="$1"
  local _compile_extra="$2"
  local _link_extra="$3"
  local _source="${srcdir}/libva"
  local _compile_flags="${CFLAGS}"
  local _cxx_flags="${CXXFLAGS}"
  local _link_flags="${LDFLAGS}"

  local _use_bfd=0
  [[ "${LIBVA_BOLT_USE_BFD:-1}" == 1 ]] && _use_bfd=1
  if (( _use_bfd )); then
    _compile_flags="$(_strip_bfd_compile_flags "$_compile_flags")"
    _cxx_flags="$(_strip_bfd_compile_flags "$_cxx_flags")"
  fi
  _link_flags="$(_sanitize_link_flags "$_link_flags" "$_use_bfd")"

  _meson_common_args
  rm -rf "${_builddir}"

  env CC="$CC" CXX="$CXX" AR="$AR" NM="$NM" RANLIB="$RANLIB" \
    STRIP="$STRIP" OBJCOPY="$OBJCOPY" OBJDUMP="$OBJDUMP" READELF="$READELF" \
    LD="$LD" meson setup "${_builddir}" "${_source}" \
    "${_meson_args[@]}" \
    -Dc_args="${_compile_flags} ${_compile_extra}" \
    -Dcpp_args="${_cxx_flags} ${_compile_extra}" \
    -Dc_link_args="${_link_flags} ${_TOOLCHAIN_LINK_FLAGS:-} ${_link_extra}" \
    -Dcpp_link_args="${_link_flags} ${_TOOLCHAIN_LINK_FLAGS:-} ${_link_extra}"
}

_collect_profraw() {
  local _dir="$1"
  local -n _out="$2"
  _out=()
  while IFS= read -r -d '' _file; do
    _out+=("$_file")
  done < <(find "$_dir" -type f -name '*.profraw' -print0)
  (( ${#_out[@]} > 0 )) || {
    error "no profraw files were generated in $_dir"
    return 1
  }
}

_write_workload() {
  cat > "${srcdir}/libva-pgo-workload.c" <<'EOF'
#define _GNU_SOURCE
#include <fcntl.h>
#include <glob.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

#include <va/va.h>
#include <va/va_drm.h>
#include <va/va_drmcommon.h>
#include <va/va_glx.h>
#include <va/va_wayland.h>
#include <va/va_x11.h>
#include <xf86drm.h>
#include <X11/Xlib.h>
#include <wayland-client.h>

static unsigned calls;
static unsigned successes;

static void record_status(const char *what, VAStatus st) {
  ++calls;
  if (st == VA_STATUS_SUCCESS) ++successes;
  if (getenv("LIBVA_PGO_VERBOSE"))
    fprintf(stderr, "%-42s: %s (%d)\n", what, vaErrorStr(st), st);
}

static void exercise_invalid_api(void) {
  int major = 0, minor = 0;
  VAConfigAttrib attrs[VAConfigAttribTypeMax];
  VAProfile profiles[8];
  VAEntrypoint entries[8];
  VASurfaceID surfaces[2] = { VA_INVALID_SURFACE, VA_INVALID_SURFACE };
  VAStatus st;

  /* Exercise every backend entry point even when no display server/GPU exists. */
  (void)vaDisplayIsValid(NULL);
  (void)vaGetDisplayDRM(-1);
  (void)vaGetDisplay(NULL);
  (void)vaGetDisplayGLX(NULL);
  (void)vaQueryVendorString(NULL);
  (void)vaMaxNumProfiles(NULL);
  (void)vaMaxNumEntrypoints(NULL);
  (void)vaMaxNumConfigAttributes(NULL);
  (void)vaSetErrorCallback(NULL, NULL, NULL);
  (void)vaSetInfoCallback(NULL, NULL, NULL);
  st = vaInitialize(NULL, &major, &minor); record_status("invalid vaInitialize", st);
  st = vaTerminate(NULL); record_status("invalid vaTerminate", st);
  st = vaQueryConfigProfiles(NULL, profiles, NULL); record_status("invalid profiles", st);
  st = vaQueryConfigEntrypoints(NULL, VAProfileNone, entries, NULL); record_status("invalid entrypoints", st);
  st = vaGetConfigAttributes(NULL, VAProfileNone, VAEntrypointVLD, attrs, 0); record_status("invalid attributes", st);
  st = vaCreateSurfaces(NULL, VA_RT_FORMAT_YUV420, 64, 64, surfaces, 2, NULL, 0); record_status("invalid surfaces", st);
}

static void exercise_display(VADisplay dpy, const char *name) {
  int major = 0, minor = 0;
  VAStatus st;
  int np, ne, na;
  VAProfile *profiles = NULL;
  VAEntrypoint *entries = NULL;
  VAConfigAttrib *attrs = NULL;

  if (!dpy) return;

  int nformats = vaMaxNumImageFormats(dpy);
  if (nformats > 0) {
    VAImageFormat *formats = calloc((size_t)nformats, sizeof(*formats));
    if (formats) {
      int got_formats = nformats;
      record_status("vaQueryImageFormats", vaQueryImageFormats(dpy, formats, &got_formats));
      free(formats);
    }
  }

  int nsubformats = vaMaxNumSubpictureFormats(dpy);
  if (nsubformats > 0) {
    VAImageFormat *subformats = calloc((size_t)nsubformats, sizeof(*subformats));
    unsigned int *subflags = calloc((size_t)nsubformats, sizeof(*subflags));
    if (subformats && subflags) {
      unsigned int got_subformats = (unsigned int)nsubformats;
      record_status("vaQuerySubpictureFormats", vaQuerySubpictureFormats(dpy, subformats, subflags, &got_subformats));
    }
    free(subflags);
    free(subformats);
  }

  st = vaInitialize(dpy, &major, &minor);
  record_status(name, st);
  if (st != VA_STATUS_SUCCESS) return;

  (void)vaSetErrorCallback(dpy, NULL, NULL);
  (void)vaSetInfoCallback(dpy, NULL, NULL);
  (void)vaQueryVendorString(dpy);
  (void)vaMaxNumSubpictureFormats(dpy);

  int ndattrs = vaMaxNumDisplayAttributes(dpy);
  if (ndattrs > 0) {
    VADisplayAttribute *dattrs = calloc((size_t)ndattrs, sizeof(*dattrs));
    if (dattrs) {
      int got = ndattrs;
      record_status("vaQueryDisplayAttributes", vaQueryDisplayAttributes(dpy, dattrs, &got));
      free(dattrs);
    }
  }

  np = vaMaxNumProfiles(dpy);
  ne = vaMaxNumEntrypoints(dpy);
  na = vaMaxNumConfigAttributes(dpy);
  if (np <= 0 || ne <= 0 || na <= 0) goto done;

  profiles = calloc((size_t)np, sizeof(*profiles));
  entries = calloc((size_t)ne, sizeof(*entries));
  attrs = calloc((size_t)na, sizeof(*attrs));
  if (!profiles || !entries || !attrs) goto done;

  int nprofiles = 0;
  st = vaQueryConfigProfiles(dpy, profiles, &nprofiles);
  record_status("vaQueryConfigProfiles", st);
  if (st != VA_STATUS_SUCCESS) goto done;

  for (int pi = 0; pi < nprofiles; ++pi) {
    int nentries = 0;
    st = vaQueryConfigEntrypoints(dpy, profiles[pi], entries, &nentries);
    record_status("vaQueryConfigEntrypoints", st);
    if (st != VA_STATUS_SUCCESS) continue;

    for (int ei = 0; ei < nentries; ++ei) {
      for (int ai = 0; ai < na; ++ai) {
        attrs[ai].type = (VAConfigAttribType)ai;
        attrs[ai].value = VA_ATTRIB_NOT_SUPPORTED;
      }
      st = vaGetConfigAttributes(dpy, profiles[pi], entries[ei], attrs, na);
      record_status("vaGetConfigAttributes", st);
      if (st != VA_STATUS_SUCCESS) continue;

      VAConfigID config = VA_INVALID_ID;
      st = vaCreateConfig(dpy, profiles[pi], entries[ei], attrs, na, &config);
      record_status("vaCreateConfig", st);
      if (st != VA_STATUS_SUCCESS) continue;

      unsigned nsurfattrs = 0;
      st = vaQuerySurfaceAttributes(dpy, config, NULL, &nsurfattrs);
      record_status("vaQuerySurfaceAttributes(size)", st);
      if (st == VA_STATUS_SUCCESS && nsurfattrs) {
        VASurfaceAttrib *sa = calloc(nsurfattrs, sizeof(*sa));
        if (sa) {
          st = vaQuerySurfaceAttributes(dpy, config, sa, &nsurfattrs);
          record_status("vaQuerySurfaceAttributes", st);
          free(sa);
        }
      }

      VASurfaceID surfaces[4] = { VA_INVALID_SURFACE, VA_INVALID_SURFACE,
                                  VA_INVALID_SURFACE, VA_INVALID_SURFACE };
      st = vaCreateSurfaces(dpy, VA_RT_FORMAT_YUV420, 64, 64, surfaces, 4, NULL, 0);
      record_status("vaCreateSurfaces", st);
      if (st == VA_STATUS_SUCCESS) {
        int image_count = vaMaxNumImageFormats(dpy);
        if (image_count > 0) {
          VAImageFormat *image_formats = calloc((size_t)image_count, sizeof(*image_formats));
          if (image_formats) {
            int got_images = image_count;
            if (vaQueryImageFormats(dpy, image_formats, &got_images) == VA_STATUS_SUCCESS && got_images > 0) {
              VAImage image = {0};
              image.image_id = VA_INVALID_ID;
              record_status("vaCreateImage", vaCreateImage(dpy, &image_formats[0], 64, 64, &image));
              if (image.image_id != VA_INVALID_ID) {
                record_status("vaDeriveImage", vaDeriveImage(dpy, surfaces[0], &image));
                record_status("vaDestroyImage", vaDestroyImage(dpy, image.image_id));
              }
            }
            free(image_formats);
          }
        }

        VAContextID context = VA_INVALID_ID;
        st = vaCreateContext(dpy, config, 64, 64, VA_PROGRESSIVE, surfaces, 4, &context);
        record_status("vaCreateContext", st);
        if (st == VA_STATUS_SUCCESS) {
          unsigned char payload[256] = {0};
          VABufferID buffer = VA_INVALID_ID;
          st = vaCreateBuffer(dpy, context, VAEncMiscParameterBufferType,
                              sizeof(payload), 1, payload, &buffer);
          record_status("vaCreateBuffer", st);
          st = vaBeginPicture(dpy, context, surfaces[0]);
          record_status("vaBeginPicture", st);
          if (buffer != VA_INVALID_ID)
            record_status("vaRenderPicture", vaRenderPicture(dpy, context, &buffer, 1));
          record_status("vaEndPicture", vaEndPicture(dpy, context));
          record_status("vaSyncSurface", vaSyncSurface(dpy, surfaces[0]));
          if (buffer != VA_INVALID_ID)
            record_status("vaDestroyBuffer", vaDestroyBuffer(dpy, buffer));
          record_status("vaDestroyContext", vaDestroyContext(dpy, context));
        }
        record_status("vaDestroySurfaces", vaDestroySurfaces(dpy, surfaces, 4));
      }
      record_status("vaDestroyConfig", vaDestroyConfig(dpy, config));
    }
  }

done:
  free(profiles);
  free(entries);
  free(attrs);
  record_status("vaTerminate", vaTerminate(dpy));
  fprintf(stderr, "%s: VA %d.%d, calls=%u successes=%u\n",
          name, major, minor, calls, successes);
}

static void exercise_drm(void) {
  glob_t nodes = {0};
  if (glob("/dev/dri/renderD*", 0, NULL, &nodes) != 0) {
    globfree(&nodes);
    return;
  }

  for (size_t i = 0; i < nodes.gl_pathc; ++i) {
    const char *path = nodes.gl_pathv[i];
    int fd = open(path, O_RDWR | O_CLOEXEC);
    if (fd < 0) continue;

    drmVersionPtr version = drmGetVersion(fd);
    if (getenv("LIBVA_PGO_VERBOSE") && version)
      fprintf(stderr, "DRM node %s: driver=%.*s\n", path,
              version->name_len, version->name ? version->name : "unknown");
    if (version) drmFreeVersion(version);

    char label[128];
    snprintf(label, sizeof(label), "DRM display %s", path);
    exercise_display(vaGetDisplayDRM(fd), label);
    close(fd);
  }
  globfree(&nodes);
}

static void exercise_x11(void) {
  const char *display = getenv("DISPLAY");
  if (!display) return;
  Display *xdpy = XOpenDisplay(display);
  if (!xdpy) return;
  exercise_display(vaGetDisplay(xdpy), "X11 display");
  XCloseDisplay(xdpy);
}

static void exercise_wayland(void) {
  if (!getenv("WAYLAND_DISPLAY")) return;
  struct wl_display *wdpy = wl_display_connect(NULL);
  if (!wdpy) return;
  exercise_display(vaGetDisplayWl(wdpy), "Wayland display");
  wl_display_disconnect(wdpy);
}

int main(void) {
  exercise_invalid_api();
  exercise_drm();
  exercise_x11();
  exercise_wayland();
  fprintf(stderr, "VA workload complete: calls=%u successes=%u\n", calls, successes);
  return 0;
}
EOF
}

_find_install_libdir() {
  local _root="$1"
  find "${_root}/usr" -type f -name 'libva.so.2.*' -printf '%h\n' -quit
}

_build_workload() {
  local _install="$1"
  local _output="$2"
  local _compile_extra="${3:-}"
  local _link_extra="${4:-}"
  local _libdir
  _libdir="$(_find_install_libdir "${_install}")"
  [[ -n "${_libdir}" ]] || { error "libva.so.2 was not found under ${_install}"; return 1; }
  local -a _cflags _ldflags _dep_cflags _dep_libs _libs=(-lva -ldl)
  local _lib _work_cflags="${CFLAGS}" _work_ldflags="${LDFLAGS}"

  if [[ "${LIBVA_BOLT_USE_BFD:-1}" == 1 ]]; then
    _work_cflags="$(_strip_bfd_compile_flags "$_work_cflags")"
  fi
  _work_ldflags="$(_sanitize_link_flags "$_work_ldflags" "${LIBVA_BOLT_USE_BFD:-1}")"
  read -r -a _cflags <<< "${_work_cflags} ${_compile_extra}"
  read -r -a _ldflags <<< "${_work_ldflags} ${_TOOLCHAIN_LINK_FLAGS:-} ${_link_extra}"
  read -r -a _dep_cflags <<< "$(pkg-config --cflags libdrm x11 wayland-client)"
  read -r -a _dep_libs <<< "$(pkg-config --libs libdrm x11 wayland-client)"
  for _lib in libva-drm libva-x11 libva-glx libva-wayland; do
    [[ -e "${_libdir}/${_lib}.so" ]] && _libs+=("-l${_lib#lib}")
  done

  "${CC}" "${_cflags[@]}" "${_dep_cflags[@]}" -pthread \
    -I"${_install}/usr/include" \
    "${srcdir}/libva-pgo-workload.c" \
    "${_ldflags[@]}" -L"${_libdir}" -Wl,-rpath,"${_libdir}" \
    "${_libs[@]}" "${_dep_libs[@]}" -o "${_output}"
}

_run_vainfo() {
  local _libpath="$1"
  local _logdir="$2"
  local _node _driver _status _index=0
  [[ -x "$(command -v vainfo 2>/dev/null || true)" ]] || return 0
  mkdir -p "${_logdir}"

  _run_vainfo_one() {
    local _label="$1"
    shift
    local _log="${_logdir}/${_index}-${_label}.log"
    _index=$((_index + 1))
    if timeout 30s env LD_LIBRARY_PATH="${_libpath}" \
      LIBVA_DRIVERS_PATH=/usr/lib/dri "$@" >"${_log}" 2>&1; then
      _status=0
    else
      _status=$?
    fi
    case "${_status}" in
      0)
        ;;
      124|125|126|127|128|129|130|131|132|133|134|135|136|137|138|139|140|141|142|143|144|145|146|147|148|149|150|151|152|153|154|155|156|157|158|159|160|161|162|163|164|165|166|167|168|169|170|171|172|173|174|175|176|177|178|179|180|181|182|183|184|185|186|187|188|189|190|191|192|193|194|195|196|197|198|199|200|201|202|203|204|205|206|207|208|209|210|211|212|213|214|215|216|217|218|219|220|221|222|223|224|225|226|227|228|229|230|231|232|233|234|235|236|237|238|239|240|241|242|243|244|245|246|247|248|249|250|251|252|253|254|255)
        warning "vainfo ${_label} terminated with status ${_status}; see ${_log}"
        return 1
        ;;
      *)
        # A normal vainfo error (no display, missing driver, permissions,
        # unsupported display backend) is expected on build hosts without a
        # usable VA device. Signal/timeout failures are not expected and are
        # fatal during BOLT validation.
        ;;
    esac
    return 0
  }

  local -a _nodes=()
  while IFS= read -r -d '' _node; do
    _nodes+=("$_node")
  done < <(find /dev/dri -maxdepth 1 -type c -name 'renderD*' -print0 2>/dev/null)

  # Test automatic selection and the Vega/RadeonSI path explicitly on every
  # render node. Do not assume renderD128 is the active GPU.
  for _node in "${_nodes[@]}"; do
    for _driver in '' radeonsi; do
      local -a _env=(env)
      [[ -n "$_driver" ]] && _env+=(LIBVA_DRIVER_NAME="$_driver")
      _run_vainfo_one "drm-${_node##*/}-${_driver:-auto}" \
        "${_env[@]}" vainfo --display drm --device "$_node" || return 1
    done
  done

  if [[ -n "${DISPLAY:-}" ]]; then
    for _driver in '' radeonsi; do
      local -a _env=(env)
      [[ -n "$_driver" ]] && _env+=(LIBVA_DRIVER_NAME="$_driver")
      _run_vainfo_one "x11-${_driver:-auto}" \
        "${_env[@]}" vainfo --display x11 || return 1
      _run_vainfo_one "x11-dri2-${_driver:-auto}" \
        "${_env[@]}" LIBVA_DRI3_DISABLE=1 vainfo --display x11 || return 1
    done
  fi

  if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    for _driver in '' radeonsi; do
      local -a _env=(env)
      [[ -n "$_driver" ]] && _env+=(LIBVA_DRIVER_NAME="$_driver")
      _run_vainfo_one "wayland-${_driver:-auto}" \
        "${_env[@]}" vainfo --display wayland || return 1
    done
  fi
}

_run_workload() {
  local _install="$1"
  local _profile_dir="$2"
  local _run_name="$3"
  local _runtime_prefix="${4:-}"
  local _workdir="${srcdir}/libva-workload-${_run_name}"
  local _harness="${_workdir}/va-workload"
  local _install_libdir="$(_find_install_libdir "${_install}")"
  [[ -n "${_install_libdir}" ]] || { error "libva installation has no libva.so.2: ${_install}"; return 1; }
  [[ -n "${_runtime_prefix}" ]] || _runtime_prefix="${_install_libdir}"
  local _libpath="${_runtime_prefix}:${_install_libdir}"
  local _logdir="${_workdir}/logs"

  rm -rf "${_workdir}"
  mkdir -p "${_logdir}"
  _build_workload "${_install}" "${_harness}" "${5:-}" "${6:-}" || return 1

  local -a _env=(LD_LIBRARY_PATH="${_libpath}" LIBVA_DRIVERS_PATH=/usr/lib/dri)
  if [[ -n "${_profile_dir}" ]]; then
    mkdir -p "${_profile_dir}"
    _env+=(LLVM_PROFILE_FILE="${_profile_dir}/%m-%p.profraw")
  else
    unset LLVM_PROFILE_FILE
  fi

  local _driver _dri3 _level _status _run_index=0 _successful=0
  local _log
  local _fatal=0
  local -a _run_env

  # Repeat the complete public-API matrix for automatic driver selection and
  # explicit RadeonSI. DRI3-disabled passes exercise the older X11/DRI2 path,
  # while the normal passes exercise DRI3. Every process status is checked;
  # the former unconditional `|| true` hid SIGILL/SIGSEGV from BOLT output.
  for _driver in '' radeonsi; do
    for _dri3 in 0 1; do
      _run_env=("${_env[@]}")
      [[ -n "$_driver" ]] && _run_env+=(LIBVA_DRIVER_NAME="$_driver")
      [[ "$_dri3" == 1 ]] && _run_env+=(LIBVA_DRI3_DISABLE=1)
      for _level in 0 1 2; do
        _log="${_logdir}/${_run_index}-driver-${_driver:-auto}-dri3-${_dri3}-level-${_level}.log"
        _run_index=$((_run_index + 1))
        if env "${_run_env[@]}" LIBVA_MESSAGING_LEVEL="$_level" \
          LIBVA_PGO_VERBOSE=0 timeout 60s "${_harness}" >"${_log}" 2>&1; then
          _status=0
        else
          _status=$?
        fi
        if (( _status == 0 )); then
          _successful=$((_successful + 1))
        else
          warning "VA workload ${_run_name} failed with status ${_status}; see ${_log}"
          _fatal=1
        fi
      done
      _log="${_logdir}/${_run_index}-driver-${_driver:-auto}-dri3-${_dri3}-verbose.log"
      _run_index=$((_run_index + 1))
      if env "${_run_env[@]}" LIBVA_MESSAGING_LEVEL=1 \
        LIBVA_PGO_VERBOSE=1 timeout 60s "${_harness}" >"${_log}" 2>&1; then
        _status=0
      else
        _status=$?
      fi
      if (( _status == 0 )); then
        _successful=$((_successful + 1))
      else
        warning "Verbose VA workload ${_run_name} failed with status ${_status}; see ${_log}"
        _fatal=1
      fi
    done
  done

  _run_vainfo "${_libpath}" "${_workdir}/vainfo" || _fatal=1

  (( _successful > 0 )) || {
    error "VA workload ${_run_name} produced no successful harness run"
    return 1
  }
  (( _fatal == 0 )) || {
    error "VA workload ${_run_name} had fatal process failures; BOLT result is invalid"
    return 1
  }
}

_bolt_optimize_libs() {
  local _install="$1"
  local _profile_dir="${srcdir}/libva-bolt-fdata"
  local _out_dir="${srcdir}/libva-bolt-output"
  local _bolt="$LLVM_BOLT" _merge="$MERGE_FDATA"
  local _libdir="$(_find_install_libdir "${_install}")"
  [[ -n "${_libdir}" ]] || { error "final libva installation has no shared library"; return 1; }
  local _librel="${_libdir#${_install}/usr/}"
  local _inst_dir="${srcdir}/libva-bolt-instrumented/usr/${_librel}"
  local -a _libs=() _fdata=()
  local _so _base _merged _out _backup _file
  local _kept=0 _skipped=0

  [[ -x "$_bolt" && -x "$_merge" ]] || {
    error 'llvm-bolt and merge-fdata are required from llvm-ultimate'
    return 1
  }

  while IFS= read -r -d '' _so; do
    _libs+=("$_so")
  done < <(find "$_libdir" -maxdepth 1 -type f -name 'libva*.so*' -print0 | sort -z)
  (( ${#_libs[@]} > 0 )) || { error 'no libva shared libraries found for BOLT'; return 1; }
  msg2 "BOLT candidates: ${#_libs[@]} real libva ELF files"

  rm -rf "${srcdir}/libva-bolt-fdata" "${srcdir}/libva-bolt-instrumented" \
    "${srcdir}/libva-bolt-output"
  mkdir -p "${_profile_dir}" "${_inst_dir}" "${_out_dir}"

  # Preserve all SONAME symlinks in the loader-first instrumentation tree.
  for _file in "${_libdir}"/libva*.so*; do
    [[ -L "$_file" ]] || continue
    cp -a "$_file" "${_inst_dir}/"
  done

  local _help
  _help="$("$_bolt" --help 2>&1; "$_bolt" --help-hidden 2>&1)"
  local -a _inst_flags=(--instrument)
  grep -q -- '--lite' <<<"$_help" && _inst_flags+=(--lite=false)
  grep -q -- '--conservative-instrumentation' <<<"$_help" && \
    _inst_flags+=(--conservative-instrumentation)

  for _so in "${_libs[@]}"; do
    _base="$(basename "$_so")"

    # libva.so contains two real implementations of vaCreateSurfaces with
    # different ELF symbol versions. LLD flattens the version suffix in the
    # regular symbol table, and LLVM BOLT rejects that representation with
    # "global symbol vaCreateSurfaces is not unique". The default final build
    # therefore uses GNU ld.bfd (with active Clang) and BOLT can process the
    # core library too. If LIBVA_BOLT_USE_BFD=0 is explicitly requested, keep
    # the PGO/CS-PGO optimized core library and BOLT the backend DSOs instead.
    if [[ "${_base}" == libva.so.* && "${LIBVA_BOLT_USE_BFD:-1}" != 1 ]]; then
      warning "Skipping BOLT instrumentation for ${_base}: LLD versioned-symbol aliases are not uniquely representable to BOLT"
      cp -a "${_so}" "${_inst_dir}/${_base}"
      # Count this library once in the profile/optimization pass below.
      continue
    fi

    "$_bolt" "$_so" "${_inst_flags[@]}" \
      --instrumentation-file="${_profile_dir}/${_base}.fdata" \
      --instrumentation-file-append-pid \
      -o "${_inst_dir}/${_base}" || {
        warning "BOLT instrumentation failed for ${_base}"
        cp -a "${_so}" "${_inst_dir}/${_base}"
        # Count this library once in the profile/optimization pass below.
      }
  done

  _run_workload "${_install}" "${_profile_dir}" bolt-profile "${_inst_dir}" '' '' || {
    error 'BOLT instrumentation workload failed; refusing to optimize unvalidated binaries'
    return 1
  }

  local -a _bolt_opts=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions
    --split-all-cold
    --dyno-stats
    --update-debug-sections)
  grep -q -- '--icf' <<<"$_help" && _bolt_opts+=(--icf=safe)
  grep -q -- '--jump-tables' <<<"$_help" && _bolt_opts+=(--jump-tables=move)
  grep -q -- '--peepholes' <<<"$_help" && _bolt_opts+=(--peepholes=all)
  grep -q -- '--indirect-call-promotion' <<<"$_help" && \
    _bolt_opts+=(--indirect-call-promotion=all)
  grep -q -- '--use-gnu-stack' <<<"$_help" && _bolt_opts+=(--use-gnu-stack)
  # Shared libraries with display-driver entry points can expose a BOLT
  # rewrite bug only when an aggressive image is executed. Use a measured
  # candidate ladder: retain all validated optimizations first, then remove
  # only one suspected feature at a time (ICP, ICF, jump-table movement,
  # peepholes, then splitting), and finally use the minimal safe transformation.
  # This is not a blind workaround: every candidate is profile-guided, executed,
  # and accepted only after the complete workload passes.
  local -a _nosplit_bolt_opts=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --dyno-stats
    --update-debug-sections)
  grep -q -- '--icf' <<<"$_help" && _nosplit_bolt_opts+=(--icf=safe)
  grep -q -- '--jump-tables' <<<"$_help" && _nosplit_bolt_opts+=(--jump-tables=move)
  grep -q -- '--peepholes' <<<"$_help" && _nosplit_bolt_opts+=(--peepholes=all)
  grep -q -- '--indirect-call-promotion' <<<"$_help" && \
    _nosplit_bolt_opts+=(--indirect-call-promotion=all)
  grep -q -- '--use-gnu-stack' <<<"$_help" && _nosplit_bolt_opts+=(--use-gnu-stack)

  local -a _no_icf_bolt_opts=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions
    --split-all-cold
    --dyno-stats
    --update-debug-sections
    --jump-tables=move
    --peepholes=all
    --indirect-call-promotion=all)
  local -a _no_jumptables_bolt_opts=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions
    --split-all-cold
    --dyno-stats
    --update-debug-sections
    --icf=safe
    --peepholes=all
    --indirect-call-promotion=all)
  local -a _no_peepholes_bolt_opts=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions
    --split-all-cold
    --dyno-stats
    --update-debug-sections
    --icf=safe
    --jump-tables=move
    --indirect-call-promotion=all)
  local -a _no_icp_bolt_opts=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --split-functions
    --split-all-cold
    --dyno-stats
    --update-debug-sections
    --icf=safe
    --jump-tables=move
    --peepholes=all)
  local -a _safe_bolt_opts=(
    --reorder-blocks=ext-tsp
    --reorder-functions=cdsort
    --dyno-stats
    --update-debug-sections)

  for _so in "${_libs[@]}"; do
    _base="$(basename "$_so")"
    _fdata=()
    while IFS= read -r -d '' _file; do
      [[ -s "$_file" ]] && _fdata+=("$_file")
    done < <(find "${_profile_dir}" -maxdepth 1 -type f \
      -name "${_base}.fdata*" -print0)
    if (( ${#_fdata[@]} == 0 )); then
      _skipped=$((_skipped + 1))
      continue
    fi

    _merged="${_out_dir}/${_base}.merged.fdata"
    "$_merge" "${_fdata[@]}" >"$_merged" || {
      warning "BOLT profile merge failed for ${_base}"
      _skipped=$((_skipped + 1))
      continue
    }
    [[ -s "$_merged" ]] || { _skipped=$((_skipped + 1)); continue; }

    _backup="${_out_dir}/${_base}.original"
    cp -a "$_so" "$_backup"
    local _validated=0 _mode _candidate _validation_name
    local -a _candidate_opts=()
    for _mode in full no-icp no-icf no-jumptables no-peepholes nosplit safe; do
      case "${_mode}" in
        full)
          _candidate="${_out_dir}/${_base}.bolt"
          _validation_name="bolt-validate-${_base}-full"
          _candidate_opts=("${_bolt_opts[@]}")
          ;;
        no-icp)
          _candidate="${_out_dir}/${_base}.no-icp.bolt"
          _validation_name="bolt-validate-${_base}-no-icp"
          _candidate_opts=("${_no_icp_bolt_opts[@]}")
          ;;
        no-icf)
          _candidate="${_out_dir}/${_base}.no-icf.bolt"
          _validation_name="bolt-validate-${_base}-no-icf"
          _candidate_opts=("${_no_icf_bolt_opts[@]}")
          ;;
        no-jumptables)
          _candidate="${_out_dir}/${_base}.no-jumptables.bolt"
          _validation_name="bolt-validate-${_base}-no-jumptables"
          _candidate_opts=("${_no_jumptables_bolt_opts[@]}")
          ;;
        no-peepholes)
          _candidate="${_out_dir}/${_base}.no-peepholes.bolt"
          _validation_name="bolt-validate-${_base}-no-peepholes"
          _candidate_opts=("${_no_peepholes_bolt_opts[@]}")
          ;;
        nosplit)
          _candidate="${_out_dir}/${_base}.nosplit.bolt"
          _validation_name="bolt-validate-${_base}-nosplit"
          _candidate_opts=("${_nosplit_bolt_opts[@]}")
          ;;
        safe)
          _candidate="${_out_dir}/${_base}.safe.bolt"
          _validation_name="bolt-validate-${_base}-safe"
          _candidate_opts=("${_safe_bolt_opts[@]}")
          ;;
      esac

      if ! "$_bolt" "$_so" --data="$_merged" "${_candidate_opts[@]}" -o "$_candidate"; then
        warning "BOLT ${_mode} optimization failed for ${_base}; trying next candidate"
        continue
      fi

      install -m755 "$_candidate" "$_so"
      if _run_workload "${_install}" '' "${_validation_name}" "${_libdir}" '' ''; then
        _validated=1
        msg2 "BOLT ${_mode} profile validated for ${_base}"
        break
      fi

      warning "BOLT ${_mode} validation failed for ${_base}; restoring original before retry"
      install -m755 "$_backup" "$_so"
    done

    if (( _validated )); then
      _kept=$((_kept + 1))
    else
      warning "No validated BOLT image for ${_base}; keeping original"
      install -m755 "$_backup" "$_so"
      _skipped=$((_skipped + 1))
    fi
  done

  rm -rf "${srcdir}/libva-bolt-fdata" "${srcdir}/libva-bolt-instrumented" \
    "${srcdir}/libva-bolt-output"
  msg2 "BOLT result: ${_kept} validated, ${_skipped} skipped/rolled back"
  (( _kept > 0 )) || { error 'BOLT produced no validated libva backend library'; return 1; }
}

build() {
  _setup_llvm
  _write_workload

  # The active llvm-ultimate is allowed to evolve independently of package
  # recipes. Probe every -mllvm option instead of allowing one stale internal
  # LLVM switch to make Meson fail its compiler sanity check. All other
  # compiler flags, including -fgnuc-version, are preserved exactly.
  CFLAGS="$(_filter_clang_flags "${CFLAGS:-}")"
  CXXFLAGS="$(_filter_clang_flags "${CXXFLAGS:-${CFLAGS}}")"
  export CFLAGS="${CFLAGS} -DENABLE_VA_MESSAGING"
  export CXXFLAGS="${CXXFLAGS}"
  if [[ "${LIBVA_BOLT_USE_BFD:-1}" == 1 ]]; then
    command -v ld.bfd >/dev/null 2>&1 || {
      error 'LIBVA_BOLT_USE_BFD=1 requires GNU ld.bfd for BOLT-compatible symbol versioning'
      return 1
    }
    export _TOOLCHAIN_LINK_FLAGS='-fuse-ld=bfd'
    msg2 'Final/link stages use active Clang with GNU ld.bfd so BOLT can process libva symbol versions'
  else
    export _TOOLCHAIN_LINK_FLAGS='-fuse-ld=lld'
  fi

  local _pgo_dir="${srcdir}/libva-pgo-raw"
  local _cs_dir="${srcdir}/libva-cs-pgo-raw"
  local _pgo_profdata="${srcdir}/libva-standard.profdata"
  local _merged_profdata="${srcdir}/libva-merged.profdata"
  local _pgo_install="${srcdir}/libva-pgo-install"
  local _cs_install="${srcdir}/libva-cs-install"
  local _final_install="${srcdir}/libva-final-install"
  local _pgo_flags="-fprofile-generate=${_pgo_dir} -fprofile-update=atomic"
  local _pgo_link="-fprofile-generate=${_pgo_dir}"
  local _cs_flags="-fprofile-use=${_pgo_profdata} -fcs-profile-generate=${_cs_dir} -fprofile-update=atomic"
  local _cs_link="-fprofile-use=${_pgo_profdata} -fcs-profile-generate=${_cs_dir}"

  rm -rf "${_pgo_dir}" "${_cs_dir}" "${_pgo_profdata}" "${_merged_profdata}" \
    "${_pgo_install}" "${_cs_install}" "${_final_install}" \
    "${srcdir}/libva-workload-"*

  msg 'Stage 1/6: IR-PGO instrumentation build'
  _meson_setup "${srcdir}/build-pgo" "${_pgo_flags}" "${_pgo_link}"
  meson compile -C "${srcdir}/build-pgo" --jobs "${LIBVA_JOBS:-$(nproc)}"
  DESTDIR="${_pgo_install}" meson install -C "${srcdir}/build-pgo" --no-rebuild

  msg 'Stage 2/6: representative libva API/driver workload'
  _run_workload "${_pgo_install}" "${_pgo_dir}" pgo-standard '' "${_pgo_flags}" "${_pgo_link}"
  local -a _raw=()
  _collect_profraw "${_pgo_dir}" _raw
  "${LLVM_PROFDATA}" merge --sparse -o "${_pgo_profdata}" "${_raw[@]}"

  msg 'Stage 3/6: CS-PGO instrumentation build'
  _meson_setup "${srcdir}/build-cs-pgo" "${_cs_flags}" "${_cs_link}"
  meson compile -C "${srcdir}/build-cs-pgo" --jobs "${LIBVA_JOBS:-$(nproc)}"
  DESTDIR="${_cs_install}" meson install -C "${srcdir}/build-cs-pgo" --no-rebuild

  msg 'Stage 4/6: identical workload for CS-PGO'
  _run_workload "${_cs_install}" "${_cs_dir}" pgo-cs '' "${_cs_flags}" "${_cs_link}"
  local -a _cs_raw=()
  _collect_profraw "${_cs_dir}" _cs_raw
  "${LLVM_PROFDATA}" merge --sparse -o "${_merged_profdata}" \
    "${_pgo_profdata}" "${_cs_raw[@]}"

  msg 'Stage 5/6: final PGO/CS-PGO build with BOLT relocations'
  _meson_setup "${srcdir}/build-final" "-fprofile-use=${_merged_profdata}" \
    "-fprofile-use=${_merged_profdata} -Wl,--emit-relocs"
  meson compile -C "${srcdir}/build-final" --jobs "${LIBVA_JOBS:-$(nproc)}"
  DESTDIR="${_final_install}" meson install -C "${srcdir}/build-final" --no-rebuild

  msg 'Stage 6/6: LLVM BOLT instrumentation, optimization and validation'
  _bolt_optimize_libs "${_final_install}"
}

check() {
  # libva v2.24.1 has no in-tree Meson test suite; the public API workload is
  # run during every profile/BOLT stage and again here without instrumentation.
  _setup_llvm
  [[ -x "${srcdir}/libva-final-install/usr/lib/libva.so.2" ]] || \
    error 'final libva installation is missing libva.so.2'
}

_verify_sonames() {
  local _base _real _actual
  local _libdir="$(_find_install_libdir "${pkgdir}")"
  [[ -n "${_libdir}" ]] || { error 'packaged libva library directory is missing'; return 1; }
  for _base in libva libva-drm libva-glx libva-wayland libva-x11; do
    _real="$(find "${_libdir}" -maxdepth 1 -type f \
      -name "${_base}.so.2.*" -print -quit)"
    [[ -n "${_real}" ]] || {
      error "missing expected ${_base}.so.2 library"
      return 1
    }
    _actual="$("${READELF}" -d "${_real}" 2>/dev/null \
      | sed -n 's/.*SONAME.*\[\(.*\)\].*/\1/p' | head -n1)"
    [[ "${_actual}" == "${_base}.so.2" ]] || {
      error "${_base}: expected SONAME ${_base}.so.2, got ${_actual:-<none>}"
      return 1
    }
  done
}

package() {
  _setup_llvm || return 1
  cp -a "${srcdir}/libva-final-install/." "${pkgdir}/"
  _verify_sonames

  install -Dm644 "${srcdir}/libva/COPYING" \
    -t "${pkgdir}/usr/share/licenses/${pkgname}"
  install -Dm644 /dev/stdin "${pkgdir}/etc/libva.conf" <<'EOF'
LIBVA_MESSAGING_LEVEL=1
EOF
}
