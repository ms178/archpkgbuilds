# Contributor: oliver < a t > first . in-berlin . de
# Contributor: 2ion <dev@2ion.de>

_pkgname=cpdf
pkgname=${_pkgname}
pkgver=2.9
pkgrel=3
pkgdesc='Coherent PDF command line tools - manipulate PDF files including merge, encrypt, decrypt, scale, crop, rotate, bookmarks, stamp, logos, page numbers'
arch=('x86_64')
url='https://www.coherentpdf.com/'
license=('AGPL-3.0-or-later')
depends=('glibc' "camlpdf>=${pkgver}")
makedepends=('ocaml' 'ocaml-findlib' 'clang' 'lld' 'llvm')
# OCaml bytecode must not be stripped, and OCamlMakefile is not parallel-safe
options=('!strip' 'staticlibs' '!makeflags')
source=("${_pkgname}-source-${pkgver}.tar.gz::https://github.com/johnwhitington/${_pkgname}-source/archive/v${pkgver}.tar.gz")
sha256sums=('944e2e578fc9653ccf09df4cf0c0b60beb3fb702ddd5b76640624d7324ae3cdb')

prepare() {
  cd "${srcdir}/${_pkgname}-source-${pkgver}"

  # Cleanup leftover fake_destdir from buggy 2.9-2 PKGBUILDs
  # (may be root-owned, then warn)
  if [[ -d "${srcdir}/fake_destdir" ]]; then
    rm -rf "${srcdir}/fake_destdir" 2>/dev/null || \
      echo "warning: ${srcdir}/fake_destdir not removable – run: sudo rm -rf ${srcdir}/fake_destdir" >&2
  fi

  # Make the upstream Makefile respect Arch/CachyOS build flags.
  sed -i \
    -e 's/^CFLAGS *=.*/CFLAGS ?= -fPIC/' \
    -e 's/^OCAMLFLAGS *=.*/OCAMLFLAGS ?= -bin-annot/' \
    -e 's/^OCAMLNCFLAGS *=.*/OCAMLNCFLAGS ?= -safe-string/' \
    -e 's/^OCAMLBCFLAGS *=.*/OCAMLBCFLAGS ?= -safe-string/' \
    -e 's/^OCAMLLDFLAGS *=.*/OCAMLLDFLAGS ?= /' \
    Makefile
}

build() {
  cd "${srcdir}/${_pkgname}-source-${pkgver}"

  # --- LLVM / Clang toolchain (CachyOS default) ---
  export CC=${CC:-clang}
  export CXX=${CXX:-clang++}

  if command -v ld.lld >/dev/null 2>&1; then
    export LDFLAGS="$LDFLAGS -fuse-ld=lld"
  fi

  local ocaml_ldflags="-cc ${CC}"
  [[ -n "${OCAMLLDFLAGS:-}" ]] && ocaml_ldflags+=" ${OCAMLLDFLAGS}"

  # Clean ocamlfind environment – prevents $srcdir/fake_destdir leak
  # which caused $pkgdir/tmp to be packaged in 2.9-2
  unset OCAMLFIND_DESTDIR OCAMLFIND_CONF OCAMLFIND_LDCONF OCAMLPATH

  make -j1 \
    CC="${CC}" \
    CXX="${CXX}" \
    CFLAGS="${CFLAGS} -fPIC" \
    CXXFLAGS="${CXXFLAGS} -fPIC" \
    LDFLAGS="${LDFLAGS}" \
    OCAMLFLAGS="-bin-annot" \
    OCAMLNCFLAGS="-safe-string" \
    OCAMLBCFLAGS="-safe-string" \
    OCAMLLDFLAGS="${ocaml_ldflags}" \
    OCAMLNLDFLAGS="${ocaml_ldflags}" \
    OCAMLBLDFLAGS="${ocaml_ldflags}"
}

package() {
  cd "${srcdir}/${_pkgname}-source-${pkgver}"

  export CC=${CC:-clang}
  export CXX=${CXX:-clang++}
  if command -v ld.lld >/dev/null 2>&1; then
    export LDFLAGS="$LDFLAGS -fuse-ld=lld"
  fi
  local ocaml_ldflags="-cc ${CC}"
  [[ -n "${OCAMLLDFLAGS:-}" ]] && ocaml_ldflags+=" ${OCAMLLDFLAGS}"

  # Clean ocamlfind environment – crucial!
  # If OCAMLFIND_DESTDIR is left set, `ocamlfind printconf destdir`
  # returns /tmp/…/fake_destdir → $pkgdir/tmp gets created → pacman warns
  unset OCAMLFIND_DESTDIR OCAMLFIND_CONF OCAMLFIND_LDCONF OCAMLPATH

  local _ocamlfind_destdir="${pkgdir}$(ocamlfind printconf destdir)"
  install -dm755 "${_ocamlfind_destdir}"

  OCAMLFIND_DESTDIR="${_ocamlfind_destdir}" \
    make install \
      CC="${CC}" CXX="${CXX}" \
      CFLAGS="${CFLAGS} -fPIC" \
      CXXFLAGS="${CXXFLAGS} -fPIC" \
      LDFLAGS="${LDFLAGS}" \
      OCAMLFLAGS="-bin-annot" \
      OCAMLNCFLAGS="-safe-string" \
      OCAMLBCFLAGS="-safe-string" \
      OCAMLLDFLAGS="${ocaml_ldflags}" \
      OCAMLNLDFLAGS="${ocaml_ldflags}" \
      OCAMLBLDFLAGS="${ocaml_ldflags}" \
      PREFIX=/usr

  # Sanitize OCaml META files – strip staged /tmp paths
  if [[ -d "${pkgdir}/usr/lib/ocaml" ]]; then
    find "${pkgdir}/usr/lib/ocaml" -name META -print0 | while IFS= read -r -d '' meta; do
      sed -i -e "s|${pkgdir}||g" -e "s|${srcdir}||g" "$meta" || true
      sed -i '/^directory=/d' "$meta" || true
    done
  fi

  # Hard fail if /tmp leaked into $pkgdir – prevents broken packages
  if [[ -e "${pkgdir}/tmp" ]]; then
    echo "ERROR: ${pkgdir}/tmp exists – OCAMLFIND_DESTDIR leak!" >&2
    find "${pkgdir}/tmp" -ls >&2 || true
    exit 1
  fi
  rm -rf "${pkgdir}/var/tmp" 2>/dev/null || true

  install -Dm755 cpdf "${pkgdir}/usr/bin/cpdf"
  install -Dm644 cpdf.1 "${pkgdir}/usr/share/man/man1/cpdf.1"
  sed -i "s|cpdfmanual.pdf|/usr/share/doc/${_pkgname}/cpdfmanual.pdf|g" \
    "${pkgdir}/usr/share/man/man1/cpdf.1"
  install -Dm644 cpdfmanual.pdf "${pkgdir}/usr/share/doc/${_pkgname}/cpdfmanual.pdf"
  install -Dm644 LICENSE.md "${pkgdir}/usr/share/licenses/${_pkgname}/LICENSE.md"
}
