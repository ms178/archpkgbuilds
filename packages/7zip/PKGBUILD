pkgname=7zip
pkgver=26.02
pkgrel=3.1
pkgdesc='File archiver for extremely high compression (Optimized for CachyOS with PGO+CS-PGO)'
arch=(x86_64 aarch64)
url='https://www.7-zip.org'
license=('LGPL-2.1-or-later' 'LicenseRef-UnRAR' 'BSD-3-Clause' 'BSD-2-Clause')
depends=(gcc-libs glibc)
makedepends=(clang llvm uasm git)
provides=(p7zip)
conflicts=(p7zip)
replaces=(p7zip)
source=("7zip::git+https://github.com/ip7z/7zip.git#tag=$pkgver")
sha512sums=('SKIP')

_get_platform_flags() {
  case $CARCH in
    x86_64)  printf '%s\n' PLATFORM=x64 IS_X64=1 MY_ASM=uasm USE_ASM=1 ;;
    i686)    printf '%s\n' PLATFORM=x86 IS_X86=1 MY_ASM=uasm USE_ASM=1 ;;
    aarch64) printf '%s\n' PLATFORM=arm64 IS_ARM64=1 USE_ASM=1 ;;
  esac
}

_build_components() {
  local stage_flags="$1"
  local -a platform_flags=()
  mapfile -t platform_flags < <(_get_platform_flags)

  # Mandatory defines for the 7-zip Linux port
  local z7_defs="-D_REENTRANT -D_FILE_OFFSET_BITS=64 -D_LARGEFILE_SOURCE -fPIC"

  # We override BASE variables to kill internal -O2 and respect CachyOS flags.
  # LDFLAGS_STATIC is used so the Makefile can still add -shared for shared objects.
  for component in Bundles/{Alone,Alone7z,Format7zF,SFXCon} UI/Console; do
    msg2 "Building component: ${component}..."
    make -C "CPP/7zip/${component}" -f "../../cmpl_clang.mak" -j$(nproc) \
      "${platform_flags[@]}" \
      CC="clang" \
      CXX="clang++" \
      CFLAGS_BASE="${CFLAGS} ${z7_defs} ${stage_flags} -c" \
      CXXFLAGS_BASE="${CXXFLAGS} ${z7_defs} ${stage_flags} -c" \
      CFLAGS_WARN_WALL="" \
      CFLAGS_WARN="" \
      LDFLAGS_STATIC="${LDFLAGS} ${stage_flags}" \
      LFLAGS_STRIP=""
  done
}

_clean_components() {
  for component in Bundles/{Alone,Alone7z,Format7zF,SFXCon} UI/Console; do
    rm -rf "CPP/7zip/${component}/b"
  done
}

_find_artifact() {
  local artifact="$1"
  local path
  path=$(find CPP/7zip -type f -path "*/b/*/${artifact}" | head -n 1)
  if [[ -z "${path}" ]]; then
    error "Could not locate built artifact: ${artifact}"
    return 1
  fi
  printf '%s\n' "${path}"
}

generate_training_data() {
  local train_dir="$1/training"
  msg2 "Generating comprehensive training data..."
  rm -rf "${train_dir}" && mkdir -p "${train_dir}"/{text,bin,small}
  for i in {1..25}; do
    { seq 1 10000; yes "CachyOS-Performance-PGO-Data-${i}" | head -n 2000;
      [[ -f /etc/protocols ]] && cat /etc/protocols; } > "${train_dir}/text/data_${i}.txt"
  done
  for i in {1..8}; do
    dd if=/dev/urandom of="${train_dir}/bin/rand_${i}.bin" bs=1M count=$((i * 2)) status=none
  done
  for i in {1..400}; do echo "file_${i}" > "${train_dir}/small/${i}.tmp"; done
}

run_training_workload() {
  local train_dir="$1/training"
  local work_dir="$1/work"
  local sevenza sevenzr sevenz
  sevenza=$(_find_artifact 7za) || return 1
  sevenzr=$(_find_artifact 7zr) || return 1
  sevenz=$(_find_artifact 7z) || return 1

  msg2 "Executing PGO training workload..."
  rm -rf "${work_dir}" && mkdir -p "${work_dir}/out"

  # Archive creation using all major algorithms
  "${sevenza}" a -bd -mx=5 "${work_dir}/a.7z" "${train_dir}/text" >/dev/null
  "${sevenzr}" a -bd -mx=9 "${work_dir}/b.7z" "${train_dir}/bin" >/dev/null
  "${sevenza}" a -bd -p"cachyos" -mhe=on "${work_dir}/s.7z" "${train_dir}" >/dev/null

  # Update and Format coverage
  "${sevenza}" u -bd "${work_dir}/a.7z" "${train_dir}/small" >/dev/null
  "${sevenza}" a -bd -tzip "${work_dir}/t.zip" "${train_dir}/text" >/dev/null

  # Validation paths (Test, List, Extract)
  "${sevenza}" t -bd "${work_dir}/s.7z" -p"cachyos" >/dev/null
  "${sevenz}" l -bd -slt "${work_dir}/a.7z" >/dev/null
  "${sevenza}" x -bd "${work_dir}/s.7z" -p"cachyos" -o"${work_dir}/out" >/dev/null
  rm -rf "${work_dir}"
}

build() {
  cd 7zip
  local pgo_dir="${srcdir}/pgo-data"
  local merged_profdata="${pgo_dir}/merged.profdata"
  mkdir -p "${pgo_dir}/"{std,cs}
  generate_training_data "${pgo_dir}"

  msg "Phase 1: Standard PGO instrumentation..."
  _clean_components
  _build_components "-fprofile-generate=${pgo_dir}/std"
  LLVM_PROFILE_FILE="${pgo_dir}/std/7z-%p.profraw" run_training_workload "${pgo_dir}"
  llvm-profdata merge -output="${pgo_dir}/std.profdata" "${pgo_dir}/std"/*.profraw

  msg "Phase 2: Context-Sensitive PGO (CS-PGO)..."
  _clean_components
  _build_components "-fprofile-use=${pgo_dir}/std.profdata -fcs-profile-generate=${pgo_dir}/cs"
  LLVM_PROFILE_FILE="${pgo_dir}/cs/7z-%p.profraw" run_training_workload "${pgo_dir}"
  llvm-profdata merge -output="${merged_profdata}" "${pgo_dir}/cs"/*.profraw "${pgo_dir}/std.profdata"

  msg "Phase 3: Final Optimized Build..."
  _clean_components
  _build_components "-fprofile-use=${merged_profdata}"
}

package() {
  cd 7zip
  local bin_7za bin_7zr bin_7zso bin_7z bin_7zcon

  bin_7za="$(_find_artifact 7za)" || return 1
  bin_7zr="$(_find_artifact 7zr)" || return 1
  bin_7zso="$(_find_artifact 7z.so)" || return 1
  bin_7z="$(_find_artifact 7z)" || return 1
  bin_7zcon="$(_find_artifact 7zCon)" || return 1

  install -Dt "$pkgdir/usr/lib/7zip" \
    "${bin_7za}" \
    "${bin_7zr}" \
    "${bin_7zso}" \
    "${bin_7z}"
  install -D "${bin_7zcon}" "$pkgdir/usr/lib/7zip/7zCon.sfx"

  local prog
  for prog in 7za 7zr 7z; do
    printf '#!/bin/sh\nexec /usr/lib/7zip/%s "$@"\n' "$prog" \
      | install -D /dev/stdin "$pkgdir/usr/bin/$prog"
  done

  install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" DOC/{,unRar}License.txt
}
