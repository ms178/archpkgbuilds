pkgname=7zip
pkgver=26.01
pkgrel=2.2
pkgdesc='File archiver for extremely high compression'
arch=(x86_64 aarch64)
url='https://www.7-zip.org'
license=('LGPL-2.1-or-later AND LicenseRef-UnRAR AND BSD-3-Clause AND BSD-2-Clause')
depends=(
  sh
  libgcc
  libstdc++
  glibc
)
makedepends=(
  clang
  llvm
)
makedepends_x86_64=(uasm)
provides=(p7zip)
conflicts=(p7zip)
replaces=(p7zip)
source=(https://7-zip.org/a/7z${pkgver//./}-src.tar.xz)
sha512sums=('fd5e6228020e1e3cc51f85b917e61c5583d307ff23b182a42de9faf7f1dda09c70fd228072e82074e81e43639c6ea7045ebd38fb90f437efc5ebff9c5323fcf9')
b2sums=('3bbe07755814a8760cfb99a0b7200d7fba5dae9704b144bc84e9f571a938c9225775d880a971190a0b2f643434ccb96865552167b65b818086ad69f4925a17fd')

_get_platform_flags() {
  case $CARCH in
    x86_64)
      printf '%s\n' PLATFORM=x64 IS_X64=1 MY_ASM=uasm USE_ASM=1
      ;;
    i686)
      printf '%s\n' PLATFORM=x86 IS_X86=1 MY_ASM=uasm USE_ASM=1
      ;;
    aarch64)
      printf '%s\n' PLATFORM=arm64 IS_ARM64=1 USE_ASM=1
      ;;
  esac
}

_clean_components() {
  local component
  for component in Bundles/{Alone,Alone7z,Format7zF,SFXCon} UI/Console; do
    rm -rf "CPP/7zip/${component}/b"
  done
}

_build_components() {
  local stage_cflags="$1"
  local stage_cxxflags="$2"
  local stage_ldflags="$3"
  local stage_makefile='../../cmpl_clang.mak'
  local -a platform_flags=()
  local component

  mapfile -t platform_flags < <(_get_platform_flags)

  for component in Bundles/{Alone,Alone7z,Format7zF,SFXCon} UI/Console; do
    make -C "CPP/7zip/${component}" -f "${stage_makefile}" "${platform_flags[@]}" \
      LFLAGS_STRIP= \
      CC="clang ${CPPFLAGS} ${stage_cflags} ${stage_ldflags}" \
      CXX="clang++ ${CPPFLAGS} ${stage_cxxflags} ${stage_ldflags}"
  done
}

_find_artifact() {
  local artifact="$1"
  local path

  path=$(find CPP/7zip -type f -path "*/b/*/${artifact}" | head -n 1)
  if [[ -z "${path}" ]]; then
    error "Could not locate built artifact: ${artifact}"
    return 1
  fi

  printf '%s\n' "${path}"
}

generate_training_data() {
  local pgo_dir="$1"
  local train_dir="${pgo_dir}/training"

  rm -rf "${train_dir}"
  mkdir -p "${train_dir}"/{text,bin,mixed}

  local i
  for i in {1..40}; do
    {
      seq 1 25000
      yes "log-pattern-${i}" | head -n 12000
      printf 'module=%02d status=ok\n' "${i}"
      head -c 262144 /dev/zero | tr '\0' 'A'
    } > "${train_dir}/text/corpus_${i}.txt"
  done

  for i in {1..10}; do
    dd if=/dev/urandom of="${train_dir}/bin/random_${i}.bin" bs=1M count=$((i * 2)) status=none
  done

  tar -C "${train_dir}" -cf "${train_dir}/mixed/docs.tar" text
}

run_training_workload() {
  local pgo_dir="$1"
  local work_dir="${pgo_dir}/work"
  local train_dir="${pgo_dir}/training"
  local sevenza
  local sevenzr
  local sevenz

  sevenza="$(_find_artifact 7za)" || return 1
  sevenzr="$(_find_artifact 7zr)" || return 1
  sevenz="$(_find_artifact 7z)" || return 1

  rm -rf "${work_dir}"
  mkdir -p "${work_dir}"/{a,b,c}

  # 7za: broad format exercise and update paths.
  "${sevenza}" a -bd -bso0 -bsp0 -mx=1 "${work_dir}/a/l1.7z" "${train_dir}/text"/* "${train_dir}/bin"/*
  "${sevenza}" a -bd -bso0 -bsp0 -mx=9 "${work_dir}/a/l9.7z" "${train_dir}/text"/* "${train_dir}/bin"/*
  "${sevenza}" a -bd -bso0 -bsp0 -tzip -mx=5 "${work_dir}/a/mixed.zip" "${train_dir}/mixed/docs.tar"
  "${sevenza}" t -bd -bso0 -bsp0 "${work_dir}/a/l1.7z"
  "${sevenza}" t -bd -bso0 -bsp0 "${work_dir}/a/l9.7z"
  "${sevenza}" x -bd -bso0 -bsp0 -y "${work_dir}/a/l9.7z" -o"${work_dir}/b"

  # 7zr: strict 7z path with high and low compression settings.
  "${sevenzr}" a -bd -bso0 -bsp0 -mx=0 "${work_dir}/c/fast.7z" "${train_dir}/text"/*
  "${sevenzr}" a -bd -bso0 -bsp0 -mx=9 "${work_dir}/c/max.7z" "${train_dir}/text"/* "${train_dir}/mixed/docs.tar"
  "${sevenzr}" t -bd -bso0 -bsp0 "${work_dir}/c/max.7z"
  "${sevenzr}" x -bd -bso0 -bsp0 -y "${work_dir}/c/max.7z" -o"${work_dir}/a/extract"

  # 7z: plugin-backed code path; keep non-fatal in case plugin lookup differs in-tree.
  if [[ -x "${sevenz}" ]]; then
    "${sevenz}" l -bd -bso0 -bsp0 "${work_dir}/a/l1.7z" >/dev/null || true
    "${sevenz}" t -bd -bso0 -bsp0 "${work_dir}/a/l1.7z" >/dev/null || true
  fi

  rm -rf "${work_dir}"
}

build() {
  local pgo_dir="${srcdir}/pgo-data"
  local std_profile_dir="${pgo_dir}/standard"
  local cs_profile_dir="${pgo_dir}/cs"
  local standard_profdata="${pgo_dir}/standard.profdata"
  local merged_profdata="${pgo_dir}/merged.profdata"

  local orig_cflags="${CFLAGS}"
  local orig_cxxflags="${CXXFLAGS}"
  local orig_ldflags="${LDFLAGS}"

  rm -rf "${pgo_dir}"
  mkdir -p "${std_profile_dir}" "${cs_profile_dir}"

  generate_training_data "${pgo_dir}"

  msg2 'Phase 1: Building with standard PGO instrumentation...'
  _clean_components
  _build_components \
    "${orig_cflags} -fprofile-generate=${std_profile_dir}" \
    "${orig_cxxflags} -fprofile-generate=${std_profile_dir}" \
    "${orig_ldflags} -fprofile-generate=${std_profile_dir}"

  msg2 'Phase 1: Running standard PGO training workload...'
  LLVM_PROFILE_FILE="${std_profile_dir}/7zip-%p-%m.profraw" run_training_workload "${pgo_dir}"

  msg2 'Phase 1: Merging standard PGO profiles...'
  llvm-profdata merge -output="${standard_profdata}" "${std_profile_dir}"/*.profraw

  msg2 'Phase 2: Building with CS-PGO instrumentation...'
  _clean_components
  _build_components \
    "${orig_cflags} -fprofile-use=${standard_profdata} -fprofile-correction -fcs-profile-generate=${cs_profile_dir}" \
    "${orig_cxxflags} -fprofile-use=${standard_profdata} -fprofile-correction -fcs-profile-generate=${cs_profile_dir}" \
    "${orig_ldflags} -fprofile-use=${standard_profdata} -fcs-profile-generate=${cs_profile_dir}"

  msg2 'Phase 2: Running CS-PGO training workload...'
  LLVM_PROFILE_FILE="${cs_profile_dir}/7zip-%p-%m.profraw" run_training_workload "${pgo_dir}"

  msg2 'Phase 2: Merging CS-PGO and standard profiles...'
  llvm-profdata merge -output="${merged_profdata}" "${cs_profile_dir}"/*.profraw "${standard_profdata}"

  msg2 'Phase 3: Final optimized build with merged profile data...'
  _clean_components
  _build_components \
    "${orig_cflags} -fprofile-use=${merged_profdata}" \
    "${orig_cxxflags} -fprofile-use=${merged_profdata}" \
    "${orig_ldflags} -fprofile-use=${merged_profdata}"
}

package() {
  local bin_7za
  local bin_7zr
  local bin_7zso
  local bin_7z
  local bin_7zcon

  bin_7za="$(_find_artifact 7za)" || return 1
  bin_7zr="$(_find_artifact 7zr)" || return 1
  bin_7zso="$(_find_artifact 7z.so)" || return 1
  bin_7z="$(_find_artifact 7z)" || return 1
  bin_7zcon="$(_find_artifact 7zCon)" || return 1

  install -Dt "$pkgdir/usr/lib/7zip" \
    "${bin_7za}" \
    "${bin_7zr}" \
    "${bin_7zso}" \
    "${bin_7z}"
  install -D "${bin_7zcon}" "$pkgdir/usr/lib/7zip/7zCon.sfx"

  local _prog
  for _prog in 7za 7zr 7z; do
    printf '#!/bin/sh\nexec /usr/lib/7zip/%s "$@"\n' "$_prog" \
      | install -D /dev/stdin "$pkgdir/usr/bin/$_prog"
  done

  install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" DOC/{,unRar}License.txt
}

