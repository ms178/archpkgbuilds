pkgbase=opus
pkgname=(
  opus
)
pkgver=1.6.1
pkgrel=4.1
pkgdesc="Totally open, royalty-free, highly versatile audio codec"
url="https://www.opus-codec.org/"
arch=(x86_64)
license=(BSD-3-Clause)
depends=(
  glibc
)
makedepends=(
  clang
  doxygen
  lld
  llvm
  meson
)
source=("https://downloads.xiph.org/releases/opus/opus-$pkgver.tar.gz")
b2sums=('5ba1d6f28594f366b545507bafb22751e15a0e78e152e7cdef456dccb0bc9fc512faa18c90fb4ea5455a9535de89df987dea8a0fabce9a25c285d0c410d4b482')

# https://downloads.xiph.org/releases/opus/SHA256SUMS.txt
sha256sums=('b84610959b8d417b611aa12a22565e0a3732097c6389d19098d844543e340f85')

_setup_llvm_toolchain() {
  export CC=clang
  export CXX=clang++
  export AR=llvm-ar
  export NM=llvm-nm
  export RANLIB=llvm-ranlib
  export STRIP=llvm-strip
}

_meson_array_from_flags() {
  local flags="$1"
  local -a arr
  local out='['
  local f

  read -r -a arr <<< "$flags"
  for f in "${arr[@]}"; do
    f=${f//\\/\\\\}
    f=${f//\'/\'"\'"\'}
    out+="'${f}',"
  done

  out=${out%,}
  out+=']'
  printf '%s\n' "$out"
}

_merge_profraw_dir() {
  local out="$1"
  local dir="$2"
  local -a files chunk parts
  local idx=0 chunk_idx=0
  local tmpdir="${dir}/.merge_tmp"

  rm -rf "$tmpdir"
  mkdir -p "$tmpdir"

  shopt -s nullglob
  files=("$dir"/*.profraw)
  shopt -u nullglob
  (( ${#files[@]} > 0 )) || return 1

  while (( idx < ${#files[@]} )); do
    chunk=("${files[@]:idx:400}")
    llvm-profdata merge -sparse -output="${tmpdir}/part-${chunk_idx}.profdata" "${chunk[@]}"
    (( idx += 400, chunk_idx++ ))
  done

  shopt -s nullglob
  parts=("${tmpdir}"/*.profdata)
  shopt -u nullglob
  (( ${#parts[@]} > 0 )) || return 1

  llvm-profdata merge -sparse -output="$out" "${parts[@]}"
}

_configure_stage() {
  local builddir="$1"
  local extra_cflags="$2"
  local extra_cxxflags="$3"
  local extra_ldflags="$4"

  local c_args cpp_args c_link_args cpp_link_args
  c_args="$(_meson_array_from_flags "${_base_cflags} ${extra_cflags}")"
  cpp_args="$(_meson_array_from_flags "${_base_cxxflags} ${extra_cxxflags}")"
  c_link_args="$(_meson_array_from_flags "${_base_ldflags} ${extra_ldflags}")"
  cpp_link_args="$(_meson_array_from_flags "${_base_ldflags} ${extra_ldflags}")"

  local meson_options=(
    -D asm=disabled
    -D docs=disabled
    -D custom-modes=true
    -D deep-plc=enabled
    -D dred=enabled
    -D osce=enabled
    -D b_ndebug=true
    -D b_pie=false
    -D c_std=gnu18
    -D cpp_std=gnu++2a
    -D c_args="${c_args}"
    -D cpp_args="${cpp_args}"
    -D c_link_args="${c_link_args}"
    -D cpp_link_args="${cpp_link_args}"
  )

  rm -rf "$builddir"
  arch-meson opus "$builddir" "${meson_options[@]}" \
    --buildtype=release \
    --wrap-mode=nofallback

  meson compile -C "$builddir"
}

_find_demo_bin() {
  local builddir="$1"
  local cand
  for cand in \
    "${builddir}/tests/opus_demo" \
    "${builddir}/src/opus_demo" \
    "${builddir}/tools/opus_demo"
  do
    [[ -x "$cand" ]] && { printf '%s\n' "$cand"; return 0; }
  done
  return 1
}

_run_opus_workload() {
  local builddir="$1"
  local work="${srcdir}/opus-pgo-work"
  local opus_demo
  opus_demo="$(_find_demo_bin "$builddir" 2>/dev/null || true)"

  [[ -n "$opus_demo" ]] || return 0

  mkdir -p "$work"

  local pcm="${work}/sample48k_s16le.raw"
  local enc="${work}/sample.opus"
  local dec="${work}/decoded.raw"

  # Deterministic stereo PCM corpus, 48 kHz, 16-bit LE, ~6s.
  python - "$pcm" <<'PY'
import math, struct, sys
out = open(sys.argv[1], "wb")
sr = 48000
dur = 6
for n in range(sr * dur):
    l = int(20000 * math.sin(2 * math.pi * 440 * n / sr))
    r = int(16000 * math.sin(2 * math.pi * 880 * n / sr))
    out.write(struct.pack("<hh", l, r))
out.close()
PY

  local iter
  for iter in {1..24}; do
    "$opus_demo" -e audio 48000 2 128000 "$pcm" "$enc" >/dev/null 2>&1 || true
    "$opus_demo" -e voip 48000 2 64000 "$pcm" "$enc" >/dev/null 2>&1 || true
    "$opus_demo" -e restricted-lowdelay 48000 2 96000 "$pcm" "$enc" >/dev/null 2>&1 || true
    "$opus_demo" -d 48000 2 "$enc" "$dec" >/dev/null 2>&1 || true
  done

  rm -rf "$work"
}

_run_profile_training() {
  local builddir="$1"
  local profdir="$2"
  local label="$3"

  mkdir -p "$profdir"
  rm -f "${profdir}"/*.profraw

  # LLVM PGO best practice for high-parallel workloads:
  # %m enables runtime in-place merge and avoids file-count explosions.
  export LLVM_PROFILE_FILE="${profdir}/default_%m.profraw"
  export LLVM_PROFILE_MERGE_POOL_SIZE=16

  echo "==> ${label}: meson tests (parallel)"
  meson test -C "$builddir" --no-rebuild -j"$(nproc)" --print-errorlogs >/dev/null 2>&1 || true

  echo "==> ${label}: meson tests (serial)"
  meson test -C "$builddir" --no-rebuild -j1 --print-errorlogs >/dev/null 2>&1 || true

  echo "==> ${label}: opus workload"
  _run_opus_workload "$builddir"
  _run_opus_workload "$builddir"

  unset LLVM_PROFILE_FILE LLVM_PROFILE_MERGE_POOL_SIZE
}

prepare() {
  ln -sfn "opus-$pkgver" opus
  cd opus
}

build() {
  _setup_llvm_toolchain

  local build_std="build-pgo-gen"
  local build_cs="build-cspgo-gen"
  local build_opt="build-opt"

  local pgo_dir="${srcdir}/pgo"
  local std_raw="${pgo_dir}/standard"
  local cs_raw="${pgo_dir}/cs"
  local std_prof="${pgo_dir}/standard.profdata"
  local cs_prof="${pgo_dir}/cs.profdata"
  local merged_prof="${pgo_dir}/merged.profdata"

  _base_cflags="${CFLAGS}"
  _base_cxxflags="${CXXFLAGS}"
  _base_ldflags="${LDFLAGS}"

  local pgo_common_flags="-fprofile-update=atomic -mllvm -enable-value-profiling"
  local std_vp_flags="${pgo_common_flags} -mllvm -vp-counters-per-site=16"
  local cs_vp_flags="${pgo_common_flags} -mllvm -vp-counters-per-site=32"
  local profile_warn_flags="-Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled"

  rm -rf "$build_std" "$build_cs" "$build_opt" "$pgo_dir"
  mkdir -p "$std_raw" "$cs_raw"

  echo "=========================================================================="
  echo " Stage 1/3: Standard IR-PGO instrumentation"
  echo "=========================================================================="
  _configure_stage \
    "$build_std" \
    "-fprofile-generate=${std_raw} ${std_vp_flags}" \
    "-fprofile-generate=${std_raw} ${std_vp_flags}" \
    "-fprofile-generate=${std_raw} -fprofile-update=atomic"

  _run_profile_training "$build_std" "$std_raw" "Stage 1"

  _merge_profraw_dir "$std_prof" "$std_raw" || {
    echo "ERROR: failed to create standard profile data" >&2
    return 1
  }

  echo "=========================================================================="
  echo " Stage 2/3: Context-sensitive PGO instrumentation"
  echo "=========================================================================="
  _configure_stage \
    "$build_cs" \
    "-fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw} ${cs_vp_flags} ${profile_warn_flags}" \
    "-fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw} ${cs_vp_flags} ${profile_warn_flags}" \
    "-fprofile-use=${std_prof} -fcs-profile-generate=${cs_raw} -fprofile-update=atomic"

  _run_profile_training "$build_cs" "$cs_raw" "Stage 2"

  _merge_profraw_dir "$cs_prof" "$cs_raw" || {
    echo "ERROR: failed to create context-sensitive profile data" >&2
    return 1
  }

  llvm-profdata merge -sparse -output="$merged_prof" "$std_prof" "$cs_prof"
  [[ -s "$merged_prof" ]] || {
    echo "ERROR: failed to create merged profile data" >&2
    return 1
  }

  echo "=========================================================================="
  echo " Stage 3/3: Final PGO-optimized build"
  echo "=========================================================================="
  _configure_stage \
    "$build_opt" \
    "-fprofile-use=${merged_prof} ${profile_warn_flags}" \
    "-fprofile-use=${merged_prof} ${profile_warn_flags}" \
    "-fprofile-use=${merged_prof}"
}

# check() {
#   meson test -C build-opt --print-errorlogs
# }

package_opus() {
  provides=(libopus.so)

  meson install -C build-opt --destdir "$pkgdir"
  install -Dt "$pkgdir/usr/share/aclocal" -m644 opus/opus.m4
  install -Dt "$pkgdir/usr/share/licenses/$pkgname" -m644 opus/COPYING
}

