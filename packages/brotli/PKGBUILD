pkgbase=brotli
pkgname=('brotli' 'python-brotli')
pkgver=1.2.0
pkgrel=4.3
pkgdesc='Generic-purpose lossless compression algorithm'
url='https://github.com/google/brotli'
arch=('x86_64')
license=('MIT')
makedepends=(
  git
  cmake
  ninja
  python-setuptools
  python-build
  python-installer
  python-wheel
  python-pkgconfig
  clang
  llvm
  llvm-libs
)
source=("${pkgbase}::git+${url}#tag=v${pkgver}")
sha512sums=('SKIP')

# Purely instrumentation-related LLVM flags — nothing else is added by the PKGBUILD
_pgo_instrument_flags=(-mllvm -vp-counters-per-site=10
                       -mllvm -runtime-counter-relocation
                       -mllvm -enable-value-profiling)

pkgver() {
  cd "${pkgbase}"
  git describe --tags --match 'v*' | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  mkdir -p "$srcdir/pgo-profiles/standard" "$srcdir/pgo-profiles/context-sensitive"

  cat > "$srcdir/training_workload.cpp" << 'WORKLOAD_EOF'
#include <brotli/decode.h>
#include <brotli/encode.h>
#include <vector>
#include <string>
#include <iostream>
#include <cstring>
#include <random>
#include <algorithm>
#include <cstdint>

static std::vector<uint8_t> generate_data(size_t size, int pattern) {
  std::vector<uint8_t> data(size);
  std::mt19937 gen(42);
  switch (pattern % 4) {
    case 0: { // Random bytes
      std::uniform_int_distribution<int> dis(0, 255);
      for (size_t i = 0; i < size; ++i)
        data[i] = static_cast<uint8_t>(dis(gen));
      break;
    }
    case 1: { // Text-like
      const char* words[] = {"the ", "quick ", "brown ", "fox ", "jumps ",
                             "over ", "lazy ", "dog ", "\n", ", ", ". "};
      std::uniform_int_distribution<int> dis(0, 10);
      size_t pos = 0;
      while (pos < size) {
        const char* w = words[dis(gen)];
        size_t wlen = strlen(w);
        for (size_t i = 0; i < wlen && pos < size; ++i)
          data[pos++] = static_cast<uint8_t>(w[i]);
      }
      break;
    }
    case 2: { // Binary with repeated runs
      std::uniform_int_distribution<int> val_dis(0, 255);
      std::uniform_int_distribution<int> len_dis(4, 128);
      size_t pos = 0;
      while (pos < size) {
        uint8_t v = static_cast<uint8_t>(val_dis(gen));
        size_t len = std::min(static_cast<size_t>(len_dis(gen)), size - pos);
        std::fill_n(data.begin() + pos, len, v);
        pos += len;
      }
      break;
    }
    case 3: { // HTML-like
      const char* tags[] = {"<div>", "</div>", "<p>", "</p>", "<span>",
                            "</span>", "<a href=\"", "\">", "</a>", "<b>",
                            "</b>", "Hello ", "World ", "test ", "content ",
                            "data ", " "};
      std::uniform_int_distribution<int> dis(0, 16);
      size_t pos = 0;
      while (pos < size) {
        const char* w = tags[dis(gen)];
        size_t wlen = strlen(w);
        for (size_t i = 0; i < wlen && pos < size; ++i)
          data[pos++] = static_cast<uint8_t>(w[i]);
      }
      break;
    }
  }
  return data;
}

static bool compress_streaming(const std::vector<uint8_t>& input,
                               std::vector<uint8_t>& output,
                               int quality, int mode, int lgwin) {
  BrotliEncoderState* state = BrotliEncoderCreateInstance(nullptr, nullptr, nullptr);
  if (!state) return false;
  BrotliEncoderSetParameter(state, BROTLI_PARAM_QUALITY, quality);
  BrotliEncoderSetParameter(state, BROTLI_PARAM_MODE, mode);
  BrotliEncoderSetParameter(state, BROTLI_PARAM_LGWIN, lgwin);

  output.resize(BrotliEncoderMaxCompressedSize(input.size()));
  size_t available_in = input.size();
  const uint8_t* next_in = input.data();
  size_t available_out = output.size();
  uint8_t* next_out = output.data();

  BROTLI_BOOL ok = BrotliEncoderCompressStream(
      state, BROTLI_OPERATION_FINISH,
      &available_in, &next_in,
      &available_out, &next_out, nullptr);

  // Drain: a single FINISH call does not guarantee all output is produced
  int safety = 1024;
  while (ok && !BrotliEncoderIsFinished(state) && safety-- > 0) {
    ok = BrotliEncoderCompressStream(
        state, BROTLI_OPERATION_FINISH,
        &available_in, &next_in,
        &available_out, &next_out, nullptr);
  }

  BrotliEncoderDestroyInstance(state);
  if (!ok || !BrotliEncoderIsFinished(state)) return false;
  output.resize(output.size() - available_out);
  return true;
}

static bool compress_oneshot(const std::vector<uint8_t>& input,
                             std::vector<uint8_t>& output,
                             int quality, int mode, int lgwin) {
  output.resize(BrotliEncoderMaxCompressedSize(input.size()));
  size_t out_size = output.size();
  BROTLI_BOOL ok = BrotliEncoderCompress(
      quality, lgwin, static_cast<BrotliEncoderMode>(mode),
      input.size(), input.data(), &out_size, output.data());
  if (ok) output.resize(out_size);
  return ok == BROTLI_TRUE;
}

static bool decompress_streaming(const std::vector<uint8_t>& input,
                                 std::vector<uint8_t>& output,
                                 size_t expected_size) {
  BrotliDecoderState* state = BrotliDecoderCreateInstance(nullptr, nullptr, nullptr);
  if (!state) return false;
  output.resize(expected_size);
  size_t available_in = input.size();
  const uint8_t* next_in = input.data();
  size_t available_out = output.size();
  uint8_t* next_out = output.data();

  BrotliDecoderResult result = BROTLI_DECODER_RESULT_NEEDS_MORE_INPUT;
  int safety = 1024;
  while (safety-- > 0) {
    result = BrotliDecoderDecompressStream(
        state, &available_in, &next_in,
        &available_out, &next_out, nullptr);
    if (result == BROTLI_DECODER_RESULT_SUCCESS ||
        result == BROTLI_DECODER_RESULT_ERROR) break;
  }

  bool ok = (result == BROTLI_DECODER_RESULT_SUCCESS) &&
            BrotliDecoderIsFinished(state);
  BrotliDecoderDestroyInstance(state);
  return ok;
}

static bool decompress_oneshot(const std::vector<uint8_t>& input,
                               std::vector<uint8_t>& output,
                               size_t expected_size) {
  output.resize(expected_size);
  size_t out_size = expected_size;
  BROTLI_BOOL ok = BrotliDecoderDecompress(
      input.size(), input.data(), &out_size, output.data());
  return ok == BROTLI_TRUE;
}

static bool roundtrip(const std::vector<uint8_t>& data,
                      int quality, int mode, int lgwin, bool use_oneshot) {
  std::vector<uint8_t> compressed, decompressed;
  bool ok;
  if (use_oneshot) {
    ok = compress_oneshot(data, compressed, quality, mode, lgwin);
    if (ok) ok = decompress_oneshot(compressed, decompressed, data.size());
  } else {
    ok = compress_streaming(data, compressed, quality, mode, lgwin);
    if (ok) ok = decompress_streaming(compressed, decompressed, data.size());
  }
  if (!ok) return false;
  if (decompressed.size() != data.size()) return false;
  return memcmp(data.data(), decompressed.data(), data.size()) == 0;
}

int main() {
  const size_t sizes[] = {256, 4096, 65536, 131072};
  const int qualities[] = {1, 6, 11};
  const int modes[] = {BROTLI_MODE_GENERIC, BROTLI_MODE_TEXT, BROTLI_MODE_FONT};
  const int lgwins[] = {10, 16, 22, 24};
  const int num_patterns = 4;

  int total = 0, passed = 0;

  for (int pat = 0; pat < num_patterns; ++pat) {
    for (size_t sz : sizes) {
      std::vector<uint8_t> data = generate_data(sz, pat);
      int iters = (sz <= 512) ? 8 : (sz <= 8192) ? 5 : (sz <= 65536) ? 3 : 2;

      for (int q : qualities) {
        if (q >= 11 && sz > 65536) continue;

        for (int m : modes) {
          int lgwin = lgwins[total % 4];

          for (int i = 0; i < iters; ++i) {
            bool ok = roundtrip(data, q, m, lgwin, i % 2 == 0);
            total++;
            if (ok) passed++;
          }
        }
      }
    }
  }

  // Edge cases
  {
    std::vector<uint8_t> empty;
    std::vector<uint8_t> comp, decomp;
    bool ok = compress_streaming(empty, comp, 5, BROTLI_MODE_GENERIC, 22);
    if (ok) ok = decompress_streaming(comp, decomp, 0);
    total++;
    if (ok) passed++;
  }
  {
    std::vector<uint8_t> one = {42};
    bool ok = roundtrip(one, 11, BROTLI_MODE_GENERIC, 22, true);
    total++;
    if (ok) passed++;
  }
  {
    std::vector<uint8_t> zeros(2048, 0);
    bool ok = roundtrip(zeros, 6, BROTLI_MODE_GENERIC, 22, false);
    total++;
    if (ok) passed++;
  }
  {
    std::vector<uint8_t> ff(2048, 0xFF);
    bool ok = roundtrip(ff, 6, BROTLI_MODE_GENERIC, 22, true);
    total++;
    if (ok) passed++;
  }

  std::cout << "Training complete: " << passed << "/" << total
            << " tests passed" << std::endl;
  return 0;
}
WORKLOAD_EOF
}

build() {
  cd "${pkgbase}"

  # ── Step 1: Standard PGO instrumentation build ──────────────────────────
  local instr_cflags="${CFLAGS}"
  for f in "${_pgo_instrument_flags[@]}"; do instr_cflags+=" $f"; done
  instr_cflags+=" -fprofile-generate=${srcdir}/pgo-profiles/standard"

  cmake -S . -B build-pgo-standard -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_SHARED_LIBS=ON \
    -DCMAKE_C_COMPILER=clang \
    -DCMAKE_CXX_COMPILER=clang++ \
    -DCMAKE_C_FLAGS="${instr_cflags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS}" \
    -DCMAKE_BUILD_TYPE=Release \
    -Wno-dev
  cmake --build build-pgo-standard

  # ── Step 2: Compile & run training workload (standard PGO) ──────────────
  local train_cxxflags="${CXXFLAGS}"
  for f in "${_pgo_instrument_flags[@]}"; do train_cxxflags+=" $f"; done
  train_cxxflags+=" -fprofile-generate=${srcdir}/pgo-profiles/standard"

  clang++ -std=c++20 \
    ${train_cxxflags} \
    -I"${srcdir}/${pkgbase}/c/include" \
    "${srcdir}/training_workload.cpp" \
    -o "${srcdir}/training_workload_standard" \
    -L"${srcdir}/${pkgbase}/build-pgo-standard" \
    -lbrotlienc -lbrotlidec -lbrotlicommon

  export LLVM_PROFILE_FILE="${srcdir}/pgo-profiles/standard/profile_%m.profraw"
  LD_LIBRARY_PATH="${srcdir}/${pkgbase}/build-pgo-standard" \
    "${srcdir}/training_workload_standard" || true
  unset LLVM_PROFILE_FILE

  # ── Step 3: Merge standard PGO profiles ─────────────────────────────────
  llvm-profdata merge --sparse -output="${srcdir}/pgo-profiles/standard.profdata" \
    "${srcdir}/pgo-profiles/standard/"*.profraw

  # ── Step 4: Context-sensitive PGO instrumentation build ─────────────────
  local cs_cflags="${CFLAGS}"
  for f in "${_pgo_instrument_flags[@]}"; do cs_cflags+=" $f"; done
  cs_cflags+=" -fprofile-use=${srcdir}/pgo-profiles/standard.profdata"
  cs_cflags+=" -fcs-profile-generate=${srcdir}/pgo-profiles/context-sensitive"

  cmake -S . -B build-pgo-cs -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_SHARED_LIBS=ON \
    -DCMAKE_C_COMPILER=clang \
    -DCMAKE_CXX_COMPILER=clang++ \
    -DCMAKE_C_FLAGS="${cs_cflags}" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS}" \
    -DCMAKE_BUILD_TYPE=Release \
    -Wno-dev
  cmake --build build-pgo-cs

  # ── Step 5: Compile & run training workload (context-sensitive PGO) ─────
  local cs_train_cxxflags="${CXXFLAGS}"
  for f in "${_pgo_instrument_flags[@]}"; do cs_train_cxxflags+=" $f"; done
  cs_train_cxxflags+=" -fcs-profile-generate=${srcdir}/pgo-profiles/context-sensitive"
  cs_train_cxxflags+=" -fprofile-use=${srcdir}/pgo-profiles/standard.profdata"

  clang++ -std=c++20 \
    ${cs_train_cxxflags} \
    -I"${srcdir}/${pkgbase}/c/include" \
    "${srcdir}/training_workload.cpp" \
    -o "${srcdir}/training_workload_cs" \
    -L"${srcdir}/${pkgbase}/build-pgo-cs" \
    -lbrotlienc -lbrotlidec -lbrotlicommon

  export LLVM_PROFILE_FILE="${srcdir}/pgo-profiles/context-sensitive/profile_%m.profraw"
  LD_LIBRARY_PATH="${srcdir}/${pkgbase}/build-pgo-cs" \
    "${srcdir}/training_workload_cs" || true
  unset LLVM_PROFILE_FILE

  # ── Step 6: Merge all PGO profiles ──────────────────────────────────────
  llvm-profdata merge --sparse -output="${srcdir}/pgo-profiles/combined.profdata" \
    "${srcdir}/pgo-profiles/standard.profdata" \
    "${srcdir}/pgo-profiles/context-sensitive/"*.profraw

  # ── Step 7: Final optimized build ───────────────────────────────────────
  cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_SHARED_LIBS=ON \
    -DCMAKE_C_COMPILER=clang \
    -DCMAKE_CXX_COMPILER=clang++ \
    -DCMAKE_C_FLAGS="${CFLAGS} -fprofile-use=${srcdir}/pgo-profiles/combined.profdata" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS}" \
    -DCMAKE_BUILD_TYPE=Release \
    -Wno-dev
  cmake --build build -v

  # ── Step 8: Python wheel ────────────────────────────────────────────────
  python -m build --wheel --no-isolation
}

check() {
  cd "${pkgbase}"
  local python_version
  python_version=$(python -c 'import sys; print("".join(map(str, sys.version_info[:2])))')
  PYTHONPATH="$PWD/bin/lib.linux-$CARCH-cpython-${python_version}" \
    python -m unittest discover python "*_test.py"
  cd build
  ctest --output-on-failure --stop-on-failure -j$(nproc)
}

package_brotli() {
  depends=('glibc')
  provides=(libbrotlicommon.so libbrotlidec.so libbrotlienc.so)

  cd "${pkgbase}"
  DESTDIR="$pkgdir" cmake --install build
  local man
  for man in docs/*.?; do
    install -Dm 644 "$man" "$pkgdir/usr/share/man/man${man##*.}/${man##*/}"
  done
  install -Dm 644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname"
}

package_python-brotli() {
  pkgdesc+=' - python library'
  depends=('python')

  cd "${pkgbase}"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm 644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname"
}
