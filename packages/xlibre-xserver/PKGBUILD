        '0e3738e099ee2b958df3e5a5adbdfcbd1150ad64645fdae70d74b50123c3f3d43f9f95f5e4bac82bf5c72b3deb978655b8c3177d37de0bd0a2a6e0e343863511'
        'd1e6621b8cc2c2fef249cd4e1984492183e276f29e6515ee10959fe2302cd4c8588f3c4a62a2fd9fb5743c1defa21cb97fc9bc35aa08b9b72314d2a7daa73f18'
        '101a65bfbabd882735edb61fcfa98004c96353cffea54b8b052f34504b28dbe0fd83a27a7a4ec93ff9c37f4313992a2b9467b5f2406fedd69aaa5aa6bb079c7a')

# Tool overrides are intentionally supported for using upstream LLVM 22.1.8 binaries:
#   CLANG=/path/to/clang LLVM_PROFDATA=/path/to/llvm-profdata LLVM_BOLT=/path/to/llvm-bolt makepkg
: "${CLANG:=clang}"
if [[ -z ${CLANGXX:-} ]]; then
  if [[ $CLANG == */* ]]; then
    CLANGXX="$(dirname "$CLANG")/clang++"
  else
    CLANGXX="clang++"
  fi
fi
: "${LLVM_PROFDATA:=llvm-profdata}"
: "${LLVM_BOLT:=llvm-bolt}"
: "${MERGE_FDATA:=merge-fdata}"

# High-fidelity instrumentation for better indirect-call/value profile coverage.
_extra_instr='-g3 -fno-omit-frame-pointer -Xclang -mllvm -Xclang -vp-counters-per-site=80 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling'

prepare() {
  rm -rf build-pgo build-cspgo build-final fakeinstall pgo-gen cspgo-gen bolt bolt_inst bolt_opt inst-pgo inst-cspgo

  cd "${_pkgsrc}"
  for srcfile in "${source[@]}"; do
    local s="${srcfile%%::*}"; s="${s##*/}"
    [[ $s = *.patch ]] || continue
    patch --forward --strip=1 < "${srcdir}/$s"
  done
}

_strip_problem_flags() {
  local in="$1"
  sed -E \
    -e 's/(^|[[:space:]])-f(no-)?plt([[:space:]]|$)/ /g' \
    -e 's/(^|[[:space:]])-f(profile|cs-profile)[^[:space:]]*//g' \
    -e 's/(^|[[:space:]])-W(no-)?profile[^[:space:]]*//g' \
    -e 's/[[:space:]]+/ /g' <<< "${in}"
}

_cc_supports() {
  local flags="$1"
  printf 'int main(void){return 0;}\n' | "${CLANG}" ${flags} -x c - -o /dev/null >/dev/null 2>&1
}

_ld_supports() {
  local flags="$1"
  printf 'int main(void){return 0;}\n' | "${CLANG}" ${flags} -x c - -o /dev/null >/dev/null 2>&1
}

_cpu_flags() {
  case "${CARCH:-$arch}" in
    x86_64)
      # i7-14700KF / Raptor Lake: no AVX-512, excellent AVX2/BMI2.  Keep this
      # explicit instead of -march=native for reproducibility on your target box.
      echo '-O3 -march=raptorlake -mtune=raptorlake -fno-semantic-interposition -fstrict-aliasing'
      ;;
    aarch64)
      echo '-O3 -fno-semantic-interposition -fstrict-aliasing'
      ;;
    *)
      echo '-O3 -fno-semantic-interposition -fstrict-aliasing'
      ;;
  esac
}

_lld_flags() {
  if _ld_supports '-fuse-ld=lld'; then
    echo '-fuse-ld=lld'
  else
    echo ''
  fi
}

_profile_stats() {
  local dir="$1"
  local count bytes
  count="$(find "$dir" -maxdepth 1 -type f -name '*.profraw' 2>/dev/null | wc -l)"
  bytes="$(find "$dir" -maxdepth 1 -type f -name '*.profraw' -printf '%s\n' 2>/dev/null | awk '{s+=$1} END{print s+0}')"
  echo "${count} ${bytes}"
}

_merge_profiles() {
  local raw_dir="$1" out_prof="$2" tag="$3"
  local count bytes
  read -r count bytes < <(_profile_stats "$raw_dir")
  echo "==> ${tag}: profraw files=${count}, bytes=${bytes}"
  find "$raw_dir" -maxdepth 1 -type f -name '*.profraw' -printf '%s %f\n' 2>/dev/null | sort -nr | head -12 | sed 's/^/    /' || true

  mapfile -t _raw < <(find "$raw_dir" -maxdepth 1 -type f -name '*.profraw' -size +256c | sort)
  (( ${#_raw[@]} > 0 )) || return 1
  "${LLVM_PROFDATA}" merge -o "$out_prof" "${_raw[@]}" || return 1
  "${LLVM_PROFDATA}" show "$out_prof" >/dev/null 2>&1
}

_meson_setup() {
  if command -v arch-meson >/dev/null 2>&1; then
    arch-meson "$@"
  else
    meson setup --prefix=/usr --libexecdir=lib "$@"
  fi
}

_meson_common_options=(
  -Dipv6=true -Dxvfb=true -Dxnest=false -Dxcsecurity=true -Dxorg=true
  -Dxephyr=false -Dglamor=true -Dudev=true -Ddtrace=false -Dseatd_libseat=false
  -Dsystemd_logind=true -Dsuid_wrapper=true -Dlibunwind=true
  -Dxkb_dir=/usr/share/X11/xkb -Dxkb_output_dir=/var/lib/xkb
  -Dwerror=false -Db_ndebug=true
  -Dc_std=gnu2x -Dcpp_std=gnu++2a --buildtype=release
)

_wait_display() {
  local d="$1"
  for _ in {1..80}; do
    DISPLAY="$d" xdpyinfo >/dev/null 2>&1 && return 0
    sleep 0.1
  done
  return 1
}

_run_x11_clients() {
  local d="$1" mode="$2"

  # Fast single-iteration profile corpus: one pass through representative
  # X11/GLAMOR/Xvfb request classes.  This keeps PGO/BOLT useful without
  # exploding makepkg wall time.
  DISPLAY="$d" xdpyinfo >/dev/null 2>&1 || true
  DISPLAY="$d" xrandr --query >/dev/null 2>&1 || true
  DISPLAY="$d" xprop -root >/dev/null 2>&1 || true
  DISPLAY="$d" xwininfo -root >/dev/null 2>&1 || true
  echo "pgo-${mode}" | DISPLAY="$d" xclip -selection clipboard >/dev/null 2>&1 || true
  DISPLAY="$d" xclip -o -selection clipboard >/dev/null 2>&1 || true
  DISPLAY="$d" glxinfo -B >/dev/null 2>&1 || true

  local perf_tests=(-rect10 -fillrect100 -copywinwin100 -copypixpix100 -putimage100 -getimage100 -text)
  local t
  for t in "${perf_tests[@]}"; do
    DISPLAY="$d" timeout -k 1 4 x11perf -time 1 "$t" >/dev/null 2>&1 || true
  done

  timeout -k 1 3 env DISPLAY="$d" glxgears >/dev/null 2>&1 || true
  timeout -k 1 4 env DISPLAY="$d" glmark2 -b build:duration=500 >/dev/null 2>&1 || true
}

_run_xserver_workload_xvfb() {
  local bindir="$1" mode="${2:-pgo}"
  local xvfb="$bindir/Xvfb"
  command -v xdpyinfo >/dev/null 2>&1 || return 0
  [[ -x "$xvfb" ]] || return 0

  local d=":93" srv
  "$xvfb" "$d" -screen 0 1280x720x24 -nolisten tcp >/dev/null 2>&1 &
  srv=$!

  if _wait_display "$d"; then
    echo "==> Fast training ${mode}: Xvfb ${d} 1280x720x24, single iteration"
    _run_x11_clients "$d" "$mode"
  fi

  kill "$srv" 2>/dev/null || true
  wait "$srv" 2>/dev/null || true
}

build() {
  local SAN_CFLAGS SAN_CXXFLAGS SAN_LDFLAGS CPU_FLAGS LD_FLAGS FINAL_LD_FLAGS
  SAN_CFLAGS="$(_strip_problem_flags "${CFLAGS:-}")"
  SAN_CXXFLAGS="$(_strip_problem_flags "${CXXFLAGS:-}")"
  SAN_LDFLAGS="$(_strip_problem_flags "${LDFLAGS:-}")"
  CPU_FLAGS="$(_cpu_flags)"
  LD_FLAGS="$(_lld_flags)"
  FINAL_LD_FLAGS="$LD_FLAGS -Wl,--emit-relocs"

  local gen_dir="$srcdir/pgo-gen"
  local cs_dir="$srcdir/cspgo-gen"
  mkdir -p "$gen_dir" "$cs_dir" "$srcdir"/{bolt,bolt_inst,bolt_opt,fakeinstall}

  local c_args_gen="$SAN_CFLAGS $CPU_FLAGS $_extra_instr -fprofile-generate=$gen_dir"
  local cxx_args_gen="$SAN_CXXFLAGS $CPU_FLAGS $_extra_instr -fprofile-generate=$gen_dir"
  local link_args_gen="$SAN_LDFLAGS $LD_FLAGS -fprofile-generate=$gen_dir"

  echo "==> PASS 1/3: IR PGO instrumented build"
  CFLAGS='' CXXFLAGS='' LDFLAGS='' CC="$CLANG" CXX="$CLANGXX" \
  _meson_setup "$_pkgsrc" "${_pkgsrc}/build-pgo" \
    "${_meson_common_options[@]}" -Db_pie=false -Db_lto=false \
    -Dc_args="$c_args_gen" -Dcpp_args="$cxx_args_gen" \
    -Dc_link_args="$link_args_gen" -Dcpp_link_args="$link_args_gen"

  meson compile -C "${_pkgsrc}/build-pgo"

  local inst_pgo="$srcdir/inst-pgo"
  DESTDIR="$inst_pgo" meson install -C "${_pkgsrc}/build-pgo"

  echo "==> PASS 1/3: IR PGO training"
  LLVM_PROFILE_FILE="$gen_dir/xorg-%m-%p.profraw" \
    _run_xserver_workload_xvfb "$inst_pgo/usr/bin" pgo

  local pgo_prof="$srcdir/xorg.profdata"
  if ! _merge_profiles "$gen_dir" "$pgo_prof" 'IR PGO'; then
    echo "==> PASS 1/3: no valid profiles; final build will continue without PGO"
    : > "$pgo_prof"
  fi

  local use_prof_args='' use_prof_link=''
  if [[ -s "$pgo_prof" ]]; then
    use_prof_args="-fprofile-use=$pgo_prof -Wno-profile-instr-unprofiled -Wno-profile-instr-out-of-date -Wno-backend-plugin"
    use_prof_link="-fprofile-use=$pgo_prof"
  fi

  local cs_prof="$srcdir/xorg-cs.profdata"
  if [[ -s "$pgo_prof" ]] && _cc_supports "-fprofile-use=$pgo_prof -fcs-profile-generate=$cs_dir"; then
    local c_args_cs="$SAN_CFLAGS $CPU_FLAGS $use_prof_args $_extra_instr -fcs-profile-generate=$cs_dir"
    local cxx_args_cs="$SAN_CXXFLAGS $CPU_FLAGS $use_prof_args $_extra_instr -fcs-profile-generate=$cs_dir"
    local link_args_cs="$SAN_LDFLAGS $LD_FLAGS $use_prof_link -fcs-profile-generate=$cs_dir"

    echo "==> PASS 2/3: Context-sensitive PGO instrumented build"
    CFLAGS='' CXXFLAGS='' LDFLAGS='' CC="$CLANG" CXX="$CLANGXX" \
    _meson_setup "$_pkgsrc" "${_pkgsrc}/build-cspgo" \
      "${_meson_common_options[@]}" -Db_pie=false -Db_lto=false \
      -Dc_args="$c_args_cs" -Dcpp_args="$cxx_args_cs" \
      -Dc_link_args="$link_args_cs" -Dcpp_link_args="$link_args_cs"

    meson compile -C "${_pkgsrc}/build-cspgo"

    local inst_cspgo="$srcdir/inst-cspgo"
    DESTDIR="$inst_cspgo" meson install -C "${_pkgsrc}/build-cspgo"

    echo "==> PASS 2/3: Context-sensitive PGO training"
    LLVM_PROFILE_FILE="$cs_dir/xorg-cs-%m-%p.profraw" \
      _run_xserver_workload_xvfb "$inst_cspgo/usr/bin" cspgo

    if _merge_profiles "$cs_dir" "$cs_prof" 'CS-PGO'; then
      use_prof_args="-fprofile-use=$cs_prof -Wno-profile-instr-unprofiled -Wno-profile-instr-out-of-date -Wno-backend-plugin"
      use_prof_link="-fprofile-use=$cs_prof"
    else
      echo "==> PASS 2/3: no valid CS profiles; falling back to IR PGO profile"
      : > "$cs_prof"
    fi
  else
    echo "==> PASS 2/3: CS-PGO unsupported or no base profile; skipping"
  fi

  local c_args_fin="$SAN_CFLAGS $CPU_FLAGS $use_prof_args"
  local cxx_args_fin="$SAN_CXXFLAGS $CPU_FLAGS $use_prof_args"
  local link_args_fin="$SAN_LDFLAGS $FINAL_LD_FLAGS $use_prof_link"

  echo "==> PASS 3/3: Final optimized LTO build"
  CFLAGS='' CXXFLAGS='' LDFLAGS='' CC="$CLANG" CXX="$CLANGXX" \
  _meson_setup "$_pkgsrc" "${_pkgsrc}/build-final" \
    "${_meson_common_options[@]}" -Db_pie=false -Db_lto=true \
    -Dc_args="$c_args_fin" -Dcpp_args="$cxx_args_fin" \
    -Dc_link_args="$link_args_fin" -Dcpp_link_args="$link_args_fin"

  meson compile -C "${_pkgsrc}/build-final"
  DESTDIR="$srcdir/fakeinstall" meson install -C "${_pkgsrc}/build-final"

  if command -v "$LLVM_BOLT" >/dev/null 2>&1; then
    echo "==> BOLT: instrumentation"
    local bindir="$srcdir/fakeinstall/usr/bin"
    local bins=()
    local name
    for name in Xorg Xvfb; do
      [[ -x "$bindir/$name" ]] && bins+=("$bindir/$name")
    done

    local b base
    for b in "${bins[@]}"; do
      base="$(basename "$b")"
      cp -f "$b" "$srcdir/bolt/${base}.orig"
      "$LLVM_BOLT" "$b" --relocs --lite --instrument \
        --instrumentation-file="$srcdir/bolt/${base}.fdata" \
        --instrumentation-file-append-pid \
        -o "$srcdir/bolt_inst/${base}" >/dev/null 2>&1 || continue
      install -m755 "$srcdir/bolt_inst/${base}" "$b"
    done

    echo "==> BOLT: training"
    BOLT_INSTRUMENTATION_FILE_APPEND_PID=1 \
      _run_xserver_workload_xvfb "$bindir" bolt

    for orig in "$srcdir"/bolt/*.orig; do
      [[ -f "$orig" ]] || continue
      base="$(basename "$orig" .orig)"
      local merged="$srcdir/bolt/${base}.merged.fdata"

      if compgen -G "$srcdir/bolt/${base}.fdata".* >/dev/null; then
        if command -v "$MERGE_FDATA" >/dev/null 2>&1; then
          "$MERGE_FDATA" "$srcdir/bolt/${base}.fdata".* -o "$merged" >/dev/null 2>&1 || continue
        else
          cat "$srcdir/bolt/${base}.fdata".* > "$merged" 2>/dev/null || continue
        fi
      elif [[ -s "$srcdir/bolt/${base}.fdata" ]]; then
        cp -f "$srcdir/bolt/${base}.fdata" "$merged"
      else
        continue
      fi

      [[ -s "$merged" ]] || continue

      local align_flags=(--align-blocks)
      "$LLVM_BOLT" --help 2>&1 | grep -q -- '--block-alignment' && \
        align_flags=(--align-blocks --block-alignment=32)

      if "$LLVM_BOLT" "$orig" --relocs --data="$merged" \
            --reorder-blocks=ext-tsp --reorder-functions=cdsort \
            --split-functions --split-strategy=cdsplit --icf=all \
            --jump-tables=move --peepholes=all --reg-reassign \
            --use-aggr-reg-reassign "${align_flags[@]}" --dyno-stats \
            -o "$srcdir/bolt_opt/$base" >/dev/null 2>&1; then
        echo "==> BOLT: optimized $base"
        install -m755 "$srcdir/bolt_opt/$base" "$bindir/$base"
      fi
    done
  fi
}

package_xlibre-xserver() {
  pkgdesc="XLibre X server"
  depends=('dbus' 'glibc' 'libdrm' 'libepoxy' 'libgl' 'libpciaccess' 'libtirpc'
           'libunwind' 'libxau' 'libxcvt' 'libxdmcp' 'libxfont2' 'libbsd'
           'libxshmfence>=1.1' 'nettle' 'pixman-git' 'sh'
           'systemd-libs>=209' 'xlibre-xserver-common' 'xlibre-xf86-input-libinput'
           "${pkgbase}-common=${pkgver}-${pkgrel}")
  provides=('X-ABI-VIDEODRV_VERSION=28.0' 'X-ABI-XINPUT_VERSION=26.0'
            'X-ABI-EXTENSION_VERSION=11.0' 'x-server' 'xorg-server' 'xlibre-server')
  conflicts=('xorg-server' 'nvidia-utils<=331.20' 'glamor-egl' 'xf86-video-modesetting' 'xlibre-server')
  replaces=('xlibre-xserver-bootstrap' 'glamor-egl' 'xf86-video-modesetting')
  options=('emptydirs')
  install="${pkgname}.install"

  cp -a "${srcdir}/fakeinstall"/. "${pkgdir}"/
  install -vdm755 "${pkgdir}/etc/X11/xorg.conf.d"
  cd "${pkgdir}/usr"
  rm -rf include lib/pkgconfig share/aclocal
  rm -f lib/xorg/protocol.txt share/man/man1/Xserver.1
  find . -type f,l \( -name '*Xephyr*' -o -name '*Xnest*' -o -name '*Xvfb*' \) -delete
}

package_xlibre-xserver-bootstrap() {
  pkgdesc="XLibre X server (bootstrap)"
  depends=('dbus' 'glibc' 'libdrm' 'libepoxy' 'libgl' 'libpciaccess' 'libtirpc'
           'libunwind' 'libxau' 'libxcvt' 'libxdmcp' 'libxfont2' 'libmd'
           'libxshmfence>=1.1' 'nettle' 'pixman-git' 'sh' 'systemd-libs>=209'
           "${pkgbase}-common=${pkgver}-${pkgrel}")
  provides=("${pkgbase}" 'X-ABI-VIDEODRV_VERSION=28.0' 'X-ABI-XINPUT_VERSION=26.0'
            'X-ABI-EXTENSION_VERSION=11.0' 'x-server' 'xorg-server')
  conflicts=({xlibre,xorg}'-server' 'nvidia-utils<=331.20' 'glamor-egl' 'xf86-video-modesetting')
  options=('emptydirs')
  install="${pkgname}.install"

  cp -a "${srcdir}/fakeinstall"/. "${pkgdir}"/
  install -vdm755 "${pkgdir}/etc/X11/xorg.conf.d"
  cd "${pkgdir}/usr"
  rm -rf include lib/pkgconfig share/aclocal
  rm -f lib/xorg/protocol.txt share/man/man1/Xserver.1
  find . -type f,l \( -name '*Xephyr*' -o -name '*Xnest*' -o -name '*Xvfb*' \) -delete
}

package_xlibre-xserver-common() {
  pkgdesc="XLibre server common files"
  arch=('any')
  depends=('xkeyboard-config' 'xorg-setxkbmap' 'xorg-xkbcomp')
  provides=('xorg-server-common' 'xlibre-server-common')
  conflicts=('xorg-server-common' 'xlibre-server-common')

  install -vDm644 "${srcdir}/fakeinstall/usr/lib/xorg/protocol.txt" \
                  "${pkgdir}/usr/lib/xorg/protocol.txt"
  install -vDm644 "${srcdir}/fakeinstall/usr/share/man/man1/Xserver.1" \
                  "${pkgdir}/usr/share/man/man1/Xserver.1"
  install -vDm644 "${srcdir}/${_pkgsrc}/COPYING" \
                  "${pkgdir}/usr/share/licenses/${pkgbase}/COPYING"
  install -vDm644 "${srcdir}/${_pkgsrc}/xkb/README.compiled" \
                  "${pkgdir}/var/lib/xkb/README.compiled"
}

package_xlibre-xserver-devel() {
  pkgdesc="Development files for the XLibre X server"
  arch=('any')
  depends=('libpciaccess' 'mesa' 'pixman-git' 'xorgproto-git' 'xorg-util-macros')
  provides=('xorg-server-devel' 'xlibre-server-devel')
  conflicts=('xorg-server-devel' 'xlibre-server-devel')

  cp -a "${srcdir}/fakeinstall"/. "${pkgdir}"/
  find "${pkgdir}" -type f,l ! \( -name '*.h' -o -name '*.pc' -o -name '*.m4' \) -delete
}

package_xlibre-xserver-xvfb() {
  pkgdesc="Virtual framebuffer XLibre server"
  license=('MIT' 'GPL-2.0-only')
  depends=('glibc' 'libgl' 'libtirpc' 'libunwind' 'libxau' 'libxdmcp'
           'libxfont2' 'nettle' 'pixman-git' 'sh' 'systemd-libs>=209'
           "${pkgbase}-common=${pkgver}-${pkgrel}" 'xorg-xauth')
  provides=('xorg-server-xvfb' 'xlibre-server-xvfb')
  conflicts=('xorg-server-xvfb' 'xlibre-server-xvfb')

  cp -a "${srcdir}/fakeinstall"/. "${pkgdir}"/
  find "${pkgdir}" -type f,l ! -name '*Xvfb*' -delete
  install -vDm755 "${srcdir}/xvfb-run" "${pkgdir}/usr/bin/xvfb-run"
  install -vDm644 "${srcdir}/xvfb-run.1" "${pkgdir}/usr/share/man/man1/xvfb-run.1"
}
