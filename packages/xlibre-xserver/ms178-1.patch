+    glCopyImageSubData(spr->fbo->tex, GL_TEXTURE_2D, 0,
+                       s_x, sp_h - (s_y + h_), 0,
+                       dpr->fbo->tex, GL_TEXTURE_2D, 0,
+                       d_x, dp_h - (d_y + h_), 0,
+                       w_, h_, 1);
+    (*commands)++;
