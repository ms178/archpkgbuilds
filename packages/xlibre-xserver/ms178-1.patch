+        const BoxPtr b = &boxes[n];
+        vbo[0] = b->x1; vbo[1] = b->y1;
+        vbo[2] = b->x1; vbo[3] = b->y2;
+        vbo[4] = b->x2; vbo[5] = b->y2;
+        vbo[6] = b->x2; vbo[7] = b->y1;
+        vbo += 8;
