+static Bool GLAMOR_HOT
+glamor_copy_box_inside_texture(const BoxRec *box, int dx, int dy,
+                              int src_off_x, int src_off_y,
+                              int dst_off_x, int dst_off_y,
+                              const glamor_pixmap_fbo *src_fbo,
+                              const glamor_pixmap_fbo *dst_fbo)
+{
+    const int src_x = box->x1 + dx + src_off_x;
+    const int src_y = box->y1 + dy + src_off_y;
+    const int dst_x = box->x1 + dst_off_x;
+    const int dst_y = box->y1 + dst_off_y;
+    const int width = box->x2 - box->x1;
+    const int height = box->y2 - box->y1;
+
+    if (width <= 0 || height <= 0 ||
+        src_x < 0 || src_y < 0 || dst_x < 0 || dst_y < 0)
+        return FALSE;
+
+    return src_x <= src_fbo->width - width &&
+        src_y <= src_fbo->height - height &&
+        dst_x <= dst_fbo->width - width &&
+        dst_y <= dst_fbo->height - height;
+}
+
+static Bool GLAMOR_HOT
+glamor_copy_fbo_fbo_copy_image(DrawablePtr src,
+                                DrawablePtr dst,
+                                GCPtr gc,
+                                BoxPtr box,
