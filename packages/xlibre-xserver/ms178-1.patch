@@ -25,11 +25,259 @@
 #include "glamor_transfer.h"
 #include "glamor_transform.h"
 
+#include <stdint.h>
+#include <string.h>
+
+#if defined(__GNUC__) || defined(__clang__)
+#define GLAMOR_HOT      __attribute__((hot))
+#define GLAMOR_COLD     __attribute__((cold))
+#define GLAMOR_PURE     __attribute__((pure))
+#define GLAMOR_LIKELY(x)   __builtin_expect(!!(x), 1)
+#define GLAMOR_UNLIKELY(x) __builtin_expect(!!(x), 0)
+#else
+#define GLAMOR_HOT
+#define GLAMOR_COLD
+#define GLAMOR_PURE
+#define GLAMOR_LIKELY(x)   (x)
+#define GLAMOR_UNLIKELY(x) (x)
+#endif
+
+#if defined(__AVX2__) && (defined(__GNUC__) || defined(__clang__))
+#include <immintrin.h>
+#define GLAMOR_IMAGE_HAVE_AVX2 1
+#else
+#define GLAMOR_IMAGE_HAVE_AVX2 0
+#endif
+
+#define GLAMOR_IMAGE_PBO_RING_SIZE 4
+#define GLAMOR_IMAGE_PBO_MIN_SIZE (256u * 1024u)
+#define GLAMOR_IMAGE_PBO_MAX_SIZE (64u * 1024u * 1024u)
+#define GLAMOR_IMAGE_PBO_THRESHOLD (128u * 1024u)
+
+typedef struct glamor_image_pbo_ring {
+    GLuint pbo[GLAMOR_IMAGE_PBO_RING_SIZE];
+    GLsync fence[GLAMOR_IMAGE_PBO_RING_SIZE];
+    uint32_t size[GLAMOR_IMAGE_PBO_RING_SIZE];
+    int current;
+} glamor_image_pbo_ring;
+
+static glamor_image_pbo_ring glamor_image_pbo_rings[MAXSCREENS];
+
+static inline Bool GLAMOR_HOT GLAMOR_PURE
+glamor_image_is_fast_zpixmap(DrawablePtr drawable, GCPtr gc, int format, int leftPad)
+{
+    if (GLAMOR_UNLIKELY(!drawable || !gc))
+        return FALSE;
+
+    if (format == XYPixmap && drawable->depth == 1 && leftPad == 0)
+        return TRUE;
+
+    return format == ZPixmap;
+}
+
+static inline Bool GLAMOR_HOT GLAMOR_PURE
+glamor_image_can_copy(GCPtr gc)
+{
+    return gc && gc->alu == GXcopy && glamor_pm_is_solid(gc->depth, gc->planemask);
+}
+
+static inline Bool GLAMOR_HOT GLAMOR_PURE
+glamor_image_checked_upload_size(uint32_t byte_stride, int h, size_t *size)
+{
+    if (byte_stride == 0 || h <= 0)
+        return FALSE;
+
+    if ((size_t) h > SIZE_MAX / byte_stride)
+        return FALSE;
+
+    *size = (size_t) h * byte_stride;
+    return *size != 0;
+}
+
+static inline Bool GLAMOR_HOT GLAMOR_PURE
+glamor_image_upload_region_is_linear(RegionPtr region)
+{
+    return region && RegionNumRects(region) == 1;
+}
+
+static void GLAMOR_HOT
+glamor_image_memcpy_to_pbo(void *dst, const void *src, size_t size)
+{
+#if GLAMOR_IMAGE_HAVE_AVX2
+    if (size >= (size_t) (512 * 1024) && (((uintptr_t) dst & 31u) == 0u)) {
+        const char *s = src;
+        char *d = dst;
+        size_t offset = 0;
+
+        for (; offset + 64u <= size; offset += 64u) {
+            __m256i a = _mm256_loadu_si256((const __m256i *) (const void *) (s + offset));
+            __m256i b = _mm256_loadu_si256((const __m256i *) (const void *) (s + offset + 32u));
+
+            _mm256_stream_si256((__m256i *) (void *) (d + offset), a);
+            _mm256_stream_si256((__m256i *) (void *) (d + offset + 32u), b);
+        }
+
+        _mm_sfence();
+
+        if (offset < size)
+            memcpy(d + offset, s + offset, size - offset);
+        return;
+    }
+#endif
+
+    memcpy(dst, src, size);
+}
+
+static Bool GLAMOR_HOT
+glamor_image_pbo_upload(DrawablePtr drawable, RegionPtr region,
+                        int x, int y, uint32_t byte_stride,
+                        const char *bits, size_t upload_size)
+{
+    ScreenPtr screen = drawable->pScreen;
+    glamor_image_pbo_ring *ring;
+    GLuint pbo;
+    void *map;
+    int slot;
+    uint32_t alloc_size;
+
+    if (GLAMOR_UNLIKELY(screen->myNum < 0 || screen->myNum >= MAXSCREENS ||
+                        upload_size < GLAMOR_IMAGE_PBO_THRESHOLD ||
+                        upload_size > GLAMOR_IMAGE_PBO_MAX_SIZE ||
+                        !glamor_image_upload_region_is_linear(region)))
+        return FALSE;
+
+    ring = &glamor_image_pbo_rings[screen->myNum];
+    slot = (ring->current + 1) & (GLAMOR_IMAGE_PBO_RING_SIZE - 1);
+
+    if (ring->fence[slot]) {
+        GLenum status = glClientWaitSync(ring->fence[slot], 0, 0);
+
+        if (status == GL_TIMEOUT_EXPIRED || status == GL_WAIT_FAILED)
+            return FALSE;
+
+        glDeleteSync(ring->fence[slot]);
+        ring->fence[slot] = NULL;
+    }
+
+    pbo = ring->pbo[slot];
+    if (!pbo) {
+        glGenBuffers(1, &pbo);
+        if (!pbo)
+            return FALSE;
+        ring->pbo[slot] = pbo;
+    }
+
+    alloc_size = (uint32_t) max((size_t) GLAMOR_IMAGE_PBO_MIN_SIZE, upload_size);
+
+    glBindBuffer(GL_PIXEL_UNPACK_BUFFER, pbo);
+    if (ring->size[slot] < alloc_size) {
+        glBufferData(GL_PIXEL_UNPACK_BUFFER, alloc_size, NULL, GL_STREAM_DRAW);
+        ring->size[slot] = alloc_size;
+    }
+
+    map = glMapBufferRange(GL_PIXEL_UNPACK_BUFFER, 0, upload_size,
+                           GL_MAP_WRITE_BIT |
+                           GL_MAP_INVALIDATE_BUFFER_BIT |
+                           GL_MAP_UNSYNCHRONIZED_BIT);
+    if (!map) {
+        glBindBuffer(GL_PIXEL_UNPACK_BUFFER, 0);
+        return FALSE;
+    }
+
+    glamor_image_memcpy_to_pbo(map, bits, upload_size);
+
+    if (GLAMOR_UNLIKELY(glUnmapBuffer(GL_PIXEL_UNPACK_BUFFER) != GL_TRUE)) {
+        glBindBuffer(GL_PIXEL_UNPACK_BUFFER, 0);
+        return FALSE;
+    }
+
+    glamor_upload_region(drawable, region, x, y, (uint8_t *) (uintptr_t) 0, byte_stride);
+
+    if (ring->fence[slot])
+        glDeleteSync(ring->fence[slot]);
+    ring->fence[slot] = glFenceSync(GL_SYNC_GPU_COMMANDS_COMPLETE, 0);
+    ring->current = slot;
+
+    glBindBuffer(GL_PIXEL_UNPACK_BUFFER, 0);
+    return TRUE;
+}
+
+void
+glamor_image_fini(ScreenPtr screen)
+{
+    if (!screen || screen->myNum < 0 || screen->myNum >= MAXSCREENS)
+        return;
+
+    glamor_image_pbo_ring *ring = &glamor_image_pbo_rings[screen->myNum];
+
+    for (int i = 0; i < GLAMOR_IMAGE_PBO_RING_SIZE; i++) {
+        if (ring->fence[i]) {
+            glDeleteSync(ring->fence[i]);
+            ring->fence[i] = NULL;
+        }
+        if (ring->pbo[i]) {
+            glDeleteBuffers(1, &ring->pbo[i]);
+            ring->pbo[i] = 0;
+        }
+        ring->size[i] = 0;
+    }
+    ring->current = 0;
+}
+
+#if GLAMOR_IMAGE_HAVE_AVX2
+static void GLAMOR_HOT
+glamor_image_apply_planemask_32_avx2(char *dst, uint32_t byte_stride, int h, uint32_t mask)
+{
+    const __m256i vmask = _mm256_set1_epi32((int) mask);
+
+    for (int y = 0; y < h; y++) {
+        uint32_t *row = (uint32_t *) (void *) (dst + (size_t) y * byte_stride);
+        uint32_t n = byte_stride / sizeof(uint32_t);
+        uint32_t x = 0;
+
+        for (; x + 8 <= n; x += 8) {
+            __m256i v = _mm256_loadu_si256((const __m256i *) (const void *) &row[x]);
+            v = _mm256_and_si256(v, vmask);
+            _mm256_storeu_si256((__m256i *) (void *) &row[x], v);
+        }
+
+        for (; x < n; x++)
+            row[x] &= mask;
+    }
+
+    _mm256_zeroupper();
+}
+#endif
+
+static void GLAMOR_HOT
+glamor_image_apply_planemask_fbstip(char *dst, uint32_t byte_stride, int h,
+                                  unsigned int bpp, unsigned long plane_mask)
+{
+    FbStip pm = fbReplicatePixel(plane_mask, bpp);
+
+#if GLAMOR_IMAGE_HAVE_AVX2
+    if (bpp == 32 && sizeof(FbStip) == sizeof(uint32_t)) {
+        glamor_image_apply_planemask_32_avx2(dst, byte_stride, h, (uint32_t) pm);
+        return;
+    }
+#endif
+
+    FbStip *bits = (FbStip *) (void *) dst;
+    uint32_t stride = byte_stride / sizeof(FbStip);
+
+    for (int y = 0; y < h; y++) {
+        FbStip *row = bits + (size_t) y * stride;
+
+        for (uint32_t x = 0; x < stride; x++)
+            row[x] &= pm;
+    }
+}
