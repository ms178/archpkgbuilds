+    PixmapPtr src_pixmap = glamor_get_drawable_pixmap(src);
+    PixmapPtr dst_pixmap = glamor_get_drawable_pixmap(dst);
+    glamor_pixmap_private *src_priv = glamor_get_pixmap_private(src_pixmap);
+    glamor_pixmap_private *dst_priv = glamor_get_pixmap_private(dst_pixmap);
+    glamor_pixmap_fbo *src_fbo;
+    glamor_pixmap_fbo *dst_fbo;
+    int src_off_x, src_off_y;
+    int dst_off_x, dst_off_y;
+
+    if (GLAMOR_UNLIKELY(bitplane || !glamor_copy_gc_is_simple(gc)))
+        return FALSE;
+
+    if (GLAMOR_UNLIKELY(!glamor_priv->has_copy_image || src_pixmap == dst_pixmap))
+        return FALSE;
+
+    if (GLAMOR_UNLIKELY(!glamor_copy_fbo_is_single(src_priv) ||
+                        !glamor_copy_fbo_is_single(dst_priv)))
+        return FALSE;
+
+    if (GLAMOR_UNLIKELY(!glamor_copy_vbo_size_valid(nbox)))
+        return FALSE;
+
+    src_fbo = src_priv->fbo;
+    dst_fbo = dst_priv->fbo;
+
+    glamor_get_drawable_deltas(src, src_pixmap, &src_off_x, &src_off_y);
+    glamor_get_drawable_deltas(dst, dst_pixmap, &dst_off_x, &dst_off_y);
+
+    for (int n = 0; n < nbox; n++) {
+        if (GLAMOR_UNLIKELY(!glamor_copy_box_inside_texture(&box[n], dx, dy,
+                                                            src_off_x, src_off_y,
+                                                            dst_off_x, dst_off_y,
+                                                            src_fbo, dst_fbo)))
+            return FALSE;
+    }
+
+    glamor_make_current(glamor_priv);
+
+    for (int n = 0; n < nbox; n++) {
+        const BoxRec *b = &box[n];
+        const int width = b->x2 - b->x1;
+        const int height = b->y2 - b->y1;
+
+        glCopyImageSubData(src_fbo->tex, GL_TEXTURE_2D, 0,
+                           b->x1 + dx + src_off_x,
+                           b->y1 + dy + src_off_y,
+                           0,
+                           dst_fbo->tex, GL_TEXTURE_2D, 0,
+                           b->x1 + dst_off_x,
+                           b->y1 + dst_off_y,
+                           0,
+                           width, height, 1);
+    }
+
+    return glGetError() == GL_NO_ERROR;
+}
