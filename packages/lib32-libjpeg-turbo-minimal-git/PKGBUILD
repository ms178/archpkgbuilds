pkgver() {
  cd "${srcdir}/${_pkgname}"
  git describe --long --tags --abbrev=8 2>/dev/null | sed 's/^v//;s/\([^-]*-\)g/r\1/;s/-/./g' \
    || printf '3.1.4.1.r%s.g%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short=8 HEAD)"
}

_setup_llvm_toolchain_32() {
  export CC="clang -m32"
  export CXX="clang++ -m32"
  export AR=llvm-ar
  export NM=llvm-nm
  export STRIP=llvm-strip
  export RANLIB=llvm-ranlib
  export READELF=llvm-readelf
  export OBJCOPY=llvm-objcopy
  export OBJDUMP=llvm-objdump
  export PKG_CONFIG="i686-pc-linux-gnu-pkg-config"
}

_verify_expected_sonames() {
  local libdir="$1"
  local -A expected=( [libjpeg.so]=8 [libturbojpeg.so]=0 )
  local base major soname link target actual

  for base in "${!expected[@]}"; do
    major="${expected[$base]}"
    soname="${base}.${major}"
    link="${libdir}/${soname}"

    [[ -e "$link" ]] || { echo "Error: missing $link" >&2; return 1; }
    target="$(readlink -f "$link")"
    [[ -f "$target" ]] || { echo "Error: cannot resolve $link" >&2; return 1; }

    actual="$("${READELF:-readelf}" -d "$target" 2>/dev/null \
              | sed -n 's/.*SONAME.*\[\(.*\)\].*/\1/p' | head -n1)"
    [[ "$actual" == "$soname" ]] || {
      echo "Error: SONAME mismatch $target: want $soname got ${actual:-<none>}" >&2
      return 1
    }
  done
  echo "  -> SONAME verification passed (32-bit)"
}

_stage_slug() { printf '%s' "$1" | tr ' /' '__'; }

_show_profiles() {
  local dir="$1" label="$2"
  local n
  n=$(find "$dir" -maxdepth 1 -name '*.profraw' 2>/dev/null | wc -l)
  echo "  -> ${label}: ${n} profile file(s)"
}

_cmake_common_options=(
  -G Ninja
  -W no-dev
  -DCMAKE_INSTALL_PREFIX=/usr
  -DCMAKE_INSTALL_LIBDIR=/usr/lib32
  -DCMAKE_C_STANDARD=23
  -DCMAKE_CXX_STANDARD=23
  -DENABLE_STATIC=OFF
  -DBUILD_TESTING=ON
  -DWITH_JAVA=OFF
  -DWITH_JPEG8=ON
  -DWITH_TURBOJPEG=ON
  -DREQUIRE_SIMD=ON
)

_configure_build() {
  local builddir="$1" buildtype="$2" cflags_extra="$3" ldflags_extra="$4"
  rm -rf "$builddir"
  cmake "${_cmake_common_options[@]}" \
    -S "${srcdir}/${_pkgname}" -B "${builddir}" \
    -DCMAKE_BUILD_TYPE="${buildtype}" \
    -DCMAKE_C_COMPILER="clang" \
    -DCMAKE_CXX_COMPILER="clang++" \
    -DCMAKE_AR="$(command -v llvm-ar)" \
    -DCMAKE_NM="$(command -v llvm-nm)" \
    -DCMAKE_RANLIB="$(command -v llvm-ranlib)" \
    -DCMAKE_C_FLAGS="${CFLAGS} -m32 ${cflags_extra} -ffp-contract=fast" \
    -DCMAKE_CXX_FLAGS="${CXXFLAGS} -m32 ${cflags_extra} -ffp-contract=fast" \
    -DCMAKE_EXE_LINKER_FLAGS="${LDFLAGS} -m32 ${linker_flags_extra}" \
    -DCMAKE_SHARED_LINKER_FLAGS="${LDFLAGS} -m32 ${ldflags_extra}" \
    -DCMAKE_MODULE_LINKER_FLAGS="${LDFLAGS} -m32 ${ldflags_extra}"
}

# ──────────────────────────────────────────────────────────────────────
# PGO workload (identical logic, compiled as 32-bit)
# ──────────────────────────────────────────────────────────────────────

_create_pgo_workload_source() {
  cat > "${srcdir}/jpeg_pgo_workload.c" <<'CEOF'
#define _GNU_SOURCE
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>
#include <math.h>
#include <time.h>
#include <pthread.h>
#include <jpeglib.h>
#include <turbojpeg.h>

static double now_sec(void) {
  struct timespec ts;
  clock_gettime(CLOCK_MONOTONIC, &ts);
  return (double)ts.tv_sec + (double)ts.tv_nsec * 1e-9;
}

static uint32_t xorshift32(uint32_t *s) {
  uint32_t x = *s; x ^= x<<13; x ^= x>>17; x ^= x<<5; *s = x; return x;
}

typedef struct { uint8_t *data; int w, h, c; } img_t;

static void mk_gradient(img_t *im, int w, int h, int c) {
  im->w=w; im->h=h; im->c=c;
  im->data=malloc((size_t)w*h*c); if(!im->data) abort();
  for(int y=0;y<h;y++) for(int x=0;x<w;x++) {
    int i=(y*w+x)*c;
    float fx=w>1?(float)x/(w-1):0.5f, fy=h>1?(float)y/(h-1):0.5f;
    if(c>=1) im->data[i]=  (uint8_t)(fx*255);
    if(c>=2) im->data[i+1]=(uint8_t)(fy*255);
    if(c>=3) im->data[i+2]=(uint8_t)((1-fx)*255);
    if(c>=4) im->data[i+3]=255;
  }
}

static void mk_noise(img_t *im, int w, int h, int c, uint32_t seed) {
  im->w=w; im->h=h; im->c=c;
  im->data=malloc((size_t)w*h*c); if(!im->data) abort();
  uint32_t s=seed?seed:1;
  for(int i=0;i<w*h*c;i++) im->data[i]=(uint8_t)(xorshift32(&s)&0xFF);
}

static void mk_pattern(img_t *im, int w, int h, int c) {
  im->w=w; im->h=h; im->c=c;
  im->data=malloc((size_t)w*h*c); if(!im->data) abort();
  for(int y=0;y<h;y++) for(int x=0;x<w;x++) {
    int i=(y*w+x)*c;
    int ck=((x/16)+(y/16))&1;
    float sx=sinf(x*0.05f)*0.5f+0.5f, sy=cosf(y*0.07f)*0.5f+0.5f;
    uint8_t b=ck?200:55;
    if(c>=1) im->data[i]=  (uint8_t)(b*sx);
    if(c>=2) im->data[i+1]=(uint8_t)(b*sy);
    if(c>=3) im->data[i+2]=(uint8_t)(b*sx*sy);
    if(c>=4) im->data[i+3]=255;
  }
}

static void mk_photo(img_t *im, int w, int h) {
  im->w=w; im->h=h; im->c=3;
  im->data=malloc((size_t)w*h*3); if(!im->data) abort();
  uint32_t s=0xDEADBEEF;
  for(int y=0;y<h;y++) for(int x=0;x<w;x++) {
    int i=(y*w+x)*3;
    float fx=w>1?(float)x/(w-1):0.5f, fy=h>1?(float)y/(h-1):0.5f;
    float r=fx*200+sinf(fy*6.28f)*30, g=fy*180+cosf(fx*6.28f)*40, b=(1-fx*fy)*220;
    float n=((float)(xorshift32(&s)&0xFF)-128)*0.15f;
    r+=n; g+=n*0.8f; b+=n*1.2f;
    im->data[i]  =(uint8_t)(r<0?0:r>255?255:r);
    im->data[i+1]=(uint8_t)(g<0?0:g>255?255:g);
    im->data[i+2]=(uint8_t)(b<0?0:b>255?255:b);
  }
}

static void free_img(img_t *im) { free(im->data); im->data=NULL; }

static unsigned char *jcompress(const img_t *im, int q, J_COLOR_SPACE cs,
                                boolean prog, boolean opt, unsigned long *osz) {
  struct jpeg_compress_struct ci; struct jpeg_error_mgr je;
  unsigned char *ob=NULL; unsigned long os=0;
  ci.err=jpeg_std_error(&je); jpeg_create_compress(&ci);
  jpeg_mem_dest(&ci, &ob, &os);
  ci.image_width=im->w; ci.image_height=im->h;
  ci.input_components=im->c; ci.in_color_space=cs;
  jpeg_set_defaults(&ci); jpeg_set_quality(&ci, q, TRUE);
  if(opt) ci.optimize_coding=TRUE;
  if(prog) jpeg_simple_progression(&ci);
  if(im->c==3 && q<80) {
    ci.comp_info[0].h_samp_factor=2; ci.comp_info[0].v_samp_factor=2;
    ci.comp_info[1].h_samp_factor=1; ci.comp_info[1].v_samp_factor=1;
    ci.comp_info[2].h_samp_factor=1; ci.comp_info[2].v_samp_factor=1;
  } else if(im->c==3) {
    for(int k=0;k<3;k++){ci.comp_info[k].h_samp_factor=1;ci.comp_info[k].v_samp_factor=1;}
  }
  jpeg_start_compress(&ci, TRUE);
  int stride=im->w*im->c; JSAMPROW rp[1];
  while(ci.next_scanline<ci.image_height){rp[0]=&im->data[ci.next_scanline*stride];jpeg_write_scanlines(&ci,rp,1);}
  jpeg_finish_compress(&ci); jpeg_destroy_compress(&ci);
  *osz=os; return ob;
}

static uint8_t *jdecompress(const unsigned char *jd, unsigned long jsz,
                            int *ow, int *oh, int *oc,
                            J_COLOR_SPACE ocs, int sn, int sd,
                            J_DCT_METHOD dct, boolean fancy) {
  struct jpeg_decompress_struct di; struct jpeg_error_mgr je;
  di.err=jpeg_std_error(&je); jpeg_create_decompress(&di);
  jpeg_mem_src(&di, jd, jsz);
  if(jpeg_read_header(&di, TRUE)!=JPEG_HEADER_OK){jpeg_destroy_decompress(&di);*ow=*oh=*oc=0;return NULL;}
  di.out_color_space=ocs; di.scale_num=sn; di.scale_denom=sd;
  di.dct_method=dct; di.do_fancy_upsampling=fancy;
  jpeg_start_decompress(&di);
  *ow=di.output_width; *oh=di.output_height; *oc=di.output_components;
  if(*ow<=0||*oh<=0||*oc<=0){jpeg_finish_decompress(&di);jpeg_destroy_decompress(&di);return NULL;}
  int rs=(*ow)*(*oc);
  uint8_t *o=malloc((size_t)rs*(*oh));
  if(!o){jpeg_finish_decompress(&di);jpeg_destroy_decompress(&di);return NULL;}
  while(di.output_scanline<di.output_height){JSAMPROW r[1]={o+di.output_scanline*rs};jpeg_read_scanlines(&di,r,1);}
  jpeg_finish_decompress(&di); jpeg_destroy_decompress(&di);
  return o;
}

static void ex_libjpeg_matrix(int loops) {
  static const int qs[]={1,10,25,50,75,85,90,95,100};
  static const int szs[][2]={
    {8,8},{16,16},{15,15},{17,17},{64,64},{100,75},{128,128},
    {160,120},{320,240},{640,480},{800,600},{1024,768},
    {7,13},{33,47},{127,255}};
  int nq=sizeof(qs)/sizeof(qs[0]), ns=sizeof(szs)/sizeof(szs[0]);
  printf("  libjpeg-matrix: %d loops x %d q x %d sizes\n", loops, nq, ns);
  for(int l=0;l<loops;l++) {
    for(int si=0;si<ns;si++) {
      int w=szs[si][0], h=szs[si][1];
      img_t ig,in,ip,igr;
      mk_gradient(&ig,w,h,3); mk_noise(&in,w,h,3,(uint32_t)(42+l*1000+si));
      mk_pattern(&ip,w,h,3); mk_gradient(&igr,w,h,1);
      for(int qi=0;qi<nq;qi++) {
        int q=qs[qi];
        unsigned long s1=0,s2=0,s3=0,s4=0;
        unsigned char *j1=jcompress(&ig,q,JCS_RGB,FALSE,FALSE,&s1);
        unsigned char *j2=jcompress(&ip,q,JCS_RGB,TRUE,TRUE,&s2);
        unsigned char *j3=jcompress(&igr,q,JCS_GRAYSCALE,FALSE,TRUE,&s3);
        unsigned char *j4=jcompress(&in,q,JCS_RGB,(q>50)?TRUE:FALSE,FALSE,&s4);
        if(j1&&s1){int dw,dh,dc;
          free(jdecompress(j1,s1,&dw,&dh,&dc,JCS_RGB,1,1,JDCT_FLOAT,TRUE));
          free(jdecompress(j1,s1,&dw,&dh,&dc,JCS_RGB,1,1,JDCT_ISLOW,TRUE));
          free(jdecompress(j1,s1,&dw,&dh,&dc,JCS_RGB,1,1,JDCT_IFAST,FALSE));
          free(jdecompress(j1,s1,&dw,&dh,&dc,JCS_RGB,1,2,JDCT_ISLOW,TRUE));
          free(jdecompress(j1,s1,&dw,&dh,&dc,JCS_RGB,1,4,JDCT_ISLOW,TRUE));
          free(jdecompress(j1,s1,&dw,&dh,&dc,JCS_RGB,1,8,JDCT_ISLOW,FALSE));
          free(jdecompress(j1,s1,&dw,&dh,&dc,JCS_GRAYSCALE,1,1,JDCT_ISLOW,TRUE));
        }
        if(j2&&s2){int dw,dh,dc;
          free(jdecompress(j2,s2,&dw,&dh,&dc,JCS_RGB,1,1,JDCT_ISLOW,TRUE));
          free(jdecompress(j2,s2,&dw,&dh,&dc,JCS_RGB,1,2,JDCT_FLOAT,TRUE));
        }
        if(j3&&s3){int dw,dh,dc;free(jdecompress(j3,s3,&dw,&dh,&dc,JCS_GRAYSCALE,1,1,JDCT_ISLOW,TRUE));}
        if(j4&&s4){int dw,dh,dc;free(jdecompress(j4,s4,&dw,&dh,&dc,JCS_RGB,1,1,JDCT_ISLOW,TRUE));}
        free(j1);free(j2);free(j3);free(j4);
      }
      free_img(&ig);free_img(&in);free_img(&ip);free_img(&igr);
    }
    /* Smaller large image for 32-bit (less memory pressure) */
    img_t il; mk_photo(&il,1280,720);
    for(int qi=0;qi<nq;qi++){
      unsigned long sz=0;
      unsigned char *j=jcompress(&il,qs[qi],JCS_RGB,(qi>4)?TRUE:FALSE,(qi>2)?TRUE:FALSE,&sz);
      if(j&&sz){int dw,dh,dc;
        free(jdecompress(j,sz,&dw,&dh,&dc,JCS_RGB,1,1,JDCT_ISLOW,TRUE));
        free(jdecompress(j,sz,&dw,&dh,&dc,JCS_RGB,1,2,JDCT_ISLOW,TRUE));
        free(jdecompress(j,sz,&dw,&dh,&dc,JCS_RGB,1,4,JDCT_IFAST,FALSE));
      }
      free(j);
    }
    free_img(&il);
  }
}

static void ex_tj_matrix(int loops) {
  static const int qs[]={1,25,50,75,90,95,100};
  static const int sss[]={TJSAMP_444,TJSAMP_422,TJSAMP_420,TJSAMP_GRAY,TJSAMP_440};
  static const int pfs[]={TJPF_RGB,TJPF_BGR,TJPF_RGBX,TJPF_BGRX,TJPF_XRGB,TJPF_XBGR,
                          TJPF_GRAY,TJPF_RGBA,TJPF_BGRA,TJPF_ABGR,TJPF_ARGB};
  static const int szs[][2]={{8,8},{16,16},{15,15},{64,64},{320,240},{640,480},{800,600},{33,47},{127,255}};
  int nq=sizeof(qs)/sizeof(qs[0]),nss=sizeof(sss)/sizeof(sss[0]),
      npf=sizeof(pfs)/sizeof(pfs[0]),nsz=sizeof(szs)/sizeof(szs[0]);
  printf("  tj-matrix: %d loops x %d sz x %d q x %d ss x %d pf\n",loops,nsz,nq,nss,npf);
  for(int l=0;l<loops;l++) for(int si=0;si<nsz;si++){
    int w=szs[si][0],h=szs[si][1];
    for(int pfi=0;pfi<npf;pfi++){
      int pf=pfs[pfi],ps=tjPixelSize[pf];
      size_t slen=(size_t)w*h*ps;
      uint8_t *src=malloc(slen); if(!src) continue;
      uint32_t seed=(uint32_t)(0xCAFE0000u+l*10000+si*100+pfi); if(!seed) seed=1;
      for(size_t i=0;i<slen;i++) src[i]=(uint8_t)(xorshift32(&seed)&0xFF);
      for(int ssi=0;ssi<nss;ssi++) for(int qi=0;qi<nq;qi++){
        tjhandle comp=tj3Init(TJINIT_COMPRESS); if(!comp) continue;
        tj3Set(comp,TJPARAM_SUBSAMP,sss[ssi]);tj3Set(comp,TJPARAM_QUALITY,qs[qi]);
        tj3Set(comp,TJPARAM_FASTDCT,(qi<3)?1:0);
        tj3Set(comp,TJPARAM_OPTIMIZE,(qi>3)?1:0);
        tj3Set(comp,TJPARAM_PROGRESSIVE,(qi>4)?1:0);
        unsigned char *jb=NULL; size_t jsz=0;
        int r=tj3Compress8(comp,src,w,0,h,pf,&jb,&jsz);
        tj3Destroy(comp);
        if(r||!jb||!jsz){tj3Free(jb);continue;}
        {int dpfs[]={TJPF_RGB,TJPF_BGR,TJPF_GRAY};
        for(int di=0;di<3;di++){
          tjhandle dec=tj3Init(TJINIT_DECOMPRESS); if(!dec) continue;
          if(tj3DecompressHeader(dec,jb,jsz)==0){
            int dw=tj3Get(dec,TJPARAM_JPEGWIDTH),dh=tj3Get(dec,TJPARAM_JPEGHEIGHT);
            if(dw>0&&dh>0){int dps=tjPixelSize[dpfs[di]];
              uint8_t *db=malloc((size_t)dw*dh*dps);
              if(db){tj3Decompress8(dec,jb,jsz,db,0,dpfs[di]);free(db);}
            }
          }
          tj3Destroy(dec);
        }}
        if(w>=8&&h>=8){
          int nsf=0;const tjscalingfactor *sf=tj3GetScalingFactors(&nsf);
          if(sf&&nsf>0){int idxs[]={0,nsf/4,nsf/2,nsf-1};
            for(int k=0;k<4;k++){int idx=idxs[k];if(idx<0||idx>=nsf)continue;
              int sw=TJSCALED(w,sf[idx]),sh=TJSCALED(h,sf[idx]);
              if(sw<=0||sh<=0)continue;
              tjhandle sd=tj3Init(TJINIT_DECOMPRESS);if(!sd)continue;
              tj3SetScalingFactor(sd,sf[idx]);
              if(tj3DecompressHeader(sd,jb,jsz)==0){
                uint8_t *sb=malloc((size_t)sw*sh*3);
                if(sb){tj3Decompress8(sd,jb,jsz,sb,0,TJPF_RGB);free(sb);}
              }
              tj3Destroy(sd);
            }
          }
        }
        if(w>=16&&h>=16){
          for(int op=TJXOP_NONE;op<=TJXOP_ROT270;op++){
            tjhandle xf=tj3Init(TJINIT_TRANSFORM);if(!xf)continue;
            tjtransform t;memset(&t,0,sizeof(t));t.op=op;t.options=TJXOPT_TRIM;
            unsigned char *xj=NULL;size_t xs=0;
            if(tj3Transform(xf,jb,jsz,1,&xj,&xs,&t)==0&&xj&&xs){
              tjhandle vd=tj3Init(TJINIT_DECOMPRESS);
              if(vd){if(tj3DecompressHeader(vd,xj,xs)==0){
                int tw=tj3Get(vd,TJPARAM_JPEGWIDTH),th=tj3Get(vd,TJPARAM_JPEGHEIGHT);
                if(tw>0&&th>0){uint8_t *tb=malloc((size_t)tw*th*3);
                  if(tb){tj3Decompress8(vd,xj,xs,tb,0,TJPF_RGB);free(tb);}}
              }tj3Destroy(vd);}
            }
            tj3Free(xj);tj3Destroy(xf);
          }
        }
        tj3Free(jb);
      }
      free(src);
    }
  }
}

static void ex_bulk(int loops) {
  printf("  bulk: %d iters\n",loops);
  /* 32-bit: use 1080p instead of 4K to avoid address space exhaustion */
  img_t im; mk_photo(&im,1920,1080);
  for(int i=0;i<loops;i++){
    int qs[]={50,75,90,95};
    for(int qi=0;qi<4;qi++){
      tjhandle c=tj3Init(TJINIT_COMPRESS);if(!c)continue;
      tj3Set(c,TJPARAM_SUBSAMP,TJSAMP_420);tj3Set(c,TJPARAM_QUALITY,qs[qi]);
      tj3Set(c,TJPARAM_PROGRESSIVE,(qi>1)?1:0);
      unsigned char *jb=NULL;size_t jsz=0;
      if(tj3Compress8(c,im.data,im.w,0,im.h,TJPF_RGB,&jb,&jsz)==0&&jb&&jsz){
        int dpfs[]={TJPF_RGB,TJPF_BGR};
        for(int di=0;di<2;di++){
          tjhandle d=tj3Init(TJINIT_DECOMPRESS);if(!d)continue;
          if(tj3DecompressHeader(d,jb,jsz)==0){
            uint8_t *db=malloc((size_t)im.w*im.h*3);
            if(db){tj3Decompress8(d,jb,jsz,db,0,dpfs[di]);free(db);}
          }
          tj3Destroy(d);
        }
      }
      tj3Free(jb);tj3Destroy(c);
    }
  }
  free_img(&im);
}

struct mt_arg{int id,loops,w,h;};
static void *mt_fn(void *a){
  struct mt_arg *m=a;
  img_t im;mk_photo(&im,m->w,m->h);
  for(int i=0;i<m->loops;i++){
    int q=50+(m->id*7+i*3)%50,ss=(i+m->id)%3;
    tjhandle c=tj3Init(TJINIT_COMPRESS);if(!c)continue;
    tj3Set(c,TJPARAM_SUBSAMP,ss);tj3Set(c,TJPARAM_QUALITY,q);
    unsigned char *jb=NULL;size_t jsz=0;
    if(tj3Compress8(c,im.data,im.w,0,im.h,TJPF_RGB,&jb,&jsz)==0&&jb&&jsz){
      tjhandle d=tj3Init(TJINIT_DECOMPRESS);
      if(d){if(tj3DecompressHeader(d,jb,jsz)==0){
        uint8_t *db=malloc((size_t)m->w*m->h*3);
        if(db){tj3Decompress8(d,jb,jsz,db,0,TJPF_RGB);free(db);}
      }tj3Destroy(d);}
    }
    tj3Free(jb);tj3Destroy(c);
  }
  free_img(&im);return NULL;
}
static void ex_mt(int nth,int loops){
  printf("  mt-codec: %d threads x %d loops\n",nth,loops);
  pthread_t *t=calloc(nth,sizeof(*t));
  struct mt_arg *a=calloc(nth,sizeof(*a));
  if(!t||!a){free(t);free(a);return;}
  for(int i=0;i<nth;i++){
    a[i]=(struct mt_arg){i,loops,320+(i%4)*80,240+(i%4)*60};
    pthread_create(&t[i],NULL,mt_fn,&a[i]);
  }
  for(int i=0;i<nth;i++) pthread_join(t[i],NULL);
  free(t);free(a);
}

static void ex_edge(void){
  printf("  edge-cases\n");
  for(int w=1;w<=8;w++) for(int h=1;h<=8;h++){
    img_t im;mk_gradient(&im,w,h,3);
    unsigned long sz=0;unsigned char *j=jcompress(&im,75,JCS_RGB,FALSE,FALSE,&sz);
    if(j&&sz){int dw,dh,dc;free(jdecompress(j,sz,&dw,&dh,&dc,JCS_RGB,1,1,JDCT_ISLOW,TRUE));}
    free(j);free_img(&im);
  }
  static const int odds[][2]={{1,1},{1,500},{500,1},{3,3},{5,7},{9,11},{13,17},
    {31,33},{63,65},{127,129},{255,257}};
  for(int i=0;i<(int)(sizeof(odds)/sizeof(odds[0]));i++){
    img_t im;mk_noise(&im,odds[i][0],odds[i][1],3,(uint32_t)(12345+i));
    unsigned long sz=0;unsigned char *j=jcompress(&im,85,JCS_RGB,TRUE,TRUE,&sz);
    if(j&&sz){int dw,dh,dc;free(jdecompress(j,sz,&dw,&dh,&dc,JCS_RGB,1,1,JDCT_ISLOW,TRUE));}
    free(j);free_img(&im);
  }
  for(int w=1;w<=32;w+=7) for(int h=1;h<=32;h+=7){
    img_t im;mk_gradient(&im,w,h,1);
    unsigned long sz=0;unsigned char *j=jcompress(&im,50,JCS_GRAYSCALE,FALSE,TRUE,&sz);
    if(j&&sz){int dw,dh,dc;free(jdecompress(j,sz,&dw,&dh,&dc,JCS_GRAYSCALE,1,1,JDCT_ISLOW,TRUE));}
    free(j);free_img(&im);
  }
}

static void ex_headers(int loops){
  printf("  header-parsing: %d loops\n",loops);
  img_t im;mk_photo(&im,640,480);
  for(int i=0;i<loops;i++){
    int q=10+(i*13)%90;unsigned long sz=0;
    unsigned char *j=jcompress(&im,q,JCS_RGB,(i&1)?TRUE:FALSE,(i&2)?TRUE:FALSE,&sz);
    if(!j||!sz){free(j);continue;}
    {struct jpeg_decompress_struct di;struct jpeg_error_mgr je;
     di.err=jpeg_std_error(&je);jpeg_create_decompress(&di);
     jpeg_mem_src(&di,j,sz);jpeg_read_header(&di,TRUE);
     (void)di.image_width;(void)di.image_height;(void)di.num_components;
     jpeg_destroy_decompress(&di);}
    {tjhandle d=tj3Init(TJINIT_DECOMPRESS);
     if(d){if(tj3DecompressHeader(d,j,sz)==0){
       (void)tj3Get(d,TJPARAM_JPEGWIDTH);(void)tj3Get(d,TJPARAM_JPEGHEIGHT);
       (void)tj3Get(d,TJPARAM_SUBSAMP);(void)tj3Get(d,TJPARAM_COLORSPACE);
       (void)tj3Get(d,TJPARAM_PRECISION);(void)tj3Get(d,TJPARAM_PROGRESSIVE);
     }tj3Destroy(d);}}
    free(j);
  }
  free_img(&im);
}

static void ex_xform(int loops){
  printf("  transform-churn: %d loops\n",loops);
  img_t im;mk_photo(&im,640,480);
  unsigned long bsz=0;
  unsigned char *bmalloc=jcompress(&im,85,JCS_RGB,FALSE,TRUE,&bsz);
  free_img(&im);
  if(!bmalloc||!bsz){free(bmalloc);return;}
  unsigned char *btj=(unsigned char*)tj3Alloc(bsz);
  if(!btj){free(bmalloc);return;}
  memcpy(btj,bmalloc,bsz);free(bmalloc);
  for(int i=0;i<loops;i++){
    unsigned char *cur=btj;size_t csz=bsz;int owns=0;
    for(int op=TJXOP_NONE;op<=TJXOP_ROT270;op++){
      tjhandle xf=tj3Init(TJINIT_TRANSFORM);if(!xf)break;
      tjtransform t;memset(&t,0,sizeof(t));t.op=op;t.options=TJXOPT_TRIM;
      unsigned char *out=NULL;size_t osz=0;
      int r=tj3Transform(xf,cur,csz,1,&out,&osz,&t);tj3Destroy(xf);
      if(r||!out||!osz){tj3Free(out);break;}
      if(owns)tj3Free(cur);
      cur=out;csz=osz;owns=1;
      if((i&3)==0){
        tjhandle vd=tj3Init(TJINIT_DECOMPRESS);
        if(vd){if(tj3DecompressHeader(vd,cur,csz)==0){
          int tw=tj3Get(vd,TJPARAM_JPEGWIDTH),th=tj3Get(vd,TJPARAM_JPEGHEIGHT);
          if(tw>0&&th>0){uint8_t *tb=malloc((size_t)tw*th*3);
            if(tb){tj3Decompress8(vd,cur,csz,tb,0,TJPF_RGB);free(tb);}}
        }tj3Destroy(vd);}
      }
    }
    if(owns)tj3Free(cur);
  }
  tj3Free(btj);
}

int main(void) {
  setvbuf(stdout,NULL,_IONBF,0);
  printf("libjpeg-turbo PGO workload start (32-bit)\n");
  printf("  JPEG lib version: %d\n", JPEG_LIB_VERSION);
  double t0=now_sec();
  ex_libjpeg_matrix(1);
  ex_tj_matrix(1);
  ex_bulk(2);
  ex_mt(4,10);
  ex_edge();
  ex_headers(200);
  ex_xform(20);
  printf("libjpeg-turbo PGO workload end (%.2fs)\n",now_sec()-t0);
  fflush(stdout);fflush(stderr);
  return 0;
}
CEOF
}

# ──────────────────────────────────────────────────────────────────────
# Workload build/run helpers (32-bit)
# ──────────────────────────────────────────────────────────────────────

_build_workload() {
  local builddir="$1" outpath="$2"
  local abs_builddir
  abs_builddir="$(cd "$builddir" && pwd)"
  echo "  -> Building 32-bit workload: $outpath"
  clang -m32 -std=gnu17 -O2 -pipe \
    -I"${abs_builddir}" -I"${srcdir}/${_pkgname}" \
    "${srcdir}/jpeg_pgo_workload.c" \
    -L"${abs_builddir}" -Wl,-rpath,"${abs_builddir}" \
    -ljpeg -lturbojpeg -lpthread -lm \
    -o "$outpath"
  echo "  -> Linked against:"
  ldd "$outpath" | grep -E 'lib(jpeg|turbojpeg)' || true
}

_run_workload() {
  local label="$1" builddir="$2" profdir="$3" helper="$4"
  local abs_builddir
  abs_builddir="$(cd "$builddir" && pwd)"
  echo "-> ${label}: running 32-bit workload..."
  (
    export LD_LIBRARY_PATH="${abs_builddir}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    export LD_BIND_NOW=1
    "$helper" 2>&1
  ) || { echo "Error: workload failed in ${label}." >&2; return 1; }
  [[ -n "$profdir" ]] && _show_profiles "$profdir" "$label"
}

_run_ctest() {
  local builddir="$1" profdir="$2" label="$3"
  local abs_builddir
  abs_builddir="$(cd "$builddir" && pwd)"
  echo "  -> ${label}: ctest (32-bit)..."
  LD_LIBRARY_PATH="${abs_builddir}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
  LLVM_PROFILE_FILE="${profdir}/%m-%p.profraw" \
    ctest --test-dir "$builddir" --output-on-failure --stop-on-failure -j"$(nproc)" || true
  _show_profiles "$profdir" "${label} ctest"
}

_run_tjbench() {
  local builddir="$1" profdir="$2" label="$3"
  local abs_builddir
  abs_builddir="$(cd "$builddir" && pwd)"
  local tjb="${abs_builddir}/tjbench"
  [[ -x "$tjb" ]] || return 0
  echo "  -> ${label}: tjbench (32-bit)..."
  local tmp; tmp=$(mktemp -d)
  (
    export LD_LIBRARY_PATH="${abs_builddir}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    export LLVM_PROFILE_FILE="${profdir}/tjbench-%m-%p.profraw"
    python3 -c "
import struct,sys
w,h=1280,720
sys.stdout.buffer.write(f'P6\n{w} {h}\n255\n'.encode())
for y in range(h):
 for x in range(w):
  sys.stdout.buffer.write(struct.pack('BBB',int(x/w*255),int(y/h*255),int((1-x/w*y/h)*255)))
" > "${tmp}/t.ppm" 2>/dev/null || true
    if [[ -f "${tmp}/t.ppm" ]]; then
      for ss in 444 422 420 440 gray; do
        timeout 30s "$tjb" "${tmp}/t.ppm" 85 -subsamp "$ss" -warmup 0 -quiet 2>/dev/null || true
        timeout 30s "$tjb" "${tmp}/t.ppm" 50 -subsamp "$ss" -warmup 0 -quiet 2>/dev/null || true
      done
    fi
  ) || true
  rm -rf "$tmp"
  _show_profiles "$profdir" "${label} tjbench"
}

# ──────────────────────────────────────────────────────────────────────
# PKGBUILD functions
# ──────────────────────────────────────────────────────────────────────

prepare() {
  _create_pgo_workload_source
}

build() {
  _setup_llvm_toolchain_32

  local abs_srcdir
  abs_srcdir="$(cd "${srcdir}" && pwd)"
  local pgo_dir="${abs_srcdir}/pgo"
  local cs_dir="${abs_srcdir}/cspgo"

  rm -rf build-pgo build-cs build-final "$pgo_dir" "$cs_dir"
  rm -f "${abs_srcdir}"/*.profdata
  mkdir -p "$pgo_dir" "$cs_dir"

  local -a tuning=(
    -g3 -fno-omit-frame-pointer
    -Xclang -mllvm -Xclang -vp-counters-per-site=50
    -Xclang -mllvm -Xclang -runtime-counter-relocation
    -Xclang -mllvm -Xclang -enable-value-profiling
  )
  local -a pwarn=(-Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled)

  # ── Stage 1: PGO ──────────────────────────────────────────────
  echo "=== Stage 1: PGO instrumented build (32-bit) ==="
  _configure_build build-pgo None \
    "${tuning[*]} -fprofile-generate=${pgo_dir}" \
    "-fprofile-generate=${pgo_dir}"
  cmake --build build-pgo -v

  export LLVM_PROFILE_FILE="${pgo_dir}/%m-%p.profraw"
  _run_ctest build-pgo "$pgo_dir" "Stage 1"
  local helper_pgo="${abs_srcdir}/workload-s1"
  _build_workload build-pgo "$helper_pgo"
  _run_workload "Stage 1 custom" build-pgo "$pgo_dir" "$helper_pgo" || return 1
  _run_tjbench build-pgo "$pgo_dir" "Stage 1"
  unset LLVM_PROFILE_FILE

  local -a raws=()
  shopt -s nullglob; raws=("${pgo_dir}"/*.profraw); shopt -u nullglob
  (( ${#raws[@]} )) || { echo "Error: no Stage 1 profiles." >&2; return 1; }
  llvm-profdata merge -sparse -output="${abs_srcdir}/standard.profdata" "${raws[@]}"

  # ── Stage 2: CS-PGO ───────────────────────────────────────────
  echo "=== Stage 2: CS-PGO instrumented build (32-bit) ==="
  _configure_build build-cs None \
    "${tuning[*]} -fprofile-use=${abs_srcdir}/standard.profdata -fcs-profile-generate=${cs_dir} ${pwarn[*]}" \
    "-fprofile-use=${abs_srcdir}/standard.profdata -fcs-profile-generate=${cs_dir}"
  cmake --build build-cs -v

  export LLVM_PROFILE_FILE="${cs_dir}/%m-%p.profraw"
  _run_ctest build-cs "$cs_dir" "Stage 2"
  local helper_cs="${abs_srcdir}/workload-s2"
  _build_workload build-cs "$helper_cs"
  _run_workload "Stage 2 custom" build-cs "$cs_dir" "$helper_cs" || return 1
  _run_tjbench build-cs "$cs_dir" "Stage 2"
  unset LLVM_PROFILE_FILE

  raws=()
  shopt -s nullglob; raws=("${cs_dir}"/*.profraw); shopt -u nullglob
  (( ${#raws[@]} )) || { echo "Error: no Stage 2 profiles." >&2; return 1; }
  llvm-profdata merge -sparse \
    -output="${abs_srcdir}/merged.profdata" \
    "${abs_srcdir}/standard.profdata" "${raws[@]}"

  # ── Stage 3: Final ────────────────────────────────────────────
  echo "=== Stage 3: Final optimized build (32-bit) ==="
  _configure_build build-final Release \
    "-fprofile-use=${abs_srcdir}/merged.profdata ${pwarn[*]}" \
    "-fprofile-use=${abs_srcdir}/merged.profdata"
  cmake --build build-final -v

  # ── Stage 4: Verification ─────────────────────────────────────
  echo "=== Stage 4: Verification (32-bit) ==="
  local helper_v="${abs_srcdir}/workload-verify"
  _build_workload build-final "$helper_v"
  _run_workload "Verification" build-final "" "$helper_v" || return 1

  echo "=== All stages completed successfully (32-bit) ==="
}

check() {
  ctest --test-dir build-final --output-on-failure --stop-on-failure -j"$(nproc)"
}

package() {
  DESTDIR="${pkgdir}" cmake --install build-final -v

  # Headers, binaries, and docs are provided by the native package
  rm -rf "${pkgdir}"/usr/{include,share,bin}

  _verify_expected_sonames "$pkgdir/usr/lib32"

  install -vDm 644 "${_pkgname}/LICENSE.md" -t "${pkgdir}/usr/share/licenses/${pkgname}/"
  install -vDm 644 "${_pkgname}/README.ijg" -t "${pkgdir}/usr/share/licenses/${pkgname}/"
}
