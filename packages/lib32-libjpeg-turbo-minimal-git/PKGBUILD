pkgname=lib32-libjpeg-turbo
_name=${pkgname#lib32-}
pkgver=3.1.4.1
pkgrel=2.1
pkgdesc="JPEG image codec with accelerated baseline compression and decompression"
url="https://libjpeg-turbo.org/"
_url="https://github.com/libjpeg-turbo/libjpeg-turbo/"
arch=(x86_64)
license=(
  BSD-3-Clause
  IJG
)
depends=(
  lib32-glibc
  "${_name}=${pkgver}"
)
makedepends=(
  cmake
  lib32-expat
  ninja
  nasm
)
provides=(
  libjpeg.so
  libturbojpeg.so
)
source=(
  "${_url}releases/download/${pkgver}/${_name}-${pkgver}.tar.gz"{,.sig}
)
sha512sums=(
  '63231854529f59a95814cf2414fe384360a4ed96c572764fabc535c3770c559d26943e129c905a63d5949088fa79138b1ffdb175b817f2f4d36329a3cbb23ea7'
  'SKIP'
)
b2sums=(
  '1e83d5c062fa3700c23e2527812cb43daa1a5f97c7520c0a894c8333fbad4acd64586fdc3bf76e3692f8b9fa9b92014d18782949d0e30e80d0f2ba3608279f63'
  'SKIP'
)
validpgpkeys=('0338C8D8D9FDA62CF9C421BD7EC2DBB6F4DBF434') # The libjpeg-turbo Project <information@libjpeg-turbo.org>

build() {
  local cmake_options=(
    -B build
    -S "${_name}-${pkgver}"
    -G Ninja
    -W no-dev
    -D CMAKE_INSTALL_PREFIX=/usr
    -D CMAKE_INSTALL_LIBDIR=/usr/lib32
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_C_STANDARD=23
    -D CMAKE_CXX_STANDARD=23
    -D ENABLE_STATIC=OFF
    -D WITH_JAVA=OFF
    -D WITH_JPEG8=ON
    -D WITH_TURBOJPEG=ON
    -D REQUIRE_SIMD=ON
  )

  export CC="clang -m32"
  export CXX="clang++ -m32"
  export PKG_CONFIG="i686-pc-linux-gnu-pkg-config"

  cmake "${cmake_options[@]}"
  cmake --build build -v
}

check() {
  ctest --test-dir build --output-on-failure --stop-on-failure -j"$(nproc)"
}

package() {
  DESTDIR="${pkgdir}" cmake --install build -v

  # These are provided by the native libjpeg-turbo package.
  rm -rf "${pkgdir}"/usr/{include,share,bin}

  install -vDm 644 "${_name}-${pkgver}"/LICENSE.md -t "${pkgdir}/usr/share/licenses/${pkgname}/"
  install -vDm 644 "${_name}-${pkgver}"/README.ijg -t "${pkgdir}/usr/share/licenses/${pkgname}/"
}
