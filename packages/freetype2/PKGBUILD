validpgpkeys=('E30674707856409FF1948010BE6C3AAC63AD8E3F')

# Aggressive PGO-only instrumentation flags.
_pgo_instr_flags='-g3 -fno-omit-frame-pointer -Xclang -mllvm -Xclang -vp-counters-per-site=150 -Xclang -mllvm -Xclang -runtime-counter-relocation -Xclang -mllvm -Xclang -enable-value-profiling'

_meson_common=(
  -Dfreetype2:default_library=shared
  -Dfreetype2:brotli=enabled
  -Dfreetype2:bzip2=enabled
  -Dfreetype2:png=enabled
  -Dfreetype2:zlib=system
  -Dfreetype2:harfbuzz=enabled
  -Dfreetype2:tests=disabled
  -Db_ndebug=true
  -Db_pie=false
  -Dc_std=gnu2x
  -Dcpp_std=gnu++2a
  --unity=on
  --buildtype=release
  --wrap-mode=nodownload
)

_prof_count() {
  local _dir="$1"
  find "$_dir" -maxdepth 1 -type f -name '*.profraw' 2>/dev/null | wc -l
}

_prof_bytes() {
  local _dir="$1"
  find "$_dir" -maxdepth 1 -type f -name '*.profraw' -printf '%s\n' 2>/dev/null | awk '{s+=$1} END{print s+0}'
}

_prof_diag() {
  local _label="$1"
  local _dir="$2"
  printf '  -> [PGO] %s: profraw files=%s bytes=%s dir=%s\n' \
    "$_label" "$(_prof_count "$_dir")" "$(_prof_bytes "$_dir")" "$_dir"
}

_supports_flag() {
  local _flag="$1"
  local _tdir="$srcdir/.flagcheck-${_flag//[^[:alnum:]]/_}"

  rm -rf "$_tdir"
  mkdir -p "$_tdir"

  cat > "${_tdir}/t.c" <<'EOF'
int main(void) { return 0; }
EOF

  "$CC" "${_tdir}/t.c" -o "${_tdir}/t" ${LDFLAGS} "$_flag" >/dev/null 2>&1
}

prepare() {
  # Apply patches to freetype source first.
  patch -d "freetype-${pkgver}" -Np1 < "0001-Enable-table-validation-modules.patch"
  patch -d "freetype-${pkgver}" -Np1 < "0002-Enable-subpixel-rendering.patch"
  patch -d "freetype-${pkgver}" -Np1 < "0003-Enable-long-PCF-family-names.patch"

  # Patch demos.
  patch -d "ft2demos-${pkgver}" -Np1 < "0001-meson.build-Add-missing-math_dep-for-SVG-support.patch"

  # Deterministic local subproject; no symlink ambiguity, no git clone fallback.
  rm -rf "ft2demos-${pkgver}/subprojects/freetype2"
  mkdir -p "ft2demos-${pkgver}/subprojects"
  cp -a "freetype-${pkgver}" "ft2demos-${pkgver}/subprojects/freetype2"

  # Fix sandbox warning: replace hardcoded cross-subproject internal include path.
  mkdir -p "ft2demos-${pkgver}/src/truetype-headers"
  cp -af "freetype-${pkgver}/src/truetype/"*.h "ft2demos-${pkgver}/src/truetype-headers/"

  python3 - <<'PY'
from pathlib import Path
p = Path("ft2demos-2.14.3/meson.build")
s = p.read_text(encoding="utf-8")
old = "subprojects/freetype2/src/truetype"
new = "src/truetype-headers"
if old in s:
    s = s.replace(old, new)
p.write_text(s, encoding="utf-8")
PY

  if grep -q "subprojects/freetype2/src/truetype" "ft2demos-${pkgver}/meson.build"; then
    echo "ERROR: sandbox include path patch did not apply" >&2
    return 1
  fi

  [[ -f "ft2demos-${pkgver}/subprojects/freetype2/meson.build" ]] || {
    echo "ERROR: local freetype2 subproject is not buildable" >&2
    return 1
  }
}

_train() {
  local bin="$1"

  echo ":: Running training workload from $bin"

  if [[ ! -x "$bin/ftdump" ]]; then
    echo "   Warning: ftdump not found, skipping training"
    return 0
  fi

  local txt_en="The quick brown fox jumps over the lazy dog 0123456789"
  local txt_de="Groesse ueberpruefen: Aepfel, Oel & Wuerstchen kosten EUR12,50"

  local font_patterns=(
    'DejaVuSans.ttf'
    'LiberationSans-Regular.ttf'
    'NotoSans-Regular.ttf'
    'Roboto-Regular.ttf'
    'Inter-Regular.otf'
    'Cantarell-Regular.otf'
    'DejaVuSerif.ttf'
    'LiberationSerif-Regular.ttf'
    'NotoSerif-Regular.ttf'
    'DejaVuSansMono.ttf'
    'LiberationMono-Regular.ttf'
    'JetBrainsMono-Regular.ttf'
    'FiraCode-Regular.ttf'
    'SourceCodePro-Regular.otf'
    'Hack-Regular.ttf'
  )

  local -a fonts=()
  local pattern
  for pattern in "${font_patterns[@]}"; do
    local found
    found="$(find /usr/share/fonts -type f -name "$pattern" 2>/dev/null | head -n1)"
    [[ -n "$found" ]] && fonts+=("$found")
  done

  if (( ${#fonts[@]} < 5 )); then
    echo "   Few priority fonts found, adding fallbacks..."
    mapfile -t -O "${#fonts[@]}" fonts < <(
      find /usr/share/fonts -type f \( -iname '*sans*.ttf' -o -iname '*serif*.ttf' \) 2>/dev/null | head -10
    )
  fi

  if (( ${#fonts[@]} == 0 )); then
    echo "   Warning: no fonts found, skipping training"
    return 0
  fi

  echo "   Processing ${#fonts[@]} fonts..."

  local f
  for f in "${fonts[@]}"; do
    "$bin/ftdump" -q "$f" >/dev/null 2>&1 || true

    if [[ -x "$bin/ftstring" ]]; then
      "$bin/ftstring" -f "$f" -r 11 "$txt_en" >/dev/null 2>&1 || true
      "$bin/ftstring" -f "$f" -r 14 "$txt_de" >/dev/null 2>&1 || true
      "$bin/ftstring" -f "$f" -r 18 "$txt_en" >/dev/null 2>&1 || true
    fi

    if [[ -x "$bin/ftbench" ]]; then
      "$bin/ftbench" -c 50 "$f" >/dev/null 2>&1 || true
    fi
  done

  echo ":: Training complete (${#fonts[@]} fonts)"
}

build() {
  export CC=clang
  export CXX=clang++
  export MESON_PACKAGE_CACHE_DIR="$srcdir"

  local _orig_cflags="${CFLAGS:-}"
  local _orig_cxxflags="${CXXFLAGS:-}"
  local _orig_ldflags="${LDFLAGS:-}"

  local pgo_gen="$srcdir/pgo-gen"
  local pgo_cs="$srcdir/pgo-cs"

  rm -rf "$pgo_gen" "$pgo_cs" "$srcdir/build-gen" "$srcdir/build-cs" "$srcdir/build-final" \
         "$srcdir/gen.profdata" "$srcdir/merged.profdata"
  mkdir -p "$pgo_gen" "$pgo_cs"

  local can_ir_pgo=1
  local can_cs_pgo=1

  if ! _supports_flag "-fprofile-generate"; then
    warning "Toolchain cannot link -fprofile-generate, building without PGO"
    can_ir_pgo=0
    can_cs_pgo=0
  fi

  if (( can_ir_pgo )) && ! _supports_flag "-fcs-profile-generate"; then
    warning "Toolchain lacks -fcs-profile-generate, using regular PGO only"
    can_cs_pgo=0
  fi

  if (( can_ir_pgo )); then
    msg2 'Pass 1: Collecting standard profile'

    local cflags_gen="${_orig_cflags} ${_pgo_instr_flags} -fprofile-generate=${pgo_gen}"
    local cxxflags_gen="${_orig_cxxflags} ${_pgo_instr_flags} -fprofile-generate=${pgo_gen}"
    local ldflags_gen="${_orig_ldflags} -fprofile-generate=${pgo_gen} -fuse-ld=lld"

    arch-meson "ft2demos-${pkgver}" "$srcdir/build-gen" \
      "${_meson_common[@]}" \
      -Dc_args="${cflags_gen}" \
      -Dcpp_args="${cxxflags_gen}" \
      -Dc_link_args="${ldflags_gen}" \
      -Dcpp_link_args="${ldflags_gen}"

    meson compile -C "$srcdir/build-gen"
    meson test -C "$srcdir/build-gen" --print-errorlogs --no-rebuild --num-processes "$(nproc)" || true
    _prof_diag "after pass1 meson test" "$pgo_gen"

    local _pre_count _pre_bytes _post_count _post_bytes
    _pre_count="$(_prof_count "$pgo_gen")"
    _pre_bytes="$(_prof_bytes "$pgo_gen")"

    _train "$srcdir/build-gen"

    _post_count="$(_prof_count "$pgo_gen")"
    _post_bytes="$(_prof_bytes "$pgo_gen")"
    printf '  -> [PGO] pass1 custom training delta: files=%d bytes=%d (before f=%d b=%d, after f=%d b=%d)\n' \
      "$((_post_count - _pre_count))" "$((_post_bytes - _pre_bytes))" \
      "$_pre_count" "$_pre_bytes" "$_post_count" "$_post_bytes"

    if compgen -G "$pgo_gen/*.profraw" >/dev/null; then
      llvm-profdata merge -output="$srcdir/gen.profdata" "$pgo_gen"/*.profraw
    else
      error "No profile data generated in Pass 1"
      return 1
    fi
  fi

  if (( can_cs_pgo )); then
    msg2 'Pass 2: Collecting context-sensitive profile'

    local cflags_cs="${_orig_cflags} ${_pgo_instr_flags} -fprofile-use=${srcdir}/gen.profdata -fcs-profile-generate=${pgo_cs}"
    local cxxflags_cs="${_orig_cxxflags} ${_pgo_instr_flags} -fprofile-use=${srcdir}/gen.profdata -fcs-profile-generate=${pgo_cs}"
    local ldflags_cs="${_orig_ldflags} -fprofile-use=${srcdir}/gen.profdata -fcs-profile-generate=${pgo_cs} -fuse-ld=lld"

    arch-meson "ft2demos-${pkgver}" "$srcdir/build-cs" \
      "${_meson_common[@]}" \
      -Dc_args="${cflags_cs}" \
      -Dcpp_args="${cxxflags_cs}" \
      -Dc_link_args="${ldflags_cs}" \
      -Dcpp_link_args="${ldflags_cs}"

    meson compile -C "$srcdir/build-cs"
    meson test -C "$srcdir/build-cs" --print-errorlogs --no-rebuild --num-processes "$(nproc)" || true
    _prof_diag "after pass2 meson test" "$pgo_cs"

    local _cs_pre_count _cs_pre_bytes _cs_post_count _cs_post_bytes
    _cs_pre_count="$(_prof_count "$pgo_cs")"
    _cs_pre_bytes="$(_prof_bytes "$pgo_cs")"

    _train "$srcdir/build-cs"

    _cs_post_count="$(_prof_count "$pgo_cs")"
    _cs_post_bytes="$(_prof_bytes "$pgo_cs")"
    printf '  -> [PGO] pass2 custom training delta: files=%d bytes=%d (before f=%d b=%d, after f=%d b=%d)\n' \
      "$((_cs_post_count - _cs_pre_count))" "$((_cs_post_bytes - _cs_pre_bytes))" \
      "$_cs_pre_count" "$_cs_pre_bytes" "$_cs_post_count" "$_cs_post_bytes"

    if compgen -G "$pgo_cs/*.profraw" >/dev/null; then
      llvm-profdata merge -output="$srcdir/merged.profdata" \
        "$pgo_cs"/*.profraw \
        "$srcdir/gen.profdata"
    else
      warning "No profile data generated in Pass 2, using pass1 profile"
      cp -f "$srcdir/gen.profdata" "$srcdir/merged.profdata"
    fi
  elif (( can_ir_pgo )) && [[ -f "$srcdir/gen.profdata" ]]; then
    cp -f "$srcdir/gen.profdata" "$srcdir/merged.profdata"
  fi

  msg2 'Pass 3: Final optimised build'

  local cflags_final="${_orig_cflags}"
  local cxxflags_final="${_orig_cxxflags}"
  local ldflags_final="${_orig_ldflags} -fuse-ld=lld"

  if [[ -f "$srcdir/merged.profdata" ]]; then
    cflags_final+=" -fprofile-use=${srcdir}/merged.profdata"
    cxxflags_final+=" -fprofile-use=${srcdir}/merged.profdata"
    ldflags_final+=" -fprofile-use=${srcdir}/merged.profdata"
  fi

  arch-meson "ft2demos-${pkgver}" "$srcdir/build-final" \
    "${_meson_common[@]}" \
    -Dc_args="${cflags_final}" \
    -Dcpp_args="${cxxflags_final}" \
    -Dc_link_args="${ldflags_final}" \
    -Dcpp_link_args="${ldflags_final}"

  meson compile -C "$srcdir/build-final"
}

check() {
  meson test -C "$srcdir/build-final" --print-errorlogs
}

package_freetype2() {
  provides=(libfreetype.so)
  install=freetype2.install
  backup=(etc/profile.d/freetype2.sh)

  meson install -C "$srcdir/build-final" --destdir="$pkgdir"
  install -Dm644 freetype2.sh -t "$pkgdir/etc/profile.d"
}

