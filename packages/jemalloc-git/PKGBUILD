pkgname=jemalloc-git
pkgver=5.3.1.r0.g81034ce1
pkgrel=1
pkgdesc='General-purpose malloc(3) implementation emphasizing fragmentation avoidance and scalable concurrency support'
arch=('x86_64' 'aarch64')
url='https://jemalloc.net/'
license=('BSD-2-Clause')
depends=('glibc' 'sh')
makedepends=('git' 'clang' 'llvm')
optdepends=('perl: for running jeprof')
provides=("jemalloc=${pkgver%%.r*}")
conflicts=('jemalloc')
options=('staticlibs')
source=("git+https://github.com/jemalloc/jemalloc.git")
sha256sums=('SKIP')

pkgver() {
  cd jemalloc
  git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  cd jemalloc

  # Preserve original makepkg flags (may include -flto from makepkg.conf)
  local _cflags_orig="$CFLAGS"
  local _cxxflags_orig="$CXXFLAGS"
  local _ldflags_orig="$LDFLAGS"

  # Shared configure options — kept identical across all PGO stages so that
  # profile data accurately reflects the final binary's code paths.
  local _confopts=(
    --prefix=/usr
    --disable-debug
    --disable-log
    --enable-prof
    --disable-doc
  )

  ############################################################
  # Stage 1: Instrumented build (initial PGO profile)
  ############################################################
  echo '==> Stage 1/3: Building with PGO instrumentation...'
  export LLVM_PROFILE_FILE="$srcdir/pgo-stage1-%p.profraw"
  export CFLAGS="$_cflags_orig -fprofile-generate -fno-omit-frame-pointer \
    -Xclang -mllvm -Xclang -vp-counters-per-site=150 \
    -Xclang -mllvm -Xclang -runtime-counter-relocation \
    -Xclang -mllvm -Xclang -enable-value-profiling"
  export CXXFLAGS="$_cxxflags_orig -fprofile-generate -fno-omit-frame-pointer \
    -Xclang -mllvm -Xclang -vp-counters-per-site=150 \
    -Xclang -mllvm -Xclang -runtime-counter-relocation \
    -Xclang -mllvm -Xclang -enable-value-profiling"
  export LDFLAGS="$_ldflags_orig -fprofile-generate"

  ./autogen.sh
  ./configure "${_confopts[@]}"
  make

  echo '==> Running training workload (Stage 1)...'
  _run_pgo_training

  echo '==> Merging Stage 1 profile data...'
  llvm-profdata merge -output="$srcdir/stage1.profdata" \
    "$srcdir"/pgo-stage1-*.profraw
  rm -f "$srcdir"/pgo-stage1-*.profraw

  make clean

  ############################################################
  # Stage 2: CS-PGO instrumented build (context-sensitive)
  ############################################################
  echo '==> Stage 2/3: Building with CS-PGO instrumentation...'
  export LLVM_PROFILE_FILE="$srcdir/pgo-stage2-%p.profraw"
  export CFLAGS="$_cflags_orig -fprofile-use=$srcdir/stage1.profdata \
    -fcs-profile-generate -fno-omit-frame-pointer \
    -Xclang -mllvm -Xclang -vp-counters-per-site=150 \
    -Xclang -mllvm -Xclang -runtime-counter-relocation \
    -Xclang -mllvm -Xclang -enable-value-profiling"
  export CXXFLAGS="$_cxxflags_orig -fprofile-use=$srcdir/stage1.profdata \
    -fcs-profile-generate -fno-omit-frame-pointer \
    -Xclang -mllvm -Xclang -vp-counters-per-site=150 \
    -Xclang -mllvm -Xclang -runtime-counter-relocation \
    -Xclang -mllvm -Xclang -enable-value-profiling"
  export LDFLAGS="$_ldflags_orig -fprofile-use=$srcdir/stage1.profdata \
    -fcs-profile-generate"

  ./autogen.sh
  ./configure "${_confopts[@]}"
  make

  echo '==> Running training workload (Stage 2)...'
  _run_pgo_training

  echo '==> Merging CS-PGO profile data...'
  llvm-profdata merge -output="$srcdir/cs.profdata" \
    "$srcdir"/pgo-stage2-*.profraw \
    "$srcdir/stage1.profdata"
  rm -f "$srcdir"/pgo-stage2-*.profraw

  make clean

  ############################################################
  # Stage 3: Final optimized build with merged CS-PGO data
  ############################################################
  echo '==> Stage 3/3: Building final optimized binary...'
  export CFLAGS="$_cflags_orig -fprofile-use=$srcdir/cs.profdata"
  export CXXFLAGS="$_cxxflags_orig -fprofile-use=$srcdir/cs.profdata"
  export LDFLAGS="$_ldflags_orig -fprofile-use=$srcdir/cs.profdata"

  ./autogen.sh
  ./configure "${_confopts[@]}"
  make
}

# ---------------------------------------------------------------------------
# Helper: compile and run the PGO training workload.
# Must be called from inside the source directory (cd jemalloc).
# ---------------------------------------------------------------------------
_run_pgo_training() {
  # Part 1: Run jemalloc's own test suite for broad code-path coverage
  make check || warning 'Some tests failed — continuing PGO process'

  # Part 2: Custom training program exercising all allocator APIs
  cat > "$srcdir/pgo_train.c" << 'TRAINEOF'
#include <stdlib.h>
#include <stdio.h>
#include <string.h>
#include <stdint.h>
#include <pthread.h>
#include <sys/time.h>
#include <errno.h>
#include <jemalloc/jemalloc.h>

/* ---- tunables ---- */
#define NUM_THREADS    8
#define ITERATIONS     1000
#define MAX_SLOTS      10000
#define MAX_HUGE_MB    5

typedef struct {
    void  *ptrs[MAX_SLOTS];
    size_t sizes[MAX_SLOTS];
    int    count;
    int    id;
    pthread_mutex_t lock;
} tdata_t;

/* Atomically claim the next slot index (wraps around) */
static inline int next_slot(tdata_t *d)
{
    int idx;
    pthread_mutex_lock(&d->lock);
    idx = (d->count++) % MAX_SLOTS;
    pthread_mutex_unlock(&d->lock);
    return idx;
}

/* Release any allocator-originated pointer */
static inline void release(void *p)
{
    if (p) free(p);
}

/* ---- allocation pattern functions ---- */

static void pat_small(tdata_t *d)
{
    for (int i = 0; i < ITERATIONS; i++) {
        int idx = next_slot(d);
        release(d->ptrs[idx]);
        size_t sz = (size_t)(rand() % 256) + 1;
        d->ptrs[idx] = malloc(sz);
        if (!d->ptrs[idx]) continue;
        d->sizes[idx] = sz;
        memset(d->ptrs[idx], 1, sz);
    }
}

static void pat_medium(tdata_t *d)
{
    for (int i = 0; i < ITERATIONS / 2; i++) {
        int idx = next_slot(d);
        release(d->ptrs[idx]);
        size_t sz = (size_t)(rand() % 3840) + 256;
        d->ptrs[idx] = malloc(sz);
        if (!d->ptrs[idx]) continue;
        d->sizes[idx] = sz;
        memset(d->ptrs[idx], 2, sz);
    }
}

static void pat_large(tdata_t *d)
{
    for (int i = 0; i < ITERATIONS / 10; i++) {
        int idx = next_slot(d);
        release(d->ptrs[idx]);
        size_t sz = (size_t)(rand() % (1048576 - 4096)) + 4096;
        d->ptrs[idx] = malloc(sz);
        if (!d->ptrs[idx]) continue;
        d->sizes[idx] = sz;
        memset(d->ptrs[idx], 3, sz < 10240 ? sz : 10240);
    }
}

static void pat_huge(tdata_t *d)
{
    for (int i = 0; i < ITERATIONS / 100; i++) {
        int idx = next_slot(d);
        release(d->ptrs[idx]);
        size_t sz = (size_t)(rand() % (MAX_HUGE_MB * 1048576)) + 1048576;
        d->ptrs[idx] = malloc(sz);
        if (!d->ptrs[idx]) continue;
        d->sizes[idx] = sz;
        memset(d->ptrs[idx], 4, sz < 10240 ? sz : 10240);
    }
}

static void pat_realloc(tdata_t *d)
{
    for (int i = 0; i < ITERATIONS / 2; i++) {
        int cnt, idx;
        pthread_mutex_lock(&d->lock);
        cnt = d->count;
        pthread_mutex_unlock(&d->lock);
        if (cnt == 0) continue;
        idx = rand() % (cnt < MAX_SLOTS ? cnt : MAX_SLOTS);
        if (!d->ptrs[idx]) continue;

        size_t cur = d->sizes[idx];
        int delta = (rand() % 1024) - 512;
        size_t nsz;
        if (delta < 0 && (size_t)(-delta) > cur)
            nsz = 1;
        else
            nsz = cur + (size_t)delta;
        if (nsz < 1) nsz = 1;

        void *np = realloc(d->ptrs[idx], nsz);
        if (!np) continue;
        d->ptrs[idx] = np;
        d->sizes[idx] = nsz;
        memset(np, 5, nsz < 10240 ? nsz : 10240);
    }
}

static void pat_calloc(tdata_t *d)
{
    for (int i = 0; i < ITERATIONS / 2; i++) {
        int idx = next_slot(d);
        release(d->ptrs[idx]);
        size_t n = (size_t)(rand() % 100) + 1;
        size_t s = (size_t)(rand() % 100) + 1;
        d->ptrs[idx] = calloc(n, s);
        if (!d->ptrs[idx]) continue;
        d->sizes[idx] = n * s;
    }
}

static void pat_aligned(tdata_t *d)
{
    for (int i = 0; i < ITERATIONS / 4; i++) {
        int idx = next_slot(d);
        release(d->ptrs[idx]);
        size_t align = (size_t)1 << (rand() % 8 + 3); /* 8 .. 1024 */
        size_t sz    = align * ((size_t)(rand() % 100) + 1);
        d->ptrs[idx] = aligned_alloc(align, sz);
        if (!d->ptrs[idx]) continue;
        d->sizes[idx] = sz;
        memset(d->ptrs[idx], 6, sz);
    }
}

static void pat_mallocx(tdata_t *d)
{
    for (int i = 0; i < ITERATIONS / 4; i++) {
        int idx = next_slot(d);
        /* Use dallocx for mallocx-originated allocations */
        if (d->ptrs[idx]) {
            dallocx(d->ptrs[idx], 0);
            d->ptrs[idx] = NULL;
        }

        size_t   sz = (size_t)(rand() % 1024) + 256;
        unsigned fl = 0;
        if (rand() % 4 == 0) fl |= MALLOCX_ZERO;
        if (rand() % 4 == 0) {
            size_t a = (size_t)1 << (rand() % 8 + 3);
            fl |= MALLOCX_ALIGN(a);
        }

        d->ptrs[idx] = mallocx(sz, fl);
        if (!d->ptrs[idx]) continue;
        d->sizes[idx] = sz;

        if (!(fl & MALLOCX_ZERO))
            memset(d->ptrs[idx], 7, sz);

        /* Grow via rallocx */
        if (rand() % 4 == 0) {
            size_t nsz = sz + (size_t)(rand() % 512);
            void *np = rallocx(d->ptrs[idx], nsz, fl);
            if (np) { d->ptrs[idx] = np; d->sizes[idx] = nsz; }
        }

        /* Exercise sallocx */
        if (rand() % 3 == 0)
            (void)sallocx(d->ptrs[idx], 0);

        /* Exercise malloc_usable_size */
        if (rand() % 3 == 0)
            (void)malloc_usable_size(d->ptrs[idx]);
    }
}

/* Exercise mallctl code paths for arena/tcache/epoch coverage */
static void pat_mallctl(void)
{
    size_t sz, val;
    sz = sizeof(val);
    mallctl("opt.narenas",             &val, &sz, NULL, 0);
    mallctl("thread.tcache.enabled",   &val, &sz, NULL, 0);

    size_t allocated = 0, deallocated = 0;
    sz = sizeof(allocated);
    mallctl("thread.allocated",        &allocated,   &sz, NULL, 0);
    mallctl("thread.deallocated",      &deallocated, &sz, NULL, 0);

    mallctl("thread.tcache.flush",     NULL, NULL, NULL, 0);

    uint64_t epoch = 1;
    sz = sizeof(epoch);
    mallctl("epoch", &epoch, &sz, &epoch, sz);
}

static void pat_mixed(tdata_t *d)
{
    switch (rand() % 8) {
        case 0: pat_small(d);   break;
        case 1: pat_medium(d);  break;
        case 2: pat_large(d);   break;
        case 3: pat_huge(d);    break;
        case 4: pat_realloc(d); break;
        case 5: pat_calloc(d);  break;
        case 6: pat_aligned(d); break;
        case 7: pat_mallocx(d); break;
    }
}

static void cleanup(tdata_t *d)
{
    for (int i = 0; i < MAX_SLOTS; i++)
        release(d->ptrs[i]);
}

static void *thread_fn(void *arg)
{
    tdata_t *d = arg;

    /* Warmup with randomized mixed patterns */
    for (int i = 0; i < MAX_SLOTS / 10; i++)
        pat_mixed(d);

    /* Exercise every size class and API */
    pat_small(d);   pat_medium(d);
    pat_large(d);   pat_huge(d);
    pat_realloc(d); pat_calloc(d);
    pat_aligned(d); pat_mallocx(d);

    /* Exercise mallctl code paths */
    pat_mallctl();

    /* Extended mixed-phase training */
    for (int i = 0; i < 20; i++)
        pat_mixed(d);

    cleanup(d);
    return NULL;
}

int main(void)
{
    struct timeval tv;
    gettimeofday(&tv, NULL);
    srand((unsigned)(tv.tv_sec ^ tv.tv_usec));

    printf("jemalloc PGO training: starting...\n");
    for (int r = 0; r < 3; r++) {
        pthread_t thr[NUM_THREADS];
        tdata_t   td[NUM_THREADS];
        int i;

        for (i = 0; i < NUM_THREADS; i++) {
            memset(&td[i], 0, sizeof(td[i]));
            td[i].id = i;
            pthread_mutex_init(&td[i].lock, NULL);
        }
        for (i = 0; i < NUM_THREADS; i++)
            pthread_create(&thr[i], NULL, thread_fn, &td[i]);
        for (i = 0; i < NUM_THREADS; i++) {
            pthread_join(thr[i], NULL);
            pthread_mutex_destroy(&td[i].lock);
        }
        printf("  pass %d/3 done\n", r + 1);
    }
    printf("jemalloc PGO training: complete\n");
    return 0;
}
TRAINEOF

  # Compile with the same toolchain the library was built with
  $CC -O2 -march=native -DJEMALLOC -I./include \
    -o "$srcdir/pgo_train" "$srcdir/pgo_train.c" \
    -L./lib -ljemalloc -pthread

  # Execute under the instrumented jemalloc library
  LD_LIBRARY_PATH=./lib \
  MALLOC_CONF='background_thread:true,narenas:8,tcache:true,prof:true' \
    "$srcdir/pgo_train"
}

check() {
  cd jemalloc
  make check
}

package() {
  cd jemalloc

  make DESTDIR="$pkgdir" install

  install -Dm644 COPYING -t "$pkgdir/usr/share/licenses/$pkgname"

  # Ensure static library has correct permissions
  find "$pkgdir" -name '*.a' -type f -exec chmod 644 {} \;
}
