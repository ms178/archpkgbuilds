From d4b8cf37a7479510f5cb7fa295319d986b920050 Mon Sep 17 00:00:00 2001
From: Arena Agent <agent@example.invalid>
Date: Wed, 17 Jun 2026 13:36:55 +0000
Subject: [PATCH 1/4] build: use llvm-mingw cross files with flag placeholders

---
 build-win32.txt | 10 ++++++++--
 build-win64.txt | 10 ++++++++--
 2 files changed, 16 insertions(+), 4 deletions(-)

diff --git a/build-win32.txt b/build-win32.txt
index 37ab36d..85a3720 100644
--- a/build-win32.txt
+++ b/build-win32.txt
@@ -1,10 +1,16 @@
 [binaries]
-c = 'i686-w64-mingw32-gcc'
-cpp = 'i686-w64-mingw32-g++'
+c = 'i686-w64-mingw32-clang'
+cpp = 'i686-w64-mingw32-clang++'
 ar = 'i686-w64-mingw32-ar'
 strip = 'i686-w64-mingw32-strip'
 widl-mingw-tools-fallback = 'i686-w64-mingw32-widl'
 
+[built-in options]
+c_args = [@CARGS@]
+cpp_args = [@CXXARGS@]
+c_link_args = [@LDARGS@]
+cpp_link_args = [@LDARGS@]
+
 [properties]
 needs_exe_wrapper = true
 
diff --git a/build-win64.txt b/build-win64.txt
index 613d192..163f868 100644
--- a/build-win64.txt
+++ b/build-win64.txt
@@ -1,10 +1,16 @@
 [binaries]
-c = 'x86_64-w64-mingw32-gcc'
-cpp = 'x86_64-w64-mingw32-g++'
+c = 'x86_64-w64-mingw32-clang'
+cpp = 'x86_64-w64-mingw32-clang++'
 ar = 'x86_64-w64-mingw32-ar'
 strip = 'x86_64-w64-mingw32-strip'
 widl-mingw-tools-fallback = 'x86_64-w64-mingw32-widl'
 
+[built-in options]
+c_args = [@CARGS@]
+cpp_args = [@CXXARGS@]
+c_link_args = [@LDARGS@]
+cpp_link_args = [@LDARGS@]
+
 [properties]
 needs_exe_wrapper = true
 
