--- a/Makefile.in	2026-06-18 17:03:38.696484479 +0000
+++ b/Makefile.in	2026-06-18 17:03:39.176484479 +0000
@@ -1980,6 +1980,11 @@
 # protonfixes bundles old autotools/libtool projects (libmspack, cabextract,
 # procps-ng, Debian unzip). Build them with GCC/binutils to avoid libtool/LTO
 # breakage and nested makefiles accidentally consuming clang-only flags.
+# Important: do not override LD with $(target)-gcc here. Autotools/libtool
+# projects expect LD to be the real linker (or to be auto-detected). Forcing
+# LD=gcc makes libtool mis-detect the linker and skip producing shared objects
+# such as libproc2.so, which later breaks ps/pscommand with
+# "cannot find ./.libs/libproc2.so".
 PROTONFIXES_USE_GCC = 1
 
 $(eval $(call rules-source,protonfixes,$(SRCDIR)/protonfixes))
@@ -1990,21 +1995,18 @@
 	$(foreach p,$(shell find $(PATCHES_SRC)/protonfixes/ -name "*.patch" | sort),patch -d $(PROTONFIXES_SRC) -Np1 -i $(p) &&) true
 	touch $@
 
-PROTONFIXES_x86_64_MAKE_ARGS = CC="$(x86_64-unix_TARGET)-gcc" CXX="$(x86_64-unix_TARGET)-g++" AR="$(x86_64-unix_TARGET)-ar" RANLIB="$(x86_64-unix_TARGET)-ranlib" NM="$(x86_64-unix_TARGET)-nm" LD="$(x86_64-unix_TARGET)-gcc" STRIP="$(x86_64-unix_TARGET)-strip"
-PROTONFIXES_aarch64_MAKE_ARGS = CC="$(aarch64-unix_TARGET)-gcc" CXX="$(aarch64-unix_TARGET)-g++" AR="$(aarch64-unix_TARGET)-ar" RANLIB="$(aarch64-unix_TARGET)-ranlib" NM="$(aarch64-unix_TARGET)-nm" LD="$(aarch64-unix_TARGET)-gcc" STRIP="$(aarch64-unix_TARGET)-strip"
-
 $(OBJ)/.protonfixes-x86_64-build:
 	cd $(PROTONFIXES_SRC) && \
-	env $(PROTONFIXES_x86_64_ENV) BUILD=$(PROTONFIXES_x86_64_OBJ) TARGET_ARCH=$(TARGET_ARCH) $(MAKE) $(PROTONFIXES_x86_64_MAKE_ARGS)
+	env $(PROTONFIXES_x86_64_ENV) BUILD=$(PROTONFIXES_x86_64_OBJ) TARGET_ARCH=$(TARGET_ARCH) $(MAKE)
 	cd $(PROTONFIXES_SRC) && \
-	env $(PROTONFIXES_x86_64_ENV) BUILD=$(PROTONFIXES_x86_64_OBJ) DIST=$(PROTONFIXES_x86_64_DST) TARGET_ARCH=$(TARGET_ARCH) $(MAKE) $(PROTONFIXES_x86_64_MAKE_ARGS) install
+	env $(PROTONFIXES_x86_64_ENV) BUILD=$(PROTONFIXES_x86_64_OBJ) DIST=$(PROTONFIXES_x86_64_DST) TARGET_ARCH=$(TARGET_ARCH) $(MAKE) install
 	touch $@
 
 $(OBJ)/.protonfixes-aarch64-build:
 	cd $(PROTONFIXES_SRC) && \
-	env $(PROTONFIXES_aarch64_ENV) BUILD=$(PROTONFIXES_aarch64_OBJ) TARGET_ARCH=$(TARGET_ARCH) $(MAKE) $(PROTONFIXES_aarch64_MAKE_ARGS)
+	env $(PROTONFIXES_aarch64_ENV) BUILD=$(PROTONFIXES_aarch64_OBJ) TARGET_ARCH=$(TARGET_ARCH) $(MAKE)
 	cd $(PROTONFIXES_SRC) && \
-	env $(PROTONFIXES_aarch64_ENV) BUILD=$(PROTONFIXES_aarch64_OBJ) DIST=$(PROTONFIXES_aarch64_DST) TARGET_ARCH=$(TARGET_ARCH) $(MAKE) $(PROTONFIXES_aarch64_MAKE_ARGS) install
+	env $(PROTONFIXES_aarch64_ENV) BUILD=$(PROTONFIXES_aarch64_OBJ) DIST=$(PROTONFIXES_aarch64_DST) TARGET_ARCH=$(TARGET_ARCH) $(MAKE) install
 	touch $@
 
 PROTONFIXES_TARGET := $(addprefix $(DST_BASE)/,protonfixes)
