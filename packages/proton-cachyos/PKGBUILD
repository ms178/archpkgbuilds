_make_wrappers () {
    #     _arch     prefix   gcc    ld             as     strip
    local _i686=(  "i686"   "-m32" "-melf_i386"   "--32" "elf32-i386")
    local _x86_64=("x86_64" "-m64" "-melf_x86_64" "--64" "elf64-x86-64")
    local _opts=(_i686 _x86_64)
    declare -n _opt
    for _opt in "${_opts[@]}"; do
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-pc-linux-gnu-ar <<EOF
#!/usr/bin/bash
if [[ "\${PROTON_FORCE_GCC:-}" == 1 ]]; then exec /usr/bin/gcc-ar "\$@"; fi
exec llvm-ar "\$@"
EOF
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-pc-linux-gnu-ranlib <<EOF
#!/usr/bin/bash
if [[ "\${PROTON_FORCE_GCC:-}" == 1 ]]; then exec /usr/bin/gcc-ranlib "\$@"; fi
exec llvm-ranlib "\$@"
EOF
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-pc-linux-gnu-nm <<EOF
#!/usr/bin/bash
if [[ "\${PROTON_FORCE_GCC:-}" == 1 ]]; then exec /usr/bin/gcc-nm "\$@"; fi
exec llvm-nm "\$@"
EOF
        ln -sf /usr/bin/llvm-strip wrappers/${_opt[0]}-pc-linux-gnu-strip
        ln -sf /usr/bin/llvm-objcopy wrappers/${_opt[0]}-pc-linux-gnu-objcopy
        ln -sf /usr/bin/llvm-objdump wrappers/${_opt[0]}-pc-linux-gnu-objdump
        ln -sf /usr/bin/llvm-readelf wrappers/${_opt[0]}-pc-linux-gnu-readelf
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-pc-linux-gnu-gcc <<EOF
#!/usr/bin/bash
if [[ "\${PROTON_FORCE_GCC:-}" == 1 ]]; then exec $(which ccache 2> /dev/null) /usr/bin/gcc ${_opt[1]} "\$@"; fi
exec $(which ccache 2> /dev/null) clang ${_opt[1]} "\$@"
EOF
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-pc-linux-gnu-g++ <<EOF
#!/usr/bin/bash
if [[ "\${PROTON_FORCE_GCC:-}" == 1 ]]; then exec $(which ccache 2> /dev/null) /usr/bin/g++ ${_opt[1]} "\$@"; fi
exec $(which ccache 2> /dev/null) clang++ ${_opt[1]} "\$@"
EOF
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-pc-linux-gnu-ld <<EOF
#!/usr/bin/bash
if [[ "\${PROTON_FORCE_GCC:-}" == 1 ]]; then exec /usr/bin/ld ${_opt[2]} "\$@"; fi
exec ld.lld ${_opt[2]} "\$@"
EOF
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-pc-linux-gnu-as <<EOF
#!/usr/bin/bash
if [[ "\${PROTON_FORCE_GCC:-}" == 1 ]]; then exec /usr/bin/as ${_opt[3]} "\$@"; fi
exec clang -c ${_opt[1]} "\$@"
EOF
    done
}

prepare() {

    # Provide wrappers to compiler tools
    rm -rf wrappers && mkdir wrappers
    _make_wrappers

    [ ! -d build ] && mkdir build

    cd proton-cachyos

    patch -p1 -i "$srcdir"/makefilein.patch
    patch -p1 -i "$srcdir"/makefilein-0002-protonfixes-do-not-set-ld-to-gcc.patch

    [ ! -d contrib ] && mkdir -p contrib
    mv "$srcdir"/wine-gecko-${_geckover}-x86{,_64}.tar.xz contrib/
    mv "$srcdir"/wine-mono-${_monover}-x86.tar.xz contrib/
    mv "$srcdir"/xalia-${_xaliaver}-net48-mono.zip contrib/

    _submodules=(
        dav1d
        dxvk
        ffmpeg
        fonts/liberation-fonts
        glslang
        graphene
        gst-orc
        gst-plugins-rs
        gstreamer
        libsoup
        meson
        openvr
        OpenXR-SDK
        protonfixes
        SPIRV-Headers
        steamrtdeps/flac
        steamrtdeps/libpcap
        steamrtdeps/libwebp
        steamrtdeps/libxkbcommon
        steamrtdeps/libxml2
        steamrtdeps/pipewire
        steamrtdeps/speex
        steamrtdeps/speexdsp
        steamrtdeps/wayland-protocols
        steamrtdeps/xz
        vkd3d
        vkd3d-proton
        Vulkan-Headers
        wine
    )

    # Explicitly set origin URL for submodules using relative paths
    git remote set-url origin https://github.com/CachyOS/proton-cachyos.git
    git submodule update --init --filter=tree:0 --recursive ${_submodules[@]}

    # Build the latest verified dxvk-git/vkd3d-proton-git revisions instead of the Proton-pinned submodule SHAs.
    # These commits were validated with the local patch stacks on 2026-06-18.
    git -C dxvk remote set-url origin https://github.com/doitsujin/dxvk.git
    git -C dxvk fetch --depth=1 origin "${_dxvk_commit}"
    git -C dxvk checkout --detach "${_dxvk_commit}"
    git -C dxvk submodule update --init --filter=tree:0 --recursive

    git -C vkd3d-proton remote set-url origin https://github.com/HansKristian-Work/vkd3d-proton.git
    git -C vkd3d-proton fetch --depth=1 origin "${_vkd3d_proton_commit}"
    git -C vkd3d-proton checkout --detach "${_vkd3d_proton_commit}"
    git -C vkd3d-proton submodule update --init --filter=tree:0 --recursive

    # The bundled libmspack package builds noinst examples/tests by default;
    # only its runtime library is packaged and needed by protonfixes.
    patch -d protonfixes -p1 -i "$srcdir/protonfixes-0001-build-only-libmspack-library.patch"

    # Apply local DXVK/vkd3d-proton patch stacks used by the standalone llvm-mingw packages.
    local _patch
    for _patch in \
        dxvk-0001-build-use-llvm-mingw-cross-files-and-allow-AVX-nativ.patch \
        dxvk-0002-dxvk-add-async-GPL-compilation-and-GPL-async-cache.patch \
        dxvk-0003-dxvk-rebase-ms178-safe-hot-path-optimizations.patch \
        dxvk-0004-dxvk-apply-Intel-performance-pattern-optimizations.patch \
        dxvk-0005-util-add-AVX2-fast-paths-for-bit-utilities.patch; do
        patch -d dxvk -p1 -i "$srcdir/${_patch}"
    done

    for _patch in \
        vkd3d-proton-0001-build-use-llvm-mingw-cross-files-with-flag-placehold.patch \
        vkd3d-proton-0002-vkd3d-harden-device-and-command-hot-paths.patch \
        vkd3d-proton-0003-vkd3d-optimize-and-harden-pipeline-cache-helpers.patch \
        vkd3d-proton-0004-vkd3d-shader-cache-override-and-dump-paths-safely.patch \
        vkd3d-proton-0005-vkd3d-apply-broader-Intel-pattern-hot-path-fixes.patch; do
        patch -d vkd3d-proton -p1 -i "$srcdir/${_patch}"
    done

    for rustlib in gst-plugins-rs; do
    pushd $rustlib
        export RUSTUP_TOOLCHAIN=stable
        export CARGO_HOME="${SRCDEST}"/proton-cargo
        export CARGO_NET_GIT_FETCH_WITH_CLI=true
        cargo fetch --locked --target i686-unknown-linux-gnu
        cargo fetch --locked --target x86_64-unknown-linux-gnu
    popd
    done
}

build() {
    local -a _toolchain_path=()
    [[ -d /home/marcus/toolchain/llvm-ultimate/bin ]] && _toolchain_path+=(/home/marcus/toolchain/llvm-ultimate/bin)
    [[ -d /opt/llvm-mingw/bin ]] && _toolchain_path+=(/opt/llvm-mingw/bin)
    _toolchain_path+=("$(pwd)/wrappers")
    export PATH="$(IFS=:; echo "${_toolchain_path[*]}"):$PATH"

    local -a split=($CFLAGS)
    local -A flags
    for opt in "${split[@]}"; do flags["${opt%%=*}"]="${opt##*=}"; done
    local march="native"
    local mtune="native"

    CFLAGS="-O3 -march=${march} -mtune=${mtune}"
    CXXFLAGS="-O3 -march=${march} -mtune=${mtune}"
    RUSTFLAGS="-C opt-level=3 -C target-cpu=${march}"
    LDFLAGS="-Wl,-O2,--sort-common,--as-needed"

    export CFLAGS CXXFLAGS RUSTFLAGS LDFLAGS

    export RUSTUP_TOOLCHAIN=stable
    export CARGO_HOME="${SRCDEST}"/proton-cargo

    cd build
    ROOTLESS_CONTAINER="" \
    ../proton-cachyos/configure.sh \
        --container-engine="none" \
        --proton-sdk-image="" \
        --build-name="${pkgname}" \
        --without-steamrt-depends \
        --without-nvidia-libs \
        --without-vklayers=all \
        --without-extras=discord-rpc-bridge \
        --without-tts

    SUBJOBS=$([[ "$MAKEFLAGS" =~ -j\ *([1-9][0-9]*) ]] && echo "${BASH_REMATCH[1]}" || echo "$(nproc)") \
        make -j1 dist

    cd dist
    sed -r \
      -e "s|##INSTALL_PATH##|.|" \
      -e "s|##DISPLAY_NAME##|proton-cachyos-${_srctag} (native)|" \
      -e "s|##INTERNAL_TOOL_NAME##|${pkgname}|" \
      "${srcdir}/compatibilitytool.vdf.template" > compatibilitytool.vdf
}

package() {
    # build() prepends custom LLVM toolchains to PATH and those exports persist
    # into package(). Packaging must use system tools, not llvm-mingw's prefixed
    # strip binaries, otherwise prebuilt PE payloads can be mis-handled.
    export PATH=/usr/bin:/bin

    cd build

    # Delete the intermediate build directories to free space (mostly for my github actions)
    rm -rf dst-* obj-* src-* pfx-*

    local _compatdir="${pkgdir}/usr/share/steam/compatibilitytools.d"
    mkdir -p "${_compatdir}/${pkgname}"
    rsync --delete -arx dist/* "${_compatdir}/${pkgname}"

    mkdir -p "${pkgdir}/usr/share/licenses/${pkgname}"
    mv "${_compatdir}/${pkgname}"/{PATENTS.AV1,LICENSE{,.OFL}} \
        "${pkgdir}/usr/share/licenses/${pkgname}"

    # Load ntsync module
    install -Dm644 "$srcdir/ntsync.conf" "$pkgdir/usr/lib/modules-load.d/10-$pkgname.conf"
    # Leave upstream prebuilt PE/CLR payloads (wine-gecko, wine-mono, etc.)
    # untouched. Stripping them provides no runtime benefit, only minor size
    # savings, but is fragile across binutils/llvm-mingw tool variants and has
    # already broken package() multiple times. `!pestrip` above prevents makepkg
    # from reintroducing blanket PE stripping.
}


