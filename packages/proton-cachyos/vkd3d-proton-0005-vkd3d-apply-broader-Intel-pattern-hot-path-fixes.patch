From 68fdda8ae6c4318384288742f3f2c5f9faa93cc4 Mon Sep 17 00:00:00 2001
From: Arena Agent <agent@example.invalid>
Date: Wed, 17 Jun 2026 14:22:50 +0000
Subject: [PATCH] vkd3d: apply broader Intel-pattern hot-path fixes

---
 include/private/copy_utils.h   | 33 ++++++++++++++++++++++++++++++---
 include/private/vkd3d_common.h | 13 ++-----------
 libs/vkd3d/command.c           |  7 ++++---
 libs/vkd3d/memory.c            |  4 ++--
 4 files changed, 38 insertions(+), 19 deletions(-)

diff --git a/include/private/copy_utils.h b/include/private/copy_utils.h
index e199258..9deffae 100644
--- a/include/private/copy_utils.h
+++ b/include/private/copy_utils.h
@@ -19,12 +19,30 @@
 #ifndef __VKD3D_COPY_UTILS_H
 #define __VKD3D_COPY_UTILS_H
 
-#ifdef __SSE2__
+#ifdef __AVX2__
+#include <immintrin.h>
+#elif defined(__SSE2__)
 #include <emmintrin.h>
 #endif
 #include <stdint.h>
 #include <memory.h>
 
+#ifdef __AVX2__
+#define vkd3d_memcpy_aligned_64_cached(dst, src) do { \
+    __m256i a, b; \
+    a = _mm256_loadu_si256((const __m256i *)(const void *)(src) + 0); \
+    b = _mm256_loadu_si256((const __m256i *)(const void *)(src) + 1); \
+    _mm256_storeu_si256((__m256i *)(void *)(dst) + 0, a); \
+    _mm256_storeu_si256((__m256i *)(void *)(dst) + 1, b); \
+} while(0)
+
+#define vkd3d_memcpy_aligned_32_cached(dst, src) do { \
+    __m256i a; \
+    a = _mm256_loadu_si256((const __m256i *)(const void *)(src)); \
+    _mm256_storeu_si256((__m256i *)(void *)(dst), a); \
+} while(0)
+#endif
+
 #ifdef __SSE2__
 
 #define vkd3d_memcpy_aligned_64_non_temporal(dst, src) do { \
@@ -53,6 +71,7 @@
     _mm_stream_si128((__m128i *)(dst), a); \
 } while(0)
 
+#ifndef vkd3d_memcpy_aligned_64_cached
 #define vkd3d_memcpy_aligned_64_cached(dst, src) do { \
     __m128i a, b, c, d; \
     a = _mm_load_si128((const __m128i *)(src) + 0); \
@@ -64,7 +83,9 @@
     _mm_store_si128((__m128i *)(dst) + 2, c); \
     _mm_store_si128((__m128i *)(dst) + 3, d); \
 } while(0)
+#endif
 
+#ifndef vkd3d_memcpy_aligned_32_cached
 #define vkd3d_memcpy_aligned_32_cached(dst, src) do { \
     __m128i a, b; \
     a = _mm_load_si128((const __m128i *)(src) + 0); \
@@ -72,6 +93,7 @@
     _mm_store_si128((__m128i *)(dst) + 0, a); \
     _mm_store_si128((__m128i *)(dst) + 1, b); \
 } while(0)
+#endif
 
 #define vkd3d_memcpy_aligned_16_cached(dst, src) do { \
     __m128i a; \
@@ -93,9 +115,14 @@ static inline void vkd3d_memcpy_aligned_cached(void *dst_, const void *src_, siz
 {
     const uint8_t *src = src_;
     uint8_t *dst = dst_;
-    size_t i;
+    size_t i = 0;
 
-    for (i = 0; i < size; i += 16)
+#ifdef __AVX2__
+    for (; i + 32 <= size; i += 32)
+        vkd3d_memcpy_aligned_32_cached(dst + i, src + i);
+#endif
+
+    for (; i < size; i += 16)
         vkd3d_memcpy_aligned_16_cached(dst + i, src + i);
 }
 
diff --git a/include/private/vkd3d_common.h b/include/private/vkd3d_common.h
index d6035b9..15c1b07 100644
--- a/include/private/vkd3d_common.h
+++ b/include/private/vkd3d_common.h
@@ -89,17 +89,8 @@ static inline unsigned int vkd3d_popcount(unsigned int v)
 
 static inline bool vkd3d_bitmask_is_contiguous(unsigned int mask)
 {
-    unsigned int i, j;
-
-    for (i = 0, j = 0; i < sizeof(mask) * CHAR_BIT; ++i)
-    {
-        if (mask & (1u << i))
-            ++j;
-        else if (j)
-            break;
-    }
-
-    return vkd3d_popcount(mask) == j;
+    unsigned int lowbit = mask & (~mask + 1u);
+    return !(mask & (mask + lowbit));
 }
 
 /* Returns 64 for mask == 0 */
diff --git a/libs/vkd3d/command.c b/libs/vkd3d/command.c
index 13fb52f..89c3dce 100644
--- a/libs/vkd3d/command.c
+++ b/libs/vkd3d/command.c
@@ -807,8 +807,8 @@ HRESULT vkd3d_enqueue_timeline_semaphore(struct vkd3d_fence_worker *worker,
         memset(&waiting_fence->timeline_cookie, 0, sizeof(waiting_fence->timeline_cookie));
     ++worker->enqueued_fence_count;
 
-    pthread_cond_signal(&worker->cond);
     pthread_mutex_unlock(&worker->mutex);
+    pthread_cond_signal(&worker->cond);
     return S_OK;
 }
 
@@ -1018,8 +1018,8 @@ static HRESULT vkd3d_fence_worker_stop(struct vkd3d_fence_worker *worker,
     }
 
     worker->should_exit = true;
-    pthread_cond_signal(&worker->cond);
     pthread_mutex_unlock(&worker->mutex);
+    pthread_cond_signal(&worker->cond);
     pthread_join(worker->thread, NULL);
 
     pthread_mutex_destroy(&worker->mutex);
@@ -25120,7 +25120,6 @@ void d3d12_command_queue_add_submission_locked(struct d3d12_command_queue *queue
     vkd3d_array_reserve((void**)&queue->submissions, &queue->submissions_size,
                         queue->submissions_count + 1, sizeof(*queue->submissions));
     queue->submissions[queue->submissions_count++] = *sub;
-    pthread_cond_signal(&queue->queue_cond);
 }
 
 static void d3d12_command_queue_add_submission(struct d3d12_command_queue *queue,
@@ -25134,6 +25133,7 @@ static void d3d12_command_queue_add_submission(struct d3d12_command_queue *queue
     pthread_mutex_lock(&queue->queue_lock);
     d3d12_command_queue_add_submission_locked(queue, sub);
     pthread_mutex_unlock(&queue->queue_lock);
+    pthread_cond_signal(&queue->queue_cond);
 }
 
 static void d3d12_command_queue_acquire_serialized(struct d3d12_command_queue *queue)
@@ -25149,6 +25149,7 @@ static void d3d12_command_queue_acquire_serialized(struct d3d12_command_queue *q
 
     current_drain = ++queue->drain_count;
     d3d12_command_queue_add_submission_locked(queue, &sub);
+    pthread_cond_signal(&queue->queue_cond);
 
     while (current_drain > queue->queue_drain_count)
         pthread_cond_wait(&queue->queue_cond, &queue->queue_lock);
diff --git a/libs/vkd3d/memory.c b/libs/vkd3d/memory.c
index 2ff9904..b2a9de3 100644
--- a/libs/vkd3d/memory.c
+++ b/libs/vkd3d/memory.c
@@ -106,8 +106,6 @@ static void vkd3d_memory_transfer_queue_track_resource_locked(struct vkd3d_memor
     entry = &queue->tracked_resources[queue->tracked_resource_count++];
     entry->resource = resource;
     entry->semaphore_value = semaphore_value;
-
-    pthread_cond_signal(&queue->cond);
 }
 
 void vkd3d_memory_transfer_queue_cleanup(struct vkd3d_memory_transfer_queue *queue)
@@ -117,6 +115,7 @@ void vkd3d_memory_transfer_queue_cleanup(struct vkd3d_memory_transfer_queue *que
     pthread_mutex_lock(&queue->mutex);
     vkd3d_memory_transfer_queue_track_resource_locked(queue, NULL, 0);
     pthread_mutex_unlock(&queue->mutex);
+    pthread_cond_signal(&queue->cond);
 
     pthread_join(queue->thread, NULL);
 
@@ -415,6 +414,7 @@ static HRESULT vkd3d_memory_transfer_queue_flush_locked(struct vkd3d_memory_tran
 
                 vkd3d_memory_transfer_queue_track_resource_locked(queue,
                         transfer->resource, queue->next_signal_value);
+                pthread_cond_signal(&queue->cond);
                 break;
 
             case VKD3D_MEMORY_TRANSFER_OP_BUILD_NULL_RTAS:
-- 
