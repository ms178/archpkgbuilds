diff --git a/components/viz/service/display/display.cc b/components/viz/service/display/display.cc
index 0912b4b..ed20116 100644
--- a/components/viz/service/display/display.cc
+++ b/components/viz/service/display/display.cc
@@ -268,8 +268,14 @@ void Display::PresentationGroupTiming::OnSwap(gfx::SwapTimings timings,
 
   auto frame_latency = timings.swap_start - frame_time_;
   if (frame_latency < base::Seconds(0)) {
-    LOG(ERROR) << "Frame latency is negative: "
-               << frame_latency.InMillisecondsF() << " ms";
+    // chromium-raptorlake: tiny sub-millisecond negative latencies are benign
+    // clock-domain jitter between swap_start and frame_time_, not real errors.
+    // Logging them at ERROR floods the log (see countless display.cc:273 spam).
+    // Only surface genuinely large negatives, and at a non-spammy level.
+    if (frame_latency < base::Milliseconds(-1)) {
+      DLOG(WARNING) << "Frame latency is negative: "
+                    << frame_latency.InMillisecondsF() << " ms";
+    }
     return;
   }
   // Can be nullptr in unittests.
